#![allow(clippy::unwrap_used, clippy::expect_used, clippy::panic)]
//! Three-layer test coverage for the {{ pack_id }} pack.
//! Generated by ggen-pack-contrib.
//!
//! Layer 1 — Manifest validity
//! Layer 2 — Render correctness (one test per template)
//! Layer 3 — Compilation proof (ignored by default)

use std::path::PathBuf;
use tera::{Context, Tera};

fn workspace_root() -> PathBuf {
    let mut root = PathBuf::from(env!("CARGO_MANIFEST_DIR"));
    root.pop();
    root.pop();
    root
}

fn pack_path(name: &str) -> PathBuf {
    workspace_root().join("marketplace").join("packs").join(name)
}

fn template_path(name: &str) -> PathBuf {
    workspace_root().join("marketplace").join("templates").join(name)
}

fn render_template(path: &PathBuf, vars: &[(&str, &str)]) -> String {
    let content = std::fs::read_to_string(path)
        .unwrap_or_else(|e| panic!("cannot read {}: {}", path.display(), e));
    let mut tera = Tera::default();
    tera.add_raw_template("t", &content).unwrap();
    let mut ctx = Context::new();
    for (k, v) in vars {
        ctx.insert(*k, *v);
    }
    tera.render("t", &ctx)
        .unwrap_or_else(|e| panic!("tera render failed for {}: {}", path.display(), e))
}

// ---------------------------------------------------------------------------
// Layer 1 — Manifest validity
// ---------------------------------------------------------------------------

#[test]
fn test_{{ pack_id | replace(from="-", to="_") }}_pack_manifest_loads() {
    let path = pack_path("{{ pack_id }}.toml");
    assert!(path.exists(), "{{ pack_id }}.toml not found at {}", path.display());

    let toml_str = std::fs::read_to_string(&path).unwrap();
    let val: toml::Value = toml::from_str(&toml_str)
        .unwrap_or_else(|e| panic!("{{ pack_id }}.toml parse error: {}", e));

    let pack = &val["pack"];
    assert_eq!(pack["id"].as_str().unwrap(), "{{ pack_id }}");
    assert_eq!(pack["version"].as_str().unwrap(), "{{ pack_version }}");

    // All declared template paths must exist on disk
    if let Some(templates) = pack.get("templates").and_then(|t| t.as_array()) {
        for t in templates {
            let rel = t["path"].as_str().unwrap();
            let full = workspace_root().join("marketplace").join(rel);
            assert!(full.exists(), "template path not found: {}", rel);
        }
    }
}

// ---------------------------------------------------------------------------
// Layer 2 — Render correctness
// ---------------------------------------------------------------------------

{% set forbidden_ns = "tower_lsp" ~ "_max" %}
{% for name in template_names %}
#[test]
fn test_{{ name | replace(from="-", to="_") }}_template_renders() {
    let path = template_path("{{ pack_id }}/{{ name }}.tera");
    // TODO: replace stub vars with real representative values for this template
    let out = render_template(&path, &[
        ("pack_id", "{{ pack_id }}"),
        ("template_name", "{{ name }}"),
    ]);
    assert!(!out.contains("{{"), "unrendered Tera markers remain in {{ name }}.tera");
    assert!(!out.contains("{{ forbidden_ns }}"), "forbidden pre-fork namespace reference in {{ name }}.tera");
}
{% endfor %}

// ---------------------------------------------------------------------------
// Layer 3 — Compilation proof
// ---------------------------------------------------------------------------

#[test]
#[ignore = "requires crates.io network + cargo toolchain; run with --include-ignored"]
fn test_{{ pack_id | replace(from="-", to="_") }}_scaffold_compiles() {
    use tempfile::TempDir;
    let tmp = TempDir::new().unwrap();
    let src = tmp.path().join("src");
    std::fs::create_dir_all(&src).unwrap();

    // TODO: render your templates here and write them to src/
    // Then fill in Cargo.toml with the correct dependencies.

    std::fs::write(tmp.path().join("Cargo.toml"), r#"
[package]
name = "{{ pack_id }}-scaffold-test"
version = "0.1.0"
edition = "2021"

[dependencies]
# TODO: add your pack's dependencies
lsp-max = "{{ pack_version }}"
"#).unwrap();

    let output = std::process::Command::new("cargo")
        .args(["check", "--message-format=short"])
        .current_dir(tmp.path())
        .output()
        .expect("cargo check failed to spawn");

    assert!(
        output.status.success(),
        "scaffold cargo check REFUSED:
{}",
        String::from_utf8_lossy(&output.stderr)
    );
}
