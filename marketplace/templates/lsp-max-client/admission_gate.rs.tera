use lsp_max::max_protocol::LawAxis;

/// CI release gate. Returns Ok(()) if axis is Admitted.
/// If strict=true, Unknown also blocks (returns Err).
pub async fn check_admission_gate(
    tx: &mut (impl tokio::io::AsyncWrite + Unpin),
    rx: &mut (impl tokio::io::AsyncRead + Unpin),
    axis: LawAxis,
    strict: bool,
) -> Result<(), String> {
    write_lsp_msg(tx, serde_json::json!({
        "jsonrpc": "2.0",
        "id": 1,
        "method": "max/admission",
        "params": serde_json::to_value(&axis).unwrap()
    }))
    .await;
    let resp = read_lsp_response(rx, 1).await;
    let result = &resp["result"];

    match result["status"].as_str() {
        Some("Admitted") => Ok(()),
        Some("Refused") => Err(format!(
            "REFUSED: {:?} — {}",
            axis,
            result["rationale"].as_str().unwrap_or("no rationale")
        )),
        Some("Unknown") if strict => Err(format!(
            "BLOCKED: {:?} status Unknown in strict mode",
            axis
        )),
        _ => Ok(()),
    }
}
