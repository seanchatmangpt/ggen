@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mcpp: <http://mcpp.io/ontology/database#> .
@prefix blog: <http://example.com/blog#> .

# ============================================================================
# Example: Blog Application Database Schema
# Demonstrates users, posts, comments, tags, and full-text search
# ============================================================================

# ----------------------------------------------------------------------------
# Database Definition
# ----------------------------------------------------------------------------

blog:BlogDatabase a mcpp:Database ;
    mcpp:databaseName "blog_production" ;
    mcpp:databaseEngine "postgresql" ;
    mcpp:characterSet "UTF8" ;
    mcpp:collation "en_US.UTF-8" ;
    mcpp:hasTable blog:UsersTable, blog:PostsTable, blog:CommentsTable, blog:TagsTable, blog:PostTagsTable .

# ----------------------------------------------------------------------------
# Users Table
# ----------------------------------------------------------------------------

blog:UsersTable a mcpp:Table ;
    mcpp:tableName "users" ;
    mcpp:tableComment "Blog users with authentication" ;
    mcpp:hasColumn blog:UserId, blog:UserEmail, blog:UserUsername, blog:UserPasswordHash, blog:UserCreatedAt, blog:UserUpdatedAt ;
    mcpp:hasConstraint blog:UsersPK, blog:UsersEmailUnique, blog:UsersUsernameUnique ;
    mcpp:hasIndex blog:UsersEmailIndex, blog:UsersUsernameIndex .

blog:UserId a mcpp:Column ;
    mcpp:columnName "id" ;
    mcpp:hasDataType blog:SerialType ;
    mcpp:isAutoIncrement true ;
    mcpp:isNullable false ;
    mcpp:columnComment "Primary key" ;
    mcpp:columnOrder 1 .

blog:UserEmail a mcpp:Column ;
    mcpp:columnName "email" ;
    mcpp:hasDataType blog:VarcharType ;
    mcpp:maxLength 255 ;
    mcpp:isNullable false ;
    mcpp:columnComment "User email address" ;
    mcpp:columnOrder 2 .

blog:UserUsername a mcpp:Column ;
    mcpp:columnName "username" ;
    mcpp:hasDataType blog:VarcharType ;
    mcpp:maxLength 100 ;
    mcpp:isNullable false ;
    mcpp:columnComment "Unique username" ;
    mcpp:columnOrder 3 .

blog:UserPasswordHash a mcpp:Column ;
    mcpp:columnName "password_hash" ;
    mcpp:hasDataType blog:VarcharType ;
    mcpp:maxLength 255 ;
    mcpp:isNullable false ;
    mcpp:columnComment "Bcrypt password hash" ;
    mcpp:columnOrder 4 .

blog:UserCreatedAt a mcpp:Column ;
    mcpp:columnName "created_at" ;
    mcpp:hasDataType blog:TimestampType ;
    mcpp:isNullable false ;
    mcpp:defaultValue "CURRENT_TIMESTAMP" ;
    mcpp:columnOrder 5 .

blog:UserUpdatedAt a mcpp:Column ;
    mcpp:columnName "updated_at" ;
    mcpp:hasDataType blog:TimestampType ;
    mcpp:isNullable false ;
    mcpp:defaultValue "CURRENT_TIMESTAMP" ;
    mcpp:columnOrder 6 .

blog:UsersPK a mcpp:PrimaryKey ;
    mcpp:constraintName "users_pkey" ;
    mcpp:constrainsColumn blog:UserId .

blog:UsersEmailUnique a mcpp:UniqueConstraint ;
    mcpp:constraintName "users_email_unique" ;
    mcpp:constrainsColumn blog:UserEmail .

blog:UsersUsernameUnique a mcpp:UniqueConstraint ;
    mcpp:constraintName "users_username_unique" ;
    mcpp:constrainsColumn blog:UserUsername .

blog:UsersEmailIndex a mcpp:BTreeIndex ;
    mcpp:indexName "idx_users_email" ;
    mcpp:indexesColumn blog:UserEmail .

blog:UsersUsernameIndex a mcpp:BTreeIndex ;
    mcpp:indexName "idx_users_username" ;
    mcpp:indexesColumn blog:UserUsername .

# ----------------------------------------------------------------------------
# Posts Table
# ----------------------------------------------------------------------------

blog:PostsTable a mcpp:Table ;
    mcpp:tableName "posts" ;
    mcpp:tableComment "Blog posts with full-text search" ;
    mcpp:hasColumn blog:PostId, blog:PostUserId, blog:PostTitle, blog:PostSlug, blog:PostContent, blog:PostMetadata, blog:PostPublishedAt, blog:PostCreatedAt, blog:PostUpdatedAt ;
    mcpp:hasConstraint blog:PostsPK, blog:PostsSlugUnique, blog:PostsUserFK ;
    mcpp:hasIndex blog:PostsUserIdIndex, blog:PostsSlugIndex, blog:PostsPublishedAtIndex, blog:PostsSearchIndex, blog:PostsMetadataIndex .

blog:PostId a mcpp:Column ;
    mcpp:columnName "id" ;
    mcpp:hasDataType blog:SerialType ;
    mcpp:isAutoIncrement true ;
    mcpp:isNullable false ;
    mcpp:columnOrder 1 .

blog:PostUserId a mcpp:Column ;
    mcpp:columnName "user_id" ;
    mcpp:hasDataType blog:IntegerType ;
    mcpp:isNullable false ;
    mcpp:columnComment "Author user ID" ;
    mcpp:columnOrder 2 .

blog:PostTitle a mcpp:Column ;
    mcpp:columnName "title" ;
    mcpp:hasDataType blog:VarcharType ;
    mcpp:maxLength 255 ;
    mcpp:isNullable false ;
    mcpp:columnOrder 3 .

blog:PostSlug a mcpp:Column ;
    mcpp:columnName "slug" ;
    mcpp:hasDataType blog:VarcharType ;
    mcpp:maxLength 255 ;
    mcpp:isNullable false ;
    mcpp:columnComment "URL-friendly slug" ;
    mcpp:columnOrder 4 .

blog:PostContent a mcpp:Column ;
    mcpp:columnName "content" ;
    mcpp:hasDataType blog:TextType ;
    mcpp:isNullable false ;
    mcpp:columnOrder 5 .

blog:PostMetadata a mcpp:Column ;
    mcpp:columnName "metadata" ;
    mcpp:hasDataType blog:JsonbType ;
    mcpp:isNullable true ;
    mcpp:columnComment "JSON metadata (tags, SEO, etc.)" ;
    mcpp:columnOrder 6 .

blog:PostPublishedAt a mcpp:Column ;
    mcpp:columnName "published_at" ;
    mcpp:hasDataType blog:TimestampType ;
    mcpp:isNullable true ;
    mcpp:columnOrder 7 .

blog:PostCreatedAt a mcpp:Column ;
    mcpp:columnName "created_at" ;
    mcpp:hasDataType blog:TimestampType ;
    mcpp:isNullable false ;
    mcpp:defaultValue "CURRENT_TIMESTAMP" ;
    mcpp:columnOrder 8 .

blog:PostUpdatedAt a mcpp:Column ;
    mcpp:columnName "updated_at" ;
    mcpp:hasDataType blog:TimestampType ;
    mcpp:isNullable false ;
    mcpp:defaultValue "CURRENT_TIMESTAMP" ;
    mcpp:columnOrder 9 .

blog:PostsPK a mcpp:PrimaryKey ;
    mcpp:constraintName "posts_pkey" ;
    mcpp:constrainsColumn blog:PostId .

blog:PostsSlugUnique a mcpp:UniqueConstraint ;
    mcpp:constraintName "posts_slug_unique" ;
    mcpp:constrainsColumn blog:PostSlug .

blog:PostsUserFK a mcpp:ForeignKey ;
    mcpp:constraintName "posts_user_id_fkey" ;
    mcpp:constrainsColumn blog:PostUserId ;
    mcpp:referencesTable blog:UsersTable ;
    mcpp:referencesColumn blog:UserId ;
    mcpp:onDelete "CASCADE" .

blog:PostsUserIdIndex a mcpp:BTreeIndex ;
    mcpp:indexName "idx_posts_user_id" ;
    mcpp:indexesColumn blog:PostUserId .

blog:PostsSlugIndex a mcpp:BTreeIndex ;
    mcpp:indexName "idx_posts_slug" ;
    mcpp:indexesColumn blog:PostSlug .

blog:PostsPublishedAtIndex a mcpp:BTreeIndex ;
    mcpp:indexName "idx_posts_published_at" ;
    mcpp:indexesColumn blog:PostPublishedAt .

blog:PostsSearchIndex a mcpp:FullTextIndex ;
    mcpp:indexName "idx_posts_search" ;
    mcpp:indexesColumn blog:PostTitle, blog:PostContent .

blog:PostsMetadataIndex a mcpp:GINIndex ;
    mcpp:indexName "idx_posts_metadata" ;
    mcpp:indexesColumn blog:PostMetadata .

# ----------------------------------------------------------------------------
# Comments Table
# ----------------------------------------------------------------------------

blog:CommentsTable a mcpp:Table ;
    mcpp:tableName "comments" ;
    mcpp:tableComment "User comments on posts" ;
    mcpp:hasColumn blog:CommentId, blog:CommentPostId, blog:CommentUserId, blog:CommentContent, blog:CommentCreatedAt ;
    mcpp:hasConstraint blog:CommentsPK, blog:CommentsPostFK, blog:CommentsUserFK ;
    mcpp:hasIndex blog:CommentsPostIdIndex, blog:CommentsUserIdIndex .

blog:CommentId a mcpp:Column ;
    mcpp:columnName "id" ;
    mcpp:hasDataType blog:SerialType ;
    mcpp:isAutoIncrement true ;
    mcpp:isNullable false ;
    mcpp:columnOrder 1 .

blog:CommentPostId a mcpp:Column ;
    mcpp:columnName "post_id" ;
    mcpp:hasDataType blog:IntegerType ;
    mcpp:isNullable false ;
    mcpp:columnOrder 2 .

blog:CommentUserId a mcpp:Column ;
    mcpp:columnName "user_id" ;
    mcpp:hasDataType blog:IntegerType ;
    mcpp:isNullable false ;
    mcpp:columnOrder 3 .

blog:CommentContent a mcpp:Column ;
    mcpp:columnName "content" ;
    mcpp:hasDataType blog:TextType ;
    mcpp:isNullable false ;
    mcpp:columnOrder 4 .

blog:CommentCreatedAt a mcpp:Column ;
    mcpp:columnName "created_at" ;
    mcpp:hasDataType blog:TimestampType ;
    mcpp:isNullable false ;
    mcpp:defaultValue "CURRENT_TIMESTAMP" ;
    mcpp:columnOrder 5 .

blog:CommentsPK a mcpp:PrimaryKey ;
    mcpp:constraintName "comments_pkey" ;
    mcpp:constrainsColumn blog:CommentId .

blog:CommentsPostFK a mcpp:ForeignKey ;
    mcpp:constraintName "comments_post_id_fkey" ;
    mcpp:constrainsColumn blog:CommentPostId ;
    mcpp:referencesTable blog:PostsTable ;
    mcpp:referencesColumn blog:PostId ;
    mcpp:onDelete "CASCADE" .

blog:CommentsUserFK a mcpp:ForeignKey ;
    mcpp:constraintName "comments_user_id_fkey" ;
    mcpp:constrainsColumn blog:CommentUserId ;
    mcpp:referencesTable blog:UsersTable ;
    mcpp:referencesColumn blog:UserId ;
    mcpp:onDelete "CASCADE" .

blog:CommentsPostIdIndex a mcpp:BTreeIndex ;
    mcpp:indexName "idx_comments_post_id" ;
    mcpp:indexesColumn blog:CommentPostId .

blog:CommentsUserIdIndex a mcpp:BTreeIndex ;
    mcpp:indexName "idx_comments_user_id" ;
    mcpp:indexesColumn blog:CommentUserId .

# ----------------------------------------------------------------------------
# Data Types
# ----------------------------------------------------------------------------

blog:SerialType a mcpp:DataType ;
    mcpp:dataTypeName "SERIAL" ;
    mcpp:postgresqlType "SERIAL" ;
    mcpp:mysqlType "INT AUTO_INCREMENT" ;
    mcpp:sqliteType "INTEGER" .

blog:IntegerType a mcpp:DataType ;
    mcpp:dataTypeName "INTEGER" ;
    mcpp:postgresqlType "INTEGER" ;
    mcpp:mysqlType "INT" ;
    mcpp:sqliteType "INTEGER" .

blog:VarcharType a mcpp:DataType ;
    mcpp:dataTypeName "VARCHAR" ;
    mcpp:postgresqlType "VARCHAR" ;
    mcpp:mysqlType "VARCHAR" ;
    mcpp:sqliteType "TEXT" .

blog:TextType a mcpp:DataType ;
    mcpp:dataTypeName "TEXT" ;
    mcpp:postgresqlType "TEXT" ;
    mcpp:mysqlType "TEXT" ;
    mcpp:sqliteType "TEXT" .

blog:TimestampType a mcpp:DataType ;
    mcpp:dataTypeName "TIMESTAMP" ;
    mcpp:postgresqlType "TIMESTAMP" ;
    mcpp:mysqlType "DATETIME" ;
    mcpp:sqliteType "TEXT" .

blog:JsonbType a mcpp:DataType ;
    mcpp:dataTypeName "JSONB" ;
    mcpp:postgresqlType "JSONB" ;
    mcpp:mysqlType "JSON" ;
    mcpp:sqliteType "TEXT" .
