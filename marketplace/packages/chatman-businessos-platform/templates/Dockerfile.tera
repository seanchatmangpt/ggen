# Multi-stage Dockerfile generated by ggen from BusinessOS ontology
# Source: ontology/businessos.ttl
# Service: {{ label }}

# ─────────────────────────────────────────────────────────────────────────────
# Stage 1: Builder
# ─────────────────────────────────────────────────────────────────────────────

FROM golang:1.24-alpine as builder

LABEL maintainer="ChatmanGPT"

# Install build dependencies
RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Build application
# Service: {{ label }} ({{ language }})
# Port: {{ port }}
# Protocol: {{ protocol }}
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-w -s" \
    -a -installsuffix cgo \
    -o /app/bin/{{ service_name }} \
    ./cmd/{{ service_name }}/main.go

# ─────────────────────────────────────────────────────────────────────────────
# Stage 2: Runtime
# ─────────────────────────────────────────────────────────────────────────────

FROM alpine:latest

LABEL maintainer="ChatmanGPT" \
      version="1.0.0" \
      description="{{ label }} - BusinessOS Service"

# Install runtime dependencies
RUN apk add --no-cache ca-certificates tzdata curl

# Create app user (security best practice)
RUN addgroup -g 1000 -S appgroup && \
    adduser -u 1000 -S appuser -G appgroup

WORKDIR /home/appuser

# Copy binary from builder
COPY --from=builder --chown=appuser:appgroup /app/bin/{{ service_name }} ./bin/{{ service_name }}

# Copy configuration (if exists)
COPY --chown=appuser:appgroup ./config ./config

# Switch to app user
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:{{ port }}/health || exit 1

# Expose port
EXPOSE {{ port }}

# Environment variables
ENV SERVICE_NAME="{{ service_name }}" \
    SERVICE_PORT="{{ port }}" \
    SERVICE_PROTOCOL="{{ protocol }}" \
    SERVICE_LANGUAGE="{{ language }}" \
    SERVICE_FRAMEWORK="{{ framework | default(value="Gin") }}" \
    LOG_LEVEL="INFO" \
    ENVIRONMENT="production"

{%- if dependencies %}

# Dependencies (from ontology):
# {{ dependencies }}
ENV DEPENDENCIES="{{ dependencies }}"
{%- endif %}

{%- if compliance_rules %}

# Compliance requirements:
# {{ compliance_rules }}
ENV COMPLIANCE_FRAMEWORKS="{{ compliance_rules }}"
{%- endif %}

# Start service
ENTRYPOINT ["./bin/{{ service_name }}"]

# ─────────────────────────────────────────────────────────────────────────────
# Build Arguments (for build-time configuration)
# ─────────────────────────────────────────────────────────────────────────────

ARG SERVICE_VERSION="1.0.0"
ARG BUILD_DATE
ARG VCS_REF

LABEL org.opencontainers.image.version="${SERVICE_VERSION}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.title="{{ label }}" \
      org.opencontainers.image.description="{{ label }} - BusinessOS microservice" \
      org.opencontainers.image.vendor="ChatmanGPT" \
      org.opencontainers.image.url="https://chatmangpt.com" \
      org.opencontainers.image.source="https://github.com/seanchatmangpt/chatmangpt"
