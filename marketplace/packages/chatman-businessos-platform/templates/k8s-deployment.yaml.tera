# Kubernetes Deployment manifest generated by ggen from BusinessOS ontology
# Source: ontology/businessos.ttl
# Service: {{ label }}
# Generated: {{ now() }}

apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ service_name }}
  namespace: businessos
  labels:
    app: {{ service_name }}
    tier: {{ service_tier | default(value="backend") }}
    version: "1.0.0"
    managed-by: ggen

spec:
  replicas: {{ replicas | default(value=3) }}

  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0

  selector:
    matchLabels:
      app: {{ service_name }}

  template:
    metadata:
      labels:
        app: {{ service_name }}
        tier: {{ service_tier | default(value="backend") }}
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "{{ port }}"
        prometheus.io/path: "/metrics"

    spec:
      serviceAccountName: {{ service_name }}
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        fsGroup: 1000

      containers:
      - name: {{ service_name }}
        image: {{ registry | default(value="ghcr.io/seanchatmangpt") }}/businessos-{{ service_name }}:latest
        imagePullPolicy: IfNotPresent

        ports:
        - name: http
          containerPort: {{ port }}
          protocol: {{ protocol | default(value="TCP") }}

        env:
        - name: SERVICE_NAME
          value: "{{ service_name }}"
        - name: SERVICE_PORT
          value: "{{ port }}"
        - name: SERVICE_PROTOCOL
          value: "{{ protocol }}"
        - name: LANGUAGE
          value: "{{ language }}"
        - name: FRAMEWORK
          value: "{{ framework | default(value="Gin") }}"
        - name: ENVIRONMENT
          value: "production"
        - name: LOG_LEVEL
          value: "INFO"

        {%- if dependencies %}
        # Dependencies
        {%- for dep in dependencies_list %}
        - name: {{ dep | uppercase }}_HOST
          value: "{{ dep }}.businessos.svc.cluster.local"
        {%- endfor %}
        {%- endif %}

        {%- if compliance_rules %}
        # Compliance Configuration
        - name: COMPLIANCE_FRAMEWORKS
          value: "{{ compliance_rules }}"
        {%- endif %}

        # Configuration from ConfigMap
        envFrom:
        - configMapRef:
            name: {{ service_name }}-config
        - secretRef:
            name: {{ service_name }}-secrets

        # Resource Limits
        resources:
          requests:
            memory: "128Mi"
            cpu: "250m"
          limits:
            memory: "512Mi"
            cpu: "1000m"

        # Startup Probe
        startupProbe:
          httpGet:
            path: /ready
            port: {{ port }}
            scheme: HTTP
          initialDelaySeconds: 5
          periodSeconds: 5
          timeoutSeconds: 3
          failureThreshold: 12  # 60 seconds

        # Liveness Probe (restart if unhealthy)
        livenessProbe:
          httpGet:
            path: /health
            port: {{ port }}
            scheme: HTTP
          initialDelaySeconds: 15
          periodSeconds: 20
          timeoutSeconds: 3
          failureThreshold: 3

        # Readiness Probe (remove from load balancing if unhealthy)
        readinessProbe:
          httpGet:
            path: /ready
            port: {{ port }}
            scheme: HTTP
          initialDelaySeconds: 5
          periodSeconds: 10
          timeoutSeconds: 3
          failureThreshold: 2

        # Volume Mounts
        volumeMounts:
        - name: config
          mountPath: /etc/config
          readOnly: true
        - name: cache
          mountPath: /tmp/cache

        # Security Context
        securityContext:
          allowPrivilegeEscalation: false
          readOnlyRootFilesystem: true
          runAsNonRoot: true
          runAsUser: 1000
          capabilities:
            drop:
            - ALL

      # Volumes
      volumes:
      - name: config
        configMap:
          name: {{ service_name }}-config
          optional: true
      - name: cache
        emptyDir: {}

      # Affinity Rules
      affinity:
        podAntiAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
          - weight: 100
            podAffinityTerm:
              labelSelector:
                matchExpressions:
                - key: app
                  operator: In
                  values:
                  - {{ service_name }}
              topologyKey: kubernetes.io/hostname

      # Termination Grace Period
      terminationGracePeriodSeconds: 30

      # Restart Policy
      restartPolicy: Always

---
# Service (ClusterIP) for internal communication
apiVersion: v1
kind: Service
metadata:
  name: {{ service_name }}
  namespace: businessos
  labels:
    app: {{ service_name }}

spec:
  type: ClusterIP
  selector:
    app: {{ service_name }}
  ports:
  - name: http
    port: {{ port }}
    targetPort: {{ port }}
    protocol: TCP

  sessionAffinity: ClientIP
  sessionAffinityConfig:
    clientIP:
      timeoutSeconds: 10800

---
# ConfigMap for service configuration
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ service_name }}-config
  namespace: businessos
  labels:
    app: {{ service_name }}

data:
  config.json: |
    {
      "service_name": "{{ service_name }}",
      "port": {{ port }},
      "protocol": "{{ protocol }}",
      "language": "{{ language }}",
      "framework": "{{ framework | default(value="Gin") }}",
      "log_level": "INFO"
    }

---
# ServiceAccount (for RBAC)
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ service_name }}
  namespace: businessos
  labels:
    app: {{ service_name }}

---
# Role (for RBAC)
apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  name: {{ service_name }}
  namespace: businessos

rules:
- apiGroups: [""]
  resources: ["configmaps"]
  verbs: ["get", "list", "watch"]
- apiGroups: [""]
  resources: ["secrets"]
  verbs: ["get"]

---
# RoleBinding (for RBAC)
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ service_name }}
  namespace: businessos

roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: Role
  name: {{ service_name }}
subjects:
- kind: ServiceAccount
  name: {{ service_name }}
  namespace: businessos
