@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mcpp: <http://mcpp.tech/ontology#> .
@prefix ms: <http://mcpp.tech/microservices#> .

# ============================================================================
# MICROSERVICES ARCHITECTURE ONTOLOGY
# Defines patterns for distributed service-oriented systems
# ============================================================================

# ----------------------------------------------------------------------------
# Core Microservice Classes
# ----------------------------------------------------------------------------

ms:Microservice a rdfs:Class ;
    rdfs:label "Microservice" ;
    rdfs:comment "Independent, deployable service with bounded context" ;
    mcpp:hasBoundedContext "true"^^xsd:boolean ;
    mcpp:isDeployable "true"^^xsd:boolean .

ms:APIGateway a rdfs:Class ;
    rdfs:subClassOf ms:Microservice ;
    rdfs:label "API Gateway" ;
    rdfs:comment "Entry point for client requests with routing and load balancing" ;
    mcpp:pattern "Gateway Pattern" ;
    mcpp:responsibility "Request routing, authentication, rate limiting" .

ms:BusinessService a rdfs:Class ;
    rdfs:subClassOf ms:Microservice ;
    rdfs:label "Business Service" ;
    rdfs:comment "Service implementing core business logic" ;
    mcpp:pattern "Domain-Driven Design" ;
    mcpp:responsibility "Business capability implementation" .

# ----------------------------------------------------------------------------
# Service Discovery
# ----------------------------------------------------------------------------

ms:ServiceDiscovery a rdfs:Class ;
    rdfs:label "Service Discovery" ;
    rdfs:comment "Dynamic service location and registration" ;
    mcpp:pattern "Service Registry Pattern" .

ms:ConsulDiscovery a rdfs:Class ;
    rdfs:subClassOf ms:ServiceDiscovery ;
    rdfs:label "Consul Service Discovery" ;
    mcpp:implementation "HashiCorp Consul" ;
    mcpp:features "DNS, HTTP API, Health Checks" ;
    mcpp:port "8500"^^xsd:integer .

ms:EtcdDiscovery a rdfs:Class ;
    rdfs:subClassOf ms:ServiceDiscovery ;
    rdfs:label "etcd Service Discovery" ;
    mcpp:implementation "CoreOS etcd" ;
    mcpp:features "Key-Value Store, Watch API" ;
    mcpp:port "2379"^^xsd:integer .

ms:DNSDiscovery a rdfs:Class ;
    rdfs:subClassOf ms:ServiceDiscovery ;
    rdfs:label "DNS-based Discovery" ;
    mcpp:implementation "DNS SRV Records" ;
    mcpp:features "Standard DNS, No dependencies" .

# ----------------------------------------------------------------------------
# Communication Patterns
# ----------------------------------------------------------------------------

ms:CommunicationPattern a rdfs:Class ;
    rdfs:label "Communication Pattern" ;
    rdfs:comment "Inter-service communication mechanism" .

ms:RESTCommunication a rdfs:Class ;
    rdfs:subClassOf ms:CommunicationPattern ;
    rdfs:label "REST API Communication" ;
    mcpp:protocol "HTTP/1.1" ;
    mcpp:contentType "application/json" ;
    mcpp:style "Request-Response" ;
    mcpp:synchronous "true"^^xsd:boolean .

ms:gRPCCommunication a rdfs:Class ;
    rdfs:subClassOf ms:CommunicationPattern ;
    rdfs:label "gRPC Communication" ;
    mcpp:protocol "HTTP/2" ;
    mcpp:serialization "Protocol Buffers" ;
    mcpp:features "Streaming, Bidirectional, Type-safe" ;
    mcpp:synchronous "true"^^xsd:boolean .

ms:MessageQueueCommunication a rdfs:Class ;
    rdfs:subClassOf ms:CommunicationPattern ;
    rdfs:label "Message Queue Communication" ;
    mcpp:pattern "Publish-Subscribe, Queue-based" ;
    mcpp:asynchronous "true"^^xsd:boolean ;
    mcpp:decoupled "true"^^xsd:boolean .

ms:RabbitMQCommunication a rdfs:Class ;
    rdfs:subClassOf ms:MessageQueueCommunication ;
    rdfs:label "RabbitMQ Messaging" ;
    mcpp:broker "RabbitMQ" ;
    mcpp:protocol "AMQP 0.9.1" ;
    mcpp:port "5672"^^xsd:integer .

ms:KafkaCommunication a rdfs:Class ;
    rdfs:subClassOf ms:MessageQueueCommunication ;
    rdfs:label "Apache Kafka Streaming" ;
    mcpp:broker "Apache Kafka" ;
    mcpp:pattern "Event Streaming" ;
    mcpp:port "9092"^^xsd:integer .

# ----------------------------------------------------------------------------
# Resilience Patterns
# ----------------------------------------------------------------------------

ms:ResiliencePattern a rdfs:Class ;
    rdfs:label "Resilience Pattern" ;
    rdfs:comment "Fault tolerance and failure handling" .

ms:CircuitBreaker a rdfs:Class ;
    rdfs:subClassOf ms:ResiliencePattern ;
    rdfs:label "Circuit Breaker" ;
    rdfs:comment "Prevents cascading failures by stopping requests to failing services" ;
    mcpp:states "Closed, Open, Half-Open" ;
    mcpp:failureThreshold "5"^^xsd:integer ;
    mcpp:timeout "60"^^xsd:integer ;
    mcpp:halfOpenRequests "3"^^xsd:integer .

ms:RetryPolicy a rdfs:Class ;
    rdfs:subClassOf ms:ResiliencePattern ;
    rdfs:label "Retry Policy" ;
    rdfs:comment "Automatic retry with exponential backoff" ;
    mcpp:maxRetries "3"^^xsd:integer ;
    mcpp:initialDelay "100"^^xsd:integer ;
    mcpp:maxDelay "5000"^^xsd:integer ;
    mcpp:backoffMultiplier "2.0"^^xsd:float .

ms:BulkheadPattern a rdfs:Class ;
    rdfs:subClassOf ms:ResiliencePattern ;
    rdfs:label "Bulkhead Isolation" ;
    rdfs:comment "Resource isolation to prevent complete system failure" ;
    mcpp:poolSize "10"^^xsd:integer ;
    mcpp:queueSize "20"^^xsd:integer .

ms:TimeoutPolicy a rdfs:Class ;
    rdfs:subClassOf ms:ResiliencePattern ;
    rdfs:label "Timeout Policy" ;
    mcpp:requestTimeout "5000"^^xsd:integer ;
    mcpp:connectionTimeout "2000"^^xsd:integer .

# ----------------------------------------------------------------------------
# Load Balancing
# ----------------------------------------------------------------------------

ms:LoadBalancer a rdfs:Class ;
    rdfs:label "Load Balancer" ;
    rdfs:comment "Distributes traffic across service instances" .

ms:RoundRobinBalancer a rdfs:Class ;
    rdfs:subClassOf ms:LoadBalancer ;
    rdfs:label "Round Robin Load Balancer" ;
    mcpp:algorithm "Round Robin" ;
    mcpp:stateless "true"^^xsd:boolean .

ms:LeastConnectionsBalancer a rdfs:Class ;
    rdfs:subClassOf ms:LoadBalancer ;
    rdfs:label "Least Connections Balancer" ;
    mcpp:algorithm "Least Active Connections" ;
    mcpp:stateful "true"^^xsd:boolean .

ms:WeightedBalancer a rdfs:Class ;
    rdfs:subClassOf ms:LoadBalancer ;
    rdfs:label "Weighted Load Balancer" ;
    mcpp:algorithm "Weighted Round Robin" ;
    mcpp:supportsWeights "true"^^xsd:boolean .

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------

ms:DistributedTracing a rdfs:Class ;
    rdfs:label "Distributed Tracing" ;
    rdfs:comment "Request tracking across service boundaries" .

ms:OpenTelemetry a rdfs:Class ;
    rdfs:subClassOf ms:DistributedTracing ;
    rdfs:label "OpenTelemetry Tracing" ;
    mcpp:vendor "CNCF OpenTelemetry" ;
    mcpp:features "Traces, Metrics, Logs" ;
    mcpp:exporters "OTLP, Jaeger, Zipkin" ;
    mcpp:samplingRate "1.0"^^xsd:float .

ms:JaegerTracing a rdfs:Class ;
    rdfs:subClassOf ms:DistributedTracing ;
    rdfs:label "Jaeger Tracing" ;
    mcpp:vendor "Uber Jaeger" ;
    mcpp:port "14268"^^xsd:integer ;
    mcpp:uiPort "16686"^^xsd:integer .

ms:HealthCheck a rdfs:Class ;
    rdfs:label "Health Check" ;
    rdfs:comment "Service health and readiness probes" .

ms:LivenessProbe a rdfs:Class ;
    rdfs:subClassOf ms:HealthCheck ;
    rdfs:label "Liveness Probe" ;
    rdfs:comment "Checks if service is running" ;
    mcpp:endpoint "/health/live" ;
    mcpp:intervalSeconds "10"^^xsd:integer ;
    mcpp:timeoutSeconds "5"^^xsd:integer .

ms:ReadinessProbe a rdfs:Class ;
    rdfs:subClassOf ms:HealthCheck ;
    rdfs:label "Readiness Probe" ;
    rdfs:comment "Checks if service can accept traffic" ;
    mcpp:endpoint "/health/ready" ;
    mcpp:intervalSeconds "5"^^xsd:integer ;
    mcpp:timeoutSeconds "3"^^xsd:integer .

ms:MetricsEndpoint a rdfs:Class ;
    rdfs:label "Metrics Endpoint" ;
    rdfs:comment "Prometheus-compatible metrics" ;
    mcpp:endpoint "/metrics" ;
    mcpp:format "prometheus" .

# ----------------------------------------------------------------------------
# Service Definitions
# ----------------------------------------------------------------------------

ms:APIGatewayService a ms:APIGateway ;
    rdfs:label "API Gateway Service" ;
    mcpp:name "api-gateway" ;
    mcpp:language "Rust" ;
    mcpp:framework "Axum" ;
    mcpp:port "8000"^^xsd:integer ;
    mcpp:hasLoadBalancer ms:RoundRobinBalancer ;
    mcpp:hasCircuitBreaker "true"^^xsd:boolean ;
    mcpp:hasTracing ms:OpenTelemetry ;
    mcpp:hasHealthCheck ms:LivenessProbe, ms:ReadinessProbe ;
    mcpp:routes "/*" ;
    mcpp:features "Authentication, Rate Limiting, Request Routing" .

ms:UserService a ms:BusinessService ;
    rdfs:label "User Service" ;
    mcpp:name "user-service" ;
    mcpp:language "TypeScript" ;
    mcpp:framework "Express" ;
    mcpp:port "8001"^^xsd:integer ;
    mcpp:database "PostgreSQL" ;
    mcpp:hasCommunication ms:RESTCommunication ;
    mcpp:hasTracing ms:OpenTelemetry ;
    mcpp:hasHealthCheck ms:LivenessProbe, ms:ReadinessProbe ;
    mcpp:endpoints "/users, /users/:id, /users/login" ;
    mcpp:boundedContext "User Management, Authentication" .

ms:ProductService a ms:BusinessService ;
    rdfs:label "Product Service" ;
    mcpp:name "product-service" ;
    mcpp:language "Python" ;
    mcpp:framework "FastAPI" ;
    mcpp:port "8002"^^xsd:integer ;
    mcpp:database "MongoDB" ;
    mcpp:hasCommunication ms:RESTCommunication ;
    mcpp:hasTracing ms:OpenTelemetry ;
    mcpp:hasHealthCheck ms:LivenessProbe, ms:ReadinessProbe ;
    mcpp:endpoints "/products, /products/:id, /products/search" ;
    mcpp:boundedContext "Product Catalog, Inventory" .

ms:OrderService a ms:BusinessService ;
    rdfs:label "Order Service" ;
    mcpp:name "order-service" ;
    mcpp:language "Rust" ;
    mcpp:framework "Axum" ;
    mcpp:port "8003"^^xsd:integer ;
    mcpp:database "PostgreSQL" ;
    mcpp:hasCommunication ms:RESTCommunication ;
    mcpp:hasMessaging ms:RabbitMQCommunication ;
    mcpp:hasTracing ms:OpenTelemetry ;
    mcpp:hasHealthCheck ms:LivenessProbe, ms:ReadinessProbe ;
    mcpp:endpoints "/orders, /orders/:id, /orders/user/:userId" ;
    mcpp:boundedContext "Order Management, Payment Processing" .

# ----------------------------------------------------------------------------
# Service Dependencies
# ----------------------------------------------------------------------------

ms:ServiceDependency a rdfs:Class ;
    rdfs:label "Service Dependency" ;
    rdfs:comment "Defines inter-service communication relationships" .

ms:GatewayToUser a ms:ServiceDependency ;
    mcpp:from ms:APIGatewayService ;
    mcpp:to ms:UserService ;
    mcpp:pattern ms:RESTCommunication ;
    mcpp:hasCircuitBreaker "true"^^xsd:boolean ;
    mcpp:hasRetry "true"^^xsd:boolean ;
    mcpp:timeout "5000"^^xsd:integer .

ms:GatewayToProduct a ms:ServiceDependency ;
    mcpp:from ms:APIGatewayService ;
    mcpp:to ms:ProductService ;
    mcpp:pattern ms:RESTCommunication ;
    mcpp:hasCircuitBreaker "true"^^xsd:boolean ;
    mcpp:hasRetry "true"^^xsd:boolean ;
    mcpp:timeout "5000"^^xsd:integer .

ms:GatewayToOrder a ms:ServiceDependency ;
    mcpp:from ms:APIGatewayService ;
    mcpp:to ms:OrderService ;
    mcpp:pattern ms:RESTCommunication ;
    mcpp:hasCircuitBreaker "true"^^xsd:boolean ;
    mcpp:hasRetry "true"^^xsd:boolean ;
    mcpp:timeout "5000"^^xsd:integer .

ms:OrderToUser a ms:ServiceDependency ;
    mcpp:from ms:OrderService ;
    mcpp:to ms:UserService ;
    mcpp:pattern ms:RESTCommunication ;
    mcpp:purpose "User validation" ;
    mcpp:hasCircuitBreaker "true"^^xsd:boolean .

ms:OrderToProduct a ms:ServiceDependency ;
    mcpp:from ms:OrderService ;
    mcpp:to ms:ProductService ;
    mcpp:pattern ms:RESTCommunication ;
    mcpp:purpose "Product availability check" ;
    mcpp:hasCircuitBreaker "true"^^xsd:boolean .

# ----------------------------------------------------------------------------
# Container Configuration
# ----------------------------------------------------------------------------

ms:ContainerConfig a rdfs:Class ;
    rdfs:label "Container Configuration" ;
    rdfs:comment "Docker container settings" .

ms:GatewayContainer a ms:ContainerConfig ;
    mcpp:service ms:APIGatewayService ;
    mcpp:image "rust:1.75-alpine" ;
    mcpp:buildContext "./api-gateway" ;
    mcpp:exposedPort "8000"^^xsd:integer ;
    mcpp:healthCheckInterval "30s" ;
    mcpp:restartPolicy "always" .

ms:UserContainer a ms:ContainerConfig ;
    mcpp:service ms:UserService ;
    mcpp:image "node:20-alpine" ;
    mcpp:buildContext "./user-service" ;
    mcpp:exposedPort "8001"^^xsd:integer ;
    mcpp:healthCheckInterval "30s" ;
    mcpp:restartPolicy "always" ;
    mcpp:dependsOn "postgres" .

ms:ProductContainer a ms:ContainerConfig ;
    mcpp:service ms:ProductService ;
    mcpp:image "python:3.11-alpine" ;
    mcpp:buildContext "./product-service" ;
    mcpp:exposedPort "8002"^^xsd:integer ;
    mcpp:healthCheckInterval "30s" ;
    mcpp:restartPolicy "always" ;
    mcpp:dependsOn "mongodb" .

ms:OrderContainer a ms:ContainerConfig ;
    mcpp:service ms:OrderService ;
    mcpp:image "rust:1.75-alpine" ;
    mcpp:buildContext "./order-service" ;
    mcpp:exposedPort "8003"^^xsd:integer ;
    mcpp:healthCheckInterval "30s" ;
    mcpp:restartPolicy "always" ;
    mcpp:dependsOn "postgres, rabbitmq" .

# ----------------------------------------------------------------------------
# Infrastructure Services
# ----------------------------------------------------------------------------

ms:InfrastructureService a rdfs:Class ;
    rdfs:label "Infrastructure Service" ;
    rdfs:comment "Supporting infrastructure components" .

ms:PostgresDB a ms:InfrastructureService ;
    rdfs:label "PostgreSQL Database" ;
    mcpp:image "postgres:15-alpine" ;
    mcpp:port "5432"^^xsd:integer ;
    mcpp:version "15" ;
    mcpp:persistence "true"^^xsd:boolean .

ms:MongoDB a ms:InfrastructureService ;
    rdfs:label "MongoDB Database" ;
    mcpp:image "mongo:7-alpine" ;
    mcpp:port "27017"^^xsd:integer ;
    mcpp:version "7" ;
    mcpp:persistence "true"^^xsd:boolean .

ms:RabbitMQ a ms:InfrastructureService ;
    rdfs:label "RabbitMQ Message Broker" ;
    mcpp:image "rabbitmq:3.12-management-alpine" ;
    mcpp:port "5672"^^xsd:integer ;
    mcpp:managementPort "15672"^^xsd:integer ;
    mcpp:version "3.12" .

ms:Jaeger a ms:InfrastructureService ;
    rdfs:label "Jaeger Tracing" ;
    mcpp:image "jaegertracing/all-in-one:1.52" ;
    mcpp:port "14268"^^xsd:integer ;
    mcpp:uiPort "16686"^^xsd:integer ;
    mcpp:otlpPort "4318"^^xsd:integer ;
    mcpp:version "1.52" .

# ----------------------------------------------------------------------------
# Kubernetes Configuration
# ----------------------------------------------------------------------------

ms:KubernetesConfig a rdfs:Class ;
    rdfs:label "Kubernetes Configuration" ;
    rdfs:comment "Kubernetes deployment settings" .

ms:Deployment a rdfs:Class ;
    rdfs:subClassOf ms:KubernetesConfig ;
    rdfs:label "Kubernetes Deployment" ;
    mcpp:apiVersion "apps/v1" ;
    mcpp:kind "Deployment" .

ms:Service a rdfs:Class ;
    rdfs:subClassOf ms:KubernetesConfig ;
    rdfs:label "Kubernetes Service" ;
    mcpp:apiVersion "v1" ;
    mcpp:kind "Service" .

ms:GatewayDeployment a ms:Deployment ;
    mcpp:name "api-gateway" ;
    mcpp:replicas "3"^^xsd:integer ;
    mcpp:container ms:GatewayContainer ;
    mcpp:resourceLimitCPU "500m" ;
    mcpp:resourceLimitMemory "512Mi" ;
    mcpp:resourceRequestCPU "250m" ;
    mcpp:resourceRequestMemory "256Mi" .

ms:GatewayK8sService a ms:Service ;
    mcpp:name "api-gateway" ;
    mcpp:type "LoadBalancer" ;
    mcpp:port "80"^^xsd:integer ;
    mcpp:targetPort "8000"^^xsd:integer ;
    mcpp:selector "api-gateway" .
