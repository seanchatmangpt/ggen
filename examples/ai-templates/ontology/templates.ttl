# Template Management System Ontology
# Demonstrates agents discovering and applying templates via MCP
# Format: RDF (Turtle)
# Schema: ggen v6 A = μ(O) pattern

@prefix tmpl: <http://ggen.dev/examples/templates#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix meta: <http://ggen.ai/ontology/meta#> .

# =============================================================================
# 1. CORE ENTITIES
# =============================================================================

tmpl:Template
  a owl:Class ;
  rdfs:label "Template"@en ;
  rdfs:comment "A reusable code/configuration template" ;
  rdfs:subClassOf meta:OntologyElement .

tmpl:TemplateRegistry
  a owl:Class ;
  rdfs:label "Template Registry"@en ;
  rdfs:comment "Central registry of available templates" ;
  rdfs:subClassOf meta:OntologyElement .

tmpl:TemplateApplication
  a owl:Class ;
  rdfs:label "Template Application"@en ;
  rdfs:comment "Application of a template with variable substitution" ;
  rdfs:subClassOf meta:OntologyElement .

tmpl:TemplateVariable
  a owl:Class ;
  rdfs:label "Template Variable"@en ;
  rdfs:comment "A variable placeholder in a template" ;
  rdfs:subClassOf meta:OntologyElement .

# =============================================================================
# 2. TEMPLATE CATEGORIES
# =============================================================================

tmpl:TemplateCategory
  a owl:Class ;
  rdfs:label "Template Category"@en ;
  rdfs:comment "Classification for templates" ;
  rdfs:subClassOf meta:OntologyElement .

tmpl:ApiController a tmpl:TemplateCategory ;
  rdfs:label "API Controller"@en ;
  rdfs:comment "REST API endpoint controller template" .

tmpl:DataModel a tmpl:TemplateCategory ;
  rdfs:label "Data Model"@en ;
  rdfs:comment "Domain model with serialization" .

tmpl:Service a tmpl:TemplateCategory ;
  rdfs:label "Service Layer"@en ;
  rdfs:comment "Business logic service template" .

tmpl:UnitTest a tmpl:TemplateCategory ;
  rdfs:label "Unit Test"@en ;
  rdfs:comment "Test template for testing" .

tmpl:Configuration a tmpl:TemplateCategory ;
  rdfs:label "Configuration"@en ;
  rdfs:comment "Configuration file template" .

tmpl:Middleware a tmpl:TemplateCategory ;
  rdfs:label "Middleware"@en ;
  rdfs:comment "Middleware/interceptor template" .

# =============================================================================
# 3. TEMPLATE DISCOVERY PATTERNS
# =============================================================================

tmpl:DiscoveryPattern
  a owl:Class ;
  rdfs:label "Discovery Pattern"@en ;
  rdfs:comment "Pattern for agents to discover templates" ;
  rdfs:subClassOf meta:OntologyElement .

tmpl:DiscoverByName a tmpl:DiscoveryPattern ;
  rdfs:label "Discover by Name"@en ;
  rdfs:comment "Find templates by exact name match" ;
  tmpl:mcp_endpoint "/mcp/tools/find_template" ;
  tmpl:discovery_param "name"^^xsd:string .

tmpl:DiscoverByCategory a tmpl:DiscoveryPattern ;
  rdfs:label "Discover by Category"@en ;
  rdfs:comment "Find templates by category" ;
  tmpl:mcp_endpoint "/mcp/tools/find_by_category" ;
  tmpl:discovery_param "category"^^xsd:string .

tmpl:DiscoverByLanguage a tmpl:DiscoveryPattern ;
  rdfs:label "Discover by Language"@en ;
  rdfs:comment "Find templates for specific language" ;
  tmpl:mcp_endpoint "/mcp/tools/find_by_language" ;
  tmpl:discovery_param "language"^^xsd:string .

tmpl:ListAllTemplates a tmpl:DiscoveryPattern ;
  rdfs:label "List All Templates"@en ;
  rdfs:comment "Enumerate all available templates" ;
  tmpl:mcp_endpoint "/mcp/tools/list_templates" .

# =============================================================================
# 4. TEMPLATE APPLICATION OPERATIONS
# =============================================================================

tmpl:ApplicationOperation
  a owl:Class ;
  rdfs:label "Application Operation"@en ;
  rdfs:comment "Operation to apply templates" ;
  rdfs:subClassOf meta:OntologyElement .

tmpl:RenderTemplate a tmpl:ApplicationOperation ;
  rdfs:label "Render Template"@en ;
  rdfs:comment "Render template with variable substitution" ;
  tmpl:mcp_endpoint "/mcp/tools/render_template" ;
  tmpl:required_params "template_name"^^xsd:string ;
  tmpl:required_params "variables"^^xsd:string .

tmpl:ValidateTemplate a tmpl:ApplicationOperation ;
  rdfs:label "Validate Template"@en ;
  rdfs:comment "Validate template syntax" ;
  tmpl:mcp_endpoint "/mcp/tools/validate_template" ;
  tmpl:required_params "template_content"^^xsd:string .

tmpl:RegisterTemplate a tmpl:ApplicationOperation ;
  rdfs:label "Register Template"@en ;
  rdfs:comment "Register new template in registry" ;
  tmpl:mcp_endpoint "/mcp/tools/register_template" ;
  tmpl:required_params "name"^^xsd:string ;
  tmpl:required_params "content"^^xsd:string ;
  tmpl:required_params "category"^^xsd:string .

tmpl:UpdateTemplate a tmpl:ApplicationOperation ;
  rdfs:label "Update Template"@en ;
  rdfs:comment "Update existing template" ;
  tmpl:mcp_endpoint "/mcp/tools/update_template" ;
  tmpl:required_params "name"^^xsd:string ;
  tmpl:required_params "new_content"^^xsd:string .

tmpl:DeleteTemplate a tmpl:ApplicationOperation ;
  rdfs:label "Delete Template"@en ;
  rdfs:comment "Remove template from registry" ;
  tmpl:mcp_endpoint "/mcp/tools/delete_template" ;
  tmpl:required_params "name"^^xsd:string .

# =============================================================================
# 5. TEMPLATE VARIABLES & VALIDATION
# =============================================================================

tmpl:VariableType
  a owl:Class ;
  rdfs:label "Variable Type"@en ;
  rdfs:comment "Type of template variable" ;
  rdfs:subClassOf meta:OntologyElement .

tmpl:StringVariable a tmpl:VariableType ;
  rdfs:label "String"@en ;
  rdfs:comment "String-type variable" .

tmpl:NumberVariable a tmpl:VariableType ;
  rdfs:label "Number"@en ;
  rdfs:comment "Numeric variable" .

tmpl:BooleanVariable a tmpl:VariableType ;
  rdfs:label "Boolean"@en ;
  rdfs:comment "Boolean flag variable" .

tmpl:ListVariable a tmpl:VariableType ;
  rdfs:label "List"@en ;
  rdfs:comment "List/array variable" .

# =============================================================================
# 6. AGENT INSTRUCTIONS FOR TEMPLATE DISCOVERY
# =============================================================================

tmpl:AgentWorkflow
  a owl:Class ;
  rdfs:label "Agent Workflow"@en ;
  rdfs:comment "Workflow instructions for agents using templates" ;
  rdfs:subClassOf meta:OntologyElement .

tmpl:workflow_discover a tmpl:AgentWorkflow ;
  rdfs:label "Discover Templates"@en ;
  rdfs:comment "Step 1: Agent queries available templates using discovery patterns" ;
  rdfs:seeAlso tmpl:DiscoveryPattern ;
  tmpl:workflow_step "1"^^xsd:integer .

tmpl:workflow_analyze a tmpl:AgentWorkflow ;
  rdfs:label "Analyze Requirements"@en ;
  rdfs:comment "Step 2: Agent analyzes task requirements" ;
  tmpl:workflow_step "2"^^xsd:integer .

tmpl:workflow_select a tmpl:AgentWorkflow ;
  rdfs:label "Select Templates"@en ;
  rdfs:comment "Step 3: Agent selects matching templates" ;
  tmpl:workflow_step "3"^^xsd:integer .

tmpl:workflow_gather_vars a tmpl:AgentWorkflow ;
  rdfs:label "Gather Variables"@en ;
  rdfs:comment "Step 4: Agent collects variable values" ;
  tmpl:workflow_step "4"^^xsd:integer .

tmpl:workflow_render a tmpl:AgentWorkflow ;
  rdfs:label "Render Templates"@en ;
  rdfs:comment "Step 5: Agent calls MCP render tool with variables" ;
  rdfs:seeAlso tmpl:RenderTemplate ;
  tmpl:workflow_step "5"^^xsd:integer .

tmpl:workflow_validate a tmpl:AgentWorkflow ;
  rdfs:label "Validate Output"@en ;
  rdfs:comment "Step 6: Agent validates rendered output" ;
  tmpl:workflow_step "6"^^xsd:integer .

# =============================================================================
# 7. CONCRETE TEMPLATE EXAMPLES
# =============================================================================

tmpl:rest_api_controller a tmpl:Template ;
  rdfs:label "REST API Controller"@en ;
  rdfs:comment "Generic REST API endpoint controller template" ;
  tmpl:hasCategory tmpl:ApiController ;
  tmpl:hasLanguage "rust" ;
  tmpl:hasFramework "actix-web" ;
  tmpl:hasVariables "endpoint_path", "resource_name", "method" ;
  tmpl:mcp_tool_path "/mcp/tools/rest_api_controller" .

tmpl:data_model_template a tmpl:Template ;
  rdfs:label "Data Model Template"@en ;
  rdfs:comment "Domain model with serialization support" ;
  tmpl:hasCategory tmpl:DataModel ;
  tmpl:hasLanguage "rust" ;
  tmpl:hasVariables "struct_name", "fields", "derives" ;
  tmpl:mcp_tool_path "/mcp/tools/data_model" .

tmpl:service_layer a tmpl:Template ;
  rdfs:label "Service Layer Template"@en ;
  rdfs:comment "Business logic service implementation" ;
  tmpl:hasCategory tmpl:Service ;
  tmpl:hasLanguage "rust" ;
  tmpl:hasVariables "service_name", "methods", "dependencies" ;
  tmpl:mcp_tool_path "/mcp/tools/service_layer" .

tmpl:unit_test_template a tmpl:Template ;
  rdfs:label "Unit Test Template"@en ;
  rdfs:comment "Unit test template for Rust" ;
  tmpl:hasCategory tmpl:UnitTest ;
  tmpl:hasLanguage "rust" ;
  tmpl:hasVariables "test_name", "assertions", "setup" ;
  tmpl:mcp_tool_path "/mcp/tools/unit_test" .

# =============================================================================
# 8. PROPERTIES
# =============================================================================

tmpl:hasCategory
  a owl:ObjectProperty ;
  rdfs:domain tmpl:Template ;
  rdfs:range tmpl:TemplateCategory ;
  rdfs:label "has category"@en .

tmpl:hasLanguage
  a owl:DatatypeProperty ;
  rdfs:domain tmpl:Template ;
  rdfs:range xsd:string ;
  rdfs:label "has programming language"@en .

tmpl:hasFramework
  a owl:DatatypeProperty ;
  rdfs:domain tmpl:Template ;
  rdfs:range xsd:string ;
  rdfs:label "has framework"@en .

tmpl:hasVariables
  a owl:DatatypeProperty ;
  rdfs:domain tmpl:Template ;
  rdfs:range xsd:string ;
  rdfs:label "has variable names"@en ;
  rdfs:comment "Comma-separated variable names" .

tmpl:mcp_tool_path
  a owl:DatatypeProperty ;
  rdfs:domain tmpl:Template ;
  rdfs:range xsd:string ;
  rdfs:label "MCP tool path"@en ;
  rdfs:comment "HTTP endpoint for MCP tool" .

tmpl:mcp_endpoint
  a owl:DatatypeProperty ;
  rdfs:domain [ a owl:Class ] ;
  rdfs:range xsd:string ;
  rdfs:label "MCP endpoint"@en ;
  rdfs:comment "HTTP endpoint for MCP operation" .

tmpl:discovery_param
  a owl:DatatypeProperty ;
  rdfs:domain tmpl:DiscoveryPattern ;
  rdfs:range xsd:string ;
  rdfs:label "discovery parameter"@en ;
  rdfs:comment "Parameter name for discovery query" .

tmpl:required_params
  a owl:DatatypeProperty ;
  rdfs:domain tmpl:ApplicationOperation ;
  rdfs:range xsd:string ;
  rdfs:label "required parameters"@en ;
  rdfs:comment "Required parameter for operation" .

tmpl:workflow_step
  a owl:DatatypeProperty ;
  rdfs:domain tmpl:AgentWorkflow ;
  rdfs:range xsd:integer ;
  rdfs:label "workflow step number"@en ;
  rdfs:comment "Order of execution in workflow" .
