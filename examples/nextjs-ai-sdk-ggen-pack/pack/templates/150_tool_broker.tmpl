import "server-only";

export type ToolExecutionContext = Readonly<{ requestId: string; userId?: string; signal?: AbortSignal }>;
export type ToolHandler = (input: unknown, context: ToolExecutionContext) => Promise<unknown>;

export class ToolRefusedError extends Error {
  readonly code = "TOOL_HANDLER_REFUSED";
  constructor(readonly handlerKey: string) { super(`No admitted tool handler is registered for ${handlerKey}`); }
}

export class ToolBroker {
  readonly #handlers = new Map<string, ToolHandler>();
  register(handlerKey: string, handler: ToolHandler): void {
    if (this.#handlers.has(handlerKey)) throw new Error(`duplicate tool handler registration: ${handlerKey}`);
    this.#handlers.set(handlerKey, handler);
  }
  async invoke(handlerKey: string, input: unknown, context: ToolExecutionContext): Promise<unknown> {
    const handler = this.#handlers.get(handlerKey);
    if (!handler) throw new ToolRefusedError(handlerKey);
    return handler(input, context);
  }
}
export const toolBroker = new ToolBroker();
