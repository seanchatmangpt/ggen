---
to: "lib/ai/agent.ts"
sparql:
  agents: >
      PREFIX nai: <https://ggen.dev/packs/nextjs-ai#>
      SELECT ?agentName ?instructions WHERE { ?agent a nai:Agent ; nai:agentName ?agentName ; nai:instructions ?instructions }
  apps: >
      PREFIX nai: <https://ggen.dev/packs/nextjs-ai#>
      SELECT ?maxSteps ?telemetryEnabled ?fallbackModelId WHERE { ?app a nai:Application ; nai:maxSteps ?maxSteps ; nai:telemetryEnabled ?telemetryEnabled ; nai:fallbackModel ?fallback . ?fallback nai:modelId ?fallbackModelId }
---
import "server-only";
import { ToolLoopAgent, stepCountIs } from "ai";
import { model } from "./models";
import { createTools } from "./tools";
import type { ToolExecutionContext } from "./tool-broker";

{% for agent in agents %}{% for app in apps %}export function createAppAgent(context: ToolExecutionContext) {
  return new ToolLoopAgent({ model, providerOptions: { gateway: { models: ["{{ app.fallbackModelId }}"] } }, instructions: `{{ agent.instructions }}`, tools: createTools(context), stopWhen: stepCountIs({{ app.maxSteps }}), experimental_telemetry: { isEnabled: {{ app.telemetryEnabled }}, functionId: "{{ agent.agentName }}", metadata: { requestId: context.requestId } } });
}
export type AppAgent = ReturnType<typeof createAppAgent>;
{% endfor %}{% endfor %}