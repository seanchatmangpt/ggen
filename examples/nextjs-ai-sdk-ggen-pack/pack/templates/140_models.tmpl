---
to: "lib/ai/models.ts"
sparql:
  models: >
      PREFIX nai: <https://ggen.dev/packs/nextjs-ai#>
      SELECT ?modelId ?modelLabel ?modelRole WHERE { ?model a nai:Model ; nai:modelId ?modelId ; nai:modelLabel ?modelLabel ; nai:modelRole ?modelRole } ORDER BY ?modelRole ?modelId
  apps: >
      PREFIX nai: <https://ggen.dev/packs/nextjs-ai#>
      SELECT ?packageName ?displayName ?description ?defaultModelId ?fallbackModelId ?maxSteps ?maxDurationSeconds ?databaseDialect ?authStrategy ?telemetryEnabled ?shadcnVersion ?aiElementsVersion ?aiSdkVersion ?nextVersion ?reactVersion ?tailwindVersion
      WHERE { ?app a nai:Application ; nai:packageName ?packageName ; nai:displayName ?displayName ; nai:description ?description ; nai:defaultModel ?defaultModel ; nai:maxSteps ?maxSteps ; nai:maxDurationSeconds ?maxDurationSeconds ; nai:databaseDialect ?databaseDialect ; nai:authStrategy ?authStrategy ; nai:telemetryEnabled ?telemetryEnabled ; nai:shadcnVersion ?shadcnVersion ; nai:aiElementsVersion ?aiElementsVersion ; nai:aiSdkVersion ?aiSdkVersion ; nai:nextVersion ?nextVersion ; nai:reactVersion ?reactVersion ; nai:tailwindVersion ?tailwindVersion . ?defaultModel nai:modelId ?defaultModelId . OPTIONAL { ?app nai:fallbackModel ?fallback . ?fallback nai:modelId ?fallbackModelId } }
---
import { gateway } from "ai";

export const admittedModels = [
{% for model in models %}  { id: "{{ model.modelId }}", label: "{{ model.modelLabel }}", role: "{{ model.modelRole }}" },
{% endfor %}] as const;

export type AdmittedModelId = (typeof admittedModels)[number]["id"];

{% for app in apps %}export const DEFAULT_MODEL_ID: AdmittedModelId =
  (process.env.AI_MODEL as AdmittedModelId | undefined) ?? "{{ app.defaultModelId }}";

export const model = gateway(DEFAULT_MODEL_ID);
{% endfor %}