PREFIX nai: <https://ggen.dev/packs/nextjs-ai#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
SELECT ?subject ?property ?count WHERE {
  { SELECT (nai:Application AS ?subject) (rdf:type AS ?property) (COUNT(?app) AS ?count) WHERE { ?app a nai:Application } HAVING (?count != 1) }
  UNION { SELECT (nai:Agent AS ?subject) (rdf:type AS ?property) (COUNT(?agent) AS ?count) WHERE { ?agent a nai:Agent } HAVING (?count != 1) }
  UNION { SELECT ?subject ?property (COUNT(?value) AS ?count) WHERE { VALUES ?class { nai:Application nai:Model nai:Agent nai:Tool } VALUES ?property { nai:packageName nai:displayName nai:description nai:defaultModel nai:fallbackModel nai:maxSteps nai:maxDurationSeconds nai:databaseDialect nai:authStrategy nai:telemetryEnabled nai:shadcnVersion nai:aiElementsVersion nai:aiSdkVersion nai:nextVersion nai:reactVersion nai:tailwindVersion nai:modelId nai:modelLabel nai:modelRole nai:agentName nai:instructions nai:toolName nai:toolTitle nai:toolKind nai:handlerKey nai:inputSchemaJson nai:approvalRequired } ?subject a ?class ; ?property ?value . } GROUP BY ?subject ?property HAVING (?count > 1) }
}
ORDER BY ?subject ?property
