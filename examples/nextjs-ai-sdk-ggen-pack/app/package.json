{
  "name": "nextjs-ai-verify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "ui:sync": "node scripts/sync-ui-registry.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "verify:projection": "node scripts/verify-projection.mjs",
    "verify": "pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e && pnpm verify:projection"
  },
  "dependencies": {
    "@ai-sdk/react": "4.0.38",
    "@neondatabase/serverless": "1.1.0",
    "ai": "7.0.22",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.44.5",
    "lucide-react": "0.468.0",
    "next": "16.2.11",
    "next-themes": "0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.3.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/jest-dom": "6.6.4",
    "@testing-library/react": "16.3.0",
    "@types/node": "24.1.0",
    "@types/react": "19.1.9",
    "@types/react-dom": "19.1.7",
    "@vitejs/plugin-react": "4.7.0",
    "drizzle-kit": "0.31.4",
    "jsdom": "26.1.0",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.3.6",
    "typescript": "5.8.3",
    "vite": "7.0.6",
    "vitest": "3.2.4"
  }
}
