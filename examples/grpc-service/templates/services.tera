{% set_global ns = row["package"] %}{% endif %}{% endfor %}

import "messages.proto";

// ─── Services ─────────────────────────────────────────────────────────────────
{% set cur = "" %}
{% for row in sparql_results %}
{% if row["serviceName"] != cur %}
{% if cur != "" %}
}
{% endif %}
// {{ row["serviceComment"] | default(value="") }}
service {{ row["serviceName"] }} {
{% set_global cur = row["serviceName"] %}{% endif %}
  // {{ row["methodComment"] | default(value="") }}
  rpc {{ row["methodName"] }} ({{ row["requestType"] }}) returns ({{ row["responseType"] }});
{% endfor %}
