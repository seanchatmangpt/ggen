groups:
{% set cur = "" %}{% for row in sparql_results %}{% if row["capId"] != cur %}{% if cur != "" %}
{% endif %}  - id: {{ row["capId"] }}
    type: span
    span_kind: internal
    brief: "{{ row["capDesc"] }}"
    attributes:
{% set_global cur = row["capId"] %}{% endif %}      - id: {{ row["attrName"] }}
        type: {{ row["attrType"] }}
        requirement_level: {{ row["attrRequired"] }}
        brief: "{{ row["attrBrief"] }}"
{% endfor %}
