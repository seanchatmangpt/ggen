# =============================================================================
# wasm4pm stage descriptor — discover stage  (AUTO-GENERATED by ggen sync)
# -----------------------------------------------------------------------------
# Renders the per-stage wasm4pm invocation descriptor for the TPOT2-selected
# elite operator of the "discover" stage. Driven by the same SELECT that chose
# the pipeline (queries/extract-pareto-pipeline.rq, 9 elite rows); this template
# filters to its own stage so each stage rule yields a distinct *-result.ttl.
# The wasm4pm semconv CONSTRUCT proof named in tpot:resultMapping is what maps
# the wasm export's JSON output to RDF at wasm4pm runtime.
# =============================================================================
@prefix tpot: <https://wasm4pm.dev/tpot#> .
@prefix pi:   <https://wasm4pm.dev/pi#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
{% for row in sparql_results %}{% if row["stage_id"] == "discover" %}
tpot:StageResult_discover a tpot:StageResult ;
    tpot:stageOrder     {{ row["stage_order"] }} ;
    tpot:stageId        "discover" ;
    tpot:eliteOperator  pi:Algo_{{ row["operator_id"] }} ;
    tpot:operatorId     "{{ row["operator_id"] }}" ;
    tpot:wasmExport     "{{ row["wasm_export"] }}" ;
    tpot:inputFormat    "{{ row["input_format"] | default(value="") }}" ;
    tpot:outputType     "{{ row["output_type"] | default(value="") }}" ;
    tpot:speedTier      {{ row["speed_tier"] }} ;
    tpot:qualityTier    {{ row["quality_tier"] }} ;
    tpot:fitnessScore   {{ row["fitness_score"] }} ;
    tpot:resultMapping  "queries/{{ row["proof_query"] }}" ;
    prov:wasGeneratedBy tpot:Config_default .
{% endif %}{% endfor %}
