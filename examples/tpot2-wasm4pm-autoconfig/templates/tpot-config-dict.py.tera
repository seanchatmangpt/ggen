"""
wasm4pm TPOT2 config_dict — auto-generated search space.

Generated by ggen sync from queries/extract-operators.rq (all 60 wasm4pm operators).
DO NOT EDIT BY HAND — re-run `ggen sync` to regenerate.

This module expresses the wasm4pm process-mining algorithm registry as a
TPOT2-style `config_dict` (operator search space) suitable for genetic-programming
pipeline optimization. Each entry maps a fully-qualified operator key
"wasm4pm.<stage_id>.<operator_id>" to its wasm export, speed/quality tiers, and
the SPARQL-derived fitness score:

    fitness_score = quality_tier - (0.5 * speed_tier)   # lambda_cost = 0.5

PARETO_ELITE records the per-stage argmax-fitness operator (the chosen pipeline).

Credits:
  wasm4pm process-mining engine (60-algorithm registry, pi: namespace).
  TPOT2 search-space / NSGA-II Pareto methodology after:
    Le, T.T., Fu, W. & Moore, J.H. (2020). "Scaling tree-based automated
    machine learning to biomedical big data with a feature set selector"
    (TPOT), Bioinformatics, 36(1), 250-256.
"""

# random_seed mirrors tpot:randomSeed (determinism).
RANDOM_SEED = 42

# Multi-objective configuration (NSGA-II): maximize quality, minimize speed (cost).
OBJECTIVES = [
    {"name": "quality", "metric": "quality_tier", "direction": "maximize", "weight": 1.0},
    {"name": "cost", "metric": "speed_tier", "direction": "minimize", "weight": 0.5},
]

# Fitness penalty on speed (cost). fitness = quality_tier - LAMBDA_COST * speed_tier.
LAMBDA_COST = 0.5

# ---------------------------------------------------------------------------
# config_dict: full operator search space (all 60 operators, grouped by stage).
# ---------------------------------------------------------------------------
config_dict = {
{%- for row in sparql_results %}
{%- set stage_id = row["stage_id"] | default(value="") -%}
{%- set operator_id = row["operator_id"] | default(value="") -%}
{%- set wasm_export = row["wasm_export"] | default(value="") -%}
{%- set speed_tier = row["speed_tier"] | default(value="0") -%}
{%- set quality_tier = row["quality_tier"] | default(value="0") -%}
{%- set fitness_score = row["fitness_score"] | default(value="0") -%}
{%- set input_format = row["input_format"] | default(value="") -%}
{%- set output_type = row["output_type"] | default(value="") -%}
{%- set cli_alias = row["cli_alias"] | default(value="") -%}
    "wasm4pm.{{ stage_id }}.{{ operator_id }}": {
        "wasm_export": "{{ wasm_export }}",
        "speed_tier": {{ speed_tier }},
        "quality_tier": {{ quality_tier }},
        "fitness_score": {{ fitness_score }},
        "input_format": "{{ input_format }}",
        "output_type": "{{ output_type }}",
{%- if cli_alias != "" %}
        "cli_alias": "{{ cli_alias }}",
{%- endif %}
    },
{%- endfor %}
}

# ---------------------------------------------------------------------------
# PARETO_ELITE: per-stage chosen operator (argmax fitness_score). The pipeline.
# ---------------------------------------------------------------------------
PARETO_ELITE = {
{%- for row in sparql_results %}
{%- set is_elite = row["is_elite"] | default(value="false") -%}
{%- if is_elite == "true" %}
{%- set stage_id = row["stage_id"] | default(value="") -%}
{%- set operator_id = row["operator_id"] | default(value="") -%}
    "{{ stage_id }}": "{{ operator_id }}",
{%- endif %}
{%- endfor %}
}


def build_pipeline():
    """Return the ordered (stage_id, operator_id, wasm_export) tuples of the elite pipeline."""
    pipeline = []
    for stage_id, operator_id in PARETO_ELITE.items():
        key = "wasm4pm.{0}.{1}".format(stage_id, operator_id)
        spec = config_dict[key]
        pipeline.append((stage_id, operator_id, spec["wasm_export"]))
    return pipeline


if __name__ == "__main__":
    print("wasm4pm TPOT2 search space: {0} operators".format(len(config_dict)))
    print("Pareto-elite pipeline ({0} stages, seed={1}):".format(len(PARETO_ELITE), RANDOM_SEED))
    for stage_id, operator_id, wasm_export in build_pipeline():
        print("  {0:14s} -> {1:24s} [{2}]".format(stage_id, operator_id, wasm_export))
