  pi:algorithmId    "analyze_variant_complexity" ;
  pi:algorithmLabel "AnalyzeVariantComplexity" ;
  pi:algorithmDoc   "Complexity metrics per trace variant — computes length distribution, unique activity count, loop density, and entropy for each distinct variant in the log." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
