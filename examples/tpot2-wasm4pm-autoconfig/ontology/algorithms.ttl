  pi:algorithmId    "ocel_dfg_per_type" ;
  pi:algorithmLabel "OcelDfgPerType" ;
  pi:algorithmDoc   "Separate DFG per object type — produces one DFG for each object type in the OCEL log, enabling per-type flow analysis without cross-type interference." ;
