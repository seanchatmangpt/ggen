  pi:standing     "REPLAYABLE" .

pi:Algo_ocel_encode a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "ocel_encode" ;
  pi:algorithmLabel "OcelEncode" ;
  pi:algorithmDoc   "Encodes OCEL log to feature matrix — transforms the object-centric log into a numeric feature matrix suitable for downstream ML algorithms." ;
  pi:citation       "van der Aalst, W.M.P. (2019). Object-Centric Process Mining. ICSOC 2019, LNCS 11895. Springer." ;
  pi:outputType     "ml_result" ;
  pi:category       "object_centric" ;
