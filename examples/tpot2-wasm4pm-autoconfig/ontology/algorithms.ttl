# PI algorithm instances — 60 ProcessIntelligenceAlgorithm individuals.
# pi:algorithmStatus is NEVER set here — CONSTRUCT-derived from pi-certified-gate.
# pi:cliAlias is OMITTED when no alias is defined (not empty string).
# Namespace: https://wasm4pm.dev/pi# (must match ggen.toml CONSTRUCT exactly)

# ============================================================
# DISCOVERY (20)
# ============================================================

pi:Algo_a_star a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "a_star" ;
  pi:algorithmLabel "AStar" ;
  pi:algorithmDoc   "A* shortest-path discovery over DFG — finds optimal path through the directly-follows graph using heuristic search, producing a Petri net model." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
  pi:outputType     "petrinet" ;
  pi:category       "discovery" ;
  pi:speedTier      "30"^^xsd:integer ;
  pi:qualityTier    "75"^^xsd:integer ;
  pi:wasmExport     "discover_a_star" ;
  pi:cliAlias       "astar" ;
  pi:inputFormat    "xes" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_aco a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "aco" ;
  pi:algorithmLabel "Aco" ;
  pi:algorithmDoc   "Ant Colony Optimisation discovery — stochastic population-based search inspired by ant foraging, producing Petri net models with good fitness/precision balance." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
  pi:outputType     "petrinet" ;
  pi:category       "discovery" ;
  pi:speedTier      "50"^^xsd:integer ;
  pi:qualityTier    "78"^^xsd:integer ;
  pi:wasmExport     "discover_aco" ;
  pi:cliAlias       "ant-colony" ;
  pi:inputFormat    "xes" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_alpha_plus_plus a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "alpha_plus_plus" ;
  pi:algorithmLabel "AlphaPlusPlus" ;
  pi:algorithmDoc   "Alpha++ miner — extends the original Alpha algorithm to handle length-one and length-two loops, producing a Petri net from the directly-follows footprint matrix." ;
  pi:citation       "van der Aalst, W.M.P., Weijters, T., & Maruster, L. (2004). Workflow Mining: Discovering Process Models from Event Logs. IEEE TKDE, 16(9), 1128-1142." ;
  pi:outputType     "petrinet" ;
  pi:category       "discovery" ;
  pi:speedTier      "5"^^xsd:integer ;
  pi:qualityTier    "50"^^xsd:integer ;
  pi:wasmExport     "discover_alpha_plus_plus" ;
  pi:cliAlias       "alpha" ;
  pi:inputFormat    "xes" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_declare a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "declare" ;
  pi:algorithmLabel "Declare" ;
  pi:algorithmDoc   "Declarative constraint mining using LTL-based temporal logic — discovers existence, response, and precedence constraints rather than a procedural model." ;
  pi:citation       "Pesic, M., & van der Aalst, W.M.P. (2006). A Declarative Approach for Flexible Business Processes. BPM 2006 Workshops, LNCS 4103. Springer." ;
  pi:outputType     "declare" ;
  pi:category       "discovery" ;
  pi:speedTier      "20"^^xsd:integer ;
  pi:qualityTier    "80"^^xsd:integer ;
  pi:wasmExport     "discover_declare" ;
  pi:cliAlias       "declare" ;
  pi:inputFormat    "xes" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_dfg a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "dfg" ;
  pi:algorithmLabel "Dfg" ;
  pi:algorithmDoc   "Directly-Follows Graph — fastest baseline discovery, counting how often one activity directly follows another. Serves as input to most other discovery algorithms." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
  pi:outputType     "dfg" ;
  pi:category       "discovery" ;
