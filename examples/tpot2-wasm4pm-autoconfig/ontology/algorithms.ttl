  pi:algorithmId    "inductive_miner" ;
  pi:algorithmLabel "InductiveMiner" ;
  pi:algorithmDoc   "Inductive Miner — recursively discovers a sound, block-structured process tree from the event log by detecting cut types (sequence, parallel, choice, loop)." ;
  pi:citation       "Leemans, S.J.J., Fahland, D., & van der Aalst, W.M.P. (2013). Discovering Block-Structured Process Models from Event Logs. Petri Nets 2013, LNCS 7927. Springer." ;
