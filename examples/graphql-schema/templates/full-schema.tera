# =============================================================================
# Complete GraphQL Schema
# Generated by ggen sync - DO NOT EDIT
# Source: ontology/graphql-schema.ttl
# =============================================================================

schema {
  query: Query
  mutation: Mutation
}

# Object types defined in this schema:
{%- set types = [] -%}
{%- for row in sparql_results -%}
{%- set t = row["typeName"] | default(value="") -%}
{%- if t != "" and types is not containing(t) -%}
{%- set_global types = types | concat(with=t) -%}
{%- endif -%}
{%- endfor %}
{%- for t in types %}
#   - {{ t }}
{%- endfor %}
