{# =============================================================================
   INPUT TYPES TEMPLATE - Generates GraphQL SDL input type definitions
   ============================================================================= #}
{%- set current_type = "" -%}
{%- for row in sparql_results -%}
{%- set typeName = row["typeName"] | default(value="") -%}
{%- set typeComment = row["typeComment"] | default(value="") -%}
{%- set fieldName = row["fieldName"] | default(value="") -%}
{%- set fieldType = row["fieldType"] | default(value="String") -%}
{%- set nonNull = row["nonNull"] | default(value="false") -%}
{%- set isList = row["isList"] | default(value="false") -%}

{%- if typeName != current_type -%}
{%- if current_type != "" %}
}
{% endif -%}
{%- set_global current_type = typeName %}
{%- if typeComment != "" %}
"""
{{ typeComment }}
"""
{%- endif %}
input {{ typeName }} {
{%- endif %}
  {{ fieldName }}: {%- if isList == "true" %} [{{ fieldType }}{%- if nonNull == "true" %}!{%- endif %}]{%- else %} {{ fieldType }}{%- endif %}{%- if nonNull == "true" %}!{%- endif %}
{%- endfor %}
}
