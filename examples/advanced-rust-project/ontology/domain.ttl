@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/advanced-rust-project#> .

# ── Services ──────────────────────────────────────────────────────────────────

ex:UserService a ex:Service ;
    ex:name        "user_service" ;
    ex:description "Manages user accounts and authentication" ;
    ex:version     "1.0.0" ;
    ex:author      "ggen-examples" .

ex:ProductService a ex:Service ;
    ex:name        "product_service" ;
    ex:description "Manages product catalogue and inventory" ;
    ex:version     "1.0.0" ;
    ex:author      "ggen-examples" .

ex:OrderService a ex:Service ;
    ex:name        "order_service" ;
    ex:description "Handles order lifecycle and fulfilment" ;
    ex:version     "1.0.0" ;
    ex:author      "ggen-examples" .

# ── API Endpoints ─────────────────────────────────────────────────────────────

ex:GetUsersEndpoint a ex:Endpoint ;
    ex:name        "get_users" ;
    ex:method      "GET" ;
    ex:path        "/api/v1/users" ;
    ex:description "List all users" .

ex:CreateUserEndpoint a ex:Endpoint ;
    ex:name        "create_user" ;
    ex:method      "POST" ;
    ex:path        "/api/v1/users" ;
    ex:description "Create a new user" .

ex:GetProductsEndpoint a ex:Endpoint ;
    ex:name        "get_products" ;
    ex:method      "GET" ;
    ex:path        "/api/v1/products" ;
    ex:description "List all products" .

# ── Entities ──────────────────────────────────────────────────────────────────

ex:User a ex:Entity ;
    ex:name        "User" ;
    ex:description "A registered user in the system" .

ex:Product a ex:Entity ;
    ex:name        "Product" ;
    ex:description "A product available for purchase" .

ex:Order a ex:Entity ;
    ex:name        "Order" ;
    ex:description "A customer order containing one or more products" .
