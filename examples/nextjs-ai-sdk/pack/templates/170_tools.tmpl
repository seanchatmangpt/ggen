---
to: "lib/ai/tools.ts"
sparql:
  tools: >
      PREFIX nai: <https://ggen.dev/packs/nextjs-ai#>
      SELECT ?toolName ?toolTitle ?description ?toolKind ?handlerKey ?inputSchemaJson ?approvalRequired WHERE {
        ?agent a nai:Agent ; nai:usesTool ?tool .
        ?tool a nai:Tool ; nai:toolName ?toolName ; nai:toolTitle ?toolTitle ; nai:description ?description ;
              nai:toolKind ?toolKind ; nai:handlerKey ?handlerKey ; nai:inputSchemaJson ?inputSchemaJson ;
              nai:approvalRequired ?approvalRequired .
      } ORDER BY ?toolName
---
import "server-only";
import { jsonSchema, tool } from "ai";
import { createToolBroker, type ToolExecutionContext } from "./tool-broker";

export function createTools(context: ToolExecutionContext) {
  const broker = createToolBroker();
  return {
{% for item in tools %}    {{ item.toolName }}: tool({
      title: "{{ item.toolTitle }}",
      description: "{{ item.description }}",
      inputSchema: jsonSchema({{ item.inputSchemaJson }}),
      needsApproval: {{ item.approvalRequired }},
      execute: (input) => broker.invoke("{{ item.handlerKey }}", input, context),
    }),
{% endfor %}  };
}

export type AppTools = ReturnType<typeof createTools>;
