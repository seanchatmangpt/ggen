{
  "name": "nextjs-ai-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "ui:verify": "node scripts/verify-ui-registry.mjs",
    "db:migrate": "node --experimental-strip-types scripts/migrate.ts",
    "verify:gates": "python3 scripts/verify-gates.py",
    "verify:projection": "node scripts/verify-projection.mjs",
    "verify": "pnpm verify:gates && pnpm ui:verify && pnpm db:migrate && pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e && pnpm verify:projection"
  },
  "dependencies": {
    "@ai-sdk/gateway": "4.0.26",
    "@ai-sdk/react": "4.0.38",
    "@neondatabase/serverless": "1.1.0",
    "ai": "7.0.22",
    "better-auth": "1.6.23",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "0.468.0",
    "next": "16.2.11",
    "next-themes": "0.4.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.3.1",
    "zod": "4.1.12",
    "@noble/hashes": "2.2.0",
    "@opentelemetry/api": "1.9.1",
    "@vercel/otel": "2.1.3",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "24.1.0",
    "@types/react": "19.1.9",
    "@types/react-dom": "19.1.7",
    "drizzle-kit": "0.31.4",
    "@opentelemetry/sdk-trace-base": "2.10.0",
    "@ai-sdk/openai-compatible": "3.0.14",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.3.6",
    "typescript": "5.8.3",
    "vite": "7.0.6",
    "vitest": "3.2.4",
    "@types/ws": "8.18.1"
  }
}
