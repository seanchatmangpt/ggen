# clap-noun-verb-pack ontology — CLI command individuals for the
# clap-noun-verb framework (noun = resource, verb = action).
# Namespace is unique to this pack.
#
# The generated-code contract is aligned with ~/clap-noun-verb's own
# authoritative pack conventions (its queries/verb-signatures.rq column
# contract and templates/verb.rs.tera): generated verb functions carry typed,
# optionally-positional arguments and delegate to a stable, hand-written
# `crate::handlers::*` seam — there is no logic slot in the generated code
# itself. `cnv:args` uses the same `field|rust_type|required|about` per-arg,
# `@@`-joined encoding as the real project's `args` query column, but as a
# single literal per cnv:Command rather than SPARQL-aggregated across
# separate Argument individuals — this avoids depending on nested
# GROUP_CONCAT/subquery aggregation, which this engine's SPARQL support was
# not verified against, while producing byte-identical generated output.

@prefix cnv:  <http://seanchatmangpt.github.io/packs/clap-noun-verb#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ── Classes ──────────────────────────────────────────────────────────

cnv:Noun
    a            rdfs:Class ;
    rdfs:label   "Noun" ;
    rdfs:comment "A CLI resource/entity (session, user) in the noun-verb pattern." .

cnv:Command
    a            rdfs:Class ;
    rdfs:label   "Command" ;
    rdfs:comment "A noun-verb CLI command registered via #[clap_noun_verb_macros::verb]." .

# ── Properties ───────────────────────────────────────────────────────

cnv:noun       a rdf:Property ; rdfs:label "noun"        ; rdfs:domain cnv:Command ; rdfs:range xsd:string .
cnv:verb       a rdf:Property ; rdfs:label "verb"         ; rdfs:domain cnv:Command ; rdfs:range xsd:string .
cnv:handler    a rdf:Property ; rdfs:label "handler"      ; rdfs:domain cnv:Command ; rdfs:range xsd:string .
cnv:doc        a rdf:Property ; rdfs:label "doc"          ; rdfs:domain cnv:Command ; rdfs:range xsd:string .
cnv:returnType a rdf:Property ; rdfs:label "return type"  ; rdfs:domain cnv:Command ; rdfs:range xsd:string .
cnv:args       a rdf:Property ; rdfs:label "argument specs" ; rdfs:comment
    "field|rust_type|required|about groups, one per argument, joined by @@. Empty string when the command takes no arguments." ;
    rdfs:domain cnv:Command ; rdfs:range xsd:string .

# ── Nouns ────────────────────────────────────────────────────────────

cnv:SessionNoun a cnv:Noun ; rdfs:label "session" ;
    rdfs:comment "Manage authenticated session tokens." .
cnv:UserNoun    a cnv:Noun ; rdfs:label "user" ;
    rdfs:comment "Manage user resources." .

# ── Command individuals ──────────────────────────────────────────────

cnv:SessionLogin
    a              cnv:Command ;
    cnv:noun       "session" ;
    cnv:verb       "login" ;
    cnv:handler    "session_login_handler" ;
    cnv:doc        "Start an authenticated session and persist the token." ;
    cnv:returnType "serde_json::Value" ;
    cnv:args       "token|String|true|Bearer token to persist for this session." .

cnv:SessionVerify
    a              cnv:Command ;
    cnv:noun       "session" ;
    cnv:verb       "verify" ;
    cnv:handler    "session_verify_handler" ;
    cnv:doc        "Verify the active session token against the stored keyring credential." ;
    cnv:returnType "serde_json::Value" ;
    cnv:args       "" .

cnv:UserCreate
    a              cnv:Command ;
    cnv:noun       "user" ;
    cnv:verb       "create" ;
    cnv:handler    "user_create_handler" ;
    cnv:doc        "Create a user resource and emit its serialized record." ;
    cnv:returnType "serde_json::Value" ;
    cnv:args       "name|String|true|Display name for the new user.@@email|String|false|Optional contact email for the new user." .
