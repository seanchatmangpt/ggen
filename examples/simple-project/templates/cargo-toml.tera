[package]
name = "{{ project_name | default(value="my-project") }}"
version = "{{ version | default(value="0.1.0") }}"
edition = "2021"
description = "{{ description | default(value="A Rust project") }}"

[dependencies]
serde = { version = "1.0", features = ["derive"] }
tokio = { version = "1", features = ["full"] }

[dev-dependencies]
