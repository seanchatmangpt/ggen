{# =============================================================================
   CREATE INDEXES TEMPLATE - Generates SQL CREATE INDEX statements
   ============================================================================= #}
-- =============================================================================
-- Indexes - Generated by ggen sync
-- =============================================================================

{%- for row in sparql_results -%}
{%- set tableName = row["tableName"] | default(value="") -%}
{%- set indexName = row["indexName"] | default(value="") -%}
{%- set indexColumn = row["indexColumn"] | default(value="") -%}
{%- set unique = row["unique"] | default(value="false") -%}
{%- if indexName != "" and tableName != "" %}
CREATE {%- if unique == "true" %} UNIQUE{%- endif %} INDEX {{ indexName }} ON {{ tableName }} ({{ indexColumn }});
{%- endif %}
{%- endfor %}
