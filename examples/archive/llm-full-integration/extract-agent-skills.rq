# Extract agent and skills for LLM generation
PREFIX a2a: <http://example.org/a2a#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>

SELECT ?agent_name ?agent_description ?skill_name ?skill_desc ?system_prompt ?implementation_hint ?behavior ?input_type ?output_type WHERE {
  ?ag a a2a:Agent ;
      rdfs:label ?agent_name ;
      schema:description ?agent_description .
  ?skill a a2a:Skill ;
         a2a:hasSystemPrompt ?system_prompt ;
         a2a:hasImplementationHint ?implementation_hint ;
         a2a:hasBehavior ?behavior ;
         rdfs:label ?skill_name ;
         schema:description ?skill_desc ;
         a2a:hasInputType ?input_type ;
         a2a:hasOutputType ?output_type .
  ?ag a2a:hasCapability ?skill .
}
ORDER BY ?skill_name
