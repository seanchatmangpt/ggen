{# =============================================================================
   MIGRATION TEMPLATE - Generates versioned migration file
   ============================================================================= #}
-- =============================================================================
-- Migration: Initial schema
-- Generated by ggen sync from ontology/db-schema.ttl
-- =============================================================================

BEGIN;

{%- set tables = [] -%}
{%- for row in sparql_results -%}
{%- set t = row["tableName"] | default(value="") -%}
{%- if t != "" and tables is not containing(t) -%}
{%- set_global tables = tables | concat(with=t) -%}
{%- endif -%}
{%- endfor %}

-- Tables created in this migration:
{%- for t in tables %}
--   {{ t }}
{%- endfor %}

-- Run create-tables.sql and create-indexes.sql to apply schema

COMMIT;
