# SPARQL Query to extract A2A agent metadata
# Extracts agent information for generating agent.rs and agent_card.json

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX a2a: <https://w3id.org/a2a/ontology#>
PREFIX agent: <https://example.com/agent#>

CONSTRUCT {
  ?agent a a2a:Agent ;
    a2a:agentName ?agent_name ;
    a2a:version ?agent_version ;
    a2a:description ?agent_description ;
    a2a:url ?agent_url ;
    a2a:provider ?provider_name ;
    a2a:hasSystemPrompt ?system_prompt .
}
WHERE {
  ?agent a a2a:Agent ;
    rdfs:label ?agent_name ;
    a2a:version ?agent_version ;
    rdfs:comment ?agent_description ;
    a2a:url ?agent_url ;
    a2a:provider ?provider_name .

  OPTIONAL { ?agent a2a:hasSystemPrompt ?system_prompt . }
}
