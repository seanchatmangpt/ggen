{# Dockerfile template - generated from RDF ontology #}
{%- set first = sparql_results | first %}
# Generated Dockerfile for {{ first["name"] | default(value="ai-microservice") }}
# Source of truth: ontology/microservice.ttl

FROM {{ first["baseImage"] | default(value="rust:1.82-slim") }} AS builder

WORKDIR /app
COPY . .
RUN cargo build --release

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/target/release/ai-microservice /app/ai-microservice

EXPOSE {{ first["port"] | default(value="8080") }}
CMD ["/app/ai-microservice"]
