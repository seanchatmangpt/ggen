# OTel Weaver semantic convention registry — generated by ggen
# Source: ontology/ggen-semconv.ttl
# DO NOT EDIT — regenerate with: ggen sync
groups:
{% set cur = "" %}{% for row in sparql_results %}{% if row["groupId"] != cur %}{% if cur != "" %}
{% endif %}  - id: {{ row["groupId"] }}
    type: {{ row["groupType"] }}
    prefix: {{ row["prefix"] }}
    stability: {{ row["stability"] | default(value="experimental") }}
    brief: "Attributes for the {{ row["groupId"] }} signal group"
    attributes:
{% set_global cur = row["groupId"] %}{% endif %}      - id: {{ row["groupId"] }}.{{ row["attrName"] }}
        type: {{ row["attrType"] }}
        requirement_level: {{ row["required"] }}
        brief: "{{ row["brief"] }}"
{% if row["examples"] %}        examples: [{{ row["examples"] }}]
{% endif %}{% endfor %}
