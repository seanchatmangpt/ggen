# Microservices Architecture - Service Dependencies
# Generated by ggen
{% for row in sparql_results %}
# {{ row["serviceName"] }} depends on {{ row["dependsOn"] }}
{% endfor %}

# Query: List all services
PREFIX ex: <https://example.com/microservices#>

SELECT ?serviceName ?port ?framework
WHERE {
  ?service a ex:Service ;
           ex:serviceName ?serviceName ;
           ex:port ?port ;
           ex:framework ?framework .
}
ORDER BY ?port
