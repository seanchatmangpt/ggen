# Code Generation Specification Ontology
# Demonstrates agents autonomously generating code from RDF specifications
# Format: RDF (Turtle)
# Schema: ggen v6 A = μ(O) pattern

@prefix cg: <http://ggen.dev/examples/code-gen#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix meta: <http://ggen.ai/ontology/meta#> .

# =============================================================================
# 1. CORE ENTITIES
# =============================================================================

cg:CodeGenerationTask
  a owl:Class ;
  rdfs:label "Code Generation Task"@en ;
  rdfs:comment "A task specification for generating code" ;
  rdfs:subClassOf meta:OntologyElement .

cg:CodeSpecification
  a owl:Class ;
  rdfs:label "Code Specification"@en ;
  rdfs:comment "RDF-based specification of code to be generated" ;
  rdfs:subClassOf meta:OntologyElement .

cg:GeneratedArtifact
  a owl:Class ;
  rdfs:label "Generated Code Artifact"@en ;
  rdfs:comment "Output code produced from specification" ;
  rdfs:subClassOf meta:OntologyElement .

cg:ValidationStep
  a owl:Class ;
  rdfs:label "Validation Step"@en ;
  rdfs:comment "A validation step in the generation pipeline" ;
  rdfs:subClassOf meta:OntologyElement .

# =============================================================================
# 2. PROGRAMMING LANGUAGES & FRAMEWORKS
# =============================================================================

cg:ProgrammingLanguage
  a owl:Class ;
  rdfs:label "Programming Language"@en ;
  rdfs:comment "Target programming language for generation" ;
  rdfs:subClassOf meta:OntologyElement .

cg:Rust a cg:ProgrammingLanguage ;
  rdfs:label "Rust"@en ;
  rdfs:comment "Rust programming language" .

cg:Python a cg:ProgrammingLanguage ;
  rdfs:label "Python"@en ;
  rdfs:comment "Python programming language" .

cg:TypeScript a cg:ProgrammingLanguage ;
  rdfs:label "TypeScript"@en ;
  rdfs:comment "TypeScript programming language" .

cg:Framework
  a owl:Class ;
  rdfs:label "Framework"@en ;
  rdfs:comment "Development framework for code generation" ;
  rdfs:subClassOf meta:OntologyElement .

cg:ActixWeb a cg:Framework ;
  rdfs:label "Actix Web"@en ;
  rdfs:comment "Rust web framework" ;
  cg:supportedLanguage cg:Rust .

cg:FastAPI a cg:Framework ;
  rdfs:label "FastAPI"@en ;
  rdfs:comment "Python API framework" ;
  cg:supportedLanguage cg:Python .

cg:NestJS a cg:Framework ;
  rdfs:label "NestJS"@en ;
  rdfs:comment "Node.js/TypeScript framework" ;
  cg:supportedLanguage cg:TypeScript .

# =============================================================================
# 3. CODE GENERATION PATTERNS
# =============================================================================

cg:CodePattern
  a owl:Class ;
  rdfs:label "Code Pattern"@en ;
  rdfs:comment "A reusable code generation pattern" ;
  rdfs:subClassOf meta:OntologyElement .

cg:ApiControllerPattern a cg:CodePattern ;
  rdfs:label "API Controller Pattern"@en ;
  rdfs:comment "REST API endpoint controller" ;
  cg:patternTemplate "controller_template" ;
  cg:requires cg:HttpRouting ;
  cg:requires cg:RequestValidation .

cg:DataModelPattern a cg:CodePattern ;
  rdfs:label "Data Model Pattern"@en ;
  rdfs:comment "Domain model with serialization" ;
  cg:patternTemplate "model_template" ;
  cg:requires cg:Serialization .

cg:ServicePattern a cg:CodePattern ;
  rdfs:label "Service Pattern"@en ;
  rdfs:comment "Business logic service layer" ;
  cg:patternTemplate "service_template" ;
  cg:requires cg:Async ;
  cg:requires cg:ErrorHandling .

cg:TestPattern a cg:CodePattern ;
  rdfs:label "Test Pattern"@en ;
  rdfs:comment "Unit/integration test template" ;
  cg:patternTemplate "test_template" ;
  cg:requires cg:Mocking .

# =============================================================================
# 4. CROSS-CUTTING CONCERNS
# =============================================================================

cg:Feature
  a owl:Class ;
  rdfs:label "Feature"@en ;
  rdfs:comment "A code feature requirement" ;
  rdfs:subClassOf meta:OntologyElement .

cg:Async a cg:Feature ;
  rdfs:label "Async/Await Support"@en ;
  rdfs:comment "Asynchronous operation support" .

cg:ErrorHandling a cg:Feature ;
  rdfs:label "Error Handling"@en ;
  rdfs:comment "Result type error handling" .

cg:Serialization a cg:Feature ;
  rdfs:label "Serialization"@en ;
  rdfs:comment "Serde/JSON serialization support" .

cg:HttpRouting a cg:Feature ;
  rdfs:label "HTTP Routing"@en ;
  rdfs:comment "REST endpoint routing" .

cg:RequestValidation a cg:Feature ;
  rdfs:label "Request Validation"@en ;
  rdfs:comment "Input validation" .

cg:Mocking a cg:Feature ;
  rdfs:label "Mocking Support"@en ;
  rdfs:comment "Test mocking utilities" .

# =============================================================================
# 5. GENERATION PIPELINE (VALIDATION STEPS)
# =============================================================================

cg:GenerationPipeline
  a owl:Class ;
  rdfs:label "Generation Pipeline"@en ;
  rdfs:comment "Multi-stage code generation pipeline" ;
  rdfs:subClassOf meta:OntologyElement .

cg:SyntaxCheck a cg:ValidationStep ;
  rdfs:label "Syntax Check"@en ;
  rdfs:comment "Verify generated code syntax" ;
  cg:toolPath "/mcp/tools/syntax_check" ;
  cg:orderIndex "1"^^xsd:integer .

cg:FormatCheck a cg:ValidationStep ;
  rdfs:label "Format Check"@en ;
  rdfs:comment "Verify code formatting compliance" ;
  cg:toolPath "/mcp/tools/format_check" ;
  cg:orderIndex "2"^^xsd:integer .

cg:CompileCheck a cg:ValidationStep ;
  rdfs:label "Compile Check"@en ;
  rdfs:comment "Compile generated code" ;
  cg:toolPath "/mcp/tools/compile" ;
  cg:orderIndex "3"^^xsd:integer .

cg:TestExecution a cg:ValidationStep ;
  rdfs:label "Test Execution"@en ;
  rdfs:comment "Run tests on generated code" ;
  cg:toolPath "/mcp/tools/test" ;
  cg:orderIndex "4"^^xsd:integer .

# =============================================================================
# 6. PROPERTIES
# =============================================================================

cg:hasLanguage
  a owl:ObjectProperty ;
  rdfs:domain cg:CodeSpecification ;
  rdfs:range cg:ProgrammingLanguage ;
  rdfs:label "has programming language"@en .

cg:hasFramework
  a owl:ObjectProperty ;
  rdfs:domain cg:CodeSpecification ;
  rdfs:range cg:Framework ;
  rdfs:label "has framework"@en .

cg:hasPattern
  a owl:ObjectProperty ;
  rdfs:domain cg:CodeSpecification ;
  rdfs:range cg:CodePattern ;
  rdfs:label "has code pattern"@en .

cg:requires
  a owl:ObjectProperty ;
  rdfs:domain cg:CodePattern ;
  rdfs:range cg:Feature ;
  rdfs:label "requires feature"@en .

cg:supportedLanguage
  a owl:ObjectProperty ;
  rdfs:domain cg:Framework ;
  rdfs:range cg:ProgrammingLanguage ;
  rdfs:label "supported language"@en .

cg:patternTemplate
  a owl:DatatypeProperty ;
  rdfs:domain cg:CodePattern ;
  rdfs:range xsd:string ;
  rdfs:label "pattern template name"@en .

cg:toolPath
  a owl:DatatypeProperty ;
  rdfs:domain cg:ValidationStep ;
  rdfs:range xsd:string ;
  rdfs:label "MCP tool endpoint path"@en .

cg:orderIndex
  a owl:DatatypeProperty ;
  rdfs:domain cg:ValidationStep ;
  rdfs:range xsd:integer ;
  rdfs:label "execution order"@en .

# =============================================================================
# 7. CONCRETE EXAMPLES
# =============================================================================

cg:example_user_service a cg:CodeSpecification ;
  rdfs:label "User Management Service"@en ;
  rdfs:comment "REST API for user management" ;
  cg:hasLanguage cg:Rust ;
  cg:hasFramework cg:ActixWeb ;
  cg:hasPattern cg:ApiControllerPattern ;
  cg:hasPattern cg:DataModelPattern ;
  cg:hasPattern cg:ServicePattern ;
  cg:hasPattern cg:TestPattern .

cg:example_python_api a cg:CodeSpecification ;
  rdfs:label "Python Data API"@en ;
  rdfs:comment "FastAPI endpoint for data processing" ;
  cg:hasLanguage cg:Python ;
  cg:hasFramework cg:FastAPI ;
  cg:hasPattern cg:ApiControllerPattern ;
  cg:hasPattern cg:DataModelPattern ;
  cg:hasPattern cg:ServicePattern .

# =============================================================================
# 8. AGENT INSTRUCTIONS
# =============================================================================

cg:AgentInstructions
  a owl:Class ;
  rdfs:label "Agent Instructions"@en ;
  rdfs:comment "Instructions for code-generating agents" ;
  rdfs:subClassOf meta:OntologyElement .

cg:instruction_read_spec a cg:AgentInstructions ;
  rdfs:label "Read Specification"@en ;
  rdfs:comment "Agent reads RDF specification to understand requirements" ;
  rdfs:seeAlso cg:CodeSpecification .

cg:instruction_select_patterns a cg:AgentInstructions ;
  rdfs:label "Select Code Patterns"@en ;
  rdfs:comment "Agent selects appropriate code patterns from ontology" ;
  rdfs:seeAlso cg:CodePattern .

cg:instruction_generate_code a cg:AgentInstructions ;
  rdfs:label "Generate Code"@en ;
  rdfs:comment "Agent generates code by combining patterns and LLM calls" .

cg:instruction_validate a cg:AgentInstructions ;
  rdfs:label "Validate Generated Code"@en ;
  rdfs:comment "Agent calls MCP tools to validate code (syntax, format, compile, test)" ;
  rdfs:seeAlso cg:ValidationStep .

cg:instruction_refine a cg:AgentInstructions ;
  rdfs:label "Refine Code"@en ;
  rdfs:comment "Agent refines code based on validation feedback" .
