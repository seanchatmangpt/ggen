rs:PaymentProcessedField a rs:Field ;
    rs:fieldOf rs:PaymentEntity ;
    rs:fieldName "processed_at" ;
    rs:fieldType "String" ;
    rs:optional "true"^^xsd:boolean ;
    rs:fieldOrder "6"^^xsd:integer .
