{# C4 Level 1: System Context Diagram #}
graph TB
    classDef actor fill:#08427b,stroke:#3c7fc0,color:#fff,font-size:14px
    classDef system fill:#438dd5,stroke:#3c7fc0,color:#fff,font-size:14px
    classDef external fill:#999,stroke:#666,color:#fff,font-size:12px

    %% Title and System Context
    A["<b>System Context</b><br/>GCP Erlang Autonomics"]
    style A fill:#f0f0f0,stroke:#000,stroke-width:3px,font-size:16px,color:#000

    SYS["<b>Autonomous Governor</b><br/><i>Erlang + GCP Cloud Run</i>"]:::system

    {# Actors and their relationships #}
    {% for row in sparql_results %}
    ACT_{{ loop.index }}["{{ row["actor_label"] | upper }}"]:::actor
    {% endfor %}

    {# Relationships from actors to system #}
    {% for row in sparql_results %}
    ACT_{{ loop.index }} -->|{{ row["rel_type"] | default(value="uses") }}| SYS
    {% endfor %}

    L["<b>Legend</b><br/>Actor: Human or external system<br/>System: Primary responsibility"]
    style L fill:#e8f4f8,stroke:#999,stroke-width:1px,color:#000,font-size:11px
