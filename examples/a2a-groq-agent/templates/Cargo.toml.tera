[package]
name = "{{ sparql_results | first | get(key="agentName") }}"
version = "{{ sparql_results | first | get(key="version") }}"
edition = "2021"
description = "A2A agent powered by Groq LLM — generated by ggen"

[dependencies]
a2a-agents = { path = "../../vendors/a2a-rs/a2a-agents", default-features = false }
a2a-rs = { path = "../../vendors/a2a-rs/a2a-rs", features = ["http-server"] }
ggen-ai = { path = "../../crates/ggen-ai" }
tokio = { version = "1", features = ["full"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tracing = "0.1"
tracing-subscriber = "0.3"
uuid = { version = "1", features = ["v4"] }
futures = "0.3"
async-trait = "0.1"
chrono = "0.4"
