# {{ sparql_results | first | get(key="agentName") }} A2A Agent — generated by ggen
# Source: ontology/a2a-agent.ttl
# DO NOT EDIT — regenerate with: ggen sync

[agent]
name = "{{ sparql_results | first | get(key="agentName") }}"
description = "{{ sparql_results | first | get(key="description") }}"
{%- if sparql_results | first | get(key="version") %}
version = "{{ sparql_results | first | get(key="version") }}"
{%- endif %}

[server]
http_port = 3000

[server.storage]
type = "inmemory"
{%- for row in sparql_results %}

[[skills]]
id = "{{ row["skillId"] }}"
name = "{{ row["skillName"] }}"
description = "{{ row["skillDesc"] }}"
input_formats = ["{{ row["inputModes"] }}"]
output_formats = ["{{ row["outputModes"] }}"]
{%- endfor %}

[features]
streaming = true
push_notifications = false
