impl AsyncMessageHandler for {{ sparql_results | first | get(key="agentStruct") }} {
    async fn process_message<'a>(
        &self,
        task_id: &'a str,
        message: &'a Message,
        session_id: Option<&'a str>,
    ) -> Result<Task, A2AError> {
        let context_id = session_id.unwrap_or("default").to_string();

        // Ensure task exists
        if !self.storage.task_exists(task_id).await? {
            self.storage.create_task(task_id, &context_id).await?;
        }

        // Dispatch to skill handler
        let input = Self::extract_text(message);
        let result_text = self.dispatch(&input).await?;

        // Build agent response message
        let response = Message::builder()
            .role(Role::Agent)
            .message_id(Uuid::new_v4().to_string())
            .context_id(context_id)
            .parts(vec![Part::text(result_text)])
            .build();

        self.storage
            .update_task_status(task_id, TaskState::Completed, Some(response))
            .await
    }
}

