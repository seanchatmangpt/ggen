---
to: "generated/{{ struct_name }}.rs"
vars:
  struct_name: string
  type_name: string
  struct_description: string
  has_id: boolean
  has_builder: boolean
  fields: string
---
//! {{ struct_description }}
//!
//! This struct was auto-generated from template: rust-struct.tera
//! Demonstrates Tera conditionals and filters

{% if has_id %}
/// Unique identifier type
pub type Id = u64;
{% endif %}

/// {{ struct_description }}
///
/// Auto-generated struct with derive macros and implementation.
#[derive(Debug, Clone, PartialEq, Eq, Default)]
{% if has_id %}
#[derive(serde::Serialize, serde::Deserialize)]
{% endif %}
pub struct {{ type_name }} {
    {% if has_id %}
    /// Unique identifier
    pub id: Id,
    {% endif %}
    // Fields: {{ fields }}
}

impl {{ type_name }} {
    /// Creates a new {{ type_name }}
    pub fn new() -> Self {
        Self::default()
    }

    {% if has_id %}
    /// Returns the ID of this {{ struct_name }}
    pub fn id(&self) -> Id {
        self.id
    }
    {% endif %}

    /// Returns the field summary for this {{ type_name }}
    pub fn fields_summary(&self) -> &'static str {
        "{{ fields }}"
    }

    /// Validates this {{ struct_name }}
    pub fn validate(&self) -> Result<(), String> {
        {% if has_id %}
        if self.id == 0 {
            return Err("ID cannot be zero".to_string());
        }
        {% endif %}
        Ok(())
    }
}

{% if has_builder %}
/// Builder for constructing {{ type_name }}
pub struct {{ type_name }}Builder {
    {% if has_id %}
    id: Option<Id>,
    {% endif %}
}

impl Default for {{ type_name }}Builder {
    fn default() -> Self {
        Self::new()
    }
}

impl {{ type_name }}Builder {
    /// Creates a new builder
    pub fn new() -> Self {
        Self {
            {% if has_id %}
            id: None,
            {% endif %}
        }
    }

    {% if has_id %}
    /// Sets the ID
    pub fn id(mut self, id: Id) -> Self {
        self.id = Some(id);
        self
    }
    {% endif %}

    /// Builds the {{ type_name }}
    pub fn build(self) -> Result<{{ type_name }}, String> {
        Ok({{ type_name }} {
            {% if has_id %}
            id: self.id.ok_or("id is required")?,
            {% endif %}
        })
    }
}
{% endif %}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_default() {
        let instance = {{ type_name }}::default();
        {% if has_id %}
        assert_eq!(instance.id, 0);
        {% endif %}
        let _ = instance;
    }

    #[test]
    fn test_new() {
        let instance = {{ type_name }}::new();
        let _ = instance;
    }

    {% if has_builder %}
    #[test]
    fn test_builder() {
        let result = {{ type_name }}Builder::new()
            {% if has_id %}
            .id(1)
            {% endif %}
            .build();
        assert!(result.is_ok());
    }

    #[test]
    fn test_builder_default() {
        let result = {{ type_name }}Builder::default().build();
        {% if has_id %}
        assert!(result.is_err());
        {% else %}
        assert!(result.is_ok());
        {% endif %}
    }
    {% endif %}

    #[test]
    fn test_validate_success() {
        let instance = {{ type_name }}::new();
        {% if has_id %}
        // validate requires id > 0, default is 0
        assert!(instance.validate().is_err());
        {% else %}
        assert!(instance.validate().is_ok());
        {% endif %}
    }

    #[test]
    fn test_fields_summary() {
        let instance = {{ type_name }}::new();
        assert!(!instance.fields_summary().is_empty());
    }
}
