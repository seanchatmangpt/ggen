// CRITICAL FACTS (rmcp 1.3.0):
//   1. #[tool_router] generates `tool_router()` fn
//   2. #[tool_handler] wires list_tools + call_tool dispatch into ServerHandler
//   3. Without #[tool_handler]: list_tools() returns empty, call_tool() returns -32601
//   4. Keep server alive: svc.waiting().await (NOT let _ = serve(...))
//   5. ToolRouter<Self> field MUST exist on the struct
// ==============================================================================

use rmcp::handler::server::router::tool::ToolRouter;
use rmcp::model::{CallToolResult, Content, Implementation, ServerCapabilities, ServerInfo};
use rmcp::schemars::JsonSchema;
use rmcp::ServerHandler;
use rmcp::ServiceExt;
use rmcp::{tool, tool_handler, tool_router};
use serde::{Deserialize, Serialize};

// ==============================================================================
// Tool index
// ==============================================================================
//
// Available tools ({{ tools | length | default(value=0) }}):
{% for tool in tools %}
//   - {{ tool.name }}: {{ tool.description | default(value="(no description)") }}
{% endfor %}

// ==============================================================================
// Input parameter structs
// ==============================================================================
// Each struct corresponds to a tool's input schema.
// schemars::JsonSchema generates the JSON Schema automatically for MCP clients.
// serde::Deserialize allows rmcp to parse incoming JSON-RPC params.

{% for tool in tools %}
/// Parameters for `{{ tool.name }}`
///
/// {{ tool.description | default(value="(no description)") }}
#[derive(Debug, Deserialize, Serialize, JsonSchema)]
pub struct {{ tool.name | pascal }}Params {
    {% for param in tool.parameters %}
    /// {{ param.description | default(value=param.name) }}
    {% if param.is_required == "true" %}
    pub {{ param.name | snake }}: {{ param.rust_type | default(value="String") }},
    {% else %}
    #[serde(default)]
    pub {{ param.name | snake }}: Option<{{ param.rust_type | default(value="String") }}>,
    {% endif %}
    {% endfor %}
}

{% endfor %}

// ==============================================================================
// Server struct
// ==============================================================================

/// MCP server: {{ server_name | default(value="mcp_server") }}
///
/// {{ server_description | default(value="Generated MCP server") }}
///
/// Generated by ggen. SDK: rmcp 1.3.0
#[derive(Debug, Clone)]
pub struct {{ server_name | default(value="McpServer") | pascal }} {
    tool_router: ToolRouter<Self>,
}

impl {{ server_name | default(value="McpServer") | pascal }} {
    /// Create a new server instance.
    pub fn new() -> Self {
        Self {
            tool_router: Self::tool_router(),
        }
    }
}

impl Default for {{ server_name | default(value="McpServer") | pascal }} {
    fn default() -> Self {
        Self::new()
    }
}

// ==============================================================================
// Tool implementations
// ==============================================================================
// #[tool_router] generates Self::tool_router() which creates a router
// that dispatches tool calls to the methods below.
//
// Each method must:
//   - Accept &self as first param
//   - Accept #[tool(aggr)] params struct as second param
//   - Return a type that implements Into<CallToolResult>
//   - Have #[tool(description = "...")] attribute

#[tool_router]
impl {{ server_name | default(value="McpServer") | pascal }} {
{% for tool in tools %}
    /// {{ tool.description | default(value=tool.name) }}
    #[tool(description = "{{ tool.description | default(value=tool.name) }}")]
    async fn {{ tool.name | snake }}(
        &self,
        #[tool(aggr)] params: {{ tool.name | pascal }}Params,
    ) -> Result<CallToolResult, rmcp::model::ServerError> {
        // TODO: implement {{ tool.name }}
        Ok(CallToolResult::success(vec![Content::text(
            format!("{{ tool.name }} executed with params: {:?}", params)
        )]))
    }

{% endfor %}
}

// ==============================================================================
// ServerHandler implementation
// ==============================================================================
// #[tool_handler] is REQUIRED on `impl ServerHandler`.
// It injects list_tools() and call_tool() delegating to the ToolRouter above.
// Without it, tools list empty and calls return -32601.

#[tool_handler]
impl ServerHandler for {{ server_name | default(value="McpServer") | pascal }} {
    fn get_info(&self) -> ServerInfo {
        ServerInfo {
            instructions: Some(
                "{{ server_description | default(value='Generated MCP server') }}".into(),
            ),
            capabilities: ServerCapabilities::builder()
                .enable_tools()
                .build(),
            server_info: Implementation {
                name: "{{ server_name | default(value='mcp-server') }}".into(),
                version: "{{ server_version | default(value='0.1.0') }}".into(),
            },
            ..Default::default()
        }
    }
}

// ==============================================================================
// Main — stdio transport
// ==============================================================================
// This server communicates via stdin/stdout using the MCP stdio transport.
// To use with HTTP or SSE, replace rmcp::transport::stdio() with the
// appropriate transport constructor.
//
// CRITICAL: svc.waiting().await keeps the server alive.
// Writing `let _ = server.serve(transport).await` drops the RunningService
// immediately and closes the connection.

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    let transport = rmcp::transport::stdio();

    let server = {{ server_name | default(value="McpServer") | pascal }}::new();

    if let Ok(svc) = server.serve(transport).await {
        svc.waiting().await?;
    }

    Ok(())
}

