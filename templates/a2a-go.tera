	Description: "{{ agent_description }}",
	URL:         "{{ agent_url }}",
	Version:     "{{ agent_version }}",
	Provider: AgentProvider{
		Name: "{{ provider_name }}",
		URL:  "{{ provider_url }}",
	},
	Skills: []AgentSkill{
		{% for skill in skills %}
		{
			ID:          "{{ skill.id | default(value=skill.name) }}",
			Name:        "{{ skill.name }}",
			Description: "{{ skill.description }}",
			Tags:        {{ skill.tags | default(value="[]string{}") }},
			Streaming:   false,
			InputSchema: {{ skill.input_schema | default(value="map[string]interface{}{}") }},
			OutputSchema: {{ skill.output_schema | default(value="map[string]interface{}{}") }},
		},
		{% endfor %}
	},
}

