// ============================================================================
// JSON-RPC 2.0 Types
// ============================================================================

type JsonRpcRequest struct {
	Jsonrpc string                 `json:"jsonrpc"`
	Method  string                 `json:"method"`
	Params  map[string]interface{} `json:"params,omitempty"`
	ID      interface{}            `json:"id,omitempty"`
}

type JsonRpcResponse struct {
	Jsonrpc string      `json:"jsonrpc"`
	Result  interface{} `json:"result,omitempty"`
	Error   *RpcError   `json:"error,omitempty"`
	ID      interface{} `json:"id"`
}

type RpcError struct {
	Code    int         `json:"code"`
	Message string      `json:"message"`
	Data    interface{} `json:"data,omitempty"`
}

// ============================================================================
// HTTP Handlers
// ============================================================================

// agentCardHandler serves the agent card at /.well-known/agent.json
func agentCardHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
		return
	}
	w.Header().Set("Content-Type", "application/json")
	if err := json.NewEncoder(w).Encode(agentCard); err != nil {
		http.Error(w, "Failed to encode agent card", http.StatusInternalServerError)
	}
}

// messageHandler processes JSON-RPC 2.0 requests on /a2a/message
func messageHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
		return
	}

	var req JsonRpcRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		writeRpcError(w, nil, -32700, "Parse error: "+err.Error())
		return
	}

	if req.Jsonrpc != "2.0" {
		writeRpcError(w, req.ID, -32600, "Invalid Request: jsonrpc must be '2.0'")
		return
	}

	entry, ok := skillRegistry[req.Method]
	if !ok {
		writeRpcError(w, req.ID, -32601, fmt.Sprintf("Method not found: %s", req.Method))
		return
	}

	params := req.Params
	if params == nil {
		params = make(map[string]interface{})
	}

	// Execute with timeout
	type handlerResult struct {
		result interface{}
		err    error
	}
	ch := make(chan handlerResult, 1)
	go func() {
		result, err := entry.Handler(params)
		ch <- handlerResult{result: result, err: err}
	}()

	select {
	case hr := <-ch:
		if hr.err != nil {
			writeRpcError(w, req.ID, -32000, hr.err.Error())
			return
		}
		writeRpcResult(w, req.ID, hr.result)
	case <-time.After(time.Duration(entry.TimeoutMs) * time.Millisecond):
		writeRpcError(w, req.ID, -32001, fmt.Sprintf("Skill %s timed out after %dms", req.Method, entry.TimeoutMs))
	}
}

// streamHandler handles SSE streaming for streaming-capable skills
func streamHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
		return
	}

	var req JsonRpcRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		http.Error(w, "Parse error", http.StatusBadRequest)
		return
	}

	entry, ok := skillRegistry[req.Method]
	if !ok {
		http.Error(w, fmt.Sprintf("Unknown skill: %s", req.Method), http.StatusNotFound)
		return
	}

	if !entry.Streaming {
		http.Error(w, fmt.Sprintf("Skill %s does not support streaming", req.Method), http.StatusBadRequest)
		return
	}

	w.Header().Set("Content-Type", "text/event-stream")
	w.Header().Set("Cache-Control", "no-cache")
	w.Header().Set("Connection", "keep-alive")
	w.WriteHeader(http.StatusOK)

	flusher, ok := w.(http.Flusher)
	if !ok {
		http.Error(w, "Streaming not supported", http.StatusInternalServerError)
		return
	}

	params := req.Params
	if params == nil {
		params = make(map[string]interface{})
	}

	result, err := entry.Handler(params)
	if err != nil {
		errData, _ := json.Marshal(map[string]string{"error": err.Error()})
		fmt.Fprintf(w, "data: %s\n\n", errData)
		flusher.Flush()
		return
	}

	resultData, _ := json.Marshal(map[string]interface{}{"result": result})
	fmt.Fprintf(w, "data: %s\n\n", resultData)
	fmt.Fprintf(w, "data: [DONE]\n\n")
	flusher.Flush()
}

// taskGetHandler returns a single task by ID
func taskGetHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
		return
	}

	id := r.PathValue("id")
	if id == "" {
		http.Error(w, "Task ID required", http.StatusBadRequest)
		return
	}

	val, ok := tasks.Load(id)
	if !ok {
		http.Error(w, fmt.Sprintf("Task not found: %s", id), http.StatusNotFound)
		return
	}
	writeJSON(w, val)
}

// taskCancelHandler cancels a task by ID
func taskCancelHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
		return
	}

	id := r.PathValue("id")
	if id == "" {
		http.Error(w, "Task ID required", http.StatusBadRequest)
		return
	}

	val, ok := tasks.Load(id)
	if !ok {
		http.Error(w, fmt.Sprintf("Task not found: %s", id), http.StatusNotFound)
		return
	}

	taskMu.Lock()
	defer taskMu.Unlock()

	task := val.(*Task)
	if task.Status == "completed" || task.Status == "cancelled" {
		http.Error(w, fmt.Sprintf("Task %s, cannot cancel", task.Status), http.StatusConflict)
		return
	}
	task.Status = "cancelled"
	task.UpdatedAt = time.Now().UnixMilli()
	writeJSON(w, task)
}

// taskListHandler lists all tasks
func taskListHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
		return
	}

	var allTasks []*Task
	tasks.Range(func(_, value interface{}) bool {
		allTasks = append(allTasks, value.(*Task))
		return true
	})
	writeJSON(w, map[string]interface{}{"tasks": allTasks})
}

// healthHandler returns agent health status
func healthHandler(w http.ResponseWriter, r *http.Request) {
	writeJSON(w, map[string]interface{}{
		"agent":   agentCard.Name,
		"version": agentCard.Version,
		"status":  "ok",
	})
}

// ============================================================================
// Response Helpers
// ============================================================================

func writeJSON(w http.ResponseWriter, data interface{}) {
	w.Header().Set("Content-Type", "application/json")
	if err := json.NewEncoder(w).Encode(data); err != nil {
		http.Error(w, "Failed to encode response", http.StatusInternalServerError)
	}
}

func writeRpcResult(w http.ResponseWriter, id interface{}, result interface{}) {
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(JsonRpcResponse{
		Jsonrpc: "2.0",
		Result:  result,
		ID:      id,
	})
}

func writeRpcError(w http.ResponseWriter, id interface{}, code int, message string) {
	w.Header().Set("Content-Type", "application/json")
	statusCode := http.StatusInternalServerError
	switch code {
	case -32700, -32600:
		statusCode = http.StatusBadRequest
	case -32601:
		statusCode = http.StatusNotFound
	}
	w.WriteHeader(statusCode)
	json.NewEncoder(w).Encode(JsonRpcResponse{
		Jsonrpc: "2.0",
		Error:   &RpcError{Code: code, Message: message},
		ID:      id,
	})
}

// ============================================================================
// Main
// ============================================================================

func main() {
	mux := http.NewServeMux()
	mux.HandleFunc("/.well-known/agent.json", agentCardHandler)
	mux.HandleFunc("/a2a/message", messageHandler)
	mux.HandleFunc("/a2a/stream", streamHandler)
	mux.HandleFunc("/a2a/tasks/{id}", taskGetHandler)
	mux.HandleFunc("/a2a/tasks/{id}/cancel", taskCancelHandler)
	mux.HandleFunc("/a2a/tasks", taskListHandler)
	mux.HandleFunc("/health", healthHandler)

	addr := ":{{ agent_port | default(value=8089) }}"
	log.Printf("[%s] A2A agent listening on %s", agentCard.Name, addr)
	log.Printf("[%s] Agent card: http://localhost%s/.well-known/agent.json", agentCard.Name, addr)
	log.Printf("[%s] Skills: %v", agentCard.Name, skillNames())

	if err := http.ListenAndServe(addr, mux); err != nil {
		log.Fatalf("[%s] Server failed: %v", agentCard.Name, err)
	}
}

func skillNames() []string {
	names := make([]string, 0, len(skillRegistry))
	for name := range skillRegistry {
		names = append(names, name)
	}
	return names
}

