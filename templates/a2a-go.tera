// ============================================================================
// WebSocket Transport
// ============================================================================

var upgrader = websocket.Upgrader{
	ReadBufferSize:  1024,
	WriteBufferSize: 1024,
	CheckOrigin: func(r *http.Request) bool {
		return true // Allow all origins in development
	},
}

type WebSocketTransport struct {
	url      string
	conn     *websocket.Conn
	mu       sync.Mutex
	retryMax int
}

func NewWebSocketTransport(url string) *WebSocketTransport {
	return &WebSocketTransport{
		url:      url,
		retryMax: 3,
	}
}

// Connect establishes WebSocket connection with retry logic
func (ws *WebSocketTransport) Connect() error {
	var err error
	retryCount := 0

	for retryCount < ws.retryMax {
		ws.conn, _, err = websocket.DefaultDialer.Dial(ws.url, nil)
		if err == nil {
			log.Printf("Connected to WebSocket: %s", ws.url)
			return nil
		}

		retryCount++
		log.Printf("WebSocket connection attempt %d failed: %v, retrying...", retryCount, err)
		time.Sleep(time.Duration(retryCount) * time.Second)
	}

	return fmt.Errorf("WebSocket connection failed after %d attempts: %v", ws.retryMax, err)
}

// Send sends a message through WebSocket
func (ws *WebSocketTransport) Send(data []byte) error {
	ws.mu.Lock()
	defer ws.mu.Unlock()

	if ws.conn == nil {
		return fmt.Errorf("WebSocket not connected")
	}

	err := ws.conn.WriteMessage(websocket.TextMessage, data)
	if err != nil {
		return fmt.Errorf("failed to send WebSocket message: %v", err)
	}

	return nil
}

// Receive receives a message from WebSocket with timeout
func (ws *WebSocketTransport) Receive() ([]byte, error) {
	if ws.conn == nil {
		return nil, fmt.Errorf("WebSocket not connected")
	}

	// Set read deadline for timeout
	ws.conn.SetReadDeadline(time.Now().Add(30 * time.Second))

	messageType, data, err := ws.conn.ReadMessage()
	if err != nil {
		return nil, fmt.Errorf("failed to receive WebSocket message: %v", err)
	}

	if messageType != websocket.TextMessage && messageType != websocket.BinaryMessage {
		return nil, fmt.Errorf("unexpected WebSocket message type: %d", messageType)
	}

	return data, nil
}

// Close closes the WebSocket connection
func (ws *WebSocketTransport) Close() error {
	ws.mu.Lock()
	defer ws.mu.Unlock()

	if ws.conn != nil {
		return ws.conn.Close()
	}
	return nil
}

