// {{ tool.description }}
type {{ tool.name | pascal_case }}Input struct {
	{% for param in tool.parameters %}
	{{ param.name | pascal_case }} {{ param.go_type }} `json:"{{ param.name }}"{% if param.required != "true" %},omitempty{% endif %}` // {{ param.description }}
	{% endfor %}
}

{% endfor %}

