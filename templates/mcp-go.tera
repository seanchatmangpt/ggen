{% for tool in tools %}
// handle{{ tool.name | pascal_case }} implements the {{ tool.name }} tool
func handle{{ tool.name | pascal_case }}(params json.RawMessage) (interface{}, error) {
	var input {{ tool.name | pascal_case }}Input
	if err := json.Unmarshal(params, &input); err != nil {
		return nil, fmt.Errorf("invalid params for {{ tool.name }}: %w", err)
