// =============================================================================
// Server
// =============================================================================

// MCPServer handles MCP protocol over stdio
type MCPServer struct {
	Name    string
	Version string
}

// NewMCPServer creates a new MCP server instance
func NewMCPServer(name, version string) *MCPServer {
	return &MCPServer{
		Name:    name,
		Version: version,
	}
}

// HandleRequest dispatches a JSON-RPC request to the appropriate handler
func (s *MCPServer) HandleRequest(req JsonRpcRequest) JsonRpcResponse {
	switch req.Method {
	case "initialize":
		return s.handleInitialize()
	case "notifications/initialized":
		return JsonRpcResponse{Jsonrpc: "2.0", ID: req.ID, Result: map[string]interface{}{}}
	case "tools/list":
		return s.handleListTools()
	case "tools/call":
		return s.handleCallTool(req.Params)
	default:
		return JsonRpcResponse{
			Jsonrpc: "2.0",
			ID:      req.ID,
			Error:   &JsonRpcError{Code: -32601, Message: fmt.Sprintf("Method not found: %s", req.Method)},
		}
	}
}

// handleInitialize responds to the initialize request
func (s *MCPServer) handleInitialize() JsonRpcResponse {
	return JsonRpcResponse{
		Jsonrpc: "2.0",
		Result: map[string]interface{}{
			"protocolVersion": "2024-11-05",
			"capabilities": map[string]interface{}{
				"tools": map[string]interface{}{
					"listChanged": false,
				},
			},
			"serverInfo": map[string]interface{}{
				"name":    s.Name,
				"version": s.Version,
			},
		},
	}
}

// handleListTools returns the list of available tools
func (s *MCPServer) handleListTools() JsonRpcResponse {
	tools := []ToolDefinition{
		{% for tool in tools %}
		{
			Name:        "{{ tool.name }}",
			Description: "{{ tool.description }}",
			InputSchema: s.{{ tool.name | camel_case }}Schema(),
		},
		{% endfor %}
	}

	return JsonRpcResponse{
		Jsonrpc: "2.0",
		Result: map[string]interface{}{
			"tools": tools,
		},
	}
}

{% for tool in tools %}
// {{ tool.name | camel_case }}Schema returns the JSON Schema for {{ tool.name }} input
func (s *MCPServer) {{ tool.name | camel_case }}Schema() map[string]interface{} {
	props := map[string]interface{}{}
	required := []string{}
	{% for param in tool.parameters %}
	{% if param.required == "true" %}
	required = append(required, "{{ param.name }}")
	{% endif %}
	props["{{ param.name }}"] = map[string]interface{}{
		"type":        "{{ param.jsonSchemaType | default(value=param.go_json_type) }}",
		"description": "{{ param.description }}",
		{% if param.enumValues %}
		"enum": []string{ {{ param.enumValues }} },
		{% endif %}
	}
	{% endfor %}

	schema := map[string]interface{}{
		"type":       "object",
		"properties": props,
	}
	if len(required) > 0 {
		schema["required"] = required
	}
	return schema
}

{% endfor %}

// handleCallTool dispatches tool invocations
func (s *MCPServer) handleCallTool(params json.RawMessage) JsonRpcResponse {
	var callParams struct {
		Name      string          `json:"name"`
		Arguments json.RawMessage `json:"arguments"`
	}
	if err := json.Unmarshal(params, &callParams); err != nil {
		return JsonRpcResponse{
			Jsonrpc: "2.0",
			Error:   &JsonRpcError{Code: -32602, Message: fmt.Sprintf("Invalid params: %s", err)},
		}
	}

	args := callParams.Arguments
	if args == nil {
		args = json.RawMessage(`{}`)
	}

	var result interface{}
	var err error

	switch callParams.Name {
	{% for tool in tools %}
	case "{{ tool.name }}":
		result, err = handle{{ tool.name | pascal_case }}(args)
	{% endfor %}
	default:
		return JsonRpcResponse{
			Jsonrpc: "2.0",
			Result: ToolResult{
				Content: []ToolContent{{Type: "text", Text: fmt.Sprintf("Unknown tool: %s", callParams.Name)}},
				IsError: true,
			},
		}
	}

	if err != nil {
		return JsonRpcResponse{
			Jsonrpc: "2.0",
			Result: ToolResult{
				Content: []ToolContent{{Type: "text", Text: err.Error()}},
				IsError: true,
			},
		}
	}

	return JsonRpcResponse{
		Jsonrpc: "2.0",
		Result:  result,
	}
}

// =============================================================================
// Stdio Transport Loop
// =============================================================================

// Run starts the stdio JSON-RPC event loop
func (s *MCPServer) Run() error {
	decoder := json.NewDecoder(os.Stdin)
	encoder := json.NewEncoder(os.Stdout)

	for {
		var req JsonRpcRequest
		if err := decoder.Decode(&req); err != nil {
			if err == io.EOF {
				return nil
			}
			// Write parse error response
			resp := JsonRpcResponse{
				Jsonrpc: "2.0",
				Error:   &JsonRpcError{Code: -32700, Message: fmt.Sprintf("Parse error: %s", err)},
			}
			_ = encoder.Encode(resp)
			continue
		}

		resp := s.HandleRequest(req)
		if err := encoder.Encode(resp); err != nil {
			return fmt.Errorf("write response error: %w", err)
		}
	}
}

// =============================================================================
// Main
// =============================================================================

func main() {
	server := NewMCPServer("{{ serverName }}", "{{ serverVersion }}")
	if err := server.Run(); err != nil {
		fmt.Fprintf(os.Stderr, "{{ serverName }} MCP server error: %s\n", err)
		os.Exit(1)
	}
}
