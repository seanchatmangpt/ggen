defmodule {{agent.0.appModule}}.Agents.Router do
  @moduledoc """
  Router for A2A agents.
  """

  use Plug.Router

  plug Plug.Parsers, parsers: [:json], pass: ["application/json"], json_decoder: Jason
  plug A2A.Plug
  plug :match
  plug :dispatch

{% for agent in agents %}
  forward "/{{agent.path}}", to: {{agent.appModule}}.Agents.{{agent.agentName | title | replace: "-", ""}}
{% endfor %}

  match _ do
    send_resp(conn, 404, "Not Found")
  end
end
