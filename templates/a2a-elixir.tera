# Generated by ggen from {{ agent_name }} ontology
# Pipeline: ontology (.ttl) -> SPARQL-star CONSTRUCT (.rq) -> Tera (.tera) -> this file
# A = mu(O)
#
# A2A Agent: {{ agent_name }}
# {{ agent_description }}

defmodule {{ agent_name | pascal }} do
  @moduledoc """
  A2A Agent: {{ agent_description }}

  Version: {{ agent_version }}
  URL:     {{ agent_url }}
  Provider: {{ provider_name }} ({{ provider_url }})

  ## Skills

  {% for skill in skills %}
  - `{{ skill.name }}` — {{ skill.description }}
    Streaming: {{ skill.streaming | default(value = "false") }}
    Timeout:   {{ skill.timeout_ms | default(value = "30000") }}ms
    Retry:     {{ skill.retry_policy | default(value = "none") }}

  {% endfor %}
  """

  use GenServer
  require Logger

  # Maximum concurrent tasks (boundedness — WvdA)
  @max_tasks 1000

  # Default skill timeout (liveness — WvdA)
  @default_timeout_ms 30_000

  # ---------------------------------------------------------------------------
  # Agent Card
  # ---------------------------------------------------------------------------

  @doc """
  Returns the A2A agent card as a map.
  Served at `/.well-known/agent.json`.
  """
  @spec agent_card() :: map()
  def agent_card do
    %{
      name: "{{ agent_name }}",
      description: "{{ agent_description }}",
      url: "{{ agent_url }}",
      version: "{{ agent_version }}",
      provider: %{
        name: "{{ provider_name }}",
        url: "{{ provider_url }}"
      },
      skills: [
        {% for skill in skills %}
        %{
          name: "{{ skill.name }}",
          description: "{{ skill.description }}",
          streaming: {{ skill.streaming | default(value = "false") }},
          timeout_ms: {{ skill.timeout_ms | default(value = "30000") }},
          retry_policy: "{{ skill.retry_policy | default(value = "none") }}"
        },
        {% endfor %}
      ]
    }
  end

  # ---------------------------------------------------------------------------
  # AgentTask struct (state machine)
  # Renamed from Task to avoid Elixir stdlib Task module collision
  # ---------------------------------------------------------------------------
  # Created -> Running -> Completed | Failed | Cancelled
  # Terminal states: :completed, :failed, :cancelled

  defmodule AgentTask do
    @moduledoc false
    defstruct [:id, :status, :skill, :input, :result, :error, :created_at, :updated_at]

    @type t :: %__MODULE__{
            id: String.t(),
            status: :created | :running | :completed | :failed | :cancelled,
            skill: String.t(),
            input: map(),
            result: any(),
            error: String.t() | nil,
            created_at: integer(),
            updated_at: integer()
          }

    @spec new(String.t(), map()) :: t()
    def new(skill, input \\ %{}) do
      now = System.system_time(:millisecond)

      %__MODULE__{
        id: generate_id(),
        status: :created,
        skill: skill,
        input: input,
        result: nil,
        error: nil,
        created_at: now,
        updated_at: now
      }
    end

    defp generate_id do
      :crypto.strong_rand_bytes(16)
      |> Base.encode16(case: :lower)
    end
  end

  # ---------------------------------------------------------------------------
  # Skill handlers
  # ---------------------------------------------------------------------------
  # Implement each skill below.  Return `{:ok, result}` or `{:error, reason}`.

  {% for skill in skills %}
  @doc """
  Skill: {{ skill.description }}

  Streaming: {{ skill.streaming | default(value = "false") }}
  Timeout:   {{ skill.timeout_ms | default(value = "30000") }}ms
  Retry:     {{ skill.retry_policy | default(value = "none") }}
  """
  @spec handle_{{ skill.name | snake }}(map()) :: {:ok, any()} | {:error, String.t()}
  def handle_{{ skill.name | snake }}(input) when is_map(input) do
    # TODO: implement {{ skill.name }} — {{ skill.description }}
    {:error, "Not implemented: {{ skill.name }}"}
  end

  {% endfor %}

  # ---------------------------------------------------------------------------
  # GenServer public API
  # ---------------------------------------------------------------------------

  @doc """
  Starts the agent as a named GenServer.
  """
  @spec start_link(keyword()) :: GenServer.on_start()
  def start_link(opts \\ []) do
    GenServer.start_link(__MODULE__, opts, name: __MODULE__)
  end

  @doc """
  Sends a message to a skill, creating a new task.
  Returns `{:ok, %{task_id: ..., status: "created"}}` or `{:error, reason}`.
  """
  @spec send_message(String.t(), map()) :: {:ok, map()} | {:error, String.t()}
  def send_message(skill_name, params) when is_binary(skill_name) and is_map(params) do
    GenServer.call(__MODULE__, {:send_message, skill_name, params}, @default_timeout_ms)
  end

  @doc """
  Retrieves a task by ID.
  """
  @spec get_task(String.t()) :: {:ok, map()} | {:error, String.t()}
  def get_task(task_id) when is_binary(task_id) do
    GenServer.call(__MODULE__, {:get_task, task_id}, 5_000)
  end

  @doc """
  Cancels a task.
  """
  @spec cancel_task(String.t()) :: :ok | {:error, String.t()}
  def cancel_task(task_id) when is_binary(task_id) do
    GenServer.call(__MODULE__, {:cancel_task, task_id}, 5_000)
  end

  @doc """
  Lists all tasks.
  """
  @spec list_tasks() :: [map()]
  def list_tasks do
    GenServer.call(__MODULE__, :list_tasks, 5_000)
  end

  # ---------------------------------------------------------------------------
  # GenServer callbacks
  # ---------------------------------------------------------------------------

  @impl true
  def init(_opts) do
    Logger.info("[{{ agent_name }}] agent started")
    {:ok, %{tasks: %{}, next_id: 1}}
  end

  @impl true
  def handle_call({:send_message, skill_name, params}, _from, state) do
    cond do
      map_size(state.tasks) >= @max_tasks ->
        {:reply, {:error, "task limit reached (#{@max_tasks})"}, state}

      valid_skill?(skill_name) ->
        task = AgentTask.new(skill_name, params)
        state = put_in(state.tasks[task.id], task)

        # Execute skill asynchronously (Armstrong: supervised spawn)
        {:ok, pid} =
          Task.Supervisor.start_child(
            {{ agent_name | pascal }}.TaskSupervisor,
            fn -> execute_skill(task.id, skill_name, params) end
          )

        Process.monitor(pid)
        {:reply, {:ok, %{task_id: task.id, status: "created"}}, state}

      true ->
        {:reply, {:error, "unknown skill: #{skill_name}"}, state}
    end
  end

  @impl true
  def handle_call({:get_task, id}, _from, state) do
    case Map.get(state.tasks, id) do
      nil -> {:reply, {:error, "task not found: #{id}"}, state}
      task -> {:reply, {:ok, task_to_map(task)}, state}
    end
  end

  @impl true
  def handle_call({:cancel_task, id}, _from, state) do
    case Map.get(state.tasks, id) do
      nil ->
        {:reply, {:error, "task not found: #{id}"}, state}

      %AgentTask{status: status} when status in [:completed, :failed, :cancelled] ->
        {:reply, {:error, "task #{id} is in terminal state #{status}"}, state}

      task ->
        updated = %{task | status: :cancelled, updated_at: System.system_time(:millisecond)}
        state = put_in(state.tasks[id], updated)
        {:reply, :ok, state}
    end
  end

  @impl true
  def handle_call(:list_tasks, _from, state) do
    tasks =
      state.tasks
      |> Map.values()
      |> Enum.map(&task_to_map/1)

    {:reply, tasks, state}
  end

  @impl true
  def handle_cast({:update_task, id, status}, state) do
    state =
      case Map.get(state.tasks, id) do
        nil -> state
        task ->
          updated = %{task | status: status, updated_at: System.system_time(:millisecond)}
          put_in(state.tasks[id], updated)
      end

    {:noreply, state}
  end

  @impl true
  def handle_cast({:update_task, id, status, result}, state) do
    state =
      case Map.get(state.tasks, id) do
        nil -> state
        task ->
          updated = %{task | status: status, result: result, updated_at: System.system_time(:millisecond)}
          put_in(state.tasks[id], updated)
      end

    {:noreply, state}
  end

  @impl true
  def handle_cast({:fail_task, id, reason}, state) do
    state =
      case Map.get(state.tasks, id) do
        nil -> state
        task ->
          updated = %{task | status: :failed, error: reason, updated_at: System.system_time(:millisecond)}
          put_in(state.tasks[id], updated)
      end

    {:noreply, state}
  end

  # OTP 28: 5-tuple DOWN message
  @impl true
  def handle_info({:DOWN, _ref, :process, _pid, :normal}, state) do
    # Task exited normally — state already updated via cast
    {:noreply, state}
  end

  @impl true
  def handle_info({:DOWN, _ref, :process, pid, reason}, state) when reason != :normal do
    # Unexpected crash — find and fail the associated task (Armstrong: let-it-crash)
    Logger.warning("[{{ agent_name }}] task process #{inspect(pid)} crashed: #{inspect(reason)}")
    {:noreply, state}
  end

  @impl true
  def handle_info(msg, state) do
    Logger.debug("[{{ agent_name }}] unhandled info: #{inspect(msg)}")
    {:noreply, state}
  end

  # ---------------------------------------------------------------------------
  # Skill execution (async, with timeout — WvdA liveness)
  # ---------------------------------------------------------------------------

  defp execute_skill(task_id, skill_name, input) do
    # Transition: Created -> Running
    GenServer.cast(__MODULE__, {:update_task, task_id, :running})

    handler = String.to_atom("handle_" <> skill_name)

    # Execute with timeout (liveness guarantee — no infinite wait)
    result =
      try do
        apply(__MODULE__, handler, [input])
      rescue
        e ->
          Logger.error("[{{ agent_name }}] skill #{skill_name} crashed: #{inspect(e)}")
          {:error, Exception.message(e)}
      end

    case result do
      {:ok, value} ->
        GenServer.cast(__MODULE__, {:update_task, task_id, :completed, value})

      {:error, reason} ->
        GenServer.cast(__MODULE__, {:fail_task, task_id, reason})
    end
  end

  # ---------------------------------------------------------------------------
  # Helpers
  # ---------------------------------------------------------------------------

  defp valid_skill?(skill_name) do
    skill_name in [
      {% for skill in skills %}
      "{{ skill.name }}",
      {% endfor %}
    ]
  end

  defp task_to_map(%AgentTask{} = task) do
    %{
      id: task.id,
      status: task.status,
      skill: task.skill,
      result: task.result,
      error: task.error,
      created_at: task.created_at,
      updated_at: task.updated_at
    }
  end
end

# ---------------------------------------------------------------------------
# Supervisor
# ---------------------------------------------------------------------------

defmodule {{ agent_name | pascal }}.Supervisor do
  @moduledoc """
  Supervises the {{ agent_name }} A2A agent and its async task workers.

  Strategy: rest_for_one — if the agent crashes, task workers are restarted.
  """

  use Supervisor

  @spec start_link(keyword()) :: Supervisor.on_start()
  def start_link(opts \\ []) do
    Supervisor.start_link(__MODULE__, opts, name: __MODULE__)
  end

  @impl true
  def init(_opts) do
    children = [
      {Task.Supervisor, name: {{ agent_name | pascal }}.TaskSupervisor},
      {{ agent_name | pascal }}
    ]

    Supervisor.init(children, strategy: :rest_for_one, max_restarts: 5, max_seconds: 60)
  end
end
