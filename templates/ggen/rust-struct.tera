{# rust-struct.tera: Concise Rust struct generator from annotated ontology axioms #}
{# A = mu(O) — Artifacts are projections of ontologies via transformation functions #}
{# Input: field_mappings — array from codegen-annotations-extract.rq CONSTRUCT output #}
{# Each object: class_name, field_name, field_range, rust_type, json_key, required, #}
{#              validator, deprecated, since_version, doc_comment, serde_attr, #}
{#              default_value, precision, minimum, maximum #}

// Generated by ggen from {{ ontology | default(value="RDF 1.2 triple-term annotated ontology") }}
// Pipeline: ontology (.ttl) -> SPARQL-star CONSTRUCT (.rq) -> Tera template (.tera) -> this file
// A = mu(O) — Artifacts are projections of ontologies

{% set seen_classes = [] %}

{% for field in field_mappings %}
{% if seen_classes is not containing(field.class_name) %}
{% if seen_classes | length > 0 %}

{% endif %}
{% set _ = seen_classes.append(field.class_name) %}

/// {{ field.class_name }} — generated from ontology axiom
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct {{ field.class_name }} {
{% endif %}

{% if field.doc_comment %}
    /// {{ field.doc_comment }}{% if field.validator %} Validated by: `{{ field.validator }}()`.{% endif %}{% if field.deprecated == "true" %} **Deprecated** since v{{ field.since_version | default(value="?") }}.{% endif %}
{% endif %}
{% if field.deprecated == "true" %}
    #[deprecated(since = "{{ field.since_version | default(value="unknown") }}")]
{% endif %}
{% if field.serde_attr %}
    {{ field.serde_attr }}
{% elif field.json_key and field.json_key != field.field_name %}
    #[serde(rename = "{{ field.json_key }}")]
{% endif %}
{% if field.default_value and field.required != "true" %}
    #[serde(default = "{{ field.default_value }}")]
{% elif field.default_value %}
    #[serde(default = "{{ field.default_value }}")]
{% endif %}
{% if field.required == "true" %}
    pub {{ field.field_name }}: {{ field.rust_type }},
{% else %}
    pub {{ field.field_name }}: Option<{{ field.rust_type }}>,
{% endif %}
{% endfor %}
}

{% for field in field_mappings %}
{% if field.precision or field.minimum or field.maximum %}
{% set ns = namespace(has_constraints=false) %}
{% break %}
{% endif %}
{% endfor %}
{% for field in field_mappings %}
{% if field.precision or field.minimum or field.maximum %}
{% set ns.has_constraints = true %}
{% break %}
{% endif %}
{% endfor %}
{% if ns.has_constraints %}

// Validation constraints:
{% for field in field_mappings %}
{% if field.precision %}//   {{ field.class_name }}.{{ field.field_name }}: precision={{ field.precision }}
{% endif %}
{% if field.minimum %}//   {{ field.class_name }}.{{ field.field_name }}: min={{ field.minimum }}
{% endif %}
{% if field.maximum %}//   {{ field.class_name }}.{{ field.field_name }}: max={{ field.maximum }}
{% endif %}
{% endfor %}
{% endif %}
