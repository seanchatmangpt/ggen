    @GetMapping(value = "/a2a/.well-known/agent.json", produces = MediaType.APPLICATION_JSON_VALUE)
    public AgentCard agentCard() {
        return new AgentCard(
            "{{ agent_name }}",
            "{{ agent_description }}",
            "{{ agent_url }}",
            "{{ agent_version }}",
            new AgentProvider("{{ provider_name }}", "{{ provider_url }}"),
            List.of(
                {% for row in sparql_results %}
                new AgentSkill(
                    "{{ row.skill_name }}",
                    "{{ row.skill_name }}",
                    "{{ row.skill_description | default(value="") }}",
                    {{ row.skill_tags | default(value="List.of()") | replace(from="[", to="List.of(") | replace(from="]", to=")") | replace(from='"', to='"') }},
                    {{ row.streaming | default(value="false") }},
                    Map.of(),
                    Map.of()
                ){% if not loop.last %},{% endif %}
                {% endfor %}
            )
        );
    }

    // ========================================================================
    // JSON-RPC Message Handler
    // ========================================================================

    @PostMapping(value = "/message", produces = MediaType.APPLICATION_JSON_VALUE,
                 consumes = MediaType.APPLICATION_JSON_VALUE)
    public JsonRpcResponse handleMessage(@RequestBody JsonRpcRequest request) {
        // Validate JSON-RPC version
        if (!"2.0".equals(request.jsonrpc())) {
            return new JsonRpcResponse("2.0", null,
                new RpcError(-32600, "Invalid Request: jsonrpc must be '2.0'", null),
                request.id());
        }

        // Dispatch to skill handler
        return switch (request.method()) {
            {% for row in sparql_results %}
            case "{{ row.skill_name }}" -> {
                try {
                    Object result = handle{{ row.skill_name | pascal }}(request.params());
                    yield new JsonRpcResponse("2.0", result, null, request.id());
                } catch (Exception e) {
                    yield new JsonRpcResponse("2.0", null,
                        new RpcError(-32000, e.getMessage(), null), request.id());
                }
            }
            {% endfor %}
            default -> new JsonRpcResponse("2.0", null,
                new RpcError(-32601, "Method not found: " + request.method(), null),
                request.id());
        };
    }

    // ========================================================================
    // Skill Handlers
    // ========================================================================

    {% for row in sparql_results %}
    /**
     * Handle {{ row.skill_name }} skill invocation.
     *
     * {{ row.skill_description | default(value=row.skill_name) }}
     *
     * @param params raw input parameters from JSON-RPC request
     * @return skill output
     */
    public Object handle{{ row.skill_name | pascal }}(Map<String, Object> params) {
        {% if row.generated_impl %}
        {{ row.generated_impl }}
        {% else %}
        // TODO: implement {{ row.skill_name }}
        // Timeout: {{ row.timeout_ms | default(value=5000) }}ms
        throw new UnsupportedOperationException("Not implemented: {{ row.skill_name }}");
        {% endif %}
    }
    {% endfor %}

    // ========================================================================
    // Task Lifecycle
    // ========================================================================

    @GetMapping(value = "/tasks/{id}", produces = MediaType.APPLICATION_JSON_VALUE)
    public ResponseEntity<?> getTask(@PathVariable String id) {
        Task task = tasks.get(id);
        if (task == null) {
            return ResponseEntity.status(HttpStatus.NOT_FOUND)
                .body(Map.of("error", "Task not found: " + id));
        }
        return ResponseEntity.ok(task);
    }

    @PostMapping(value = "/tasks/{id}/cancel", produces = MediaType.APPLICATION_JSON_VALUE)
    public ResponseEntity<?> cancelTask(@PathVariable String id) {
        Task task = tasks.get(id);
        if (task == null) {
            return ResponseEntity.status(HttpStatus.NOT_FOUND)
                .body(Map.of("error", "Task not found: " + id));
        }
        if ("completed".equals(task.status()) || "cancelled".equals(task.status())) {
            return ResponseEntity.status(HttpStatus.CONFLICT)
                .body(Map.of("error", "Task " + task.status() + ", cannot cancel"));
        }
        Task cancelled = new Task(task.id(), "cancelled", null, null,
            task.createdAt(), Instant.now().toEpochMilli());
        tasks.put(id, cancelled);
        return ResponseEntity.ok(cancelled);
    }

    @GetMapping(value = "/tasks", produces = MediaType.APPLICATION_JSON_VALUE)
    public Map<String, Object> listTasks() {
        List<Task> allTasks = tasks.values().stream()
            .sorted(Comparator.comparingLong(Task::createdAt).reversed())
            .toList();
        return Map.of("tasks", allTasks);
    }

    // ========================================================================
    // Health Check
    // ========================================================================

    @GetMapping(value = "/health", produces = MediaType.APPLICATION_JSON_VALUE)
    public Map<String, Object> health() {
        return Map.of(
            "agent", "{{ agent_name }}",
            "version", "{{ agent_version }}",
            "status", "ok",
            "tasks", tasks.size()
        );
    }

}

