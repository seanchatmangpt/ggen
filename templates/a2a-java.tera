@JsonInclude(JsonInclude.Include.NON_NULL)
record JsonRpcRequest(
    String jsonrpc,
    String method,
    Map<String, Object> params,
    Object id
) {}

@JsonInclude(JsonInclude.Include.NON_NULL)
record RpcError(int code, String message, Object data) {}

@JsonInclude(JsonInclude.Include.NON_NULL)
record JsonRpcResponse(
    String jsonrpc,
    Object result,
    RpcError error,
    Object id
) {}

// ============================================================================
// WebSocket Transport
// ============================================================================

class WebSocketTransport {
    private final String url;
    private WebSocketClient client;
    private static final int MAX_RETRIES = 3;
    private static final int CONNECTION_TIMEOUT_MS = 5000;

    public WebSocketTransport(String url) {
        this.url = url;
    }

    public void connect() throws Exception {
        int retryCount = 0;
        while (retryCount < MAX_RETRIES) {
            try {
                client = new WebSocketClient(new URI(url)) {
                    @Override
                    public void onOpen(ServerHandshake handshake) {
                        System.out.println("Connected to WebSocket: " + url);
                    }

                    @Override
                    public void onMessage(String message) {
                        // Handle incoming messages
                    }

                    @Override
                    public void onClose(int code, String reason, boolean remote) {
                        System.out.println("WebSocket connection closed: " + reason);
                    }

                    @Override
                    public void onError(Exception ex) {
                        System.err.println("WebSocket error: " + ex.getMessage());
                    }
                };

                client.connect();
                // Wait for connection with timeout
                client.getConnection().getConnectionLatch().await(CONNECTION_TIMEOUT_MS, java.util.concurrent.TimeUnit.MILLISECONDS);
                return;
            } catch (Exception e) {
                retryCount++;
                System.err.println("WebSocket connection attempt " + retryCount + " failed: " + e.getMessage());
                if (retryCount < MAX_RETRIES) {
                    Thread.sleep(retryCount * 1000L);
                } else {
                    throw new Exception("WebSocket connection failed after " + MAX_RETRIES + " attempts", e);
                }
            }
        }
    }

    public void send(byte[] data) throws Exception {
        if (client == null || !client.isOpen()) {
            throw new Exception("WebSocket not connected");
        }
        client.send(new String(data));
    }

    public void close() {
        if (client != null) {
            client.close();
        }
    }
}

// ============================================================================
// WebSocket Server Endpoint
// ============================================================================

class AgentWebSocketServer extends WebSocketServer {
    private final {{ agent_name | pascal }}Agent agent;

    public AgentWebSocketServer(int port, {{ agent_name | pascal }}Agent agent) throws UnknownHostException {
        super(new InetSocketAddress(port));
        this.agent = agent;
    }

    @Override
    public void onOpen(WebSocket conn, ClientHandshake handshake) {
        System.out.println("[{{ agent_name }}] WebSocket connection opened: " + conn.getRemoteSocketAddress());
    }

    @Override
    public void onClose(WebSocket conn, int code, String reason, boolean remote) {
        System.out.println("[{{ agent_name }}] WebSocket connection closed: " + reason);
    }

    @Override
    public void onMessage(WebSocket conn, String message) {
        try {
            ObjectMapper mapper = new ObjectMapper();
            JsonRpcRequest request = mapper.readValue(message, JsonRpcRequest.class);

            JsonRpcResponse response = agent.handleMessage(request);
            String responseJson = mapper.writeValueAsString(response);
            conn.send(responseJson);
        } catch (Exception e) {
            System.err.println("[{{ agent_name }}] WebSocket message error: " + e.getMessage());
        }
    }

    @Override
    public void onError(WebSocket conn, Exception ex) {
        System.err.println("[{{ agent_name }}] WebSocket error: " + ex.getMessage());
    }

    @Override
    public void onStart() {
        System.out.println("[{{ agent_name }}] WebSocket server started on port " + getPort());
    }
}

