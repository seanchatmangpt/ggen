record AgentSkill(
    String id,
    String name,
    String description,
    List<String> tags,
    boolean streaming,
    Map<String, Object> inputSchema,
    Map<String, Object> outputSchema
) {}

record AgentProvider(String name, String url) {}

record AgentCard(
    String name,
    String description,
    String url,
    String version,
    AgentProvider provider,
    List<AgentSkill> skills
) {}

// ============================================================================
// Task Model
// ============================================================================

record Task(
    String id,
    String status,
    @JsonInclude(JsonInclude.Include.NON_NULL) Object result,
    @JsonInclude(JsonInclude.Include.NON_NULL) String error,
    long createdAt,
    long updatedAt
) {}

// ============================================================================
// JSON-RPC 2.0 Model
// ============================================================================

record JsonRpcRequest(
    String jsonrpc,
    String method,
    @JsonInclude(JsonInclude.Include.NON_NULL) Map<String, Object> params,
    @JsonInclude(JsonInclude.Include.NON_NULL) Object id
) {}

record RpcError(int code, String message, @JsonInclude(JsonInclude.Include.NON_NULL) Object data) {}

record JsonRpcResponse(
    String jsonrpc,
    @JsonInclude(JsonInclude.Include.NON_NULL) Object result,
    @JsonInclude(JsonInclude.Include.NON_NULL) RpcError error,
    Object id
) {}

