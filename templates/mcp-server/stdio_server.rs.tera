    fn default() -> Self {
        Self {
            server_name: "{{ server_name }}".to_string(),
            server_version: "{{ server_version }}".to_string(),
            description: "{{ description }}".to_string(),
            capabilities: ServerCapabilities {
                tools: Some(ToolsCapability {
                    list_changed: false,
                }),
                resources: Some(ResourcesCapability {
                    subscribe: false,
                    list_changed: false,
                }),
                prompts: Some(PromptsCapability {
                    list_changed: false,
                }),
                logging: Some(LoggingCapability {
                    level: "info".to_string(),
                }),
            },
            {% if use_zai %}
            zai_config: None,
            {% endif %}
            {% if use_a2a %}
            enable_a2a_bridge: false,
            {% endif %}
        }
    }
}

// =============================================================================
// MCP Server Implementation
// =============================================================================

/// MCP stdio server
pub struct McpStdioServer {
    config: McpServerConfig,
    {% if use_zai %}
    zai_handler: Option<ZaiHandler>,
    {% endif %}
    {% if use_a2a %}
    a2a_bridge: Option<A2aMessageBridge>,
    {% endif %}
    initialized: bool,
    shutdown: bool,
}

impl McpStdioServer {
    /// Create a new MCP stdio server
    pub fn new(config: McpServerConfig) -> Self {
        info!(
            "Creating MCP server: {} v{}",
            config.server_name, config.server_version
        );

        Self {
            config,
            {% if use_zai %}
            zai_handler: None,
            {% endif %}
            {% if use_a2a %}
            a2a_bridge: None,
            {% endif %}
            initialized: false,
            shutdown: false,
        }
    }

    {% if use_zai %}
    /// Set the ZAI handler for streaming support
    pub fn with_zai_handler(mut self, handler: ZaiHandler) -> Self {
        self.zai_handler = Some(handler);
        self
    }
    {% endif %}

    {% if use_a2a %}
    /// Set the A2A message bridge
    pub fn with_a2a_bridge(mut self, bridge: A2aMessageBridge) -> Self {
        self.a2a_bridge = Some(bridge);
        self
    }
    {% endif %}

    /// Start the server (blocks until exit)
    pub fn run(&mut self) -> AnyhowResult<()> {
        info!("Starting MCP stdio server");

        let stdin = io::stdin();
        let stdout = io::stdout();
        let mut stdout_lock = stdout.lock();
        let reader = BufReader::new(stdin);

        for line in reader.lines() {
            if self.shutdown {
                debug!("Server shutdown, exiting read loop");
                break;
            }

            let line = line.map_err(|e| {
                error!("Failed to read line from stdin: {}", e);
                anyhow::anyhow!("Stdin read error: {}", e)
            })?;

            if line.trim().is_empty() {
                continue;
            }

            debug!("Received request: {}", line);

            let response = self.handle_request(&line);

            let response_json = serde_json::to_string(&response)?;
            writeln!(stdout_lock, "{}", response_json)?;
            stdout_lock.flush()?;
        }

        info!("MCP stdio server stopped");
        Ok(())
    }

    /// Handle a single JSON-RPC request
    fn handle_request(&mut self, request_str: &str) -> JsonRpcResponse {
        let request: JsonRpcRequest = match serde_json::from_str(request_str) {
            Ok(req) => req,
            Err(e) => {
                error!("Failed to parse request: {}", e);
                return JsonRpcResponse {
                    jsonrpc: "2.0".to_string(),
                    id: None,
                    result: JsonRpcResult::Error {
                        error: JsonRpcError {
                            code: -32700,
                            message: format!("Parse error: {}", e),
                            data: None,
                        },
                    },
                };
            }
        };

        debug!("Handling method: {:?}", request.method);

        let result = match request.method {
            JsonRpcMethod::Initialize {} => self.handle_initialize(),
            JsonRpcMethod::ListTools {} => self.handle_list_tools(),
            JsonRpcMethod::CallTool {
                name,
                arguments,
            } => self.handle_call_tool(name, arguments),
            JsonRpcMethod::ListResources {} => self.handle_list_resources(),
            JsonRpcMethod::ReadResource { uri } => self.handle_read_resource(uri),
            JsonRpcMethod::WriteResource {
                uri,
                content,
            } => self.handle_write_resource(uri, content),
            JsonRpcMethod::ListPrompts {} => self.handle_list_prompts(),
            JsonRpcMethod::GetPrompt {
                name,
                arguments,
            } => self.handle_get_prompt(name, arguments),
            JsonRpcMethod::Initialized {} => {
                self.initialized = true;
                debug!("Server initialized");
                Ok(JsonValue::Null)
            }
            JsonRpcMethod::Cancelled { reason } => {
                debug!("Request cancelled: {}", reason);
                Ok(JsonValue::Null)
            }
            JsonRpcMethod::Shutdown {} => {
                debug!("Shutdown requested");
                self.shutdown = true;
                Ok(JsonValue::Null)
            }
            JsonRpcMethod::Exit {} => {
                debug!("Exit requested");
                self.shutdown = true;
                Ok(JsonValue::Null)
            }
        };

        match result {
            Ok(result_value) => JsonRpcResponse {
                jsonrpc: "2.0".to_string(),
                id: request.id,
                result: JsonRpcResult::Success {
                    result: result_value,
                },
            },
            Err(e) => {
                error!("Method error: {}", e);
                JsonRpcResponse {
                    jsonrpc: "2.0".to_string(),
                    id: request.id,
                    result: JsonRpcResult::Error {
                        error: JsonRpcError {
                            code: -32603,
                            message: e.to_string(),
                            data: None,
                        },
                    },
                }
            }
        }
    }

    // -------------------------------------------------------------------------
    // Method Handlers
    // -------------------------------------------------------------------------

    fn handle_initialize(&self) -> AnyhowResult<JsonValue> {
        debug!("Handling initialize");

        let response = serde_json::json!({
            "protocolVersion": "2024-11-05",
            "serverInfo": {
                "name": self.config.server_name,
                "version": self.config.server_version,
            },
            "capabilities": self.config.capabilities,
        });

        Ok(response)
    }

    fn handle_list_tools(&self) -> AnyhowResult<JsonValue> {
        debug!("Handling tools/list");

        {% if tools %}
        let tools = vec![
            {% for tool in tools %}
            Tool {
                name: "{{ tool.name }}".to_string(),
                description: "{{ tool.description }}".to_string(),
                input_schema: Some(serde_json::from_str(r#"{{ tool.input_schema | default(default="{}") }}"#)?),
            },
            {% endfor %}
        ];
        {% else %}
        let tools: Vec<Tool> = vec![
            // Add default tools here or generate from ontology
        ];
        {% endif %}

        Ok(serde_json::to_value(tools)?)
    }

    fn handle_call_tool(
        &mut self,
        name: String,
        arguments: HashMap<String, JsonValue>,
    ) -> AnyhowResult<JsonValue> {
        debug!("Handling tools/call: {}", name);

        {% if use_a2a %}
        // Check if this is an A2A-bridged tool
        if let Some(bridge) = &self.a2a_bridge {
            if let Ok(result) = bridge.handle_tool_call(&name, &arguments) {
                return Ok(serde_json::to_value(result)?);
            }
        }
        {% endif %}

        // Handle tool invocation
        let result = match name.as_str() {
            {% for tool in tools %}
            "{{ tool.name }}" => self.{{ tool.name | snake }}_handler(arguments)?,
            {% endfor %}
            _ => {
                warn!("Unknown tool: {}", name);
                return Ok(serde_json::json!({
                    "content": [{
                        "type": "text",
                        "text": format!("Unknown tool: {}", name)
                    }],
                    "isError": true
                }));
            }
        };

        Ok(serde_json::to_value(result)?)
    }

    fn handle_list_resources(&self) -> AnyhowResult<JsonValue> {
        debug!("Handling resources/list");

        {% if resources %}
        let resources = vec![
            {% for resource in resources %}
            Resource {
                uri: "{{ resource.uri }}".to_string(),
                name: "{{ resource.name }}".to_string(),
                description: "{{ resource.description }}".to_string(),
                mime_type: Some("{{ resource.mime_type | default(default="text/plain") }}".to_string()),
            },
            {% endfor %}
        ];
        {% else %}
        let resources: Vec<Resource> = vec![];
        {% endif %}

        Ok(serde_json::to_value(resources)?)
    }

    fn handle_read_resource(&self, uri: String) -> AnyhowResult<JsonValue> {
        debug!("Handling resources/read: {}", uri);

        // Resource reading logic
        let content = ResourceContent {
            uri: uri.clone(),
            text: Some(format!("Resource content for: {}", uri)),
            blob: None,
        };

        Ok(serde_json::to_value(content)?)
    }

    fn handle_write_resource(&self, uri: String, content: String) -> AnyhowResult<JsonValue> {
        debug!("Handling resources/write: {}", uri);

        // Resource writing logic
        Ok(serde_json::json!({
            "uri": uri,
            "success": true
        }))
    }

    fn handle_list_prompts(&self) -> AnyhowResult<JsonValue> {
        debug!("Handling prompts/list");

        {% if prompts %}
        let prompts = vec![
            {% for prompt in prompts %}
            Prompt {
                name: "{{ prompt.name }}".to_string(),
                description: "{{ prompt.description }}".to_string(),
                arguments: Some(vec![
                    {% for arg in prompt.arguments %}
                    PromptArgument {
                        name: "{{ arg.name }}".to_string(),
                        description: "{{ arg.description }}".to_string(),
                        required: Some({{ arg.required | default(default="false") }}),
                    },
                    {% endfor %}
                ]),
            },
            {% endfor %}
        ];
        {% else %}
        let prompts: Vec<Prompt> = vec![];
        {% endif %}

        Ok(serde_json::to_value(prompts)?)
    }

    fn handle_get_prompt(
        &self,
        name: String,
        arguments: HashMap<String, String>,
    ) -> AnyhowResult<JsonValue> {
        debug!("Handling prompts/get: {}", name);

        let result = PromptResult {
            messages: vec![PromptMessage {
                role: "user".to_string(),
                content: PromptContent::Text {
                    text: format!("Prompt: {} with args: {:?}", name, arguments),
                },
            }],
            meta: None,
        };

        Ok(serde_json::to_value(result)?)
    }

    // -------------------------------------------------------------------------
    // Tool Handlers
    // -------------------------------------------------------------------------

    {% for tool in tools %}
    fn {{ tool.name | snake }}_handler(
        &self,
        arguments: HashMap<String, JsonValue>,
    ) -> AnyhowResult<ToolResult> {
        debug!("Executing tool: {{ tool.name }}");

        // Tool implementation here
        let result = ToolResult {
            content: vec![ToolContent::Text {
                text: format!("{{ tool.name }} executed with args: {:?}", arguments),
            }],
            is_error: Some(false),
            meta: None,
        };

        Ok(result)
    }

    {% endfor %}
}

// =============================================================================
// Builder
// =============================================================================

/// Builder for creating MCP stdio servers
pub struct McpServerBuilder {
    config: McpServerConfig,
    {% if use_zai %}
    zai_handler: Option<ZaiHandler>,
    {% endif %}
    {% if use_a2a %}
    a2a_bridge: Option<A2aMessageBridge>,
    {% endif %}
}

impl Default for McpServerBuilder {
    fn default() -> Self {
        Self {
            config: McpServerConfig::default(),
            {% if use_zai %}
            zai_handler: None,
            {% endif %}
            {% if use_a2a %}
            a2a_bridge: None,
            {% endif %}
        }
    }
}

impl McpServerBuilder {
    pub fn new() -> Self {
        Self::default()
    }

    pub fn with_name(mut self, name: impl Into<String>) -> Self {
        self.config.server_name = name.into();
        self
    }

    pub fn with_version(mut self, version: impl Into<String>) -> Self {
        self.config.server_version = version.into();
        self
    }

    pub fn with_description(mut self, description: impl Into<String>) -> Self {
        self.config.description = description.into();
        self
    }

    {% if use_zai %}
    pub fn with_zai_config(mut self, config: ZaiStreamingConfig) -> Self {
        self.config.zai_config = Some(config);
        self
    }

    pub fn with_zai_handler(mut self, handler: ZaiHandler) -> Self {
        self.zai_handler = Some(handler);
        self
    }
    {% endif %}

    {% if use_a2a %}
    pub fn with_a2a_bridge(mut self, bridge: A2aMessageBridge) -> Self {
        self.a2a_bridge = Some(bridge);
        self
    }

    pub fn enable_a2a(mut self) -> Self {
        self.config.enable_a2a_bridge = true;
        self
    }
    {% endif %}

    pub fn build(self) -> AnyhowResult<McpStdioServer> {
        Ok(McpStdioServer {
            config: self.config,
            {% if use_zai %}
            zai_handler: self.zai_handler,
            {% endif %}
            {% if use_a2a %}
            a2a_bridge: self.a2a_bridge,
            {% endif %}
            initialized: false,
            shutdown: false,
        })
    }
}

// =============================================================================
// Tests
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_server_config_default() {
        let config = McpServerConfig::default();
        assert_eq!(config.server_name, "{{ server_name }}");
        assert_eq!(config.server_version, "{{ server_version }}");
    }

    #[test]
    fn test_server_builder() {
        let server = McpServerBuilder::new()
            .with_name("test-server")
            .with_version("1.0.0")
            .build()
            .unwrap();

        assert_eq!(server.config.server_name, "test-server");
        assert_eq!(server.config.server_version, "1.0.0");
    }
}
