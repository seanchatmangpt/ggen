    {% if tool.use_zai %}
    pub fn with_zai_handler(mut self, handler: ZaiStreamingHandler) -> Self {
        self.zai_handler = Some(handler);
        self
    }
    {% endif %}
}

impl Default for {{ tool.name | pascal }}Handler {
    fn default() -> Self {
        Self::new()
    }
}

impl ToolHandler for {{ tool.name | pascal }}Handler {
    fn execute(&self, args: &HashMap<String, JsonValue>) -> AnyhowResult<ToolResult> {
        debug!("Executing {{ tool.name }} with args: {:?}", args);

        {% if tool.use_zai %}
        if let Some(ref zai) = self.zai_handler {
            // Use ZAI streaming handler
            return zai.execute_tool("{{ tool.name }}", args);
        }
        {% endif %}

        // Tool implementation
        let result = ToolResult {
            content: vec![
                ToolContent::Text {
                    text: format!("{{ tool.name }} result: {:?}", args),
                }
            ],
            is_error: Some(false),
            meta: None,
        };

        Ok(result)
    }

    fn schema(&self) -> &ToolSchema {
        &self.schema
    }

    {% if tool.use_zai %}
    fn supports_streaming(&self) -> bool {
        self.zai_handler.is_some()
    }
    {% endif %}
}

