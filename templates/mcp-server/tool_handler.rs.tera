// =============================================================================
// Built-in Tool Handlers
// =============================================================================

/// Echo tool - returns input as output
#[derive(Debug, Clone)]
pub struct EchoHandler;

impl ToolHandler for EchoHandler {
    fn execute(&self, args: &HashMap<String, JsonValue>) -> AnyhowResult<ToolResult> {
        let text = args.get("message")
            .and_then(|v| v.as_str())
            .unwrap_or("No message provided");

        Ok(ToolResult {
            content: vec![
                ToolContent::Text {
                    text: text.to_string(),
                }
            ],
            is_error: Some(false),
            meta: None,
        })
    }

    fn schema(&self) -> &ToolSchema {
        static SCHEMA: ToolSchema = ToolSchema {
            name: "echo".to_string(),
            description: "Echo the input message back to the caller".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string",
                        "description": "The message to echo back"
                    }
                },
                "required": ["message"]
            }),
        };
        &SCHEMA
    }
}

/// Get current time
#[derive(Debug, Clone)]
pub struct CurrentTimeHandler;

impl ToolHandler for CurrentTimeHandler {
    fn execute(&self, _args: &HashMap<String, JsonValue>) -> AnyhowResult<ToolResult> {
        use chrono::Utc;

        Ok(ToolResult {
            content: vec![
                ToolContent::Text {
                    text: Utc::now().to_rfc3339(),
                }
            ],
            is_error: Some(false),
            meta: None,
        })
    }

    fn schema(&self) -> &ToolSchema {
        static SCHEMA: ToolSchema = ToolSchema {
            name: "current_time".to_string(),
            description: "Get the current UTC timestamp".to_string(),
            input_schema: serde_json::json!({
                "type": "object",
                "properties": {},
            }),
        };
        &SCHEMA
    }
}

// =============================================================================
// Tests
// =============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_tool_registry() {
        let mut registry = ToolRegistry::new();
        registry.register(Box::new(EchoHandler)).unwrap();

        assert!(registry.has_tool("echo"));

        let tools = registry.list_tools();
        assert_eq!(tools.len(), 1);
        assert_eq!(tools[0].name, "echo");
    }

    #[test]
    fn test_echo_handler() {
        let handler = EchoHandler;
        let mut args = HashMap::new();
        args.insert("message".to_string(), JsonValue::String("Hello, world!".to_string()));

        let result = handler.execute(&args).unwrap();
        assert!(!result.is_error.unwrap_or(false));
        assert_eq!(result.content.len(), 1);

        match &result.content[0] {
            ToolContent::Text { text } => assert_eq!(text, "Hello, world!"),
            _ => panic!("Expected text content"),
        }
    }

    #[test]
    fn test_current_time_handler() {
        let handler = CurrentTimeHandler;
        let result = handler.execute(&HashMap::new()).unwrap();

        assert!(!result.is_error.unwrap_or(false));
        assert_eq!(result.content.len(), 1);

        match &result.content[0] {
            ToolContent::Text { text } => {
                // Should be a valid ISO 8601 timestamp
                assert!(text.len() > 0);
            }
            _ => panic!("Expected text content"),
        }
    }

    {% for tool in tools %}
    #[test]
    fn test_{{ tool.name | snake }}_handler() {
        let handler = {{ tool.name | pascal }}Handler::new();
        let args = HashMap::new();

        let result = handler.execute(&args);
        assert!(result.is_ok());
    }
    {% endfor %}
}
