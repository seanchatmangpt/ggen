{% if use_a2a %}

// =============================================================================
// A2A Tool Adapter
// =============================================================================

/// A2A tool adapter - bridges A2A messages to MCP tools
#[derive(Debug, Clone)]
pub struct A2aToolAdapter {
    registry: ToolRegistry,
}

impl A2aToolAdapter {
    pub fn new() -> Self {
        Self {
            registry: ToolRegistry::new(),
        }
    }

    /// Register all A2A-compatible tools
    pub fn register_a2a_tools(&mut self) -> AnyhowResult<()> {
        // Register tools that can handle A2A messages
        Ok(())
    }

    /// Convert A2A message to tool call
    pub fn a2a_to_tool_call(&self, message: &ConvergedMessage) -> AnyhowResult<(String, HashMap<String, JsonValue>)> {
        match message.message_type {
            a2a_generated::converged::message::ConvergedMessageType::Request => {
                // Extract tool name and arguments from A2A request
                let tool_name = message.content.get("tool")
                    .and_then(|v| v.as_str())
                    .ok_or_else(|| anyhow::anyhow!("Missing tool name"))?
                    .to_string();

                let arguments = message.content.get("arguments")
                    .and_then(|v| v.as_object())
                    .map(|obj| {
                        obj.iter()
                            .map(|(k, v)| (k.clone(), v.clone()))
                            .collect()
                    })
                    .unwrap_or_default();

                Ok((tool_name, arguments))
            }
            _ => Err(anyhow::anyhow!("Unsupported message type for tool call"))
        }
    }

    /// Convert tool result to A2A message
    pub fn tool_result_to_a2a(&self, result: ToolResult) -> AnyhowResult<ConvergedMessage> {
        // Convert tool result to A2A response message
        use a2a_generated::converged::message::ConvergedMessageType;

        let content = serde_json::json!({
            "result": result,
        });

        Ok(ConvergedMessage {
            message_type: ConvergedMessageType::Response,
            content,
            ..Default::default()
        })
    }
}

impl Default for A2aToolAdapter {
    fn default() -> Self {
        Self::new()
    }
}

