// =============================================================================
// Tool Handler Types
// =============================================================================

/// Tool handler trait
pub trait ToolHandler: Send + Sync {
    /// Execute the tool with given arguments
    fn execute(&self, args: &HashMap<String, JsonValue>) -> AnyhowResult<ToolResult>;

    /// Get tool schema
    fn schema(&self) -> &ToolSchema;

    /// Check if tool supports streaming
    fn supports_streaming(&self) -> bool {
        false
    }

    /// Execute tool with streaming (if supported)
    fn execute_streaming(
        &self,
        _args: &HashMap<String, JsonValue>,
    ) -> AnyhowResult<Box<dyn Iterator<Item = String> + Send>> {
        Err(anyhow::anyhow!("Streaming not supported"))
    }
}

/// Tool schema definition
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ToolSchema {
    pub name: String,
    pub description: String,
    pub input_schema: JsonValue,
}

/// Tool execution result
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ToolResult {
    pub content: Vec<ToolContent>,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub is_error: Option<bool>,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub meta: Option<HashMap<String, JsonValue>>,
}

/// Tool content types
#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(tag = "type")]
pub enum ToolContent {
    #[serde(rename = "text")]
    Text {
        text: String,
    },

    #[serde(rename = "image")]
    Image {
        data: String,
        mime_type: String,
    },

    #[serde(rename = "resource")]
    Resource {
        uri: String,
        #[serde(skip_serializing_if = "Option::is_none")]
        text: Option<String>,
        #[serde(skip_serializing_if = "Option::is_none")]
        blob: Option<String>,
    },

    {% if use_zai %}
    #[serde(rename = "streaming")]
    Streaming {
        stream_id: String,
    },
    {% endif %}
}

/// Tool registry
pub struct ToolRegistry {
    tools: HashMap<String, Box<dyn ToolHandler>>,
}

impl Default for ToolRegistry {
    fn default() -> Self {
        Self::new()
    }
}

impl ToolRegistry {
    pub fn new() -> Self {
        Self {
            tools: HashMap::new(),
        }
    }

    /// Register a tool handler
    pub fn register(&mut self, handler: Box<dyn ToolHandler>) -> AnyhowResult<()> {
        let name = handler.schema().name.clone();
        debug!("Registering tool: {}", name);
        self.tools.insert(name, handler);
        Ok(())
    }

    /// List all registered tools
    pub fn list_tools(&self) -> Vec<ToolSchema> {
        self.tools.values().map(|h| h.schema().clone()).collect()
    }

    /// Execute a tool by name
    pub fn execute(
        &self,
        name: &str,
        args: &HashMap<String, JsonValue>,
    ) -> AnyhowResult<ToolResult> {
        let handler = self.tools.get(name).ok_or_else(|| {
            error!("Tool not found: {}", name);
            anyhow::anyhow!("Tool not found: {}", name)
        })?;

        debug!("Executing tool: {}", name);
        handler.execute(args)
    }

    /// Check if tool exists
    pub fn has_tool(&self, name: &str) -> bool {
        self.tools.contains_key(name)
    }

    /// Get tool handler
    pub fn get_handler(&self, name: &str) -> Option<&dyn ToolHandler> {
        self.tools.get(name).map(|h| h.as_ref())
    }
}

