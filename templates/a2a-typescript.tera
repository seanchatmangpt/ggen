import express, { Request, Response } from "express";
import { randomUUID } from "crypto";

// ============================================================================
// Agent Card
// ============================================================================

interface AgentSkill {
  id: string;
  name: string;
  description: string;
  tags: string[];
  streaming: boolean;
  inputSchema: Record<string, unknown>;
  outputSchema: Record<string, unknown>;
}

interface AgentCard {
  name: string;
  description: string;
  url: string;
  version: string;
  provider: { name: string; url: string };
  skills: AgentSkill[];
}

const AGENT_CARD: AgentCard = {
  name: "{{ agent_name }}",
  description: "{{ agent_description }}",
  url: "{{ agent_url }}",
  version: "{{ agent_version }}",
  provider: {
    name: "{{ provider_name }}",
    url: "{{ provider_url }}",
  },
  skills: [
    {% for row in sparql_results %}
    {
      id: "{{ row.skill_name }}",
      name: "{{ row.skill_name }}",
      description: "{{ row.skill_description | default(value="") }}",
      tags: {{ row.skill_tags | default(value="[]") }},
      streaming: {{ row.streaming | default(value="false") }},
      inputSchema: {},
      outputSchema: {},
    },
    {% endfor %}
  ],
};

// ============================================================================
// Task Store
// ============================================================================

interface Task {
  id: string;
  status: "pending" | "running" | "completed" | "cancelled" | "failed";
  result?: unknown;
  error?: string;
  createdAt: number;
  updatedAt: number;
}

const taskStore = new Map<string, Task>();

