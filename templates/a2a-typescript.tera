// ============================================================================
// JSON-RPC 2.0 Types
// ============================================================================

interface JsonRpcRequest {
  jsonrpc: "2.0";
  method: string;
  params?: Record<string, unknown>;
  id?: string | number | null;
}

interface JsonRpcResponse {
  jsonrpc: "2.0";
  result?: unknown;
  error?: { code: number; message: string; data?: unknown };
  id: string | number | null;
}

// ============================================================================
// Skill Registry
// ============================================================================

const SKILL_TIMEOUT_MS: Record<string, number> = {
  {% for row in sparql_results %}
  "{{ row.skill_name }}": {{ row.timeout_ms | default(value=5000) }},
  {% endfor %}
};

type SkillHandler = (input: Record<string, unknown>) => Promise<unknown>;

const skillRegistry: Record<string, SkillHandler> = {
  {% for row in sparql_results %}
  "{{ row.skill_name }}": async (input) => {
    return handle{{ row.skill_name | pascal }}(input as {{ row.skill_name | pascal }}Input);
  },
  {% endfor %}
};

// ============================================================================
// Timeout Wrapper
// ============================================================================

async function withTimeout<T>(
  promise: Promise<T>,
  timeoutMs: number,
  skillName: string
): Promise<T> {
  let timer: ReturnType<typeof setTimeout>;
  return Promise.race([
    promise,
    new Promise<never>((_, reject) => {
      timer = setTimeout(
        () => reject(new Error(`Skill ${skillName} timed out after ${timeoutMs}ms`)),
        timeoutMs
      );
    }),
  ]).finally(() => clearTimeout(timer));
}

// ============================================================================
// WebSocket Transport
// ============================================================================

class WebSocketTransport {
  private url: string;
  private ws: WebSocket | null = null;
  private reconnectAttempts = 0;
  private maxReconnectAttempts = 3;
  private reconnectDelay = 1000;

  constructor(url: string) {
    this.url = url;
  }

  async connect(): Promise<void> {
    while (this.reconnectAttempts < this.maxReconnectAttempts) {
      try {
        this.ws = new WebSocket(this.url);

        await new Promise<void>((resolve, reject) => {
          if (!this.ws) return reject(new Error("WebSocket not initialized"));

          this.ws.on("open", () => {
            console.log(`Connected to WebSocket: ${this.url}`);
            resolve();
          });

          this.ws.on("error", (err) => {
            reject(err);
          });
        });

        return;
      } catch (error) {
        this.reconnectAttempts++;
        console.error(`WebSocket connection attempt ${this.reconnectAttempts} failed:`, error);
        if (this.reconnectAttempts < this.maxReconnectAttempts) {
          await new Promise((resolve) => setTimeout(resolve, this.reconnectDelay * this.reconnectAttempts));
        }
      }
    }

    throw new Error(`WebSocket connection failed after ${this.maxReconnectAttempts} attempts`);
  }

  async send(data: Buffer): Promise<void> {
    return new Promise((resolve, reject) => {
      if (!this.ws || this.ws.readyState !== WebSocket.OPEN) {
        return reject(new Error("WebSocket not connected"));
      }

      this.ws.send(data, (err) => {
        if (err) {
          reject(new Error(`Failed to send WebSocket message: ${err.message}`));
        } else {
          resolve();
        }
      });
    });
  }

  async receive(): Promise<Buffer> {
    return new Promise((resolve, reject) => {
      if (!this.ws || this.ws.readyState !== WebSocket.OPEN) {
        return reject(new Error("WebSocket not connected"));
      }

      const timeout = setTimeout(() => {
        reject(new Error("WebSocket receive timeout"));
      }, 30000);

      this.ws.once("message", (data: Buffer) => {
        clearTimeout(timeout);
        resolve(data);
      });

      this.ws.once("error", (err) => {
        clearTimeout(timeout);
        reject(err);
      });
    });
  }

  close(): void {
    if (this.ws) {
      this.ws.close();
      this.ws = null;
    }
  }
}

// ============================================================================
// Express Server
// ============================================================================

const app = express();
app.use(express.json());

// WebSocket server
const wss = new WebSocketServer({ noServer: true });

// --- Agent Card Endpoint ---

app.get("/.well-known/agent.json", (_req: Request, res: Response) => {
  res.json(AGENT_CARD);
});

// --- JSON-RPC Message Handler ---

app.post("/a2a/message", async (req: Request, res: Response) => {
  const body = req.body as JsonRpcRequest;

  if (!body || body.jsonrpc !== "2.0") {
    const errorResp: JsonRpcResponse = {
      jsonrpc: "2.0",
      error: { code: -32600, message: "Invalid Request: jsonrpc must be '2.0'" },
      id: body?.id ?? null,
    };
    return res.status(400).json(errorResp);
  }

  const handler = skillRegistry[body.method];
  if (!handler) {
    const errorResp: JsonRpcResponse = {
      jsonrpc: "2.0",
      error: { code: -32601, message: `Method not found: ${body.method}` },
      id: body.id ?? null,
    };
    return res.status(404).json(errorResp);
  }

  const timeoutMs = SKILL_TIMEOUT_MS[body.method] ?? 5000;

  try {
    const result = await withTimeout(
      handler(body.params ?? {}),
      timeoutMs,
      body.method
    );
    const successResp: JsonRpcResponse = {
      jsonrpc: "2.0",
      result,
      id: body.id ?? null,
    };
    res.json(successResp);
  } catch (err) {
    const errorMsg = err instanceof Error ? err.message : String(err);
    const errorResp: JsonRpcResponse = {
      jsonrpc: "2.0",
      error: { code: -32000, message: errorMsg },
      id: body.id ?? null,
    };
    res.status(500).json(errorResp);
  }
});

// --- Streaming Endpoint (SSE) for streaming skills ---

app.post("/a2a/stream", async (req: Request, res: Response) => {
  const body = req.body as JsonRpcRequest;
  const handler = skillRegistry[body.method];

  if (!handler) {
    return res.status(404).json({ error: `Unknown skill: ${body.method}` });
  }

  const skillDef = AGENT_CARD.skills.find((s) => s.name === body.method);
  if (!skillDef?.streaming) {
    return res.status(400).json({ error: `Skill ${body.method} does not support streaming` });
  }

  res.setHeader("Content-Type", "text/event-stream");
  res.setHeader("Cache-Control", "no-cache");
  res.setHeader("Connection", "keep-alive");
  res.flushHeaders();

  try {
    const result = await handler(body.params ?? {});
    res.write(`data: ${JSON.stringify({ result })}\n\n`);
    res.write("data: [DONE]\n\n");
    res.end();
  } catch (err) {
    const errorMsg = err instanceof Error ? err.message : String(err);
    res.write(`data: ${JSON.stringify({ error: errorMsg })}\n\n`);
    res.end();
  }
});

// --- Task Lifecycle Endpoints ---

app.get("/a2a/tasks/:id", (req: Request, res: Response) => {
  const task = taskStore.get(req.params.id);
  if (!task) {
    return res.status(404).json({ error: `Task not found: ${req.params.id}` });
  }
  res.json(task);
});

app.post("/a2a/tasks/:id/cancel", (req: Request, res: Response) => {
  const task = taskStore.get(req.params.id);
  if (!task) {
    return res.status(404).json({ error: `Task not found: ${req.params.id}` });
  }
  if (task.status === "completed" || task.status === "cancelled") {
    return res.status(409).json({ error: `Task ${task.status}, cannot cancel` });
  }
  task.status = "cancelled";
  task.updatedAt = Date.now();
  res.json(task);
});

app.get("/a2a/tasks", (_req: Request, res: Response) => {
  const allTasks = Array.from(taskStore.values()).sort((a, b) => b.createdAt - a.createdAt);
  res.json({ tasks: allTasks });
});

// --- Health Check ---

app.get("/health", (_req: Request, res: Response) => {
  res.json({
    agent: AGENT_CARD.name,
    version: AGENT_CARD.version,
    status: "ok",
    tasks: taskStore.size,
    uptime: process.uptime(),
  });
});

// ============================================================================
// Start Server
// ============================================================================

const PORT = {{ agent_port | default(value=8089) }};

// Create HTTP server with WebSocket upgrade support
const server = app.listen(PORT, () => {
  console.log(`[${AGENT_CARD.name}] A2A agent listening on port ${PORT}`);
  console.log(`[${AGENT_CARD.name}] Agent card: http://localhost:${PORT}/.well-known/agent.json`);
  console.log(`[${AGENT_CARD.name}] Skills: ${AGENT_CARD.skills.map((s) => s.name).join(", ")}`);
});

// Handle WebSocket upgrade
server.on("upgrade", (request, socket, head) => {
  if (request.url === "/a2a/ws") {
    wss.handleUpgrade(request, socket, head, (ws) => {
      wss.emit("connection", ws, request);
    });
  } else {
    socket.destroy();
  }
});

// WebSocket connection handler
wss.on("connection", (ws: WebSocket) => {
  console.log(`[${AGENT_CARD.name}] WebSocket connection established`);

  ws.on("message", async (data: Buffer) => {
    try {
      const body = JSON.parse(data.toString()) as JsonRpcRequest;

      if (body.jsonrpc !== "2.0") {
        const errorResp: JsonRpcResponse = {
          jsonrpc: "2.0",
          error: { code: -32600, message: "Invalid Request: jsonrpc must be '2.0'" },
          id: body?.id ?? null,
        };
        ws.send(JSON.stringify(errorResp));
        return;
      }

      const handler = skillRegistry[body.method];
      if (!handler) {
        const errorResp: JsonRpcResponse = {
          jsonrpc: "2.0",
          error: { code: -32601, message: `Method not found: ${body.method}` },
          id: body.id ?? null,
        };
        ws.send(JSON.stringify(errorResp));
        return;
      }

      const timeoutMs = SKILL_TIMEOUT_MS[body.method] ?? 5000;

      try {
        const result = await withTimeout(
          handler(body.params ?? {}),
          timeoutMs,
          body.method
        );
        const successResp: JsonRpcResponse = {
          jsonrpc: "2.0",
          result,
          id: body.id ?? null,
        };
        ws.send(JSON.stringify(successResp));
      } catch (err) {
        const errorMsg = err instanceof Error ? err.message : String(err);
        const errorResp: JsonRpcResponse = {
          jsonrpc: "2.0",
          error: { code: -32000, message: errorMsg },
          id: body.id ?? null,
        };
        ws.send(JSON.stringify(errorResp));
      }
    } catch (err) {
      const errorMsg = err instanceof Error ? err.message : String(err);
      ws.send(JSON.stringify({ error: errorMsg }));
    }
  });

  ws.on("close", () => {
    console.log(`[${AGENT_CARD.name}] WebSocket connection closed`);
  });

  ws.on("error", (err) => {
    console.error(`[${AGENT_CARD.name}] WebSocket error:`, err);
  });
});
