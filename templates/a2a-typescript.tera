interface AgentSkill {
  id: string;
  name: string;
  description: string;
  tags: string[];
  streaming: boolean;
  inputSchema: Record<string, unknown>;
  outputSchema: Record<string, unknown>;
}

interface AgentCard {
  name: string;
  description: string;
  url: string;
  version: string;
  provider: { name: string; url: string };
  skills: AgentSkill[];
}

const AGENT_CARD: AgentCard = {
  name: "{{ agent_name }}",
  description: "{{ agent_description }}",
  url: "{{ agent_url }}",
  version: "{{ agent_version }}",
  provider: {
    name: "{{ provider_name }}",
    url: "{{ provider_url }}",
