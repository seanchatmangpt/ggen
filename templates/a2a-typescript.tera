      name: "{{ row.skill_name }}",
      description: "{{ row.skill_description | default(value="") }}",
      tags: {{ row.skill_tags | default(value="[]") }},
      streaming: {{ row.streaming | default(value="false") }},
      inputSchema: {},
      outputSchema: {},
    },
    {% endfor %}
  ],
};

