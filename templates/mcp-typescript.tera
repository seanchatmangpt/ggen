// =============================================================================
// MCP Server: {{ server_name }} v{{ server_version }}
// =============================================================================
//
// Generated by ggen from {{ server_name }} ontology
// Pipeline: ontology (.ttl) -> SPARQL-star CONSTRUCT (.rq) -> Tera (.tera) -> this file
// Core axiom: A = mu(O), mu o mu = mu, hash(A) = hash(mu(O)), O |= Sigma
//
// {{ server_description }}
//
// Transport: {{ transport_type | default(value="stdio") }}
// Tools: extracted from sparql_results
// =============================================================================

import { Server } from "@modelcontextprotocol/sdk/server/index.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
{% if transport_type == "sse" %}
import { SSEServerTransport } from "@modelcontextprotocol/sdk/server/sse.js";
import express from "express";
{% endif %}
import {
  CallToolRequestSchema,
  ListToolsRequestSchema,
} from "@modelcontextprotocol/sdk/types.js";
import { z } from "zod";
import { zodToJsonSchema } from "zod-to-json-schema";

// =============================================================================
// Zod Input Schemas
// =============================================================================

{% for row in sparql_results %}
/**
 * Input schema for {{ row.tool_name }}
 * {{ row.tool_description | default(value="(no description)") }}
 */
// TODO: add parameters from extract-mcp-params.rq
const {{ row.tool_name | snake }}InputSchema = z.object({});

type {{ row.tool_name | pascal }}Input = z.infer<typeof {{ row.tool_name | snake }}InputSchema>;

{% endfor %}

// =============================================================================
// Server Setup
// =============================================================================

const server = new Server(
  {
    name: "{{ server_name }}",
    version: "{{ server_version }}",
  },
  {
    capabilities: {
      tools: {
        listChanged: false,
      },
    },
  }
);

// =============================================================================
// Tool Handlers
// =============================================================================

{% for row in sparql_results %}
/**
 * Handle {{ row.tool_name }}
 * {{ row.tool_description | default(value="(no description)") }}
 */
async function handle{{ row.tool_name | pascal }}(
  args: Record<string, unknown>
): Promise<{ content: Array<{ type: string; text: string }>; isError?: boolean }> {
  const parsed = {{ row.tool_name | snake }}InputSchema.safeParse(args);

  if (!parsed.success) {
    return {
      content: [
        {
          type: "text",
          text: `Invalid arguments for {{ row.tool_name }}: ${parsed.error.message}`,
        },
      ],
      isError: true,
    };
  }

  const input = parsed.data as {{ row.tool_name | pascal }}Input;

  // TODO: Implement {{ row.tool_name }} logic here
  // TODO: add parameters from extract-mcp-params.rq

  return {
    content: [
      {
        type: "text",
        text: JSON.stringify({ success: true, tool: "{{ row.tool_name }}", input }, null, 2),
      },
    ],
  };
}

{% endfor %}

// =============================================================================
// Tool Registration
// =============================================================================

server.setRequestHandler(ListToolsRequestSchema, async () => {
  return {
    tools: [
{% for row in sparql_results %}
      {
        name: "{{ row.tool_name }}",
        description: "{{ row.tool_description | default(value="(no description)") }}",
        inputSchema: {
          type: "object",
          properties: {},
        },
      },
{% endfor %}
    ],
  };
});

server.setRequestHandler(CallToolRequestSchema, async (request) => {
  const { name, arguments: args } = request.params;

  try {
    switch (name) {
{% for row in sparql_results %}
      case "{{ row.tool_name }}":
        return await handle{{ row.tool_name | pascal }}(args ?? {});
{% endfor %}
      default:
        return {
          content: [
            {
              type: "text",
              text: `Unknown tool: ${name}`,
            },
          ],
          isError: true,
        };
    }
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    return {
      content: [
        {
          type: "text",
          text: `Error executing ${name}: ${message}`,
        },
      ],
      isError: true,
    };
  }
});

// =============================================================================
// Transport & Startup
// =============================================================================

{% if transport_type == "sse" %}
// HTTP SSE Transport (for remote clients)
const app = express();
app.get("/sse", async (_req, res) => {
  const transport = new SSEServerTransport("/messages", res);
  await server.connect(transport);
});
app.post("/messages", async (req, res) => {
  // SSEServerTransport handles message routing internally
  res.sendStatus(200);
});

async function main() {
  const port = process.env.MCP_PORT ? parseInt(process.env.MCP_PORT, 10) : 3000;
  app.listen(port, () => {
    console.error(`{{ server_name }} MCP server listening on http://localhost:${port}/sse`);
  });
}
{% else %}
// Stdio Transport (default -- for local CLI clients)
async function main() {
  const transport = new StdioServerTransport();
  await server.connect(transport);
  console.error(`{{ server_name }} MCP server v{{ server_version }} running on stdio`);
}

