//   app.listen(port, () => {
//     console.error(`{{ server_name }} MCP server listening on http://localhost:${port}/mcp`);
//   });
// }
{% endif %}

main().catch((error) => {
  console.error("Fatal error in {{ server_name }} MCP server:", error);
  process.exit(1);
});
