// =============================================================================
// MCP Server: {{ serverName }} v{{ serverVersion }}
// =============================================================================
//
// Generated by ggen from {{ serverName }} ontology
// Pipeline: ontology (.ttl) -> SPARQL-star CONSTRUCT (.rq) -> Tera (.tera) -> this file
// Core axiom: A = mu(O), mu o mu = mu, hash(A) = hash(mu(O)), O |= Sigma
//
// {{ serverDescription }}
//
// Transport: {{ transportType | default(value="stdio") }}
// Tools: {{ tools | length }}
// =============================================================================

import { Server } from "@modelcontextprotocol/sdk/server/index.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
{% if transportType == "sse" %}
import { SSEServerTransport } from "@modelcontextprotocol/sdk/server/sse.js";
import express from "express";
{% endif %}
import {
  CallToolRequestSchema,
  ListToolsRequestSchema,
  ListResourcesRequestSchema,
  ReadResourceRequestSchema,
} from "@modelcontextprotocol/sdk/types.js";
import { z } from "zod";
import { zodToJsonSchema } from "zod-to-json-schema";

// =============================================================================
// Zod Input Schemas
// =============================================================================

{% for tool in tools %}
/**
 * Input schema for {{ tool.name }}
 * {{ tool.description }}
 */
const {{ tool.name | snake_case }}InputSchema = z.object({
{% for param in tool.parameters %}
  {{ param.name }}: {% if param.jsonSchema %}z.any(){% else %}{{ param.zod_type }}(){% endif %}{% if param.required != "true" %}.optional(){% endif %}{% if param.description %}.describe("{{ param.description }}"){% endif %}{% if param.defaultValue %}.default({{ param.defaultValue }}){% endif %}{% if param.enumValues %},
  // NOTE: enum constraint from ontology: {{ param.enumValues }}
  // Apply via .pipe(z.enum([...])) if runtime validation needed{% endif %},
{% endfor %}
});

type {{ tool.name | pascal_case }}Input = z.infer<typeof {{ tool.name | snake_case }}InputSchema>;

{% endfor %}

// =============================================================================
// Server Setup
// =============================================================================

const server = new Server(
  {
    name: "{{ serverName }}",
    version: "{{ serverVersion }}",
  },
  {
    capabilities: {
      tools: {
        listChanged: false,
      },
    },
  }
);

// =============================================================================
// Tool Handlers
// =============================================================================

{% for tool in tools %}
/**
 * Handle {{ tool.name }}
 * {{ tool.description }}
 */
async function handle{{ tool.name | pascal_case }}(
  args: Record<string, unknown>
): Promise<{ content: Array<{ type: string; text: string }>; isError?: boolean }> {
  const parsed = {{ tool.name | snake_case }}InputSchema.safeParse(args);

  if (!parsed.success) {
    return {
      content: [
        {
          type: "text",
          text: `Invalid arguments for {{ tool.name }}: ${parsed.error.message}`,
        },
      ],
      isError: true,
    };
  }

  const input = parsed.data as {{ tool.name | pascal_case }}Input;

  // TODO: Implement {{ tool.name }} logic here
  // Parameters available:
  {% for param in tool.parameters %}
  // - {{ param.name }}: {{ param.tsType }}{{ param.description ? " -- " + param.description : "" }}
  {% endfor %}

  return {
    content: [
      {
        type: "text",
        text: JSON.stringify({ success: true, tool: "{{ tool.name }}", input }, null, 2),
      },
    ],
  };
}

{% endfor %}

// =============================================================================
// Tool Registration
// =============================================================================

server.setRequestHandler(ListToolsRequestSchema, async () => {
  return {
    tools: [
{% for tool in tools %}
      {
        name: "{{ tool.name }}",
        description: "{{ tool.description }}",
        inputSchema: {% if tool.parameters | length > 0 %}zodToJsonSchema({{ tool.name | snake_case }}InputSchema, { name: "{{ tool.name }}Input" }){% else %}{
  type: "object",
  properties: {},
}{% endif %},
      },
{% endfor %}
    ],
  };
});

server.setRequestHandler(CallToolRequestSchema, async (request) => {
  const { name, arguments: args } = request.params;

  try {
    switch (name) {
{% for tool in tools %}
      case "{{ tool.name }}":
        return await handle{{ tool.name | pascal_case }}(args ?? {});
{% endfor %}
      default:
        return {
          content: [
            {
              type: "text",
              text: `Unknown tool: ${name}`,
            },
          ],
          isError: true,
        };
    }
  } catch (error) {
    const message = error instanceof Error ? error.message : String(error);
    return {
      content: [
        {
          type: "text",
          text: `Error executing ${name}: ${message}`,
        },
      ],
      isError: true,
    };
  }
});

// =============================================================================
// Transport & Startup
// =============================================================================

{% if transportType == "sse" %}
// HTTP SSE Transport (for remote clients)
const app = express();
app.get("/sse", async (_req, res) => {
  const transport = new SSEServerTransport("/messages", res);
  await server.connect(transport);
});
app.post("/messages", async (req, res) => {
  // SSEServerTransport handles message routing internally
  res.sendStatus(200);
});

async function main() {
  const port = process.env.MCP_PORT ? parseInt(process.env.MCP_PORT, 10) : 3000;
  app.listen(port, () => {
    console.error(`{{ serverName }} MCP server listening on http://localhost:${port}/sse`);
  });
}
{% else %}
// Stdio Transport (default -- for local CLI clients)
async function main() {
  const transport = new StdioServerTransport();
  await server.connect(transport);
  console.error(`{{ serverName }} MCP server v{{ serverVersion }} running on stdio`);
}

// Uncomment below for HTTP transport alternative:
//
// import { StreamableHTTPServerTransport } from "@modelcontextprotocol/sdk/server/streamableHttp.js";
// import express from "express";
//
// async function main() {
//   const app = express();
//   app.post("/mcp", async (req, res) => {
//     const transport = new StreamableHTTPServerTransport({ sessionIdGenerator: () => crypto.randomUUID() });
//     await server.connect(transport);
//     // Handle the request via transport
//   });
//   const port = process.env.MCP_PORT ? parseInt(process.env.MCP_PORT, 10) : 3000;
//   app.listen(port, () => {
//     console.error(`{{ serverName }} MCP server listening on http://localhost:${port}/mcp`);
//   });
// }
{% endif %}

main().catch((error) => {
  console.error("Fatal error in {{ serverName }} MCP server:", error);
  process.exit(1);
});
