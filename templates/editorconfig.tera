# EditorConfig generated by ggen from project conventions
# Regenerate with: ggen onboarding --ide editorconfig
# Source: onboarding-conventions.ttl
#
# Project: {{ project_name }}
# Generated: {{ now() | date(format="%Y-%m-%d %H:%M:%S") }}

# Top-level defaults
root = true

[*]
charset = {{ default_charset | default(value="utf-8") }}
end_of_line = {{ default_eol | default(value="lf") }}
indent_style = {{ default_indent_style | default(value="space") }}
indent_size = {{ default_indent_size | default(value=2) }}
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = {{ default_max_line_width | default(value=120) }}

{% for ec in editor_configs %}
{% if ec.appliesToLanguage is defined %}
# {{ ec.appliesToLanguage }} files
[{{ ec.fileExtension }}]
indent_style = {{ ec.indentStyle }}
indent_size = {{ ec.indentSize }}
max_line_length = {{ ec.maxLineWidth }}

{% endif %}
{% endfor %}

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# TOML
[*.toml]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Makefiles (must use tabs)
[Makefile]
indent_style = tab

# Generated files
[generated/**]
generated = true

# Lock files (binary or machine-generated)
[Cargo.lock]
generated = true

[go.sum]
generated = true

[mix.lock]
generated = true

[package-lock.json]
generated = true
