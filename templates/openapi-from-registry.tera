{# openapi-from-registry.tera -- OpenAPI 3.0.3 generation from RDF 1.2 type registry #}
{# Constitutional Equation: openapi.yaml = mu(type-registry.ttl + endpoint annotations) #}
{# Pipeline: type-registry.ttl -> openapi-typegen-extract.rq -> openapi-from-registry.tera -> openapi.yaml #}
{# #}
{# RDF 1.2 triple terms (<<s p o>>) enable axiom-level OpenAPI schema generation. #}
{# Each schema component is a projection of ontology axioms through SPARQL-star CONSTRUCT + Tera. #}
{# #}
{# Input variables (from SPARQL-star CONSTRUCT results, Vec<BTreeMap<String, String>>): #}
{#   schemas: Array of schema objects (grouped from api:Schema nodes) #}
{#     - name: string (entity local name) #}
{#     - description: string (source ontology provenance) #}
{#     - source_ontology: string (ontology name) #}
{#     - canonical: string ("true"/"false") #}
{#     - confidence: string (0.0-1.0) #}
{#     - properties: Array of property objects #}
{#       - name: string (property local name) #}
{#       - type: string (OpenAPI type: string/number/integer/boolean/object/array) #}
{#       - format: string (OpenAPI format: date-time/email/int32/etc) #}
{#       - required: string ("true"/"false") #}
{#       - description: string #}
{#       - rust_type: string #}
{#       - go_type: string #}
{#       - ts_type: string #}
{#       - json_schema: string #}
{#       - validation: string #}
{#       - source_ontology: string #}
{#       - confidence: string #}
{#   endpoints: Array of endpoint objects (from api:Endpoint nodes) #}
{#     - method: string (GET/POST/PUT/DELETE) #}
{#     - path: string (URL path) #}
{#     - operationId: string #}
{#     - summary: string #}
{#     - request_body_schema: string (schema name for request body) #}
{#     - response_schema: string (schema name for response) #}
{#     - tags: string (comma-separated tags) #}
{#   ontology_name: string (registry name) #}
{#   api_version: string (OpenAPI spec version) #}
{# #}
{# Example output structure: #}
{#   components: #}
{#     schemas: #}
{#       Person: #}
{#         type: object #}
{#         description: "Auto-generated from schema.org" #}
{#         x-provenance: #}
{#           source: "schema.org" #}
{#           confidence: "0.95" #}
{#           canonical: true #}
{#         properties: #}
{#           hasName: #}
{#             type: string #}
{#             description: "Property hasName (range: string)" #}
{#             x-provenance: #}
{#               source: "schema.org" #}
{#               rust_type: "String" #}
{#           hasEmail: #}
{#             type: string #}
{#             format: email #}
{#         required: #}
{#           - hasName

# ============================================================================
# OpenAPI 3.0.3 Specification
# Generated by ggen OpenAPI Type Registry pipeline: A = mu(O)
# RDF 1.2 triple terms (<<s p o>>) enable axiom-level OpenAPI schema generation
# ============================================================================

openapi: 3.0.3
info:
  title: "{{ ontology_name | default(value='Cross-Ontology Type Registry') }}"
  version: "{{ api_version | default(value='1.0.0') }}"
  description: >
    Auto-generated OpenAPI specification from RDF 1.2 triple-term annotated
    type registry. Each schema component is a projection of ontology axioms
    through SPARQL-star CONSTRUCT + Tera.

    Schemas are derived from canonical type mappings where `tr:isCanonical = true`.
    Properties are typed from `tr:jsonSchema` annotations or inferred from
    `tr:rustType`, `tr:goType`, and `tr:tsType` language bindings.

    Source ontologies: {% set seen_sources = [] %}{% for s in schemas %}{% if s.source_ontology not in seen_sources %}{{ s.source_ontology }}{% if not loop.last %}, {% endif %}{% set _ = seen_sources.append(s.source_ontology) %}{% endif %}{% endfor %}

    Generated: {{ generated_date | default(value=now() | date(format="%Y-%m-%d")) }}
  contact:
    name: "ggen OpenAPI Generator"
    url: "https://ggen.dev"
  license:
    name: "MIT"
    url: "https://opensource.org/licenses/MIT"

servers:
  - url: "http://localhost:8090"
    description: "Local development server"
  - url: "http://localhost:8001"
    description: "BusinessOS backend"
  - url: "http://localhost:8089"
    description: "OSA agent server"

tags:
{% for entity_name in schema_names %}
  - name: "{{ entity_name }}"
    description: "Operations on {{ entity_name }} entities"
{% endfor %}

paths:
{% if endpoints | length > 0 %}
{% for ep in endpoints %}
  {{ ep.path }}:
    {{ ep.method | lower }}:
      operationId: "{{ ep.operationId | default(value=(ep.method | lower ~ '_' ~ ep.path | replace('/', '_') | trim_start_matches(pat='_'))) }}"
      summary: "{{ ep.summary | default(value=(ep.method ~ ' ' ~ ep.path)) }}"
{% if ep.tags and ep.tags != "" %}
      tags:
{% for tag in ep.tags | split(pat=",") %}
        - {{ tag | trim }}
{% endfor %}
{% else %}
      tags:
        - default
{% endif %}
{% if ep.request_body_schema and ep.request_body_schema != "" %}
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: "#/components/schemas/{{ ep.request_body_schema }}"
{% endif %}
      responses:
        "200":
          description: "Successful response"
{% if ep.response_schema and ep.response_schema != "" %}
          content:
            application/json:
              schema:
                $ref: "#/components/schemas/{{ ep.response_schema }}"
{% endif %}
        "400":
          description: "Invalid request"
          content:
            application/json:
              schema:
                type: object
                properties:
                  error:
                    type: string
        "500":
          description: "Internal server error"
          content:
            application/json:
              schema:
                type: object
                properties:
                  error:
                    type: string
{% endfor %}
{% else %}
  /health:
    get:
      operationId: "health_check"
      summary: "Health check endpoint"
      tags:
        - system
      responses:
        "200":
          description: "Service is healthy"
          content:
            application/json:
              schema:
                type: object
                properties:
                  status:
                    type: string
                  version:
                    type: string
{% endif %}

components:
  schemas:
{% for schema in schemas %}
    {{ schema.name }}:
      type: object
      description: "{{ schema.description }}"
      x-provenance:
        source: "{{ schema.source_ontology }}"
        confidence: "{{ schema.confidence }}"
        canonical: {% if schema.canonical == "true" %}true{% else %}false{% endif %}
      properties:
{% for prop in schema.properties %}
        {{ prop.name }}:
          type: {{ prop.type }}
{% if prop.format and prop.format != "" %}
          format: {{ prop.format }}
{% endif %}
          description: "{{ prop.description }}"
{% if prop.validation and prop.validation != "" %}
          x-validation: "{{ prop.validation }}"
{% endif %}
          x-provenance:
            source: "{{ prop.source_ontology }}"
            confidence: "{{ prop.confidence }}"
{% if prop.rust_type and prop.rust_type != "" %}
            rust_type: "{{ prop.rust_type }}"
{% endif %}
{% if prop.go_type and prop.go_type != "" %}
            go_type: "{{ prop.go_type }}"
{% endif %}
{% if prop.ts_type and prop.ts_type != "" %}
            ts_type: "{{ prop.ts_type }}"
{% endif %}
{% endfor %}
{% set required_props = schema.properties | selectattr("required", "equalto", "true") %}
{% if required_props | length > 0 %}
      required:
{% for req in required_props %}
        - {{ req.name }}
{% endfor %}
{% endif %}
{% endfor %}

  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
    apiKeyAuth:
      type: apiKey
      in: header
      name: X-API-Key

security:
  - bearerAuth: []
  - apiKeyAuth: []

# ============================================================================
# Generated by ggen OpenAPI Type Registry pipeline: A = mu(O)
# RDF 1.2 triple terms (<<s p o>>) enable axiom-level OpenAPI schema generation
# SPARQL-star CONSTRUCT + Tera template projection
# Total schemas: {{ schemas | length }}, Total endpoints: {{ endpoints | length }}
# ============================================================================
