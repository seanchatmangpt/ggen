// ---------------------------------------------------------------------------
// HTTP routes
// ---------------------------------------------------------------------------

pub fn router() -> Router {
    let state = Arc::new(AgentState::new());

    Router::new()
        // Agent card
        .route("/.well-known/agent.json", get(agent_card_handler))
        // A2A message dispatch
        .route("/a2a/message", post(message_handler))
        // Task lifecycle
        .route("/a2a/tasks", get(list_tasks_handler))
        .route("/a2a/tasks/{task_id}", get(get_task_handler))
        .route("/a2a/tasks/{task_id}/cancel", post(cancel_task_handler))
        .with_state(state)
}

// -- Agent card ---------------------------------------------------------------

async fn agent_card_handler(State(_state): State<Arc<AgentState>>) -> Json<AgentCard> {
    Json(AgentCard {
        name: "{{ agent_name }}".into(),
        description: "{{ agent_description }}".into(),
        url: "{{ agent_url }}".into(),
        version: "{{ agent_version }}".into(),
        provider: Provider {
            name: "{{ provider_name }}".into(),
            url: if !"{{ provider_url }}".is_empty() {
                Some("{{ provider_url }}".into())
            } else {
                None
            },
        },
        skills: vec![
            {% for skill in skills %}
            SkillDef {
                name: "{{ skill.name }}".into(),
                description: "{{ skill.description }}".into(),
                streaming: {{ skill.streaming | default(value = "false") }},
                timeout_ms: Some({{ skill.timeout_ms | default(value = "30000") }}),
            },
            {% endfor %}
        ],
    })
}

// -- Message dispatch ---------------------------------------------------------

async fn message_handler(
    State(state): State<Arc<AgentState>>,
    Json(msg): Json<A2AMessage>,
) -> (StatusCode, Json<A2AResponse>) {
    match msg.method.as_str() {
        {% for skill in skills %}
        "{{ skill.name }}" => {
            let task = Task::new("{{ skill.name }}".into());
            let task_id = task.id.clone();
            {
                let mut tasks = state.tasks.write().await;
                tasks.insert(task_id.clone(), task);
            }

            let input = match serde_json::from_value::<{{ skill.name | pascal }}Input>(msg.params) {
                Ok(v) => v,
                Err(e) => {
                    return (
                        StatusCode::BAD_REQUEST,
                        Json(A2AResponse::err(
                            msg.id,
                            -32602,
                            format!("Invalid params for {{ skill.name }}: {}", e),
                        )),
                    );
                }
            };

            let id = task_id.clone();
            let state = Arc::clone(&state);

            tokio::spawn(async move {
                // Mark running
                {
                    let mut tasks = state.tasks.write().await;
                    if let Some(t) = tasks.get_mut(&id) {
                        let _ = t.transition_to(TaskStatus::Running);
                    }
                }

                match handle_{{ skill.name | snake }}(input).await {
                    Ok(output) => {
                        let value = serde_json::to_value(&output).unwrap_or_default();
                        let mut tasks = state.tasks.write().await;
                        if let Some(t) = tasks.get_mut(&id) {
                            let _ = t.transition_to(TaskStatus::Completed);
                            t.result = Some(value);
                        }
                    }
                    Err(e) => {
                        let mut tasks = state.tasks.write().await;
                        if let Some(t) = tasks.get_mut(&id) {
                            let _ = t.transition_to(TaskStatus::Failed);
                            t.error = Some(e);
                        }
                    }
                }
            });

            (
                StatusCode::OK,
                Json(A2AResponse::ok(
                    msg.id,
                    serde_json::json!({"taskId": task_id, "status": "created"}),
                )),
            )
        }
        {% endfor %}
        _ => (
            StatusCode::NOT_FOUND,
            Json(A2AResponse::err(msg.id, -32601, format!("Unknown method: {}", msg.method))),
        ),
    }
}

// -- Task lifecycle -----------------------------------------------------------

async fn list_tasks_handler(
    State(state): State<Arc<AgentState>>,
) -> (StatusCode, Json<A2AResponse>) {
    let tasks = state.tasks.read().await;
    let list: Vec<&Task> = tasks.values().collect();
    let value = serde_json::to_value(&list).unwrap_or_default();
    (
        StatusCode::OK,
        Json(A2AResponse::ok(None, serde_json::json!({ "tasks": value }))),
    )
}

async fn get_task_handler(
    State(state): State<Arc<AgentState>>,
    Path(task_id): Path<String>,
) -> (StatusCode, Json<A2AResponse>) {
    let tasks = state.tasks.read().await;
    match tasks.get(&task_id) {
        Some(task) => {
            let value = serde_json::to_value(task).unwrap_or_default();
            (StatusCode::OK, Json(A2AResponse::ok(None, value)))
        }
        None => (
            StatusCode::NOT_FOUND,
            Json(A2AResponse::err(
                None,
                -32603,
                format!("Task not found: {}", task_id),
            )),
        ),
    }
}

async fn cancel_task_handler(
    State(state): State<Arc<AgentState>>,
    Path(task_id): Path<String>,
) -> (StatusCode, Json<A2AResponse>) {
    let mut tasks = state.tasks.write().await;
    match tasks.get_mut(&task_id) {
        Some(task) => match task.transition_to(TaskStatus::Cancelled) {
            Ok(()) => {
                let value = serde_json::to_value(&*task).unwrap_or_default();
                (StatusCode::OK, Json(A2AResponse::ok(None, value)))
            }
            Err(e) => (
                StatusCode::CONFLICT,
                Json(A2AResponse::err(None, -32603, e)),
            ),
        },
        None => (
            StatusCode::NOT_FOUND,
            Json(A2AResponse::err(
                None,
                -32603,
                format!("Task not found: {}", task_id),
            )),
        ),
    }
}

// ---------------------------------------------------------------------------
// Binary entry point
// ---------------------------------------------------------------------------

#[tokio::main]
async fn main() {
    let app = router();

    let addr = std::net::SocketAddr::from(([0, 0, 0, 0], 8090));
    tracing::info!("{{ agent_name }} agent listening on {}", addr);

    let listener = tokio::net::TcpListener::bind(addr).await.unwrap();
    axum::serve(listener, app).await.unwrap();
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

#[cfg(test)]
mod tests {
    use super::*;
    use axum::{
        body::Body,
        http::{Request, StatusCode},
    };
    use tower::ServiceExt; // for oneshot()

    fn app() -> Router {
        router()
    }

    #[tokio::test]
    async fn test_agent_card_returns_200() {
        let resp = app()
            .oneshot(
                Request::builder()
                    .uri("/.well-known/agent.json")
                    .body(Body::empty())
                    .unwrap(),
            )
            .await
            .unwrap();

        assert_eq!(resp.status(), StatusCode::OK);

        let body = hyper::body::to_bytes(resp.into_body()).await.unwrap();
        let card: AgentCard = serde_json::from_slice(&body).unwrap();
        assert_eq!(card.name, "{{ agent_name }}");
        assert_eq!(card.version, "{{ agent_version }}");
        assert!(!card.skills.is_empty());
    }

    #[tokio::test]
    async fn test_task_state_machine_valid_transitions() {
        let mut task = Task::new("test_skill".into());
        assert_eq!(task.status, TaskStatus::Created);

        assert!(task.transition_to(TaskStatus::Running).is_ok());
        assert_eq!(task.status, TaskStatus::Running);

        assert!(task.transition_to(TaskStatus::Completed).is_ok());
        assert!(task.status.is_terminal());
    }

    #[tokio::test]
    async fn test_task_state_machine_invalid_transitions() {
        let mut task = Task::new("test_skill".into());
        // Cannot go Created -> Completed directly
        assert!(task.transition_to(TaskStatus::Completed).is_err());

        // Complete it then try to move again
        let _ = task.transition_to(TaskStatus::Running);
        let _ = task.transition_to(TaskStatus::Completed);
        assert!(task.transition_to(TaskStatus::Running).is_err());
    }

    #[tokio::test]
    async fn test_unknown_method_returns_error() {
        let resp = app()
            .oneshot(
                Request::builder()
                    .method("POST")
                    .uri("/a2a/message")
                    .header("content-type", "application/json")
                    .body(Body::from(
                        r#"{"jsonrpc":"2.0","id":1,"method":"nonexistent","params":{}}"#,
                    ))
                    .unwrap(),
            )
            .await
            .unwrap();

        assert_eq!(resp.status(), StatusCode::NOT_FOUND);
    }

    #[tokio::test]
    async fn test_task_lifecycle() {
        let state = Arc::new(AgentState::new());

        // Create task directly
        let task = Task::new("test".into());
        let task_id = task.id.clone();
        state.tasks.write().await.insert(task_id.clone(), task);

        // Get task
        let tasks = state.tasks.read().await;
        let found = tasks.get(&task_id).unwrap();
        assert_eq!(found.status, TaskStatus::Created);
        drop(tasks);

        // Cancel task
        let mut tasks = state.tasks.write().await;
        let t = tasks.get_mut(&task_id).unwrap();
        assert!(t.transition_to(TaskStatus::Cancelled).is_ok());
    }

    #[tokio::test]
    async fn test_task_status_is_terminal() {
        assert!(!TaskStatus::Created.is_terminal());
        assert!(!TaskStatus::Running.is_terminal());
        assert!(TaskStatus::Completed.is_terminal());
        assert!(TaskStatus::Failed.is_terminal());
        assert!(TaskStatus::Cancelled.is_terminal());
    }
}
