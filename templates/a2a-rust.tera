// ---------------------------------------------------------------------------
// Agent Card  (.well-known/agent.json)
// ---------------------------------------------------------------------------

#[derive(Debug, Clone, Serialize)]
pub struct AgentCard {
    pub name: String,
    pub description: String,
    pub url: String,
    pub version: String,
    pub provider: Provider,
    pub skills: Vec<SkillDef>,
}

#[derive(Debug, Clone, Serialize)]
pub struct Provider {
    pub name: String,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub url: Option<String>,
}

#[derive(Debug, Clone, Serialize)]
pub struct SkillDef {
    pub name: String,
    pub description: String,
    #[serde(rename = "streaming")]
    pub streaming: bool,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub timeout_ms: Option<u64>,
}

// ---------------------------------------------------------------------------
// Task State Machine
// ---------------------------------------------------------------------------
// States: Created -> Running -> Completed | Failed | Cancelled
// Terminal states: Completed, Failed, Cancelled

#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
#[serde(rename_all = "lowercase")]
pub enum TaskStatus {
    Created,
    Running,
    Completed,
    Failed,
    Cancelled,
}

impl TaskStatus {
    pub fn is_terminal(self) -> bool {
        matches!(self, TaskStatus::Completed | TaskStatus::Failed | TaskStatus::Cancelled)
    }

    pub fn can_transition_to(self, target: TaskStatus) -> bool {
        match (self, target) {
            (TaskStatus::Created, TaskStatus::Running) => true,
            (TaskStatus::Created, TaskStatus::Failed) => true,
            (TaskStatus::Created, TaskStatus::Cancelled) => true,
            (TaskStatus::Running, TaskStatus::Completed) => true,
            (TaskStatus::Running, TaskStatus::Failed) => true,
            (TaskStatus::Running, TaskStatus::Cancelled) => true,
            _ => false,
        }
    }
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Task {
    pub id: String,
    pub status: TaskStatus,
    pub skill: String,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub result: Option<serde_json::Value>,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub error: Option<String>,
    pub created_at: u64,
    pub updated_at: u64,
}

impl Task {
    pub fn new(skill: String) -> Self {
        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap_or_default()
            .as_millis() as u64;
        Self {
            id: Uuid::new_v4().to_string(),
            status: TaskStatus::Created,
            skill,
            result: None,
            error: None,
            created_at: now,
            updated_at: now,
        }
    }

    pub fn transition_to(&mut self, target: TaskStatus) -> Result<(), String> {
        if self.status.is_terminal() {
            return Err(format!("task {} is in terminal state {:?}", self.id, self.status));
        }
        if !self.status.can_transition_to(target) {
            return Err(format!(
                "invalid transition from {:?} to {:?}",
                self.status, target
            ));
        }
        self.status = target;
        self.updated_at = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap_or_default()
            .as_millis() as u64;
        Ok(())
    }
}

