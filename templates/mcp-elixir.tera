{# MCP Server template — Elixir/OTP GenServer + JSON-RPC 2.0 (external, user-customizable) #}
{# Pipeline: ontology (.ttl) -> SPARQL CONSTRUCT (.rq) -> Tera (.tera) -> this file #}
{# A = mu(O) #}
{# #}
{# Context variables: #}
{#   server_name        - Server identifier (snake_case) #}
{#   server_description - Human-readable description #}
{#   server_version     - Semver string #}
{#   transport_type     - "stdio" | "http" #}
{#   tools              - Array of tool objects with: #}
{#     name, description, parameters (array of: #}
{#       name, description, elixir_type, json_type, #}
{#       is_required, default_value, enum_values) #}
{# #}
{# Type mapping (json_type -> elixir_type): #}
{#   "string"  -> String.t()  #}
{#   "integer" -> integer()   #}
{#   "number"  -> float()     #}
{#   "boolean" -> boolean()   #}
{#   "array"   -> list()      #}
{#   "object"  -> map()       #}

# ==============================================================================
# Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
# Pipeline: ontology (.ttl) -> SPARQL CONSTRUCT (.rq) -> Tera (.tera) -> this file
# A = mu(O)
#
# Server   : {{ server_name | default(value="mcp_server") }}
# Version  : {{ server_version | default(value="0.1.0") }}
# Transport: {{ transport_type | default(value="stdio") }}
# Tools    : {{ tools | length | default(value=0) }}
# ==============================================================================

defmodule {{ server_name | default(value="mcp_server") | pascal }}.McpServer do
  @moduledoc """
  MCP (Model Context Protocol) server for {{ server_name | default(value="mcp_server") }}.

  {{ server_description | default(value="Generated MCP server") }}

  Communicates via JSON-RPC 2.0 over stdio transport.

  ## Tools ({{ tools | length | default(value=0) }})

  {% for tool in tools %}
  - `{{ tool.name }}` — {{ tool.description | default(value="(no description)") }}
  {% endfor %}

  ## Usage

      iex> {:ok, pid} = {{ server_name | default(value="mcp_server") | pascal }}.McpServer.start_link()
      iex> {{ server_name | default(value="mcp_server") | pascal }}.McpServer.tools()
      iex> {{ server_name | default(value="mcp_server") | pascal }}.McpServer.call_tool("tool_name", %{"param" => "value"})
  """

  use GenServer

  require Logger

  # ===========================================================================
  # Tool definitions — @tools module attribute
  # ===========================================================================
  # Each tool follows the MCP tool schema:
  #   name         - Unique tool identifier
  #   description  - Human-readable description shown to LLM clients
  #   input_schema - JSON Schema object describing parameters
  #     type       - Always "object"
  #     properties - Map of param name -> {type, description}
  #     required   - List of required parameter names

  @tools [
    {% for tool in tools %}
    %{
      name: "{{ tool.name }}",
      description: "{{ tool.description | default(value="(no description)") }}",
      input_schema: %{
        "type" => "object",
        "properties" => %{
          {% for param in tool.parameters %}
          "{{ param.name }}" => %{
            "type" => "{{ param.json_type | default(value="string") }}",
            "description" => "{{ param.description | default(value=param.name) }}"
            {% if param.enum_values %}
            , "enum" => {{ param.enum_values }}
            {% endif %}
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        },
        "required" => [
          {% for param in tool.parameters %}
          {% if param.is_required == "true" %}
          "{{ param.name }}"{% if not loop.last %},{% endif %}
          {% endif %}
          {% endfor %}
        ]
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]

  # ===========================================================================
  # @callback — behavior contract for tool handlers
  # ===========================================================================
  # Implement this callback in a separate module to provide actual tool logic.
  # Pass the handler module via start_link(handler: MyHandler).

  @callback handle_tool(tool_name :: String.t(), params :: map()) ::
              {:ok, map()} | {:ok, String.t()} | {:error, String.t()}

  @callback handle_resource(uri :: String.t()) ::
              {:ok, String.t()} | {:error, String.t()}

  # ===========================================================================
  # Type specifications
  # ===========================================================================

  @type tool_def :: %{
    name: String.t(),
    description: String.t(),
    input_schema: map()
  }

  @type state :: %{
    handler: module(),
    started_at: DateTime.t(),
    request_count: non_neg_integer()
  }

  # ===========================================================================
  # Client API
  # ===========================================================================

  @doc """
  Start the MCP server.

  ## Options

    * `:handler` — Module implementing the `handle_tool/2` callback.
                   Defaults to `__MODULE__` (returns not-implemented stubs).
  """
  @spec start_link(keyword()) :: GenServer.on_start()
  def start_link(opts \\ []) do
    GenServer.start_link(__MODULE__, opts, name: __MODULE__)
  end

  @doc """
  List all available tools with their schemas.
  """
  @spec tools() :: [tool_def()]
  def tools do
    GenServer.call(__MODULE__, :list_tools, 5000)
  end

  @doc """
  Invoke a tool by name with the given parameters.

  Returns `{:ok, result}` on success or `{:error, reason}` on failure.
  """
  @spec call_tool(String.t(), map()) :: {:ok, map() | String.t()} | {:error, String.t()}
  def call_tool(name, params) when is_binary(name) and is_map(params) do
    GenServer.call(__MODULE__, {:call_tool, name, params}, 30_000)
  end

  @doc """
  Get server info (name, version, protocol version, capabilities).
  """
  @spec server_info() :: map()
  def server_info do
    %{
      "name" => "{{ server_name | default(value='mcp-server') }}",
      "version" => "{{ server_version | default(value='0.1.0') }}",
      "protocolVersion" => "2024-11-05",
      "capabilities" => %{
        "tools" => %{}
      }
    }
  end

  @doc """
  Get the current request count.
  """
  @spec request_count() :: non_neg_integer()
  def request_count do
    GenServer.call(__MODULE__, :request_count, 1000)
  end

  # ===========================================================================
  # Default tool handler (stub — override via :handler option)
  # ===========================================================================
  # Returns not-implemented responses for all tools.
  # Users should provide their own handler module.

  @impl true
  def handle_tool(tool_name, _params) do
    Logger.warning("MCP tool '#{tool_name}' called but no handler module configured")
    {:error, "Tool '#{tool_name}' not implemented — configure a handler module"}
  end

  # ===========================================================================
  # GenServer callbacks
  # ===========================================================================

  @impl true
  @spec init(keyword()) :: {:ok, state()}
  def init(opts) do
    handler = Keyword.get(opts, :handler, __MODULE__)
    Logger.info("MCP server starting: handler=#{inspect(handler)}, tools=#{length(@tools)}")
    {:ok, %{
      handler: handler,
      started_at: DateTime.utc_now(),
      request_count: 0
    }}
  end

  @impl true
  def handle_call(:list_tools, _from, state) do
    {:reply, @tools, state}
  end

  @impl true
  def handle_call({:call_tool, name, params}, _from, state) do
    case Enum.find(@tools, & &1[:name] == name) do
      nil ->
        Logger.warning("MCP: unknown tool called: #{name}")
        {:reply, {:error, "Unknown tool: #{name}"}, state}

      _tool ->
        new_count = state.request_count + 1
        case apply(state.handler, :handle_tool, [name, params]) do
          {:ok, result} ->
            {:reply, {:ok, result}, %{state | request_count: new_count}}

          {:error, reason} ->
            Logger.error("MCP tool '#{name}' failed: #{reason}")
            {:reply, {:error, reason}, %{state | request_count: new_count}}
        end
    end
  end

  @impl true
  def handle_call(:request_count, _from, state) do
    {:reply, state.request_count, state}
  end

  # ===========================================================================
  # Stdio JSON-RPC 2.0 transport
  # ===========================================================================
  # Reads JSON-RPC requests from stdin, dispatches to the appropriate handler,
  # and writes JSON-RPC responses to stdout.
  #
  # Supported methods:
  #   "initialize"      -> server info + capabilities
  #   "notifications/initialized" -> ack (no response)
  #   "tools/list"      -> list all tool definitions
  #   "tools/call"      -> invoke a tool by name with params

  @impl true
  def handle_info({:stdin, line}, state) do
    case Jason.decode(line) do
      {:ok, request} ->
        response = handle_json_rpc(request, state)
        write_json_rpc_response(response)

      {:error, _reason} ->
        error_resp = json_rpc_error(nil, -32700, "Parse error: invalid JSON")
        write_json_rpc_response(error_resp)
    end

    {:noreply, state}
  end

  @impl true
  def handle_info({:stdin_eof}, state) do
    Logger.info("MCP server: stdin closed, shutting down")
    {:stop, :normal, state}
  end

  @impl true
  def handle_info(msg, state) do
    Logger.debug("MCP server: unhandled message: #{inspect(msg)}")
    {:noreply, state}
  end

  # ===========================================================================
  # JSON-RPC 2.0 dispatch
  # ===========================================================================

  defp handle_json_rpc(%{"method" => "initialize"} = req, _state) do
    id = Map.get(req, "id")
    json_rpc_result(id, %{
      "protocolVersion" => "2024-11-05",
      "capabilities" => %{"tools" => %{}},
      "serverInfo" => %{
        "name" => "{{ server_name | default(value='mcp-server') }}",
        "version" => "{{ server_version | default(value='0.1.0') }}"
      }
    })
  end

  defp handle_json_rpc(%{"method" => "notifications/initialized"}, _state) do
    :no_response
  end

  defp handle_json_rpc(%{"method" => "tools/list"} = req, _state) do
    id = Map.get(req, "id")
    tool_list = Enum.map(@tools, fn t ->
      %{"name" => t.name, "description" => t.description, "inputSchema" => t.input_schema}
    end)
    json_rpc_result(id, %{"tools" => tool_list})
  end

  defp handle_json_rpc(%{"method" => "tools/call"} = req, state) do
    id = Map.get(req, "id")
    params = Map.get(req, "params", %{})
    tool_name = Map.get(params, "name", "")
    arguments = Map.get(params, "arguments", %{})

    case Enum.find(@tools, & &1[:name] == tool_name) do
      nil ->
        json_rpc_error(id, -32601, "Tool not found: #{tool_name}")

      _tool ->
        new_count = state.request_count + 1
        case apply(state.handler, :handle_tool, [tool_name, arguments]) do
          {:ok, result} ->
            content = format_tool_result(result)
            json_rpc_result(id, %{
              "content" => [content],
              "isError" => false
            })

          {:error, reason} ->
            json_rpc_result(id, %{
              "content" => [%{"type" => "text", "text" => "Error: #{reason}"}],
              "isError" => true
            })
        end
    end
  end

  defp handle_json_rpc(%{"id" => id} = _req, _state) do
    json_rpc_error(id, -32601, "Method not found")
  end

  defp handle_json_rpc(_req, _state) do
    :no_response
  end

  # ===========================================================================
  # JSON-RPC 2.0 message helpers
  # ===========================================================================

  defp json_rpc_result(nil, _result), do: :no_response
  defp json_rpc_result(id, result) do
    %{"jsonrpc" => "2.0", "id" => id, "result" => result}
  end

  defp json_rpc_error(id, code, message) do
    %{
      "jsonrpc" => "2.0",
      "id" => id,
      "error" => %{"code" => code, "message" => message}
    }
  end

  defp write_json_rpc_response(:no_response), do: :ok
  defp write_json_rpc_response(response) do
    case Jason.encode(response) do
      {:ok, json} ->
        IO.puts(json)
        IO.flush()

      {:error, reason} ->
        Logger.error("MCP: failed to encode response: #{inspect(reason)}")
    end
  end

  defp format_tool_result(result) when is_binary(result) do
    %{"type" => "text", "text" => result}
  end

  defp format_tool_result(result) when is_map(result) do
    %{"type" => "text", "text" => Jason.encode!(result)}
  end

  defp format_tool_result(result) do
    %{"type" => "text", "text" => inspect(result)}
  end
end

# ==============================================================================
# Application module
# ==============================================================================
# Registers the MCP server under the application supervision tree.
# Add this to your mix.exs `applications` list.

defmodule {{ server_name | default(value="mcp_server") | pascal }}.Application do
  @moduledoc """
  OTP Application for {{ server_name | default(value="mcp_server") }} MCP server.

  Starts the MCP server GenServer and links it to the supervision tree.
  """
  use Application
  require Logger

  @impl true
  def start(_type, _args) do
    children = [
      {{ server_name | default(value="mcp_server") | pascal }}.McpServer
    ]

    opts = [strategy: :one_for_one, name: {{ server_name | default(value="mcp_server") | pascal }}.Supervisor]
    Supervisor.start_link(children, opts)
  end
end

# ==============================================================================
# Stdio reader — spawns a process that reads stdin and sends to the server
# ==============================================================================
# Call `{{ server_name | default(value="mcp_server") | pascal }}.StdioReader.start()` to begin
# reading JSON-RPC lines from stdin.

defmodule {{ server_name | default(value="mcp_server") | pascal }}.StdioReader do
  @moduledoc """
  Reads JSON-RPC lines from stdin and forwards them to the MCP server GenServer.

  Designed for stdio transport: the parent process (e.g., an LLM client) writes
  JSON-RPC requests to this process's stdin. This module reads each line and
  sends it as a message to the MCP server.
  """
  require Logger

  @read_timeout_ms 30_000

  @spec start() :: GenServer.on_start()
  def start do
    spawn_link(fn -> read_loop() end)
  end

  defp read_loop do
    case IO.gets("") do
      :eof ->
        Logger.info("StdioReader: EOF received")
        send({{ server_name | default(value="mcp_server") | pascal }}.McpServer, {:stdin_eof})

      {:error, reason} ->
        Logger.error("StdioReader: read error: #{inspect(reason)}")

      line ->
        line = String.trim(line)
        if line != "" do
          send({{ server_name | default(value="mcp_server") | pascal }}.McpServer, {:stdin, line})
        end
        read_loop()
    end
  end
end

