[package]
name    = "{{ server_name }}"
version = "0.1.0"
edition = "2021"

[workspace]

[[bin]]
name = "{{ server_name }}"
path = "src/main.rs"

[dependencies]
lsp-max              = { path = "../../../../../../../lsp-max" }
tree-sitter          = "0.26"
{{ grammar_crate | replace(from="_", to="-") }} = "0.23"
tokio                = { version = "1", features = ["full"] }
tracing              = "0.1"
tracing-subscriber   = { version = "0.3", features = ["env-filter"] }
toml                 = "0.8"
clap                 = { version = "4", features = ["derive"] }
regex                = "1"

[build-dependencies]
# cc = "1"  # uncomment if grammar crate requires a C source build step
