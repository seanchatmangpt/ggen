{# rust-struct-from-ontology.tera: Generate Rust struct definitions from annotated ontology axioms #}
{# Constitutional Equation: struct.rs = mu(codegen_annotations_ontology.ttl) #}
{# Input: field_mappings — array of objects from codegen-annotations-extract.rq CONSTRUCT output #}
{# Each object: className, fieldName, fieldRange, rustType, goType, elixirType, tsType, #}
{#              jsonKey, required, validator, deprecated, sinceVersion, docComment, #}
{#              serdeAttr, defaultValue, precision, minimum, maximum #}

// Auto-generated by ggen from codegen annotations ontology — DO NOT EDIT
// Source: codegen-annotations.ttl + codegen-annotations-example.ttl
// Query: codegen-annotations-extract.rq
// Generated: {{ generated_date | default(value=now() | date(format="%Y-%m-%d %H:%M")) }}

{% set seen_classes = [] %}
{% set current_class = "" %}

{% for field in field_mappings %}
{% if seen_classes is not containing(field.class_name) %}
{% if current_class != "" %}
}
{% endif %}

{% set _ = seen_classes.append(field.class_name) %}
{% set current_class = field.class_name %}

/// Auto-generated struct for `{{ field.class_name }}`.
#[derive(Debug, Clone, Serialize, Deserialize)]
{% for f in field_mappings %}
{% if f.class_name == current_class and f.deprecated == "true" %}
/// # Deprecated Fields
/// This struct contains deprecated fields. See field-level docs for migration guidance.
{% break %}
{% endif %}
{% endfor %}
pub struct {{ field.class_name }} {
{% endif %}

{# --- field doc comment --- #}
{% if field.doc_comment %}
    /// {{ field.doc_comment }}.
{% endif %}
{% if field.validator %}
    /// Validated by: `{{ field.validator }}()`.
{% endif %}
{% if field.deprecated == "true" %}
    #[deprecated(since = "{{ field.since_version | default(value="unknown") }}")]
{% endif %}
{% if field.serde_attr %}
    {{ field.serde_attr }}
{% elif field.json_key and field.json_key != field.field_name %}
    #[serde(rename = "{{ field.json_key }}")]
{% endif %}
{% if field.required == "true" %}
    pub {{ field.field_name }}: {{ field.rust_type }},
{% else %}
    pub {{ field.field_name }}: Option<{{ field.rust_type }}>,
{% endif %}
{% endfor %}
}

{% for field in field_mappings %}
{% if field.class_name == current_class and (field.precision or field.minimum or field.maximum) %}
{% break %}
{% endif %}
{% endfor %}
{# --- validation constraints (as impl block doc comment) --- #}
{% set has_constraints = false %}
{% for field in field_mappings %}
{% if field.precision or field.minimum or field.maximum %}
{% set has_constraints = true %}
{% break %}
{% endif %}
{% endfor %}

{% if has_constraints %}

// Validation constraints for generated structs:
{% for field in field_mappings %}
{% if field.class_name == current_class %}
{% if field.precision %}
//   {{ current_class }}.{{ field.field_name }}: precision = {{ field.precision }} decimal places
{% endif %}
{% if field.minimum %}
//   {{ current_class }}.{{ field.field_name }}: minimum = {{ field.minimum }}
{% endif %}
{% if field.maximum %}
//   {{ current_class }}.{{ field.field_name }}: maximum = {{ field.maximum }}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
