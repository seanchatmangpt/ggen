{
  // VS Code settings generated by ggen from project conventions
  // Regenerate with: ggen onboarding --ide vscode
  // Source: onboarding-conventions.ttl
  //
  // Project: {{ project_name }}
  // Generated: {{ now() | date(format="%Y-%m-%d %H:%M:%S") }}

  // ========================================================================
  // Editor Configuration
  // ========================================================================

  "editor.fontSize": 14,
  "editor.tabSize": {{ default_indent_size | default(value=2) }},
  "editor.insertSpaces": {% if default_indent_style == "space" %}true{% else %}false{% endif %},
  "editor.rulers": [{% for ec in editor_configs %}{{ ec.maxLineWidth }}{% if not loop.last %}, {% endif %}{% endfor %}],
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "files.encoding": "{{ default_charset | default(value="utf-8") }}",
  "files.eol": "{{ default_eol | default(value="\n") }}",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ========================================================================
  // Language-Specific Settings
  // ========================================================================

{% for ec in editor_configs %}
{% if ec.appliesToLanguage is defined %}
  // --- {{ ec.appliesToLanguage }} ---
  "[{{ ec.fileExtension }}]": {
    "editor.tabSize": {{ ec.indentSize }},
    "editor.insertSpaces": {% if ec.indentStyle == "space" %}true{% else %}false{% endif %},
    "editor.rulers": [{{ ec.maxLineWidth }}]
  },

{% endif %}
{% endfor %}

  // ========================================================================
  // Formatters
  // ========================================================================

{% for fmt in formatters %}
{% if fmt.languageName == "Rust" %}
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "rust-analyzer.formatting.command": "rustfmt",
{% elif fmt.languageName == "Go" %}
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
{% elif fmt.languageName == "Elixir" %}
  "[elixir]": {
    "editor.defaultFormatter": "JakeBecker.elixir-ls"
  },
{% elif fmt.languageName == "TypeScript" %}
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
{% endif %}
{% endfor %}

  // ========================================================================
  // Linters
  // ========================================================================

{% for lint in linters %}
{% if lint.languageName == "Rust" %}
  "rust-analyzer.checkOnSave.command": "clippy",
  "rust-analyzer.checkOnSave.extraArgs": ["--", "-D", "warnings"],
{% elif lint.languageName == "Go" %}
  "go.lintTool": "staticcheck",
  "go.lintOnSave": "package",
{% elif lint.languageName == "Elixir" %}
  "elixirLS.credo.enabled": true,
{% endif %}
{% endfor %}

  // ========================================================================
  // Recommended Extensions
  // ========================================================================

  "recommendations": [
{% for lang in languages %}
{% if lang is mapping %}
{% if lang.languageName == "Rust" %}
    "rust-lang.rust-analyzer",
    "vadimcn.vscode-lldb",
    "serayuzgur.crates",
{% elif lang.languageName == "Go" %}
    "golang.go",
{% elif lang.languageName == "Elixir" %}
    "JakeBecker.elixir-ls",
{% elif lang.languageName == "TypeScript" %}
    "esbenp.prettier-vscode",
    "dbaeumer.vscode-eslint",
{% endif %}
{% endif %}
{% endfor %}
    "EditorConfig.EditorConfig",
    "streetsidesoftware.code-spell-checker",
    "GitHub.copilot"
  ]
}
