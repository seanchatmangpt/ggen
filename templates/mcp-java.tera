// =============================================================================
// JSON-RPC 2.0 Protocol Types
// =============================================================================

/**
 * JSON-RPC 2.0 request envelope.
 */
record JsonRpcRequest(
    String jsonrpc,
    Object id,
    String method,
    JsonNode params
) {}

/**
 * JSON-RPC 2.0 response envelope.
 */
@JsonInclude(JsonInclude.Include.NON_NULL)
record JsonRpcResponse(
    String jsonrpc,
    Object id,
    Object result,
    JsonRpcError error
) {
    static JsonRpcResponse success(Object id, Object result) {
        return new JsonRpcResponse("2.0", id, result, null);
    }

    static JsonRpcResponse error(Object id, int code, String message) {
        return new JsonRpcResponse("2.0", id, null, new JsonRpcError(code, message, null));
    }
}

/**
 * JSON-RPC 2.0 error object.
 */
record JsonRpcError(int code, String message, Object data) {}

// =============================================================================
// MCP Domain Types
// =============================================================================

/**
 * Tool definition for tools/list response.
 */
record ToolDefinition(
    String name,
    String description,
    Map<String, Object> inputSchema
) {}

/**
 * Content block in a tool result.
 */
@JsonInclude(JsonInclude.Include.NON_NULL)
record ToolContent(String type, String text) {}

/**
 * Tool invocation result.
 */
@JsonInclude(JsonInclude.Include.NON_NULL)
record ToolResult(List<ToolContent> content, Boolean isError) {
    static ToolResult ok(String text) {
        return new ToolResult(List.of(new ToolContent("text", text)), null);
    }

    static ToolResult fail(String text) {
        return new ToolResult(List.of(new ToolContent("text", text)), true);
    }
}

