/**
 * {{ server_name }} - MCP Server v{{ server_version }}.
 *
 * {{ server_description }}
 *
 * Implements the Model Context Protocol over stdio using JSON-RPC 2.0.
 */
public class {{ server_name | pascal }}Server {

    private static final String PROTOCOL_VERSION = "2024-11-05";
    private final ObjectMapper mapper;
    private final String serverName;
    private final String serverVersion;
    private boolean shutdownRequested = false;

    public {{ server_name | pascal }}Server() {
        this("{{ server_name }}", "{{ server_version }}");
    }

    public {{ server_name | pascal }}Server(String serverName, String serverVersion) {
        this.serverName = serverName;
        this.serverVersion = serverVersion;
        this.mapper = new ObjectMapper();
        this.mapper.setSerializationInclusion(JsonInclude.Include.NON_NULL);
    }

    // -------------------------------------------------------------------------
    // Tool Handlers
    // -------------------------------------------------------------------------

    {% for tool in tools %}
    /**
     * Handle {{ tool.name }}: {{ tool.description }}
     */
    public ToolResult handle{{ tool.name | pascal }}(Map<String, Object> params) {
        try {
            {{ tool.name | pascal }}Input input = mapper.convertValue(params, {{ tool.name | pascal }}Input.class);

            // TODO: Implement {{ tool.name }} logic here
            // Parameters available:
            {% for param in tool.parameters %}
            // - {{ param.name }}: {{ param.java_type }}{% if param.description %} -- {{ param.description }}{% endif %}
            {% endfor %}

            return ToolResult.ok(mapper.writeValueAsString(
                Map.of("success", true, "tool", "{{ tool.name }}")
            ));
        } catch (IllegalArgumentException e) {
            return ToolResult.fail("Invalid arguments for {{ tool.name }}: " + e.getMessage());
        } catch (JsonProcessingException e) {
            return ToolResult.fail("Serialization error: " + e.getMessage());
        }
    }

    {% endfor %}

    // -------------------------------------------------------------------------
    // Request Dispatch
    // -------------------------------------------------------------------------

    /**
     * Dispatch a JSON-RPC request to the appropriate handler.
     */
    public JsonRpcResponse handleRequest(JsonRpcRequest request) {
        return switch (request.method()) {
            case "initialize" -> handleInitialize(request.id());
            case "notifications/initialized" -> JsonRpcResponse.success(request.id(), Map.of());
            case "tools/list" -> handleListTools(request.id());
            case "tools/call" -> handleCallTool(request.id(), request.params());
            case "shutdown" -> {
                shutdownRequested = true;
                yield JsonRpcResponse.success(request.id(), Map.of());
            }
            case "exit" -> JsonRpcResponse.success(request.id(), Map.of());
            default -> JsonRpcResponse.error(request.id(), -32601,
                "Method not found: " + request.method());
        };
    }

    // -------------------------------------------------------------------------
    // Protocol Handlers
    // -------------------------------------------------------------------------

    private JsonRpcResponse handleInitialize(Object id) {
        Map<String, Object> result = new LinkedHashMap<>();
        result.put("protocolVersion", PROTOCOL_VERSION);

        Map<String, Object> serverInfo = new LinkedHashMap<>();
        serverInfo.put("name", serverName);
        serverInfo.put("version", serverVersion);
        result.put("serverInfo", serverInfo);

        Map<String, Object> capabilities = new LinkedHashMap<>();
        Map<String, Object> toolsCap = new LinkedHashMap<>();
        toolsCap.put("listChanged", false);
        capabilities.put("tools", toolsCap);
        result.put("capabilities", capabilities);

        return JsonRpcResponse.success(id, result);
    }

    private JsonRpcResponse handleListTools(Object id) {
        List<ToolDefinition> tools = List.of(
            {% for tool in tools %}
            new ToolDefinition(
                "{{ tool.name }}",
                "{{ tool.description }}",
                {{ tool.name | camel }}Schema()
            ){% if not loop.last %},{% endif %}
            {% endfor %}
        );

        return JsonRpcResponse.success(id, Map.of("tools", tools));
    }

    private JsonRpcResponse handleCallTool(Object id, JsonNode params) {
        if (params == null || !params.has("name")) {
            return JsonRpcResponse.error(id, -32602, "Missing tool name");
        }

        String toolName = params.get("name").asText();
        Map<String, Object> arguments = new LinkedHashMap<>();

        if (params.has("arguments") && params.get("arguments").isObject()) {
            Iterator<Map.Entry<String, JsonNode>> fields = params.get("arguments").fields();
            while (fields.hasNext()) {
                Map.Entry<String, JsonNode> entry = fields.next();
                arguments.put(entry.getKey(), convertJsonNode(entry.getValue()));
            }
        }

        ToolResult result = switch (toolName) {
            {% for tool in tools %}
            case "{{ tool.name }}" -> handle{{ tool.name | pascal }}(arguments);
            {% endfor %}
            default -> ToolResult.fail("Unknown tool: " + toolName);
        };

        return JsonRpcResponse.success(id, result);
    }

    // -------------------------------------------------------------------------
    // Tool Schemas
    // -------------------------------------------------------------------------

    {% for tool in tools %}
    /**
     * Build JSON Schema for {{ tool.name }} input.
     */
    @SuppressWarnings("unchecked")
    private Map<String, Object> {{ tool.name | camel }}Schema() {
        Map<String, Object> properties = new LinkedHashMap<>();
        List<String> required = new ArrayList<>();

        {% for param in tool.parameters %}
        Map<String, Object> {{ param.name }}Schema = new LinkedHashMap<>();
        {{ param.name }}Schema.put("type", "{{ param.json_schema_type | default(value=param.java_json_type) }}");
        {{ param.name }}Schema.put("description", "{{ param.description }}");
        {% if param.enum_values %}
        {{ param.name }}Schema.put("enum", List.of({{ param.enum_values }}));
        {% endif %}
        properties.put("{{ param.name }}", {{ param.name }}Schema);
        {% if param.is_required == "true" %}
        required.add("{{ param.name }}");
        {% endif %}

        {% endfor %}

        Map<String, Object> schema = new LinkedHashMap<>();
        schema.put("type", "object");
        schema.put("properties", properties);
        if (!required.isEmpty()) {
            schema.put("required", required);
        }
        return schema;
    }

    {% endfor %}

    // -------------------------------------------------------------------------
    // Utilities
    // -------------------------------------------------------------------------

    /**
     * Convert a Jackson JsonNode to a plain Java Object for handler consumption.
     */
    private Object convertJsonNode(JsonNode node) {
        if (node == null || node.isNull()) {
            return null;
        }
        if (node.isTextual()) return node.asText();
        if (node.isInt()) return node.asInt();
        if (node.isLong()) return node.asLong();
        if (node.isDouble()) return node.asDouble();
        if (node.isBoolean()) return node.asBoolean();
        if (node.isArray()) {
            List<Object> list = new ArrayList<>();
            for (JsonNode element : node) {
                list.add(convertJsonNode(element));
            }
            return list;
        }
        if (node.isObject()) {
            Map<String, Object> map = new LinkedHashMap<>();
            Iterator<Map.Entry<String, JsonNode>> fields = node.fields();
            while (fields.hasNext()) {
                Map.Entry<String, JsonNode> entry = fields.next();
                map.put(entry.getKey(), convertJsonNode(entry.getValue()));
            }
            return map;
        }
        return node.toString();
    }

    // -------------------------------------------------------------------------
    // Stdio Transport Loop
    // -------------------------------------------------------------------------

    /**
     * Run the MCP server over stdio (JSON-RPC 2.0 line-delimited).
     */
    public void run() throws IOException {
        BufferedReader reader = new BufferedReader(new InputStreamReader(System.in));
        PrintWriter writer = new PrintWriter(System.out, true);

        String line;
        while (!shutdownRequested && (line = reader.readLine()) != null) {
            line = line.trim();
            if (line.isEmpty()) continue;

            try {
                JsonRpcRequest request = mapper.readValue(line, JsonRpcRequest.class);
                JsonRpcResponse response = handleRequest(request);
                writer.println(mapper.writeValueAsString(response));
            } catch (JsonProcessingException e) {
                JsonRpcResponse errorResp = JsonRpcResponse.error(null, -32700,
                    "Parse error: " + e.getMessage());
                writer.println(mapper.writeValueAsString(errorResp));
            }
        }
    }

    // =============================================================================
    // Main
    // =============================================================================

    public static void main(String[] args) throws IOException {
        {{ server_name | pascal }}Server server = new {{ server_name | pascal }}Server();
        server.run();
    }
}
