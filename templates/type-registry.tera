{# type-registry.tera — Cross-Ontology Unified Type Registry #}
{# Constitutional Equation: registry.md = mu(type-registry.ttl + all source ontologies) #}
{# Input: SPARQL-star CONSTRUCT results from type-registry-extract.rq #}
{# Output: Markdown type registry showing unified mappings across all ontologies #}
{# #}
{# Variables expected from CONSTRUCT output (Vec<BTreeMap<String, String>>): #}
{#   mappings: Array of TypeMapping objects with fields: #}
{#     domainEntity, domainProperty, domainRange, sourceName, rustType, goType, #}
{#     elixirType, tsType, pythonType, confidence, isCanonical, jsonSchema, #}
{#     validationRule, sinceVersion, conversionNote, deprecatedBy #}
{#   registrySummary: Object with fields: totalMappings, canonicalCount, deprecatedCount #}
{#   sourceCounts: Array of source count objects with fields: sourceName, mappingCount #}

# Cross-Ontology Type Registry

