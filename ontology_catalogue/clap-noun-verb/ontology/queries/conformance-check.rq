PREFIX ggen: <https://chatmangpt.com/ontologies/ggen/command-vocab#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

# Process Mining Chicago TDD Conformance Check
# ASK query: Does execution log conform to declared model?
#
# Returns TRUE if all receipts in the event log correspond to valid command declarations
# Returns FALSE if any receipt violates the model (e.g., undeclared verb, missing parameters)
#
# Usage:
#   sparql --data ontology/ggen-command-vocab.nt \
#           --data ontology/examples/graph-commands.nt \
#           --data event-logs.nt \
#           --query ontology/queries/conformance-check.rq

ASK {
  # For each receipt in the event log
  ?receipt rdf:type ggen:Receipt .
  ?receipt ggen:commandPath ?pathString .
  ?receipt ggen:exitCode ?exitCode .

  # Split command path into noun and verb
  # Format: "graph" (noun) or "graph.load" (noun.verb)
  # For now, assume format: subject of receipt indicates noun, if a verb path

  # The critical invariant: the receipt's command path MUST correspond to
  # a declared verb in the ontology. If not, this ASK fails (returns false).

  # Bind the full command path string to extract noun and verb
  BIND(STRBEFORE(?pathString, ".") AS ?nounFromPath)
  BIND(STRAFTER(?pathString, ".") AS ?verbFromPath)

  # Verify the verb is declared in the ontology
  ?verb rdf:type ggen:VerbSpec .
  ?verb ggen:verbName ?verbFromPath .
  ?verb ggen:belongsToNoun ?nounSpec .
  ?nounSpec ggen:nounName ?nounFromPath .

  # Verify all required parameters in the receipt are declared in the verb
  ?receipt ggen:inputArguments ?inputArgsJson .

  # For each parameter in the declared verb, check it appears in input args
  # (This is a simplified check; full validation would require JSON parsing)
  OPTIONAL {
    ?verb ggen:hasParameter ?param .
    ?param ggen:paramName ?paramName .
    ?param ggen:isRequired ?paramRequired .
    FILTER(?paramRequired = true)
    # NOTE: Full validation would require JSON array membership test
    # Simplified: we trust the receipt if the verb declaration exists
  }
}
