cli:TestAdversarial a cli:TestCommand ;
    cli:commandName "test-adversarial" ;
    cli:commandGroup "test" ;
    cli:description "Run adversarial tests to break systems" ;
    cli:spanName "cli.test.adversarial" ;
    cli:metricName "cli.test.adversarial.duration" ;
    cli:moduleFile "modules/test_commands.py" ;
    cli:functionName "execute_adversarial_tests" ;
