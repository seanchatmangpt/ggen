# =============================================================================
# COMMAND ARGUMENTS AND OPTIONS INSTANCES
# =============================================================================

# Status Command Arguments
cli:StatusVerboseOption a cli:CommandOption ;
    cli:optionName "verbose" ;
    cli:shortFlag "-v" ;
    cli:longFlag "--verbose" ;
    cli:argumentType "bool" ;
    cli:defaultValue "false"^^xsd:boolean ;
    cli:required "false"^^xsd:boolean ;
    rdfs:comment "Show detailed status information" .

cli:Status cli:hasOption cli:StatusVerboseOption .

# Build Command Options
cli:BuildOptimizationOption a cli:CommandOption ;
    cli:optionName "optimization" ;
    cli:shortFlag "-O" ;
    cli:longFlag "--optimization" ;
    cli:argumentType "string" ;
    cli:defaultValue "O3" ;
    cli:required "false"^^xsd:boolean ;
    rdfs:comment "Optimization level (O0/O1/O2/O3)" .

cli:BuildTargetOption a cli:CommandOption ;
    cli:optionName "target" ;
    cli:shortFlag "-t" ;
    cli:longFlag "--target" ;
    cli:argumentType "string" ;
    cli:defaultValue "all" ;
    cli:required "false"^^xsd:boolean ;
    rdfs:comment "Build target (all/core/specific)" .

cli:BuildAll cli:hasOption cli:BuildOptimizationOption ;
           cli:hasOption cli:BuildTargetOption .

# Turtle Analysis Arguments
cli:TurtleFileArgument a cli:CommandArgument ;
    cli:argumentName "file" ;
    cli:argumentType "path" ;
    cli:required "true"^^xsd:boolean ;
    rdfs:comment "Turtle file to analyze" .

cli:TurtleDetailedOption a cli:CommandOption ;
    cli:optionName "detailed" ;
    cli:shortFlag "-d" ;
    cli:longFlag "--detailed" ;
    cli:argumentType "bool" ;
    cli:defaultValue "false"^^xsd:boolean ;
    cli:required "false"^^xsd:boolean ;
    rdfs:comment "Show detailed analysis results" .

cli:TurtleSwarmOption a cli:CommandOption ;
    cli:optionName "swarm" ;
    cli:shortFlag "-s" ;
    cli:longFlag "--swarm" ;
    cli:argumentType "bool" ;
    cli:defaultValue "false"^^xsd:boolean ;
    cli:required "false"^^xsd:boolean ;
    rdfs:comment "Deploy 12-agent swarm for analysis" .

cli:AnalyzeTurtle cli:hasArgument cli:TurtleFileArgument ;
                 cli:hasOption cli:TurtleDetailedOption ;
                 cli:hasOption cli:TurtleSwarmOption .

# =============================================================================
# WEAVER INSTRUMENTATION DEFINITIONS
# =============================================================================

# Status Command Instrumentation
cli:StatusSpan a cli:TelemetrySpan ;
    cli:spanName "cli.system.status" ;
    otel:operationName "system_status_check" ;
    otel:spanKind "internal" ;
    cli:attributes [
        otel:attributeName "cli.command" ;
        otel:attributeValue "status" ;
        otel:attributeType "string"
    ] ,
    [
        otel:attributeName "cli.group" ;
        otel:attributeValue "system" ;
        otel:attributeType "string"  
    ] ,
    [
        otel:attributeName "system.components_checked" ;
        otel:attributeType "int"
    ] ,
    [
        otel:attributeName "system.health_score" ;
        otel:attributeType "float"
    ] .

cli:StatusDurationMetric a cli:MetricDefinition ;
    cli:metricName "cli.system.status.duration" ;
    otel:metricType "histogram" ;
    otel:unit "ms" ;
    otel:description "Duration of status command execution" .

cli:Status cli:emitsSpan cli:StatusSpan ;
          cli:tracksMetric cli:StatusDurationMetric .

# Build Command Instrumentation
cli:BuildSpan a cli:TelemetrySpan ;
    cli:spanName "cli.build.all" ;
    otel:operationName "build_execution" ;
    otel:spanKind "internal" ;
    cli:attributes [
        otel:attributeName "cli.command" ;
        otel:attributeValue "build" ;
        otel:attributeType "string"
    ] ,
    [
        otel:attributeName "build.target" ;
        otel:attributeType "string"
    ] ,
    [
        otel:attributeName "build.optimization" ;
        otel:attributeType "string"
    ] ,
    [
        otel:attributeName "build.components_built" ;
        otel:attributeType "int"
    ] ,
    [
        otel:attributeName "build.success" ;
        otel:attributeType "bool"
    ] .

cli:BuildDurationMetric a cli:MetricDefinition ;
    cli:metricName "cli.build.duration" ;
    otel:metricType "histogram" ;
    otel:unit "ms" ;
    otel:description "Duration of build command execution" .

cli:BuildSuccessMetric a cli:MetricDefinition ;
    cli:metricName "cli.build.success_rate" ;
    otel:metricType "counter" ;
    otel:unit "1" ;
    otel:description "Build success rate counter" .

cli:BuildAll cli:emitsSpan cli:BuildSpan ;
            cli:tracksMetric cli:BuildDurationMetric ;
            cli:tracksMetric cli:BuildSuccessMetric .

# =============================================================================
# SHACL CONSTRAINTS FOR VALIDATION
# =============================================================================

# Every command must have a name and module
cli:CommandShape a sh:NodeShape ;
    sh:targetClass cli:Command ;
    sh:property [
        sh:path cli:commandName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^[a-z][a-z0-9-]*[a-z0-9]$"
    ] ;
    sh:property [
        sh:path cli:moduleFile ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^modules/.*\\.py$"
    ] ;
    sh:property [
        sh:path cli:functionName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^execute_.*"
    ] .

# Core commands must have OTEL instrumentation
cli:CoreCommandShape a sh:NodeShape ;
    sh:targetClass cli:CoreCommand ;
    sh:property [
        sh:path cli:spanName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^cli\\.[a-z]+\\.[a-z_]+$"
    ] ;
    sh:property [
        sh:path cli:metricName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^cli\\.[a-z]+\\.[a-z_]+\\.(duration|count|rate)$"
    ] ;
    sh:property [
        sh:path cli:maxCycles ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minInclusive 1 ;
        sh:maxInclusive 8
    ] .

# =============================================================================
# GENERATION RULES FOR WEAVER
# =============================================================================

cli:WeaverGenerationRule a owl:Class ;
    rdfs:label "Weaver Generation Rule" ;
    rdfs:comment "Rules for generating OTEL Weaver command wrappers" .

cli:CommandWrapperRule a cli:WeaverGenerationRule ;
    rdfs:label "Command Wrapper Generation" ;
    cli:condition "For each cli:Command" ;
    cli:generates "OTEL instrumented Typer command wrapper" ;
    cli:template """
@app.command("{command_name}")
@weaver.instrument(
    span_name="{span_name}",
    metrics=["{metric_name}"]
)
def {command_name}_wrapper({args}):
    ''''{description}''''
    with weaver.start_span("{span_name}") as span:
        span.set_attribute("cli.command", "{command_name}")
        span.set_attribute("cli.group", "{command_group}")
        
        try:
            result = {module_name}.{function_name}({args})
            span.set_attribute("cli.success", True)
            return result
        except Exception as e:
            span.set_attribute("cli.success", False)
            span.set_attribute("cli.error", str(e))
            raise
""" .

cli:MetricCollectionRule a cli:WeaverGenerationRule ;
    rdfs:label "Metric Collection Generation" ;
    cli:condition "For each cli:MetricDefinition" ;
    cli:generates "OTEL metric collection code" ;
    cli:template """
{metric_name} = weaver.create_histogram(
    name="{metric_name}",
    description="{description}",
    unit="{unit}"
)
""" .