# ========================================
# Telemetry and Performance Measurement
# ========================================

telemetry:ExecutionMetrics a owl:Class ;
    rdfs:label "Execution Metrics" ;
    rdfs:comment "Real-time performance measurements for pattern execution" .

telemetry:hasBlake3Hash a owl:DatatypeProperty ;
    rdfs:domain telemetry:ExecutionMetrics ;
    rdfs:range xsd:string ;
    rdfs:label "Blake3 Hash" ;
    rdfs:comment "Cryptographic hash of execution data" .

telemetry:actualTicks a owl:DatatypeProperty ;
    rdfs:domain telemetry:ExecutionMetrics ;
    rdfs:range xsd:integer ;
    rdfs:label "Actual Ticks" ;
    rdfs:comment "Measured CPU ticks consumed" .

telemetry:taskState a owl:DatatypeProperty ;
    rdfs:domain telemetry:ExecutionMetrics ;
    rdfs:range xsd:string ;
    rdfs:label "Task State" ;
    rdfs:comment "Current execution state (EXECUTING, COMPLETED, etc.)" .

telemetry:memoryUsage a owl:DatatypeProperty ;
    rdfs:domain telemetry:ExecutionMetrics ;
    rdfs:range xsd:integer ;
    rdfs:label "Memory Usage" ;
    rdfs:comment "Scratch memory consumed in bytes" .

# ========================================
# SHACL Validation Constraints
# ========================================

:BitFlowPatternShape a sh:NodeShape ;
    sh:targetClass :BitFlowPattern ;
    sh:property [
        sh:path :patternID ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0 ;
        sh:maxInclusive 42 ;
        sh:message "Pattern ID must be between 0 and 42 (zero-based)"
    ] ;
    sh:property [
        sh:path :maxExecutionTicks ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 1 ;
        sh:maxInclusive 8 ;
        sh:message "Execution must complete within 8 ticks"
    ] ;
    sh:property [
        sh:path :handlerFunction ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every pattern must have a handler function"
    ] ;
    sh:property [
        sh:path :scratchSize ;
        sh:hasValue 128 ;
        sh:message "All patterns use 128-byte aligned scratch space"
    ] ;
    sh:property [
        sh:path :isBranchless ;
        sh:datatype xsd:boolean ;
        sh:message "Branchless optimization must be specified"
    ] ;
    sh:property [
        sh:path :usesAtomicOps ;
        sh:datatype xsd:boolean ;
        sh:message "Atomic operation usage must be specified"
    ] .

# ========================================
# Pattern Registry Instances
# ========================================

:PatternRegistry a owl:Class ;
    rdfs:label "Pattern Registry" ;
    rdfs:comment "Static registry of all 43 pattern implementations" .

:bitflowPatternRegistry a :PatternRegistry ;
    rdfs:label "BitFlow Pattern Registry" ;
    rdfs:comment "Main registry instance containing all patterns" ;
    :containsPattern 
        :SequencePattern, :ParallelSplitPattern, :SynchronizationPattern, :ExclusiveChoicePattern, :SimpleMergePattern,
        :MultiChoicePattern, :StructuredSyncMergePattern, :MultiMergePattern, :StructuredDiscriminatorPattern,
        :ArbitraryCyclesPattern, :ImplicitTerminationPattern,
        :MIWithoutSyncPattern, :MIDesignTimePattern, :MIRuntimePattern, :MINoRuntimePattern,
        :DeferredChoicePattern, :InterleavedParallelPattern, :MilestonePattern,
        :CancelActivityPattern, :CancelCasePattern, :StructuredLoopPattern, :RecursionPattern, :TransientTriggerPattern, :PersistentTriggerPattern, :CancelRegionPattern,
        :BlockingDiscriminatorPattern, :CancellingDiscriminatorPattern, :StructuredPartialJoinPattern, :BlockingPartialJoinPattern, :CancellingPartialJoinPattern,
        :GeneralizedANDJoinPattern, :StaticPartialJoinMIPattern, :CancellingPartialJoinMIPattern, :DynamicPartialJoinMIPattern,
        :AcyclicSyncMergePattern, :GeneralSyncMergePattern, :CriticalSectionPattern, :InterleavedRoutingPattern, :ThreadMergePattern,
        :ThreadSplitPattern, :ExplicitTerminationPattern, :HierarchicalCancellationPattern, :NonLocalSyncPattern .

:containsPattern a owl:ObjectProperty ;
    rdfs:domain :PatternRegistry ;
    rdfs:range :BitFlowPattern ;
    rdfs:label "contains pattern" .

# ========================================
# Performance Optimization Classifications
# ========================================

:OptimizationClass a owl:Class ;
    rdfs:label "Optimization Class" ;
    rdfs:comment "Classification of patterns by optimization strategy" .

:SIMDOptimizable a :OptimizationClass ;
    rdfs:label "SIMD Optimizable" ;
    rdfs:comment "Patterns that benefit from SIMD vectorization" ;
    rdfs:seeAlso :ParallelSplitPattern, :SynchronizationPattern, :MultiChoicePattern, :MIWithoutSyncPattern, :MIDesignTimePattern, :MIRuntimePattern, :CancelCasePattern, :CancelRegionPattern, :CancellingDiscriminatorPattern, :StructuredPartialJoinPattern, :CancellingPartialJoinPattern, :StaticPartialJoinMIPattern, :CancellingPartialJoinMIPattern, :ThreadSplitPattern, :ExplicitTerminationPattern, :HierarchicalCancellationPattern .

:AtomicRequired a :OptimizationClass ;
    rdfs:label "Atomic Required" ;
    rdfs:comment "Patterns requiring atomic operations for correctness" ;
    rdfs:seeAlso :SynchronizationPattern, :StructuredSyncMergePattern, :StructuredDiscriminatorPattern, :ImplicitTerminationPattern, :MIRuntimePattern, :MINoRuntimePattern, :DeferredChoicePattern, :InterleavedParallelPattern, :CancelActivityPattern, :CancelCasePattern, :RecursionPattern, :PersistentTriggerPattern, :CancelRegionPattern .

:BranchlessOptimized a :OptimizationClass ;
    rdfs:label "Branchless Optimized" ;
    rdfs:comment "Patterns using branchless programming techniques" ;
    rdfs:seeAlso :SequencePattern, :ParallelSplitPattern, :SynchronizationPattern, :ExclusiveChoicePattern, :SimpleMergePattern, :MultiChoicePattern, :MultiMergePattern, :ArbitraryCyclesPattern, :MIWithoutSyncPattern, :MIDesignTimePattern, :MIRuntimePattern, :MilestonePattern, :CancelActivityPattern, :CancelCasePattern, :StructuredLoopPattern, :TransientTriggerPattern, :PersistentTriggerPattern, :CancelRegionPattern .

# ========================================
# SPARQL Query Templates for Analysis
# ========================================

:BitFlowPatternAnalysisQuery a sparql:QueryTemplate ;
    rdfs:label "BitFlow Pattern Analysis Query" ;
    sparql:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        PREFIX bitflow: <http://bitflow.ai/ontology/core#>
        
        # Find all patterns with their performance characteristics
        SELECT ?pattern ?id ?ticks ?simd ?atomic ?branchless ?handler
        WHERE {
            ?pattern a :BitFlowPattern ;
                     :patternID ?id ;
                     :maxExecutionTicks ?ticks ;
                     :requiredFeatures ?features ;
                     :isBranchless ?branchless ;
                     :usesAtomicOps ?atomic ;
                     :handlerFunction ?handler .
            BIND(CONTAINS(?features, "SIMD") AS ?simd)
        }
        ORDER BY ?id
    """ .

:SIMDOptimizationQuery a sparql:QueryTemplate ;
    rdfs:label "SIMD Optimization Query" ;
    sparql:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        
        # Find patterns suitable for SIMD optimization
        SELECT ?pattern ?id ?hint ?ticks
        WHERE {
            ?pattern a :BitFlowPattern ;
                     :patternID ?id ;
                     :maxExecutionTicks ?ticks ;
                     :requiredFeatures ?features ;
                     :hasImplementationHint ?hint .
            FILTER(CONTAINS(?features, "SIMD"))
        }
        ORDER BY ?ticks DESC
    """ .

:ComplexityAnalysisQuery a sparql:QueryTemplate ;
    rdfs:label "Complexity Analysis Query" ;
    sparql:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        
        # Find high-complexity patterns requiring special attention
        SELECT ?pattern ?id ?ticks ?atomic ?hint
        WHERE {
            ?pattern a :BitFlowPattern ;
                     :patternID ?id ;
                     :maxExecutionTicks ?ticks ;
                     :usesAtomicOps ?atomic ;
                     :hasImplementationHint ?hint .
            FILTER(?ticks >= 5)
        }
        ORDER BY DESC(?ticks)
    """ .

:PatternDependencyQuery a sparql:QueryTemplate ;
    rdfs:label "Pattern Dependency Query" ;
    sparql:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        PREFIX yawl: <http://bitflow.ai/ontology/yawl/v2#>
        
        # Find split/join pattern combinations
        SELECT ?pattern ?id ?splitType ?joinType ?ticks
        WHERE {
            ?pattern a :BitFlowPattern ;
                     :patternID ?id ;
                     :maxExecutionTicks ?ticks ;
                     yawl:hasSplitType ?splitType ;
                     yawl:hasJoinType ?joinType .
        }
        ORDER BY ?splitType, ?joinType, ?id
    """ .