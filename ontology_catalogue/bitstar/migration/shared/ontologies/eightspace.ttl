@prefix e8: <http://bitstar.ai/eight#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Eight-Space Ontology for BitStar Legal System
# Defines computational constraints and optimization parameters

# Eight-Space Classes
e8:Contract rdf:type rdfs:Class ;
    rdfs:label "Eight-Space Contract" ;
    rdfs:comment "Computational contract defining system constraints" .

e8:Constraint rdf:type rdfs:Class ;
    rdfs:label "System Constraint" ;
    rdfs:comment "Computational or resource constraint" .

e8:Profile rdf:type rdfs:Class ;
    rdfs:label "Performance Profile" ;
    rdfs:comment "System performance and optimization profile" .

e8:Pool rdf:type rdfs:Class ;
    rdfs:label "Resource Pool" ;
    rdfs:comment "Pool of computational resources" .

e8:Ring rdf:type rdfs:Class ;
    rdfs:label "Communication Ring" ;
    rdfs:comment "Inter-component communication ring buffer" .

# Properties
e8:maxTicks rdf:type rdf:Property ;
    rdfs:domain e8:Contract ;
    rdfs:range xsd:string ;
    rdfs:label "Maximum Ticks" ;
    rdfs:comment "Maximum computational ticks allowed" .

e8:maxHops rdf:type rdf:Property ;
    rdfs:domain e8:Contract ;
    rdfs:range xsd:string ;
    rdfs:label "Maximum Hops" ;
    rdfs:comment "Maximum network hops allowed" .

e8:bitWidth rdf:type rdf:Property ;
    rdfs:domain e8:Contract ;
    rdfs:range xsd:string ;
    rdfs:label "Bit Width" ;
    rdfs:comment "System bit width constraint" .

e8:poolSize rdf:type rdf:Property ;
    rdfs:domain e8:Pool ;
    rdfs:range xsd:integer ;
    rdfs:label "Pool Size" .

e8:ringBuffer rdf:type rdf:Property ;
    rdfs:domain e8:Ring ;
    rdfs:range xsd:integer ;
    rdfs:label "Ring Buffer Size" .

e8:latencyTarget rdf:type rdf:Property ;
    rdfs:domain e8:Profile ;
    rdfs:range xsd:duration ;
    rdfs:label "Latency Target" .

e8:throughputTarget rdf:type rdf:Property ;
    rdfs:domain e8:Profile ;
    rdfs:range xsd:integer ;
    rdfs:label "Throughput Target" .

e8:memoryLimit rdf:type rdf:Property ;
    rdfs:domain e8:Contract ;
    rdfs:range xsd:integer ;
    rdfs:label "Memory Limit" .

e8:cpuLimit rdf:type rdf:Property ;
    rdfs:domain e8:Contract ;
    rdfs:range xsd:integer ;
    rdfs:label "CPU Limit" .

# Default Eight-Space Contract
e8:constraints rdf:type e8:Contract ;
    rdfs:label "Legal System Constraints" ;
    e8:maxTicks "8" ;
    e8:maxHops "8" ;
    e8:bitWidth "8" ;
    e8:memoryLimit "134217728"^^xsd:integer ;  # 128MB
    e8:cpuLimit "8"^^xsd:integer ;             # 8 cores max
    rdfs:comment "Default computational constraints for legal filing system" .

# Performance Profiles
e8:LegalFiling rdf:type e8:Profile ;
    rdfs:label "Legal Filing Performance Profile" ;
    e8:latencyTarget "PT30S"^^xsd:duration ;    # 30 seconds max
    e8:throughputTarget "100"^^xsd:integer ;     # 100 filings/hour
    rdfs:comment "Performance profile for legal document filing" .

e8:DocumentGeneration rdf:type e8:Profile ;
    rdfs:label "Document Generation Performance Profile" ;
    e8:latencyTarget "PT5M"^^xsd:duration ;     # 5 minutes max
    e8:throughputTarget "20"^^xsd:integer ;      # 20 documents/hour
    rdfs:comment "Performance profile for legal document generation" .

e8:PaymentProcessing rdf:type e8:Profile ;
    rdfs:label "Payment Processing Performance Profile" ;
    e8:latencyTarget "PT10S"^^xsd:duration ;    # 10 seconds max
    e8:throughputTarget "500"^^xsd:integer ;     # 500 transactions/hour
    rdfs:comment "Performance profile for payment processing" .

# Resource Pools
e8:ChromeAgentPool rdf:type e8:Pool ;
    rdfs:label "Chrome Agent Pool" ;
    e8:poolSize "8"^^xsd:integer ;
    rdfs:comment "Pool of Chrome automation agents" .

e8:DocumentAgentPool rdf:type e8:Pool ;
    rdfs:label "Document Agent Pool" ;
    e8:poolSize "4"^^xsd:integer ;
    rdfs:comment "Pool of document generation agents" .

e8:PlannerAgentPool rdf:type e8:Pool ;
    rdfs:label "Planner Agent Pool" ;
    e8:poolSize "2"^^xsd:integer ;
    rdfs:comment "Pool of strategic planning agents" .

# Communication Rings
e8:WorkflowRing rdf:type e8:Ring ;
    rdfs:label "Workflow Communication Ring" ;
    e8:ringBuffer "64"^^xsd:integer ;
    rdfs:comment "Ring buffer for workflow task communication" .

e8:StatusRing rdf:type e8:Ring ;
    rdfs:label "Status Communication Ring" ;
    e8:ringBuffer "32"^^xsd:integer ;
    rdfs:comment "Ring buffer for status updates and monitoring" .

e8:ErrorRing rdf:type e8:Ring ;
    rdfs:label "Error Communication Ring" ;
    e8:ringBuffer "16"^^xsd:integer ;
    rdfs:comment "Ring buffer for error reporting and recovery" .

# Optimization Constraints
e8:RealTimeConstraints rdf:type e8:Contract ;
    rdfs:label "Real-Time Filing Constraints" ;
    e8:maxTicks "4" ;
    e8:maxHops "4" ;
    e8:bitWidth "16" ;
    e8:memoryLimit "67108864"^^xsd:integer ;   # 64MB
    e8:cpuLimit "4"^^xsd:integer ;             # 4 cores max
    rdfs:comment "Tighter constraints for real-time filing operations" .

e8:BulkProcessingConstraints rdf:type e8:Contract ;
    rdfs:label "Bulk Processing Constraints" ;
    e8:maxTicks "16" ;
    e8:maxHops "12" ;
    e8:bitWidth "32" ;
    e8:memoryLimit "268435456"^^xsd:integer ;  # 256MB
    e8:cpuLimit "16"^^xsd:integer ;            # 16 cores max
    rdfs:comment "Relaxed constraints for bulk document processing" .

# Security Constraints
e8:SecurityProfile rdf:type e8:Profile ;
    rdfs:label "Security Performance Profile" ;
    e8:latencyTarget "PT2S"^^xsd:duration ;    # 2 seconds max for auth
    e8:throughputTarget "1000"^^xsd:integer ;   # 1000 auth/hour
    rdfs:comment "Performance profile for security operations" .

# Fortune 500 Optimizations
e8:Fortune500Profile rdf:type e8:Profile ;
    rdfs:label "Fortune 500 Enterprise Profile" ;
    e8:latencyTarget "PT10S"^^xsd:duration ;   # 10 seconds max
    e8:throughputTarget "1000"^^xsd:integer ;   # 1000 operations/hour
    rdfs:comment "High-performance profile for Fortune 500 legal operations" .

e8:Fortune500Constraints rdf:type e8:Contract ;
    rdfs:label "Fortune 500 Enterprise Constraints" ;
    e8:maxTicks "32" ;
    e8:maxHops "16" ;
    e8:bitWidth "64" ;
    e8:memoryLimit "1073741824"^^xsd:integer ; # 1GB
    e8:cpuLimit "32"^^xsd:integer ;            # 32 cores max
    rdfs:comment "Enterprise-grade constraints for Fortune 500 legal systems" .