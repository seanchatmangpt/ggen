    :hasImplementationHint "Fire-and-forget spawning" .

# Pattern 13: Multiple Instances with a priori Design-Time Knowledge
:MIAprioriDesignPattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 13: MI with Design-Time Knowledge" ;
    rdfs:comment "Number of instances known at design time" ;
    :patternID 13 ;
    :patternCategory :AdvancedBranching ;
