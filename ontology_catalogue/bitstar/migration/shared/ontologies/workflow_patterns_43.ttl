# Pattern 12: Multiple Instances without Synchronization
:MIWithoutSyncPattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 12: MI without Synchronization" ;
    rdfs:comment "Creates instances without waiting for completion" ;
    :patternID 12 ;
    :patternCategory :AdvancedBranching ;
    :averageExecutionTicks 2 ;
