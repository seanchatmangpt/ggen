@prefix : <http://bitflow.ai/ontology/patterns#> .
@prefix wp: <http://bitflow.ai/ontology/workflow-patterns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix yawl: <http://bitflow.ai/ontology/yawl/v2#> .
@prefix perf: <http://bitflow.ai/ontology/performance#> .
@prefix sparql: <http://bitflow.ai/sparql/patterns#> .

# ========================================
# Workflow Patterns Ontology v1.0 for Bitflow
# Complete Definition of 43 Workflow Patterns
# ========================================

<http://bitflow.ai/ontology/workflow-patterns> a owl:Ontology ;
    rdfs:label "Workflow Patterns Ontology v1.0" ;
    rdfs:comment "Complete semantic definition of all 43 workflow patterns with performance hints and SHACL constraints" ;
    owl:versionInfo "1.0" ;
    rdfs:seeAlso <http://www.workflowpatterns.com/> ;
    rdfs:seeAlso <https://www.yawlfoundation.org/> .

# ========================================
# Pattern Categories
# ========================================

:PatternCategory a owl:Class ;
    rdfs:label "Pattern Category" ;
    rdfs:comment "Category grouping for workflow patterns" .

:BasicControl a :PatternCategory ;
    rdfs:label "Basic Control Flow Patterns" ;
    rdfs:comment "Fundamental patterns for process control" .

:AdvancedBranching a :PatternCategory ;
    rdfs:label "Advanced Branching and Synchronization" ;
    rdfs:comment "Complex split and join patterns" .

:MultipleInstance a :PatternCategory ;
    rdfs:label "Multiple Instance Patterns" ;
    rdfs:comment "Patterns for handling multiple instances" .

:StateBased a :PatternCategory ;
    rdfs:label "State-based Patterns" ;
    rdfs:comment "Patterns based on process state" .

:Cancellation a :PatternCategory ;
    rdfs:label "Cancellation and Force Completion" ;
    rdfs:comment "Patterns for process cancellation" .

:Triggering a :PatternCategory ;
    rdfs:label "Trigger Patterns" ;
    rdfs:comment "Event-based triggering patterns" .

# ========================================
# Base Pattern Class
# ========================================

:WorkflowPattern a owl:Class ;
    rdfs:subClassOf yawl:Task ;
    rdfs:label "Workflow Pattern" ;
    rdfs:comment "Abstract base class for all workflow patterns" .

# Pattern Properties
:patternID a owl:DatatypeProperty ;
    rdfs:domain :WorkflowPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "Pattern ID" ;
    rdfs:comment "Unique identifier for the pattern (1-43)" .

:patternCategory a owl:ObjectProperty ;
    rdfs:domain :WorkflowPattern ;
    rdfs:range :PatternCategory ;
    rdfs:label "Pattern Category" .

:hasImplementationHint a owl:DatatypeProperty ;
    rdfs:domain :WorkflowPattern ;
    rdfs:range xsd:string ;
    rdfs:label "Implementation Hint" ;
    rdfs:comment "Performance and implementation guidance" .

:supportsSIMD a owl:DatatypeProperty ;
    rdfs:domain :WorkflowPattern ;
    rdfs:range xsd:boolean ;
    rdfs:label "Supports SIMD" ;
    rdfs:comment "Whether pattern can leverage SIMD instructions" .

:averageExecutionTicks a owl:DatatypeProperty ;
    rdfs:domain :WorkflowPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "Average Execution Ticks" ;
    rdfs:comment "Typical CPU ticks for pattern execution" .

# ========================================
# CATEGORY 1: Basic Control Flow Patterns (1-5)
# ========================================

# Pattern 1: Sequence
:SequencePattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 1: Sequence" ;
    rdfs:comment "Sequential execution of activities" ;
    :patternID 1 ;
    :patternCategory :BasicControl ;
    :averageExecutionTicks 1 ;
    :supportsSIMD false ;
    :hasImplementationHint "Direct flow transition, zero overhead" .

# Pattern 2: Parallel Split
:ParallelSplitPattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 2: Parallel Split (AND-split)" ;
    rdfs:comment "Splits execution into multiple parallel branches" ;
    :patternID 2 ;
    :patternCategory :BasicControl ;
    :averageExecutionTicks 2 ;
    :supportsSIMD true ;
    :hasImplementationHint "Use SIMD for parallel branch initialization" ;
    yawl:hasSplitType yawl:AND .

# Pattern 3: Synchronization
:SynchronizationPattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 3: Synchronization (AND-join)" ;
    rdfs:comment "Synchronizes multiple parallel branches" ;
    :patternID 3 ;
    :patternCategory :BasicControl ;
    :averageExecutionTicks 3 ;
    :supportsSIMD true ;
    :hasImplementationHint "Atomic counter for branch tracking" ;
    yawl:hasJoinType yawl:AND .

# Pattern 4: Exclusive Choice
:ExclusiveChoicePattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 4: Exclusive Choice (XOR-split)" ;
    rdfs:comment "Selects one branch from multiple alternatives" ;
    :patternID 4 ;
    :patternCategory :BasicControl ;
    :averageExecutionTicks 2 ;
    :supportsSIMD false ;
    :hasImplementationHint "Branch prediction optimization" ;
    yawl:hasSplitType yawl:XOR .

# Pattern 5: Simple Merge
:SimpleMergePattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 5: Simple Merge (XOR-join)" ;
    rdfs:comment "Merges alternative branches without synchronization" ;
    :patternID 5 ;
    :patternCategory :BasicControl ;
    :averageExecutionTicks 1 ;
    :supportsSIMD false ;
    :hasImplementationHint "Direct flow merge, no waiting" ;
    yawl:hasJoinType yawl:XOR .

# ========================================
# CATEGORY 2: Advanced Branching and Synchronization (6-13)
# ========================================

# Pattern 6: Multi-Choice
:MultiChoicePattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 6: Multi-Choice (OR-split)" ;
    rdfs:comment "Selects one or more branches based on conditions" ;
    :patternID 6 ;
    :patternCategory :AdvancedBranching ;
    :averageExecutionTicks 3 ;
    :supportsSIMD true ;
    :hasImplementationHint "Bitmap for branch selection" ;
    yawl:hasSplitType yawl:OR .

# Pattern 7: Structured Synchronizing Merge
:StructuredSyncMergePattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 7: Structured Synchronizing Merge" ;
    rdfs:comment "Merges paths that diverged from same OR-split" ;
    :patternID 7 ;
    :patternCategory :AdvancedBranching ;
    :averageExecutionTicks 4 ;
    :supportsSIMD false ;
    :hasImplementationHint "Track split context for proper sync" .

# Pattern 8: Multi-Merge
:MultiMergePattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 8: Multi-Merge" ;
    rdfs:comment "Allows activity execution for each incoming branch" ;
    :patternID 8 ;
    :patternCategory :AdvancedBranching ;
    :averageExecutionTicks 2 ;
    :supportsSIMD false ;
    :hasImplementationHint "Queue incoming tokens" .

# Pattern 9: Structured Discriminator
:StructuredDiscriminatorPattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 9: Structured Discriminator" ;
    rdfs:comment "Waits for first incoming branch then cancels others" ;
    :patternID 9 ;
    :patternCategory :AdvancedBranching ;
    :averageExecutionTicks 3 ;
    :supportsSIMD false ;
    :hasImplementationHint "Atomic first-arrival detection" .

# Pattern 10: Arbitrary Cycles
:ArbitraryCyclesPattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 10: Arbitrary Cycles" ;
    rdfs:comment "Supports loops in workflow graph" ;
    :patternID 10 ;
    :patternCategory :AdvancedBranching ;
    :averageExecutionTicks 2 ;
    :supportsSIMD false ;
    :hasImplementationHint "Loop counter with overflow protection" .

# Pattern 11: Implicit Termination
:ImplicitTerminationPattern a owl:Class ;
    rdfs:subClassOf :WorkflowPattern ;
    rdfs:label "Pattern 11: Implicit Termination" ;
    rdfs:comment "Process ends when no activities can execute" ;
    :patternID 11 ;
    :patternCategory :AdvancedBranching ;
