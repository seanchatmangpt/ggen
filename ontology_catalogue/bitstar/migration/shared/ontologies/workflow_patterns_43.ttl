# ========================================
# SHACL Constraints for Pattern Validation
# ========================================

:WorkflowPatternShape a sh:NodeShape ;
    sh:targetClass :WorkflowPattern ;
    sh:property [
        sh:path :patternID ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 1 ;
        sh:maxInclusive 43 ;
        sh:message "Pattern ID must be between 1 and 43"
    ] ;
    sh:property [
        sh:path :patternCategory ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Every pattern must belong to exactly one category"
    ] ;
    sh:property [
        sh:path :averageExecutionTicks ;
        sh:minInclusive 1 ;
        sh:maxInclusive 8 ;
        sh:message "Execution must complete within 8 ticks"
    ] ;
    sh:property [
        sh:path :supportsSIMD ;
        sh:datatype xsd:boolean ;
        sh:message "SIMD support must be explicitly specified"
    ] .

# ========================================
# Performance Optimization Hints
# ========================================

:OptimizationHint a owl:Class ;
    rdfs:label "Optimization Hint" ;
    rdfs:comment "Performance optimization guidance" .

:ParallelizablePatterns a :OptimizationHint ;
    rdfs:label "Parallelizable Patterns" ;
    rdfs:comment "Patterns 2, 3, 6, 12, 13, 14, 20, 25, 26, 27, 29, 30, 32, 34, 35, 42" ;
    :useSIMD true ;
    :recommendedOptimization "SIMD vectorization for parallel operations" .

:BranchingPatterns a :OptimizationHint ;
    rdfs:label "Branching Patterns" ;
    rdfs:comment "Patterns 4, 5, 6, 7, 16" ;
    :recommendedOptimization "Branch prediction hints, speculative execution" .

:SynchronizationPatterns a :OptimizationHint ;
    rdfs:label "Synchronization Patterns" ;
    rdfs:comment "Patterns 3, 7, 11, 28, 33, 37, 38" ;
    :recommendedOptimization "Lock-free algorithms, atomic operations" .

:LoopPatterns a :OptimizationHint ;
    rdfs:label "Loop Patterns" ;
    rdfs:comment "Patterns 10, 21, 22" ;
    :recommendedOptimization "Loop unrolling, iterator optimization" .

# ========================================
# SPARQL Query Templates
# ========================================

:PatternAnalysisQuery a sparql:QueryTemplate ;
    rdfs:label "Pattern Analysis Query" ;
    sparql:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        PREFIX wp: <http://bitflow.ai/ontology/workflow-patterns#>
        
        # Find all patterns in a category
        SELECT ?pattern ?id ?ticks ?simd
        WHERE {
            ?pattern a :WorkflowPattern ;
                     :patternCategory ?category ;
                     :patternID ?id ;
                     :averageExecutionTicks ?ticks ;
                     :supportsSIMD ?simd .
            FILTER (?category = :AdvancedBranching)
        }
        ORDER BY ?id
    """ .

:PerformanceOptimizationQuery a sparql:QueryTemplate ;
    rdfs:label "Performance Optimization Query" ;
    sparql:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        
        # Find patterns suitable for SIMD optimization
        SELECT ?pattern ?id ?hint
        WHERE {
            ?pattern a :WorkflowPattern ;
                     :patternID ?id ;
                     :supportsSIMD true ;
                     :hasImplementationHint ?hint .
        }
        ORDER BY ?id
    """ .

:ComplexityAnalysisQuery a sparql:QueryTemplate ;
    rdfs:label "Complexity Analysis Query" ;
    sparql:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        
        # Find high-complexity patterns
        SELECT ?pattern ?id ?ticks ?category
        WHERE {
            ?pattern a :WorkflowPattern ;
                     :patternID ?id ;
                     :averageExecutionTicks ?ticks ;
                     :patternCategory ?category .
            FILTER (?ticks >= 5)
        }
        ORDER BY DESC(?ticks)
    """ .

# ========================================
# Pattern Relationships and Dependencies
# ========================================

:dependsOn a owl:ObjectProperty ;
    rdfs:domain :WorkflowPattern ;
    rdfs:range :WorkflowPattern ;
    rdfs:label "depends on" ;
    rdfs:comment "Pattern execution dependency" .

:incompatibleWith a owl:ObjectProperty ;
    rdfs:domain :WorkflowPattern ;
    rdfs:range :WorkflowPattern ;
    rdfs:label "incompatible with" ;
    rdfs:comment "Patterns that cannot coexist" .

:canCombineWith a owl:ObjectProperty ;
    rdfs:domain :WorkflowPattern ;
    rdfs:range :WorkflowPattern ;
    rdfs:label "can combine with" ;
    rdfs:comment "Patterns that work well together" .

# Example relationships
:StructuredSyncMergePattern :dependsOn :MultiChoicePattern .
:ExclusiveChoicePattern :incompatibleWith :ParallelSplitPattern .
:ParallelSplitPattern :canCombineWith :SynchronizationPattern .

# ========================================
# Telemetry and Monitoring Extensions
# ========================================

:PatternMetrics a owl:Class ;
    rdfs:label "Pattern Metrics" ;
    rdfs:comment "Runtime metrics for pattern execution" .

:executionCount a owl:DatatypeProperty ;
    rdfs:domain :PatternMetrics ;
    rdfs:range xsd:integer ;
    rdfs:label "execution count" .

:averageLatency a owl:DatatypeProperty ;
    rdfs:domain :PatternMetrics ;
    rdfs:range xsd:decimal ;
    rdfs:label "average latency" ;
    rdfs:comment "Average execution time in microseconds" .

:successRate a owl:DatatypeProperty ;
    rdfs:domain :PatternMetrics ;
    rdfs:range xsd:decimal ;
    rdfs:label "success rate" ;
    rdfs:comment "Percentage of successful executions" .

:lastExecutionHash a owl:DatatypeProperty ;
    rdfs:domain :PatternMetrics ;
    rdfs:range xsd:string ;
    rdfs:label "last execution hash" ;
    rdfs:comment "Blake3 hash of last execution" .