:FaultToleranceModel a conc:FaultTolerance ;
  rdfs:label "ByteActor Fault Tolerance Specification" ;
  conc:faultTypes [
    conc:fault "Process crash" ;
    conc:detection "Supervision tree monitoring" ;
    conc:recovery "Automatic process restart with clean state" ;
    conc:recoveryTime "< 100ms"
  ], [
    conc:fault "Memory corruption" ;
    conc:detection "BLAKE3 hash validation" ;
    conc:recovery "Discard corrupted data, log incident" ;
    conc:impact "Single signal loss acceptable"
  ], [
    conc:fault "Ring buffer overflow" ;
    conc:detection "Ring full condition check" ;
    conc:recovery "Back-pressure to sender, overflow logging" ;
    conc:prevention "Proper ring sizing based on traffic patterns"
  ], [
    conc:fault "Dispatch table corruption" ;
    conc:detection "Function pointer validation" ;
    conc:recovery "Reload dispatch table from AOT artifacts" ;
    conc:recoveryTime "< 1ms"
  ] ;
  conc:errorHandling "Fail-fast with comprehensive logging" ;
  conc:gracefulDegradation "Reduce throughput but maintain availability" .