@prefix :      <http://bitbizeco.dev/ontology/v1/byteactor_master#> .
@prefix byte:  <http://bitbizeco.dev/ontology/v1/byteactor#> .
@prefix dflss: <http://bitbizeco.dev/ontology/v1/dflss#> .
@prefix build: <http://bitbizeco.dev/ontology/v1/build#> .
@prefix exec:  <http://bitbizeco.dev/ontology/v1/execution#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<http://bitbizeco.dev/ontology/v1/byteactor_master>
  a exec:Ontology ;
  rdfs:label "ByteActor Master Build Ontology - Complete Autonomous Construction Specification" ;
  rdfs:comment "The definitive, machine-readable specification that enables complete autonomous ByteActor system construction by coding agents" ;
  owl:versionInfo "1.0.0" ;
  owl:imports 
    <http://bitbizeco.dev/ontology/v1/byteactor_c4_complete>,
    <http://bitbizeco.dev/ontology/v1/byteactor_dflss_project>,
    <http://bitbizeco.dev/ontology/v1/byteactor_implementation_spec>,
    <http://bitbizeco.dev/ontology/v1/byteactor_performance_requirements>,
    <http://bitbizeco.dev/ontology/v1/byteactor_concurrency_model> .

#################################################################
#
# MASTER BUILD PLAN - EXECUTION SEQUENCE
#
#################################################################

:ByteActorMasterPlan a exec:BuildPlan ;
  rdfs:label "ByteActor Complete Construction Plan" ;
  exec:constructionPhases :PreparationPhase, :FoundationPhase, :CorePhase, :IntegrationPhase, :ValidationPhase ;
  exec:totalEstimate "P21D" ;
  exec:resourceRequirements :BuildResources ;
  exec:successCriteria :CompletionCriteria ;
  exec:rollbackPlan :RollbackStrategy .

#################################################################
#
# PHASE 1: PREPARATION (P1D)
#
#################################################################

:PreparationPhase a exec:BuildPhase ;
  rdfs:label "Environment Preparation and Code Analysis" ;
  exec:phaseNumber 1 ;
  exec:duration "P1D" ;
  exec:objectives "Set up build environment, analyze existing code, prepare foundations" ;
  exec:tasks [
    exec:task "Analyze existing code in ~/cns/" ;
    exec:description "Deep analysis of all BitActor implementations" ;
    exec:duration "PT4H" ;
    exec:deliverables "Code analysis report, component inventory" ;
    exec:tools "grep, find, static analysis" ;
    exec:success "All relevant code identified and catalogued"
  ], [
    exec:task "Set up build environment" ;
    exec:description "Install dependencies, configure toolchain" ;
    exec:duration "PT2H" ;
    exec:commands "apt-get install libnuma-dev erlang cmake gcc-11" ;
    exec:validation "cmake --version, erlc -v, gcc --version" ;
    exec:success "All tools available and versions verified"
  ], [
    exec:task "Create project structure" ;
    exec:description "Initialize directory tree and basic files" ;
    exec:duration "PT1H" ;
    exec:structure "src/, include/, erlang/src/, tests/, benchmarks/, docs/" ;
    exec:success "Complete directory structure created"
  ], [
    exec:task "Copy foundation code from ~/cns/" ;
    exec:description "Copy relevant source files to project" ;
    exec:duration "PT1H" ;
    exec:sources [
      "~/cns/src/cns/bitactor.c → src/bitactor_core.c" ;
      "~/cns/bitactor/src/bitactor_dispatch.c → src/bitactor_dispatch.c" ;
      "~/cns/bitactor/src/bitactor_blake3.c → src/bitactor_blake3.c" ;
      "~/cns/legacy/elixir/bitactor_otp/c_src/bitactor_nif.c → src/bitactor_nif.c" ;
      "~/cns/legacy/elixir/bitactor_otp/src/ → erlang/src/"
    ] ;
    exec:success "All foundation files copied and adapted"
  ] .

#################################################################
#
# PHASE 2: FOUNDATION (P3D)
#################################################################

:FoundationPhase a exec:BuildPhase ;
  rdfs:label "Core Data Structures and Lock-Free Primitives" ;
  exec:phaseNumber 2 ;
  exec:duration "P3D" ;
  exec:dependencies :PreparationPhase ;
  exec:objectives "Implement foundational lock-free data structures" ;
  exec:tasks [
    exec:task "Implement SPSC Ring Buffer" ;
    exec:file "src/ring_buffer.c" ;
    exec:functions "spsc_init, spsc_enqueue, spsc_dequeue" ;
    exec:requirements "Lock-free, cache-aligned, atomic operations" ;
    exec:testCriteria "10M ops/sec, zero data loss, FIFO ordering" ;
    exec:implementation """
// Ring buffer with separated cache lines
typedef struct __attribute__((cache_aligned)) {
    __attribute__((aligned(64)))
    volatile uint32_t head;  // Producer
    
    __attribute__((aligned(64)))
    volatile uint32_t tail;  // Consumer
    
    __attribute__((aligned(64)))
    signal_t* buffer;
    uint32_t size;
    uint32_t mask;
} spsc_ring_t;
"""
  ], [
    exec:task "Implement Atomic Operations Library" ;
    exec:file "src/atomic_ops.c" ;
    exec:functions "atomic_ptr_load, atomic_ptr_store, atomic_counter_inc" ;
    exec:requirements "Memory ordering semantics, platform abstraction" ;
    exec:testCriteria "Correct memory ordering, no races detected"
  ], [
    exec:task "Implement Memory Alignment Utilities" ;
    exec:file "src/memory_utils.c" ;
    exec:functions "cache_aligned_alloc, numa_local_alloc, prefetch_sequence" ;
    exec:requirements "64-byte alignment, NUMA awareness" ;
    exec:testCriteria "Alignment verification, NUMA locality validation"
  ] .

#################################################################
#
# PHASE 3: CORE ENGINE (P5D)
#################################################################

:CorePhase a exec:BuildPhase ;
  rdfs:label "BitActor Core Engine Implementation" ;
  exec:phaseNumber 3 ;
  exec:duration "P5D" ;
  exec:dependencies :FoundationPhase ;
  exec:objectives "Implement core execution engine with performance guarantees" ;
  exec:tasks [
    exec:task "Implement BitActor Core Engine" ;
    exec:file "src/bitactor_core.c" ;
    exec:basedOn "~/cns/src/cns/bitactor.c" ;
    exec:functions "bitactor_init, bitactor_tick, bitactor_enqueue_signal" ;
    exec:requirements "≤8 tick guarantee, SIMD optimization, telemetry" ;
    exec:testCriteria "P99.9 ≤ 8 ticks, 10M signals/sec throughput" ;
    exec:keyImplementation """
__attribute__((hot, always_inline))
void bitactor_tick(bitactor_t* ba) {
    uint64_t start_cycle = __rdtsc();
    
    // Tick 1: Check ring buffer (lock-free)
    if (spsc_is_empty(&ba->signal_ring)) return;
    
    // Tick 1: Perfect hash dispatch  
    signal_t signal;
    spsc_dequeue(&ba->signal_ring, &signal);
    uint32_t handler_idx = signal.kind & ba->dispatch_mask;
    
    // Tick 2: Memory crystallization
    void* scratch = crystal_allocate(ba->memory_pool, signal.kind);
    
    // Ticks 3-7: Execute handler (branch-free)
    handler_fn handler = ba->dispatch[handler_idx];
    result_t result = handler(&signal, scratch);
    
    // Tick 8: Seal result crystal
    result_crystal_t crystal = seal_result(&result, &signal, __rdtsc() - start_cycle);
    spsc_enqueue(&ba->result_ring, &crystal);
    
    crystal_deallocate(ba->memory_pool, scratch);
}
"""
  ], [
    exec:task "Implement Perfect Hash Dispatch Table" ;
    exec:file "src/dispatch_table.c" ;
    exec:basedOn "~/cns/bitactor/src/bitactor_dispatch.c" ;
    exec:functions "generate_mphf, dispatch_lookup, register_handler" ;
    exec:requirements "O(1) lookup, zero collisions, cache optimization" ;
    exec:algorithm "Minimal Perfect Hash Function (CHD algorithm)" ;
    exec:testCriteria "Zero hash collisions, ≤1 tick lookup time"
  ], [
    exec:task "Implement Memory Crystallization Engine" ;
    exec:file "src/memory_crystal.c" ;
    exec:basedOn "~/cns/bitflow/core/src/bitflow_memory_crystallization.c" ;
    exec:functions "crystal_init_pools, crystal_allocate, crystal_deallocate" ;
    exec:requirements "≤2 tick allocation, NUMA-local, zero fragmentation" ;
    exec:testCriteria "≤2 tick allocation time, 95% memory efficiency"
  ], [
    exec:task "Implement BLAKE3 Result Sealing" ;
    exec:file "src/result_sealing.c" ;
    exec:basedOn "~/cns/bitactor/src/bitactor_blake3.c" ;
    exec:functions "seal_result_crystal, verify_crystal_integrity" ;
    exec:requirements "Cryptographic integrity, ≤1 tick overhead" ;
    exec:testCriteria "100% hash validation success, minimal overhead"
  ], [
    exec:task "Implement Work-Stealing Scheduler" ;
    exec:file "src/work_stealing.c" ;
    exec:functions "steal_attempt, victim_selection, load_balance" ;
    exec:requirements "Chase-Lev deques, randomized victims, exponential backoff" ;
    exec:testCriteria ">95% core utilization, <5% stealing overhead"
  ] .

#################################################################
#
# PHASE 4: INTEGRATION (P4D)  
#################################################################

:IntegrationPhase a exec:BuildPhase ;
  rdfs:label "Erlang-C Integration and NIF Bridge" ;
  exec:phaseNumber 4 ;
  exec:duration "P4D" ;
  exec:dependencies :CorePhase ;
  exec:objectives "Integrate C engine with Erlang orchestration layer" ;
  exec:tasks [
    exec:task "Implement Erlang NIF Bridge" ;
    exec:file "src/bitactor_nif.c" ;
    exec:basedOn "~/cns/legacy/elixir/bitactor_otp/c_src/bitactor_nif.c" ;
    exec:functions "create_actor_nif, send_signal_nif, process_signals_nif" ;
    exec:requirements "Zero-copy data transfer, resource management" ;
    exec:testCriteria "NIF loading success, zero memory leaks"
  ], [
    exec:task "Implement Erlang Orchestration Layer" ;
    exec:file "erlang/src/bitactor_server.erl" ;
    exec:basedOn "~/cns/legacy/elixir/bitactor_otp/src/bitactor_server.erl" ;
    exec:behavior "gen_server" ;
    exec:functions "create_actor, send_signal, get_stats" ;
    exec:requirements "Ultra-fast message path, process dictionary caching" ;
    exec:testCriteria "Sub-microsecond message routing"
  ], [
    exec:task "Implement OTP Supervision Tree" ;
    exec:file "erlang/src/bitactor_sup.erl" ;
    exec:strategy "one_for_one" ;
    exec:children "bitactor_server, bitactor_telemetry, bitactor_cluster" ;
    exec:testCriteria "Fault tolerance, automatic recovery"
  ], [
    exec:task "Implement Distributed Clustering" ;
    exec:file "erlang/src/bitactor_cluster.erl" ;
    exec:basedOn "~/cns/legacy/elixir/bitactor_otp/src/bitactor_cluster.erl" ;
    exec:functions "join_cluster, select_optimal_node, heartbeat_monitor" ;
    exec:requirements "Automatic discovery, load balancing, fault tolerance" ;
    exec:testCriteria "Node discovery <100ms, failover <500ms"
  ] .

#################################################################
#
# PHASE 5: VALIDATION (P8D)
#################################################################

:ValidationPhase a exec:BuildPhase ;
  rdfs:label "Comprehensive Validation and Performance Certification" ;
  exec:phaseNumber 5 ;
  exec:duration "P8D" ;
  exec:dependencies :IntegrationPhase ;
  exec:objectives "Validate all performance requirements and production readiness" ;
  exec:tasks [
    exec:task "Unit Test Implementation" ;
    exec:coverage "100% function coverage, 95% line coverage" ;
    exec:framework "Unity (C), EUnit (Erlang)" ;
    exec:testCount "500+ unit tests" ;
    exec:duration "P2D"
  ], [
    exec:task "Integration Test Suite" ;
    exec:coverage "End-to-end signal flow, fault scenarios" ;
    exec:scenarios "Normal operation, high load, fault injection" ;
    exec:duration "P2D"
  ], [
    exec:task "Performance Benchmark Validation" ;
    exec:benchmarks "Latency, throughput, scalability, reliability" ;
    exec:duration "P2D" ;
    exec:requirements "All performance targets must be met or exceeded"
  ], [
    exec:task "Production Readiness Assessment" ;
    exec:criteria "Security, monitoring, deployment, operations" ;
    exec:duration "P1D" ;
    exec:deliverables "Production readiness checklist, deployment guide"
  ], [
    exec:task "Documentation Generation" ;
    exec:types "API docs, architecture docs, operations guide" ;
    exec:duration "P1D" ;
    exec:formats "Markdown, HTML, PDF"
  ] .

#################################################################
#
# AUTONOMOUS CONSTRUCTION INSTRUCTIONS
#
#################################################################

:AutonomousAgent a exec:AgentSpecification ;
  rdfs:label "Coding Agent Instructions for ByteActor Construction" ;
  exec:agentCapabilities "C programming, Erlang/OTP, build systems, testing, performance analysis" ;
  exec:requiredTools "gcc/clang, cmake, erlang, git, performance profilers" ;
  exec:executionStrategy [
    exec:step 1 ;
    exec:action "Read and analyze all ontology files" ;
    exec:files "byteactor_c4_complete.ttl, byteactor_dflss_project.ttl, byteactor_implementation_spec.ttl, byteactor_performance_requirements.ttl, byteactor_concurrency_model.ttl" ;
    exec:output "Complete understanding of system requirements"
  ], [
    exec:step 2 ;
    exec:action "Execute preparation phase tasks" ;
    exec:reference ":PreparationPhase" ;
    exec:validation "Environment ready, code analyzed, structure created"
  ], [
    exec:step 3 ;
    exec:action "Implement foundation components" ;
    exec:reference ":FoundationPhase" ;
    exec:validation "Lock-free primitives working, tests passing"
  ], [
    exec:step 4 ;
    exec:action "Build core engine" ;
    exec:reference ":CorePhase" ;
    exec:validation "All performance targets met, benchmarks passing"
  ], [
    exec:step 5 ;
    exec:action "Integrate with Erlang layer" ;
    exec:reference ":IntegrationPhase" ;
    exec:validation "End-to-end signal flow working"
  ], [
    exec:step 6 ;
    exec:action "Complete validation suite" ;
    exec:reference ":ValidationPhase" ;
    exec:validation "Production readiness confirmed"
  ] ;
  exec:decisionPoints [
    exec:decision "Performance targets not met in Phase 4" ;
    exec:action "Optimize hot paths, review SIMD usage, check memory alignment" ;
    exec:escalation "Consult performance ontology for optimization guidance"
  ], [
    exec:decision "Integration issues in Phase 5" ;
    exec:action "Review NIF resource management, check Erlang supervision" ;
    exec:escalation "Validate concurrency model compliance"
  ] .

#################################################################
#
# COMPLETE FILE MANIFEST
#
#################################################################

:CompleteFileManifest a exec:FileManifest ;
  rdfs:label "Complete ByteActor System File Manifest" ;
  exec:coreFiles [
    exec:file "src/bitactor_core.c" ;
    exec:description "Main execution engine with ≤8 tick guarantee" ;
    exec:loc 500 ;
    exec:complexity "Medium" ;
    exec:criticalPath true
  ], [
    exec:file "src/ring_buffer.c" ;
    exec:description "Lock-free SPSC ring buffer implementation" ;
    exec:loc 200 ;
    exec:complexity "High" ;
    exec:criticalPath true
  ], [
    exec:file "src/dispatch_table.c" ;
    exec:description "Perfect hash dispatch table" ;
    exec:loc 300 ;
    exec:complexity "High" ;
    exec:criticalPath true
  ], [
    exec:file "src/memory_crystal.c" ;
    exec:description "Memory crystallization allocation engine" ;
    exec:loc 400 ;
    exec:complexity "Medium" ;
    exec:criticalPath true
  ], [
    exec:file "src/result_sealing.c" ;
    exec:description "BLAKE3 result crystal sealing" ;
    exec:loc 250 ;
    exec:complexity "Medium" ;
    exec:criticalPath true
  ], [
    exec:file "src/work_stealing.c" ;
    exec:description "Work-stealing load balancer" ;
    exec:loc 600 ;
    exec:complexity "Very High" ;
    exec:criticalPath false
  ] ;
  exec:erlangFiles [
    exec:file "erlang/src/bitactor_server.erl" ;
    exec:behavior "gen_server" ;
    exec:loc 800 ;
    exec:complexity "Medium"
  ], [
    exec:file "erlang/src/bitactor_nif.erl" ;
    exec:description "NIF wrapper interface" ;
    exec:loc 200 ;
    exec:complexity "Low"
  ], [
    exec:file "erlang/src/bitactor_sup.erl" ;
    exec:behavior "supervisor" ;
    exec:loc 150 ;
    exec:complexity "Low"
  ] ;
  exec:testFiles [
    exec:file "tests/test_bitactor_core.c" ;
    exec:testCount 50 ;
    exec:coverage "Core engine functionality"
  ], [
    exec:file "tests/test_ring_buffer.c" ;
    exec:testCount 30 ;
    exec:coverage "Lock-free operations"
  ], [
    exec:file "tests/test_performance.c" ;
    exec:testCount 20 ;
    exec:coverage "Performance requirements"
  ] ;
  exec:buildFiles [
    exec:file "CMakeLists.txt" ;
    exec:description "Main build configuration"
  ], [
    exec:file "erlang/rebar.config" ;
    exec:description "Erlang build configuration"
  ] .

#################################################################
#
# SUCCESS CRITERIA AND VALIDATION
#
#################################################################

:CompletionCriteria a exec:SuccessCriteria ;
  rdfs:label "ByteActor Construction Success Criteria" ;
  exec:functionalCriteria [
    exec:criterion "All unit tests passing" ;
    exec:measurement "Test suite execution" ;
    exec:target "100% pass rate" ;
    exec:current "TBD"
  ], [
    exec:criterion "Performance requirements met" ;
    exec:measurement "Benchmark suite execution" ;
    exec:target "All performance targets achieved" ;
    exec:validation "Automated benchmark validation"
  ], [
    exec:criterion "Integration tests passing" ;
    exec:measurement "End-to-end test execution" ;
    exec:target "Complete signal flow working" ;
    exec:scenarios "Normal, high load, fault injection"
  ] ;
  exec:qualityCriteria [
    exec:criterion "Code quality standards" ;
    exec:tools "Static analysis, code review" ;
    exec:standards "No warnings, complexity limits met"
  ], [
    exec:criterion "Memory safety" ;
    exec:tools "Valgrind, AddressSanitizer" ;
    exec:target "Zero memory errors detected"
  ], [
    exec:criterion "Concurrency correctness" ;
    exec:tools "ThreadSanitizer, Helgrind" ;
    exec:target "Zero race conditions detected"
  ] ;
  exec:productionCriteria [
    exec:criterion "Security validation" ;
    exec:measurement "BLAKE3 integrity checking" ;
    exec:target "100% result crystal validation"
  ], [
    exec:criterion "Monitoring integration" ;
    exec:measurement "OpenTelemetry metrics emission" ;
    exec:target "Complete observability"
  ], [
    exec:criterion "Documentation complete" ;
    exec:measurement "Documentation coverage" ;
    exec:target "All APIs documented, deployment guide available"
  ] .

#################################################################
#
# EMERGENCY ROLLBACK STRATEGY
#################################################################

:RollbackStrategy a exec:RollbackPlan ;
  rdfs:label "Construction Failure Recovery Plan" ;
  exec:triggers [
    exec:trigger "Performance targets not achievable" ;
    exec:action "Revert to proven ~/cns implementations" ;
    exec:timeline "PT4H"
  ], [
    exec:trigger "Critical bugs in core engine" ;
    exec:action "Rollback to last stable checkpoint" ;
    exec:timeline "PT2H"
  ], [
    exec:trigger "Integration failures" ;
    exec:action "Isolate C and Erlang layers, debug independently" ;
    exec:timeline "PT8H"
  ] ;
  exec:checkpoints [
    exec:checkpoint "Foundation phase complete" ;
    exec:validation "Lock-free primitives working"
  ], [
    exec:checkpoint "Core engine complete" ;
    exec:validation "Performance targets achieved"
  ], [
    exec:checkpoint "Integration complete" ;
    exec:validation "End-to-end flow operational"
  ] .

#################################################################
#
# RESOURCE REQUIREMENTS
#
#################################################################

:BuildResources a exec:ResourceRequirements ;
  rdfs:label "ByteActor Construction Resource Requirements" ;
  exec:hardware [
    exec:cpu "x86_64 or ARM64 with AVX2/NEON support" ;
    exec:cores "8+ cores recommended for testing" ;
    exec:memory "32GB+ RAM for build and test" ;
    exec:storage "100GB+ fast SSD"
  ] ;
  exec:software [
    exec:os "Linux (Ubuntu 22.04+) or macOS (12.0+)" ;
    exec:compiler "GCC 11+ or Clang 13+" ;
    exec:cmake "3.20+" ;
    exec:erlang "OTP 26+" ;
    exec:deps "libnuma-dev, libblake3-dev"
  ] ;
  exec:timeEstimate [
    exec:experienced "14 days" ;
    exec:intermediate "21 days" ;
    exec:novice "35 days"
  ] .

#################################################################
#
# FINAL VALIDATION CHECKLIST
#
#################################################################

:FinalValidation a exec:ValidationChecklist ;
  rdfs:label "ByteActor Construction Completion Checklist" ;
  exec:checklist [
    exec:item "✅ All ontology specifications read and understood" ;
    exec:validation "Agent confirms understanding of all requirements"
  ], [
    exec:item "✅ Environment setup and dependencies installed" ;
    exec:validation "All build tools functional"
  ], [
    exec:item "✅ Foundation code implemented and tested" ;
    exec:validation "Lock-free primitives working correctly"
  ], [
    exec:item "✅ Core engine meets performance requirements" ;
    exec:validation "≤8 tick execution guarantee validated"
  ], [
    exec:item "✅ Erlang integration functional" ;
    exec:validation "NIF bridge working, supervision tree operational"
  ], [
    exec:item "✅ End-to-end signal flow operational" ;
    exec:validation "Complete lifecycle: ingress → processing → egress"
  ], [
    exec:item "✅ All tests passing" ;
    exec:validation "Unit, integration, and performance tests green"
  ], [
    exec:item "✅ Performance benchmarks meet targets" ;
    exec:validation "All performance requirements satisfied"
  ], [
    exec:item "✅ Production readiness confirmed" ;
    exec:validation "Monitoring, logging, deployment ready"
  ], [
    exec:item "✅ Documentation complete" ;
    exec:validation "All components documented, deployment guide available"
  ] ;
  exec:signOff "Senior Engineer Review and Approval Required" .

#################################################################
#
# CODING AGENT ENTRY POINT
#
#################################################################

:AgentEntryPoint a exec:EntryPoint ;
  rdfs:label "Autonomous Coding Agent Entry Point" ;
  exec:startCommand "Begin ByteActor system construction using this master ontology" ;
  exec:firstTask "Read and parse all five ontology specifications" ;
  exec:validationLoop [
    exec:phase "After each major task completion" ;
    exec:action "Validate against ontology requirements" ;
    exec:criteria "All constraints satisfied, performance targets met"
  ] ;
  exec:successCondition "All items in :FinalValidation checklist completed" ;
  exec:completionArtifact "Fully functional ByteActor system ready for production deployment" ;
  exec:estimatedEffort "21 person-days for experienced agent" ;
  exec:confidenceLevel "High (95%) - based on existing code foundation and detailed specifications" .