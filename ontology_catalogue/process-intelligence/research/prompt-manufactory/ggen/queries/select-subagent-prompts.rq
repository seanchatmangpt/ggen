PREFIX pm:   <https://pi-research.dev/ontology/prompt-manufactory#>
PREFIX dct:  <http://purl.org/dc/terms/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# Select subagent role prompts
# Used by subagent-prompt.md.tera to render subagent role warrants

SELECT ?roleId ?roleLabel ?roleMission ?ownerProgram ?outputContract
WHERE {
  ?role a pm:SubagentRole ;
    rdfs:label ?roleLabel ;
    pm:mission ?roleMission ;
    pm:hasOutputContract ?outputContract .

  OPTIONAL { ?role pm:roleId ?roleId . }
  OPTIONAL {
    ?program pm:hasPhase ?phase .
    ?phase pm:hasSubagentRole ?role .
    BIND (?program AS ?ownerProgram)
  }
}
ORDER BY ?roleLabel
