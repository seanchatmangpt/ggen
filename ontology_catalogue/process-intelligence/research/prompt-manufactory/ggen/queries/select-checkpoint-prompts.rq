PREFIX pm:   <https://pi-research.dev/ontology/prompt-manufactory#>
PREFIX dct:  <http://purl.org/dc/terms/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# Select checkpoint prompts
# Used by checkpoint-prompt.md.tera to render checkpoint warrants

SELECT ?programId ?checkpointLabel ?checkpointMission
WHERE {
  ?program a pm:ResearchProgram ;
    pm:programId ?programId .

  ?checkpoint a pm:Checkpoint ;
    rdfs:label ?checkpointLabel ;
    pm:mission ?checkpointMission .
}
ORDER BY ?programId ?checkpointLabel
