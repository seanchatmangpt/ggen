PREFIX pm:   <https://pi-research.dev/ontology/prompt-manufactory#>
PREFIX dct:  <http://purl.org/dc/terms/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# Select all ResearchProgram instances with required properties
# Used to discover which programs exist and what warrant class each emits

SELECT DISTINCT ?program ?programId ?mission ?promptClass
WHERE {
  ?program a pm:ResearchProgram ;
    pm:programId ?programId ;
    pm:mission ?mission ;
    pm:hasPromptClass ?promptClass .
}
ORDER BY ?programId
