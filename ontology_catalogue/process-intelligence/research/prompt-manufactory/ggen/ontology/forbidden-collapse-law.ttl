@prefix pm:   <https://pi-research.dev/ontology/prompt-manufactory#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# ============================================================================
# FORBIDDEN COLLAPSE LAW
# ============================================================================
# Defines absolute boundaries that must not be crossed.
# Three categories: .ggen source files, DTO/JSON flattening, forced ALIVE.
# Also defines the classification system for legacy .ggen files.
# ============================================================================

# --- .ggen Source File Ban ---

pm:FORBIDDEN_ggen_source_files a rdfs:Class ;
  rdfs:label "Forbidden: .ggen Source Files" ;
  rdfs:comment "No .ggen extension files allowed in source directories (ggen/ontology, ggen/queries, ggen/templates, ggen.toml)" ;
  rdfs:comment "Valid source surfaces ONLY: .ttl, .rq, .tera, ggen.toml, .md (documentation)" ;
  rdfs:comment "Audit rule: find . -name '*.ggen' → must return zero results in prompt-manufactory/ggen/" .

# --- DTO/JSON Flattening Ban ---

pm:FORBIDDEN_dto_flattening a rdfs:Class ;
  rdfs:label "Forbidden: DTO/JSON Flattening" ;
  rdfs:comment "No collapse of structured Evidence<T, State, W> into casual JSON/string carriers without boundary classification" ;
  rdfs:comment "Examples: EvidenceDto, payload_json, state_tag as unbounded string" ;
  rdfs:comment "Refusal: REFUSAL_DTO_COLLAPSE" .

# --- Forced ALIVE Ban ---

pm:FORBIDDEN_forced_alive a rdfs:Class ;
  rdfs:label "Forbidden: Forced ALIVE" ;
  rdfs:comment "No ALIVE verdict claimed when critical audit gates have failed or prerequisite proofs are incomplete" ;
  rdfs:comment "PARTIAL is the honest verdict when: end-to-end warrant path unproven, legacy .ggen unclassified, or gates fail" ;
  rdfs:comment "Audit rule: FAIL if ALIVE claimed with unresolved blockers" .

# --- Legacy .ggen File Classification System ---

pm:InvalidGgenFile_Classification a rdfs:Class ;
  rdfs:label "Invalid .ggen File Classification" ;
  rdfs:subClassOf pm:InvalidGgenFile ;
  rdfs:comment "Classification system for the 22 legacy .ggen files found across the research tree" .

# Classification values (enumeration)

pm:LEGACY_INVALID_SOURCE a pm:InvalidGgenFile_Classification ;
  rdfs:label "LEGACY_INVALID_SOURCE" ;
  rdfs:comment "File was generated by previous workflow as source file with wrong extension; must be reclassified or deleted" .

pm:RENDERED_ARTIFACT_WITH_WRONG_EXTENSION a pm:InvalidGgenFile_Classification ;
  rdfs:label "RENDERED_ARTIFACT_WITH_WRONG_EXTENSION" ;
  rdfs:comment "File is a valid rendered artifact but has .ggen extension instead of intended output extension" ;
  rdfs:comment "Fix: rename to correct extension (e.g., audit-*.sh.ggen → audit-*.sh)" .

pm:MIGRATION_REQUIRED a pm:InvalidGgenFile_Classification ;
  rdfs:label "MIGRATION_REQUIRED" ;
  rdfs:comment "File must be migrated to new location or refactored; blocking but fixable" .

pm:OUT_OF_SCOPE_EXTERNAL_ARTIFACT a pm:InvalidGgenFile_Classification ;
  rdfs:label "OUT_OF_SCOPE_EXTERNAL_ARTIFACT" ;
  rdfs:comment "File is generated artifact in external project; non-blocking" .

pm:BLOCKING_SOURCE_SURFACE a pm:InvalidGgenFile_Classification ;
  rdfs:label "BLOCKING_SOURCE_SURFACE" ;
  rdfs:comment "File is source surface with .ggen extension in Prompt Manufactory scope; blocks ALIVE" .

