# --- Prompt Classes (enumeration values) ---

pm:INTEL a pm:PromptClass ;
  rdfs:label "INTEL" ;
  rdfs:comment "Census, classify, map existing work" .

pm:RECONCILE a pm:PromptClass ;
  rdfs:label "RECONCILE" ;
  rdfs:comment "Unify checkpoints, resolve contradictions" .

pm:REMEDIATE a pm:PromptClass ;
  rdfs:label "REMEDIATE" ;
  rdfs:comment "Route failed gates without broad implementation" .

pm:SYNC a pm:PromptClass ;
  rdfs:label "SYNC" ;
  rdfs:comment "Run ggen sync from known-good graph" .

pm:AUDIT a pm:PromptClass ;
  rdfs:label "AUDIT" ;
  rdfs:comment "Inspect for forbidden collapses" .

pm:CHECKPOINT a pm:PromptClass ;
  rdfs:label "CHECKPOINT" ;
  rdfs:comment "Emit ALIVE/PARTIAL verdict" .

pm:SPR a pm:PromptClass ;
  rdfs:label "SPR" ;
  rdfs:comment "Compress program state for cold-load" .

pm:LIVESTREAM a pm:PromptClass ;
  rdfs:label "LIVESTREAM" ;
  rdfs:comment "Turn workflow into public narration" .
