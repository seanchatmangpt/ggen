@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix schema:  <https://schema.org/> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix pi:      <https://process.intelligence/ontology/> .
@prefix chk:     <https://process.intelligence/checkpoint/> .
@prefix proj:    <https://process.intelligence/project/> .

# ============================================================
# checkpoint-ledger.ttl — All ALIVE/PARTIAL Checkpoints
# Authority: Process Intelligence Research Foundry
# Date: 2026-06-01
# Immutability: Checkpoint verdicts stand as issued.
#   Only dated addendums permitted. Never revert.
# ============================================================

<https://process.intelligence/ontology/checkpoint-ledger>
    a owl:Ontology ;
    owl:imports <https://process.intelligence/ontology/pi-program> ;
    dcterms:title "PI Program Checkpoint Ledger" ;
    dcterms:description "Immutable ledger of all ALIVE and PARTIAL checkpoint verdicts issued by the PI research program. Each checkpoint is classified as ALIVE_CLAIM or PARTIAL_CLAIM with its gate criteria evidence." ;
    dcterms:created "2026-06-01"^^xsd:date ;
    dcterms:creator <https://process.intelligence/agent/research-foundry> ;
    owl:versionInfo "1.0.0" .

# ============================================================
# SECTION 1: Checkpoint Property Definitions
# ============================================================

pi:verdictType
    a owl:DatatypeProperty ;
    rdfs:label "verdict type" ;
    rdfs:range xsd:string ;
    skos:definition "The verdict issued at a checkpoint: ALIVE, PARTIAL, or FAILED." .

pi:gatesCriteriaMet
    a owl:DatatypeProperty ;
    rdfs:label "gates criteria met" ;
    rdfs:range xsd:integer ;
    skos:definition "Number of gate criteria simultaneously satisfied at checkpoint issuance." .

pi:gatesCriteriaTotal
    a owl:DatatypeProperty ;
    rdfs:label "gates criteria total" ;
    rdfs:range xsd:integer ;
    skos:definition "Total number of gate criteria required for an ALIVE verdict." .

pi:commitHash
    a owl:DatatypeProperty ;
    rdfs:label "commit hash" ;
    rdfs:range xsd:string ;
    skos:definition "The git commit hash anchoring the checkpoint verdict to the tamper-evident history." .

pi:authoritySignature
    a owl:DatatypeProperty ;
    rdfs:label "authority signature" ;
    rdfs:range xsd:string ;
    skos:definition "BLAKE3 or Ed25519 signature from the issuing authority, cryptographically binding the verdict." .

pi:authorizedDownstream
    a owl:ObjectProperty ;
    rdfs:label "authorized downstream" ;
    rdfs:domain pi:ALIVE_CLAIM ;
    rdfs:range prov:Entity ;
    skos:definition "Names the downstream implementations authorized by this ALIVE verdict." .

pi:blockingGap
    a owl:ObjectProperty ;
    rdfs:label "blocking gap" ;
    rdfs:domain pi:PARTIAL_CLAIM ;
    rdfs:range pi:FAILED_GATE ;
    skos:definition "Links a PARTIAL checkpoint to the specific failed gate that blocks advancement to ALIVE." .

