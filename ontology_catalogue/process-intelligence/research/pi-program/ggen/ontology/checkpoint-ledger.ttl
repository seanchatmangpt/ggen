# ============================================================
# SECTION 7: SHACL — Checkpoint Immutability Constraints
# ============================================================

pi:CheckpointImmutabilityShape
    a sh:NodeShape ;
    sh:targetClass pi:CHECKPOINT ;
    sh:property [
        sh:path pi:verdictType ;
        sh:minCount 1 ;
        sh:in ("ALIVE" "PARTIAL" "FAILED" "OPEN" "RESOLVED") ;
        sh:message "Checkpoint verdict must be one of: ALIVE, PARTIAL, FAILED, OPEN, RESOLVED." ;
    ] ;
    sh:property [
        sh:path dcterms:created ;
        sh:minCount 1 ;
        sh:datatype xsd:date ;
        sh:message "Every checkpoint must have a creation date — checkpoints are immutable and dated." ;
    ] .

pi:ALIVEClaimShape
    a sh:NodeShape ;
    sh:targetClass pi:ALIVE_CLAIM ;
    sh:property [
        sh:path pi:gatesCriteriaMet ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "ALIVE claims must document how many gate criteria were met." ;
    ] .

pi:PARTIALClaimShape
    a sh:NodeShape ;
    sh:targetClass pi:PARTIAL_CLAIM ;
    sh:property [
        sh:path pi:blockingGap ;
        sh:minCount 1 ;
        sh:message "PARTIAL claims must identify at least one blocking gap or failed gate." ;
    ] .
