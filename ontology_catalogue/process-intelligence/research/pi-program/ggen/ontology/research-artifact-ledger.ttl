# ============================================================
# research-artifact-ledger.ttl — Papers, Experiments, Audits
# Authority: Process Intelligence Research Foundry
# Date: 2026-06-01
# ============================================================

<https://process.intelligence/ontology/research-artifact-ledger>
    a owl:Ontology ;
    owl:imports <https://process.intelligence/ontology/pi-program> ;
    dcterms:title "PI Research Artifact Ledger" ;
    dcterms:description "Ledger of all research artifacts produced by the PI program: academic paper classifications, experiment fixtures, audit findings, and comparison matrices. Every artifact must cite its evidence source." ;
    dcterms:created "2026-06-01"^^xsd:date ;
    dcterms:creator <https://process.intelligence/agent/research-foundry> ;
    owl:versionInfo "1.0.0" .

# ============================================================
# SECTION 1: Artifact Sub-Classifications
# ============================================================

pi:PaperClassification
    a owl:Class ;
    rdfs:subClassOf pi:RESEARCH_ARTIFACT ;
    rdfs:label "Paper Classification" ;
    skos:definition "A formal mapping of an academic paper to process mining type-law and execution-law surfaces. Requires reading the paper and confirming the cited claim appears in it." .

pi:ExperimentFixture
    a owl:Class ;
    rdfs:subClassOf pi:RESEARCH_ARTIFACT ;
    rdfs:label "Experiment Fixture" ;
    skos:definition "A synthetic or recorded event log, Petri net model, or benchmark comparison matrix used to validate program claims." .

pi:AuditFinding
    a owl:Class ;
    rdfs:subClassOf pi:RESEARCH_ARTIFACT ;
    rdfs:label "Audit Finding" ;
    skos:definition "A completeness audit result documenting source coverage, gap analysis, or conformance status. Audits are append-only; never reverted." .

pi:CapabilityMap
    a owl:Class ;
    rdfs:subClassOf pi:RESEARCH_ARTIFACT ;
    rdfs:label "Capability Map" ;
    skos:definition "A systematic mapping of a system's function surface (e.g., PM4Py API) to equivalence/gap status relative to the wasm4pm engine." .

# ============================================================
# SECTION 2: Paper Canon (9 classified papers)
# ============================================================

art:paper-workflow-mining-2004
    a prov:Entity, pi:PaperClassification, bibo:AcademicArticle ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "Workflow Mining: Discovering Process Models from Event Logs" ;
    dcterms:creator "van der Aalst, Weijters, Maruster" ;
    dcterms:date "2004" ;
    dcterms:source "IEEE Transactions on Knowledge and Data Engineering" ;
    dcterms:description "Foundational process discovery paper. Type-law mapping: DFG → HeuristicsWitness, directly-follows relations → AlphaWitness. Execution-law: wasm4pm alpha_miner and heuristics_miner surfaces." ;
    prov:wasAttributedTo <https://process.intelligence/agent/paper-census> ;
    schema:url <file:///Users/sac/process-intelligence/sources/papers> .

art:paper-inductive-miner-2011
    a prov:Entity, pi:PaperClassification, bibo:AcademicArticle ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "Discovering Block-Structured Process Models from Event Logs" ;
    dcterms:creator "Leemans, Fahland, van der Aalst" ;
    dcterms:date "2013" ;
    dcterms:source "Proceedings of ACSD" ;
    dcterms:description "Block-structured discovery guaranteeing soundness by construction. Type-law mapping: ProcessTree → InductiveWitness (tree_depth, xor_blocks, and_blocks, seq_blocks, loop_blocks). Execution-law: wasm4pm inductive_miner surface." ;
    prov:wasAttributedTo <https://process.intelligence/agent/paper-census> .

art:paper-wfnet-soundness-1998
    a prov:Entity, pi:PaperClassification, bibo:AcademicArticle ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "WF-net Soundness (van der Aalst 1998/1999)" ;
    dcterms:creator "van der Aalst" ;
    dcterms:date "1998" ;
    dcterms:description "Workflow Net soundness: unique source/sink, strong connectivity, liveness, 1-boundedness. Type-law: wasm4pm-compat WfNetSoundnessPaper witness. Execution-law: wasm4pm PetriNet::analyze_soundness(), Blue River Gate 1." ;
    prov:wasAttributedTo <https://process.intelligence/agent/paper-census> .

art:paper-conformance-checking-2011
    a prov:Entity, pi:PaperClassification, bibo:AcademicArticle ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "Conformance Checking using Alignments" ;
    dcterms:creator "Adriansyah, Sidorova, van Dongen" ;
    dcterms:date "2011" ;
    dcterms:description "Alignment-based conformance: synchronous moves (cost=0), log moves (cost=1), model moves (cost=1). Optimal alignment via A* search. Type-law: WitnessState {PartialReplay, trace_indices, marking, cost}. Status in wasm4pm: conformance_boundary=false (NOT GRADUATED — alignment stub only)." ;
    prov:wasAttributedTo <https://process.intelligence/agent/paper-census> .

art:paper-adriansyah-phd-2014
    a prov:Entity, pi:PaperClassification, bibo:Thesis ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "Alignment-Based Process Conformance Checking (PhD thesis)" ;
    dcterms:creator "Adriansyah" ;
    dcterms:date "2014" ;
    dcterms:description "PhD thesis on alignment-based conformance. Authoritative reference for A* alignment algorithm. Type-law: WitnessState lattice. Execution-law: wasm4pm conformance.rs alignment surface (stub — NotImplementedYet refusal)." ;
    prov:wasAttributedTo <https://process.intelligence/agent/paper-census> .

art:paper-petri-nets-murata-1989
    a prov:Entity, pi:PaperClassification, bibo:AcademicArticle ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "Petri Nets: Properties, Analysis and Applications" ;
    dcterms:creator "Murata" ;
    dcterms:date "1989" ;
    dcterms:source "Proceedings of the IEEE" ;
    dcterms:description "Foundational Petri Net theory. Type-law: wasm4pm-compat ConditionCell<BITS> (generic_const_exprs, Need9 law enforced at 8 bits max). Execution-law: wasm4pm PetriNet, Marking, firing, coverability tree." ;
    prov:wasAttributedTo <https://process.intelligence/agent/paper-census> .

art:paper-ocel-2-0-2023
    a prov:Entity, pi:PaperClassification, bibo:AcademicArticle ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "Object-Centric Event Logs (OCEL 2.0)" ;
    dcterms:creator "van der Aalst et al." ;
    dcterms:date "2023" ;
    dcterms:source "IEEE Transactions" ;
    dcterms:description "OCEL 2.0 object-centric event log standard: tuple (E, O, EA, OA, E2O, O2O). Type-law: wasm4pm-compat Ocel20 witness. Execution-law: wasm4pm ZeroCopyOcel (binary format, OCEL magic 0x4F43454C). OCPQ queries over object-centric logs." ;
    dcterms:conformsTo <https://doi.org/10.1109/TKDE.2023.3318844> ;
    prov:wasAttributedTo <https://process.intelligence/agent/paper-census> .

art:paper-ocpn-van-der-aalst-berti-2020
    a prov:Entity, pi:PaperClassification, bibo:AcademicArticle ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "Object-Centric Petri Nets" ;
    dcterms:creator "van der Aalst, Berti" ;
    dcterms:date "2020" ;
    dcterms:description "Object-Centric Petri Net discovery from object-centric event logs. Type-law: wasm4pm-compat ObjectCentricPetriNetPaper witness. Execution-law: mapped to wasm4pm OCPQ query surface." ;
    prov:wasAttributedTo <https://process.intelligence/agent/paper-census> .

art:paper-powl-kourani-2023
    a prov:Entity, pi:PaperClassification, bibo:AcademicArticle ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "POWL: Partially Ordered Workflow Language" ;
    dcterms:creator "Kourani" ;
    dcterms:date "2023" ;
    dcterms:description "POWL: Partially Ordered Workflow Language for process models. Type-law: wasm4pm-compat PowlPaper witness, TypedNode<{Kind}> using adt_const_params nightly feature. TreeProjectable trait seals over-block loss. Status: PARTIAL (SeparableWfNet compile-fail fixture not yet in tests/ui/)." ;
    prov:wasAttributedTo <https://process.intelligence/agent/paper-census> .

