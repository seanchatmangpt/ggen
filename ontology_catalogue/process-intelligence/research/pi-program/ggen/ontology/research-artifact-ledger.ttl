# ============================================================
# SECTION 6: SHACL Constraints
# ============================================================

pi:ResearchArtifactShape
    a sh:NodeShape ;
    sh:targetClass pi:RESEARCH_ARTIFACT ;
    sh:property [
        sh:path prov:wasGeneratedBy ;
        sh:minCount 1 ;
        sh:message "Every research artifact must identify the activity that generated it." ;
    ] ;
    sh:property [
        sh:path dcterms:description ;
        sh:minCount 1 ;
        sh:message "Every research artifact must have a description." ;
    ] .

pi:PaperClassificationShape
    a sh:NodeShape ;
    sh:targetClass pi:PaperClassification ;
    sh:property [
        sh:path dcterms:creator ;
        sh:minCount 1 ;
        sh:message "Paper classifications must name the author(s)." ;
    ] ;
    sh:property [
        sh:path dcterms:date ;
        sh:minCount 1 ;
        sh:message "Paper classifications must include publication year." ;
    ] .
