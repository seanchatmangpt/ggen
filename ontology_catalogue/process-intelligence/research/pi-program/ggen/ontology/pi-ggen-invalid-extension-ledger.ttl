# Remediation Plan
inv:REMEDIATION_PLAN a owl:NamedIndividual, pi:RemediationPlan ;
    dcterms:title "ggen Tera Engine Implementation & Integration" ;
    dcterms:description "Systematic approach to unblock all 23 .ggen files" ;
    pi:phase1 "Implement ggen Tera Processing Engine (Rust or Python MVP, 2-3 weeks)" ;
    pi:phase1Detail "Input: .{ext}.ggen Tera template source; Template Variables: from SPARQL queries; Output: deterministic rendered files (.sh, .rs, .wit, .yaml, .md); Receipt: BLAKE3 checksum + cryptographic chain" ;
    pi:phase2 "Extend ggen.toml with Audit & Template Rules" ;
    pi:phase2Detail "Add 7 audit rules (primary cell) + 5 audit rules (telemetry cell) + 6 template rules (primary) + 5 template rules (telemetry); Specify output paths, checksums, witness injection" ;
    pi:phase3 "Configure Audit Gate Pipeline" ;
    pi:phase3Detail "Define gate execution order: render templates → run audits → block/pass downstream; Specify PASS criteria; Link to checkpoint verdicts" ;
    pi:phase4 "Integrate with Receipt Chain" ;
    pi:phase4Detail "Each template rendering produces receipt (per ggen.toml [output] section); Store at ../receipts/template-{name}-receipt.json; Immutability: append-only" ;
    .

# Vocabulary Classes
pi:InvalidFilesCensus a owl:Class ;
    rdfs:label "Invalid Files Census" ;
    skos:definition "Summary classification of all .ggen files in the ecosystem" ;
    .

pi:GgenFile a owl:Class ;
    rdfs:label "Ggen File" ;
    skos:definition "A .ggen Tera template source file in the ggen ecosystem" ;
    .

pi:RemediationPlan a owl:Class ;
    rdfs:label "Remediation Plan" ;
    skos:definition "Systematic approach to enabling all MIGRATION_REQUIRED files" ;
    .

# Vocabulary Properties
pi:classification a owl:DatatypeProperty ;
    rdfs:label "classification" ;
    rdfs:range xsd:string ;
    skos:definition "File classification: MIGRATION_REQUIRED, LEGACY_INVALID_SOURCE, RENDERED_ARTIFACT_WITH_WRONG_EXTENSION, OUT_OF_SCOPE_EXTERNAL_ARTIFACT, or BLOCKING_SOURCE_SURFACE" ;
    .

pi:blockingStatus a owl:DatatypeProperty ;
    rdfs:label "blocking status" ;
    rdfs:range xsd:string ;
    skos:definition "YES or NO: whether this file blocks downstream processes" ;
    .

pi:remediationRoute a owl:DatatypeProperty ;
    rdfs:label "remediation route" ;
    rdfs:range xsd:string ;
    skos:definition "Specific steps to remediate or enable this file" ;
    .

pi:purpose a owl:DatatypeProperty ;
    rdfs:label "purpose" ;
    rdfs:range xsd:string ;
    skos:definition "What this .ggen file generates or validates" ;
    .

pi:templatingPattern a owl:DatatypeProperty ;
    rdfs:label "templating pattern" ;
    rdfs:range xsd:string ;
    skos:definition "Type of Tera template: shell script, Rust code, YAML, etc." ;
    .

pi:outputType a owl:DatatypeProperty ;
    rdfs:label "output type" ;
    rdfs:range xsd:string ;
    skos:definition "Language/format of the rendered output artifact" ;
    .

pi:totalGgenFiles a owl:DatatypeProperty ;
    rdfs:label "total ggen files" ;
    rdfs:range xsd:integer ;
    .

pi:migrationRequired a owl:DatatypeProperty ;
    rdfs:label "migration required" ;
    rdfs:range xsd:integer ;
    .

pi:legacyInvalid a owl:DatatypeProperty ;
    rdfs:label "legacy invalid" ;
    rdfs:range xsd:integer ;
    .

pi:renderedWithWrongExtension a owl:DatatypeProperty ;
    rdfs:label "rendered with wrong extension" ;
    rdfs:range xsd:integer ;
    .

pi:outOfScope a owl:DatatypeProperty ;
    rdfs:label "out of scope" ;
    rdfs:range xsd:integer ;
    .

pi:blockingSource a owl:DatatypeProperty ;
    rdfs:label "blocking source" ;
    rdfs:range xsd:integer ;
    .

pi:verdict a owl:DatatypeProperty ;
    rdfs:label "verdict" ;
    rdfs:range xsd:string ;
    .

pi:note a owl:DatatypeProperty ;
    rdfs:label "note" ;
    rdfs:range xsd:string ;
    skos:definition "Additional context or recommendations" ;
    .

pi:phase1 a owl:DatatypeProperty ;
    rdfs:label "phase 1" ;
    rdfs:range xsd:string ;
    .

pi:phase1Detail a owl:DatatypeProperty ;
    rdfs:label "phase 1 detail" ;
    rdfs:range xsd:string ;
    .

pi:phase2 a owl:DatatypeProperty ;
    rdfs:label "phase 2" ;
    rdfs:range xsd:string ;
    .

pi:phase2Detail a owl:DatatypeProperty ;
    rdfs:label "phase 2 detail" ;
    rdfs:range xsd:string ;
    .

pi:phase3 a owl:DatatypeProperty ;
    rdfs:label "phase 3" ;
    rdfs:range xsd:string ;
    .

pi:phase3Detail a owl:DatatypeProperty ;
    rdfs:label "phase 3 detail" ;
    rdfs:range xsd:string ;
    .

pi:phase4 a owl:DatatypeProperty ;
    rdfs:label "phase 4" ;
    rdfs:range xsd:string ;
    .

pi:phase4Detail a owl:DatatypeProperty ;
    rdfs:label "phase 4 detail" ;
    rdfs:range xsd:string ;
    .
