proj:ggen-primary-cell
    a prov:Entity ;
    pi:hasRole pi:MANUFACTURING_CELL ;
    rdfs:label "ggen Primary Manufacturing Cell" ;
    dcterms:description "Primary ggen cell at /ggen/. Manufactures board-admissible M&A assets and autonomic governance engines. Ontology: ontology-extensions.ttl (592 lines). SPARQL queries: extract-board-claims.rq, extract-diligence-claims.rq, extract-lifecycle-governance.rq. Templates: ma-deck.tera, ma-diligence.tera, blue-river.tera. Board-admissible gate: fitness >= 0.95 AND precision >= 0.90." ;
    schema:codeRepository <file:///Users/sac/process-intelligence/ggen> ;
    prov:wasAttributedTo <https://process.intelligence/agent/ggen-census> .

proj:ggen-telemetry-cell
    a prov:Entity ;
    pi:hasRole pi:MANUFACTURING_CELL ;
    rdfs:label "ggen Telemetry Bridge Manufacturing Cell" ;
    dcterms:description "Telemetry bridge cell at /otel-weaver/ggen/. Generates OTel Weaver intake validation code and court consequence routing. Manifests: live-check-intake.manifest.yaml, weaver-template-targets.manifest.yaml. Audit templates enforce feedstock/court separation." ;
    schema:codeRepository <file:///Users/sac/process-intelligence/otel-weaver/ggen> ;
    prov:wasPartOf proj:ggen-primary-cell .

# ============================================================
# SECTION 6: TELEMETRY FEEDSTOCK
# ============================================================

proj:otel-weaver
    a prov:Entity, dcat:Dataset ;
    pi:hasRole pi:TELEMETRY_FEEDSTOCK ;
    rdfs:label "OTel Weaver Integration Layer" ;
    dcterms:description "OpenTelemetry Weaver integration at /otel-weaver/. Validates OTel schema compliance (live-check), maps feedstock witnesses, routes findings to named refusal codes, enforces feedstock/court separation. Status: GGEN_OTEL_WEAVER_PI_ALIVE_001. Doctrine: 6 foundational laws. 5 experiments (custom registry, diff bridge, live-check validator, witness generator, collector config)." ;
    schema:codeRepository <file:///Users/sac/process-intelligence/otel-weaver> ;
    prov:wasAttributedTo <https://process.intelligence/agent/otel-weaver-census> ;
    dcterms:conformsTo <https://opentelemetry.io/schemas/1.25.0> .

proj:otel-weaver-admission
    a pi:ADMISSION_SURFACE ;
    rdfs:label "OTel Weaver Admission Surface" ;
    dcterms:description "Feedstock admitted via Admit boundary: OTel spans wrapped in Admission<T, W> using OtelSpanToOcelEventProjection witness. Requirements: schema URL present, TraceID present, timestamps monotonic, no dangling parent spans, payload non-empty. Admitted feedstock generates LossReport." ;
    prov:wasPartOf proj:otel-weaver .

proj:otel-weaver-refusals
    a pi:REFUSAL_SURFACE ;
    rdfs:label "OTel Weaver Refusal Surface" ;
    dcterms:description "Finding-to-refusal codex: find_empty_payload→EmptyTrace(violation_halt), find_missing_trace_id→MissingCaseId(violation_halt), find_non_monotone_timestamps→InvalidTimestampOrder(violation_halt), find_dangling_span_parent→DanglingEventObjectLink(escalation_warning), find_schema_url_missing→ProjectionNameRequired(violation_halt), find_strict_schema_mismatch→SchemaVersionMismatch(escalation_warning)." ;
    prov:wasPartOf proj:otel-weaver .

# ============================================================
# SECTION 7: MOBILE SUBSTRATE
# ============================================================

proj:expo-supabase-framework
    a prov:Entity, dcat:Dataset ;
    pi:hasRole pi:MOBILE_SUBSTRATE ;
    rdfs:label "Expo/Supabase Mobile Framework" ;
    dcterms:description "Reusable mobile substrate extracted from ZOEapp. Components: Expo Router file-system navigation with Stack.Protected guards, Supabase Auth (SessionProvider, JWT lifecycle, AsyncStorage persistence), RLS deny-by-default policies, Realtime CDC channels (actor_commands/events/receipts/rdf_quads_ld), Edge Functions (Deno), EAS build/update infrastructure, ApprovalFlowManager governance, identity boundary hierarchy (anonymous→authenticated→verified→mfa_verified)." ;
    prov:wasAttributedTo <https://process.intelligence/agent/expo-supabase-census> ;
    skos:note "Reusable across domains. Church-specific patterns (Schema.org Church, volunteer scheduling, pastoral gates) are domain-specific." .

# ============================================================
# SECTION 8: WORKFLOW SUBSTRATE
# ============================================================

proj:claude-workflow
    a prov:Entity ;
    pi:hasRole pi:WORKFLOW_SUBSTRATE ;
    rdfs:label "Claude Code Research Orchestration" ;
    dcterms:description "Phase-gated, receipt-bearing, adversarial audit loop. 12 sequential phases (0-11). 13 simultaneous gate criteria, all met (ALIVE). 570+ commits in conventional commit format. 4 master checkpoints. 6 receipt categories. 13 subagent roles. 20-agent adversarial swarm (v30.1.1). State persists via git commit log + immutable checkpoints + BLAKE3 receipt chain." ;
    prov:wasAttributedTo <https://process.intelligence/agent/claude-workflow-census> .

# ============================================================
# SECTION 9: SOURCE COURT
# ============================================================

proj:source-court
    a prov:Entity ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "PI Source Courts" ;
    dcterms:description "All source authority repositories: sources/papers/ (9 classified papers with type-law mappings), sources/pm4py/ (PM4Py capability atlas, 140+ functions), sources/wasm4pm-compat/ (type-law atlas), standards/ (39 public standards compliance mappings), comparisons/ (5 comparison matrices), crosswalks/ (4 type-law crosswalks)." ;
    prov:wasPartOf proj:process-intelligence .

proj:paper-canon
    a prov:Entity, dcat:Dataset ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "Paper Canon" ;
    dcterms:description "9 classified process mining papers with formal object mappings and type-law bindings. Van der Aalst corpus: Workflow Mining (2004), Inductive Miner (2011/2013), OCEL 2.0 (2023), Conformance Checking (1999/2011/2014), Petri Nets (Murata 1989), Workflow Management (2002). Every citation confirmed in source text." ;
    schema:url <file:///Users/sac/process-intelligence/sources/papers> .

proj:pm4py-capability-atlas
    a prov:Entity, dcat:Dataset ;
    pi:hasRole pi:SOURCE_COURT ;
    rdfs:label "PM4Py Capability Atlas" ;
    dcterms:description "9-file capability atlas mapping 140+ PM4Py functions to wasm4pm equivalence/gap status. Functions classified as: COVERED (direct equivalent), GAP (no equivalent), PARTIAL (partial coverage). Serves as comparative truth oracle for downstream conformance claims." ;
    schema:url <file:///Users/sac/process-intelligence/sources/pm4py> .

# ============================================================
# SECTION 10: AUTHORIZATION COURT
# ============================================================

proj:blue-river-dam
    a prov:Entity ;
    pi:hasRole pi:AUTHORIZATION_COURT ;
    pi:hasRole pi:EXECUTION_COURT ;
    rdfs:label "Blue River Dam Orchestrator" ;
    dcterms:description "629-line safe Rust MAPE-K orchestrator. 5 authority components (Governor, Architect, Operator, Auditor, Doctor). 6 lifecycle quality gates. 4 actuation protocols (elastic 0.85-0.95, compliance <0.85, debt >15%, retirement). 11-pathway admission law. Cryptographic governance ledger (SHA-256 block chain). LTL safety invariants. Status: ORCHESTRATOR_ALIVE." ;
    schema:codeRepository <file:///Users/sac/process-intelligence/blue_river_dam> ;
    prov:wasAttributedTo <https://process.intelligence/agent/blue-river-dam-census> .

proj:blue-river-admission
    a pi:ADMISSION_SURFACE ;
    rdfs:label "Blue River Dam Admission Law" ;
    dcterms:description "11-pathway refusal boundary. Pathways: (1) temporal monotonicity, (2) schema type mismatch, (3) causal disconnection, (4) memory bounds violation, (5) cryptographic signature invalid, (6) Petri net soundness violation, (7) fitness threshold violation, (8) object identity conflict, (9) BPMN OR-join quorum undefined, (10) Declare constraints not supported, (11) duplicate event IDs. Default policy: DENY." ;
    prov:wasPartOf proj:blue-river-dam .

proj:blue-river-refusals
    a pi:REFUSAL_SURFACE ;
    rdfs:label "Blue River Dam Refusal Surface" ;
    dcterms:description "Structured RefusalReport: TemporalAnomaly, SchemaViolation, CausalDisconnect, MemoryBoundsViolation, HashMismatch, UnknownAuthority, SignatureVerificationFailed, UnsoundPetriNet, FitnessThresholdViolation, ObjectIdentityConflict, AmbiguousBpmnGateway, UnsupportedFeature, DuplicateEventId. All refusals logged to immutable governance ledger." ;
    prov:wasPartOf proj:blue-river-dam .

proj:blue-river-receipts
    a pi:RECEIPT_SURFACE ;
    rdfs:label "Blue River Dam Receipt Surface" ;
    dcterms:description "Receipt emitted on every action execution (success and failure). Receipt {action_id: u64, timestamp: u64, outcome: ActionOutcome}. Decommissioning magic constant: 0xDEC0FFEE. Governance ledger: SHA-256 block-chained entries with authority_signature (Ed25519)." ;
    prov:wasPartOf proj:blue-river-dam .

proj:blue-river-conformance
    a pi:CONFORMANCE_SURFACE ;
    rdfs:label "Blue River Dam Conformance Surface" ;
    dcterms:description "Auditor::compute_fitness (LCS-based alignment). ConformanceMetric {fitness, trace_id, alignment_moves, threshold}. ConformanceViolation: CriticalDeviation (fitness < 0.85, lockdown+escalation), WarningDeviation (0.85 <= fitness < 0.95, elastic repair). Gate 3: admissible(σ) ≡ fitness(σ,N) >= 0.95 ∨ (fitness >= 0.85 ∧ override_signed)." ;
    prov:wasPartOf proj:blue-river-dam .

# ============================================================
# SECTION 11: SHACL — Registry Completeness
# ============================================================

pi:ProjectRegistryShape
    a sh:NodeShape ;
    sh:targetClass prov:Entity ;
    sh:property [
        sh:path pi:hasRole ;
        sh:minCount 1 ;
        sh:message "Every registered project must have at least one program role." ;
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Every registered project must have a label." ;
    ] ;
    sh:property [
        sh:path dcterms:description ;
        sh:minCount 1 ;
        sh:message "Every registered project must have a description." ;
    ] .
