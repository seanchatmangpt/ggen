@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcat:    <http://www.w3.org/ns/dcat#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix schema:  <https://schema.org/> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix pi:      <https://process.intelligence/ontology/> .
@prefix proj:    <https://process.intelligence/project/> .

# ============================================================
# project-registry.ttl — All Projects and Their Program Roles
# Authority: Process Intelligence Research Foundry
# Date: 2026-06-01
# Census Sources: 8 census agents (zoeapp, wasm4pm, wasm4pm-compat,
#   ggen, otel-weaver, claude-workflow, expo-supabase, blue-river-dam)
# ============================================================

<https://process.intelligence/ontology/project-registry>
    a owl:Ontology ;
    owl:imports <https://process.intelligence/ontology/pi-program> ;
    dcterms:title "PI Program Project Registry" ;
    dcterms:description "Registry of all projects, repositories, and system components in the Process Intelligence program, each classified with its program role per the unified census." ;
    dcterms:created "2026-06-01"^^xsd:date ;
    dcterms:creator <https://process.intelligence/agent/research-foundry> ;
    owl:versionInfo "1.0.0" .

# ============================================================
# SECTION 1: THE PROGRAM ITSELF
# ============================================================

proj:process-intelligence
    a prov:Entity, dcat:Dataset ;
    pi:hasRole pi:PROGRAM ;
    rdfs:label "Process Intelligence Research Foundry" ;
    dcterms:description "The governing research foundry at /Users/sac/process-intelligence. Produces evidence, verdicts, doctrine, and downstream authorizations. 570+ commits, 13 gate criteria, ALIVE_001 verdict." ;
    schema:codeRepository <file:///Users/sac/process-intelligence> ;
    dcterms:created "2026-05-31"^^xsd:date ;
    prov:wasGeneratedBy proj:phase-0-doctrine-lock ;
    skos:note "Mission: study, validate, and manufacture the complete doctrine stack required for full-lifecycle process intelligence." .

# ============================================================
# SECTION 2: PROOF CELLS
# ============================================================

proj:zoeapp
    a prov:Entity, dcat:Dataset ;
    pi:hasRole pi:PROOF_CELL ;
    rdfs:label "ZOEapp" ;
    dcterms:description "Expo SDK 56 + React Native 0.85 + Supabase mobile application for Zoe Community Church. Demonstrates full-lifecycle process intelligence: OCEL 2.0 event logs, BLAKE3 receipts, 516 replay fixtures, 268 Jest test suites, RDF inference engine, Schema.org ministry workflows." ;
    schema:codeRepository <file:///Users/sac/zoeapp> ;
    dcterms:subject "Church ministry process intelligence proof cell" ;
    prov:wasAttributedTo <https://process.intelligence/agent/zoeapp-census> ;
    skos:note "ZOEapp is not a standalone product. It is a PROOF_CELL validating process mining, event conformance, and domain governance patterns required for wasm4pm." ;
    pi:hasRole proj:zoeapp-admission-surface ;
    pi:hasRole proj:zoeapp-refusal-surface ;
    pi:hasRole proj:zoeapp-receipt-surface ;
    pi:hasRole proj:zoeapp-replay-surface .

proj:zoeapp-admission-surface
    a pi:ADMISSION_SURFACE ;
    rdfs:label "ZOEapp Admission Surface" ;
    dcterms:description "Route admission gates in ZOEapp: identity boundary checks (anonymous|authenticated|verified|mfa_verified), disclosure verification, and BLAKE3 receipt verification via 3-tier storage fallback (Zustand→MMKV→SQLite)." ;
    skos:example "src/route-law/ProtectedRoute.tsx" .

proj:zoeapp-refusal-surface
    a pi:REFUSAL_SURFACE ;
    rdfs:label "ZOEapp Refusal Surface" ;
    dcterms:description "Named refusal codes from ZOEapp route gating: UNAUTHENTICATED, INSUFFICIENT_BOUNDARY, MISSING_DISCLOSURE, RECEIPT_NOT_FOUND, RECEIPT_HASH_MISMATCH, RECEIPT_VERIFICATION_ERROR." ;
    skos:example "src/route-law/ProtectedRoute.tsx RefusalReason enum" .

proj:zoeapp-receipt-surface
    a pi:RECEIPT_SURFACE ;
    rdfs:label "ZOEapp Receipt Surface" ;
    dcterms:description "BLAKE3-signed cryptographic receipts in ZOEapp. Supabase Edge Functions: truex-verify, truex-min-verify, truex-hook-replay. Tables: actor_receipts. 516 replay fixtures in OCEL 2.0 format with SHA256 batch hashes and BLAKE3 receipt hashes." ;
    skos:example "supabase/functions/truex-verify/, replays/rec_intel_*.json" .

proj:zoeapp-replay-surface
    a pi:REPLAY_SURFACE ;
    rdfs:label "ZOEapp Replay Surface" ;
    dcterms:description "Deterministic replay verification in ZOEapp via truex-hook-replay Edge Function. 516 × rec_intel_*.json replay fixtures with ocel2 batch hashes, SHA256 expected_path_hash, BLAKE3 receipt_hash, batchValid/receiptValid/verified audit verdicts." ;
    skos:example "supabase/functions/truex-hook-replay/, replays/" .

# ============================================================
# SECTION 3: ENGINE
# ============================================================

proj:wasm4pm
    a prov:Entity, dcat:Dataset ;
    pi:hasRole pi:ENGINE ;
    rdfs:label "wasm4pm" ;
    dcterms:description "Pure-Rust WASM execution court. 10,098 source lines. Implements: Inductive Miner, Heuristics Miner, Alpha Miner, DFG mining, token-game replay executor, step simulator, token-replay conformance, OCPQ object-centric queries, BLAKE3/Ed25519/SHA-256/Curve25519 cryptography, zero-copy OCEL 2.0 binary parser, 12-state autonomic lifecycle, gas metering, FFI bridge. Checkpoint: PROCESS_INTELLIGENCE_ALIVE_001." ;
    schema:codeRepository <file:///Users/sac/process-intelligence/sources/wasm4pm> ;
    prov:wasAttributedTo <https://process.intelligence/agent/wasm4pm-engine-census> ;
    dcterms:conformsTo <https://doi.org/10.1109/TKDE.2023.3318844> . # OCEL 2.0

proj:wasm4pm-discovery
    a pi:EXECUTION_COURT ;
    rdfs:label "wasm4pm Discovery Surface" ;
    dcterms:description "Three discovery algorithms: Inductive Miner (Evidence<ProcessTree, Admitted, InductiveWitness>), Heuristics Miner (Evidence<PetriNet, Admitted, HeuristicsWitness>), Alpha Miner (Evidence<PetriNet, Admitted, AlphaWitness>), DFG Mining. All output Evidence<T, Admitted, W> with BLAKE3 sealing." ;
    prov:wasPartOf proj:wasm4pm .

proj:wasm4pm-conformance
    a pi:CONFORMANCE_SURFACE ;
    rdfs:label "wasm4pm Conformance Surface" ;
    dcterms:description "Token replay conformance producing ConformanceVerdict (FullyConforming|PartiallyConforming{fitness,deviations}|NonConforming). ConformanceVerdicts aggregator with aggregate_fitness, aggregate_precision, admission_rate. Fitness = 1.0 - (alignment_cost / (log_length * 2))." ;
    prov:wasPartOf proj:wasm4pm .

proj:wasm4pm-replay
    a pi:REPLAY_SURFACE ;
    rdfs:label "wasm4pm Replay Surface" ;
    dcterms:description "ReplayEngine (full token game, OtelSpan per step, BLAKE3 receipt per step) and StepSimulator (interactive single-step execution). ReplayRefusal enum: EmptyLog, NoValidReplay, ActivityNotEnabled, NoFinalMarking, Deadlock, ChainCapExceeded, TimestampNonMonotonic." ;
    prov:wasPartOf proj:wasm4pm .

proj:wasm4pm-receipts
    a pi:RECEIPT_SURFACE ;
    rdfs:label "wasm4pm Receipt Surface" ;
    dcterms:description "ReplayModuleReceipt::mint(artifact_hash, witness_marker, previous_receipt). OtelTrace with event_chain_root (Blake3 hex). Evidence<T, State, W> with IdentitySignature (Ed25519 32-byte pubkey + 64-byte signature) and Blake3Hash binding." ;
    prov:wasPartOf proj:wasm4pm .

proj:wasm4pm-admission
    a pi:ADMISSION_SURFACE ;
    rdfs:label "wasm4pm Admission Surface" ;
    dcterms:description "Evidence lifecycle admission: Evidence<T, Parsed> → transition_to_validated(public_key) → Evidence<T, ValidatedSound> → transition_to_replayed(next_witness) → Evidence<T, Replayed>. Monotonic witness lattice enforced." ;
    prov:wasPartOf proj:wasm4pm .

proj:wasm4pm-refusals
    a pi:REFUSAL_SURFACE ;
    rdfs:label "wasm4pm Refusal Surface" ;
    dcterms:description "ConformanceRefusal (EmptyLog, EmptyModel, UnsoundNet, UnknownActivity, EarlyTermination, StateSpaceExceeded, MalformedCase, NotImplementedYet). ReplayRefusal (EmptyLog, NoValidReplay, ActivityNotEnabled, NoFinalMarking, Deadlock, ChainCapExceeded, TimestampNonMonotonic). OcelError (InvalidMagic, InvalidVersion, OutOfBounds, Utf8Error, NullPointer)." ;
    prov:wasPartOf proj:wasm4pm .

# ============================================================
# SECTION 4: COMPATIBILITY LAYER
# ============================================================

proj:wasm4pm-compat
    a prov:Entity, dcat:Dataset ;
    pi:hasRole pi:COMPATIBILITY_LAYER ;
    rdfs:label "wasm4pm-compat" ;
    dcterms:description "Nightly-only, paper-complete, structure-only Rust process-evidence standard. Enforces one-way lifecycle (Raw→Parsed→Admitted→{Projected|Exportable|Receipted}) via typestate. 46 compile-pass/fail fixtures. PAPERLAW_ALIVE verdict. Zero execution engine logic. 5 Cargo features (3 documented + 2 undocumented: ts, wasm)." ;
    schema:codeRepository <file:///Users/sac/wasm4pm-compat> ;
    prov:wasAttributedTo <https://process.intelligence/agent/wasm4pm-compat-census> .

proj:compat-admission
    a pi:ADMISSION_SURFACE ;
    rdfs:label "wasm4pm-compat Admission Surface" ;
    dcterms:description "Admit trait: Evidence<T, Raw, W> → Result<Admission<T, W>, Refusal<R, W>>. Every impl Admit must return a specific Reason type with named law variants. No bare InvalidInput. Compile-time enforcement via typestate." ;
    prov:wasPartOf proj:wasm4pm-compat .

proj:compat-refusals
    a pi:REFUSAL_SURFACE ;
    rdfs:label "wasm4pm-compat Refusal Surface" ;
    dcterms:description "Named refusal laws: DanglingEventObjectLink, MissingFinalMarking, UnsoundWfNet, FlatteningLoss, InvalidPowlProjection, UnreplayableClaim, MissingWitness. StrictViolation: MissingWitness, MissingRoundTripFixture, MissingLossPolicy, RawEvidenceExported, MissingRefusalPath, MissingConformanceFields, MissingReceiptShape, HiddenProcessMiningGrowth." ;
    prov:wasPartOf proj:wasm4pm-compat .

proj:compat-graduation
    a pi:GRADUATION_SIGNAL ;
    rdfs:label "wasm4pm-compat Graduation Bridge" ;
    dcterms:description "GraduateToWasm4pm trait. GraduationReason: NeedsDiscovery, NeedsConformanceExecution, NeedsReplay, NeedsObjectCentricQueryExecution, RebuildingProcessMiningLocally. Available only with wasm4pm Cargo feature." ;
    prov:wasPartOf proj:wasm4pm-compat .

proj:compat-forbidden-collapse
    a pi:FORBIDDEN_COLLAPSE ;
    rdfs:label "wasm4pm-compat DTO Boundary Risk" ;
    dcterms:description "WASM boundary DTOs serialize string fields without enumeration or bounds: WasmStateTag::name:String, WasmAdmissionResult::refusal_law:Option<String>, WasmGraduationCandidate::evidence_ref:String, WasmLossReport::items_dropped:Vec<String>, WasmWitness::key:String. Validation deferred to wasm4pm engine. Audit 1 FAIL in GGEN census: to_json_string() and receipt_json() in manufacturing module." ;
    prov:wasPartOf proj:wasm4pm-compat .

