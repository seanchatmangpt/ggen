# Vocabulary Classes
pi:Source a owl:Class ;
    rdfs:label "Source" ;
    skos:definition "A file (TTL, RQ, or Tera) in the ggen ecosystem" ;
    .

pi:Ontology a owl:Class ;
    rdfs:label "Ontology" ;
    skos:definition "TTL RDF/OWL ontology file" ;
    rdfs:subClassOf pi:Source ;
    .

pi:Query a owl:Class ;
    rdfs:label "Query" ;
    skos:definition "SPARQL RQ query file" ;
    rdfs:subClassOf pi:Source ;
    .

pi:QuerySet a owl:Class ;
    rdfs:label "Query Set" ;
    skos:definition "Grouped collection of SPARQL queries with common purpose" ;
    .

pi:Template a owl:Class ;
    rdfs:label "Template" ;
    skos:definition "Tera template file for code/document generation" ;
    rdfs:subClassOf pi:Source ;
    .

pi:SourceStatistics a owl:Class ;
    rdfs:label "Source Statistics" ;
    skos:definition "Aggregate counts and metrics for source inventory" ;
    .

# Vocabulary Properties
pi:sourceType a owl:DatatypeProperty ;
    rdfs:label "source type" ;
    rdfs:range xsd:string ;
    skos:definition "File type: ttl, rq, or tera" ;
    .

pi:projectId a owl:DatatypeProperty ;
    rdfs:label "project ID" ;
    rdfs:range xsd:string ;
    skos:definition "ggen project name or identifier" ;
    .

pi:fileSize a owl:DatatypeProperty ;
    rdfs:label "file size" ;
    rdfs:range xsd:string ;
    .

pi:parseStatus a owl:DatatypeProperty ;
    rdfs:label "parse status" ;
    rdfs:range xsd:string ;
    skos:definition "VALID, SUSPICIOUS, or ERROR" ;
    .

pi:referenced a owl:DatatypeProperty ;
    rdfs:label "referenced" ;
    rdfs:range xsd:string ;
    skos:definition "YES or NO: whether this source is used in active generation rules" ;
    .

pi:role a owl:DatatypeProperty ;
    rdfs:label "role" ;
    rdfs:range xsd:string ;
    skos:definition "Functional description of source purpose" ;
    .

pi:queryType a owl:DatatypeProperty ;
    rdfs:label "query type" ;
    rdfs:range xsd:string ;
    skos:definition "Extraction, Selection, Audit, or other SPARQL category" ;
    .

pi:purpose a owl:DatatypeProperty ;
    rdfs:label "purpose" ;
    rdfs:range xsd:string ;
    skos:definition "Intended use of this source file" ;
    .

pi:templateRole a owl:DatatypeProperty ;
    rdfs:label "template role" ;
    rdfs:range xsd:string ;
    skos:definition "Code Generation or Document Generation" ;
    .

pi:queryCount a owl:DatatypeProperty ;
    rdfs:label "query count" ;
    rdfs:range xsd:integer ;
    skos:definition "Number of queries in a QuerySet" ;
    .

pi:queries a owl:DatatypeProperty ;
    rdfs:label "queries" ;
    rdfs:range xsd:string ;
    skos:definition "Comma-separated list of query file names" ;
    .

pi:totalSources a owl:DatatypeProperty ;
    rdfs:label "total sources" ;
    rdfs:range xsd:integer ;
    .

pi:ttlFiles a owl:DatatypeProperty ;
    rdfs:label "TTL files" ;
    rdfs:range xsd:integer ;
    .

pi:rqFiles a owl:DatatypeProperty ;
    rdfs:label "RQ files" ;
    rdfs:range xsd:integer ;
    .

pi:teraFiles a owl:DatatypeProperty ;
    rdfs:label "Tera files" ;
    rdfs:range xsd:integer ;
    .

pi:parseStatusValid a owl:DatatypeProperty ;
    rdfs:label "parse status valid" ;
    rdfs:range xsd:integer ;
    .

pi:parseStatusSuspicious a owl:DatatypeProperty ;
    rdfs:label "parse status suspicious" ;
    rdfs:range xsd:integer ;
    .

pi:parseStatusError a owl:DatatypeProperty ;
    rdfs:label "parse status error" ;
    rdfs:range xsd:integer ;
    .

pi:referencedByGeneration a owl:DatatypeProperty ;
    rdfs:label "referenced by generation" ;
    rdfs:range xsd:integer ;
    .

pi:unreferencedByGeneration a owl:DatatypeProperty ;
    rdfs:label "unreferenced by generation" ;
    rdfs:range xsd:integer ;
    .

pi:referencedPercentage a owl:DatatypeProperty ;
    rdfs:label "referenced percentage" ;
    rdfs:range xsd:string ;
    .

pi:unreferencedPercentage a owl:DatatypeProperty ;
    rdfs:label "unreferenced percentage" ;
    rdfs:range xsd:string ;
    .
