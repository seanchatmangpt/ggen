# Summary Statistics
gen:SUMMARY a owl:NamedIndividual, pi:GenerationStatistics ;
    dcterms:title "Generation Rule Census Summary" ;
    pi:tomlFiles 3 ;
    pi:programs 3 ;
    pi:totalRules 15 ;
