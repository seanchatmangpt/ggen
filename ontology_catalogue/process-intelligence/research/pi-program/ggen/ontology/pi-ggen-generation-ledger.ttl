    pi:functionalRulesPercentage "13.3%" ;
    .

# Vocabulary Classes
pi:GenerationProgram a owl:Class ;
    rdfs:label "Generation Program" ;
    skos:definition "A ggen.toml program definition with generation rules and configuration" ;
    .

pi:GenerationRule a owl:Class ;
    rdfs:label "Generation Rule" ;
    skos:definition "Individual code/document generation rule within a generation program" ;
    .

pi:QuerySet a owl:Class ;
    rdfs:label "Query Set" ;
    skos:definition "Grouped collection of SPARQL queries for research or generation" ;
    .

pi:GenerationStatistics a owl:Class ;
    rdfs:label "Generation Statistics" ;
    skos:definition "Aggregate metrics across all generation programs" ;
    .

# Vocabulary Properties
pi:program a owl:ObjectProperty ;
    rdfs:label "program" ;
    skos:definition "The generation program containing this rule" ;
    .

pi:handCoding a owl:DatatypeProperty ;
    rdfs:label "hand coding" ;
    rdfs:range xsd:boolean ;
    .

pi:evidenceSources a owl:DatatypeProperty ;
    rdfs:label "evidence sources" ;
    rdfs:range xsd:string ;
    skos:definition "Paths to receipt/checkpoint directories containing evidence" ;
    .

pi:ruleCount a owl:DatatypeProperty ;
    rdfs:label "rule count" ;
    rdfs:range xsd:integer ;
    .

pi:activeRules a owl:DatatypeProperty ;
    rdfs:label "active rules" ;
    rdfs:range xsd:integer ;
    .

pi:inactiveRules a owl:DatatypeProperty ;
    rdfs:label "inactive rules" ;
    rdfs:range xsd:integer ;
    .

pi:blockedRules a owl:DatatypeProperty ;
    rdfs:label "blocked rules" ;
    rdfs:range xsd:integer ;
    .

pi:mode a owl:DatatypeProperty ;
    rdfs:label "mode" ;
    rdfs:range xsd:string ;
    .

pi:queryCount a owl:DatatypeProperty ;
    rdfs:label "query count" ;
    rdfs:range xsd:integer ;
    .

pi:auditQueries a owl:DatatypeProperty ;
    rdfs:label "audit queries" ;
    rdfs:range xsd:integer ;
    .

pi:selectionQueries a owl:DatatypeProperty ;
    rdfs:label "selection queries" ;
    rdfs:range xsd:integer ;
    .

pi:ontology a owl:DatatypeProperty ;
    rdfs:label "ontology" ;
    rdfs:range xsd:string ;
    skos:definition "Input TTL ontology file path" ;
    .

pi:query a owl:DatatypeProperty ;
    rdfs:label "query" ;
    rdfs:range xsd:string ;
    skos:definition "Input SPARQL query file path" ;
    .

pi:template a owl:DatatypeProperty ;
    rdfs:label "template" ;
    rdfs:range xsd:string ;
    skos:definition "Tera template file path for rendering" ;
    .

pi:outputFile a owl:DatatypeProperty ;
    rdfs:label "output file" ;
    rdfs:range xsd:string ;
    skos:definition "Destination file path for generated artifact" ;
    .

pi:outputMode a owl:DatatypeProperty ;
    rdfs:label "output mode" ;
    rdfs:range xsd:string ;
    skos:definition "Write mode: Overwrite, Append, or Merge" ;
    .

pi:targetFormat a owl:DatatypeProperty ;
    rdfs:label "target format" ;
    rdfs:range xsd:string ;
    skos:definition "Language or format of output: Rust, TypeScript, Python, etc." ;
    .

pi:audience a owl:DatatypeProperty ;
    rdfs:label "audience" ;
    rdfs:range xsd:string ;
    skos:definition "Intended consumer of the generated artifact" ;
    .

pi:compliance a owl:DatatypeProperty ;
    rdfs:label "compliance" ;
    rdfs:range xsd:string ;
    skos:definition "Specification or standard this rule generates from" ;
    .

pi:evidence a owl:DatatypeProperty ;
    rdfs:label "evidence" ;
    rdfs:range xsd:string ;
    skos:definition "Source evidence backing this generation rule" ;
    .

pi:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:range xsd:string ;
    skos:definition "READY, DEACTIVATED, BLOCKED, or AVAILABLE" ;
    .

pi:note a owl:DatatypeProperty ;
    rdfs:label "note" ;
    rdfs:range xsd:string ;
    skos:definition "Additional context or status notes" ;
    .

pi:blockingIssue a owl:DatatypeProperty ;
    rdfs:label "blocking issue" ;
    rdfs:range xsd:string ;
    skos:definition "Describes why this rule is blocked" ;
    .

pi:queries a owl:DatatypeProperty ;
    rdfs:label "queries" ;
    rdfs:range xsd:string ;
    skos:definition "Comma-separated list of query names in this set" ;
    .

pi:blockedRuleNote a owl:DatatypeProperty ;
    rdfs:label "blocked rule note" ;
    rdfs:range xsd:string ;
    .

pi:totalQueries a owl:DatatypeProperty ;
    rdfs:label "total queries" ;
    rdfs:range xsd:integer ;
    .

pi:generationQueries a owl:DatatypeProperty ;
    rdfs:label "generation queries" ;
    rdfs:range xsd:integer ;
    .

pi:functionalGenerationRules a owl:DatatypeProperty ;
    rdfs:label "functional generation rules" ;
    rdfs:range xsd:integer ;
    .

pi:functionalProgramsPercentage a owl:DatatypeProperty ;
    rdfs:label "functional programs percentage" ;
    rdfs:range xsd:string ;
    .

pi:functionalRulesPercentage a owl:DatatypeProperty ;
    rdfs:label "functional rules percentage" ;
    rdfs:range xsd:string ;
    .
