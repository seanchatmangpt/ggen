@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .
@prefix pi:     <https://process.intelligence/ontology/> .
@prefix gen:    <https://process.intelligence/generation-rule/> .

# Generation Ledger — All Generation Rules from 3 ggen.toml Files
# Date: 2026-06-01
# Authority: PI Research Program — ggen-manifest-census.md

# File 1: process-intelligence-ggen (ggen/ggen.toml)
gen:PROJECT_001 a owl:NamedIndividual, pi:GenerationProgram ;
    dcterms:title "process-intelligence-ggen" ;
    dcterms:description "Generate board-admissible M&A assets and autonomic governance engines from process intelligence" ;
    pi:version "0.1.0" ;
    pi:handCoding "false" ;
    pi:evidenceSources "../receipts, ../checkpoints" ;
    pi:ruleCount 2 ;
    pi:activeRules 2 ;
    pi:inactiveRules 2 ;
    .

gen:RULE_001 a owl:NamedIndividual, pi:GenerationRule ;
    dcterms:title "blue-river-orchestrator" ;
    dcterms:description "Autonomic MAPE-K governance engine with lifecycle state transitions" ;
    pi:program gen:PROJECT_001 ;
    pi:ontology "ontology-extensions.ttl" ;
    pi:query "queries/extract-lifecycle-governance.rq" ;
    pi:template "templates/blue-river.tera" ;
    pi:outputFile "../blue_river_dam/src/lib.rs" ;
    pi:outputMode "Overwrite" ;
    pi:targetFormat "Rust" ;
    pi:audience "Process Intelligence Runtime" ;
    pi:compliance "MAPE-K autonomic loop" ;
    pi:evidence "lifecycle state machine + governance rule enforcement" ;
    pi:status "READY" ;
    .

gen:RULE_002 a owl:NamedIndividual, pi:GenerationRule ;
    dcterms:title "visualizer-dashboard-nextjs" ;
    dcterms:description "Generate NextJS visualizer dashboard pages with conformance-backed claims" ;
    pi:program gen:PROJECT_001 ;
    pi:query "queries/extract-visualizer-data.rq" ;
    pi:template "templates/visualizer-dashboard.tsx.tera" ;
    pi:outputFile "../experiments/visualizer-nextjs/src/app/page.tsx" ;
    pi:outputMode "Overwrite" ;
    pi:status "READY" ;
    .

gen:RULE_003_INACTIVE a owl:NamedIndividual, pi:GenerationRule ;
    dcterms:title "ma-deck" ;
    dcterms:description "M&A pitch deck generation from board claims" ;
    pi:program gen:PROJECT_001 ;
    pi:query "queries/extract-board-claims.rq" ;
    pi:template "templates/ma-deck.tera" ;
    pi:status "DEACTIVATED" ;
    pi:note "Template artifact exists but generation rule is disabled (commented in ggen.toml)" ;
    .

gen:RULE_004_INACTIVE a owl:NamedIndividual, pi:GenerationRule ;
    dcterms:title "ma-diligence" ;
    dcterms:description "M&A diligence workbook generation from operational debt claims" ;
    pi:program gen:PROJECT_001 ;
    pi:query "queries/extract-diligence-claims.rq" ;
    pi:template "templates/ma-diligence.tera" ;
    pi:status "DEACTIVATED" ;
    pi:note "Template artifact exists but generation rule is disabled (commented in ggen.toml)" ;
    .

# File 2: PI_RESEARCH_PROGRAM_INTEL_001 (research/pi-program/ggen/ggen.toml)
gen:PROJECT_002 a owl:NamedIndividual, pi:GenerationProgram ;
    dcterms:title "PI_RESEARCH_PROGRAM_INTEL_001" ;
    dcterms:description "Research program reconciliation analyzer with audit and selection query subsystems" ;
    pi:version "unversioned" ;
    pi:mode "research_program_reconciliation" ;
    pi:ruleCount 0 ;
    pi:queryCount 32 ;
    pi:auditQueries 17 ;
    pi:selectionQueries 15 ;
    pi:activeGenerationRules "NONE (query-only, no generation rules)" ;
    pi:note "Research mode: queries available for programmatic analysis; no code generation configured" ;
    .

gen:QUERY_SET_AUDIT a owl:NamedIndividual, pi:QuerySet ;
    dcterms:title "Audit Query Set (PI_RESEARCH_PROGRAM_INTEL_001)" ;
    dcterms:description "17 audit queries validating research program integrity constraints" ;
    pi:program gen:PROJECT_002 ;
    pi:queryCount 17 ;
    pi:queries "audit-checkpoint-has-receipts", "audit-closure-invariant", "audit-commitment-integrity", "audit-compliance-ledger", "audit-evidence-traceability", "audit-gates-complete", "audit-no-client-only-auth", "audit-no-dashboard-truth", "audit-no-dto-flattening", "audit-no-forced-alive", "audit-no-invalid-ggen-extension", "audit-no-realtime-as-evidence", "audit-no-telemetry-as-receipt", "audit-no-tool-smuggling", "audit-no-unsigned-verdicts", "audit-partial-has-gaps", "audit-source-court-citations" ;
    pi:status "AVAILABLE (not in generation rules)" ;
    .

gen:QUERY_SET_SELECTION a owl:NamedIndividual, pi:QuerySet ;
    dcterms:title "Selection Query Set (PI_RESEARCH_PROGRAM_INTEL_001)" ;
    dcterms:description "15 selection queries for filtering and enumeration across all PI artifacts" ;
    pi:program gen:PROJECT_002 ;
    pi:queryCount 15 ;
    pi:queries "select-alive-claims", "select-all-projects", "select-checkpoints", "select-compatibility-surfaces", "select-engine-surfaces", "select-failed-gates", "select-forbidden-collapses", "select-manufacturing-surfaces", "select-mobile-substrate-surfaces", "select-next-workflows", "select-partial-claims", "select-proof-cells", "select-remediation-candidates", "select-telemetry-feedstock-surfaces", "select-workflow-substrate-surfaces" ;
    pi:status "AVAILABLE (not in generation rules)" ;
    .

