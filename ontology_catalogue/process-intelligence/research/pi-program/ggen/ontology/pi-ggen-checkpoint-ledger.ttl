# Vocabulary Classes
pi:CheckpointLedger a owl:Class ;
    rdfs:label "Checkpoint Ledger" ;
    skos:definition "Master registry of all checkpoint verdicts and their status" ;
    .

pi:Checkpoint a owl:Class ;
    rdfs:label "Checkpoint" ;
    skos:definition "Immutable verdict record at a milestone in research program execution" ;
    .

pi:ALIVEVerdictCheckpoint a owl:Class ;
    rdfs:label "ALIVE Verdict Checkpoint" ;
    skos:definition "Sealed checkpoint declaring ALIVE operational status with all gates passing" ;
    rdfs:subClassOf pi:Checkpoint ;
    .

pi:PARTIALVerdictCheckpoint a owl:Class ;
    rdfs:label "PARTIAL Verdict Checkpoint" ;
    skos:definition "Open checkpoint with identified gaps blocking full operational status" ;
    rdfs:subClassOf pi:Checkpoint ;
    .

# Vocabulary Properties
pi:status a owl:DatatypeProperty ;
    rdfs:label "status" ;
    rdfs:range xsd:string ;
    skos:definition "SEALED, OPEN, FAILED, or other verdict status" ;
    .

pi:authority a owl:DatatypeProperty ;
    rdfs:label "authority" ;
    rdfs:range xsd:string ;
    skos:definition "Authority or court issuing this checkpoint" ;
    .

pi:verificationCode a owl:DatatypeProperty ;
    rdfs:label "verification code" ;
    rdfs:range xsd:string ;
    skos:definition "Cryptographic or symbolic verification code" ;
    .

pi:committedHash a owl:DatatypeProperty ;
    rdfs:label "committed hash" ;
    rdfs:range xsd:string ;
    skos:definition "Git commit hash when checkpoint was sealed" ;
    .

pi:gateCriteria a owl:DatatypeProperty ;
    rdfs:label "gate criteria" ;
    rdfs:range xsd:integer ;
    skos:definition "Total number of proof gates for this checkpoint" ;
    .

pi:gatesCriteriaMet a owl:DatatypeProperty ;
    rdfs:label "gates criteria met" ;
    rdfs:range xsd:integer ;
    skos:definition "Number of proof gates that passed" ;
    .

pi:gatesDescription a owl:DatatypeProperty ;
    rdfs:label "gates description" ;
    rdfs:range xsd:string ;
    skos:definition "Human-readable description of gate categories and criteria" ;
    .

pi:downstreamAuthorization a owl:DatatypeProperty ;
    rdfs:label "downstream authorization" ;
    rdfs:range xsd:string ;
    skos:definition "Project, process, or capability authorized by this checkpoint" ;
    .

pi:failedGates a owl:DatatypeProperty ;
    rdfs:label "failed gates" ;
    rdfs:range xsd:integer ;
    skos:definition "Number of proof gates that failed" ;
    .

pi:unresolvedPartials a owl:DatatypeProperty ;
    rdfs:label "unresolved partials" ;
    rdfs:range xsd:string ;
    skos:definition "Gap IDs or open items blocking full operational status" ;
    .

pi:riskAssessment a owl:DatatypeProperty ;
    rdfs:label "risk assessment" ;
    rdfs:range xsd:string ;
    skos:definition "Safety and integrity analysis of this checkpoint verdict" ;
    .

pi:receiptReference a owl:DatatypeProperty ;
