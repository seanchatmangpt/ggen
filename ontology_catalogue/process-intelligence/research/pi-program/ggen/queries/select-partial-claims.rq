PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX pi: <https://process.intelligence/ontology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dcterms: <http://purl.org/dc/terms/>

# SELECT all PARTIAL_CLAIM checkpoints with blocking gaps
SELECT ?partialClaim ?label ?gatesMet ?blockingGap
WHERE {
  ?partialClaim a pi:PARTIAL_CLAIM ;
                rdfs:label ?label ;
                pi:gatesCriteriaMet ?gatesMet ;
                pi:blockingGap ?blockingGap .
}
ORDER BY ?partialClaim
