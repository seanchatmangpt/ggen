PREFIX pi: <https://process.intelligence/ontology/>
PREFIX gen: <https://process.intelligence/generation-rule/>
PREFIX dcterms: <http://purl.org/dc/terms/>

# SELECT: All Query Surfaces (36 RQ files)
# Returns all SPARQL query sources with classification, status, and purpose
# Date: 2026-06-01

SELECT ?query ?title ?sourceType ?projectId ?queryType ?role ?referenced
WHERE {
    ?query a pi:Query .
    ?query dcterms:title ?title .
    ?query pi:sourceType ?sourceType .
    ?query pi:projectId ?projectId .

    OPTIONAL { ?query pi:queryType ?queryType }
    OPTIONAL { ?query pi:role ?role }
    OPTIONAL { ?query pi:referenced ?referenced }
}
ORDER BY ?projectId ?title
