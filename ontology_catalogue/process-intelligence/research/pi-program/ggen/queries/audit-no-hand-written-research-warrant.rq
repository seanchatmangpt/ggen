PREFIX pi: <https://process.intelligence/ontology/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX dcterms: <http://purl.org/dc/terms/>

# AUDIT: No Hand-Written Research Warrant
# ASK query: Verifies all research warrants have derivedFrom provenance
# Passes if: Every research warrant in doctrine/ has prov:derivedFrom pointing to source
# Date: 2026-06-01

ASK {
    FILTER NOT EXISTS {
        ?warrant a pi:ResearchWarrant .
        FILTER NOT EXISTS { ?warrant prov:derivedFrom ?source }
    }
}
