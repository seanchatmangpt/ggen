PREFIX pi: <https://process.intelligence/ontology/>
PREFIX ggen: <https://codegen.org/ggen/>
PREFIX prov: <http://www.w3.org/ns/prov#>

# AUDIT: Validator Passes Valid Tera
# ASK query: Verifies validator template accepts syntactically valid Tera templates
# Passes if: At least one test case with valid Tera syntax passes validation
# Date: 2026-06-01

ASK {
    ?testCase a ggen:ValidatorTestCase .
    ?testCase ggen:templateInput ?template .
    ?testCase ggen:validTeraTemplate true .
    ?testCase ggen:validationResult "PASS" .
}
