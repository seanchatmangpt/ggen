PREFIX pi: <https://process.intelligence/ontology/>
PREFIX gen: <https://process.intelligence/generation-rule/>
PREFIX dcterms: <http://purl.org/dc/terms/>

# AUDIT: Every Generation Rule Has Query, Template, and Output
# ASK query: Verifies READY rules are complete with all required inputs and outputs
# Passes if: All READY rules declare query, template, and outputFile properties
# Date: 2026-06-01

ASK {
    FILTER NOT EXISTS {
        ?rule a pi:GenerationRule .
        ?rule pi:status "READY" .
        (
            FILTER NOT EXISTS { ?rule pi:query ?q }
            OR
            FILTER NOT EXISTS { ?rule pi:template ?t }
            OR
            FILTER NOT EXISTS { ?rule pi:outputFile ?o }
        )
    }
}
