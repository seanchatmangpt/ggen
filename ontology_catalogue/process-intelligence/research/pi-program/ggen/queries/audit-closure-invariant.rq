PREFIX pi: <https://process.intelligence/ontology/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# AUDIT: Verify MAPE-K loop closure — Monitor, Analyze, Plan, Execute must all be present
# Blue River Dam ORCHESTRATOR should have all 5 authority components (Governor, Architect, Operator, Auditor, Doctor)
SELECT ?orchestrator ?label ?description
WHERE {
  ?orchestrator a pi:AUTHORIZATION_COURT ;
                pi:hasRole pi:EXECUTION_COURT ;
                rdfs:label ?label ;
                rdfs:comment ?description .
  FILTER (REGEX(?label, "Blue River|Orchestrator", "i"))
}
