PREFIX pi: <https://process.intelligence/ontology/>
PREFIX chk: <https://process.intelligence/checkpoint/>
PREFIX dcterms: <http://purl.org/dc/terms/>

# AUDIT: No Forced ALIVE Verdicts
# ASK query: Verifies all ALIVE checkpoints have documented gate pass counts
# Passes if: All ALIVE checkpoints explicitly report gates met with zero arbitration
# Date: 2026-06-01

ASK {
    FILTER NOT EXISTS {
        ?checkpoint a pi:ALIVEVerdictCheckpoint .
        FILTER NOT EXISTS { ?checkpoint pi:gatesCriteriaMet ?metCount }
    }
}
