PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX pi: <https://process.intelligence/ontology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dcterms: <http://purl.org/dc/terms/>

# AUDIT: SELECT all FORBIDDEN_COLLAPSE violations
SELECT ?forbiddenCollapse ?label ?description
WHERE {
  ?forbiddenCollapse a pi:FORBIDDEN_COLLAPSE ;
                     rdfs:label ?label ;
                     dcterms:description ?description .
}
ORDER BY ?forbiddenCollapse
