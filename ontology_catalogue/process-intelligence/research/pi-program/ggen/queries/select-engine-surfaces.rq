PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX pi: <https://process.intelligence/ontology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dcterms: <http://purl.org/dc/terms/>

# SELECT all ENGINE surfaces (execution courts)
SELECT ?surface ?label ?description ?surfaceType
WHERE {
  ?surface a prov:Entity ;
           rdfs:label ?label ;
           dcterms:description ?description ;
           rdf:type ?surfaceType .
  FILTER (?surfaceType IN (pi:EXECUTION_COURT, pi:DISCOVERY_SURFACE, pi:CONFORMANCE_SURFACE, pi:REPLAY_SURFACE, pi:RECEIPT_SURFACE))
}
ORDER BY ?surface
