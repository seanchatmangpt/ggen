PREFIX pi: <https://process.intelligence/ontology/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dcterms: <http://purl.org/dc/terms/>

# AUDIT: Count papers, standards, and capability atlases registered in SOURCE_COURT
# Verifies foundational source authority density
SELECT (COUNT(DISTINCT ?source) AS ?sourceCount)
WHERE {
  ?source a prov:Entity ;
          pi:hasRole pi:SOURCE_COURT .
}
