PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX pi: <https://process.intelligence/ontology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX proj: <https://process.intelligence/project/>

# SELECT all registered projects and their program roles
SELECT ?project ?label ?description ?role
WHERE {
  ?project a prov:Entity ;
           pi:hasRole ?role ;
           rdfs:label ?label ;
           dcterms:description ?description .
}
ORDER BY ?project
