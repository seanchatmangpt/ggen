PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX pi: <https://process.intelligence/ontology/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dcterms: <http://purl.org/dc/terms/>

# SELECT all COMPATIBILITY_LAYER surfaces
SELECT ?compat ?label ?description ?surface
WHERE {
  ?compat a prov:Entity ;
          pi:hasRole pi:COMPATIBILITY_LAYER ;
          rdfs:label ?label ;
          dcterms:description ?description .
  OPTIONAL {
    ?compat pi:hasRole ?surface .
    FILTER (?surface IN (pi:ADMISSION_SURFACE, pi:REFUSAL_SURFACE, pi:GRADUATION_SIGNAL))
  }
}
ORDER BY ?compat
