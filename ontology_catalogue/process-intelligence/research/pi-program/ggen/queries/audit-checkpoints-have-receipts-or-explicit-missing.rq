PREFIX pi: <https://process.intelligence/ontology/>
PREFIX chk: <https://process.intelligence/checkpoint/>
PREFIX dcterms: <http://purl.org/dc/terms/>

# AUDIT: Checkpoints Have Receipts or Explicit Missing Declaration
# ASK query: Verifies every checkpoint either references a receipt or documents missing receipt
# Passes if: All checkpoints declare receiptReference OR explicitly note receipt unavailable
# Date: 2026-06-01

ASK {
    FILTER NOT EXISTS {
        ?checkpoint a pi:Checkpoint .
        ?checkpoint pi:status "SEALED" .
        (
            FILTER NOT EXISTS { ?checkpoint pi:receiptReference ?ref }
            AND
            FILTER NOT EXISTS { ?checkpoint pi:blake3Seal ?seal }
        )
    }
}
