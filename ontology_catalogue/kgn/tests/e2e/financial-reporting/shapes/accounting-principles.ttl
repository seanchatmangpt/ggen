@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix fin: <https://kgen.dev/ontologies/finance#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# SHACL shapes for validating accounting principles

fin:JournalEntryShape a sh:NodeShape ;
    sh:targetClass fin:JournalEntry ;
    sh:property [
        sh:path fin:hasDate ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fin:hasAccount ;
        sh:class fin:Account ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fin:hasDescription ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path fin:hasDebit ;
        sh:datatype xsd:decimal ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:minInclusive 0 ;
    ] ;
    sh:property [
        sh:path fin:hasCredit ;
        sh:datatype xsd:decimal ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:minInclusive 0 ;
    ] .