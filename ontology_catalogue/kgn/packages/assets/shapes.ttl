@prefix ex: <https://kgen.dev/example#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# SHACL shapes for data validation
ex:FinancialRecordShape rdf:type sh:NodeShape ;
    sh:targetClass ex:FinancialRecord ;
    sh:property [
        sh:path ex:hasRevenue ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0
    ] ;
    sh:property [
        sh:path ex:hasExpenses ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0
    ] ;
    sh:property [
        sh:path ex:hasProfit ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path ex:belongsTo ;
        sh:class ex:Organization ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .

ex:OrganizationShape rdf:type sh:NodeShape ;
    sh:targetClass ex:Organization ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .