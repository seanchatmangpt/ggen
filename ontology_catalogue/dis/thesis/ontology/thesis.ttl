    rdfs:label "Chapter" ;
    rdfs:comment "A chapter in the thesis" .

:Section a rdfs:Class ;
    rdfs:label "Section" ;
    rdfs:comment "A section within a chapter" .

:CaseStudy a rdfs:Class ;
    rdfs:label "Case Study" ;
    rdfs:comment "A case study demonstrating the methodology" .

:Concept a rdfs:Class ;
    rdfs:label "Concept" ;
    rdfs:comment "A key theoretical concept" .

:Theorem a rdfs:Class ;
    rdfs:label "Theorem" ;
    rdfs:comment "A formal theorem" .

:Equation a rdfs:Class ;
    rdfs:label "Equation" ;
    rdfs:comment "A mathematical equation" .

