# =============================================================================
# KEY CONCEPTS
# =============================================================================

:ZeroDrift a :Concept ;
    rdfs:label "Zero Drift" ;
    :definition "d(t) = ||Code(t) - gen(O(t),T)|| = 0 for all t" ;
    :explanation "Code is always regenerated from ontology, eliminating specification-implementation divergence" .

:SingleSourceOfTruth a :Concept ;
    rdfs:label "Single Source of Truth" ;
    :definition "The ontology O is the canonical representation; all artifacts derive from O" ;
    :explanation "Eliminates redundant specifications, ensures consistency" .

:DeterministicGeneration a :Concept ;
    rdfs:label "Deterministic Generation" ;
    :definition "gen: O x T to C is a pure function" ;
    :explanation "Same ontology plus template always produces same code" .

:BigBang8020 a :Concept ;
    rdfs:label "Big Bang 80/20" ;
    :definition "20 percent of features equals 80 percent of value, implemented in ONE pass" ;
    :explanation "Single-pass feature implementation using Pareto optimization" .

:PokayYoke a :Concept ;
    rdfs:label "Poka-Yoke" ;
    :definition "Error-proofing through structural prevention" ;
    :explanation "Impossible states are structurally prevented, not just UI-disabled" .

# =============================================================================
# THEOREMS
# =============================================================================

:DeterminismTheorem a :Theorem ;
    rdfs:label "Determinism Theorem" ;
    :statement "For all o1, o2 in O, o1 = o2 implies gen(o1,T) = gen(o2,T)" ;
    :proof "gen is composed of pure functions: parse, query, render. Each is deterministic." .

:ZeroDriftTheorem a :Theorem ;
    rdfs:label "Zero Drift Theorem" ;
    :statement "If Code = gen(O,T) always, then d(t) = 0 for all t" ;
    :proof "By definition, Code(t) = gen(O(t),T), so ||Code(t) - gen(O(t),T)|| = 0." .

:CompletenessTheorem a :Theorem ;
    rdfs:label "Completeness Theorem" ;
    :statement "If O is a complete domain model, then gen(O,T) is a complete implementation" ;
    :proof "Templates T are total functions over query results. Completeness of O ensures all cases covered." .

# =============================================================================
# EQUATIONS
# =============================================================================

:InformationEntropy a :Equation ;
    rdfs:label "Information Entropy" ;
    :latex "H(X) = -\\sum_{x} p(x) \\log_2 p(x)" ;
    :description "Shannon entropy measuring information content" .

:ConditionedCodeEntropy a :Equation ;
    rdfs:label "Conditioned Code Entropy" ;
    :latex "H(Code|Ontology) \\leq 0.2 \\times H(Ontology)" ;
    :description "80/20 principle: code entropy is bounded by 20 percent of ontology entropy" .

:DriftMetric a :Equation ;
    rdfs:label "Drift Metric" ;
    :latex "d(t) = ||Code(t) - gen(O(t), T)||" ;
    :description "Measures divergence between actual code and generated code" .

:GenerationFunction a :Equation ;
    rdfs:label "Generation Function" ;
    :latex "gen: O \\times T \\rightarrow C" ;
    :description "Pure function from ontology and template to code" .
