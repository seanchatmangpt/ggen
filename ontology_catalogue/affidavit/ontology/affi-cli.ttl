# ============================================================================
# BENCH NOUN — surface `affi bench <verb>`.
# ============================================================================

affi:BenchNoun a cnv:Noun ;
    cnv:hasNounName "bench" ;
    cnv:nounAbout "Throughput, variance, and profiling benchmarks" ;
    cnv:hasVerbs affi:ReceiptThroughputVerb , affi:VarianceVerb , affi:ProfileVerb ;
    rdfs:comment "The bench noun: affi bench <receipt-throughput|variance|profile>"@en .

# --- Verb: receipt-throughput -----------------------------------------------
affi:ReceiptThroughputVerb a cnv:Verb ;
    cnv:hasVerbName "receipt-throughput" ;
    cnv:verbAbout "Measure end-to-end latency of the emit -> assemble -> verify pipeline" ;
    cnv:belongsToNoun affi:BenchNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:BenchIterationsArg .

# --- Verb: variance ---------------------------------------------------------
affi:VarianceVerb a cnv:Verb ;
    cnv:hasVerbName "variance" ;
    cnv:verbAbout "Measure control-flow surprise (anomaly score) and its computation cost" ;
    cnv:belongsToNoun affi:BenchNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:BenchReceiptArg , affi:BenchIterationsArg .

# --- Verb: profile ----------------------------------------------------------
affi:ProfileVerb a cnv:Verb ;
    cnv:hasVerbName "profile" ;
    cnv:verbAbout "Run a sustained workload for flamegraph profiling" ;
    cnv:belongsToNoun affi:BenchNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:BenchReceiptArg , affi:BenchDurationArg .

# --- Shared Arguments for Bench Noun ---

affi:BenchIterationsArg a cnv:Argument ;
    cnv:hasArgumentName "iterations" ;
    cnv:argumentAbout "Number of iterations to run (default: 100)" ;
    cnv:valueType "u32" ;
    cnv:required "false" .

affi:BenchReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Optional path to a receipt JSON to use as benchmark input" ;
    cnv:valueType "String" ;
    cnv:required "false" .

affi:BenchDurationArg a cnv:Argument ;
    cnv:hasArgumentName "duration" ;
    cnv:argumentAbout "Duration in seconds to run the sustained workload" ;
    cnv:valueType "u64" ;
    cnv:required "false" .


# ============================================================================
# GOVERNANCE NOUN — surface `affi governance audit`.
# ============================================================================

affi:GovernanceNoun a cnv:Noun ;
    cnv:hasNounName "governance" ;
    cnv:nounAbout "Autonomous governance and rule enforcement" ;
    cnv:hasVerbs affi:AuditVerb ;
    rdfs:comment "The governance noun: affi governance audit"@en .

# --- Verb: audit ------------------------------------------------------------
affi:AuditVerb a cnv:Verb ;
    cnv:hasVerbName "audit" ;
    cnv:verbAbout "Run the Autonomous Governance Agent over the workspace" ;
    cnv:belongsToNoun affi:GovernanceNoun ;
    cnv:returnType "()" .


# ============================================================================
# SBOM & SUPPLY-CHAIN CLUSTER (Fortune-5 solution architecture requirement)
# Verbs that ingest, certify, and analyze Software Bills of Materials.
# Wrappers delegate to crate::handlers::sbom_*; the heavy lifting lives in
# src/sbom*.rs (canonical model, OCEL, compliance, vulnerability, supply chain).
# ============================================================================

# --- Verb: emit-from-sbom ---------------------------------------------------
affi:EmitFromSbomVerb a cnv:Verb ;
    cnv:hasVerbName "emit-from-sbom" ;
    cnv:verbAbout "Ingest an SPDX/CycloneDX SBOM and emit OCEL component/dependency events" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:SbomPathArg , affi:FormatArg .

affi:SbomPathArg a cnv:Argument ;
    cnv:hasArgumentName "sbom-path" ;
    cnv:argumentAbout "Path to an SPDX 2.3 or CycloneDX 1.5/1.6 JSON document" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: sbom-ntia --------------------------------------------------------
affi:SbomNtiaVerb a cnv:Verb ;
    cnv:hasVerbName "sbom-ntia" ;
    cnv:verbAbout "Certify an SBOM against the NTIA minimum elements (EO 14028)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:SbomPathArg , affi:FormatArg .

# --- Verb: sbom-compliance --------------------------------------------------
affi:SbomComplianceVerb a cnv:Verb ;
    cnv:hasVerbName "sbom-compliance" ;
    cnv:verbAbout "Assess an SBOM against NTIA/EO14028/SLSA/in-toto/CISA/C-SCRM frameworks" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:SbomPathArg , affi:FrameworkArg , affi:FormatArg .

affi:FrameworkArg a cnv:Argument ;
    cnv:hasArgumentName "framework" ;
    cnv:argumentAbout "Compliance framework or 'all' (ntia|eo14028|slsa|in-toto|cisa|cscrm|iso27001|soc2|vex|all)" ;
    cnv:valueType "String" ;
    cnv:required "false" .

# --- Verb: sbom-scan --------------------------------------------------------
affi:SbomScanVerb a cnv:Verb ;
    cnv:hasVerbName "sbom-scan" ;
    cnv:verbAbout "Correlate vulnerabilities/VEX against SBOM components and propagate risk" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:SbomPathArg , affi:AdvisoriesPathArg , affi:FormatArg .

affi:AdvisoriesPathArg a cnv:Argument ;
    cnv:hasArgumentName "advisories-path" ;
    cnv:argumentAbout "Path to a JSON file of vulnerabilities and optional VEX statements" ;
    cnv:valueType "String" ;
    cnv:required "false" .

# --- Verb: sbom-blast-radius ------------------------------------------------
affi:SbomBlastRadiusVerb a cnv:Verb ;
    cnv:hasVerbName "sbom-blast-radius" ;
    cnv:verbAbout "Compute the supply-chain blast radius of a component (transitive dependents)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:SbomPathArg , affi:ComponentArg , affi:FormatArg .

affi:ComponentArg a cnv:Argument ;
    cnv:hasArgumentName "component" ;
    cnv:argumentAbout "The bom-ref of the component to analyze" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: sbom-attest ------------------------------------------------------
affi:SbomAttestVerb a cnv:Verb ;
    cnv:hasVerbName "sbom-attest" ;
    cnv:verbAbout "Emit a SLSA-flavored provenance attestation linking SBOM address to receipt" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:SbomPathArg , affi:AttestReceiptArg , affi:FormatArg .

affi:AttestReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Optional receipt reference to bind the attestation to" ;
    cnv:valueType "String" ;
    cnv:required "false" .
