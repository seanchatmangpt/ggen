@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix cnv:  <http://clap-noun-verb.io/ontology#> .
@prefix affi: <http://affidavit.io/cli#> .

# =============================================================================
# The affi CLI surface, described once in the authoritative clap-noun-verb (cnv)
# noun-verb vocabulary. This ontology is the ONLY affidavit-supplied input to
# `ggen sync`; the pack supplies the queries + templates that render thin #[verb]
# wrappers under src/verbs/, each delegating to crate::handlers::<verb>.
#
# Surface: `affi receipt <emit|assemble|verify|show|inspect|diff|stats|graph|replay|model|conformance|diagnose|visualize|catalog>`.
# =============================================================================

affi: a owl:Ontology ;
    rdfs:label "affidavit CLI — Maximalist Nexus Edition"@en ;
    rdfs:comment "Provenance Layer CLI — 80+ verbs for unified organizational provenance and governance across 300+ repos."@en ;
    dcterms:creator "Sean Chatman" ;
    owl:imports cnv: ;
    owl:versionInfo "26.7.0-maximalist" .

# ============================================================================
# RECEIPT NOUN — surface `affi receipt <verb>`.
# ============================================================================

affi:ReceiptNoun a cnv:Noun ;
    cnv:hasNounName "receipt" ;
    cnv:hasAlias "r" ;
    cnv:nounAbout "Emit, assemble, verify, and analyze provenance receipts (nexus-wide operational events)" ;
    cnv:hasVerbs
        # Emission — core + platform variants
        affi:EmitVerb ,
        affi:EmitBatchVerb ,
        affi:EmitFromGitHubVerb ,
        affi:EmitFromGitLabVerb ,
        affi:EmitFromCICDVerb ,
        affi:EmitFromMonitoringVerb ,
        affi:EmitFromCloudVerb ,
        affi:EmitFromSecurityVerb ,

        # Assembly & sealing
        affi:AssembleVerb ,
        affi:AssembleWithSignatureVerb ,
        affi:AssembleAndNotarizeVerb ,

        # Core verification
        affi:VerifyVerb ,
        affi:VerifyFamilyVerb ,
        affi:VerifySLAVerb ,
        affi:VerifyComplianceVerb ,

        # Attestation & signing
        affi:AttestVerb ,
        affi:NotarizeVerb ,
        affi:SignVerb ,

        # Display & analysis
        affi:ShowVerb ,
        affi:InspectVerb ,
        affi:DiffVerb ,
        affi:StatsVerb ,
        affi:GraphVerb ,
        affi:ReplayVerb ,
        affi:ModelVerb ,
        affi:ConformanceVerb ,
        affi:DiagnoseVerb ,
        affi:VisualizeVerb ,
        affi:CatalogVerb ,

        # Querying & aggregation
        affi:QueryVerb ,
        affi:TimelineVerb ,
        affi:CausalityChainVerb ,
        affi:SearchVerb ,
        affi:FindBlastRadiusVerb ,

        # Analytics & metrics
        affi:DORAMetricsVerb ,
        affi:TeamVelocityVerb ,
        affi:TechDebtVerb ,
        affi:SecurityDebtVerb ,
        affi:CoverageAnalysisVerb ,
        affi:AnomalyDetectVerb ,
        affi:PredictVerb ,
        affi:TrendAnalysisVerb ,

        # Compliance & governance
        affi:SOC2AuditVerb ,
        affi:GDPRProofVerb ,
        affi:HIPAAVerb ,
        affi:PCIDSSVerb ,
        affi:LicenseComplianceVerb ,
        affi:PolicyEnforceVerb ,

        # Cross-repo intelligence
        affi:PortfolioHealthVerb ,
        affi:DependencyMatrixVerb ,
        affi:BusFactorVerb ,
        affi:OrphanedCodeVerb ,

        # Testing & diagnosis
        affi:TestVerb ,
        affi:ExplainIncidentVerb ,
        affi:RootCauseVerb ,

        # SBOM & supply-chain provenance (Fortune-5 solution architecture)
        affi:EmitFromSbomVerb ,
        affi:SbomNtiaVerb ,
        affi:SbomComplianceVerb ,
        affi:SbomScanVerb ,
        affi:SbomBlastRadiusVerb ,
        affi:SbomAttestVerb ;
    rdfs:comment "Receipt noun (maximalist): emit, assemble, verify, query, analyze, audit, and govern 300+ repos"@en .

# --- Shared Arguments ---
...
# --- Verb: test -------------------------------------------------------------
affi:TestVerb a cnv:Verb ;
    cnv:hasVerbName "test" ;
    cnv:verbAbout "A dummy test verb for ontology validation" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" .

affi:FormatArg a cnv:Argument ;
    cnv:hasArgumentName "format" ;
    cnv:argumentAbout "Output format: text (default) or json" ;
    cnv:valueType "String" ;
    cnv:required "false" ;
    cnv:defaultValue "text" .

# --- Verb: emit -------------------------------------------------------------
affi:EmitVerb a cnv:Verb ;
    cnv:hasVerbName "emit" ;
    cnv:hasAlias "e" ;
    cnv:verbAbout "Append one operation-event to the working receipt" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:TypeArg , affi:ObjectArg , affi:PayloadArg , affi:FormatArg .

affi:TypeArg a cnv:Argument ;
    cnv:hasArgumentName "type" ;
    cnv:argumentAbout "The operation-event type" ;
    cnv:valueType "String" ;
    cnv:required "true" .

affi:ObjectArg a cnv:Argument ;
    cnv:hasArgumentName "object" ;
    cnv:argumentAbout "A related object as `id:type` (repeatable)" ;
    cnv:valueType "Vec<String>" ;
    cnv:required "true" .

affi:PayloadArg a cnv:Argument ;
    cnv:hasArgumentName "payload" ;
    cnv:argumentAbout "Payload source: a file path, or `-` for stdin" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: assemble ---------------------------------------------------------
affi:AssembleVerb a cnv:Verb ;
    cnv:hasVerbName "assemble" ;
    cnv:hasAlias "a" ;
    cnv:verbAbout "Finalize the working receipt into an immutable receipt file" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:OutArg , affi:FormatArg .

affi:OutArg a cnv:Argument ;
    cnv:hasArgumentName "out" ;
    cnv:argumentAbout "Optional output path; defaults to a content-addressed file name" ;
    cnv:valueType "String" ;
    cnv:required "false" .

# --- Verb: verify -----------------------------------------------------------
affi:VerifyVerb a cnv:Verb ;
    cnv:hasVerbName "verify" ;
    cnv:hasAlias "v" ;
    cnv:verbAbout "Run the certify pipeline over a receipt and print the verdict" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:VerifyReceiptArg , affi:FormatArg , affi:ProfileArg , affi:StrictArg .

affi:VerifyReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to verify" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

affi:ProfileArg a cnv:Argument ;
    cnv:hasArgumentName "profile" ;
    cnv:argumentAbout "Conformance profile [default: core/v1]" ;
    cnv:valueType "String" ;
    cnv:required "false" ;
    cnv:defaultValue "core/v1" .

affi:StrictArg a cnv:Argument ;
    cnv:hasArgumentName "strict" ;
    cnv:argumentAbout "Treat warnings as failures" ;
    cnv:valueType "bool" ;
    cnv:required "false" ;
    cnv:defaultValue "false" .

# --- Verb: show -------------------------------------------------------------
affi:ShowVerb a cnv:Verb ;
    cnv:hasVerbName "show" ;
    cnv:hasAlias "s" ;
    cnv:verbAbout "Print a human-readable dump of a receipt chain" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:ShowReceiptArg , affi:FormatArg .

affi:ShowReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to display" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

# --- Verb: inspect ----------------------------------------------------------
affi:InspectVerb a cnv:Verb ;
    cnv:hasVerbName "inspect" ;
    cnv:hasAlias "i" ;
    cnv:verbAbout "Detailed structural analysis of a receipt (event/object distribution)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:InspectReceiptArg , affi:FormatArg .

affi:InspectReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to inspect" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

# --- Verb: diff -------------------------------------------------------------
affi:DiffVerb a cnv:Verb ;
    cnv:hasVerbName "diff" ;
    cnv:hasAlias "d" ;
    cnv:verbAbout "Compare two receipts and print their differences" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:ReceiptAArg , affi:ReceiptBArg , affi:FormatArg .

affi:ReceiptAArg a cnv:Argument ;
    cnv:hasArgumentName "receipt-a" ;
    cnv:argumentAbout "Path to the first receipt JSON" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

affi:ReceiptBArg a cnv:Argument ;
    cnv:hasArgumentName "receipt-b" ;
    cnv:argumentAbout "Path to the second receipt JSON" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 2 .

# --- Verb: stats ------------------------------------------------------------
affi:StatsVerb a cnv:Verb ;
    cnv:hasVerbName "stats" ;
    cnv:verbAbout "One-shot aggregate stats for a receipt (counts + DFG size + conformance)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:StatsReceiptArg , affi:FormatArg .

affi:StatsReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to analyze" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

# --- Verb: graph ------------------------------------------------------------
affi:GraphVerb a cnv:Verb ;
    cnv:hasVerbName "graph" ;
    cnv:verbAbout "Discover the directly-follows graph from a receipt (wasm4pm)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:GraphReceiptArg , affi:FormatArg .

affi:GraphReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to graph" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

# --- Verb: replay -----------------------------------------------------------
affi:ReplayVerb a cnv:Verb ;
    cnv:hasVerbName "replay" ;
    cnv:verbAbout "Replay a receipt's event sequence step by step in lawful seq order" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:ReplayReceiptArg .

affi:ReplayReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to replay" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

# --- Verb: model ------------------------------------------------------------
affi:ModelVerb a cnv:Verb ;
    cnv:hasVerbName "model" ;
    cnv:verbAbout "Discover a process model from a receipt's events (wasm4pm)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:ModelReceiptArg .

affi:ModelReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to model" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

# --- Verb: conformance ------------------------------------------------------
affi:ConformanceVerb a cnv:Verb ;
    cnv:hasVerbName "conformance" ;
    cnv:verbAbout "Compute fitness, activity coverage, and simplicity metrics" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:ConformanceReceiptArg .

affi:ConformanceReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to evaluate" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

# --- Verb: diagnose ---------------------------------------------------------
affi:DiagnoseVerb a cnv:Verb ;
    cnv:hasVerbName "diagnose" ;
    cnv:verbAbout "Render verify outcomes as LSP-shaped diagnostics (lsp-max)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:DiagnoseReceiptArg .

affi:DiagnoseReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to diagnose" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

# --- Verb: visualize --------------------------------------------------------
affi:VisualizeVerb a cnv:Verb ;
    cnv:hasVerbName "visualize" ;
    cnv:verbAbout "Visualize receipt as graph (DOT or JSON)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:VisualizeFormatArg , affi:VisualizeReceiptArg .

affi:VisualizeFormatArg a cnv:Argument ;
    cnv:hasArgumentName "format" ;
    cnv:argumentAbout "Output format: dot or json" ;
    cnv:valueType "String" ;
    cnv:required "true" .

affi:VisualizeReceiptArg a cnv:Argument ;
    cnv:hasArgumentName "receipt" ;
    cnv:argumentAbout "Path to the receipt JSON to visualize" ;
    cnv:valueType "String" ;
    cnv:required "true" ;
    cnv:positional 1 .

# --- Verb: catalog ---------------------------------------------------------
affi:CatalogVerb a cnv:Verb ;
    cnv:hasVerbName "catalog" ;
    cnv:verbAbout "List and search available receipt fixtures" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:FilterNameArg , affi:FilterEventsArg .

affi:FilterNameArg a cnv:Argument ;
    cnv:hasArgumentName "filter-name" ;
    cnv:argumentAbout "Filter fixtures by name (substring match)" ;
    cnv:valueType "String" ;
    cnv:required "false" .

affi:FilterEventsArg a cnv:Argument ;
    cnv:hasArgumentName "filter-events" ;
    cnv:argumentAbout "Filter fixtures by exact event count" ;
    cnv:valueType "usize" ;
    cnv:required "false" .

# ============================================================================
# EMISSION CLUSTER — emit variants for different platforms
# ============================================================================

# --- Verb: emit-batch -------------------------------------------------------
affi:EmitBatchVerb a cnv:Verb ;
    cnv:hasVerbName "emit-batch" ;
    cnv:verbAbout "Emit multiple events from JSON array in a single command" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:BatchFileArg , affi:FormatArg .

affi:BatchFileArg a cnv:Argument ;
    cnv:hasArgumentName "batch-file" ;
    cnv:argumentAbout "JSON file containing array of events to emit" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: emit-from-github ------------------------------------------------
affi:EmitFromGitHubVerb a cnv:Verb ;
    cnv:hasVerbName "emit-from-github" ;
    cnv:verbAbout "Consume GitHub webhooks and emit events (push, PR, release, workflow)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:RepoArg , affi:EventTypeGHArg , affi:FormatArg .

affi:RepoArg a cnv:Argument ;
    cnv:hasArgumentName "repo" ;
    cnv:argumentAbout "GitHub repo in owner/name format" ;
    cnv:valueType "String" ;
    cnv:required "true" .

affi:EventTypeGHArg a cnv:Argument ;
    cnv:hasArgumentName "event-type" ;
    cnv:argumentAbout "GitHub event type (push|pull_request|release|workflow_run)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: emit-from-gitlab ------------------------------------------------
affi:EmitFromGitLabVerb a cnv:Verb ;
    cnv:hasVerbName "emit-from-gitlab" ;
    cnv:verbAbout "Consume GitLab webhooks and emit events" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:RepoArg , affi:EventTypeGLArg , affi:FormatArg .

affi:EventTypeGLArg a cnv:Argument ;
    cnv:hasArgumentName "event-type" ;
    cnv:argumentAbout "GitLab event type (push|merge_request|release|pipeline)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: emit-from-cicd ---------------------------------------------------
affi:EmitFromCICDVerb a cnv:Verb ;
    cnv:hasVerbName "emit-from-cicd" ;
    cnv:verbAbout "Consume CI/CD platform events (GitHub Actions, CircleCI, GitLab CI, Jenkins)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:CICDProviderArg , affi:JobStatusArg , affi:FormatArg .

affi:CICDProviderArg a cnv:Argument ;
    cnv:hasArgumentName "provider" ;
    cnv:argumentAbout "CI/CD platform (github-actions|circleci|gitlab-ci|jenkins)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

affi:JobStatusArg a cnv:Argument ;
    cnv:hasArgumentName "job-status" ;
    cnv:argumentAbout "Job outcome (success|failure|skipped)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: emit-from-monitoring -------------------------------------------
affi:EmitFromMonitoringVerb a cnv:Verb ;
    cnv:hasVerbName "emit-from-monitoring" ;
    cnv:verbAbout "Consume monitoring/observability events (Datadog, New Relic, Prometheus)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:MonitoringProviderArg , affi:AlertTypeArg , affi:FormatArg .

affi:MonitoringProviderArg a cnv:Argument ;
    cnv:hasArgumentName "provider" ;
    cnv:argumentAbout "Monitoring platform (datadog|newrelic|prometheus)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

affi:AlertTypeArg a cnv:Argument ;
    cnv:hasArgumentName "alert-type" ;
    cnv:argumentAbout "Alert type (metric_alert|anomaly|slo_violation)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: emit-from-cloud --------------------------------------------------
affi:EmitFromCloudVerb a cnv:Verb ;
    cnv:hasVerbName "emit-from-cloud" ;
    cnv:verbAbout "Consume cloud platform events (AWS CloudTrail, GCP Audit Logs, Azure Activity)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:CloudProviderArg , affi:ResourceTypeArg , affi:FormatArg .

affi:CloudProviderArg a cnv:Argument ;
    cnv:hasArgumentName "provider" ;
    cnv:argumentAbout "Cloud provider (aws|gcp|azure)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

affi:ResourceTypeArg a cnv:Argument ;
    cnv:hasArgumentName "resource-type" ;
    cnv:argumentAbout "Resource type (compute|storage|database|network)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: emit-from-security -----------------------------------------------
affi:EmitFromSecurityVerb a cnv:Verb ;
    cnv:hasVerbName "emit-from-security" ;
    cnv:verbAbout "Consume security events (Snyk, SonarQube, Trivy, GitHub Advanced Security)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:SecurityProviderArg , affi:VulnerabilityTypeArg , affi:FormatArg .

affi:SecurityProviderArg a cnv:Argument ;
    cnv:hasArgumentName "provider" ;
    cnv:argumentAbout "Security scanner (snyk|sonarqube|trivy|ghas)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

affi:VulnerabilityTypeArg a cnv:Argument ;
    cnv:hasArgumentName "vuln-type" ;
    cnv:argumentAbout "Vulnerability type (sast|dast|sca|secret)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# ============================================================================
# ASSEMBLY & SIGNING CLUSTER
# ============================================================================

# --- Verb: assemble-with-signature ------------------------------------------
affi:AssembleWithSignatureVerb a cnv:Verb ;
    cnv:hasVerbName "assemble-with-signature" ;
    cnv:verbAbout "Assemble receipt and sign with Ed25519 or Sigstore keyless" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:SigningMethodArg , affi:OutArg , affi:FormatArg .

affi:SigningMethodArg a cnv:Argument ;
    cnv:hasArgumentName "signing-method" ;
    cnv:argumentAbout "Signing method (ed25519|sigstore|hardware)" ;
    cnv:valueType "String" ;
    cnv:required "false" ;
    cnv:defaultValue "sigstore" .

# --- Verb: assemble-and-notarize -------------------------------------------
affi:AssembleAndNotarizeVerb a cnv:Verb ;
    cnv:hasVerbName "assemble-and-notarize" ;
    cnv:verbAbout "Assemble receipt and obtain timestamp notarization from external authority" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:NotaryProviderArg , affi:OutArg , affi:FormatArg .

affi:NotaryProviderArg a cnv:Argument ;
    cnv:hasArgumentName "notary-provider" ;
    cnv:argumentAbout "Notarization service (rfc3161|chronosphere|custom)" ;
    cnv:valueType "String" ;
    cnv:required "false" ;
    cnv:defaultValue "rfc3161" .

# ============================================================================
# VERIFICATION & ATTESTATION CLUSTER
# ============================================================================

# --- Verb: verify-family ---------------------------------------------------
affi:VerifyFamilyVerb a cnv:Verb ;
    cnv:hasVerbName "verify-family" ;
    cnv:verbAbout "Verify multiple receipts from same repo/org are consistent" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:ReceiptsDirectoryArg , affi:FormatArg .

affi:ReceiptsDirectoryArg a cnv:Argument ;
    cnv:hasArgumentName "receipts-dir" ;
    cnv:argumentAbout "Directory containing multiple receipt JSON files" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: verify-sla -------------------------------------------------------
affi:VerifySLAVerb a cnv:Verb ;
    cnv:hasVerbName "verify-sla" ;
    cnv:verbAbout "Verify receipt meets SLA/SLO targets (e.g., 4h MTTR, 2-person approval)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:VerifyReceiptArg , affi:SLAFileArg , affi:FormatArg .

affi:SLAFileArg a cnv:Argument ;
    cnv:hasArgumentName "sla-file" ;
    cnv:argumentAbout "YAML/JSON file defining SLA rules" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: verify-compliance -----------------------------------------------
affi:VerifyComplianceVerb a cnv:Verb ;
    cnv:hasVerbName "verify-compliance" ;
    cnv:verbAbout "Verify receipt against compliance rules (SOC 2, GDPR, HIPAA, PCI-DSS)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:VerifyReceiptArg , affi:ComplianceFrameworkArg , affi:FormatArg .

affi:ComplianceFrameworkArg a cnv:Argument ;
    cnv:hasArgumentName "framework" ;
    cnv:argumentAbout "Compliance framework (soc2|gdpr|hipaa|pci-dss)" ;
    cnv:valueType "String" ;
    cnv:required "true" .

# --- Verb: attest ----------------------------------------------------------
affi:AttestVerb a cnv:Verb ;
    cnv:hasVerbName "attest" ;
    cnv:verbAbout "Create a signed attestation for a receipt (SLSA provenance)" ;
    cnv:belongsToNoun affi:ReceiptNoun ;
    cnv:returnType "()" ;
    cnv:hasArguments affi:VerifyReceiptArg , affi:AttestationTypeArg , affi:OutArg , affi:FormatArg .

affi:AttestationTypeArg a cnv:Argument ;
    cnv:hasArgumentName "attestation-type" ;
    cnv:argumentAbout "Attestation type (slsa-v1|in-toto|custom)" ;
    cnv:valueType "String" ;
    cnv:required "false" ;
    cnv:defaultValue "slsa-v1" .

# --- Verb: notarize --------------------------------------------------------
affi:NotarizeVerb a cnv:Verb ;
