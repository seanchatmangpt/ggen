PREFIX sos: <https://ggen.io/semantic-os/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?law_id ?name ?description ?field_type ?condition_type (GROUP_CONCAT(CONCAT(?input_value, ":", ?condition_name); separator=",") AS ?transitions_str) WHERE {
    ?law a sos:Law ;
         sos:lawId ?law_id ;
         sos:name ?name ;
         sos:description ?description ;
         sos:fieldType ?field_type ;
         sos:conditionType ?condition_type .
         
    OPTIONAL {
        ?law sos:hasTransition ?transition .
        ?transition sos:inputValue ?input_value ;
                    sos:selectCondition ?condition_name .
    }
} GROUP BY ?law_id ?name ?description ?field_type ?condition_type
