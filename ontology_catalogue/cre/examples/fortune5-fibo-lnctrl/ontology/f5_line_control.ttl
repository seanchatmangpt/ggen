@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ln: <http://lnctrl.io/ontology#> .
@prefix f5: <http://fortune5.lnctrl.io/ontology#> .
@prefix fibo-fnd: <https://spec.edmcouncil.org/fibo/ontology/FND/> .
@prefix fibo-be: <https://spec.edmcouncil.org/fibo/ontology/BE/> .
@prefix fibo-loan: <https://spec.edmcouncil.org/fibo/ontology/LOAN/> .

# =============================================================================
# Fortune-5 FIBO LineController Factory - Control Ontology
# Generates 300k+ LOC Erlang/OTP from FIBO patterns
# =============================================================================

# -----------------------------------------------------------------------------
# CONNECTOR CATALOG (30+ connectors × 20 ops = 600 modules)
# -----------------------------------------------------------------------------

f5:CRMConnector a ln:Connector ;
    ln:connectorId "crm" ;
    ln:name "CRM Connector" ;
    ln:operations (
        f5:CreateLeadOp f5:UpdateLeadOp f5:GetLeadOp f5:ConvertLeadOp
        f5:CreateAccountOp f5:UpdateAccountOp f5:GetAccountOp f5:ArchiveAccountOp
        f5:CreateContactOp f5:UpdateContactOp f5:GetContactOp f5:MergeContactsOp
        f5:CreateOpportunityOp f5:UpdateOpportunityOp f5:GetOpportunityOp f5:CloseOpportunityOp
        f5:CreateNoteOp f5:GetNotesOp f5:SearchCRMOp f5:BulkExportOp
    ) ;
    ln:authScheme "oauth2" ;
    ln:rateLimit "1000/min" .

f5:KYCAMLConnector a ln:Connector ;
    ln:connectorId "kyc_aml" ;
    ln:name "KYC/AML Connector" ;
    ln:operations (
        f5:VerifyIdentityOp f5:CheckDocumentsOp f5:FacialRecognitionOp f5:LivenessCheckOp
        f5:AMLScreeningOp f5:PEPScreeningOp f5:SanctionsCheckOp f5:AdverseMediaOp
        f5:RiskScoringOp f5:GetVerificationStatusOp f5:UpdateVerificationOp f5:ArchiveVerificationOp
        f5:GenerateReportOp f5:SubmitToRegulatorsOp f5:WebhookNotificationOp f5:BulkScreeningOp
        f5:MonitorOngoingOp f5:FlagSuspiciousOp f5:FileRSAROp f5:GetComplianceHistoryOp
    ) ;
    ln:authScheme "api_key" ;
    ln:rateLimit "500/min" .

f5:CreditBureauConnector a ln:Connector ;
    ln:connectorId "credit_bureau" ;
    ln:name "Credit Bureau Connector" ;
    ln:operations (
        f5:PullCreditReportOp f5:MonitorScoreOp f5:DisputeReportOp f5:FreezeUnfreezeOp
        f5:GetScoreHistoryOp f5:GetTradeLinesOp f5:GetInquiriesOp f5:GetPublicRecordsOp
        f5:GetCollectionsOp f5:GetBankruptciesOp f5:GetForeclosuresOp f5:GetJudgmentsOp
        f5:SoftPullOp f5:HardPullOp f5:TriMergeReportOp f5:RapidRescoreOp
        f5:RentReportingOp f5:AlternativeDataOp f5:FraudAlertOp f5:IdentityVerificationOp
    ) ;
    ln:authScheme "mtls" ;
    ln:rateLimit "200/min" .

f5:DocumentConnector a ln:Connector ;
    ln:connectorId "document" ;
    ln:name "Document Management Connector" ;
    ln:operations (
        f5:UploadDocumentOp f5:GetDocumentOp f5:DeleteDocumentOp f5:UpdateMetadataOp
        f5:GeneratePDFOp f5:SignDocumentOp f5:GetSignatureStatusOp f5:SendForSignatureOp
        f5:DownloadSignedOp f5:VoidEnvelopeOp f5:GetAuditTrailOp f5:ArchiveDocumentOp
        f5:OCRExtractionOp f5:ClassifyDocumentOp f5:ValidateDataOp f5:CompareVersionsOp
        f5:WatermarkOp f5:EncryptOp f5:DecryptOp f5:ShareLinkOp
    ) ;
    ln:authScheme "oauth2" ;
    ln:rateLimit "2000/min" .

f5:CoreLedgerConnector a ln:Connector ;
    ln:connectorId "core_ledger" ;
    ln:name "Core Ledger Connector" ;
    ln:operations (
        f5:CreateAccountOp f5:GetAccountBalanceOp f5:PostTransactionOp f5:ReverseTransactionOp
        f5:GetTransactionHistoryOp f5:ReconcileOp f5:GenerateStatementOp f5:ApplyInterestOp
        f5:ApplyFeesOp f5:WaiveFeeOp f5:GetAccrualOp f5:SetACHLimitOp
        f5:FreezeAccountOp f5:UnfreezeAccountOp f5:CloseAccountOp f5:ReopenAccountOp
        f5:LinkAccountsOp f5:GetGLBalanceOp f5:PostGLEntryOp f5:GetTrialBalanceOp
    ) ;
    ln:authScheme "mtls" ;
