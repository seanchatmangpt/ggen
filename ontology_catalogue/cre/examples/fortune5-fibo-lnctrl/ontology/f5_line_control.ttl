f5:CaseManagementConnector a ln:Connector ;
    ln:connectorId "case_mgmt" ;
    ln:name "Case Management Connector" ;
    ln:operations (
        f5:CreateCaseOp f5:UpdateCaseOp f5:GetCaseOp f5:CloseCaseOp
