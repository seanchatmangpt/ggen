@prefix job: <http://rflow.dev/ontology/job-model#> .
@prefix yawl: <http://rflow.dev/ontology/yawl-core#> .
@prefix example: <http://rflow.dev/example/simple-sequence#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

@base <http://rflow.dev/example/simple-sequence> .

# Example ABox: Simple Sequential Workflow
# Demonstrates: Start -> Activity A -> Activity B -> End

#################################################################
# Job Definition
#################################################################

example:SimpleSequenceJob rdf:type job:JobDefinition ;
   job:hasJobId "simple-sequence-001" ;
   yawl:hasName "Simple Sequence Workflow" ;
   yawl:hasDescription "A basic workflow with two sequential activities" .

#################################################################
# Workflow Elements
#################################################################

# Start Event
example:StartEvent rdf:type yawl:StartEvent ;
   yawl:hasId "start" ;
   yawl:hasName "Start" ;
   yawl:belongsTo example:SimpleSequenceJob ;
   yawl:isEnabled true .

# Activity A
example:ActivityA rdf:type yawl:AtomicActivity ;
   yawl:hasId "activity-a" ;
   yawl:hasName "Process Data" ;
   yawl:hasDescription "Initial data processing activity" ;
   yawl:belongsTo example:SimpleSequenceJob ;
   yawl:isEnabled false ;
   yawl:isExecuting false ;
   yawl:isCompleted false .

# Activity B  
example:ActivityB rdf:type yawl:AtomicActivity ;
   yawl:hasId "activity-b" ;
   yawl:hasName "Validate Results" ;
   yawl:hasDescription "Validation of processed data" ;
   yawl:belongsTo example:SimpleSequenceJob ;
   yawl:isEnabled false ;
   yawl:isExecuting false ;
   yawl:isCompleted false .

# End Event
example:EndEvent rdf:type yawl:EndEvent ;
   yawl:hasId "end" ;
   yawl:hasName "End" ;
   yawl:belongsTo example:SimpleSequenceJob ;
   yawl:isEnabled false .

#################################################################
# Flow Connections (Sequence Patterns)
#################################################################

# Flow: Start -> Activity A
example:Flow1 rdf:type yawl:Flow ;
   yawl:hasId "flow-1" ;
   yawl:flowsFrom example:StartEvent ;
   yawl:flowsTo example:ActivityA .

example:StartEvent yawl:hasOutputFlow example:Flow1 .
example:ActivityA yawl:hasInputFlow example:Flow1 .

# Flow: Activity A -> Activity B  
example:Flow2 rdf:type yawl:Flow ;
   yawl:hasId "flow-2" ;
   yawl:flowsFrom example:ActivityA ;
   yawl:flowsTo example:ActivityB .

example:ActivityA yawl:hasOutputFlow example:Flow2 .
example:ActivityB yawl:hasInputFlow example:Flow2 .

# Flow: Activity B -> End
example:Flow3 rdf:type yawl:Flow ;
   yawl:hasId "flow-3" ;
   yawl:flowsFrom example:ActivityB ;
   yawl:flowsTo example:EndEvent .

example:ActivityB yawl:hasOutputFlow example:Flow3 .
example:EndEvent yawl:hasInputFlow example:Flow3 .

#################################################################
# Pattern Classifications
#################################################################

# This workflow uses only Sequence patterns (MVP supported)
example:SimpleSequenceJob yawl:contains [
   rdf:type yawl:Sequence ;
   yawl:hasName "Start to Activity A Sequence" ;
   yawl:flowsFrom example:StartEvent ;
   yawl:flowsTo example:ActivityA
] .

example:SimpleSequenceJob yawl:contains [
   rdf:type yawl:Sequence ;
   yawl:hasName "Activity A to Activity B Sequence" ;
   yawl:flowsFrom example:ActivityA ;
   yawl:flowsTo example:ActivityB  
] .

example:SimpleSequenceJob yawl:contains [
   rdf:type yawl:Sequence ;
   yawl:hasName "Activity B to End Sequence" ;
   yawl:flowsFrom example:ActivityB ;
   yawl:flowsTo example:EndEvent
] .

#################################################################
# Runtime Configuration
#################################################################

# Execution context for this workflow
example:ExecutionContext rdf:type job:ExecutionContext ;
   job:hasProgramCounter 0 ;
   job:hasVersion "1.0.0" .

# Namespace and security
example:DefaultNamespace rdf:type job:Namespace ;
   yawl:hasId "default" ;
   yawl:hasName "Default Namespace" .

example:SimpleSequenceJob job:belongsToNamespace example:DefaultNamespace .

#################################################################
# Expected PlanPack Metadata
#################################################################

# This will be generated by the compiler
example:ExpectedPlanPack rdf:type job:PlanPack ;
   job:hasPlanHash "blake3-hash-will-be-generated" ;
   job:hasTBoxHash "yawl-core-tbox-hash" ;
   job:compiledFrom example:SimpleSequenceJob .

# Pattern assertions that should be generated
example:PatternAssertions rdf:type job:PatternAssertions ;
   rdfs:comment "All patterns in this workflow are MVP supported" ;
   rdfs:comment "No RequiresRule patterns present" .