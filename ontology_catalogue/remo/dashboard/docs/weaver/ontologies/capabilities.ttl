## Authentication & Authorization Services
wvr:AuthenticationService a owl:Class ;
    rdfs:label "Authentication Service" ;
    rdfs:comment "Service for user authentication and session management" ;
    rdfs:subClassOf wvr:EdgeFunction .

wvr:LoginComponent a owl:Class ;
    rdfs:label "Login Component" ;
    rdfs:comment "UI component for user login" ;
    rdfs:subClassOf wvr:VueComponent .

wvr:AuthorizationService a owl:Class ;
    rdfs:label "Authorization Service" ;
    rdfs:comment "Service for role-based access control" ;
    rdfs:subClassOf wvr:EdgeFunction .

wvr:PermissionGuard a owl:Class ;
    rdfs:label "Permission Guard" ;
    rdfs:comment "Route guard for authorization checks" ;
    rdfs:subClassOf wvr:Artifact ;
    wvr:hasFileExtension ".ts" .

## Encryption & Security Services
wvr:EncryptionService a owl:Class ;
