    rdfs:subClassOf wvr:EdgeFunction .

wvr:KeyManagementService a owl:Class ;
    rdfs:label "Key Management Service" ;
    rdfs:comment "Service for cryptographic key management" ;
    rdfs:subClassOf wvr:EdgeFunction .

wvr:DataClassificationService a owl:Class ;
    rdfs:label "Data Classification Service" ;
    rdfs:comment "Service for automatic data classification" ;
