## Threat Detection & Response
wvr:ThreatDetector a owl:Class ;
    rdfs:label "Threat Detector" ;
    rdfs:comment "Automated threat detection system" ;
    rdfs:subClassOf wvr:EdgeFunction .

wvr:AlertingSystem a owl:Class ;
    rdfs:label "Alerting System" ;
    rdfs:comment "System for security alerts and notifications" ;
    rdfs:subClassOf wvr:EdgeFunction .

wvr:IncidentHandler a owl:Class ;
    rdfs:label "Incident Handler" ;
    rdfs:comment "Service for incident response automation" ;
    rdfs:subClassOf wvr:EdgeFunction .

wvr:ResponsePlaybook a owl:Class ;
    rdfs:label "Response Playbook" ;
    rdfs:comment "Automated incident response procedures" ;
    rdfs:subClassOf wvr:ConfigFile .

## Monitoring & Analysis
wvr:TraceCollector a owl:Class ;
    rdfs:label "Trace Collector" ;
    rdfs:comment "Distributed tracing data collector" ;
    rdfs:subClassOf wvr:Artifact ;
    wvr:hasFileExtension ".ts" .

wvr:TraceAnalyzer a owl:Class ;
    rdfs:label "Trace Analyzer" ;
    rdfs:comment "System for analyzing distributed traces" ;
    rdfs:subClassOf wvr:EdgeFunction .

wvr:LogCollector a owl:Class ;
    rdfs:label "Log Collector" ;
    rdfs:comment "Centralized log collection service" ;
    rdfs:subClassOf wvr:EdgeFunction .

wvr:LogProcessor a owl:Class ;
    rdfs:label "Log Processor" ;
    rdfs:comment "Service for log processing and analysis" ;
    rdfs:subClassOf wvr:EdgeFunction .

## Security Policies
wvr:PasswordPolicy a wvr:SecurityPolicy ;
    rdfs:label "Password Policy" ;
    rdfs:comment "Password strength and rotation policy" ;
    wvr:hasRule "minimum_length", "complexity_requirements", "rotation_period" .

# =============================================================================
# TECHNOLOGY STACK PROPERTIES
# =============================================================================

wvr:hasFramework a owl:DatatypeProperty ;
    rdfs:label "has framework" ;
    rdfs:domain wvr:TechnologyStack ;
    rdfs:range xsd:string .

wvr:hasLanguage a owl:DatatypeProperty ;
    rdfs:label "has language" ;
    rdfs:domain wvr:TechnologyStack ;
    rdfs:range xsd:string .

wvr:hasRuntime a owl:DatatypeProperty ;
    rdfs:label "has runtime" ;
    rdfs:domain wvr:TechnologyStack ;
    rdfs:range xsd:string .

wvr:hasDatabase a owl:DatatypeProperty ;
    rdfs:label "has database" ;
    rdfs:domain wvr:TechnologyStack ;
    rdfs:range xsd:string .

wvr:hasAuth a owl:DatatypeProperty ;
    rdfs:label "has authentication" ;
    rdfs:domain wvr:TechnologyStack ;
    rdfs:range xsd:string .

wvr:hasStorage a owl:DatatypeProperty ;
    rdfs:label "has storage" ;
    rdfs:domain wvr:TechnologyStack ;
    rdfs:range xsd:string .

wvr:hasRealtime a owl:DatatypeProperty ;
    rdfs:label "has realtime" ;
    rdfs:domain wvr:TechnologyStack ;
    rdfs:range xsd:string .

wvr:hasAlgorithm a owl:DatatypeProperty ;
    rdfs:label "has algorithm" ;
    rdfs:domain wvr:TechnologyStack ;
    rdfs:range xsd:string .

wvr:hasLibrary a owl:DatatypeProperty ;
    rdfs:label "has library" ;
    rdfs:domain wvr:TechnologyStack ;
    rdfs:range xsd:string .

wvr:hasRule a owl:DatatypeProperty ;
    rdfs:label "has rule" ;
    rdfs:domain wvr:SecurityPolicy ;
    rdfs:range xsd:string .

wvr:hasEntity a owl:ObjectProperty ;
    rdfs:label "has entity" ;
    rdfs:domain wvr:Capability ;
    rdfs:range wvr:Entity .

wvr:hasVariable a owl:ObjectProperty ;
    rdfs:label "has variable" ;
    rdfs:domain wvr:Artifact ;
    rdfs:range weaver:Variable .

wvr:supportsFramework a owl:ObjectProperty ;
    rdfs:label "supports framework" ;
    rdfs:domain wvr:Entity ;
    rdfs:range wvr:ComplianceFramework .

# =============================================================================
# RULES AND CONSTRAINTS
# =============================================================================

## Capability Rules
[] a owl:Restriction ;
    owl:onProperty wvr:hasArtifact ;
    owl:someValuesFrom wvr:Artifact ;
    rdfs:comment "Every capability must have at least one artifact" .

[] a owl:Restriction ;
    owl:onProperty wvr:requiresCompliance ;
    owl:allValuesFrom wvr:ComplianceFramework ;
    rdfs:comment "Compliance requirements must reference valid frameworks" .

## Security Rules
[] a owl:Restriction ;
    owl:onProperty wvr:hasSecurityPolicy ;
    owl:someValuesFrom wvr:SecurityPolicy ;
    rdfs:comment "Security capabilities must have associated security policies" .

[] a owl:Restriction ;
    owl:onProperty wvr:requiresAuthentication ;
    owl:maxCardinality 1 ;
    rdfs:comment "Authentication requirement is a boolean property" .

## Data Rules
[] a owl:Restriction ;
    owl:onProperty wvr:hasAttribute ;
    owl:someValuesFrom owl:DatatypeProperty ;
    rdfs:comment "Entities must have at least one attribute" .

[] a owl:Restriction ;
    owl:onProperty wvr:belongsToLayer ;
    owl:maxCardinality 1 ;
    rdfs:comment "Each artifact belongs to exactly one architectural layer" .

## Artifact Rules
[] a owl:Restriction ;
    owl:onProperty wvr:hasFileExtension ;
    owl:maxCardinality 1 ;
    rdfs:comment "Each artifact has at most one file extension" .

[] a owl:Restriction ;
    owl:onProperty wvr:hasTemplate ;
    owl:maxCardinality 1 ;
    rdfs:comment "Each artifact uses at most one template" .

## Compliance Rules
[] a owl:Restriction ;
    owl:onProperty wvr:requiresEvidence ;
    owl:allValuesFrom wvr:EvidenceType ;
    rdfs:comment "Frameworks can only require valid evidence types" .

# =============================================================================
# INFERENCE RULES (SWRL-style comments for future implementation)
# =============================================================================

# Rule: If a capability requires GDPR compliance, it must implement data encryption
# SecurityCapability(?c) ∧ requiresCompliance(?c, wvr:GDPRFramework) → dependsOn(?c, wvr:DataEncryption)

# Rule: If an entity handles personal data, it requires consent evidence  
# Entity(?e) ∧ handlesPersonalData(?e, true) → requiresEvidence(?e, wvr:ConsentEvidence)

# Rule: If a capability processes sensitive data, it requires audit logging
# Capability(?c) ∧ processesSensitiveData(?c, true) → appliesTo(wvr:Logging, ?c)

# Rule: Security capabilities must have authentication requirements
# SecurityCapability(?c) → requiresAuthentication(?c, true)

# Rule: All artifacts that belong to data layer must have SQL extension or database connection
# Artifact(?a) ∧ belongsToLayer(?a, wvr:DataLayer) → (hasFileExtension(?a, ".sql") ∨ hasDatabase(?a, ?db))

# Rule: VueComponent artifacts must belong to presentation layer
# VueComponent(?a) → belongsToLayer(?a, wvr:PresentationLayer)

# Rule: EdgeFunction artifacts must belong to application layer
# EdgeFunction(?a) → belongsToLayer(?a, wvr:ApplicationLayer)

# Rule: If a capability has a security policy, it is a security capability
# Capability(?c) ∧ hasSecurityPolicy(?c, ?p) → SecurityCapability(?c)

# Rule: Governance capabilities must support at least one compliance framework
# GovernanceCapability(?c) → ∃?f(ComplianceFramework(?f) ∧ supportsFramework(?c, ?f))

# Rule: Monitoring capabilities must have telemetry artifacts
# MonitoringCapability(?c) → ∃?a(TelemetryArtifact(?a) ∧ hasArtifact(?c, ?a))

# =============================================================================
# DISJOINT CLASSES
# =============================================================================

[] a owl:AllDisjointClasses ;
    owl:members (
        wvr:GovernanceCapability
        wvr:SecurityCapability
        wvr:ManagementCapability
        wvr:MonitoringCapability
    ) .

[] a owl:AllDisjointClasses ;
    owl:members (
        wvr:PresentationLayer
        wvr:LogicLayer
        wvr:ApplicationLayer
        wvr:DataLayer
    ) .

[] a owl:AllDisjointClasses ;
    owl:members (
        wvr:AdminRole
        wvr:UserRole
        wvr:AuditorRole
    ) .

# =============================================================================
# EQUIVALENT CLASSES
# =============================================================================

wvr:TelemetryArtifact a owl:Class ;
    rdfs:label "Telemetry Artifact" ;
    owl:equivalentClass [
        a owl:Class ;
        owl:unionOf (
            wvr:MetricsCollector
            wvr:MetricsDashboard
            wvr:TraceCollector
            wvr:TraceAnalyzer
            wvr:LogCollector
            wvr:LogProcessor
        )
    ] .

# =============================================================================
# END OF ONTOLOGY
# =============================================================================