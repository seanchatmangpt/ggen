@prefix a2a: <https://ggen.io/ontology/a2a/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# A2A Protocol v0.3.0 - Task-Related Instance Data
# Source: spec/task.json, spec/events.json
# =============================================================================

# =============================================================================
# TaskState Enum Values
# =============================================================================

a2a:TaskState a a2a:Enum ;
    a2a:name "TaskState" ;
    a2a:description "Represents the possible states of a Task." ;
    a2a:type "string" ;
    a2a:hasValue a2a:TaskState.submitted ,
                 a2a:TaskState.working ,
                 a2a:TaskState.input-required ,
                 a2a:TaskState.completed ,
                 a2a:TaskState.canceled ,
                 a2a:TaskState.failed ,
                 a2a:TaskState.rejected ,
                 a2a:TaskState.auth-required ,
                 a2a:TaskState.unknown .

a2a:TaskState.submitted a a2a:EnumValue ;
    a2a:name "submitted" ;
    a2a:belongsTo a2a:TaskState ;
    a2a:description "The task has been submitted and is awaiting processing." .

a2a:TaskState.working a a2a:EnumValue ;
    a2a:name "working" ;
    a2a:belongsTo a2a:TaskState ;
    a2a:description "The agent is actively working on the task." .

a2a:TaskState.input-required a a2a:EnumValue ;
    a2a:name "input-required" ;
    a2a:belongsTo a2a:TaskState ;
    a2a:description "The agent requires additional input from the client to continue." .

a2a:TaskState.completed a a2a:EnumValue ;
    a2a:name "completed" ;
    a2a:belongsTo a2a:TaskState ;
    a2a:description "The task has been completed successfully." .

a2a:TaskState.canceled a a2a:EnumValue ;
    a2a:name "canceled" ;
    a2a:belongsTo a2a:TaskState ;
    a2a:description "The task has been canceled." .

a2a:TaskState.failed a a2a:EnumValue ;
    a2a:name "failed" ;
    a2a:belongsTo a2a:TaskState ;
    a2a:description "The task has failed." .

a2a:TaskState.rejected a a2a:EnumValue ;
    a2a:name "rejected" ;
    a2a:belongsTo a2a:TaskState ;
    a2a:description "The task has been rejected by the agent." .

a2a:TaskState.auth-required a a2a:EnumValue ;
    a2a:name "auth-required" ;
    a2a:belongsTo a2a:TaskState ;
    a2a:description "The task requires authentication before it can proceed." .

a2a:TaskState.unknown a a2a:EnumValue ;
    a2a:name "unknown" ;
    a2a:belongsTo a2a:TaskState ;
    a2a:description "The task state is unknown." .

# =============================================================================
# Task Entity
# =============================================================================

a2a:Task a a2a:Entity ;
    a2a:name "Task" ;
    a2a:description "Represents a single, stateful operation or conversation between a client and an agent." ;
    a2a:type "object" ;
    a2a:hasProperty a2a:Task.id ,
                    a2a:Task.contextId ,
                    a2a:Task.status ,
                    a2a:Task.history ,
                    a2a:Task.artifacts ,
                    a2a:Task.metadata ,
                    a2a:Task.kind .

a2a:Task.id a a2a:Property ;
    a2a:name "id" ;
    a2a:type "string" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "A unique identifier (e.g. UUID) for the task, generated by the server for a new task." ;
    a2a:belongsTo a2a:Task .

a2a:Task.contextId a a2a:Property ;
    a2a:name "contextId" ;
    a2a:type "string" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "A server-generated unique identifier (e.g. UUID) for maintaining context across multiple related tasks or interactions." ;
    a2a:belongsTo a2a:Task .

a2a:Task.status a a2a:Property ;
    a2a:name "status" ;
    a2a:type "TaskStatus" ;
    a2a:refType a2a:TaskStatus ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "The current status of the task, including its state and a descriptive message." ;
    a2a:belongsTo a2a:Task .

a2a:Task.history a a2a:Property ;
    a2a:name "history" ;
    a2a:type "array" ;
    a2a:items "Message" ;
    a2a:required "false"^^xsd:boolean ;
    a2a:description "An array of messages exchanged during the task, representing the conversation history." ;
    a2a:belongsTo a2a:Task .

a2a:Task.artifacts a a2a:Property ;
    a2a:name "artifacts" ;
    a2a:type "array" ;
    a2a:items "Artifact" ;
    a2a:required "false"^^xsd:boolean ;
    a2a:description "A collection of artifacts generated by the agent during the execution of the task." ;
    a2a:belongsTo a2a:Task .

a2a:Task.metadata a a2a:Property ;
    a2a:name "metadata" ;
    a2a:type "object" ;
    a2a:required "false"^^xsd:boolean ;
    a2a:description "Optional metadata for extensions. The key is an extension-specific identifier." ;
    a2a:belongsTo a2a:Task .

a2a:Task.kind a a2a:Property ;
    a2a:name "kind" ;
    a2a:type "string" ;
    a2a:constValue "task" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "The type of this object, used as a discriminator. Always 'task' for a Task." ;
    a2a:belongsTo a2a:Task .

# =============================================================================
# TaskStatus Entity
# =============================================================================

a2a:TaskStatus a a2a:Entity ;
    a2a:name "TaskStatus" ;
    a2a:description "Represents the status of a task at a specific point in time." ;
    a2a:type "object" ;
    a2a:hasProperty a2a:TaskStatus.state ,
                    a2a:TaskStatus.message ,
                    a2a:TaskStatus.timestamp .

a2a:TaskStatus.state a a2a:Property ;
    a2a:name "state" ;
    a2a:type "TaskState" ;
    a2a:refType a2a:TaskState ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "The current state of the task's lifecycle." ;
    a2a:enumValues a2a:TaskState.submitted ,
                   a2a:TaskState.working ,
                   a2a:TaskState.input-required ,
                   a2a:TaskState.completed ,
                   a2a:TaskState.canceled ,
                   a2a:TaskState.failed ,
                   a2a:TaskState.rejected ,
                   a2a:TaskState.auth-required ,
                   a2a:TaskState.unknown ;
    a2a:belongsTo a2a:TaskStatus .

a2a:TaskStatus.message a a2a:Property ;
    a2a:name "message" ;
    a2a:type "Message" ;
    a2a:required "false"^^xsd:boolean ;
    a2a:description "An optional, human-readable message providing more details about the current status." ;
    a2a:belongsTo a2a:TaskStatus .

a2a:TaskStatus.timestamp a a2a:Property ;
    a2a:name "timestamp" ;
    a2a:type "string" ;
    a2a:required "false"^^xsd:boolean ;
    a2a:description "An ISO 8601 datetime string indicating when this status was recorded." ;
    a2a:belongsTo a2a:TaskStatus .

# =============================================================================
# TaskStatusUpdateEvent Entity
# =============================================================================

a2a:TaskStatusUpdateEvent a a2a:Entity ;
    a2a:name "TaskStatusUpdateEvent" ;
    a2a:description "Sent by server during sendStream or subscribe requests to notify the client of a task status change." ;
    a2a:type "object" ;
    a2a:hasProperty a2a:TaskStatusUpdateEvent.taskId ,
                    a2a:TaskStatusUpdateEvent.contextId ,
                    a2a:TaskStatusUpdateEvent.final ,
                    a2a:TaskStatusUpdateEvent.status ,
                    a2a:TaskStatusUpdateEvent.metadata ,
                    a2a:TaskStatusUpdateEvent.kind .

a2a:TaskStatusUpdateEvent.taskId a a2a:Property ;
    a2a:name "taskId" ;
    a2a:type "string" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "Task id." ;
    a2a:belongsTo a2a:TaskStatusUpdateEvent .

a2a:TaskStatusUpdateEvent.contextId a a2a:Property ;
    a2a:name "contextId" ;
    a2a:type "string" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "The context the task is associated with." ;
    a2a:belongsTo a2a:TaskStatusUpdateEvent .

a2a:TaskStatusUpdateEvent.final a a2a:Property ;
    a2a:name "final" ;
    a2a:type "boolean" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "Indicates the end of the event stream." ;
    a2a:belongsTo a2a:TaskStatusUpdateEvent .

a2a:TaskStatusUpdateEvent.status a a2a:Property ;
    a2a:name "status" ;
    a2a:type "TaskStatus" ;
    a2a:refType a2a:TaskStatus ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "Current status of the task." ;
    a2a:belongsTo a2a:TaskStatusUpdateEvent .

a2a:TaskStatusUpdateEvent.metadata a a2a:Property ;
    a2a:name "metadata" ;
    a2a:type "object" ;
    a2a:required "false"^^xsd:boolean ;
    a2a:description "Extension metadata." ;
    a2a:belongsTo a2a:TaskStatusUpdateEvent .

a2a:TaskStatusUpdateEvent.kind a a2a:Property ;
    a2a:name "kind" ;
    a2a:type "string" ;
    a2a:constValue "status-update" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "Event type discriminator. Always 'status-update' for TaskStatusUpdateEvent." ;
    a2a:belongsTo a2a:TaskStatusUpdateEvent .

# =============================================================================
# TaskArtifactUpdateEvent Entity
# =============================================================================

a2a:TaskArtifactUpdateEvent a a2a:Entity ;
    a2a:name "TaskArtifactUpdateEvent" ;
    a2a:description "Sent by server during sendStream or subscribe requests to deliver an artifact update to the client." ;
    a2a:type "object" ;
    a2a:hasProperty a2a:TaskArtifactUpdateEvent.taskId ,
                    a2a:TaskArtifactUpdateEvent.contextId ,
                    a2a:TaskArtifactUpdateEvent.artifact ,
                    a2a:TaskArtifactUpdateEvent.metadata ,
                    a2a:TaskArtifactUpdateEvent.kind ,
                    a2a:TaskArtifactUpdateEvent.append ,
                    a2a:TaskArtifactUpdateEvent.lastChunk .

a2a:TaskArtifactUpdateEvent.taskId a a2a:Property ;
    a2a:name "taskId" ;
    a2a:type "string" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "Task id." ;
    a2a:belongsTo a2a:TaskArtifactUpdateEvent .

a2a:TaskArtifactUpdateEvent.contextId a a2a:Property ;
    a2a:name "contextId" ;
    a2a:type "string" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "The context the task is associated with." ;
    a2a:belongsTo a2a:TaskArtifactUpdateEvent .

a2a:TaskArtifactUpdateEvent.artifact a a2a:Property ;
    a2a:name "artifact" ;
    a2a:type "Artifact" ;
    a2a:refType a2a:Artifact ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "Generated artifact." ;
    a2a:belongsTo a2a:TaskArtifactUpdateEvent .

a2a:TaskArtifactUpdateEvent.metadata a a2a:Property ;
    a2a:name "metadata" ;
    a2a:type "object" ;
    a2a:required "false"^^xsd:boolean ;
    a2a:description "Extension metadata." ;
    a2a:belongsTo a2a:TaskArtifactUpdateEvent .

a2a:TaskArtifactUpdateEvent.kind a a2a:Property ;
    a2a:name "kind" ;
    a2a:type "string" ;
    a2a:constValue "artifact-update" ;
    a2a:required "true"^^xsd:boolean ;
    a2a:description "Event type discriminator. Always 'artifact-update' for TaskArtifactUpdateEvent." ;
    a2a:belongsTo a2a:TaskArtifactUpdateEvent .

a2a:TaskArtifactUpdateEvent.append a a2a:Property ;
    a2a:name "append" ;
    a2a:type "boolean" ;
    a2a:required "false"^^xsd:boolean ;
    a2a:description "Indicates if this artifact appends to a previous one." ;
    a2a:belongsTo a2a:TaskArtifactUpdateEvent .

a2a:TaskArtifactUpdateEvent.lastChunk a a2a:Property ;
    a2a:name "lastChunk" ;
    a2a:type "boolean" ;
    a2a:required "false"^^xsd:boolean ;
    a2a:description "Indicates if this is the last chunk of the artifact." ;
    a2a:belongsTo a2a:TaskArtifactUpdateEvent .
