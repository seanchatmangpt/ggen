@prefix a2a: <https://ggen.io/ontology/a2a/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# A2A Protocol v0.3.0 - Message Instance Data
#
# RDF/Turtle instance definitions for all Message-related types derived from
# the A2A protocol JSON schema (spec/message.json and spec/task.json).
# =============================================================================

# -----------------------------------------------------------------------------
# Enum: Role
# Identifies the sender of a message.
# -----------------------------------------------------------------------------

a2a:Role a a2a:Enum ;
    a2a:enumName "Role" ;
    a2a:description "Identifies the sender of the message." ;
    a2a:hasEnumValue a2a:Role_User, a2a:Role_Agent .

a2a:Role_User a a2a:EnumValue ;
    a2a:valueName "user" ;
    a2a:description "The client/user role." .

a2a:Role_Agent a a2a:EnumValue ;
    a2a:valueName "agent" ;
    a2a:description "The agent/service role." .

# -----------------------------------------------------------------------------
# Entity: Message
# Represents a single message in the conversation between a user and an agent.
# -----------------------------------------------------------------------------

a2a:Message a a2a:Entity ;
    a2a:entityName "Message" ;
    a2a:description "Represents a single message in the conversation between a user and an agent." ;
    a2a:hasProperty a2a:Message_kind,
                    a2a:Message_messageId,
                    a2a:Message_role,
                    a2a:Message_parts,
                    a2a:Message_taskId,
                    a2a:Message_contextId,
                    a2a:Message_referenceTaskIds,
                    a2a:Message_metadata,
                    a2a:Message_extensions .

a2a:Message_kind a a2a:Property ;
    a2a:propertyName "kind" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "The type of this object, used as a discriminator. Always 'message' for a Message." ;
    a2a:formatConstraint "const: \"message\"" .

a2a:Message_messageId a a2a:Property ;
    a2a:propertyName "messageId" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "A unique identifier for the message, typically a UUID, generated by the sender." ;
    a2a:formatConstraint "UUID format recommended" .

a2a:Message_role a a2a:Property ;
    a2a:propertyName "role" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "Identifies the sender of the message. 'user' for the client, 'agent' for the service." ;
    a2a:formatConstraint "enum: [\"agent\", \"user\"]" ;
    a2a:referencesEnum a2a:Role .

a2a:Message_parts a a2a:Property ;
    a2a:propertyName "parts" ;
    a2a:propertyType "array" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "An array of content parts that form the message body. A message can be composed of multiple parts of different types (e.g., text and files)." ;
    a2a:formatConstraint "items: Part (TextPart | FilePart | DataPart)" ;
    a2a:referencesEntity a2a:Part .

a2a:Message_taskId a a2a:Property ;
    a2a:propertyName "taskId" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "The ID of the task this message is part of. Can be omitted for the first message of a new task." ;
    a2a:formatConstraint "UUID format recommended" .

a2a:Message_contextId a a2a:Property ;
    a2a:propertyName "contextId" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "The context ID for this message, used to group related interactions." ;
    a2a:formatConstraint "none" .

a2a:Message_referenceTaskIds a a2a:Property ;
    a2a:propertyName "referenceTaskIds" ;
    a2a:propertyType "array" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "A list of other task IDs that this message references for additional context." ;
    a2a:formatConstraint "items: string" .

a2a:Message_metadata a a2a:Property ;
    a2a:propertyName "metadata" ;
    a2a:propertyType "object" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional metadata for extensions. The key is an extension-specific identifier." ;
    a2a:formatConstraint "additionalProperties allowed; free-form key-value map" .

a2a:Message_extensions a a2a:Property ;
    a2a:propertyName "extensions" ;
    a2a:propertyType "array" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "The URIs of extensions that are relevant to this message." ;
    a2a:formatConstraint "items: string (URI)" .

# -----------------------------------------------------------------------------
# Entity: Part (abstract union type)
# Represents a part of a message, which can be text, a file, or structured data.
# -----------------------------------------------------------------------------

a2a:Part a a2a:Entity ;
    a2a:entityName "Part" ;
    a2a:description "Represents a part of a message, which can be text, a file, or structured data. Abstract union type resolved via the 'kind' discriminator." ;
    a2a:isAbstract "true"^^xsd:boolean ;
    a2a:hasVariant a2a:TextPart, a2a:FilePart, a2a:DataPart .

# -----------------------------------------------------------------------------
# Entity: PartBase
# Base properties common to all message parts.
# -----------------------------------------------------------------------------

a2a:PartBase a a2a:Entity ;
    a2a:entityName "PartBase" ;
    a2a:description "Base properties common to all message parts." ;
    a2a:isAbstract "true"^^xsd:boolean ;
    a2a:hasProperty a2a:PartBase_metadata .

a2a:PartBase_metadata a a2a:Property ;
    a2a:propertyName "metadata" ;
    a2a:propertyType "object" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional metadata associated with the part." ;
    a2a:formatConstraint "additionalProperties allowed; free-form key-value map" .

# -----------------------------------------------------------------------------
# Entity: TextPart
# Represents a text segment within parts.
# -----------------------------------------------------------------------------

a2a:TextPart a a2a:Entity ;
    a2a:entityName "TextPart" ;
    a2a:description "Represents a text segment within parts." ;
    a2a:extendsEntity a2a:PartBase ;
    a2a:hasProperty a2a:TextPart_kind,
                    a2a:TextPart_text,
                    a2a:TextPart_metadata .

a2a:TextPart_kind a a2a:Property ;
    a2a:propertyName "kind" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "Part type discriminator for TextPart." ;
    a2a:formatConstraint "const: \"text\"" .

a2a:TextPart_text a a2a:Property ;
    a2a:propertyName "text" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "Text content." ;
    a2a:formatConstraint "none" .

a2a:TextPart_metadata a a2a:Property ;
    a2a:propertyName "metadata" ;
    a2a:propertyType "object" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional metadata associated with the part." ;
    a2a:formatConstraint "additionalProperties allowed; free-form key-value map" .

# -----------------------------------------------------------------------------
# Entity: FilePart
# Represents a file segment within parts.
# -----------------------------------------------------------------------------

a2a:FilePart a a2a:Entity ;
    a2a:entityName "FilePart" ;
    a2a:description "Represents a File segment within parts." ;
    a2a:extendsEntity a2a:PartBase ;
    a2a:hasProperty a2a:FilePart_kind,
                    a2a:FilePart_file,
                    a2a:FilePart_metadata .

a2a:FilePart_kind a a2a:Property ;
    a2a:propertyName "kind" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "Part type discriminator for FilePart." ;
    a2a:formatConstraint "const: \"file\"" .

a2a:FilePart_file a a2a:Property ;
    a2a:propertyName "file" ;
    a2a:propertyType "object" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "File content either as URL or bytes." ;
    a2a:formatConstraint "anyOf: FileWithBytes | FileWithUri" ;
    a2a:referencesEntity a2a:FileBase .

a2a:FilePart_metadata a a2a:Property ;
    a2a:propertyName "metadata" ;
    a2a:propertyType "object" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional metadata associated with the part." ;
    a2a:formatConstraint "additionalProperties allowed; free-form key-value map" .

# -----------------------------------------------------------------------------
# Entity: DataPart
# Represents a structured data segment within a message part.
# -----------------------------------------------------------------------------

a2a:DataPart a a2a:Entity ;
    a2a:entityName "DataPart" ;
    a2a:description "Represents a structured data segment within a message part." ;
    a2a:extendsEntity a2a:PartBase ;
    a2a:hasProperty a2a:DataPart_kind,
                    a2a:DataPart_data,
                    a2a:DataPart_metadata .

a2a:DataPart_kind a a2a:Property ;
    a2a:propertyName "kind" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "Part type discriminator for DataPart." ;
    a2a:formatConstraint "const: \"data\"" .

a2a:DataPart_data a a2a:Property ;
    a2a:propertyName "data" ;
    a2a:propertyType "object" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "Structured data content as a JSON object." ;
    a2a:formatConstraint "additionalProperties allowed; free-form JSON object" .

a2a:DataPart_metadata a a2a:Property ;
    a2a:propertyName "metadata" ;
    a2a:propertyType "object" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional metadata associated with the part." ;
    a2a:formatConstraint "additionalProperties allowed; free-form key-value map" .

# -----------------------------------------------------------------------------
# Entity: FileBase
# Base properties shared by all file representations.
# -----------------------------------------------------------------------------

a2a:FileBase a a2a:Entity ;
    a2a:entityName "FileBase" ;
    a2a:description "Represents the base entity for FileParts." ;
    a2a:isAbstract "true"^^xsd:boolean ;
    a2a:hasProperty a2a:FileBase_name,
                    a2a:FileBase_mimeType .

a2a:FileBase_name a a2a:Property ;
    a2a:propertyName "name" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional name for the file." ;
    a2a:formatConstraint "none" .

a2a:FileBase_mimeType a a2a:Property ;
    a2a:propertyName "mimeType" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional MIME type for the file." ;
    a2a:formatConstraint "IANA media type (e.g. \"application/pdf\", \"image/png\")" .

# -----------------------------------------------------------------------------
# Entity: FileWithBytes
# File variant where content is provided as inline base64-encoded bytes.
# -----------------------------------------------------------------------------

a2a:FileWithBytes a a2a:Entity ;
    a2a:entityName "FileWithBytes" ;
    a2a:description "Define the variant where 'bytes' is present and 'uri' is absent." ;
    a2a:extendsEntity a2a:FileBase ;
    a2a:hasProperty a2a:FileWithBytes_bytes,
                    a2a:FileWithBytes_name,
                    a2a:FileWithBytes_mimeType .

a2a:FileWithBytes_bytes a a2a:Property ;
    a2a:propertyName "bytes" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "Base64 encoded content of the file." ;
    a2a:formatConstraint "base64 encoding" .

a2a:FileWithBytes_name a a2a:Property ;
    a2a:propertyName "name" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional name for the file." ;
    a2a:formatConstraint "none" .

a2a:FileWithBytes_mimeType a a2a:Property ;
    a2a:propertyName "mimeType" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional MIME type for the file." ;
    a2a:formatConstraint "IANA media type (e.g. \"application/pdf\", \"image/png\")" .

# -----------------------------------------------------------------------------
# Entity: FileWithUri
# File variant where content is referenced by a URI.
# -----------------------------------------------------------------------------

a2a:FileWithUri a a2a:Entity ;
    a2a:entityName "FileWithUri" ;
    a2a:description "Define the variant where 'uri' is present and 'bytes' is absent." ;
    a2a:extendsEntity a2a:FileBase ;
    a2a:hasProperty a2a:FileWithUri_uri,
                    a2a:FileWithUri_name,
                    a2a:FileWithUri_mimeType .

a2a:FileWithUri_uri a a2a:Property ;
    a2a:propertyName "uri" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "URL for the File content." ;
    a2a:formatConstraint "valid URI (RFC 3986)" .

a2a:FileWithUri_name a a2a:Property ;
    a2a:propertyName "name" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional name for the file." ;
    a2a:formatConstraint "none" .

a2a:FileWithUri_mimeType a a2a:Property ;
    a2a:propertyName "mimeType" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional MIME type for the file." ;
    a2a:formatConstraint "IANA media type (e.g. \"application/pdf\", \"image/png\")" .

# -----------------------------------------------------------------------------
# Entity: Artifact
# Represents a file, data structure, or other resource generated by an agent
# during a task.
# -----------------------------------------------------------------------------

a2a:Artifact a a2a:Entity ;
    a2a:entityName "Artifact" ;
    a2a:description "Represents a file, data structure, or other resource generated by an agent during a task." ;
    a2a:hasProperty a2a:Artifact_artifactId,
                    a2a:Artifact_name,
                    a2a:Artifact_description,
                    a2a:Artifact_parts,
                    a2a:Artifact_metadata,
                    a2a:Artifact_extensions .

a2a:Artifact_artifactId a a2a:Property ;
    a2a:propertyName "artifactId" ;
    a2a:propertyType "string" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "A unique identifier (e.g. UUID) for the artifact within the scope of the task." ;
    a2a:formatConstraint "UUID format recommended" .

a2a:Artifact_name a a2a:Property ;
    a2a:propertyName "name" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "An optional, human-readable name for the artifact." ;
    a2a:formatConstraint "none" .

a2a:Artifact_description a a2a:Property ;
    a2a:propertyName "description" ;
    a2a:propertyType "string" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "An optional, human-readable description of the artifact." ;
    a2a:formatConstraint "none" .

a2a:Artifact_parts a a2a:Property ;
    a2a:propertyName "parts" ;
    a2a:propertyType "array" ;
    a2a:isRequired "true"^^xsd:boolean ;
    a2a:description "An array of content parts that make up the artifact." ;
    a2a:formatConstraint "items: Part (TextPart | FilePart | DataPart)" ;
    a2a:referencesEntity a2a:Part .

a2a:Artifact_metadata a a2a:Property ;
    a2a:propertyName "metadata" ;
    a2a:propertyType "object" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "Optional metadata for extensions. The key is an extension-specific identifier." ;
    a2a:formatConstraint "additionalProperties allowed; free-form key-value map" .

a2a:Artifact_extensions a a2a:Property ;
    a2a:propertyName "extensions" ;
    a2a:propertyType "array" ;
    a2a:isRequired "false"^^xsd:boolean ;
    a2a:description "The URIs of extensions that are relevant to this artifact." ;
    a2a:formatConstraint "items: string (URI)" .
