feat:TimeTravel a feat:ProductionFeature ;
    rdfs:label "Time Travel Queries" ;
    feat:status feat:Implemented ;
    feat:priority "P2" ;
    feat:completeness 1.0 ;
    feat:implementedIn "internal/timetravel/query.go" ;
