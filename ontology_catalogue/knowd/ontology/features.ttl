    feat:priority "P0" ;
    feat:completeness 1.0 ;
    feat:implementedIn "internal/gdpr/rights.go" ;
    feat:testCoverage 0.90 ;
    rdfs:comment "Right to erasure, access, and data portability" .

feat:AuditLogging a feat:ComplianceFeature ;
    rdfs:label "Audit Logging" ;
    feat:status feat:Implemented ;
    feat:priority "P0" ;
    feat:completeness 1.0 ;
    feat:implementedIn "internal/audit/logger.go" ;
    feat:testCoverage 0.88 ;
    rdfs:comment "Immutable audit trail for all operations" .

# P0 - Performance Testing
feat:LoadTesting a feat:PerformanceFeature ;
    rdfs:label "Load Testing Suite" ;
    feat:status feat:Implemented ;
    feat:priority "P0" ;
    feat:completeness 1.0 ;
    feat:implementedIn "loadtest/k6/" ;
    feat:validates feat:PrometheusMetrics ;
    rdfs:comment "K6-based load testing for production scenarios" .

