@prefix feat: <http://knowd.io/features#> .
@prefix knowd: <http://knowd.io/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Feature Ontology for Production Readiness Tracking

# Feature classes
feat:ProductionFeature a owl:Class ;
    rdfs:label "Production Feature" ;
    rdfs:comment "A feature required for production deployment" .

feat:SecurityFeature rdfs:subClassOf feat:ProductionFeature ;
    rdfs:label "Security Feature" ;
    rdfs:comment "Security-related feature (encryption, auth, etc.)" .

feat:PerformanceFeature rdfs:subClassOf feat:ProductionFeature ;
    rdfs:label "Performance Feature" ;
    rdfs:comment "Performance optimization feature" .

feat:ComplianceFeature rdfs:subClassOf feat:ProductionFeature ;
    rdfs:label "Compliance Feature" ;
    rdfs:comment "Regulatory compliance feature (GDPR, etc.)" .

feat:ObservabilityFeature rdfs:subClassOf feat:ProductionFeature ;
    rdfs:label "Observability Feature" ;
    rdfs:comment "Monitoring, logging, and tracing features" .

# Status class
feat:Status a owl:Class ;
    rdfs:label "Feature Status" .

# Properties
feat:status a owl:ObjectProperty ;
    rdfs:label "has status" ;
    rdfs:domain feat:ProductionFeature ;
    rdfs:range feat:Status .

feat:priority a owl:DatatypeProperty ;
    rdfs:label "priority level" ;
    rdfs:domain feat:ProductionFeature ;
    rdfs:range xsd:string ;
    rdfs:comment "Priority: P0 (critical), P1 (important), P2 (nice-to-have)" .

feat:completeness a owl:DatatypeProperty ;
    rdfs:label "completeness score" ;
    rdfs:domain feat:ProductionFeature ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Completeness from 0.0 to 1.0" .

feat:blocksProduction a owl:ObjectProperty ;
    rdfs:label "blocks production" ;
    rdfs:domain feat:ProductionFeature ;
    rdfs:range feat:ProductionFeature ;
    rdfs:comment "This feature blocks another feature from production" .

feat:jiraTicket a owl:DatatypeProperty ;
    rdfs:label "JIRA ticket" ;
    rdfs:domain feat:ProductionFeature ;
    rdfs:range xsd:string .

feat:implementedIn a owl:DatatypeProperty ;
    rdfs:label "implemented in" ;
    rdfs:domain feat:ProductionFeature ;
    rdfs:range xsd:string ;
    rdfs:comment "File path where feature is implemented" .

feat:testCoverage a owl:DatatypeProperty ;
    rdfs:label "test coverage" ;
    rdfs:domain feat:ProductionFeature ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Test coverage from 0.0 to 1.0" .

feat:performanceImprovement a owl:DatatypeProperty ;
    rdfs:label "performance improvement" ;
    rdfs:domain feat:PerformanceFeature ;
    rdfs:range xsd:string .

feat:cacheHitRate a owl:DatatypeProperty ;
    rdfs:label "cache hit rate" ;
    rdfs:domain feat:PerformanceFeature ;
    rdfs:range xsd:decimal .

feat:requiresLLM a owl:DatatypeProperty ;
    rdfs:label "requires LLM" ;
    rdfs:domain feat:ProductionFeature ;
    rdfs:range xsd:boolean .

feat:validates a owl:ObjectProperty ;
    rdfs:label "validates" ;
    rdfs:domain feat:ProductionFeature ;
    rdfs:range feat:ProductionFeature ;
    rdfs:comment "This feature validates another feature" .

# Status instances
feat:NotStarted a feat:Status ;
    rdfs:label "Not Started" .

feat:InProgress a feat:Status ;
    rdfs:label "In Progress" .

feat:Implemented a feat:Status ;
    rdfs:label "Implemented" .

feat:Tested a feat:Status ;
    rdfs:label "Tested" .

feat:Deployed a feat:Status ;
    rdfs:label "Deployed" .

# ============================================================================
# ACTUAL PRODUCTION FEATURES FROM VALIDATION CHECKLIST
# ============================================================================

# P0 - Critical Security Features
feat:EncryptionAtRest a feat:SecurityFeature ;
    rdfs:label "Encryption at Rest" ;
    feat:status feat:Implemented ;
    feat:priority "P0" ;
    feat:completeness 1.0 ;
    feat:jiraTicket "KNOW-001" ;
    feat:implementedIn "internal/crypto/encryption.go" ;
    feat:testCoverage 0.95 ;
    rdfs:comment "AES-256-GCM encryption for all stored data" .

feat:mTLSAuthentication a feat:SecurityFeature ;
    rdfs:label "mTLS Authentication" ;
    feat:status feat:Implemented ;
    feat:priority "P0" ;
    feat:completeness 1.0 ;
    feat:jiraTicket "KNOW-002" ;
    feat:implementedIn "internal/auth/mtls.go" ;
    feat:testCoverage 0.92 ;
    rdfs:comment "Mutual TLS certificate-based authentication" .

feat:AccessControl a feat:SecurityFeature ;
    rdfs:label "Role-Based Access Control" ;
    feat:status feat:Implemented ;
    feat:priority "P0" ;
    feat:completeness 1.0 ;
    feat:jiraTicket "KNOW-003" ;
    feat:implementedIn "internal/auth/rbac.go" ;
    feat:testCoverage 0.88 ;
    rdfs:comment "RBAC with namespace-level permissions" .

