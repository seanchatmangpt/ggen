@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/TestOntology> a owl:Ontology ;
    rdfs:label "Test Ontology"@en ;
    rdfs:comment "A well-formed Turtle fixture for mcpp onto-validate testing."@en .

<https://example.org/TestClass> a owl:Class ;
    rdfs:label "Test Class"@en ;
    rdfs:comment "A simple class."@en .
