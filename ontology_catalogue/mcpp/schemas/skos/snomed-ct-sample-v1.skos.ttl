@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sct:  <https://w3id.org/mcpp/skos/snomed-ct-sample-v1/> .

# ----------------------------------------------------------------------
# SNOMED-CT sample SKOS scheme (v26.5.17 Slice F)
#
# Sample subset of SNOMED-CT concept identifiers used by the healthcare
# ADE fixtures. Covers anatomical sites, administration routes, and
# adverse-event types. NOT a clinically authoritative replication —
# full SNOMED-CT loaded out-of-band in production under a SNOMED
# International license.
# ----------------------------------------------------------------------

sct:Scheme a skos:ConceptScheme ;
    skos:prefLabel "SNOMED-CT (sample subset, v1)"@en ;
    skos:notation  "snomed-ct-sample-v1" ;
    skos:definition "Sample subset of SNOMED-CT clinical concepts used by mcpp v26.5.17 healthcare fixtures."@en .

