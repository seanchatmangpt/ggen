@prefix ex: <http://example.org/gitvan/hooks/> .
@prefix gv: <https://gitvan.dev/ontology#> .
@prefix gh: <https://gitvan.dev/graph-hook#> .
@prefix op: <https://gitvan.dev/op#> .
@prefix git: <https://gitvan.dev/git#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# =============================================================================
# Auto-Deploy on Version Tag Hook
# =============================================================================
#
# USE CASE:
# Automatically trigger deployment workflows when version tags are created
# Supports semantic versioning (v1.0.0, v2.1.3) and environment-specific deploys
#
# TRIGGERS ON:
# - post-tag (after git tag is created)
# - post-push (when tag is pushed to remote)
#
# SUCCESS CRITERIA:
# - Detects semantic version tags (v*.*.*)
# - Determines deployment environment (production, staging, preview)
# - Triggers appropriate CI/CD pipeline
# - Records deployment metadata in knowledge graph
#
# INSTALLATION:
# 1. Copy to .gitvan/hooks/deploy-on-version-tag.ttl
# 2. Configure deployment URLs:
#    git config gitvan.deploy.production "https://api.deploy.com/prod"
#    git config gitvan.deploy.staging "https://api.deploy.com/staging"
# 3. Set deployment credentials:
#    git config gitvan.deploy.token "your-deploy-token"
# 4. Enable hook: gitvan hooks enable deploy-on-version-tag
#
# =============================================================================

ex:deploy-on-version-tag-hook rdf:type gh:Hook ;
    rdfs:label "Auto-Deploy on Version Tag" ;
    gv:title "Automated Deployment on Version Tags" ;
    rdfs:comment "Triggers deployment workflows when semantic version tags are created" ;
    gh:hookType "post-tag" ;
    gh:priority 50 ;
    gh:enabled true ;
    gh:hasPredicate ex:version-tag-predicate ;
    gh:orderedPipelines ex:deployment-pipeline .

# =============================================================================
# ASK Predicate - Detects Version Tags
# =============================================================================
ex:version-tag-predicate rdf:type gh:ASKPredicate ;
    gh:queryText """
        PREFIX git: <https://gitvan.dev/git#>
        PREFIX gv: <https://gitvan.dev/ontology#>
        PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

        ASK WHERE {
            # Detect newly created tags
            ?tag rdf:type git:Tag ;
                 git:tagName ?name ;
                 git:createdAt ?created .

            # Filter for semantic version tags (v1.0.0, v2.1.3, etc.)
            FILTER(REGEX(?name, "^v[0-9]+\\.[0-9]+\\.[0-9]+(-[a-z0-9.-]+)?$", "i"))

            # Ensure this is a recent tag (created in last 5 minutes)
            BIND(NOW() - ?created AS ?age)
            FILTER(?age < "PT5M"^^xsd:duration)
        }
    """ ;
    gh:description "Detects semantic version tags for automated deployment" .

# =============================================================================
# Pipeline - Automated Deployment Workflow
# =============================================================================
ex:deployment-pipeline rdf:type op:Pipeline ;
    rdfs:label "Automated Deployment Pipeline" ;
    op:steps (
        ex:parse-version-tag,
        ex:determine-environment,
        ex:validate-deployment-readiness,
        ex:trigger-deployment,
        ex:record-deployment-metadata,
        ex:generate-deployment-report
    ) .

# =============================================================================
# Step 1: Parse Version Tag
# =============================================================================
ex:parse-version-tag rdf:type gv:SparqlStep ;
    rdfs:label "Parse Version Tag Information" ;
    gv:text """
        PREFIX git: <https://gitvan.dev/git#>
        PREFIX gv: <https://gitvan.dev/ontology#>
        PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

        SELECT ?tagName ?major ?minor ?patch ?prerelease ?commit ?author ?message WHERE {
            # Get the newly created tag
            ?tag rdf:type git:Tag ;
                 git:tagName ?tagName ;
                 git:pointsTo ?commit .

            ?commit git:author ?author ;
                    git:message ?message ;
                    git:sha ?commitSha .

            # Parse semantic version components
            # Format: v1.2.3 or v1.2.3-beta.1
            BIND(REPLACE(?tagName, "^v([0-9]+)\\.[0-9]+\\.[0-9]+.*", "$1") AS ?major)
            BIND(REPLACE(?tagName, "^v[0-9]+\\.([0-9]+)\\.[0-9]+.*", "$1") AS ?minor)
            BIND(REPLACE(?tagName, "^v[0-9]+\\.[0-9]+\\.([0-9]+).*", "$1") AS ?patch)

            # Extract prerelease identifier if present
            OPTIONAL {
                FILTER(REGEX(?tagName, "-[a-z0-9.-]+$", "i"))
                BIND(REPLACE(?tagName, "^v[0-9]+\\.[0-9]+\\.[0-9]+-(.+)$", "$1") AS ?prerelease)
            }

            FILTER(REGEX(?tagName, "^v[0-9]+\\.[0-9]+\\.[0-9]+", "i"))
        }
        ORDER BY DESC(?tagName)
        LIMIT 1
    """ ;
    gv:outputMapping '{
        "version": "results[0].tagName.value",
        "major": "parseInt(results[0].major.value)",
        "minor": "parseInt(results[0].minor.value)",
        "patch": "parseInt(results[0].patch.value)",
        "prerelease": "results[0].prerelease ? results[0].prerelease.value : null",
        "commit": "results[0].commit.value",
        "commitSha": "results[0].commitSha.value.substring(0, 7)",
        "author": "results[0].author.value",
        "message": "results[0].message.value"
    }' .

# =============================================================================
# Step 2: Determine Deployment Environment
# =============================================================================
ex:determine-environment rdf:type gv:SparqlStep ;
    rdfs:label "Determine Deployment Environment" ;
    gv:text """
        PREFIX git: <https://gitvan.dev/git#>
        PREFIX gv: <https://gitvan.dev/ontology#>
        PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

        SELECT ?environment ?deployUrl ?requiresApproval WHERE {
            ?tag rdf:type git:Tag ;
                 git:tagName ?tagName .

            # Determine environment based on version pattern
            BIND(
                IF(REGEX(?tagName, "-alpha|-beta|-rc", "i"), "staging",
                IF(REGEX(?tagName, "^v[0-9]+\\.0\\.0$"), "production",
                IF(REGEX(?tagName, "^v[0-9]+\\.[0-9]+\\.0$"), "production",
                "production")))
                AS ?environment
            )

            # Set deployment URL based on environment
            BIND(
                IF(?environment = "production",
                   "https://api.deploy.com/prod",
                   "https://api.deploy.com/staging")
                AS ?deployUrl
            )

            # Production deployments require approval
            BIND(?environment = "production" AS ?requiresApproval)
        }
    """ ;
    gv:outputMapping '{
        "environment": "results[0].environment.value",
        "deployUrl": "results[0].deployUrl.value",
        "requiresApproval": "results[0].requiresApproval.value === \"true\"",
        "isProduction": "results[0].environment.value === \"production\"",
        "isPrerelease": "prerelease !== null"
    }' ;
    gv:dependsOn ex:parse-version-tag .

# =============================================================================
# Step 3: Validate Deployment Readiness
# =============================================================================
ex:validate-deployment-readiness rdf:type gv:SparqlStep ;
    rdfs:label "Validate Deployment Readiness" ;
    gv:text """
        PREFIX git: <https://gitvan.dev/git#>
        PREFIX gv: <https://gitvan.dev/ontology#>
        PREFIX ci: <https://gitvan.dev/ci#>
        PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

        SELECT ?testsPass ?buildSuccess ?securityScanPass ?readyToDeploy WHERE {
            ?commit rdf:type git:Commit .
            ?tag git:pointsTo ?commit .

            # Check CI/CD status
            OPTIONAL {
                ?commit ci:hasTestRun ?testRun .
                ?testRun ci:status ?testStatus .
                BIND(?testStatus = "passed" AS ?testsPass)
            }

            OPTIONAL {
                ?commit ci:hasBuild ?build .
                ?build ci:status ?buildStatus .
                BIND(?buildStatus = "success" AS ?buildSuccess)
            }

            OPTIONAL {
                ?commit ci:hasSecurityScan ?scan .
                ?scan ci:vulnerabilities ?vulnCount .
                BIND(?vulnCount = 0 AS ?securityScanPass)
            }

            # All checks must pass for deployment
            BIND(
                COALESCE(?testsPass, false) &&
                COALESCE(?buildSuccess, false) &&
                COALESCE(?securityScanPass, false)
                AS ?readyToDeploy
            )
        }
    """ ;
    gv:outputMapping '{
        "testsPass": "results[0]?.testsPass?.value === \"true\"",
        "buildSuccess": "results[0]?.buildSuccess?.value === \"true\"",
        "securityScanPass": "results[0]?.securityScanPass?.value === \"true\"",
        "readyToDeploy": "results[0]?.readyToDeploy?.value === \"true\"",
        "blockers": "[testsPass, buildSuccess, securityScanPass].filter(x => !x)"
    }' ;
    gv:dependsOn ex:determine-environment .

# =============================================================================
# Step 4: Trigger Deployment
# =============================================================================
ex:trigger-deployment rdf:type gv:ActionStep ;
    rdfs:label "Trigger Deployment Workflow" ;
    gv:actionType "http-request" ;
    gv:httpMethod "POST" ;
    gv:httpUrl "{{ deployUrl }}/deploy" ;
    gv:httpHeaders '{
        "Content-Type": "application/json",
        "Authorization": "Bearer {{ deployToken }}",
        "X-GitVan-Hook": "deploy-on-version-tag"
    }' ;
    gv:httpBody '{
        "version": "{{ version }}",
        "environment": "{{ environment }}",
        "commit": "{{ commitSha }}",
        "author": "{{ author }}",
        "timestamp": "{{ now | date(\"ISO8601\") }}",
        "requiresApproval": {{ requiresApproval }},
        "metadata": {
            "major": {{ major }},
            "minor": {{ minor }},
            "patch": {{ patch }},
            "prerelease": "{{ prerelease }}",
            "isProduction": {{ isProduction }}
        }
    }' ;
    gv:condition "readyToDeploy" ;
    gv:dependsOn ex:validate-deployment-readiness .

# =============================================================================
# Step 5: Record Deployment Metadata
# =============================================================================
ex:record-deployment-metadata rdf:type gv:SparqlStep ;
    rdfs:label "Record Deployment in Knowledge Graph" ;
    gv:updateQuery """
        PREFIX git: <https://gitvan.dev/git#>
        PREFIX gv: <https://gitvan.dev/ontology#>
        PREFIX deploy: <https://gitvan.dev/deployment#>
        PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

        INSERT DATA {
            <urn:deployment:{{ version }}-{{ timestamp }}> rdf:type deploy:Deployment ;
                deploy:version "{{ version }}" ;
                deploy:environment "{{ environment }}" ;
                deploy:commit <{{ commit }}> ;
                deploy:author "{{ author }}" ;
                deploy:triggeredBy "git-tag" ;
                deploy:triggeredAt "{{ now }}"^^xsd:dateTime ;
                deploy:status "{% if readyToDeploy %}initiated{% else %}blocked{% endif %}" ;
                deploy:requiresApproval {{ requiresApproval }} ;
                deploy:isProduction {{ isProduction }} ;
                deploy:deploymentUrl "{{ deployUrl }}" .
        }
    """ ;
    gv:dependsOn ex:trigger-deployment .

# =============================================================================
# Step 6: Generate Deployment Report
# =============================================================================
ex:generate-deployment-report rdf:type gv:TemplateStep ;
    rdfs:label "Generate Deployment Report" ;
    gv:text """
# Automated Deployment Report

**Generated:** {{ "now" | date("YYYY-MM-DD HH:mm:ss") }}
**Hook:** Deploy on Version Tag
**Status:** {% if readyToDeploy %}🚀 DEPLOYMENT INITIATED{% else %}⏸️ DEPLOYMENT BLOCKED{% endif %}

## Version Information

- **Tag:** `{{ version }}`
- **Semantic Version:** {{ major }}.{{ minor }}.{{ patch }}{% if prerelease %}-{{ prerelease }}{% endif %}
- **Commit:** {{ commitSha }}
- **Author:** {{ author }}
- **Message:** {{ message }}

## Deployment Configuration

- **Environment:** {% if isProduction %}🏭 **PRODUCTION**{% else %}🧪 Staging{% endif %}
- **Target URL:** {{ deployUrl }}
- **Requires Approval:** {% if requiresApproval %}✅ Yes{% else %}❌ No{% endif %}
- **Prerelease:** {% if isPrerelease %}✅ Yes ({{ prerelease }}){% else %}❌ No{% endif %}

## Readiness Checks

{% if readyToDeploy %}
✅ **All checks passed - Ready to deploy**

- ✅ Tests: Passed
- ✅ Build: Success
- ✅ Security Scan: No vulnerabilities

{% else %}
⚠️ **Deployment blocked - Checks failed**

- {% if testsPass %}✅{% else %}❌{% endif %} Tests
- {% if buildSuccess %}✅{% else %}❌{% endif %} Build
- {% if securityScanPass %}✅{% else %}❌{% endif %} Security Scan

**Blockers:** {{ blockers.length }} check(s) failed

### Required Actions
1. Review failed checks in CI/CD dashboard
2. Fix issues and re-tag when ready
3. Ensure all tests pass before deployment

{% endif %}

## Deployment Timeline

{% if readyToDeploy %}
1. ✅ Tag created: `{{ version }}`
2. ✅ Readiness validated
3. 🚀 Deployment initiated to {{ environment }}
4. ⏳ Waiting for deployment completion...
5. ⏳ Post-deployment verification pending

**Next Steps:**
- Monitor deployment progress: {{ deployUrl }}/status
- Verify application health after deployment
- Check logs for any errors
- Run smoke tests in {{ environment }}

{% else %}
1. ✅ Tag created: `{{ version }}`
2. ❌ Readiness validation failed
3. ⏸️ Deployment blocked

**Fix Issues:**
```bash
# Review CI failures
git log {{ commitSha }}

# Fix issues and create new tag
git tag -a {{ version }}-fixed -m "Fixed deployment blockers"
git push origin {{ version }}-fixed
```
{% endif %}

## Version History

### Semantic Versioning
- **Major ({{ major }})**: Breaking changes
- **Minor ({{ minor }})**: New features (backward compatible)
- **Patch ({{ patch }})**: Bug fixes
{% if prerelease %}- **Prerelease ({{ prerelease }})**: Pre-production release{% endif %}

### Environment Selection
- **Production**: Final releases (v1.0.0, v2.1.3)
- **Staging**: Pre-releases (v1.0.0-beta.1, v2.0.0-rc.1)
- **Preview**: Alpha releases (v1.0.0-alpha.1)

## Deployment Metadata

**Deployment ID:** deployment-{{ version }}-{{ now | date("YYYY-MM-DD-HH-mm-ss") }}
**Triggered By:** Git Tag Creation
**Hook Version:** 1.0.0

---
*This report was automatically generated by the Auto-Deploy on Version Tag Hook*
    """ ;
    gv:filePath "./reports/deployments/{{ version }}-{{ 'now' | date('YYYY-MM-DD-HH-mm-ss') }}.md" ;
    gv:dependsOn ex:record-deployment-metadata .

# =============================================================================
# Metadata
# =============================================================================
ex:deploy-on-version-tag-hook
    gv:version "1.0.0" ;
    gv:author "GitVan Team" ;
    gv:created "2025-12-03T00:00:00Z" ;
    gv:tags "git", "deployment", "automation", "ci-cd", "semantic-versioning" ;
    gv:documentation "https://gitvan.dev/docs/hooks/deploy-on-version-tag" .
