@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix gitv: <https://gitvan.dev/ontology/git#> .

# ============================================================================
# Git Commit SHACL Shape
# ============================================================================

# Shape for Git Commit validation
gitv:CommitShape a sh:NodeShape ;
    sh:targetClass gitv:Commit ;
    sh:name "Git Commit Shape" ;
    sh:description "Validates that git commits have required metadata with proper formats" ;
    sh:property [
        sh:path gitv:commitHash ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:pattern "^[a-f0-9]{7,40}$" ;
        sh:message "Commit hash must be a valid Git SHA-1 or abbreviated SHA (7-40 hex characters)" ;
    ] ;
    sh:property [
        sh:path gitv:commitMessage ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Commit must have a message describing changes" ;
    ] ;
    sh:property [
        sh:path gitv:author ;
        sh:minCount 1 ;
        sh:message "Commit must have an author" ;
    ] ;
    sh:property [
        sh:path prov:atTime ;
        sh:datatype xsd:dateTime ;
        sh:message "Commit timestamp must be in ISO 8601 format (YYYY-MM-DDTHH:mm:ssZ)" ;
    ] ;
    sh:property [
        sh:path gitv:filesChanged ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "Number of files changed must be a non-negative integer" ;
    ] ;
    sh:property [
        sh:path gitv:linesAdded ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "Number of lines added must be a non-negative integer" ;
    ] ;
    sh:property [
        sh:path gitv:linesDeleted ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "Number of lines deleted must be a non-negative integer" ;
    ] .

# Shape for Git User (author/committer)
gitv:GitUserShape a sh:NodeShape ;
    sh:targetClass gitv:GitUser ;
    sh:name "Git User Shape" ;
    sh:description "Validates that git users have required identity properties" ;
    sh:property [
        sh:path dct:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Git user must have a unique identifier (email or username)" ;
    ] ;
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Git user must have a display name" ;
    ] .

# Shape for Git Repository
gitv:RepositoryShape a sh:NodeShape ;
    sh:targetClass gitv:Repository ;
    sh:name "Git Repository Shape" ;
    sh:description "Validates that git repositories have required metadata" ;
    sh:property [
        sh:path dct:identifier ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "Repository must have a path or identifier" ;
    ] ;
    sh:property [
        sh:path dct:created ;
        sh:datatype xsd:dateTime ;
        sh:message "Repository creation date must be in ISO 8601 format if specified" ;
    ] .

# Shape for Git Branch
gitv:BranchShape a sh:NodeShape ;
    sh:targetClass gitv:Branch ;
    sh:name "Git Branch Shape" ;
    sh:description "Validates that git branches have required reference information" ;
    sh:property [
        sh:path gitv:branchName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:pattern "^[a-zA-Z0-9/_.-]+$" ;
        sh:message "Branch name must contain only alphanumeric characters, slashes, underscores, dots, and hyphens" ;
    ] ;
    sh:property [
        sh:path gitv:refName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:pattern "^refs/(heads|tags|remotes)/" ;
        sh:message "Reference name must be a valid Git ref (refs/heads/..., refs/tags/..., or refs/remotes/...)" ;
    ] .
