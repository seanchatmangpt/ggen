@prefix ex: <http://example.org/> .
@prefix gv: <https://gitvan.dev/ontology#> .
@prefix gh: <https://gitvan.dev/graph-hook#> .
@prefix op: <https://gitvan.dev/op#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

# Gap Analysis Test Hook
# Generated on: 2025-09-20T20:47:03.976Z

ex:test-gap-analysis rdf:type gh:Hook ;
    gv:title "Gap Analysis Test" ;
    gh:hasPredicate ex:test-gap-analysis-predicate ;
    gh:orderedPipelines ex:test-gap-analysis-pipeline .

ex:test-gap-analysis-predicate rdf:type gh:ASKPredicate ;
    gh:queryText """
        PREFIX gv: <https://gitvan.dev/ontology#>
        ASK WHERE {
            ?item rdf:type gv:ExampleItem .
        }
    """ ;
    gh:description "Evaluates a boolean condition using SPARQL ASK" .

ex:test-gap-analysis-pipeline rdf:type op:Pipeline ;
    op:steps (ex:test-gap-analysis-step1) .

ex:test-gap-analysis-step1 rdf:type gv:TemplateStep ;
    gv:text "Hook test-gap-analysis triggered at {{ 'now' | date('YYYY-MM-DD HH:mm:ss') }}" ;
    gv:filePath "./output/test-gap-analysis-output.txt" .