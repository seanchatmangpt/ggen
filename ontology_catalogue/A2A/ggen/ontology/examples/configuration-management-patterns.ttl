# Configuration Management Pattern Examples
:configuration_pattern a owl:Class ;
    rdfs:label "Configuration Management Pattern" ;
    rdfs:comment "Common configuration management patterns" ;
    rdfs:subClassOf owl:Thing .

:idempotent_configuration a configuration_pattern ;
    rdfs:label "Idempotent Configuration" ;
    rdfs:comment "Configuration that can be applied multiple times without side effects" ;
    rdfs:property [
        rdfs:label "State" ;
        rdfs:comment "Desired state of the configuration" ;
        rdfs:range ["present", "absent", "started", "stopped", "enabled", "disabled"] ;
    ] ;
    rdfs:property [
        rdfs:label "Resource" ;
        rdfs:comment "Resource to configure" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Properties" ;
        rdfs:comment "Resource properties" ;
        rdfs:range [a rdf:List] ;
    ] .

:templated_configuration a configuration_pattern ;
    rdfs:label "Templated Configuration" ;
    rdfs:comment "Configuration generated from templates" ;
    rdfs:property [
        rdfs:label "Template Engine" ;
        rdfs:comment "Template engine used" ;
        rdfs:range ["jinja2", "erb", "handlebars", "mustache"] ;
    ] ;
    rdfs:property [
        rdfs:label "Template File" ;
        rdfs:comment "Template file path" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Template Variables" ;
        rdfs:comment "Template variables" ;
        rdfs:range [a rdf:List] ;
    ] ;
    rdfs:property [
        rdfs:label "Output File" ;
        rdfs:comment "Output file path" ;
        rdfs:range xsd:string ;
    ] .

:versioned_configuration a configuration_pattern ;
    rdfs:label "Versioned Configuration" ;
    rdfs:comment "Configuration with version control" ;
    rdfs:property [
        rdfs:label "Version Control System" ;
        rdfs:comment "Version control system used" ;
        rdfs:range ["git", "svn", "mercurial", "perforce"] ;
    ] ;
    rdfs:property [
        rdfs:label "Repository URL" ;
        rdfs:comment "Repository URL" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Branch" ;
        rdfs:comment "Branch name" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Commit Message" ;
        rdfs:comment "Commit message pattern" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Version Strategy" ;
        rdfs:comment "Version strategy" ;
        rdfs:range ["semantic", "calendar", "incremental"] ;
    ] .

:encrypted_configuration a configuration_pattern ;
    rdfs:label "Encrypted Configuration" ;
    rdfs:comment "Configuration with encryption" ;
    rdfs:property [
        rdfs:label "Encryption Algorithm" ;
        rdfs:comment "Encryption algorithm" ;
        rdfs:range ["aes-256", "aes-128", "rsa-2048", "rsa-4096"] ;
    ] ;
    rdfs:property [
        rdfs:label "Encryption Key" ;
        rdfs:comment "Encryption key" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Encryption Mode" ;
        rdfs:comment "Encryption mode" ;
        rdfs:range ["cbc", "gcm", "ecb"] ;
    ] ;
    rdfs:property [
        rdfs:label "Sensitive Data" ;
        rdfs:comment "Sensitive data pattern" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Decryption Command" ;
        rdfs:comment "Decryption command" ;
        rdfs:range xsd:string ;
    ] .