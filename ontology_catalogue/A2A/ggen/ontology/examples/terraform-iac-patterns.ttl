@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix a2a: <https://a2a.com/schema/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# Infrastructure as Code (Terraform) Pattern Examples

# Complete AWS Infrastructure Configuration
# AWS Infrastructure Instance
:aws_production_infrastructure a a2a:terraform_config ;
    a2a:app_label "aws-production" ;
    a2a:version_label "4.2.0" ;
    a2a:managed_by "a2a" ;
    a2a:terraform_provider "aws" ;
    a2a:terraform_provider "kubernetes" ;
    a2a:terraform_provider "helm" ;
    a2a:terraform_provider "random" ;
    a2a:terraform_resource "aws_vpc.main" ;
    a2a:terraform_resource "aws_subnet.public" ;
    a2a:terraform_resource "aws_subnet.private" ;
    a2a:terraform_resource "aws_internet_gateway.main" ;
    a2a:terraform_resource "aws_nat_gateway.main" ;
    a2a:terraform_resource "aws_route_table.public" ;
    a2a:terraform_resource "aws_route_table.private" ;
    a2a:terraform_resource "aws_security_group.web" ;
    a2a:terraform_resource "aws_security_group.app" ;
    a2a:terraform_resource "aws_security_group.db" ;
    a2a:terraform_resource "aws_iam_role.ecs" ;
    a2a:terraform_resource "aws_iam_role_policy.ecs" ;
    a2a:terraform_resource "aws_ecs_cluster.main" ;
    a2a:terraform_resource "aws_ecs_service.web" ;
    a2a:terraform_resource "aws_ecs_service.api" ;
    a2a:terraform_resource "aws_ecr_repository.web" ;
    a2a:terraform_resource "aws_elb.web" ;
    a2a:terraform_resource "aws_rds_cluster.main" ;
    a2a:terraform_resource "aws_s3_bucket.assets" ;
    a2a:terraform_resource "aws_cloudfront_distribution.assets" ;
    a2a:terraform_variable "region" "us-west-2" ;
    a2a:terraform_variable "environment" "production" ;
    a2a:terraform_variable "vpc_cidr" "10.0.0.0/16" ;
    a2a:terraform_variable "public_subnet_cidr" "10.0.1.0/24" ;
    a2a:terraform_variable "private_subnet_cidr" "10.0.2.0/24" ;
    a2a:terraform_variable "web_app_count" "3" ;
    a2a:terraform_variable "api_app_count" "2" ;
    a2a:terraform_variable "db_instance_type" "db.t3.large" ;
    a2a:terraform_variable "db_engine_version" "13.7" ;
    a2a:terraform_variable "db_storage_size" "100" ;
    a2a:terraform_variable "db_storage_type" "gp3" ;
    a2a:terraform_variable "aws_access_key_id" "" ;
    a2a:terraform_variable "aws_secret_access_key" "" ;
    a2a:terraform_variable "aws_session_token" "" ;
    a2a:terraform_output "vpc_id" ;
    a2a:terraform_output "public_subnet_ids" ;
    a2a:terraform_output "private_subnet_ids" ;
    a2a:terraform_output "web_lb_dns" ;
    a2a:terraform_output "api_lb_dns" ;
    a2a:terraform_output "db_endpoint" ;
    a2a:terraform_output "db_port" ;
    a2a:terraform_output "cloudfront_domain" .

# Multi-Cloud Configuration
:multi_cloud_infrastructure a a2a:terraform_config ;
    a2a:app_label "multi-cloud" ;
    a2a:version_label "1.5.0" ;
    a2a:managed_by "a2a" ;
    a2a:terraform_provider "aws" ;
    a2a:terraform_provider "google" ;
    a2a:terraform_provider "azurerm" ;
    a2a:terraform_resource "aws_vpc.aws_infra" ;
    a2a:terraform_resource "aws_subnet.aws_public" ;
    a2a:terraform_resource "google_compute_network.gcp_infra" ;
    a2a:terraform_resource "google_compute_subnetwork.gcp_public" ;
    a2a:terraform_resource "azurerm_resource_group.az_rg" ;
    a2a:terraform_resource "azurerm_virtual_network.az_vnet" ;
    a2a:terraform_resource "azurerm_subnet.az_public" ;
    a2a:terraform_variable "aws_region" "us-east-1" ;
    a2a:terraform_variable "gcp_project" "my-project-123" ;
    a2a:terraform_variable "gcp_region" "us-central1" ;
    a2a:terraform_variable "azure_location" "East US" ;
    a2a:terraform_variable "azure_resource_group_name" "multi-cloud-rg" ;
    a2a:terraform_output "aws_vpc_id" ;
    a2a:terraform_output "gcp_network_id" ;
    a2a:terraform_output "az_vnet_id" .

# Kubernetes Infrastructure with Terraform
:kubernetes_infrastructure a a2a:terraform_config ;
    a2a:app_label "k8s-infra" ;
    a2a:version_label "3.1.0" ;
    a2a:managed_by "a2a" ;
    a2a:terraform_provider "kubernetes" ;
    a2a:terraform_provider "helm" ;
    a2a:terraform_resource "kubernetes_namespace.prod" ;
    a2a:terraform_resource "kubernetes_namespace.staging" ;
    a2a:terraform_resource "kubernetes_namespace.dev" ;
    a2a:terraform_resource "kubernetes_service_account.prod" ;
    a2a:terraform_resource "kubernetes_service_account.staging" ;
    a2a:terraform_resource "kubernetes_service_account.dev" ;
    a2a:terraform_resource "kubernetes_role.prod" ;
    a2a:terraform_resource "kubernetes_role_binding.prod" ;
    a2a:terraform_resource "helm_release.ingress_nginx" ;
    a2a:terraform_resource "helm_release.cert_manager" ;
    a2a:terraform_resource "helm_release.monitoring" ;
    a2a:terraform_resource "helm_release.logging" ;
    a2a:terraform_variable "kubernetes_config_path" "~/.kube/config" ;
    a2a:terraform_variable "kubernetes_context" "my-cluster" ;
    a2a:terraform_variable "namespace_prod" "production" ;
    a2a:terraform_variable "namespace_staging" "staging" ;
    a2a:terraform_variable "namespace_dev" "development" ;
    a2a:terraform_variable "helm_repo_url_nginx" "https://kubernetes.github.io/ingress-nginx" ;
    a2a:terraform_variable "helm_repo_url_certmanager" "https://charts.jetstack.io" ;
    a2a:terraform_variable "helm_repo_url_monitoring" "https://prometheus-community.github.io/helm-charts" ;
    a2a:terraform_output "prod_namespace_id" ;
    a2a:terraform_output "staging_namespace_id" ;
    a2a:terraform_output "dev_namespace_id" ;
    a2a:terraform_output "ingress_nginx_status" ;
    a2a:terraform_output "cert_manager_status" .

# Terraform Provider Classes
:aws_provider a a2a:terraform_provider ;
    rdfs:label "AWS Provider" ;
    rdfs:comment "Amazon Web Services provider configuration" ;
    rdfs:property [
        rdfs:label "Region" ;
        rdfs:comment "AWS region" ;
        rdfs:range xsd:string ;
        rdfs:pattern "^(us|eu|ap|sa|ca)-(east|west|south|central|northeast|northwest)-[1-9]$" ;
    ] ;
    rdfs:property [
        rdfs:label "Access Key" ;
        rdfs:comment "AWS access key ID" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Secret Key" ;
        rdfs:comment "AWS secret access key" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Session Token" ;
        rdfs:comment "AWS session token" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Profile" ;
        rdfs:comment "AWS profile name" ;
        rdfs:range xsd:string ;
    ] .

:google_provider a a2a:terraform_provider ;
    rdfs:label "Google Cloud Provider" ;
    rdfs:comment "Google Cloud provider configuration" ;
    rdfs:property [
        rdfs:label "Project" ;
        rdfs:comment "Google Cloud project ID" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Region" ;
        rdfs:comment "Google Cloud region" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Zone" ;
        rdfs:comment "Google Cloud zone" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Credentials" ;
        rdfs:comment "Google Cloud credentials file path" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Billing Account" ;
        rdfs:comment "Google Cloud billing account ID" ;
        rdfs:range xsd:string ;
    ] .

:azure_provider a a2a:terraform_provider ;
    rdfs:label "Azure Provider" ;
    rdfs:comment "Microsoft Azure provider configuration" ;
    rdfs:property [
        rdfs:label "Subscription ID" ;
        rdfs:comment "Azure subscription ID" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Tenant ID" ;
        rdfs:comment "Azure tenant ID" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Client ID" ;
        rdfs:comment "Azure client ID" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Client Secret" ;
        rdfs:comment "Azure client secret" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Location" ;
        rdfs:comment "Azure location" ;
        rdfs:range xsd:string ;
    ] .

:kubernetes_provider a a2a:terraform_provider ;
    rdfs:label "Kubernetes Provider" ;
    rdfs:comment "Kubernetes provider configuration" ;
    rdfs:property [
        rdfs:label "Config Path" ;
        rdfs:comment "Path to kubeconfig file" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Context" ;
        rdfs:comment "Kubernetes context name" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Cluster Name" ;
        rdfs:comment "Kubernetes cluster name" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Host" ;
        rdfs:comment "Kubernetes API server host" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Token" ;
        rdfs:comment "Kubernetes authentication token" ;
        rdfs:range xsd:string ;
    ] .

# Terraform Resource Pattern Classes
:vpc_resource a a2a:terraform_resource ;
    rdfs:label "VPC Resource" ;
    rdfs:comment "Virtual Private Cloud resource" ;
    rdfs:property [
        rdfs:label "CIDR Block" ;
        rdfs:comment "VPC CIDR block" ;
        rdfs:range xsd:string ;
        rdfs:pattern "^([0-9]{1,3}\\.){3}[0-9]{1,3}/(8|16|24)$" ;
    ] ;
    rdfs:property [
        rdfs:label "Enable DNS Hostnames" ;
        rdfs:comment "Enable DNS hostnames" ;
        rdfs:range xsd:boolean ;
    ] ;
    rdfs:property [
        rdfs:label "Enable DNS Support" ;
        rdfs:comment "Enable DNS support" ;
        rdfs:range xsd:boolean ;
    ] ;
    rdfs:property [
        rdfs:label "Tags" ;
        rdfs:comment "Resource tags" ;
        rdfs:range [a rdf:List] ;
    ] .

:subnet_resource a a2a:terraform_resource ;
    rdfs:label "Subnet Resource" ;
    rdfs:comment "Subnet resource" ;
    rdfs:property [
        rdfs:label "VPC ID" ;
        rdfs:comment "VPC ID" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "CIDR Block" ;
        rdfs:comment "Subnet CIDR block" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Availability Zone" ;
        rdfs:comment "Availability zone" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Map Public IP" ;
        rdfs:comment "Map public IP" ;
        rdfs:range xsd:boolean ;
    ] ;
    rdfs:property [
        rdfs:label "Tags" ;
        rdfs:comment "Resource tags" ;
        rdfs:range [a rdf:List] ;
    ] .

:security_group_resource a a2a:terraform_resource ;
    rdfs:label "Security Group Resource" ;
    rdfs:comment "Security group resource" ;
    rdfs:property [
        rdfs:label "VPC ID" ;
        rdfs:comment "VPC ID" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Name" ;
        rdfs:comment "Security group name" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Description" ;
        rdfs:comment "Security group description" ;
        rdfs:range xsd:string ;
    ] ;
    rdfs:property [
        rdfs:label "Ingress Rules" ;
        rdfs:comment "Ingress rules" ;
        rdfs:range [a rdf:List] ;
    ] ;
    rdfs:property [
        rdfs:label "Egress Rules" ;
        rdfs:comment "Egress rules" ;
        rdfs:range [a rdf:List] ;
    ] ;
    rdfs:property [
        rdfs:label "Tags" ;
        rdfs:comment "Resource tags" ;
        rdfs:range [a rdf:List] ;
    ] .