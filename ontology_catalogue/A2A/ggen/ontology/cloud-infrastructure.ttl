    rdfs:label "CI/CD Pipeline" ;
    rdfs:comment "Continuous integration/continuous deployment pipeline" ;
    rdfs:subClassOf a2a:infrastructure_pattern .

a2a:ci_pipeline a owl:Class ;
    rdfs:label "CI Pipeline" ;
    rdfs:comment "Continuous integration pipeline" ;
    rdfs:subClassOf a2a:cicd_pipeline .

a2a:cd_pipeline a owl:Class ;
    rdfs:label "CD Pipeline" ;
    rdfs:comment "Continuous deployment pipeline" ;
    rdfs:subClassOf a2a:cicd_pipeline .

a2a:github_actions_workflow a owl:Class ;
    rdfs:label "GitHub Actions Workflow" ;
    rdfs:comment "GitHub Actions workflow configuration" ;
    rdfs:subClassOf a2a:cicd_pipeline .

a2a:gitlab_ci a owl:Class ;
    rdfs:label "GitLab CI" ;
