    rdfs:range ( "development" "staging" "production" ) .

a2a:approval_required a owl:DatatypeProperty ;
    rdfs:label "Approval Required" ;
    rdfs:comment "Manual approval required for deployment" ;
    rdfs:domain a2a:cd_pipeline ;
    rdfs:range xsd:boolean .

a2a:build_matrix a owl:DatatypeProperty ;
    rdfs:label "Build Matrix" ;
    rdfs:comment "Build matrix configuration" ;
    rdfs:domain a2a:ci_pipeline ;
    rdfs:range [a rdf:List] .

a2a:artifacts a owl:DatatypeProperty ;
    rdfs:label "Artifacts" ;
    rdfs:comment "Build artifacts" ;
    rdfs:domain a2a:ci_pipeline ;
    rdfs:range [a rdf:List] .

