    rdfs:range ( "push" "pull_request" "schedule" "workflow_dispatch" ) .

a2a:branch_filter a owl:DatatypeProperty ;
    rdfs:label "Branch Filter" ;
    rdfs:comment "Branch filter for pipeline triggers" ;
    rdfs:domain a2a:cicd_pipeline ;
    rdfs:range xsd:string .

a2a:environment a owl:DatatypeProperty ;
    rdfs:label "Environment" ;
    rdfs:comment "Target environment for deployment" ;
