@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix k8s: <https://kubernetes.io/schema/> .
@prefix docker: <https://docker.io/schema/> .
@prefix helm: <https://helm.io/schema/> .
@prefix a2a: <https://a2a.com/schema/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rfc: <https://www.w3.org/2001/XMLSchema#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .

# Cloud Infrastructure Types
a2a:cloud_infrastructure a owl:Class ;
    rdfs:label "Cloud Infrastructure" ;
    rdfs:comment "Cloud deployment configuration" ;
    rdfs:subClassOf owl:Thing .

# Root Infrastructure Types
a2a:infrastructure_pattern a owl:Class ;
    rdfs:label "Infrastructure Pattern" ;
    rdfs:comment "Base class for infrastructure patterns" ;
    rdfs:subClassOf owl:Thing .

a2a:docker_config a owl:Class ;
    rdfs:label "Docker Configuration" ;
    rdfs:comment "Docker container configuration" ;
    rdfs:subClassOf a2a:cloud_infrastructure, a2a:infrastructure_pattern .

a2a:kubernetes_config a owl:Class ;
    rdfs:label "Kubernetes Configuration" ;
    rdfs:comment "Kubernetes resource configuration" ;
    rdfs:subClassOf a2a:cloud_infrastructure, a2a:infrastructure_pattern .

a2a:helm_chart a owl:Class ;
    rdfs:label "Helm Chart" ;
    rdfs:comment "Helm chart configuration" ;
    rdfs:subClassOf a2a:cloud_infrastructure, a2a:infrastructure_pattern .

a2a:cicd_pipeline a owl:Class ;
    rdfs:label "CI/CD Pipeline" ;
    rdfs:comment "Continuous integration/continuous deployment pipeline" ;
    rdfs:subClassOf a2a:infrastructure_pattern .

a2a:terraform_config a owl:Class ;
    rdfs:label "Terraform Configuration" ;
    rdfs:comment "Infrastructure as code using Terraform" ;
    rdfs:subClassOf a2a:infrastructure_pattern .

a2a:config_management a owl:Class ;
    rdfs:label "Configuration Management" ;
    rdfs:comment "Configuration management pattern" ;
    rdfs:subClassOf a2a:infrastructure_pattern .

# Docker Container Patterns
a2a:base_image a owl:DatatypeProperty ;
    rdfs:label "Base Image" ;
    rdfs:comment "Base image for Docker container" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:dockerfile_template a owl:DatatypeProperty ;
    rdfs:label "Dockerfile Template" ;
    rdfs:comment "Multi-stage Dockerfile template" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:expose_port a owl:DatatypeProperty ;
    rdfs:label "Expose Port" ;
    rdfs:comment "Port exposed by the container" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:integer .

a2a:volume_mount a owl:DatatypeProperty ;
    rdfs:label "Volume Mount" ;
    rdfs:comment "Volume mount configuration" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:environment_variable a owl:DatatypeProperty ;
    rdfs:label "Environment Variable" ;
    rdfs:comment "Environment variable configuration" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:multi_stage_build a owl:DatatypeProperty ;
    rdfs:label "Multi-Stage Build" ;
    rdfs:comment "Enable multi-stage builds for optimized images" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:boolean .

a2a:health_check a owl:DatatypeProperty ;
    rdfs:label "Health Check" ;
    rdfs:comment "Health check configuration" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:liveness_probe a owl:DatatypeProperty ;
    rdfs:label "Liveness Probe" ;
    rdfs:comment "Liveness probe configuration" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:readiness_probe a owl:DatatypeProperty ;
    rdfs:label "Readiness Probe" ;
    rdfs:comment "Readiness probe configuration" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:build_arg a owl:DatatypeProperty ;
    rdfs:label "Build Argument" ;
    rdfs:comment "Build argument for Docker image" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:network_mode a owl:DatatypeProperty ;
    rdfs:label "Network Mode" ;
    rdfs:comment "Container network mode" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range ( "bridge" "host" "none" "overlay" ) .

a2a:user a owl:DatatypeProperty ;
    rdfs:label "User" ;
    rdfs:comment "User to run container as" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:working_dir a owl:DatatypeProperty ;
    rdfs:label "Working Directory" ;
    rdfs:comment "Working directory inside container" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:command a owl:DatatypeProperty ;
    rdfs:label "Command" ;
    rdfs:comment "Command to run in container" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

a2a:entrypoint a owl:DatatypeProperty ;
    rdfs:label "Entrypoint" ;
    rdfs:comment "Container entrypoint" ;
    rdfs:domain a2a:docker_config ;
    rdfs:range xsd:string .

# Kubernetes Resource Types
a2a:deployment a owl:Class ;
    rdfs:label "Kubernetes Deployment" ;
    rdfs:comment "Kubernetes deployment configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

a2a:service a owl:Class ;
    rdfs:label "Kubernetes Service" ;
    rdfs:comment "Kubernetes service configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

a2a:configmap a owl:Class ;
    rdfs:label "Kubernetes ConfigMap" ;
    rdfs:comment "Kubernetes ConfigMap configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

a2a:secret a owl:Class ;
    rdfs:label "Kubernetes Secret" ;
    rdfs:comment "Kubernetes Secret configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

a2a:ingress a owl:Class ;
    rdfs:label "Kubernetes Ingress" ;
    rdfs:comment "Kubernetes Ingress configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

a2a:persistent_volume_claim a owl:Class ;
    rdfs:label "Persistent Volume Claim" ;
    rdfs:comment "Kubernetes Persistent Volume Claim configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

a2a:statefulset a owl:Class ;
    rdfs:label "Kubernetes StatefulSet" ;
    rdfs:comment "Kubernetes StatefulSet configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

a2a:daemonset a owl:Class ;
    rdfs:label "Kubernetes DaemonSet" ;
    rdfs:comment "Kubernetes DaemonSet configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

a2a:job a owl:Class ;
    rdfs:label "Kubernetes Job" ;
    rdfs:comment "Kubernetes Job configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

a2a:cronjob a owl:Class ;
    rdfs:label "Kubernetes CronJob" ;
    rdfs:comment "Kubernetes CronJob configuration" ;
    rdfs:subClassOf a2a:kubernetes_config .

# Kubernetes Properties
a2a:replicas a owl:DatatypeProperty ;
    rdfs:label "Replicas" ;
    rdfs:comment "Number of replicas for deployment" ;
    rdfs:domain a2a:kubernetes_config, a2a:deployment, a2a:statefulset ;
    rdfs:range xsd:integer .

a2a:namespace a owl:DatatypeProperty ;
    rdfs:label "Namespace" ;
    rdfs:comment "Kubernetes namespace" ;
    rdfs:domain a2a:kubernetes_config ;
    rdfs:range xsd:string .

a2a:resource_request_cpu a owl:DatatypeProperty ;
    rdfs:label "CPU Request" ;
    rdfs:comment "CPU resource request" ;
    rdfs:domain a2a:kubernetes_config ;
    rdfs:range xsd:string .

a2a:resource_request_memory a owl:DatatypeProperty ;
    rdfs:label "Memory Request" ;
    rdfs:comment "Memory resource request" ;
    rdfs:domain a2a:kubernetes_config ;
    rdfs:range xsd:string .

a2a:resource_limit_cpu a owl:DatatypeProperty ;
    rdfs:label "CPU Limit" ;
    rdfs:comment "CPU resource limit" ;
    rdfs:domain a2a:kubernetes_config ;
    rdfs:range xsd:string .

a2a:resource_limit_memory a owl:DatatypeProperty ;
    rdfs:label "Memory Limit" ;
    rdfs:comment "Memory resource limit" ;
    rdfs:domain a2a:kubernetes_config ;
    rdfs:range xsd:string .

a2a:service_type a owl:DatatypeProperty ;
    rdfs:label "Service Type" ;
    rdfs:comment "Kubernetes service type" ;
    rdfs:domain a2a:service ;
    rdfs:range ( "ClusterIP" "NodePort" "LoadBalancer" "ExternalName" ) .

a2a:ingress_class a owl:DatatypeProperty ;
    rdfs:label "Ingress Class" ;
    rdfs:comment "Ingress class name" ;
    rdfs:domain a2a:ingress ;
    rdfs:range xsd:string .

a2a:container_port a owl:DatatypeProperty ;
    rdfs:label "Container Port" ;
    rdfs:comment "Container port configuration" ;
    rdfs:domain a2a:deployment ;
    rdfs:range xsd:integer .

a2a:image_pull_policy a owl:DatatypeProperty ;
    rdfs:label "Image Pull Policy" ;
    rdfs:comment "Image pull policy for containers" ;
    rdfs:domain a2a:deployment ;
    rdfs:range ( "Always" "Never" "IfNotPresent" ) .

a2a:image_pull_secrets a owl:DatatypeProperty ;
    rdfs:label "Image Pull Secrets" ;
    rdfs:comment "Image pull secrets for private registries" ;
    rdfs:domain a2a:deployment ;
    rdfs:range [a rdf:List] .

a2a:service_account_name a owl:DatatypeProperty ;
    rdfs:label "Service Account Name" ;
    rdfs:comment "Service account name" ;
    rdfs:domain a2a:kubernetes_config ;
    rdfs:range xsd:string .

a2a:tolerations a owl:DatatypeProperty ;
    rdfs:label "Tolerations" ;
    rdfs:comment "Kubernetes tolerations" ;
    rdfs:domain a2a:kubernetes_config ;
    rdfs:range [a rdf:List] .

a2a:node_selector a owl:DatatypeProperty ;
    rdfs:label "Node Selector" ;
    rdfs:comment "Node selector labels" ;
    rdfs:domain a2a:kubernetes_config ;
    rdfs:range [a rdf:List] .

a2a:affinity a owl:DatatypeProperty ;
    rdfs:label "Affinity" ;
    rdfs:comment "Pod affinity rules" ;
    rdfs:domain a2a:kubernetes_config ;
    rdfs:range xsd:string .

