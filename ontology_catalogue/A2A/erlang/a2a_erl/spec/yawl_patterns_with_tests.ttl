  rdfs:label "Create Multi-Instance Workflow" ;
  test:arrange "Start with empty pattern registry" ;
  test:act "Create workflow with multi_instance, num_instances=5" ;
  test:assert "Workflow created with 5 parallel instances" ;
  test:expected_result "{ok, WorkflowDef}" ;
  .

yawl:test_multi_instance_parallel a test:TestCase ;
  rdfs:label "Execute All Instances in Parallel" ;
  test:arrange "Multi-instance workflow with 5 instances" ;
  test:act "Start all instances simultaneously" ;
  test:assert "All 5 instances are running in parallel" ;
  test:expected_result "{ok, 5_running}" ;
  .

yawl:test_multi_instance_collect a test:TestCase ;
  rdfs:label "Collect Instance Results" ;
  test:arrange "All 5 instances completed" ;
  test:act "Collect results from all instances" ;
  test:assert "All 5 results collected and aggregated" ;
  test:expected_result "{ok, results_collected}" ;
  .

# =============================================================================
# Pattern 8: Interleaved Parallelism
# =============================================================================

yawl:interleaved_parallelism a yawl:AdvancedControlFlow ;
  rdfs:label "Interleaved Parallelism" ;
  yawl:complexity "medium" ;
  test:has_test yawl:test_interleaved_create ;
  test:has_test yawl:test_interleaved_any_order ;
  test:has_test yawl:test_interleaved_complete ;
  .

yawl:test_interleaved_create a test:TestCase ;
  rdfs:label "Create Interleaved Parallelism Workflow" ;
  test:arrange "Start with empty pattern registry" ;
  test:act "Create workflow with interleaved_parallelism pattern" ;
  test:assert "Workflow created with interleaved execution" ;
  test:expected_result "{ok, WorkflowDef}" ;
  .

yawl:test_interleaved_any_order a test:TestCase ;
  rdfs:label "Execute Tasks in Any Order" ;
  test:arrange "Interleaved workflow with 3 tasks" ;
  test:act "Execute tasks in random order" ;
  test:assert "Tasks complete successfully in any order" ;
  test:expected_result "{ok, tasks_complete}" ;
  .

yawl:test_interleaved_complete a test:TestCase ;
  rdfs:label "Complete All Interleaved Tasks" ;
  test:arrange "2 of 3 tasks completed" ;
  test:act "Complete final task" ;
  test:assert "Workflow completes after all tasks done" ;
  test:expected_result "{ok, completed}" ;
  .

# =============================================================================
# Pattern 9: Implicit Merge
# =============================================================================

yawl:implicit_merge a yawl:AdvancedControlFlow ;
  rdfs:label "Implicit Merge" ;
  yawl:complexity "medium" ;
  test:has_test yawl:test_implicit_merge_create ;
  test:has_test yawl:test_implicit_merge_auto ;
  test:has_test yawl:test_implicit_merge_no_conflict ;
  .

yawl:test_implicit_merge_create a test:TestCase ;
  rdfs:label "Create Implicit Merge Workflow" ;
  test:arrange "Start with empty pattern registry" ;
  test:act "Create workflow with implicit_merge pattern" ;
  test:assert "Workflow created without explicit merge point" ;
  test:expected_result "{ok, WorkflowDef}" ;
  .

yawl:test_implicit_merge_auto a test:TestCase ;
  rdfs:label "Auto-Merge Incoming Paths" ;
  test:arrange "Implicit merge workflow with 2 paths" ;
  test:act "Complete either path" ;
  test:assert "Workflow continues automatically (no merge wait)" ;
  test:expected_result "{ok, auto_continued}" ;
  .

yawl:test_implicit_merge_no_conflict a test:TestCase ;
  rdfs:label "No Conflict on Concurrent Arrival" ;
  test:arrange "Both paths complete simultaneously" ;
  test:act "Handle concurrent tokens" ;
  test:assert "One token proceeds, other consumed" ;
  test:expected_result "{ok, no_conflict}" ;
  .

