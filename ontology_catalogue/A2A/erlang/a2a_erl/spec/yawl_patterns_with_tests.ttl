  .

# =============================================================================
# Pattern 6: Iterative Loop
# =============================================================================

yawl:iterative_loop a yawl:BasicControlFlow ;
  rdfs:label "Iterative Loop" ;
  yawl:complexity "high" ;
  test:has_test yawl:test_iterative_loop_create ;
  test:has_test yawl:test_iterative_loop_continue ;
  test:has_test yawl:test_iterative_loop_exit ;
  .

yawl:test_iterative_loop_create a test:TestCase ;
  rdfs:label "Create Iterative Loop Workflow" ;
  test:arrange "Start with empty pattern registry" ;
  test:act "Create workflow with iterative_loop pattern" ;
  test:assert "Workflow created with loop condition" ;
  test:expected_result "{ok, WorkflowDef}" ;
  .

yawl:test_iterative_loop_continue a test:TestCase ;
  rdfs:label "Continue Loop" ;
  test:arrange "Create iterative_loop, condition=true" ;
  test:act "Execute loop iteration" ;
  test:assert "Loop repeats, counter increments" ;
  test:expected_result "{ok, loop_continue}" ;
  .

yawl:test_iterative_loop_exit a test:TestCase ;
  rdfs:label "Exit Loop" ;
  test:arrange "Loop running, condition becomes false" ;
  test:act "Evaluate loop condition" ;
  test:assert "Loop exits, workflow continues" ;
  test:expected_result "{ok, loop_exit}" ;
  .

# =============================================================================
# Pattern 7: Multi-Instance
# =============================================================================

yawl:multi_instance a yawl:BasicControlFlow ;
  rdfs:label "Multi-Instance" ;
  yawl:complexity "high" ;
  test:has_test yawl:test_multi_instance_create ;
  test:has_test yawl:test_multi_instance_parallel ;
