yawl:test_multiple_merge_points a test:TestCase ;
  rdfs:label "Multiple Merge Points Active" ;
  test:arrange "Multiple merge workflow with 3 merge points" ;
  test:act "Route to different merge points" ;
  test:assert "Each merge point operates independently" ;
  test:expected_result "{ok, merges_active}" ;
  .

yawl:test_multiple_merge_select a test:TestCase ;
  rdfs:label "Select at Merge Point" ;
  test:arrange "Multiple incoming paths at merge" ;
