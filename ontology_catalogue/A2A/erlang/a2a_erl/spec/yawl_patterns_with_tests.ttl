yawl:test_deferred_choice_single a test:TestCase ;
  rdfs:label "Execute Single Option Only" ;
  test:arrange "Option selected" ;
  test:act "Execute selected option" ;
  test:assert "Only one option executes, other cancelled" ;
  test:expected_result "{ok, single_executed}" ;
  .

