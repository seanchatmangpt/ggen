  .

yawl:test_deferred_choice_runtime a test:TestCase ;
  rdfs:label "Choice at Runtime" ;
  test:arrange "Deferred choice with 2 options" ;
  test:act "Trigger runtime choice based on availability" ;
  test:assert "First available option is selected" ;
