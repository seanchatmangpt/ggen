@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix yawl: <http://yawl.org/patterns#> .
@prefix test: <http://test.ggen.org#> .

# =============================================================================
# YAWL Workflow Patterns with Chicago TDD Test Cases
# =============================================================================
# Each pattern includes:
# - Arrange: Initial state setup
# - Act: Trigger the pattern
# - Assert: Verify expected behavior
# =============================================================================

<http://yawl.org/patterns-with-tests>
  a owl:Ontology ;
  rdfs:label "YAWL Patterns with Tests" ;
  rdfs:comment "Complete YAWL patterns with Chicago TDD test cases" ;
  owl:versionInfo "1.0.0" ;
  .

# =============================================================================
# Test Case Definitions
# =============================================================================

test:TestCase a owl:Class ;
  rdfs:label "Test Case" ;
  rdfs:comment "Chicago TDD test case (Arrange-Act-Assert)" ;
  .

test:arrange a owl:DatatypeProperty ;
  rdfs:domain test:TestCase ;
  rdfs:range xsd:string ;
  rdfs:label "Arrange" ;
  .

test:act a owl:DatatypeProperty ;
  rdfs:domain test:TestCase ;
  rdfs:range xsd:string ;
  rdfs:label "Act" ;
  .

test:assert a owl:DatatypeProperty ;
  rdfs:domain test:TestCase ;
  rdfs:range xsd:string ;
  rdfs:label "Assert" ;
  .

test:expected_result a owl:DatatypeProperty ;
  rdfs:domain test:TestCase ;
  rdfs:range xsd:string ;
  rdfs:label "Expected Result" ;
  .

# =============================================================================
# Pattern 1: Basic Sequential
# =============================================================================

yawl:basic_sequential a yawl:BasicControlFlow ;
  rdfs:label "Basic Sequential" ;
  yawl:complexity "low" ;
  test:has_test yawl:test_basic_sequential_create ;
  test:has_test yawl:test_basic_sequential_execute ;
  test:has_test yawl:test_basic_sequential_validate ;
  .

yawl:test_basic_sequential_create a test:TestCase ;
  rdfs:label "Create Basic Sequential Workflow" ;
  test:arrange "Start with empty pattern registry" ;
  test:act "Create workflow with basic_sequential pattern" ;
  test:assert "Workflow created with 2 sequential tasks" ;
  test:expected_result "{ok, WorkflowDef}" ;
  .

yawl:test_basic_sequential_execute a test:TestCase ;
  rdfs:label "Execute Basic Sequential" ;
  test:arrange "Create basic_sequential workflow" ;
  test:act "Execute workflow instance" ;
  test:assert "Tasks execute in order: task1 -> task2" ;
  test:expected_result "{ok, completed}" ;
  .

yawl:test_basic_sequential_validate a test:TestCase ;
  rdfs:label "Validate Basic Sequential Config" ;
  test:arrange "Pattern module loaded" ;
  test:act "Validate basic_sequential with empty config" ;
  test:assert "Validation passes (no required params)" ;
  test:expected_result "true" ;
  .

# =============================================================================
# Pattern 2: Parallel Split
# =============================================================================

yawl:parallel_split a yawl:BasicControlFlow ;
  rdfs:label "Parallel Split" ;
  yawl:complexity "medium" ;
  test:has_test yawl:test_parallel_split_create ;
  test:has_test yawl:test_parallel_split_branches ;
  test:has_test yawl:test_parallel_split_validate ;
  .

yawl:test_parallel_split_create a test:TestCase ;
  rdfs:label "Create Parallel Split Workflow" ;
  test:arrange "Start with empty pattern registry" ;
  test:act "Create workflow with parallel_split pattern, branches=3" ;
  test:assert "Workflow created with 3 parallel branches" ;
  test:expected_result "{ok, WorkflowDef}" ;
  .

yawl:test_parallel_split_branches a test:TestCase ;
  rdfs:label "Execute Parallel Split" ;
  test:arrange "Create parallel_split workflow with 3 branches" ;
  test:act "Execute workflow - all branches start simultaneously" ;
  test:assert "All 3 branch tasks are active in parallel" ;
  test:expected_result "{ok, running}" ;
  .

yawl:test_parallel_split_validate a test:TestCase ;
  rdfs:label "Validate Parallel Split Config" ;
  test:arrange "Pattern module loaded" ;
  test:act "Validate parallel_split with branches=3" ;
  test:assert "Validation passes for valid branch count" ;
  test:expected_result "true" ;
  .

# =============================================================================
# Pattern 3: Parallel Join
# =============================================================================

yawl:parallel_join a yawl:BasicControlFlow ;
  rdfs:label "Parallel Join" ;
  yawl:complexity "medium" ;
  test:has_test yawl:test_parallel_join_create ;
  test:has_test yawl:test_parallel_join_wait ;
  test:has_test yawl:test_parallel_join_sync ;
  .

yawl:test_parallel_join_create a test:TestCase ;
  rdfs:label "Create Parallel Join Workflow" ;
  test:arrange "Start with empty pattern registry" ;
  test:act "Create workflow with parallel_join pattern" ;
  test:assert "Workflow created with join synchronization" ;
  test:expected_result "{ok, WorkflowDef}" ;
  .

yawl:test_parallel_join_wait a test:TestCase ;
  rdfs:label "Wait at Parallel Join" ;
  test:arrange "Create parallel_join workflow with 2 branches" ;
  test:act "Complete 1 branch, other still running" ;
  test:assert "Join waits for all branches to complete" ;
  test:expected_result "{ok, waiting}" ;
  .

yawl:test_parallel_join_sync a test:TestCase ;
  rdfs:label "Synchronize at Parallel Join" ;
  test:arrange "Both branches completed" ;
  test:act "Trigger join transition" ;
  test:assert "Workflow proceeds after all branches complete" ;
  test:expected_result "{ok, joined}" ;
  .

# =============================================================================
# Pattern 4: Exclusive Choice
# =============================================================================

yawl:exclusive_choice a yawl:BasicControlFlow ;
  rdfs:label "Exclusive Choice" ;
  yawl:complexity "medium" ;
  test:has_test yawl:test_exclusive_choice_create ;
  test:has_test yawl:test_exclusive_choice_select ;
  test:has_test yawl:test_exclusive_choice_single_path ;
  .

yawl:test_exclusive_choice_create a test:TestCase ;
  rdfs:label "Create Exclusive Choice Workflow" ;
  test:arrange "Start with empty pattern registry" ;
  test:act "Create workflow with exclusive_choice pattern" ;
  test:assert "Workflow created with choice gateway" ;
  test:expected_result "{ok, WorkflowDef}" ;
  .

yawl:test_exclusive_choice_select a test:TestCase ;
  rdfs:label "Select Path at Exclusive Choice" ;
  test:arrange "Create exclusive_choice workflow with 2 options" ;
  test:act "Evaluate condition, select path1" ;
  test:assert "Only path1 is activated, path2 not taken" ;
  test:expected_result "{ok, path1_selected}" ;
  .

yawl:test_exclusive_choice_single_path a test:TestCase ;
  rdfs:label "Verify Single Path Execution" ;
  test:arrange "Path1 selected" ;
  test:act "Complete path1 execution" ;
  test:assert "Workflow completes without executing path2" ;
  test:expected_result "{ok, completed}" ;
  .

# =============================================================================
# Pattern 5: Simple Merge
# =============================================================================

yawl:simple_merge a yawl:BasicControlFlow ;
  rdfs:label "Simple Merge" ;
  yawl:complexity "medium" ;
  test:has_test yawl:test_simple_merge_create ;
