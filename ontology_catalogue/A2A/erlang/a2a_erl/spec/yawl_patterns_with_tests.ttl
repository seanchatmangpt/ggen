yawl:deferred_choice a yawl:AdvancedControlFlow ;
  rdfs:label "Deferred Choice" ;
  yawl:complexity "medium" ;
  test:has_test yawl:test_deferred_choice_create ;
  test:has_test yawl:test_deferred_choice_runtime ;
  test:has_test yawl:test_deferred_choice_single ;
  .

yawl:test_deferred_choice_create a test:TestCase ;
  rdfs:label "Create Deferred Choice Workflow" ;
  test:arrange "Start with empty pattern registry" ;
  test:act "Create workflow with deferred_choice pattern" ;
  test:assert "Workflow created with deferred choice" ;
