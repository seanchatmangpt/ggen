#################################################################
# Kernel Properties and Relations
#################################################################

bscore:hasOpcode a owl:DatatypeProperty ;
  rdfs:label "hasOpcode" ;
  rdfs:comment "The numerical opcode for the kernel" ;
  rdfs:domain bscore:Kernel ;
  rdfs:range xsd:integer .

bscore:kernelCategory a owl:DatatypeProperty ;
  rdfs:label "kernelCategory" ;
  rdfs:comment "The functional category of the kernel" ;
  rdfs:domain bscore:Kernel ;
  rdfs:range xsd:string .

bscore:implementation a owl:DatatypeProperty ;
  rdfs:label "implementation" ;
  rdfs:comment "The C source file implementing this kernel" ;
  rdfs:domain bscore:Kernel ;
  rdfs:range xsd:string .

#################################################################
# Validation Constraints
#################################################################

# All kernels must have tick cost ≤ 8 (Doctrine of 8)
bscore:Kernel rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty bscore:hasTickCost ;
  owl:allValuesFrom [
    a rdfs:Datatype ;
    owl:onDatatype xsd:integer ;
    owl:withRestrictions (
      [ xsd:minInclusive "1"^^xsd:integer ]
      [ xsd:maxInclusive "8"^^xsd:integer ]
    )
  ]
] .

# All kernels must have unique opcodes
bscore:Kernel rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty bscore:hasOpcode ;
  owl:cardinality "1"^^xsd:nonNegativeInteger
] .