# Complete ByteStar Kernel Ontology - All 64 Kernels (A01..A64)
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bs: <urn:bs:> .
@prefix bscore: <https://bytestar.org/ontology/bytestar-core#> .

<https://bytestar.org/ontology/bytestar-kernels>
  a owl:Ontology ;
  rdfs:label "ByteStar Complete Kernel Definitions" ;
  rdfs:comment """Complete ontological definitions for all 64 ByteActor kernels (A01..A64).
    Each kernel is a constant-time, branch-free, L1-resident algorithm that executes in ≤8 CPU ticks.
    This ontology implements the Ontology-as-Algorithm (OAA) principle where these definitions
    directly drive the C implementation and validation.""" ;
  owl:versionInfo "3.0.0" ;
  owl:imports <https://bytestar.org/ontology/bytestar-core> .

#################################################################
# Movement Control Kernels (A01-A16)
#################################################################

<urn:bs:k/A01> a bscore:Kernel ;
  rdfs:label "MPHF Dispatch" ;
  rdfs:comment "Minimal Perfect Hash Function dispatch to target kernel" ;
  bscore:hasTickCost "2"^^xsd:integer ;
  bscore:hasOpcode "0"^^xsd:integer ;
  bscore:kernelCategory "movement_control" ;
  bscore:implementation "k01_mphf_dispatch.c" .

<urn:bs:k/A02> a bscore:Kernel ;
  rdfs:label "LOUDS Select" ;
