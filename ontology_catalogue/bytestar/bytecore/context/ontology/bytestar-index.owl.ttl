@prefix bcore_idx: <https://bytestar.org/ontology/bytecore-index#> .
@prefix :        <https://bytestar.org/ontology/bytecore-index#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

<https://bytestar.org/ontology/bytecore-index>
  a owl:Ontology ;
  rdfs:label "Bytecore v3 Module Index Ontology" ;
  rdfs:comment """A hyper-detailed, canonical index that formally defines the bytecore project.
    It serves as the single, authoritative entry point for any coding agent or system needing to understand the complete set of physical and logical contracts for the bytestar ecosystem.
    It achieves this by importing all constituent ABI, registry, and governance-hook ontologies under the canonical bytestar.org namespace.""" ;
  owl:versionInfo "v3.0.0" ;

  # I. CORE CANONS (The Foundational Vocabulary & Registries)
  # These ontologies define the "what" - the set of all legal kernels and patterns.
  owl:imports <https://bytestar.org/ontology/bytecore/core> ;
  owl:imports <https://bytestar.org/ontology/bytecore/kernels-registry> ;
  owl:imports <https://bytestar.org/ontology/bytecore/patterns-registry> ;

  # II. ABI CANONS (The Physical Contracts)
  # These ontologies define the "how" - the precise memory layouts and data structures.
  owl:imports <https://bytestar.org/ontology/bytecore/abi/envelope> ;
  owl:imports <https://bytestar.org/ontology/bytecore/abi/crystal> ;
  owl:imports <https://bytestar.org/ontology/bytecore/abi/pulse> ;
  owl:imports <https://bytestar.org/ontology/bytecore/abi/ring-spsc> ;
  owl:imports <https://bytestar.org/ontology/bytecore/abi/tables> ;
  owl:imports <https://bytestar.org/ontology/bytecore/abi/dispatch> ;
  owl:imports <https://bytestar.org/ontology/bytecore/abi/pqc> ;
  owl:imports <https://bytestar.org/ontology/bytecore/abi/nif-boundary> ;

  # III. GOVERNANCE HOOK CANONS (The Logical Contracts)
  # These ontologies define the rules and shapes that ByteFlow's admission gate uses.
  owl:imports <https://bytestar.org/ontology/bytecore/governance/admission-gate> ;
  owl:imports <https://bytestar.org/ontology/bytecore/governance/cxp-header> ;
  owl:imports <https://bytestar.org/ontology/bytecore/governance/pb-congruence> .

  # IV. PQC CANONS (The Post-Quantum Cryptography Contracts)
  # These ontologies define the PQC algorithms and their fabrics.
  owl:imports <https://bytestar.org/ontology/pqc-fabric-index> .

#################################################################
# Formal Definition of the Bytecore Project
#################################################################

bcore_idx:BytecoreProject a owl:Class ;
  rdfs:label "The Bytecore Project" .

:Bytecore_v3 a bcore_idx:BytecoreProject ;
  rdfs:label "Bytecore v3" ;
  rdfs:comment "The specific v3 release of the bytecore contracts. Any compliant system (ByteActor, ByteFlow, ByteEthos) MUST conform to the complete set of imported ontologies." ;
  bcore_idx:hasCanonicalVersion "3.0.0"^^xsd:string .

#################################################################
# Properties Defining the Imported Modules
#################################################################

bcore_idx:importsCoreCanon a owl:ObjectProperty .
bcore_idx:importsApiCanon a owl:ObjectProperty .
bcore_idx:importsGovernanceCanon a owl:ObjectProperty .

:Bytecore_v3
  bcore_idx:importsCoreCanon <https://bytestar.org/ontology/bytecore/core>,
                             <https://bytestar.org/ontology/bytecore/kernels-registry>,
                             <https://bytestar.org/ontology/bytecore/patterns-registry> ;
  
  bcore_idx:importsApiCanon <https://bytestar.org/ontology/bytecore/abi/envelope>,
                            <https://bytestar.org/ontology/bytecore/abi/crystal>,
                            <https://bytestar.org/ontology/bytecore/abi/pulse>,
                            <https://bytestar.org/ontology/bytecore/abi/ring-spsc>,
                            <https://bytestar.org/ontology/bytecore/abi/tables>,
                            <https://bytestar.org/ontology/bytecore/abi/dispatch>,
                            <https://bytestar.org/ontology/bytecore/abi/pqc>,
                            <https://bytestar.org/ontology/bytecore/abi/nif-boundary> ;

  bcore_idx:importsGovernanceCanon <https://bytestar.org/ontology/bytecore/governance/admission-gate>,
                                   <https://bytestar.org/ontology/bytecore/governance/cxp-header>,
                                   <https://bytestar.org/ontology/bytecore/governance/pb-congruence> .