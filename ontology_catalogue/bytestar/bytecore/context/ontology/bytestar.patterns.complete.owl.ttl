  rdfs:comment "Join data from multiple sources" ;
  bscore:hasHopCount "5"^^xsd:integer ;
  bscore:patternType "dataflow" ;
  bscore:complexity "high" .

<urn:bs:p/P28> a bscore:Pattern ;
  rdfs:label "Data Cache" ;
  rdfs:comment "Cache data for fast access" ;
  bscore:hasHopCount "2"^^xsd:integer ;
  bscore:patternType "dataflow" ;
  bscore:complexity "low" .

<urn:bs:p/P29> a bscore:Pattern ;
  rdfs:label "Data Compress" ;
  rdfs:comment "Compress data for storage" ;
  bscore:hasHopCount "4"^^xsd:integer ;
  bscore:patternType "dataflow" ;
  bscore:complexity "medium" .

<urn:bs:p/P30> a bscore:Pattern ;
  rdfs:label "Data Decompress" ;
