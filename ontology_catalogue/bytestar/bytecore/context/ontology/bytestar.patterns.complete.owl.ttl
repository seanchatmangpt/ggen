#################################################################

<urn:bs:p/P11> a bscore:Pattern ;
  rdfs:label "Fork-Join" ;
  rdfs:comment "Parallel execution with synchronization" ;
  bscore:hasHopCount "4"^^xsd:integer ;
  bscore:patternType "parallel" ;
  bscore:complexity "medium" .

<urn:bs:p/P12> a bscore:Pattern ;
  rdfs:label "Producer-Consumer" ;
  rdfs:comment "Producer-consumer parallel pattern" ;
  bscore:hasHopCount "5"^^xsd:integer ;
  bscore:patternType "parallel" ;
  bscore:complexity "medium" .

<urn:bs:p/P13> a bscore:Pattern ;
  rdfs:label "Pipeline Stage" ;
  rdfs:comment "Pipeline execution stage" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "parallel" ;
  bscore:complexity "low" .

<urn:bs:p/P14> a bscore:Pattern ;
  rdfs:label "Scatter-Gather" ;
  rdfs:comment "Scatter work, gather results" ;
  bscore:hasHopCount "6"^^xsd:integer ;
  bscore:patternType "parallel" ;
  bscore:complexity "high" .

<urn:bs:p/P15> a bscore:Pattern ;
  rdfs:label "Map-Reduce" ;
