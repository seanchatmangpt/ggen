<urn:bs:p/P21> a bscore:Pattern ;
  rdfs:label "Data Transform" ;
  rdfs:comment "Transform data format or structure" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "dataflow" ;
