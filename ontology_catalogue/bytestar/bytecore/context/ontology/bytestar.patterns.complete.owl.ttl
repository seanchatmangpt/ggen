# Complete ByteStar Pattern Ontology - All 43 Patterns (P01..P43)
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bs: <urn:bs:> .
@prefix bscore: <https://bytestar.org/ontology/bytestar-core#> .

<https://bytestar.org/ontology/bytestar-patterns>
  a owl:Ontology ;
  rdfs:label "ByteStar Complete Pattern Definitions" ;
  rdfs:comment """Complete ontological definitions for all 43 ByteFlow patterns (P01..P43).
    Each pattern defines a legal sequence of kernel executions that completes in ≤8 hops.
    These patterns implement workflow topologies for the ByteStar execution model.""" ;
  owl:versionInfo "3.0.0" ;
  owl:imports <https://bytestar.org/ontology/bytestar-core> .

#################################################################
# Sequential Patterns (P01-P10)
#################################################################

<urn:bs:p/P01> a bscore:Pattern ;
  rdfs:label "Linear Chain" ;
  rdfs:comment "Simple linear sequence of kernel executions" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "low" .

<urn:bs:p/P02> a bscore:Pattern ;
  rdfs:label "Conditional Branch" ;
  rdfs:comment "Two-way conditional execution pattern" ;
  bscore:hasHopCount "4"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "low" .

<urn:bs:p/P03> a bscore:Pattern ;
  rdfs:label "Loop Pattern" ;
  rdfs:comment "Bounded iteration pattern" ;
  bscore:hasHopCount "6"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "medium" .

<urn:bs:p/P04> a bscore:Pattern ;
  rdfs:label "Multi-Branch" ;
  rdfs:comment "Multi-way conditional execution" ;
  bscore:hasHopCount "5"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "medium" .

<urn:bs:p/P05> a bscore:Pattern ;
  rdfs:label "Nested Conditional" ;
  rdfs:comment "Nested conditional execution pattern" ;
  bscore:hasHopCount "7"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "medium" .

<urn:bs:p/P06> a bscore:Pattern ;
  rdfs:label "Sequential Merge" ;
  rdfs:comment "Merge multiple sequential paths" ;
  bscore:hasHopCount "5"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "medium" .

<urn:bs:p/P07> a bscore:Pattern ;
  rdfs:label "Error Recovery" ;
  rdfs:comment "Error handling and recovery pattern" ;
  bscore:hasHopCount "6"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "high" .

<urn:bs:p/P08> a bscore:Pattern ;
  rdfs:label "Transaction Begin" ;
  rdfs:comment "Start transactional execution" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "low" .

<urn:bs:p/P09> a bscore:Pattern ;
  rdfs:label "Transaction Commit" ;
  rdfs:comment "Commit transactional changes" ;
  bscore:hasHopCount "4"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "medium" .

<urn:bs:p/P10> a bscore:Pattern ;
  rdfs:label "Transaction Abort" ;
  rdfs:comment "Abort and rollback transaction" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "sequential" ;
  bscore:complexity "medium" .

