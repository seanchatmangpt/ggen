  bscore:hasHopCount "7"^^xsd:integer ;
  bscore:patternType "parallel" ;
  bscore:complexity "high" .

<urn:bs:p/P16> a bscore:Pattern ;
  rdfs:label "Barrier Sync" ;
  rdfs:comment "Barrier synchronization pattern" ;
  bscore:hasHopCount "2"^^xsd:integer ;
  bscore:patternType "parallel" ;
  bscore:complexity "low" .

<urn:bs:p/P17> a bscore:Pattern ;
  rdfs:label "Async Message" ;
  rdfs:comment "Asynchronous message passing" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "parallel" ;
  bscore:complexity "medium" .

<urn:bs:p/P18> a bscore:Pattern ;
  rdfs:label "Future Wait" ;
  rdfs:comment "Wait for future result" ;
  bscore:hasHopCount "2"^^xsd:integer ;
  bscore:patternType "parallel" ;
  bscore:complexity "low" .

<urn:bs:p/P19> a bscore:Pattern ;
  rdfs:label "Lock Acquire" ;
