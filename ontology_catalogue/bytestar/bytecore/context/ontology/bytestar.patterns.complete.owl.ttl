#################################################################

<urn:bs:p/P31> a bscore:Pattern ;
  rdfs:label "Admission Gate" ;
  rdfs:comment "Control admission to execution context" ;
  bscore:hasHopCount "2"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "low" .

<urn:bs:p/P32> a bscore:Pattern ;
  rdfs:label "Flow Control" ;
  rdfs:comment "Control execution flow rate" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "medium" .

<urn:bs:p/P33> a bscore:Pattern ;
  rdfs:label "Priority Queue" ;
  rdfs:comment "Priority-based execution ordering" ;
  bscore:hasHopCount "4"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "medium" .

<urn:bs:p/P34> a bscore:Pattern ;
  rdfs:label "Load Balance" ;
  rdfs:comment "Balance load across executors" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "medium" .

<urn:bs:p/P35> a bscore:Pattern ;
  rdfs:label "Circuit Breaker" ;
  rdfs:comment "Circuit breaker for fault tolerance" ;
  bscore:hasHopCount "2"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "medium" .

<urn:bs:p/P36> a bscore:Pattern ;
  rdfs:label "Retry Pattern" ;
  rdfs:comment "Retry failed operations" ;
  bscore:hasHopCount "5"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "medium" .

<urn:bs:p/P37> a bscore:Pattern ;
  rdfs:label "Timeout Control" ;
  rdfs:comment "Timeout-based execution control" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "medium" .

<urn:bs:p/P38> a bscore:Pattern ;
  rdfs:label "Resource Pool" ;
  rdfs:comment "Resource pooling and allocation" ;
  bscore:hasHopCount "4"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "high" .

<urn:bs:p/P39> a bscore:Pattern ;
  rdfs:label "Event Handler" ;
  rdfs:comment "Event-driven execution pattern" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "medium" .

<urn:bs:p/P40> a bscore:Pattern ;
  rdfs:label "State Machine" ;
  rdfs:comment "Finite state machine pattern" ;
  bscore:hasHopCount "4"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "high" .

<urn:bs:p/P41> a bscore:Pattern ;
  rdfs:label "Observer Pattern" ;
  rdfs:comment "Observer notification pattern" ;
  bscore:hasHopCount "2"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "low" .

<urn:bs:p/P42> a bscore:Pattern ;
  rdfs:label "Command Queue" ;
  rdfs:comment "Command queuing and execution" ;
  bscore:hasHopCount "3"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "medium" .

<urn:bs:p/P43> a bscore:Pattern ;
  rdfs:label "Workflow End" ;
  rdfs:comment "Workflow termination pattern" ;
  bscore:hasHopCount "1"^^xsd:integer ;
  bscore:patternType "control" ;
  bscore:complexity "low" .

#################################################################
# Pattern Properties and Relations
#################################################################

bscore:patternType a owl:DatatypeProperty ;
  rdfs:label "patternType" ;
  rdfs:comment "The functional type of the pattern" ;
  rdfs:domain bscore:Pattern ;
  rdfs:range xsd:string .

bscore:complexity a owl:DatatypeProperty ;
  rdfs:label "complexity" ;
  rdfs:comment "The execution complexity of the pattern" ;
  rdfs:domain bscore:Pattern ;
  rdfs:range xsd:string .

bscore:usesKernel a owl:ObjectProperty ;
  rdfs:label "usesKernel" ;
  rdfs:comment "Indicates which kernel a pattern uses" ;
  rdfs:domain bscore:Pattern ;
  rdfs:range bscore:Kernel .

bscore:followedBy a owl:ObjectProperty ;
  rdfs:label "followedBy" ;
  rdfs:comment "Indicates pattern execution order" ;
  rdfs:domain bscore:Pattern ;
  rdfs:range bscore:Pattern .

#################################################################
# Validation Constraints
#################################################################

# All patterns must have hop count ≤ 8 (Doctrine of 8)
bscore:Pattern rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty bscore:hasHopCount ;
  owl:allValuesFrom [
    a rdfs:Datatype ;
    owl:onDatatype xsd:integer ;
    owl:withRestrictions (
      [ xsd:minInclusive "1"^^xsd:integer ]
      [ xsd:maxInclusive "8"^^xsd:integer ]
    )
  ]
] .

# Pattern types must be from defined vocabulary
bscore:Pattern rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty bscore:patternType ;
  owl:allValuesFrom [
    a rdfs:Datatype ;
    owl:onDatatype xsd:string ;
    owl:withRestrictions (
      [ xsd:pattern "sequential|parallel|dataflow|control" ]
    )
  ]
] .