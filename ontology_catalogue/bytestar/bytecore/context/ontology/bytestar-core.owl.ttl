@prefix :        <https://bytestar.org/ontology/bytestar-core#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

<https://bytestar.org/ontology/bytestar-core>
  a owl:Ontology ;
  rdfs:label "Bytestar Core Canon" ;
  rdfs:comment """The foundational ontology for the entire bytestar ecosystem. 
    It defines the highest-level, canonical concepts such as Subsystems (A, F, E), 
    computational primitives (Kernels, Patterns), and the core data artifacts (Crystals, Envelopes).
    This canon is the immutable root of the ecosystem's vocabulary.""" ;
  owl:versionInfo "3.0.0" .

#################################################################
# 1. Core Architectural Classes (The Three Realms)
#################################################################

:Subsystem a owl:Class ;
  rdfs:label "Bytestar Subsystem" ;
  rdfs:comment "Represents one of the three core, physically isolated, and functionally distinct realms of the bytestar ecosystem: ByteActor (A), ByteFlow (F), or ByteEthos (E)." .

:ByteActor a owl:Class ;
  rdfs:subClassOf :Subsystem ;
  rdfs:label "ByteActor (A)" ;
  rdfs:comment "The C-fast, hot-path execution realm. Its sole purpose is the deterministic, <= 8-tick execution of a single crystal. It is governed by the physical laws of LGC." .

:ByteFlow a owl:Class ;
  rdfs:subClassOf :Subsystem ;
  rdfs:label "ByteFlow (F)" ;
  rdfs:comment "The Erlang-wide, warm-path orchestration realm. It is responsible for the AOT fabrication of artifacts, the admission of work via the Theta (Θ) predicate, and the strategic management of workflow lifecycles." .

:ByteEthos a owl:Class ;
  rdfs:subClassOf :Subsystem ;
  rdfs:label "ByteEthos (E)" ;
  rdfs:comment "The governance and finality realm. It enforces the canonical rules of the ecosystem, manages identity, and maintains the PQC-sealed append-only ledger." .

#################################################################
# 2. Core Computational & Data Primitives
#################################################################

:Kernel a owl:Class ;
  rdfs:label "ByteActor Kernel" ;
  rdfs:comment "A single, constant-time, branch-free, L1-resident C algorithm from the canonical set of 64. This is the atomic unit of execution." .

:Pattern a owl:Class ;
  rdfs:label "Workflow Pattern" ;
  rdfs:comment "A single, canonical workflow topology from the established set of 43. It defines a legal sequence of kernel executions." .

:Crystal a owl:Class ;
  rdfs:label "Crystal" ;
  rdfs:comment "The atomic unit of work in the ecosystem. It is a self-contained, sealed artifact composed of an envelope and pointers to AOT-fabricated tables." .

:Envelope a owl:Class ;
  rdfs:label "Envelope" ;
  rdfs:comment "The 64-byte, cache-line-aligned data structure that serves as the primary ingress/egress format for the ByteActor hot path." .

:AOT_Table a owl:Class ;
  rdfs:label "AOT-Fabricated Table" ;
  rdfs:comment "A read-only, L2-resident data structure (e.g., MPHF, LOUDS, XOR Filter, Bitset) that is generated by the ByteFlow AOT compiler." .

#################################################################
# 3. Core Contract & Governance Classes
#################################################################

:ABI a owl:Class ;
  rdfs:label "Application Binary Interface (ABI)" ;
  rdfs:comment "A formal, physical contract that defines the precise memory layout, alignment, and constant-time access patterns for a shared data structure." .

:Manifest a owl:Class ;
  rdfs:label "Fabrication Manifest" ;
  rdfs:comment "A declarative, machine-readable document that specifies all inputs to the AOT fabrication process, ensuring byte-for-byte reproducibility." .

:PQCTrait a owl:Class ;
  rdfs:label "Post-Quantum Cryptography Trait" ;
  rdfs:comment "A formal declaration of the PQC capabilities (verify, sign, keygen) required by a component, with their designated execution paths (warm/cold)." .

#################################################################
# 4. Core Properties
#################################################################

:conformsTo a owl:ObjectProperty ;
  rdfs:label "conformsTo" ;
  rdfs:comment "A fundamental property linking a Subsystem to an ABI it MUST obey. This property is the primary mechanism for enforcing architectural discipline." ;
  rdfs:domain :Subsystem ;
  rdfs:range :ABI .

:hasDigest a owl:DatatypeProperty ;
  rdfs:label "hasDigest" ;
  rdfs:comment "The BLAKE3 content-address (cid) of a Manifest, used to enforce driver parity and build reproducibility." ;
  rdfs:domain :Manifest ;
  rdfs:range xsd:hexBinary .

:toolchainLock a owl:DatatypeProperty ;
  rdfs:label "toolchainLock" ;
  rdfs:comment "A string within a Manifest that specifies the exact version and flags of the toolchain used for fabrication." ;
  rdfs:domain :Manifest ;
  rdfs:range xsd:string .

:providesVerify a owl:DatatypeProperty ;
  rdfs:label "providesVerify" ;
  rdfs:comment "A boolean property of a PQCTrait, indicating that a component provides a PQC verification capability, typically on a warm path." ;
  rdfs:domain :PQCTrait ;
  rdfs:range xsd:boolean .

:providesSign a owl:DatatypeProperty ;
  rdfs:label "providesSign" ;
  rdfs:comment "A boolean property of a PQCTrait, indicating that a component provides a PQC signing capability, typically on a cold path." ;
  rdfs:domain :PQCTrait ;
  rdfs:range xsd:boolean .

:providesKeygen a owl:DatatypeProperty ;
  rdfs:label "providesKeygen" ;
  rdfs:comment "A boolean property of a PQCTrait, indicating that a component provides a PQC key generation capability, typically on a cold path." ;
  rdfs:domain :PQCTrait ;
  rdfs:range xsd:boolean .