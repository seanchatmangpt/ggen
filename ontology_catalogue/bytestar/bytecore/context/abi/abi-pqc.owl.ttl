@prefix :        <https://bytestar.org/ontology/bytecore/abi/pqc#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix bcore:   <https://bytestar.org/ontology/bytestar-core#> .

<https://bytestar.org/ontology/bytecore/abi/pqc>
  a owl:Ontology ;
  rdfs:label "ByteCore PQC Artifact ABI" ;
  rdfs:comment "The ABI for data structures used in Post-Quantum Cryptography operations, like signatures and keys." ;
  owl:imports <https://bytestar.org/ontology/bytestar-core> ;
  owl:versionInfo "4.2.0" .

:PQCArtifactABI a owl:Class ; rdfs:subClassOf bcore:ABI .
