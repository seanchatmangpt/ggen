@prefix :        <https://bytestar.org/ontology/bytecore/abi/nif-boundary#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix bcore:   <https://bytestar.org/ontology/bytestar-core#> .

<https://bytestar.org/ontology/bytecore/abi/nif-boundary>
  a owl:Ontology ;
  rdfs:label "ByteCore NIF Boundary ABI" ;
  rdfs:comment "The ABI for data structures passed between the Erlang (ByteFlow) and C (ByteActor) realms." ;
  owl:imports <https://bytestar.org/ontology/bytestar-core> ;
  owl:versionInfo "4.2.0" .

:NIFBoundaryABI a owl:Class ; rdfs:subClassOf bcore:ABI .
