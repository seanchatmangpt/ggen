@prefix : <https://bytestar.org/ontology/byteethos/production-readiness#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bcore: <https://bytestar.org/ontology/bytestar-core#> .

<https://bytestar.org/ontology/byteethos/production-readiness>
  a owl:Ontology ;
  rdfs:label "ByteEthos Production Readiness Specification" ;
  rdfs:comment "Defines the formal requirements and metrics for ByteEthos to achieve Fortune 5 production readiness, covering scalability, reliability, security, and operational aspects." ;
  owl:versionInfo "1.0.0" ;
  owl:imports bcore: .

#################################################################
# Production Readiness Classes
#################################################################

:ProductionReadinessStatus a owl:Class ;
  rdfs:label "Production Readiness Status" ;
  rdfs:comment "Represents the overall readiness status of a ByteEthos deployment." .

:Ready a :ProductionReadinessStatus ; rdfs:label "Ready for Production" .
:NotReady a :ProductionReadinessStatus ; rdfs:label "Not Ready for Production" .
:Degraded a :ProductionReadinessStatus ; rdfs:label "Degraded Production" .

:ProductionReadinessMetric a owl:Class ;
  rdfs:label "Production Readiness Metric" ;
  rdfs:comment "A quantifiable measure used to assess production readiness." .

:ComplianceStandard a owl:Class ;
  rdfs:label "Compliance Standard" ;
  rdfs:comment "A regulatory or industry standard that ByteEthos must conform to." .

:OperationalRequirement a owl:Class ;
  rdfs:label "Operational Requirement" ;
  rdfs:comment "A requirement related to the deployment, management, or maintenance of ByteEthos in production." .

:SecurityPosture a owl:Class ;
  rdfs:label "Security Posture" ;
  rdfs:comment "Describes the security state and controls implemented for ByteEthos." .

#################################################################
# Production Readiness Properties
#################################################################

:hasStatus a owl:ObjectProperty ;
  rdfs:label "has status" ;
  rdfs:domain bcore:ByteEthos ;
  rdfs:range :ProductionReadinessStatus ;
  rdfs:comment "Links a ByteEthos instance to its overall production readiness status." .

:hasMetric a owl:ObjectProperty ;
  rdfs:label "has metric" ;
  rdfs:domain bcore:ByteEthos ;
  rdfs:range :ProductionReadinessMetric ;
  rdfs:comment "Links a ByteEthos instance to a specific production readiness metric." .

:conformsTo a owl:ObjectProperty ;
  rdfs:label "conforms to" ;
  rdfs:domain bcore:ByteEthos ;
  rdfs:range :ComplianceStandard ;
  rdfs:comment "Indicates that a ByteEthos instance conforms to a specific compliance standard." .

:meetsRequirement a owl:ObjectProperty ;
  rdfs:label "meets requirement" ;
  rdfs:domain bcore:ByteEthos ;
  rdfs:range :OperationalRequirement ;
  rdfs:comment "Indicates that a ByteEthos instance meets a specific operational requirement." .

:hasSecurityPosture a owl:ObjectProperty ;
  rdfs:label "has security posture" ;
  rdfs:domain bcore:ByteEthos ;
  rdfs:range :SecurityPosture ;
  rdfs:comment "Describes the security posture of a ByteEthos instance." .

# Metric-specific properties
:metricName a owl:DatatypeProperty ;
  rdfs:label "metric name" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:string .

:metricValue a owl:DatatypeProperty ;
  rdfs:label "metric value" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:decimal .

:targetValue a owl:DatatypeProperty ;
  rdfs:label "target value" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:decimal .

:thresholdValue a owl:DatatypeProperty ;
  rdfs:label "threshold value" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:decimal .

:unit a owl:DatatypeProperty ;
  rdfs:label "unit" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:string .

# Compliance Standard properties
:standardName a owl:DatatypeProperty ;
  rdfs:label "standard name" ;
  rdfs:domain :ComplianceStandard ;
  rdfs:range xsd:string .

# Operational Requirement properties
:requirementName a owl:DatatypeProperty ;
  rdfs:label "requirement name" ;
  rdfs:domain :OperationalRequirement ;
  rdfs:range xsd:string .

# Security Posture properties
:postureLevel a owl:DatatypeProperty ;
  rdfs:label "posture level" ;
  rdfs:domain :SecurityPosture ;
  rdfs:range xsd:string .

:controlImplemented a owl:DatatypeProperty ;
  rdfs:label "control implemented" ;
  rdfs:domain :SecurityPosture ;
  rdfs:range xsd:boolean .
