@prefix : <https://bytestar.org/ontology/byteethos/zk-compliance#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/2002/07/rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ethos: <https://bytestar.org/ontology/byteethos/ethos-framework#> .
@prefix risk: <https://bytestar.org/ontology/byteethos/risk-classification#> .

<https://bytestar.org/ontology/byteethos/zk-compliance>
    a owl:Ontology ;
    rdfs:label "Zero-Knowledge Compliance Ontology" ;
    rdfs:comment """
    Comprehensive ontology for Zero-Knowledge Proof-based compliance verification
    within the ETHOS framework. Enables privacy-preserving compliance checking
    while maintaining transparency and auditability.
    
    Supports multiple ZK proof systems:
    - zk-SNARKs for succinct proofs
    - zk-STARKs for quantum-resistant proofs
    - Bulletproofs for range proofs
    - Plonk for universal setup
    """ ;
    owl:imports <https://bytestar.org/ontology/byteethos/ethos-framework> ,
                <https://bytestar.org/ontology/byteethos/risk-classification> ;
    owl:versionInfo "1.0.0" ;
    owl:versionIRI <https://bytestar.org/ontology/byteethos/zk-compliance/1.0.0> .

#################################################################
# Zero-Knowledge Proof Systems
#################################################################

:ZKProofSystem a owl:Class ;
    rdfs:label "Zero-Knowledge Proof System" ;
    rdfs:comment "Cryptographic system enabling zero-knowledge proofs." .

:ZKSNARK a :ZKProofSystem ;
    rdfs:label "zk-SNARK" ;
    rdfs:comment "Zero-Knowledge Succinct Non-Interactive Argument of Knowledge." .

:ZKSTARK a :ZKProofSystem ;
    rdfs:label "zk-STARK" ;
    rdfs:comment "Zero-Knowledge Scalable Transparent Argument of Knowledge." .

:Bulletproof a :ZKProofSystem ;
    rdfs:label "Bulletproof" ;
    rdfs:comment "Short zero-knowledge proofs for confidential transactions." .

:Plonk a :ZKProofSystem ;
    rdfs:label "PLONK" ;
    rdfs:comment "Permutations over Lagrange-bases for Oecumenical Noninteractive arguments of Knowledge." .

:Groth16 a :ZKProofSystem ;
    rdfs:label "Groth16" ;
    rdfs:comment "Efficient zk-SNARK construction." .

:Marlin a :ZKProofSystem ;
    rdfs:label "Marlin" ;
    rdfs:comment "Universal zk-SNARK with efficient verification." .

#################################################################
# Circuit Design and Implementation
#################################################################

:ArithmeticCircuit a owl:Class ;
    rdfs:label "Arithmetic Circuit" ;
    rdfs:comment "Circuit representation using arithmetic operations." .

:BooleanCircuit a owl:Class ;
    rdfs:label "Boolean Circuit" ;
    rdfs:comment "Circuit representation using boolean operations." .

:R1CSCircuit a owl:Class ;
    rdfs:label "R1CS Circuit" ;
    rdfs:comment "Rank-1 Constraint System circuit representation." .

:CircuitCompiler a owl:Class ;
    rdfs:label "Circuit Compiler" ;
    rdfs:comment "Tool for compiling high-level code to circuits." .

:ConstraintSystem a owl:Class ;
    rdfs:label "Constraint System" ;
    rdfs:comment "System of constraints defining the circuit." .

#################################################################
# Compliance-Specific Circuits
#################################################################

:ComplianceCircuit a owl:Class ;
    rdfs:subClassOf ethos:ZKCircuit ;
    rdfs:label "Compliance Circuit" ;
    rdfs:comment "ZK circuit for proving regulatory compliance." .

:PrivacyComplianceCircuit a :ComplianceCircuit ;
    rdfs:label "Privacy Compliance Circuit" ;
    rdfs:comment "Circuit for proving privacy protection compliance." .

:FairnessComplianceCircuit a :ComplianceCircuit ;
    rdfs:label "Fairness Compliance Circuit" ;
    rdfs:comment "Circuit for proving fairness in AI decisions." .

:SafetyComplianceCircuit a :ComplianceCircuit ;
    rdfs:label "Safety Compliance Circuit" ;
    rdfs:comment "Circuit for proving safety guarantees." .

:TransparencyCircuit a :ComplianceCircuit ;
    rdfs:label "Transparency Circuit" ;
    rdfs:comment "Circuit for proving transparency compliance." .

:AccountabilityCircuit a :ComplianceCircuit ;
    rdfs:label "Accountability Circuit" ;
    rdfs:comment "Circuit for proving accountability measures." .

:BiasDetectionCircuit a :ComplianceCircuit ;
    rdfs:label "Bias Detection Circuit" ;
    rdfs:comment "Circuit for proving absence of discriminatory bias." .

:DataGovernanceCircuit a :ComplianceCircuit ;
    rdfs:label "Data Governance Circuit" ;
    rdfs:comment "Circuit for proving data handling compliance." .

#################################################################
# Proof Generation and Verification
#################################################################

:ProofGeneration a owl:Class ;
    rdfs:label "Proof Generation" ;
    rdfs:comment "Process of generating zero-knowledge proofs." .

:ProofVerification a owl:Class ;
    rdfs:label "Proof Verification" ;
    rdfs:comment "Process of verifying zero-knowledge proofs." .

:TrustedSetup a owl:Class ;
    rdfs:label "Trusted Setup" ;
    rdfs:comment "Initial setup ceremony for generating proving/verification keys." .

:UniversalSetup a owl:Class ;
    rdfs:label "Universal Setup" ;
    rdfs:comment "Setup that can be reused across multiple circuits." .

:CircuitSpecificSetup a owl:Class ;
    rdfs:label "Circuit-Specific Setup" ;
    rdfs:comment "Setup specific to individual circuits." .

:CeremonyParticipant a owl:Class ;
    rdfs:label "Ceremony Participant" ;
    rdfs:comment "Entity participating in trusted setup ceremony." .

#################################################################
# Cryptographic Keys and Parameters
#################################################################

:ProvingKey a owl:Class ;
    rdfs:label "Proving Key" ;
    rdfs:comment "Cryptographic key used for proof generation." .

:VerificationKey a owl:Class ;
    rdfs:label "Verification Key" ;
    rdfs:comment "Cryptographic key used for proof verification." .

:PublicParameters a owl:Class ;
    rdfs:label "Public Parameters" ;
    rdfs:comment "Public parameters for the ZK proof system." .

:PrivateWitness a owl:Class ;
    rdfs:label "Private Witness" ;
    rdfs:comment "Private inputs used in proof generation." .

:PublicInput a owl:Class ;
    rdfs:label "Public Input" ;
    rdfs:comment "Public inputs to the circuit." .

:CircuitHash a owl:Class ;
    rdfs:label "Circuit Hash" ;
    rdfs:comment "Cryptographic hash of the circuit." .

#################################################################
# Compliance Verification Process
#################################################################

:ComplianceAttestation a owl:Class ;
    rdfs:label "Compliance Attestation" ;
    rdfs:comment "Attestation of compliance using ZK proofs." .

:ComplianceReport a owl:Class ;
    rdfs:label "Compliance Report" ;
    rdfs:comment "Report containing compliance verification results." .

:ComplianceAuditor a owl:Class ;
    rdfs:label "Compliance Auditor" ;
    rdfs:comment "Entity responsible for compliance verification." .

:ComplianceCertificate a owl:Class ;
    rdfs:label "Compliance Certificate" ;
    rdfs:comment "Certificate proving compliance status." .

:NonComplianceEvidence a owl:Class ;
    rdfs:label "Non-Compliance Evidence" ;
    rdfs:comment "Evidence of compliance violations." .

:ComplianceTimestamp a owl:Class ;
    rdfs:label "Compliance Timestamp" ;
    rdfs:comment "Timestamped proof of compliance at specific time." .

#################################################################
# Privacy-Preserving Computation
#################################################################

:SecureComputation a owl:Class ;
    rdfs:label "Secure Computation" ;
    rdfs:comment "Computation that preserves input privacy." .

:MultiPartyComputation a owl:Class ;
    rdfs:label "Multi-Party Computation" ;
    rdfs:comment "Computation involving multiple parties with private inputs." .

:HomomorphicEncryption a owl:Class ;
    rdfs:label "Homomorphic Encryption" ;
    rdfs:comment "Encryption allowing computation on encrypted data." .

:SecretSharing a owl:Class ;
    rdfs:label "Secret Sharing" ;
    rdfs:comment "Method for distributing secret among multiple parties." .

:ObliviousTransfer a owl:Class ;
    rdfs:label "Oblivious Transfer" ;
    rdfs:comment "Protocol where receiver obtains subset of data without revealing which." .

#################################################################
# Performance and Scalability
#################################################################

:ProofSize a owl:Class ;
    rdfs:label "Proof Size" ;
    rdfs:comment "Size of the generated proof in bytes." .

:VerificationTime a owl:Class ;
    rdfs:label "Verification Time" ;
    rdfs:comment "Time required to verify a proof." .

:GenerationTime a owl:Class ;
    rdfs:label "Generation Time" ;
    rdfs:comment "Time required to generate a proof." .

:ComputationalComplexity a owl:Class ;
    rdfs:label "Computational Complexity" ;
    rdfs:comment "Computational complexity of proof generation/verification." .

:MemoryRequirement a owl:Class ;
    rdfs:label "Memory Requirement" ;
    rdfs:comment "Memory required for proof generation/verification." .

:Scalability a owl:Class ;
    rdfs:label "Scalability" ;
    rdfs:comment "Scalability characteristics of the ZK system." .

#################################################################
# Properties for ZK Compliance
#################################################################

:usesProofSystem a owl:ObjectProperty ;
    rdfs:label "uses proof system" ;
    rdfs:domain :ComplianceCircuit ;
    rdfs:range :ZKProofSystem ;
    rdfs:comment "Specifies which ZK proof system is used." .

:hasProvingKey a owl:ObjectProperty ;
    rdfs:label "has proving key" ;
    rdfs:domain :ComplianceCircuit ;
    rdfs:range :ProvingKey ;
    rdfs:comment "Associates circuit with its proving key." .

:hasVerificationKey a owl:ObjectProperty ;
    rdfs:label "has verification key" ;
    rdfs:domain :ComplianceCircuit ;
    rdfs:range :VerificationKey ;
    rdfs:comment "Associates circuit with its verification key." .

:generatedBy a owl:ObjectProperty ;
    rdfs:label "generated by" ;
    rdfs:domain ethos:ZKProof ;
    rdfs:range :ProofGeneration ;
    rdfs:comment "Links proof to its generation process." .

:verifiedBy a owl:ObjectProperty ;
    rdfs:label "verified by" ;
    rdfs:domain ethos:ZKProof ;
    rdfs:range :ProofVerification ;
    rdfs:comment "Links proof to its verification process." .

:attestedBy a owl:ObjectProperty ;
    rdfs:label "attested by" ;
    rdfs:domain :ComplianceAttestation ;
    rdfs:range :ComplianceAuditor ;
    rdfs:comment "Indicates who provided the attestation." .

:basedOnProof a owl:ObjectProperty ;
    rdfs:label "based on proof" ;
    rdfs:domain :ComplianceAttestation ;
    rdfs:range ethos:ZKProof ;
    rdfs:comment "Links attestation to underlying ZK proof." .

:derivedFromSetup a owl:ObjectProperty ;
    rdfs:label "derived from setup" ;
    rdfs:domain :ProvingKey ;
    rdfs:range :TrustedSetup ;
    rdfs:comment "Links proving key to its trusted setup." .

:participatedIn a owl:ObjectProperty ;
    rdfs:label "participated in" ;
    rdfs:domain :CeremonyParticipant ;
    rdfs:range :TrustedSetup ;
    rdfs:comment "Indicates participation in trusted setup ceremony." .

:implementsCircuit a owl:ObjectProperty ;
    rdfs:label "implements circuit" ;
    rdfs:domain :CircuitCompiler ;
    rdfs:range :ComplianceCircuit ;
    rdfs:comment "Links compiler to implemented circuit." .

:hasConstraints a owl:ObjectProperty ;
    rdfs:label "has constraints" ;
    rdfs:domain :ComplianceCircuit ;
    rdfs:range :ConstraintSystem ;
    rdfs:comment "Links circuit to its constraint system." .

:measuredBy a owl:ObjectProperty ;
    rdfs:label "measured by" ;
    rdfs:domain ethos:ZKProof ;
    rdfs:range :PerformanceMetric ;
    rdfs:comment "Links proof to performance measurements." .

#################################################################
# Data Properties for ZK Metrics
#################################################################

:proofSizeBytes a owl:DatatypeProperty ;
    rdfs:label "proof size bytes" ;
    rdfs:domain ethos:ZKProof ;
    rdfs:range xsd:integer ;
    rdfs:comment "Size of the proof in bytes." .

:verificationTimeMs a owl:DatatypeProperty ;
    rdfs:label "verification time milliseconds" ;
    rdfs:domain ethos:ZKProof ;
    rdfs:range xsd:integer ;
    rdfs:comment "Time to verify proof in milliseconds." .

:generationTimeMs a owl:DatatypeProperty ;
    rdfs:label "generation time milliseconds" ;
    rdfs:domain ethos:ZKProof ;
    rdfs:range xsd:integer ;
    rdfs:comment "Time to generate proof in milliseconds." .

:memoryUsageMB a owl:DatatypeProperty ;
    rdfs:label "memory usage megabytes" ;
    rdfs:domain ethos:ZKProof ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Memory usage during proof generation in MB." .

:securityLevel a owl:DatatypeProperty ;
    rdfs:label "security level" ;
    rdfs:domain :ZKProofSystem ;
    rdfs:range xsd:integer ;
    rdfs:comment "Security level in bits." .

:constraintCount a owl:DatatypeProperty ;
    rdfs:label "constraint count" ;
    rdfs:domain :ComplianceCircuit ;
    rdfs:range xsd:integer ;
    rdfs:comment "Number of constraints in the circuit." .

:setupToxicity a owl:DatatypeProperty ;
    rdfs:label "setup toxicity" ;
    rdfs:domain :TrustedSetup ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether setup parameters are toxic if revealed." .

:universalSetup a owl:DatatypeProperty ;
    rdfs:label "universal setup" ;
    rdfs:domain :ZKProofSystem ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether the system uses universal setup." .

:quantumResistant a owl:DatatypeProperty ;
    rdfs:label "quantum resistant" ;
    rdfs:domain :ZKProofSystem ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether the system is quantum resistant." .

:transparentSetup a owl:DatatypeProperty ;
    rdfs:label "transparent setup" ;
    rdfs:domain :ZKProofSystem ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether the setup is transparent (no trusted setup)." .

:succinctness a owl:DatatypeProperty ;
    rdfs:label "succinctness" ;
    rdfs:domain ethos:ZKProof ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Succinctness ratio of proof size to statement size." .

:soundnessParameter a owl:DatatypeProperty ;
    rdfs:label "soundness parameter" ;
    rdfs:domain :ZKProofSystem ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Soundness parameter of the proof system." .

:completenessParameter a owl:DatatypeProperty ;
    rdfs:label "completeness parameter" ;
    rdfs:domain :ZKProofSystem ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Completeness parameter of the proof system." .

:zeroKnowledgeParameter a owl:DatatypeProperty ;
    rdfs:label "zero knowledge parameter" ;
    rdfs:domain :ZKProofSystem ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Zero-knowledge parameter of the proof system." .

#################################################################
# Compliance Verification Rules
#################################################################

# Rule: High-risk agents require zk-STARK proofs for quantum resistance
:HighRiskQuantumResistanceRule a owl:Class ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty ethos:hasRiskTier ;
        owl:hasValue risk:HighRisk
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty :usesProofSystem ;
        owl:hasValue :ZKSTARK
    ] ;
    rdfs:comment "High-risk agents must use quantum-resistant zk-STARK proofs." .

# Rule: Privacy compliance requires specific circuit
:PrivacyComplianceRule a owl:Class ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty ethos:adheresTo ;
        owl:hasValue ethos:Privacy
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty ethos:verifiedBy ;
        owl:someValuesFrom :PrivacyComplianceCircuit
    ] ;
    rdfs:comment "Privacy compliance must be verified using privacy compliance circuit." .

# Rule: Fairness verification requires bias detection circuit
:FairnessVerificationRule a owl:Class ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty ethos:adheresTo ;
        owl:hasValue ethos:Fairness
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty ethos:verifiedBy ;
        owl:someValuesFrom :BiasDetectionCircuit
    ] ;
    rdfs:comment "Fairness compliance requires bias detection circuit verification." .

# Rule: Unacceptable risk agents cannot generate compliance proofs
:UnacceptableRiskProofProhibition a owl:Class ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty ethos:hasRiskTier ;
        owl:hasValue risk:UnacceptableRisk
    ] ;
    owl:disjointWith [
        a owl:Restriction ;
        owl:onProperty :generatedBy ;
        owl:someValuesFrom :ProofGeneration
    ] ;
    rdfs:comment "Unacceptable risk agents cannot generate compliance proofs." .

#################################################################
# Performance Optimization Classes
#################################################################

:BatchVerification a owl:Class ;
    rdfs:label "Batch Verification" ;
    rdfs:comment "Optimization technique for verifying multiple proofs together." .

:RecursiveProof a owl:Class ;
    rdfs:label "Recursive Proof" ;
    rdfs:comment "Proof that verifies other proofs within itself." .

:ProofAggregation a owl:Class ;
    rdfs:label "Proof Aggregation" ;
    rdfs:comment "Technique for combining multiple proofs into one." .

:IncrementalVerification a owl:Class ;
    rdfs:label "Incremental Verification" ;
    rdfs:comment "Verification that builds on previous verifications." .

:CachedVerification a owl:Class ;
    rdfs:label "Cached Verification" ;
    rdfs:comment "Optimization using cached verification results." .