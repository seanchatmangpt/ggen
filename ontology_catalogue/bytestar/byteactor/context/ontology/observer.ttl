@prefix obs:   <http://bitbizeco.dev/ontology/v3/observer#> .
@prefix :      <http://bitbizeco.dev/ontology/v3/observer#> .
@prefix ba3:   <http://bitbizeco.dev/ontology/v3/byteactor#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<http://bitbizeco.dev/ontology/v3/observer>
  a owl:Ontology ;
  rdfs:label "ByteActor v3 Observer & Afterlife Ontology" ;
  rdfs:comment "The formal ontology for the off-path observers and the completion pulse emitted by the ByteActor core." .

#################################################################
# Core Classes
#################################################################

obs:CompletionPulse  a owl:Class ; rdfs:label "Completion Pulse" .
obs:Observer         a owl:Class ; rdfs:label "Observer" .

# Observer Specializations
obs:CrystalManager   a owl:Class ; rdfs:subClassOf obs:Observer .
obs:Telemetry        a owl:Class ; rdfs:subClassOf obs:Observer .
obs:Metrics          a owl:Class ; rdfs:subClassOf obs:Observer .
obs:Logging          a owl:Class ; rdfs:subClassOf obs:Observer .
obs:Governance       a owl:Class ; rdfs:subClassOf obs:Observer .

#################################################################
# Properties
#################################################################

obs:inputCrystalId   a owl:DatatypeProperty ; rdfs:domain obs:CompletionPulse ; rdfs:range xsd:unsignedLong .
obs:outputCrystalId  a owl:DatatypeProperty ; rdfs:domain obs:CompletionPulse ; rdfs:range xsd:unsignedLong .
obs:cubePosition     a owl:DatatypeProperty ; rdfs:domain obs:CompletionPulse ; rdfs:range xsd:integer .
obs:tickRange        a owl:DatatypeProperty ; rdfs:domain obs:CompletionPulse ; rdfs:range xsd:string .

obs:subscribesTo     a owl:ObjectProperty ; rdfs:domain obs:Observer ; rdfs:range ba3:Actor .