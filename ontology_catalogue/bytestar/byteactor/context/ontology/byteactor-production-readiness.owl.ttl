@prefix : <https://bytestar.org/ontology/byteactor/production-readiness#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bcore: <https://bytestar.org/ontology/bytestar-core#> .

<https://bytestar.org/ontology/byteactor/production-readiness>
  a owl:Ontology ;
  rdfs:label "ByteActor Production Readiness Specification" ;
  rdfs:comment "Defines the formal requirements and metrics for ByteActor to achieve Fortune 5 production readiness, focusing on deterministic performance, resource utilization, and reliability." ;
  owl:versionInfo "1.0.0" ;
  owl:imports bcore: .

#################################################################
# Production Readiness Classes
#################################################################

:ProductionReadinessStatus a owl:Class ;
  rdfs:label "Production Readiness Status" ;
  rdfs:comment "Represents the overall readiness status of a ByteActor deployment." .

:Ready a :ProductionReadinessStatus ; rdfs:label "Ready for Production" .
:NotReady a :ProductionReadinessStatus ; rdfs:label "Not Ready for Production" .
:Degraded a :ProductionReadinessStatus ; rdfs:label "Degraded Production" .

:ProductionReadinessMetric a owl:Class ;
  rdfs:label "Production Readiness Metric" ;
  rdfs:comment "A quantifiable measure used to assess ByteActor's production readiness." .

:PerformanceRequirement a owl:Class ;
  rdfs:label "Performance Requirement" ;
  rdfs:comment "A requirement related to ByteActor's speed, throughput, or latency." .

:ResourceUtilizationRequirement a owl:Class ;
  rdfs:label "Resource Utilization Requirement" ;
  rdfs:comment "A requirement related to ByteActor's memory, CPU, or cache usage." .

:ReliabilityRequirement a owl:Class ;
  rdfs:label "Reliability Requirement" ;
  rdfs:comment "A requirement related to ByteActor's fault tolerance, data integrity, or uptime." .

:SecurityControl a owl:Class ;
  rdfs:label "Security Control" ;
  rdfs:comment "A specific security measure implemented in ByteActor." .

#################################################################
# Production Readiness Properties
#################################################################

:hasStatus a owl:ObjectProperty ;
  rdfs:label "has status" ;
  rdfs:domain bcore:ByteActor ;
  rdfs:range :ProductionReadinessStatus ;
  rdfs:comment "Links a ByteActor instance to its overall production readiness status." .

:hasMetric a owl:ObjectProperty ;
  rdfs:label "has metric" ;
  rdfs:domain bcore:ByteActor ;
  rdfs:range :ProductionReadinessMetric ;
  rdfs:comment "Links a ByteActor instance to a specific production readiness metric." .

:meetsPerformanceRequirement a owl:ObjectProperty ;
  rdfs:label "meets performance requirement" ;
  rdfs:domain bcore:ByteActor ;
  rdfs:range :PerformanceRequirement ;
  rdfs:comment "Indicates that a ByteActor instance meets a specific performance requirement." .

:meetsResourceRequirement a owl:ObjectProperty ;
  rdfs:label "meets resource utilization requirement" ;
  rdfs:domain bcore:ByteActor ;
  rdfs:range :ResourceUtilizationRequirement ;
  rdfs:comment "Indicates that a ByteActor instance meets a specific resource utilization requirement." .

:meetsReliabilityRequirement a owl:ObjectProperty ;
  rdfs:label "meets reliability requirement" ;
  rdfs:domain bcore:ByteActor ;
  rdfs:range :ReliabilityRequirement ;
  rdfs:comment "Indicates that a ByteActor instance meets a specific reliability requirement." .

:implementsSecurityControl a owl:ObjectProperty ;
  rdfs:label "implements security control" ;
  rdfs:domain bcore:ByteActor ;
  rdfs:range :SecurityControl ;
  rdfs:comment "Indicates that a ByteActor instance implements a specific security control." .

# Metric-specific properties
:metricName a owl:DatatypeProperty ;
  rdfs:label "metric name" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:string .

:metricValue a owl:DatatypeProperty ;
  rdfs:label "metric value" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:decimal .

:targetValue a owl:DatatypeProperty ;
  rdfs:label "target value" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:decimal .

:thresholdValue a owl:DatatypeProperty ;
  rdfs:label "threshold value" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:decimal .

:unit a owl:DatatypeProperty ;
  rdfs:label "unit" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:string .

# Requirement-specific properties
:requirementName a owl:DatatypeProperty ;
  rdfs:label "requirement name" ;
  rdfs:domain owl:Thing ;
  rdfs:range xsd:string .

# Security Control properties
:controlName a owl:DatatypeProperty ;
  rdfs:label "control name" ;
  rdfs:domain :SecurityControl ;
  rdfs:range xsd:string .

:isImplemented a owl:DatatypeProperty ;
  rdfs:label "is implemented" ;
  rdfs:domain :SecurityControl ;
  rdfs:range xsd:boolean .
