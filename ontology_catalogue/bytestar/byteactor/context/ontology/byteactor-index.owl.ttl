@prefix bactor_idx: <https://bytestar.org/ontology/byteactor-index#> .
@prefix :          <https://bytestar.org/ontology/byteactor-index#> .
@prefix owl:       <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:      <http://www.w3.org/2000/01/rdf-schema#> .

<https://bytestar.org/ontology/byteactor-index>
  a owl:Ontology ;
  owl:versionInfo "4.2.0" ;
  rdfs:label "ByteActor v3 Module Index Ontology" ;
  rdfs:comment "The canonical index for the ByteActor subsystem. It imports the core contracts from ByteCore and all specifications local to ByteActor, including its definitive Kernel Registry." ;

  owl:imports <https://bytestar.org/ontology/bytecore-index> ,
              <https://bytestar.org/ontology/byteactor/dflss-plan> ,
              <https://bytestar.org/ontology/byteactor/testing-canon> ,
              <https://bytestar.org/ontology/byteactor/kernels-registry> ,
              <https://bytestar.org/ontology/byteactor/implementation/kernels-A01-A12> ,
              <https://bytestar.org/ontology/byteactor/implementation/kernels-A13-A24> ,
              <https://bytestar.org/ontology/byteactor/implementation/kernels-A25-A32> ,
              <https://bytestar.org/ontology/byteactor/implementation/kernels-A33-A36> ,
              <https://bytestar.org/ontology/byteactor/implementation/kernels-A37-A40> ,
              <https://bytestar.org/ontology/byteactor/implementation/kernels-A41-A49> ,
              <https://bytestar.org/ontology/byteactor/implementation/kernels-A50-A59> ,
              <https://bytestar.org/ontology/byteactor/implementation/kernels-A60-A64> ,
              <https://bytestar.org/ontology/byteactor/production-readiness#> ,
              <https://bytestar.org/ontology/byteactor/production-shapes#> ,
              <https://bytestar.org/ontology/byteactor/production-queries#> .
