#################################################################
#
# BUILD SYSTEM SPECIFICATION
#
#################################################################

:CMakeBuildSystem a build:BuildSystem ;
  rdfs:label "CMake Build Configuration" ;
  build:buildFile "CMakeLists.txt" ;
  build:minVersion "3.20" ;
  build:cStandard "C11" ;
  build:compilerFlags "-O3 -march=native -Wall -Wextra -Werror" ;
  build:dependencies [
    build:name "numa" ;
    build:version ">=2.0.14" ;
    build:required true
  ], [
    build:name "blake3" ;
    build:version ">=1.3.0" ;
    build:required true
  ] ;
  build:targets [
    build:name "bitactor_core" ;
    build:type "STATIC_LIBRARY" ;
    build:sources "src/bitactor_core.c src/bitactor_dispatch.c src/bitactor_memory.c" ;
    build:includeDirectories "include/" ;
    build:linkLibraries "numa blake3"
  ], [
    build:name "bitactor_nif" ;
    build:type "SHARED_LIBRARY" ;
    build:sources "src/bitactor_nif.c" ;
    build:linkLibraries "bitactor_core" ;
    build:properties "PREFIX '', SUFFIX '.so'"
  ] ;
  build:cmakeContent """
cmake_minimum_required(VERSION 3.20)
project(ByteActor C)

set(CMAKE_C_STANDARD 11)
set(CMAKE_C_STANDARD_REQUIRED ON)
set(CMAKE_C_FLAGS_RELEASE "-O3 -march=native -DNDEBUG -ffast-math")

# Find dependencies
find_package(PkgConfig REQUIRED)
pkg_check_modules(NUMA REQUIRED numa)
pkg_check_modules(BLAKE3 REQUIRED libblake3)

# Core library
add_library(bitactor_core STATIC
    src/bitactor_core.c
    src/bitactor_dispatch.c
    src/bitactor_memory.c
    src/bitactor_blake3.c
    src/bitactor_telemetry.c
)

target_include_directories(bitactor_core PUBLIC include/)
target_link_libraries(bitactor_core ${NUMA_LIBRARIES} ${BLAKE3_LIBRARIES})

# NIF shared library
add_library(bitactor_nif SHARED src/bitactor_nif.c)
target_link_libraries(bitactor_nif bitactor_core)
set_target_properties(bitactor_nif PROPERTIES PREFIX "" SUFFIX ".so")

# Tests
enable_testing()
add_subdirectory(tests)

# Benchmarks
add_subdirectory(benchmarks)
""" .

#################################################################
#
# TEST SPECIFICATIONS
