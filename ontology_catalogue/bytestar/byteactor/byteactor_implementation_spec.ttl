#################################################################
#
# DEPLOYMENT SPECIFICATIONS
#
#################################################################

:DeploymentSpec a impl:DeploymentSpecification ;
  rdfs:label "ByteActor Deployment Configuration" ;
  impl:targetOS "Linux (Ubuntu 22.04+), macOS (12.0+)" ;
  impl:requiredRAM "16GB minimum, 32GB recommended" ;
  impl:requiredCores "4 minimum, 16+ recommended" ;
  impl:dependencies [
    impl:package "libnuma-dev" ;
    impl:package "erlang (>= OTP-26)" ;
    impl:package "cmake (>= 3.20)" ;
    impl:package "gcc (>= 11.0) or clang (>= 13.0)"
  ] ;
  impl:installationSteps """
1. Clone repository: git clone <repo-url>
2. Install dependencies: apt-get install libnuma-dev erlang cmake gcc
3. Create build directory: mkdir build && cd build
4. Configure: cmake .. -DCMAKE_BUILD_TYPE=Release
5. Build: make -j$(nproc)
6. Test: make test
7. Install: make install
8. Configure Erlang path: export ERL_LIBS=<install-path>
9. Start system: erl -pa <install-path> -s bitactor_app start
""" .

