#################################################################
#
# FUNCTION SPECIFICATIONS
#
#################################################################

# Core Functions
:BitActorInit a impl:Function ;
  rdfs:label "bitactor_init" ;
  impl:signature "void bitactor_init(bitactor_t* ba)" ;
  impl:description "Initialize BitActor engine with pre-allocated memory" ;
  impl:sourceLocation "bitactor_core.c:6-19" ;
  impl:maxExecutionTime "100ns" ;
  impl:sideEffects "Initializes memory, sets up dispatch table" ;
  impl:preconditions "ba != NULL" ;
  impl:postconditions "ba fully initialized, ready for operation" ;
  impl:implementation """
void bitactor_init(bitactor_t* ba) {
    // Zero all memory
    memset(ba, 0, sizeof(bitactor_t));
    
    // Initialize dispatch table with default handler
    for (int i = 0; i < BITACTOR_DISPATCH_SIZE; i++) {
        ba->dispatch[i] = NULL;
    }
    
    // Prefetch critical memory regions
    __builtin_prefetch(&ba->signal_ring[0], 0, 3);
    __builtin_prefetch(&ba->dispatch[0], 0, 3);
    __builtin_prefetch(&ba->scratch[0], 1, 3);
}
""" .

:BitActorTick a impl:Function ;
  rdfs:label "bitactor_tick" ;
  impl:signature "void bitactor_tick(bitactor_t* ba)" ;
  impl:description "Core execution loop with ≤8 tick guarantee" ;
  impl:sourceLocation "bitactor_core.c:54-94" ;
  impl:maxExecutionTicks 8 ;
  impl:attributes "__attribute__((hot, always_inline))" ;
  impl:sideEffects "Processes one signal, updates counters" ;
  impl:preconditions "ba initialized, signal available" ;
  impl:postconditions "Signal processed, telemetry updated" ;
  impl:criticalPath true ;
  impl:implementation """
__attribute__((hot, always_inline))
void bitactor_tick(bitactor_t* ba) {
    uint64_t start_cycle = __rdtsc();
    
    if (bitactor_ring_empty(ba)) {
        return;
    }
    
    uint32_t tail = ba->signal_tail;
    signal_t* sig = &ba->signal_ring[tail];
    
    // Perfect hash dispatch (≤1 tick)
    uint32_t dispatch_idx = sig->kind & (BITACTOR_DISPATCH_SIZE - 1);
    handler_fn handler = ba->dispatch[dispatch_idx];
    
    if (handler) {
        // Record telemetry frame
        telemetry_frame_t* frame = &ba->telemetry[ba->telemetry_head];
        frame->timestamp = sig->timestamp;
        frame->signal_id = sig->kind;
        frame->exec_hash = (uint32_t)(uintptr_t)handler;
        
        // Execute handler (≤5 ticks)
        handler(sig, ba->scratch);
        
        // Advance telemetry
        ba->telemetry_head = (ba->telemetry_head + 1) & (BITACTOR_TELEMETRY_SIZE - 1);
    }
    
    // Advance signal ring
    __atomic_store_n(&ba->signal_tail, bitactor_ring_next(tail), __ATOMIC_RELEASE);
    
    ba->tick_count++;
    ba->signal_count++;
    ba->cycle_count += __rdtsc() - start_cycle;
}
""" .

:BitActorEnqueue a impl:Function ;
  rdfs:label "bitactor_enqueue_signal" ;
  impl:signature "bool bitactor_enqueue_signal(bitactor_t* ba, const signal_t* sig)" ;
  impl:description "Lock-free signal enqueuing with SPSC ring buffer" ;
  impl:sourceLocation "bitactor_core.c:21-37" ;
  impl:lockFree true ;
  impl:atomicOperations "ATOMIC_RELEASE" ;
  impl:maxExecutionTime "20ns" ;
  impl:implementation """
bool bitactor_enqueue_signal(bitactor_t* ba, const signal_t* sig) {
    uint32_t next_head = bitactor_ring_next(ba->signal_head);
    
    // Check if ring is full
    if (next_head == ba->signal_tail) {
        return false;
    }
    
    // Copy signal to ring
    ba->signal_ring[ba->signal_head] = *sig;
    
    // Memory fence to ensure write completes
    __atomic_store_n(&ba->signal_head, next_head, __ATOMIC_RELEASE);
    
    return true;
}
""" .

#################################################################
#
# DATA STRUCTURE SPECIFICATIONS
#
#################################################################

:BitActorStruct a impl:DataStructure ;
  rdfs:label "bitactor_t" ;
  impl:description "Main BitActor engine state structure" ;
  impl:size 8192 ;
  impl:alignment 64 ;
  impl:cacheOptimized true ;
  impl:definition """
typedef struct __attribute__((cache_aligned)) {
    // Hot path data (first cache line)
    signal_t signal_ring[BITACTOR_RING_SIZE];          // Signal ring buffer
    volatile uint32_t signal_head;                     // Ring head pointer
    volatile uint32_t signal_tail;                     // Ring tail pointer
    
    // Dispatch table (second cache line)
    handler_fn dispatch[BITACTOR_DISPATCH_SIZE];       // Function pointer table
    
    // Scratch memory for handlers
    uint8_t scratch[BITACTOR_SCRATCH_SIZE];            // Handler scratch space
    
    // Telemetry data
    telemetry_frame_t telemetry[BITACTOR_TELEMETRY_SIZE];
    uint32_t telemetry_head;
    
    // Statistics (cold data)
    uint64_t tick_count;
    uint64_t cycle_count;
    uint64_t signal_count;
} bitactor_t;

// Compile-time size validation
_Static_assert(sizeof(bitactor_t) <= 8192, "BitActor struct too large");
_Static_assert(sizeof(bitactor_t) % 64 == 0, "BitActor struct not cache aligned");
""" .

:SignalStruct a impl:DataStructure ;
  rdfs:label "signal_t" ;
  impl:description "Signal message structure" ;
  impl:size 64 ;
  impl:alignment 64 ;
  impl:definition """
typedef struct __attribute__((packed, aligned(64))) {
    uint32_t kind;                    // Signal type identifier
    uint32_t flags;                   // Processing flags
    uint64_t timestamp;               // Creation timestamp
    uint64_t payload[6];              // 48 bytes payload
} signal_t;

_Static_assert(sizeof(signal_t) == 64, "Signal struct must be exactly 64 bytes");
""" .

:ResultCrystalStruct a impl:DataStructure ;
  rdfs:label "result_crystal_t" ;
  impl:description "64-byte Result Crystal with BLAKE3 seal" ;
  impl:size 64 ;
  impl:alignment 64 ;
  impl:cryptographic true ;
  impl:definition """
typedef struct __attribute__((packed, aligned(64))) {
    uint64_t result_ptr;              // Result data pointer
    uint64_t timestamp;               // Execution timestamp  
    uint32_t signal_id;               // Original signal ID
    uint32_t exec_ticks;              // Actual execution ticks
    uint8_t  blake3_hash[32];         // BLAKE3 proof hash
    uint64_t telemetry;               // Compressed metrics
} result_crystal_t;

_Static_assert(sizeof(result_crystal_t) == 64, "Result crystal must be exactly 64 bytes");
""" .

