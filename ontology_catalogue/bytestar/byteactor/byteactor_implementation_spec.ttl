#################################################################

:TestFiles a impl:FileSet ;
  impl:file [
    impl:filename "test_bitactor_core.c" ;
    impl:description "Core functionality unit tests" ;
    impl:framework "Unity" ;
    impl:tests [
      test:name "test_bitactor_init" ;
      test:description "Verify proper initialization" ;
      test:preconditions "Fresh bitactor_t structure" ;
      test:steps "Call bitactor_init(), verify all fields zeroed, dispatch table initialized" ;
      test:expectedResult "All fields properly initialized"
    ], [
      test:name "test_signal_enqueue_dequeue" ;
      test:description "Lock-free ring buffer operations" ;
      test:preconditions "Initialized BitActor" ;
      test:steps "Enqueue signals, verify head/tail pointers, dequeue and verify content" ;
      test:expectedResult "FIFO order preserved, no corruption"
    ], [
      test:name "test_8_tick_guarantee" ;
      test:description "Execution time guarantee validation" ;
      test:preconditions "Loaded dispatch table, queued signals" ;
      test:steps "Execute bitactor_tick() 1000 times, measure RDTSC cycles" ;
      test:expectedResult "P99.9 ≤ 8 ticks, no outliers > 12 ticks"
    ]
  ] ;
  impl:file [
    impl:filename "test_dispatch.c" ;
    impl:description "Dispatch table validation tests" ;
    impl:tests [
      test:name "test_perfect_hash_collision" ;
      test:description "Verify zero hash collisions" ;
      test:steps "Generate hash for all signal types, verify uniqueness" ;
      test:expectedResult "Zero collisions for all valid signal types"
    ]
  ] ;
  impl:file [
    impl:filename "test_memory_crystallization.c" ;
    impl:description "Memory allocation performance tests" ;
    impl:tests [
      test:name "test_allocation_speed" ;
      test:description "Memory allocation within tick budget" ;
      test:steps "Allocate 1000 crystals, measure time per allocation" ;
      test:expectedResult "All allocations ≤ 2 ticks"
    ]
  ] .

:BenchmarkFiles a impl:FileSet ;
  impl:file [
    impl:filename "benchmark_throughput.c" ;
    impl:description "End-to-end throughput benchmark" ;
    impl:targetMetric "10M signals/sec sustained throughput" ;
    impl:duration "60 seconds" ;
    impl:cores "1,2,4,8,16" ;
    impl:reportFormat "CSV with timestamps, throughput, latency percentiles"
  ] ;
  impl:file [
    impl:filename "benchmark_latency.c" ;
    impl:description "Single-signal latency measurement" ;
    impl:targetMetric "P99.9 ≤ 10ns end-to-end latency" ;
    impl:samples 1000000 ;
    impl:reportFormat "Latency histogram with percentiles"
  ] .

