@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix canon: <http://bytestar.ai/canonical/> .
@prefix fuller: <http://bytestar.ai/fuller-canon/> .
@prefix sap: <http://bytestar.ai/sovereign-access-plane/> .
@prefix esc: <http://bytestar.ai/external-system-canon/> .
@prefix : <http://bytestar.ai/external-system-canon/shapes/> .

# ==============================================================================
# SHACL Validation Shapes for External System Canonical Ontologies
# Phase 1: Sovereign Access Plane
#
# These shapes validate canonical ontologies generated by the introspection
# and canonicalization agents against Fuller Canon principles and ByteGen
# fabrication requirements.
# ==============================================================================

<http://bytestar.ai/external-system-canon/shapes/> a owl:Ontology ;
    rdfs:label "External System Canon Validation Shapes"@en ;
    rdfs:comment """
    SHACL shapes for validating canonical ontologies produced by the 
    Sovereign Access Plane against Fuller Canon principles and 
    ByteGen fabrication requirements.
    """@en ;
    sh:declare [
        sh:prefix "esc" ;
        sh:namespace "http://bytestar.ai/external-system-canon/"^^xsd:anyURI ;
    ] ;
    sh:declare [
        sh:prefix "fuller" ;
        sh:namespace "http://bytestar.ai/fuller-canon/"^^xsd:anyURI ;
    ] .

# ==============================================================================
# CORE SYSTEM VALIDATION SHAPES
# ==============================================================================

:ExternalSystemShape a sh:NodeShape ;
    sh:targetClass esc:ExternalSystem ;
    rdfs:label "External System Shape" ;
    rdfs:comment "Validates external system canonical representation" ;
    sh:severity sh:Violation ;
    
    # System must have metadata
    sh:property [
        sh:path esc:hasSystemMetadata ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "External system must have exactly one system metadata record" ;
    ] ;
    
    # System must have canonical form
    sh:property [
        sh:path esc:hasCanonicalForm ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class esc:FullerCanonForm ;
        sh:message "External system must have exactly one Fuller Canon form" ;
    ] ;
    
    # System must have unique canonical identifier
    sh:property [
        sh:path esc:hasCanonicalIdentifier ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:pattern "^http://bytestar\\.ai/canonical/[a-zA-Z0-9_-]+$" ;
        sh:message "System must have unique canonical identifier with proper namespace" ;
    ] .

:DatabaseSystemShape a sh:NodeShape ;
    sh:targetClass esc:DatabaseSystem ;
    rdfs:label "Database System Shape" ;
    rdfs:comment "Validates database system canonical representation" ;
    sh:severity sh:Violation ;
    
    # Database must have schema
    sh:property [
        sh:path esc:hasSchema ;
        sh:minCount 1 ;
        sh:class esc:DatabaseSchema ;
        sh:message "Database system must have at least one schema" ;
    ] ;
    
    # Performance requirement validation
    sh:property [
        sh:path esc:hasPerformanceProfile ;
        sh:minCount 1 ;
        sh:class esc:PerformanceProfile ;
        sh:message "Database system must have performance profile" ;
    ] .

:APISystemShape a sh:NodeShape ;
    sh:targetClass esc:APISystem ;
    rdfs:label "API System Shape" ;
    rdfs:comment "Validates API system canonical representation" ;
    sh:severity sh:Violation ;
    
    # API must have specification
    sh:property [
        sh:path esc:hasAPISpec ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class esc:APISpecification ;
        sh:message "API system must have exactly one API specification" ;
    ] .

# ==============================================================================
# CANONICAL ENTITY VALIDATION SHAPES
# ==============================================================================

:CanonicalEntityShape a sh:NodeShape ;
    sh:targetClass esc:CanonicalEntity ;
    rdfs:label "Canonical Entity Shape" ;
    rdfs:comment "Validates canonical entity representation following Fuller Canon principles" ;
    sh:severity sh:Violation ;
    
    # Must have canonical identifier
    sh:property [
        sh:path esc:hasCanonicalIdentifier ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:nodeKind sh:IRI ;
        sh:message "Canonical entity must have unique IRI identifier" ;
    ] ;
    
    # Must have canonical properties
    sh:property [
        sh:path esc:hasCanonicalProperties ;
        sh:minCount 1 ;
        sh:class esc:CanonicalProperty ;
        sh:message "Canonical entity must have at least one canonical property" ;
    ] ;
    
    # Must have Fuller Canon form
    sh:property [
        sh:path esc:hasCanonicalForm ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class esc:FullerCanonForm ;
        sh:message "Canonical entity must have Fuller Canon form" ;
    ] ;
    
    # Label validation
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 3 ;
        sh:maxLength 100 ;
        sh:message "Entity must have descriptive label (3-100 characters)" ;
    ] ;
    
    # Description validation  
    sh:property [
        sh:path rdfs:comment ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 10 ;
        sh:maxLength 500 ;
        sh:message "Entity must have meaningful description (10-500 characters)" ;
    ] .

:CanonicalPropertyShape a sh:NodeShape ;
    sh:targetClass esc:CanonicalProperty ;
    rdfs:label "Canonical Property Shape" ;
    rdfs:comment "Validates canonical property with semantic precision" ;
    sh:severity sh:Violation ;
    
    # Must have semantic type
    sh:property [
        sh:path esc:hasSemanticType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:message "Canonical property must have semantic type annotation" ;
    ] ;
    
    # Must have Fuller Canon form
    sh:property [
        sh:path fuller:canonicalForm ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^[A-Za-z]+\\([^)]+\\)\\s*→.*$" ;
        sh:message "Property must have valid Fuller Canon form representation" ;
    ] ;
    
    # Domain and range validation
    sh:property [
        sh:path rdfs:domain ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Property must specify at least one domain class" ;
    ] ;
    
    sh:property [
        sh:path rdfs:range ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Property must specify at least one range" ;
    ] .

:CanonicalRelationshipShape a sh:NodeShape ;
    sh:targetClass esc:CanonicalRelationship ;
    rdfs:label "Canonical Relationship Shape" ;
    rdfs:comment "Validates canonical relationships with clear semantics" ;
    sh:severity sh:Violation ;
    
    # Must have source
    sh:property [
        sh:path esc:hasSource ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Relationship must have exactly one source" ;
    ] ;
    
    # Must have target
    sh:property [
        sh:path esc:hasTarget ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Relationship must have exactly one target" ;
    ] ;
    
    # Cardinality validation
    sh:property [
        sh:path esc:hasCardinality ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "1:1" "1:N" "N:1" "N:M" ) ;
        sh:message "Relationship must specify valid cardinality" ;
    ] .

# ==============================================================================
# SCHEMA VALIDATION SHAPES
# ==============================================================================

:DatabaseSchemaShape a sh:NodeShape ;
    sh:targetClass esc:DatabaseSchema ;
    rdfs:label "Database Schema Shape" ;
    rdfs:comment "Validates database schema structure" ;
    sh:severity sh:Violation ;
    
    # Must have tables
    sh:property [
        sh:path esc:hasTable ;
        sh:minCount 1 ;
        sh:class esc:CanonicalTable ;
        sh:message "Database schema must contain at least one table" ;
    ] ;
    
    # Schema name validation
    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^[a-zA-Z][a-zA-Z0-9_]*$" ;
        sh:message "Schema name must be valid identifier" ;
    ] .

:CanonicalTableShape a sh:NodeShape ;
    sh:targetClass esc:CanonicalTable ;
    rdfs:label "Canonical Table Shape" ;
    rdfs:comment "Validates table structure in canonical form" ;
    sh:severity sh:Violation ;
    
    # Must have columns
    sh:property [
        sh:path esc:hasColumn ;
        sh:minCount 1 ;
        sh:class esc:CanonicalColumn ;
        sh:message "Table must have at least one column" ;
    ] ;
    
    # Must have primary key
    sh:property [
        sh:path esc:hasPrimaryKey ;
        sh:minCount 1 ;
        sh:message "Table must have primary key defined" ;
    ] ;
    
    # Table name validation
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:pattern "^[a-zA-Z][a-zA-Z0-9_]*$" ;
        sh:message "Table name must be valid identifier" ;
    ] .

:CanonicalColumnShape a sh:NodeShape ;
    sh:targetClass esc:CanonicalColumn ;
    rdfs:label "Canonical Column Shape" ;
    rdfs:comment "Validates column definition in canonical form" ;
    sh:severity sh:Violation ;
    
    # Must have data type
    sh:property [
        sh:path esc:hasDataType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:message "Column must specify exactly one data type" ;
    ] ;
    
    # Nullable specification
    sh:property [
        sh:path esc:isNullable ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "Column must specify nullable constraint" ;
    ] ;
    
    # Column name validation
    sh:property [
        sh:path rdfs:label ;
        sh:datatype xsd:string ;
        sh:pattern "^[a-zA-Z][a-zA-Z0-9_]*$" ;
        sh:message "Column name must be valid identifier" ;
    ] .

:APISpecificationShape a sh:NodeShape ;
    sh:targetClass esc:APISpecification ;
    rdfs:label "API Specification Shape" ;
    rdfs:comment "Validates API specification completeness" ;
    sh:severity sh:Violation ;
    
    # Must have endpoints
    sh:property [
        sh:path esc:hasEndpoint ;
        sh:minCount 1 ;
        sh:class esc:CanonicalEndpoint ;
        sh:message "API specification must define at least one endpoint" ;
    ] ;
    
    # OpenAPI version
    sh:property [
        sh:path esc:hasOpenAPIVersion ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^3\\.[0-9]+\\.[0-9]+$" ;
        sh:message "Must specify valid OpenAPI 3.x version" ;
    ] .

:CanonicalEndpointShape a sh:NodeShape ;
    sh:targetClass esc:CanonicalEndpoint ;
    rdfs:label "Canonical Endpoint Shape" ;
    rdfs:comment "Validates API endpoint canonical representation" ;
    sh:severity sh:Violation ;
    
    # Must have path
    sh:property [
        sh:path esc:hasPath ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^/[a-zA-Z0-9/_-]*$" ;
        sh:message "Endpoint must have valid URL path starting with /" ;
    ] ;
    
    # Must have HTTP method
    sh:property [
        sh:path esc:hasHTTPMethod ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "GET" "POST" "PUT" "DELETE" "PATCH" "HEAD" "OPTIONS" ) ;
        sh:message "Endpoint must specify valid HTTP method" ;
    ] ;
    
    # Must have responses
    sh:property [
        sh:path esc:hasResponse ;
        sh:minCount 1 ;
        sh:message "Endpoint must define at least one response" ;
    ] .

# ==============================================================================
# SECURITY POLICY VALIDATION SHAPES
# ==============================================================================

:SecurityPolicyShape a sh:NodeShape ;
    sh:targetClass esc:SecurityPolicy ;
    rdfs:label "Security Policy Shape" ;
    rdfs:comment "Validates canonical security policy structure" ;
    sh:severity sh:Violation ;
    
    # Must have security rules
    sh:property [
        sh:path esc:hasSecurityRule ;
        sh:minCount 1 ;
        sh:class esc:AccessControlRule ;
        sh:message "Security policy must contain at least one rule" ;
    ] ;
    
    # Must apply to something
    sh:property [
        sh:path esc:appliesTo ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Security policy must apply to at least one resource" ;
    ] ;
    
    # Policy type validation
    sh:property [
        sh:path esc:hasPolicyType ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "access_control" "encryption" "audit" "compliance" ) ;
        sh:message "Policy must specify valid policy type" ;
    ] .

:RLSPolicyShape a sh:NodeShape ;
    sh:targetClass esc:RLSPolicy ;
    rdfs:label "RLS Policy Shape" ;
    rdfs:comment "Validates Row Level Security policy" ;
    sh:severity sh:Violation ;
    
    # Must specify target class
    sh:property [
        sh:path esc:hasTargetClass ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "RLS policy must specify exactly one target class" ;
    ] ;
    
    # Must specify operations
    sh:property [
        sh:path esc:hasOperation ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "select" "insert" "update" "delete" "all" ) ;
        sh:message "RLS policy must specify valid database operations" ;
    ] ;
    
    # Must specify roles
    sh:property [
        sh:path esc:hasRole ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "RLS policy must specify at least one role" ;
    ] .

:AccessControlRuleShape a sh:NodeShape ;
    sh:targetClass esc:AccessControlRule ;
    rdfs:label "Access Control Rule Shape" ;
    rdfs:comment "Validates access control rule structure" ;
    sh:severity sh:Violation ;
    
    # Must have subject
    sh:property [
        sh:path esc:hasSubject ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Access control rule must have exactly one subject" ;
    ] ;
    
    # Must have object
    sh:property [
        sh:path esc:hasObject ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "Access control rule must have exactly one object" ;
    ] ;
    
    # Must have action
    sh:property [
        sh:path esc:hasAction ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Access control rule must specify exactly one action" ;
    ] ;
    
    # Effect validation
    sh:property [
        sh:path esc:hasEffect ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "allow" "deny" ) ;
        sh:message "Access control rule must specify allow or deny effect" ;
    ] .

# ==============================================================================
# PERFORMANCE VALIDATION SHAPES
# ==============================================================================

:PerformanceProfileShape a sh:NodeShape ;
    sh:targetClass esc:PerformanceProfile ;
    rdfs:label "Performance Profile Shape" ;
    rdfs:comment "Validates performance profile meets ByteGen requirements" ;
    sh:severity sh:Violation ;
    
    # Must have latency metrics
    sh:property [
        sh:path esc:hasLatencyMetrics ;
        sh:minCount 1 ;
        sh:class esc:CanonicalMetric ;
        sh:message "Performance profile must include latency metrics" ;
    ] ;
    
    # Must have throughput metrics
    sh:property [
        sh:path esc:hasThroughputMetrics ;
        sh:minCount 1 ;
        sh:class esc:CanonicalMetric ;
        sh:message "Performance profile must include throughput metrics" ;
    ] ;
    
    # Sub-microsecond latency requirement
    sh:sparql [
        sh:message "System must meet sub-microsecond latency requirement" ;
        sh:prefixes [
            sh:declare [ sh:prefix "esc" ; sh:namespace "http://bytestar.ai/external-system-canon/" ] ;
        ] ;
        sh:select """
            SELECT $this WHERE {
                $this esc:hasLatencyMetrics ?metric .
                ?metric esc:hasValue ?value .
                ?metric esc:hasUnit "microseconds" .
                FILTER (?value >= 1.0)
            }
        """ ;
    ] .

:CanonicalMetricShape a sh:NodeShape ;
    sh:targetClass esc:CanonicalMetric ;
    rdfs:label "Canonical Metric Shape" ;
    rdfs:comment "Validates performance metric structure" ;
    sh:severity sh:Violation ;
    
    # Must have value
    sh:property [
        sh:path esc:hasValue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:message "Metric must have non-negative numeric value" ;
    ] ;
    
    # Must have unit
    sh:property [
        sh:path esc:hasUnit ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Metric must specify measurement unit" ;
    ] ;
    
    # Must have context
    sh:property [
        sh:path esc:hasContext ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Metric must specify measurement context" ;
    ] ;
    
    # Must have timestamp
    sh:property [
        sh:path esc:hasTimestamp ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "Metric must have measurement timestamp" ;
    ] .

# ==============================================================================
# FULLER CANON VALIDATION SHAPES
# ==============================================================================

:FullerCanonFormShape a sh:NodeShape ;
    sh:targetClass esc:FullerCanonForm ;
    rdfs:label "Fuller Canon Form Shape" ;
    rdfs:comment "Validates Fuller Canon form adherence and entropy reduction" ;
    sh:severity sh:Violation ;
    
    # Must have original entropy
    sh:property [
        sh:path esc:hasOriginalEntropy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:message "Fuller Canon form must specify original entropy" ;
    ] ;
    
    # Must have canonical entropy
    sh:property [
        sh:path esc:hasCanonicalEntropy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:message "Fuller Canon form must specify canonical entropy" ;
    ] ;
    
    # Must have entropy reduction
    sh:property [
        sh:path esc:hasEntropyReduction ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "Entropy reduction must be ratio between 0.0 and 1.0" ;
    ] ;
    
    # Minimum entropy reduction requirement (30%)
    sh:property [
        sh:path esc:hasEntropyReduction ;
        sh:minInclusive 0.3 ;
        sh:message "Fuller Canon form must achieve at least 30% entropy reduction" ;
    ] ;
    
    # Must have canonicality score
    sh:property [
        sh:path esc:hasCanonicality ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:minInclusive 0.7 ;
        sh:message "Canonicality score must be at least 0.7" ;
    ] ;
    
    # Entropy reduction validation via SPARQL
    sh:sparql [
        sh:message "Canonical entropy must be less than original entropy" ;
        sh:prefixes [
            sh:declare [ sh:prefix "esc" ; sh:namespace "http://bytestar.ai/external-system-canon/" ] ;
        ] ;
        sh:select """
            SELECT $this WHERE {
                $this esc:hasOriginalEntropy ?original .
                $this esc:hasCanonicalEntropy ?canonical .
                FILTER (?canonical >= ?original)
            }
        """ ;
    ] .

:ProvenanceRecordShape a sh:NodeShape ;
    sh:targetClass esc:ProvenanceRecord ;
    rdfs:label "Provenance Record Shape" ;
    rdfs:comment "Validates provenance information completeness" ;
    sh:severity sh:Violation ;
    
    # Must have source
    sh:property [
        sh:path esc:hasSource ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:anyURI ;
        sh:message "Provenance record must specify source system" ;
    ] ;
    
    # Must have transformation timestamp
    sh:property [
        sh:path esc:hasTransformationTimestamp ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "Provenance record must have transformation timestamp" ;
    ] ;
    
    # Must have confidence score
    sh:property [
        sh:path esc:hasConfidence ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "Confidence score must be between 0.0 and 1.0" ;
    ] ;
    
    # Must have evidence
    sh:property [
        sh:path esc:hasEvidence ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Provenance record must include supporting evidence" ;
    ] .

# ==============================================================================
# QUALITY VALIDATION SHAPES
# ==============================================================================

:QualityAssuranceShape a sh:NodeShape ;
    sh:targetClass esc:CanonicalOntology ;
    rdfs:label "Quality Assurance Shape" ;
    rdfs:comment "Comprehensive quality validation for canonical ontologies" ;
    sh:severity sh:Warning ;
    
    # Minimum class count
    sh:sparql [
        sh:message "Ontology should define at least 3 classes for meaningful canonicalization" ;
        sh:select """
            SELECT $this WHERE {
                {
                    SELECT $this (COUNT(?class) as ?classCount) WHERE {
                        $this a esc:CanonicalOntology .
                        ?class a owl:Class .
                        ?class rdfs:isDefinedBy $this .
                    }
                    GROUP BY $this
                }
                FILTER (?classCount < 3)
            }
        """ ;
    ] ;
    
    # Property-to-class ratio
    sh:sparql [
        sh:message "Ontology should have reasonable property-to-class ratio (2-10 properties per class)" ;
        sh:select """
            SELECT $this WHERE {
                {
                    SELECT $this (COUNT(?class) as ?classCount) (COUNT(?prop) as ?propCount) WHERE {
                        $this a esc:CanonicalOntology .
                        ?class a owl:Class .
                        ?class rdfs:isDefinedBy $this .
                        ?prop a owl:ObjectProperty, owl:DatatypeProperty .
                        ?prop rdfs:isDefinedBy $this .
                    }
                    GROUP BY $this
                }
                BIND(?propCount / ?classCount as ?ratio)
                FILTER (?ratio < 2 || ?ratio > 10)
            }
        """ ;
    ] .

# ==============================================================================
# CUSTOM VALIDATION FUNCTIONS
# ==============================================================================

:validateFullerCanonAdherence a sh:SPARQLFunction ;
    rdfs:label "Validate Fuller Canon Adherence" ;
    rdfs:comment "Custom validation function for Fuller Canon principles" ;
    sh:parameter [
        sh:path :ontology ;
        sh:datatype xsd:anyURI ;
    ] ;
    sh:returnType xsd:boolean ;
    sh:select """
        PREFIX esc: <http://bytestar.ai/external-system-canon/>
        PREFIX fuller: <http://bytestar.ai/fuller-canon/>
        
        SELECT ?result WHERE {
            ?form esc:belongsTo $ontology .
            ?form esc:hasEntropyReduction ?reduction .
            ?form esc:hasCanonicality ?canonicality .
            ?form esc:hasSemanticCoherence ?coherence .
            
            BIND((?reduction >= 0.3 && ?canonicality >= 0.7 && ?coherence >= 0.8) as ?result)
        }
    """ .

:validatePerformanceCompliance a sh:SPARQLFunction ;
    rdfs:label "Validate Performance Compliance" ;
    rdfs:comment "Custom validation for sub-microsecond performance requirements" ;
    sh:parameter [
        sh:path :system ;
        sh:datatype xsd:anyURI ;
    ] ;
    sh:returnType xsd:boolean ;
    sh:select """
        PREFIX esc: <http://bytestar.ai/external-system-canon/>
        
        SELECT ?result WHERE {
            $system esc:hasPerformanceProfile ?profile .
            ?profile esc:hasLatencyMetrics ?latency .
            ?latency esc:hasValue ?value .
            ?latency esc:hasUnit "microseconds" .
            
            BIND(?value < 1.0 as ?result)
        }
    """ .

# ==============================================================================
# SEVERITY AND MESSAGE CUSTOMIZATION
# ==============================================================================

# Custom severity for Fuller Canon violations
:FullerCanonViolation a sh:Severity ;
    rdfs:label "Fuller Canon Violation" ;
    rdfs:comment "Critical violation of Fuller Canon principles" ;
    sh:order 0 .  # Highest priority

# Custom message templates
:entropyReductionMessage sh:message "Entropy reduction of {?reduction} does not meet minimum requirement of 0.3" .
:canonicalityScoreMessage sh:message "Canonicality score of {?score} does not meet minimum requirement of 0.7" .
:performanceMessage sh:message "Latency of {?latency} {?unit} exceeds sub-microsecond requirement" .