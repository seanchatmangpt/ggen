@prefix : <https://bytestar.org/ontology/byteflow/production-readiness#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bcore: <https://bytestar.org/ontology/bytestar-core#> .

<https://bytestar.org/ontology/byteflow/production-readiness>
  a owl:Ontology ;
  rdfs:label "ByteFlow Production Readiness Specification" ;
  rdfs:comment "Defines the formal requirements and metrics for ByteFlow to achieve Fortune 5 production readiness, focusing on orchestration, AOT fabrication, and admission gates." ;
  owl:versionInfo "1.0.0" ;
  owl:imports bcore: .

#################################################################
# Production Readiness Classes
#################################################################

:ProductionReadinessStatus a owl:Class ;
  rdfs:label "Production Readiness Status" ;
  rdfs:comment "Represents the overall readiness status of a ByteFlow deployment." .

:Ready a :ProductionReadinessStatus ; rdfs:label "Ready for Production" .
:NotReady a :ProductionReadinessStatus ; rdfs:label "Not Ready for Production" .
:Degraded a :ProductionReadinessStatus ; rdfs:label "Degraded Production" .

:ProductionReadinessMetric a owl:Class ;
  rdfs:label "Production Readiness Metric" ;
  rdfs:comment "A quantifiable measure used to assess ByteFlow's production readiness." .

:PerformanceRequirement a owl:Class ;
  rdfs:label "Performance Requirement" ;
  rdfs:comment "A requirement related to ByteFlow's admission latency, fabrication throughput, or orchestration latency." .

:ReliabilityRequirement a owl:Class ;
  rdfs:label "Reliability Requirement" ;
  rdfs:comment "A requirement related to ByteFlow's admission gate uptime, fabrication success rate, or workflow instance stability." .

:SecurityRequirement a owl:Class ;
  rdfs:label "Security Requirement" ;
  rdfs:comment "A requirement related to ByteFlow's admission gate robustness or manifest signing integrity." .

:OperationalRequirement a owl:Class ;
  rdfs:label "Operational Requirement" ;
  rdfs:comment "A requirement related to ByteFlow's workflow deployment success rate or planner efficiency." .

#################################################################
# Production Readiness Properties
#################################################################

:hasStatus a owl:ObjectProperty ;
  rdfs:label "has status" ;
  rdfs:domain bcore:ByteFlow ;
  rdfs:range :ProductionReadinessStatus ;
  rdfs:comment "Links a ByteFlow instance to its overall production readiness status." .

:hasMetric a owl:ObjectProperty ;
  rdfs:label "has metric" ;
  rdfs:domain bcore:ByteFlow ;
  rdfs:range :ProductionReadinessMetric ;
  rdfs:comment "Links a ByteFlow instance to a specific production readiness metric." .

:meetsPerformanceRequirement a owl:ObjectProperty ;
  rdfs:label "meets performance requirement" ;
  rdfs:domain bcore:ByteFlow ;
  rdfs:range :PerformanceRequirement ;
  rdfs:comment "Indicates that a ByteFlow instance meets a specific performance requirement." .

:meetsReliabilityRequirement a owl:ObjectProperty ;
  rdfs:label "meets reliability requirement" ;
  rdfs:domain bcore:ByteFlow ;
  rdfs:range :ReliabilityRequirement ;
  rdfs:comment "Indicates that a ByteFlow instance meets a specific reliability requirement." .

:meetsSecurityRequirement a owl:ObjectProperty ;
  rdfs:label "meets security requirement" ;
  rdfs:domain bcore:ByteFlow ;
  rdfs:range :SecurityRequirement ;
  rdfs:comment "Indicates that a ByteFlow instance meets a specific security requirement." .

:meetsOperationalRequirement a owl:ObjectProperty ;
  rdfs:label "meets operational requirement" ;
  rdfs:domain bcore:ByteFlow ;
  rdfs:range :OperationalRequirement ;
  rdfs:comment "Indicates that a ByteFlow instance meets a specific operational requirement." .

# Metric-specific properties
:metricName a owl:DatatypeProperty ;
  rdfs:label "metric name" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:string .

:metricValue a owl:DatatypeProperty ;
  rdfs:label "metric value" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:decimal .

:targetValue a owl:DatatypeProperty ;
  rdfs:label "target value" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:decimal .

:thresholdValue a owl:DatatypeProperty ;
  rdfs:label "threshold value" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:decimal .

:unit a owl:DatatypeProperty ;
  rdfs:label "unit" ;
  rdfs:domain :ProductionReadinessMetric ;
  rdfs:range xsd:string .

# Requirement-specific properties
:requirementName a owl:DatatypeProperty ;
  rdfs:label "requirement name" ;
  rdfs:domain owl:Thing ;
  rdfs:range xsd:string .
