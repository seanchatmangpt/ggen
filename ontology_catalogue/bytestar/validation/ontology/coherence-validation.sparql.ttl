# ByteStar Ontological Coherence Validation Suite
# HIVE MIND TAU-27 Analysis Report
# Validates consistency, identifies redundancies, and proves 80/20 semantic distribution

@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

# ================================================================
# QUERY SET 1: CORE CONCEPT DISTRIBUTION ANALYSIS
# ================================================================

# Q1.1: Identify all Crystal concept definitions across ontologies
SELECT ?ontology ?crystal_class ?definition WHERE {
  ?ontology a owl:Ontology .
  ?crystal_class a owl:Class .
  ?crystal_class rdfs:label ?label .
  ?crystal_class rdfs:comment ?definition .
  FILTER(regex(?label, "Crystal", "i"))
}

# Q1.2: Count kernel definitions by ontology module
SELECT ?ontology (COUNT(?kernel) AS ?kernel_count) WHERE {
  ?ontology a owl:Ontology .
  ?kernel a owl:Class .
  ?kernel rdfs:label ?label .
  FILTER(regex(?label, "Kernel", "i"))
} GROUP BY ?ontology ORDER BY DESC(?kernel_count)

# Q1.3: Analyze Pulse concept distribution and redundancy
SELECT ?ontology ?pulse_concept ?semantic_weight WHERE {
  ?ontology a owl:Ontology .
  ?pulse_concept a owl:Class .
  ?pulse_concept rdfs:label ?label .
  ?pulse_concept rdfs:comment ?comment .
  FILTER(regex(?label, "Pulse", "i"))
  BIND(strlen(?comment) AS ?semantic_weight)
} ORDER BY DESC(?semantic_weight)

# ================================================================
# QUERY SET 2: REDUNDANCY DETECTION ANALYSIS  
# ================================================================

# Q2.1: Find duplicate class definitions across ontologies
SELECT ?class_name (COUNT(?class) AS ?occurrences) (GROUP_CONCAT(?ontology; separator="|") AS ?defined_in) WHERE {
  ?class a owl:Class .
  ?class rdfs:label ?class_name .
  ?class ?property ?ontology .
  ?ontology a owl:Ontology .
} GROUP BY ?class_name HAVING(?occurrences > 1) ORDER BY DESC(?occurrences)

# Q2.2: Identify semantically similar properties across modules
SELECT ?prop1 ?prop2 ?similarity_score WHERE {
  ?prop1 a owl:ObjectProperty .
  ?prop2 a owl:ObjectProperty .
  ?prop1 rdfs:label ?label1 .
  ?prop2 rdfs:label ?label2 .
  ?prop1 rdfs:comment ?comment1 .
  ?prop2 rdfs:comment ?comment2 .
  FILTER(?prop1 != ?prop2)
  BIND(
    IF(
      (contains(?comment1, ?comment2) || contains(?comment2, ?comment1)),
      0.8,
      IF(
        (contains(?label1, ?label2) || contains(?label2, ?label1)),
        0.6,
        0.0
      )
    ) AS ?similarity_score
  )
  FILTER(?similarity_score > 0.5)
} ORDER BY DESC(?similarity_score)

# Q2.3: Detect unused or orphaned ontological constructs
SELECT ?construct ?type ?ontology WHERE {
  ?construct a ?type .
  ?ontology a owl:Ontology .
  FILTER(?type IN (owl:Class, owl:ObjectProperty, owl:DatatypeProperty))
  FILTER NOT EXISTS {
    ?subject ?construct ?object
  }
  FILTER NOT EXISTS {
    ?construct rdfs:subClassOf ?parent
  }
  FILTER NOT EXISTS {
    ?child rdfs:subClassOf ?construct
  }
}

# ================================================================
# QUERY SET 3: CONSISTENCY VALIDATION
# ================================================================

# Q3.1: Validate ontological imports consistency
SELECT ?importing_ontology ?imported_ontology ?consistency_status WHERE {
  ?importing_ontology a owl:Ontology .
  ?importing_ontology owl:imports ?imported_ontology .
  BIND(
    IF(EXISTS { ?imported_ontology a owl:Ontology },
       "CONSISTENT",
       "MISSING_IMPORT"
    ) AS ?consistency_status
  )
}

# Q3.2: Check for circular import dependencies
SELECT ?ontology1 ?ontology2 WHERE {
  ?ontology1 owl:imports+ ?ontology2 .
  ?ontology2 owl:imports+ ?ontology1 .
  FILTER(?ontology1 != ?ontology2)
}

# Q3.3: Validate class hierarchy consistency
SELECT ?class ?inconsistency_type WHERE {
  ?class a owl:Class .
  {
    # Multiple inheritance conflicts
    ?class rdfs:subClassOf ?parent1, ?parent2 .
    ?parent1 owl:disjointWith ?parent2 .
    BIND("DISJOINT_PARENTS" AS ?inconsistency_type)
  } UNION {
    # Circular inheritance
    ?class rdfs:subClassOf+ ?class .
    BIND("CIRCULAR_INHERITANCE" AS ?inconsistency_type)
  }
}

# ================================================================
# QUERY SET 4: PARETO (80/20) SEMANTIC ANALYSIS
# ================================================================

# Q4.1: Identify top 20% of ontological constructs by usage frequency
SELECT ?construct ?usage_count ?semantic_impact WHERE {
  {
    SELECT ?construct (COUNT(?usage) AS ?usage_count) WHERE {
      ?subject ?construct ?object .
      ?construct a ?type .
      FILTER(?type IN (owl:Class, owl:ObjectProperty, owl:DatatypeProperty))
    } GROUP BY ?construct
  }
  BIND(?usage_count * 1.0 AS ?semantic_impact)
} ORDER BY DESC(?semantic_impact)

# Q4.2: Calculate semantic concentration by ontology module
SELECT ?ontology ?total_constructs ?high_impact_constructs ?concentration_ratio WHERE {
  {
    SELECT ?ontology (COUNT(?construct) AS ?total_constructs) WHERE {
      ?construct a ?type .
      FILTER(?type IN (owl:Class, owl:ObjectProperty, owl:DatatypeProperty))
      # Determine which ontology defines this construct
      ?construct ?property ?ontology .
      ?ontology a owl:Ontology .
    } GROUP BY ?ontology
  }
  {
    SELECT ?ontology (COUNT(?high_impact) AS ?high_impact_constructs) WHERE {
      ?high_impact a ?type .
      FILTER(?type IN (owl:Class, owl:ObjectProperty, owl:DatatypeProperty))
      ?high_impact ?property ?ontology .
      ?ontology a owl:Ontology .
      # High impact defined as constructs used more than average
      {
        SELECT ?high_impact WHERE {
          ?subject ?high_impact ?object .
        } GROUP BY ?high_impact HAVING(COUNT(?subject) > 5)
      }
    } GROUP BY ?ontology
  }
  BIND(?high_impact_constructs / ?total_constructs AS ?concentration_ratio)
} ORDER BY DESC(?concentration_ratio)

# Q4.3: Identify the "Dark 80/20" - core concepts that drive system behavior
SELECT ?core_concept ?governance_impact ?fabrication_dependency WHERE {
  ?core_concept a owl:Class .
  ?core_concept rdfs:label ?label .
  # High governance impact
  BIND(
    IF(
      regex(?label, "(Doctrine|Canon|Law|Principle)", "i"),
      1.0,
      IF(
        regex(?label, "(Core|Foundation|Base)", "i"),
        0.8,
        0.2
      )
    ) AS ?governance_impact
  )
  # High fabrication dependency  
  BIND(
    IF(
      regex(?label, "(ABI|Interface|Contract|Protocol)", "i"),
      1.0,
      IF(
        regex(?label, "(Registry|Index|Specification)", "i"),
        0.8,
        0.2
      )
    ) AS ?fabrication_dependency
  )
  FILTER(?governance_impact > 0.7 || ?fabrication_dependency > 0.7)
} ORDER BY DESC(?governance_impact + ?fabrication_dependency)

# ================================================================
# QUERY SET 5: OPTIMIZATION RECOMMENDATIONS
# ================================================================

# Q5.1: Identify consolidation opportunities for similar concepts
SELECT ?concept_cluster (COUNT(?similar_concept) AS ?cluster_size) ?consolidation_potential WHERE {
  ?concept a owl:Class .
  ?concept rdfs:label ?label .
  ?similar_concept a owl:Class .
  ?similar_concept rdfs:label ?similar_label .
  FILTER(?concept != ?similar_concept)
  BIND(
    CONCAT(
      substr(?label, 1, 6),
      "_CLUSTER"
    ) AS ?concept_cluster
  )
  FILTER(contains(?label, substr(?similar_label, 1, 6)))
  BIND("HIGH" AS ?consolidation_potential)
} GROUP BY ?concept_cluster ?consolidation_potential HAVING(?cluster_size > 2)

# Q5.2: Find ontologies with excessive complexity (anti-pattern detection)  
SELECT ?ontology ?complexity_score ?optimization_priority WHERE {
  {
    SELECT ?ontology 
           (COUNT(?class) AS ?class_count)
           (COUNT(?property) AS ?property_count)
           (COUNT(?import) AS ?import_count) WHERE {
      ?ontology a owl:Ontology .
      OPTIONAL { ?class a owl:Class }
      OPTIONAL { ?property a ?prop_type . FILTER(?prop_type IN (owl:ObjectProperty, owl:DatatypeProperty)) }
      OPTIONAL { ?ontology owl:imports ?import }
    } GROUP BY ?ontology
  }
  BIND(?class_count + ?property_count + (?import_count * 0.5) AS ?complexity_score)
  BIND(
    IF(?complexity_score > 100, "HIGH",
       IF(?complexity_score > 50, "MEDIUM", "LOW")
    ) AS ?optimization_priority
  )
} ORDER BY DESC(?complexity_score)

# ================================================================
# QUERY SET 6: STRUCTURAL VALIDATION
# ================================================================

# Q6.1: Validate ByteStar architectural layers (Core → Actor → Flow → Ethos)
SELECT ?layer ?depends_on ?architectural_consistency WHERE {
  VALUES (?layer ?expected_deps) {
    ("byteactor" "bytecore")
    ("byteflow" "bytecore byteactor")  
    ("byteethos" "bytecore byteflow")
  }
  ?layer_ontology a owl:Ontology .
  ?layer_ontology owl:imports ?depends_on .
  FILTER(contains(str(?layer_ontology), ?layer))
  BIND(
    IF(contains(?expected_deps, substr(str(?depends_on), 30, 10)),
       "CONSISTENT",
       "VIOLATION"
    ) AS ?architectural_consistency
  )
}

# Q6.2: Ensure production readiness coverage across all modules
SELECT ?module ?has_production_queries ?has_production_shapes ?readiness_score WHERE {
  ?module a owl:Ontology .
  FILTER(regex(str(?module), "(bytecore|byteactor|byteflow|byteethos)-index"))
  BIND(EXISTS { ?module owl:imports ?prod_queries . FILTER(contains(str(?prod_queries), "production-queries")) } AS ?has_production_queries)
  BIND(EXISTS { ?module owl:imports ?prod_shapes . FILTER(contains(str(?prod_shapes), "production-shapes")) } AS ?has_production_shapes)
  BIND(
    (IF(?has_production_queries, 0.5, 0) + IF(?has_production_shapes, 0.5, 0)) AS ?readiness_score
  )
} ORDER BY ?readiness_score

# ================================================================
# SUMMARY METRICS QUERY
# ================================================================

# Q7: Generate comprehensive coherence report
SELECT 
  (COUNT(DISTINCT ?ontology) AS ?total_ontologies)
  (COUNT(DISTINCT ?class) AS ?total_classes)  
  (COUNT(DISTINCT ?property) AS ?total_properties)
  (COUNT(DISTINCT ?import) AS ?total_imports)
  ("COMPLETE" AS ?analysis_status)
WHERE {
  ?ontology a owl:Ontology .
  OPTIONAL { ?class a owl:Class }
  OPTIONAL { ?property a ?prop_type . FILTER(?prop_type IN (owl:ObjectProperty, owl:DatatypeProperty)) }
  OPTIONAL { ?ontology owl:imports ?import }
}