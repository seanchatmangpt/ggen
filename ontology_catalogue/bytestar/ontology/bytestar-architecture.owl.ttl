@prefix : <https://bytestar.org/ontology/architecture#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix spr: <http://bytestar.net/ontology/spr_calculus#> .
@prefix lgc: <https://bytestar.org/ontology/bytestar-lgc#> .
@prefix dc: <https://bytestar.org/ontology/dark-canon#> .

<https://bytestar.org/ontology/architecture>
    rdf:type owl:Ontology ;
    owl:versionIRI <https://bytestar.org/ontology/architecture/v1.0> ;
    rdfs:comment "Ontology describing the core architecture of the ByteStar ecosystem, including its Tri-Realm structure and key components." ;
    owl:imports spr: ,
                lgc: ,
                dc: .

#################################################################
#    Classes
#################################################################

:ByteStarEcosystem rdf:type owl:Class ;
    rdfs:comment "The overarching ByteStar computational ecosystem." .

:Realm rdf:type owl:Class ;
    rdfs:comment "A distinct, physically separated realm within the ByteStar architecture." .

:ByteEthos rdf:type owl:Class ;
    rdfs:subClassOf :Realm ;
    rdfs:comment "The PQC-sealed governance and finality realm (the \"Why\")." .

:ByteFlow rdf:type owl:Class ;
    rdfs:subClassOf :Realm ;
    rdfs:comment "The Erlang/OTP orchestration and AOT fabrication layer (the \"How\")." .

:ByteActor rdf:type owl:Class ;
    rdfs:subClassOf :Realm ;
    rdfs:comment "The C-fast, hot-path execution engine (the \"What\")." .

:ByteGen rdf:type owl:Class ;
    rdfs:comment "The Fabricator; compiles ontologies into artifacts." .

:Component rdf:type owl:Class ;
    rdfs:comment "A generic component within any ByteStar realm." .

:DataFlow rdf:type owl:Class ;
    rdfs:comment "A flow of information or artifacts between components or realms." .

#################################################################
#    Object Properties
#################################################################

:hasRealm rdf:type owl:ObjectProperty ;
    rdfs:domain :ByteStarEcosystem ;
    rdfs:range :Realm ;
    rdfs:comment "Links the ByteStar Ecosystem to its constituent realms." .

:hasRole rdf:type owl:ObjectProperty ;
    rdfs:domain :Realm ;
    rdfs:range rdfs:Literal ;
    rdfs:comment "Describes the primary role or function of a realm." .

:interactsWith rdf:type owl:ObjectProperty ;
    rdfs:domain :Realm ;
    rdfs:range :Realm ;
    rdfs:comment "Indicates interaction between two realms." .

:fabricates rdf:type owl:ObjectProperty ;
    rdfs:domain :ByteGen ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Indicates what ByteGen fabricates (e.g., schemas, policies, clients)." .

:processesDataFlow rdf:type owl:ObjectProperty ;
    rdfs:domain :Component ;
    rdfs:range :DataFlow ;
    rdfs:comment "Indicates that a component processes a specific data flow." .

:originatesFrom rdf:type owl:ObjectProperty ;
    rdfs:domain :DataFlow ;
    rdfs:range :Component ;
    rdfs:comment "Indicates the origin of a data flow." .

:terminatesAt rdf:type owl:ObjectProperty ;
    rdfs:domain :DataFlow ;
    rdfs:range :Component ;
    rdfs:comment "Indicates the termination point of a data flow." .

#################################################################
#    Individuals
#################################################################

:TheByteStarEcosystem rdf:type :ByteStarEcosystem ;
    :hasRealm :ByteEthos ,
              :ByteFlow ,
              :ByteActor ;
    rdfs:comment "The complete ByteStar computational ecosystem." .

:ByteEthos_Instance rdf:type :ByteEthos ;
    :hasRole "PQC-sealed governance and finality" ;
    :interactsWith :ByteFlow_Instance ,
                   :ByteActor_Instance ;
    rdfs:comment "The instance of the ByteEthos realm." .

:ByteFlow_Instance rdf:type :ByteFlow ;
    :hasRole "Erlang/OTP orchestration and AOT fabrication" ;
    :interactsWith :ByteEthos_Instance ,
                   :ByteActor_Instance ,
                   :ByteGen_Instance ;
    rdfs:comment "The instance of the ByteFlow realm." .

:ByteActor_Instance rdf:type :ByteActor ;
    :hasRole "C-fast, hot-path execution" ;
    :interactsWith :ByteEthos_Instance ,
                   :ByteFlow_Instance ;
    rdfs:comment "The instance of the ByteActor realm." .

:ByteGen_Instance rdf:type :ByteGen ;
    :fabricates "Ontologies, SHACL shapes, Supabase SQL, Nuxt Layers, Typed Clients, Receipts" ;
    rdfs:comment "The instance of the ByteGen fabricator." .

### Example Data Flows
:SPR_Flow rdf:type :DataFlow ;
    :originatesFrom :ByteGen_Instance ;
    :terminatesAt :ByteEthos_Instance ;
    rdfs:comment "Flow of SPR messages from ByteGen to ByteEthos for validation." .

:Receipt_Flow rdf:type :DataFlow ;
    :originatesFrom :ByteActor_Instance ;
    :terminatesAt :ByteEthos_Instance ;
    rdfs:comment "Flow of sealed receipts from ByteActor to ByteEthos for finality." .

:Orchestration_Command_Flow rdf:type :DataFlow ;
    :originatesFrom :ByteFlow_Instance ;
    :terminatesAt :ByteActor_Instance ;
    rdfs:comment "Flow of orchestration commands from ByteFlow to ByteActor." .
