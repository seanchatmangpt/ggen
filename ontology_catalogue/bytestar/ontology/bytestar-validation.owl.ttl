@prefix : <https://bytestar.org/ontology/validation#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix arch: <https://bytestar.org/ontology/architecture#> .
@prefix doctrines: <https://bytestar.org/ontology/doctrines#> .
@prefix spr: <http://bytestar.net/ontology/spr_calculus#> .
@prefix metrics: <https://bytestar.org/ontology/metrics#> .

<https://bytestar.org/ontology/validation>
    rdf:type owl:Ontology ;
    owl:versionIRI <https://bytestar.org/ontology/validation/v1.0> ;
    rdfs:comment "Ontology defining mechanisms for formal verification and validation criteria within the ByteStar ecosystem." ;
    owl:imports arch: ,
                doctrines: ,
                spr: ,
                metrics: .

#################################################################
#    Classes
#################################################################

:ValidationMechanism rdf:type owl:Class ;
    rdfs:comment "A mechanism or process for formally validating aspects of the ByteStar system." .

:CorrectnessValidation rdf:type owl:Class ;
    rdfs:subClassOf :ValidationMechanism ;
    rdfs:comment "Validation ensuring the system behaves as specified." .

:SecurityValidation rdf:type owl:Class ;
    rdfs:subClassOf :ValidationMechanism ;
    rdfs:comment "Validation ensuring the system's security properties." .

:PerformanceValidation rdf:type owl:Class ;
    rdfs:subClassOf :ValidationMechanism ;
    rdfs:comment "Validation ensuring the system meets performance targets." .

:ReceiptCompleteness rdf:type owl:Class ;
    rdfs:subClassOf :CorrectnessValidation ;
    rdfs:comment "A validation criterion ensuring all expected receipts are produced." .

:PolicyFidelity rdf:type owl:Class ;
    rdfs:subClassOf :CorrectnessValidation ;
    rdfs:comment "A validation criterion ensuring adherence to defined policies." .

:DP_Conformance rdf:type owl:Class ;
    rdfs:subClassOf :SecurityValidation ;
    rdfs:comment "A validation criterion ensuring compliance with Differential Privacy budgets." .

#################################################################
#    Object Properties
#################################################################

:appliesValidation rdf:type owl:ObjectProperty ;
    rdfs:domain arch:ByteStarEcosystem ;
    rdfs:range :ValidationMechanism ;
    rdfs:comment "The ByteStar ecosystem applies various validation mechanisms." .

:validatesCorrectnessOf rdf:type owl:ObjectProperty ;
    rdfs:domain :CorrectnessValidation ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Correctness validation applies to a specific resource or process." .

:validatesSecurityOf rdf:type owl:ObjectProperty ;
    rdfs:domain :SecurityValidation ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Security validation applies to a specific resource or process." .

:validatesPerformanceOf rdf:type owl:ObjectProperty ;
    rdfs:domain :PerformanceValidation ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Performance validation applies to a specific resource or process." .

:ensuresCompletenessOf rdf:type owl:ObjectProperty ;
    rdfs:domain :ReceiptCompleteness ;
    rdfs:range spr:Receipt ;
    rdfs:comment "Receipt completeness ensures the presence of all expected receipts." .

:ensuresFidelityTo rdf:type owl:ObjectProperty ;
    rdfs:domain :PolicyFidelity ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "Policy fidelity ensures adherence to a specific policy." .

:ensuresConformanceTo rdf:type owl:ObjectProperty ;
    rdfs:domain :DP_Conformance ;
    rdfs:range rdfs:Resource ;
    rdfs:comment "DP conformance ensures adherence to Differential Privacy standards." .

#################################################################
#    Data Properties
#################################################################

:hasPassRateTarget rdf:type owl:DatatypeProperty ;
    rdfs:domain :ValidationMechanism ;
    rdfs:range xsd:float ;
    rdfs:comment "The target pass rate for a validation mechanism (e.g., 0.99999 for 99.999%)." .

:hasCoverageTarget rdf:type owl:DatatypeProperty ;
    rdfs:domain :PolicyFidelity ;
    rdfs:range xsd:float ;
    rdfs:comment "The target coverage for policy fidelity (e.g., 0.995 for 99.5%)." .

:hasViolationCountTarget rdf:type owl:DatatypeProperty ;
    rdfs:domain :SecurityValidation ;
    rdfs:range xsd:integer ;
    rdfs:comment "The target count for violations (e.g., 0 for zero violations)." .

