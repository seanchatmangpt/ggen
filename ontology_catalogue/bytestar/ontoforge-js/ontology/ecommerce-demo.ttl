  rdfs:range xsd:integer .

:reservedQuantity a rdf:Property ;
  rdfs:label "Reserved Quantity" ;
  rdfs:domain :Inventory ;
  rdfs:range xsd:integer .

:reorderPoint a rdf:Property ;
  rdfs:label "Reorder Point" ;
  rdfs:domain :Inventory ;
  rdfs:range xsd:integer .

:lastRestocked a rdf:Property ;
  rdfs:label "Last Restocked" ;
  rdfs:domain :Inventory ;
  rdfs:range xsd:dateTime .

# Coupon Properties
:couponCode a rdf:Property ;
  rdfs:label "Coupon Code" ;
  rdfs:domain :Coupon ;
  rdfs:range xsd:string .

:discountType a rdf:Property ;
  rdfs:label "Discount Type" ;
  rdfs:domain :Coupon ;
  rdfs:range xsd:string .

:discountValue a rdf:Property ;
  rdfs:label "Discount Value" ;
  rdfs:domain :Coupon ;
  rdfs:range xsd:decimal .

:minOrderAmount a rdf:Property ;
  rdfs:label "Minimum Order Amount" ;
  rdfs:domain :Coupon ;
  rdfs:range xsd:decimal .

:expirationDate a rdf:Property ;
  rdfs:label "Expiration Date" ;
  rdfs:domain :Coupon ;
  rdfs:range xsd:date .

:usageLimit a rdf:Property ;
  rdfs:label "Usage Limit" ;
  rdfs:domain :Coupon ;
  rdfs:range xsd:integer .

:usageCount a rdf:Property ;
  rdfs:label "Usage Count" ;
  rdfs:domain :Coupon ;
  rdfs:range xsd:integer .

# Shipment Properties
:trackingNumber a rdf:Property ;
  rdfs:label "Tracking Number" ;
  rdfs:domain :Shipment ;
  rdfs:range xsd:string .

:carrier a rdf:Property ;
  rdfs:label "Carrier" ;
  rdfs:domain :Shipment ;
  rdfs:range xsd:string .

:shipmentStatus a rdf:Property ;
  rdfs:label "Shipment Status" ;
  rdfs:domain :Shipment ;
  rdfs:range xsd:string .

:shippedDate a rdf:Property ;
  rdfs:label "Shipped Date" ;
  rdfs:domain :Shipment ;
  rdfs:range xsd:dateTime .

:deliveryDate a rdf:Property ;
  rdfs:label "Delivery Date" ;
  rdfs:domain :Shipment ;
  rdfs:range xsd:dateTime .

:estimatedDelivery a rdf:Property ;
  rdfs:label "Estimated Delivery" ;
  rdfs:domain :Shipment ;
  rdfs:range xsd:dateTime .

# Timestamp properties for all entities
:createdAt a rdf:Property ;
  rdfs:label "Created At" ;
  rdfs:range xsd:dateTime .

:updatedAt a rdf:Property ;
  rdfs:label "Updated At" ;
  rdfs:range xsd:dateTime .

# Object Properties (Relationships)
:belongsToCategory a rdf:Property ;
  rdfs:label "Belongs to Category" ;
  rdfs:domain :Product ;
  rdfs:range :Category .

:hasParentCategory a rdf:Property ;
  rdfs:label "Has Parent Category" ;
  rdfs:domain :Category ;
  rdfs:range :Category .

:placedBy a rdf:Property ;
  rdfs:label "Placed By" ;
  rdfs:domain :Order ;
  rdfs:range :Customer .

:containsItem a rdf:Property ;
  rdfs:label "Contains Item" ;
  rdfs:domain :Order ;
  rdfs:range :OrderItem .

:itemProduct a rdf:Property ;
  rdfs:label "Item Product" ;
  rdfs:domain :OrderItem ;
  rdfs:range :Product .

:belongsToOrder a rdf:Property ;
  rdfs:label "Belongs to Order" ;
  rdfs:domain :OrderItem ;
  rdfs:range :Order .

:reviewedBy a rdf:Property ;
  rdfs:label "Reviewed By" ;
  rdfs:domain :Review ;
  rdfs:range :Customer .

:reviewsProduct a rdf:Property ;
  rdfs:label "Reviews Product" ;
  rdfs:domain :Review ;
  rdfs:range :Product .

:hasAddress a rdf:Property ;
  rdfs:label "Has Address" ;
  rdfs:domain :User ;
  rdfs:range :Address .

:shippingAddress a rdf:Property ;
  rdfs:label "Shipping Address" ;
  rdfs:domain :Order ;
  rdfs:range :Address .

:billingAddress a rdf:Property ;
  rdfs:label "Billing Address" ;
  rdfs:domain :Order ;
  rdfs:range :Address .

:paymentForOrder a rdf:Property ;
  rdfs:label "Payment for Order" ;
  rdfs:domain :Payment ;
  rdfs:range :Order .

:hasInventory a rdf:Property ;
  rdfs:label "Has Inventory" ;
  rdfs:domain :Product ;
  rdfs:range :Inventory .

:appliedCoupon a rdf:Property ;
  rdfs:label "Applied Coupon" ;
  rdfs:domain :Order ;
  rdfs:range :Coupon .

:shipmentForOrder a rdf:Property ;
  rdfs:label "Shipment for Order" ;
  rdfs:domain :Shipment ;
  rdfs:range :Order .

:ownsCart a rdf:Property ;
  rdfs:label "Owns Cart" ;
  rdfs:domain :Customer ;
  rdfs:range :ShoppingCart .

:cartContains a rdf:Property ;
  rdfs:label "Cart Contains" ;
  rdfs:domain :ShoppingCart ;
  rdfs:range :CartItem .

:cartItemProduct a rdf:Property ;
  rdfs:label "Cart Item Product" ;
  rdfs:domain :CartItem ;
  rdfs:range :Product .