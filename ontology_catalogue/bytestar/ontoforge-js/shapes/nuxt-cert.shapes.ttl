@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <https://example.org/nuxt-cert#> .

# Minimal SHACL shapes for Nuxt Certification ontology

ex:CertificationProgramShape a sh:NodeShape ;
  sh:targetClass ex:CertificationProgram ;
  sh:property [
    sh:path ex:name ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
  ] .

ex:CertificateLevelShape a sh:NodeShape ;
  sh:targetClass ex:CertificateLevel ;
  sh:property [ sh:path ex:name ; sh:minCount 1 ; sh:datatype xsd:string ] .

ex:ExamShape a sh:NodeShape ;
  sh:targetClass ex:Exam ;
  sh:property [ sh:path ex:name ; sh:minCount 1 ; sh:datatype xsd:string ] .




