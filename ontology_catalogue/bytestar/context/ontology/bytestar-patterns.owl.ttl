@prefix : <https://bytestar.org/ontology/bytestar-patterns#> .
@prefix bytestar: <https://bytestar.org/ontology/bytestar-core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://bytestar.org/ontology/bytestar-patterns>
  a owl:Ontology ;
  owl:imports <https://bytestar.org/ontology/bytestar-core> ;
  rdfs:label "ByteStar Pattern Registry" ;
  rdfs:comment "Enumerates the 43 patterns and links to micro-ops & PB mapping." .

:MicroOp a owl:Class .
:hasMicroOp a owl:ObjectProperty ; rdfs:domain bytestar:Pattern ; rdfs:range :MicroOp .
:pbMask a owl:DatatypeProperty ; rdfs:domain bytestar:Pattern ; rdfs:range xsd:unsignedByte .

### Placeholder individuals for the 43 patterns (expand names as you finalize)
:Pattern01 a bytestar:Pattern ; :pbMask "0"^^xsd:unsignedByte .
