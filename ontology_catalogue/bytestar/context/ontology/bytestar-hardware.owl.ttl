@prefix : <https://bytestar.org/ontology/bytestar-hardware#> .
@prefix bytestar: <https://bytestar.org/ontology/bytestar-core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://bytestar.org/ontology/bytestar-hardware>
  a owl:Ontology ;
  owl:imports <https://bytestar.org/ontology/bytestar-core> ;
  rdfs:label "ByteStar Hardware & Pinning" ;
  rdfs:comment "Core/NUMA model, pinning policies, SPSC topology constraints." .

:Host a owl:Class .
:Core a owl:Class .
:NUMANode a owl:Class .

:hasCore a owl:ObjectProperty ; rdfs:domain :Host ; rdfs:range :Core .
:inNUMA a owl:ObjectProperty ; rdfs:domain :Core ; rdfs:range :NUMANode .

:pinsTo a owl:ObjectProperty ; rdfs:domain bytestar:Subsystem ; rdfs:range :Core .
:exclusiveCore a owl:DatatypeProperty ; rdfs:domain :Core ; rdfs:range xsd:boolean .

### SPSC constraints
:SPRing a owl:Class ; rdfs:subClassOf bytestar:RingBuffer .
:producer a owl:ObjectProperty ; rdfs:domain :SPRing ; rdfs:range bytestar:Subsystem .
:consumer a owl:ObjectProperty ; rdfs:domain :SPRing ; rdfs:range bytestar:Subsystem .
:isSPSC a owl:DatatypeProperty ; rdfs:domain :SPRing ; rdfs:range xsd:boolean .

### L1 residency requirement (link to core)
:l1SetResident a owl:DatatypeProperty ; rdfs:domain :Core ; rdfs:range xsd:boolean .