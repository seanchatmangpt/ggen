############
# PATTERNS
############

# • 43 workflow patterns P01..P43
# • pbMask: unique xsd:hexBinary (01..2B)
# • microOpsFixed: true; maxHops ≤ 8
# • hasOpSeq: RDF list of kernels (non-empty)

bsreg:P01 a bs:Pattern ;
  rdfs:label "Pattern P01" ;
  bsds:patternId "PAT-01" ;
  bsds:pbMask "01"^^xsd:hexBinary ;
  bsds:microOpsFixed true ;
  bsds:maxHops 8 ;
  bsds:hasOpSeq ( bsreg:K01 bsreg:K17 bsreg:K33 bsreg:K49 ) .

