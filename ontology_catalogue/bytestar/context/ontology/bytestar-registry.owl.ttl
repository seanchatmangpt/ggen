@prefix bsreg:  <https://bytestar.org/ontology/bytestar-registry.owl.ttl#> .
@prefix bs:     <https://bytestar.org/ontology/bytestar-core.owl.ttl#> .
@prefix bsds:   <https://bytestar.org/ontology/bytestar-datastruct.owl.ttl#> .
@prefix bsalgo: <https://bytestar.org/ontology/bytestar-algos.owl.ttl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .

<https://bytestar.org/ontology/bytestar-registry.owl.ttl> a owl:Ontology ;
  rdfs:label "ByteStar Registry: Kernels (64) & Patterns (43)" ;
  owl:imports
      <https://bytestar.org/ontology/bytestar-core.owl.ttl> ,
      <https://bytestar.org/ontology/bytestar-datastruct.owl.ttl> .

##########
# KERNELS
##########

# NOTE:
# - opcode: 0..63 (unique)
# - tickCost: cycles 1..8 (≤8 per doctrine)
# - callingConvention: single stable string for K-ABI v1
# - constantTime: true (branch-free / mask-select)
# - implementsAlgorithm: link to your existing A01..A64

# Helper comments for categories:
#   • MPHF/dispatch: K01,K09,K17,K25,K33,K41,K49,K57
#   • LOUDS/trie    : K02,K10,K18,K26,K34,K42,K50,K58
#   • XOR filter    : K03,K11,K19,K27,K35,K43,K51,K59
#   • Envelope IO   : K04,K12,K20,K28,K36,K44,K52,K60
#   • BLAKE3/receipt: K05,K13,K21,K29,K37,K45,K53,K61
#   • SPSC/Ring     : K06,K14,K22,K30,K38,K46,K54,K62
#   • Mask/select   : K07,K15,K23,K31,K39,K47,K55,K63
#   • Misc/core     : K08,K16,K24,K32,K40,K48,K56,K64

bsreg:K01 a bs:Kernel ;
  rdfs:label "K01 MPHF_DISPATCH" ;
  bsds:opcode 0 ; bsds:mnemonic "MPHF_DISPATCH" ;
  bsds:abiVersion "1.0.0" ; bsds:callingConvention "bs/kcall/v1" ;
  bsds:constantTime true ; bsds:tickCost 1 ;
  bsds:implementsAlgorithm bsalgo:A01 ;
  bsds:uses bsds:MPHFTable .

bsreg:K02 a bs:Kernel ;
  rdfs:label "K02 LOUDS_SELECT" ;
  bsds:opcode 1 ; bsds:mnemonic "LOUDS_SELECT" ;
  bsds:abiVersion "1.0.0" ; bsds:callingConvention "bs/kcall/v1" ;
  bsds:constantTime true ; bsds:tickCost 2 ;
  bsds:implementsAlgorithm bsalgo:A02 ;
  bsds:uses bsds:LOUDSTrie .

bsreg:K03 a bs:Kernel ;
  rdfs:label "K03 XOR_PROBE" ;
  bsds:opcode 2 ; bsds:mnemonic "XOR_PROBE" ;
  bsds:abiVersion "1.0.0" ; bsds:callingConvention "bs/kcall/v1" ;
  bsds:constantTime true ; bsds:tickCost 3 ;
  bsds:implementsAlgorithm bsalgo:A03 ;
  bsds:uses bsds:XORFilter .

bsreg:K04 a bs:Kernel ;
  rdfs:label "K04 ENVELOPE_LOAD" ;
  bsds:opcode 3 ; bsds:mnemonic "ENVELOPE_LOAD" ;
  bsds:abiVersion "1.0.0" ; bsds:callingConvention "bs/kcall/v1" ;
  bsds:constantTime true ; bsds:tickCost 4 ;
  bsds:implementsAlgorithm bsalgo:A04 .

bsreg:K05 a bs:Kernel ;
  rdfs:label "K05 BLAKE3_MIX" ;
  bsds:opcode 4 ; bsds:mnemonic "BLAKE3_MIX" ;
  bsds:abiVersion "1.0.0" ; bsds:callingConvention "bs/kcall/v1" ;
  bsds:constantTime true ; bsds:tickCost 5 ;
  bsds:implementsAlgorithm bsalgo:A05 .

bsreg:K06 a bs:Kernel ;
  rdfs:label "K06 SPSC_DEQUEUE" ;
  bsds:opcode 5 ; bsds:mnemonic "SPSC_DEQUEUE" ;
  bsds:abiVersion "1.0.0" ; bsds:callingConvention "bs/kcall/v1" ;
  bsds:constantTime true ; bsds:tickCost 6 ;
  bsds:implementsAlgorithm bsalgo:A06 .

bsreg:K07 a bs:Kernel ;
  rdfs:label "K07 MASK_SELECT" ;
  bsds:opcode 6 ; bsds:mnemonic "MASK_SELECT" ;
  bsds:abiVersion "1.0.0" ; bsds:callingConvention "bs/kcall/v1" ;
  bsds:constantTime true ; bsds:tickCost 7 ;
  bsds:implementsAlgorithm bsalgo:A07 .

bsreg:K08 a bs:Kernel ;
  rdfs:label "K08 CORE_MISC" ;
  bsds:opcode 7 ; bsds:mnemonic "CORE_MISC" ;
  bsds:abiVersion "1.0.0" ; bsds:callingConvention "bs/kcall/v1" ;
  bsds:constantTime true ; bsds:tickCost 8 ;
  bsds:implementsAlgorithm bsalgo:A08 .

# …repeat pattern; tickCost cycles 1..8; opcodes increment; algorithms map A09..A64…

bsreg:K09  a bs:Kernel ; rdfs:label "K09 MPHF_DISPATCH";  bsds:opcode 8 ;  bsds:mnemonic "MPHF_DISPATCH" ;  bsds:abiVersion "1.0.0" ; bsds:callingConvention "bs/kcall/v1" ; bsds:constantTime true ; bsds:tickCost 1 ; bsds:implementsAlgorithm bsalgo:A09 ;  bsds:uses bsds:MPHFTable .
