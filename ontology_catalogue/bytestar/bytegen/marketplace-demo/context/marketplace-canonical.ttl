@prefix bs: <https://bytestar.org/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# ============================================================================
# BYTESTAR MARKETPLACE CANONICAL ONTOLOGY
# The single source of truth for the sovereign marketplace
# ============================================================================

<https://bytestar.org/ontology> rdf:type owl:Ontology ;
    rdfs:label "ByteStar Marketplace Canonical Ontology" ;
    rdfs:comment "Defines the immutable laws of the sovereign marketplace reality" ;
    owl:versionInfo "1.0.0" ;
    bs:fabricationTarget "nuxt-supabase" ;
    bs:physicsCompliant "true" .

# ============================================================================
# CORE ENTITIES - The Fundamental Particles of Marketplace Reality
# ============================================================================

# User Entity
bs:User rdf:type owl:Class ;
    rdfs:label "User" ;
    rdfs:comment "A sovereign entity participating in the marketplace" ;
    bs:tableName "users" ;
    bs:hasOwnership "true" .

bs:user_email rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:User ;
    rdfs:range xsd:string ;
    rdfs:label "Email Address" ;
    bs:required "true" ;
    bs:unique "true" .

bs:user_username rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:User ;
    rdfs:range xsd:string ;
    rdfs:label "Username" ;
    bs:required "true" ;
    bs:unique "true" .

bs:user_reputation_score rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:User ;
    rdfs:range xsd:decimal ;
    rdfs:label "Reputation Score" ;
    bs:defaultValue "0.0" ;
    bs:range "0.0..100.0" .

# Product Entity
bs:Product rdf:type owl:Class ;
    rdfs:label "Product" ;
    rdfs:comment "A tradeable item in the marketplace" ;
    bs:tableName "products" ;
    bs:hasOwnership "true" .

bs:product_name rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Product ;
    rdfs:range xsd:string ;
    rdfs:label "Product Name" ;
    bs:required "true" ;
    bs:maxLength "255" .

bs:product_description rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Product ;
    rdfs:range xsd:string ;
    rdfs:label "Description" ;
    bs:maxLength "2000" .

bs:product_price rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Product ;
    rdfs:range xsd:decimal ;
    rdfs:label "Price" ;
    bs:required "true" ;
    bs:range "0.01..999999.99" .

bs:product_category rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Product ;
    rdfs:range xsd:string ;
    rdfs:label "Category" ;
    bs:enum "{electronics,books,clothing,home,sports}" .

bs:product_owner_id rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Product ;
    rdfs:range xsd:string ;
    rdfs:label "Owner ID" ;
    bs:required "true" ;
    bs:accessControl "true" .

# Transaction Entity - The Core of Marketplace Physics
bs:Transaction rdf:type owl:Class ;
    rdfs:label "Transaction" ;
    rdfs:comment "An atomic exchange event in the marketplace" ;
    bs:tableName "marketplace_transactions" ;
    bs:hasOwnership "true" ;
    bs:requiresQuantumSealing "true" .

bs:transaction_type rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Transaction ;
    rdfs:range xsd:string ;
    rdfs:label "Transaction Type" ;
    bs:required "true" ;
    bs:enum "{b2b,g2x,b2c,p2p}" .

bs:transaction_amount rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Transaction ;
    rdfs:range xsd:decimal ;
    rdfs:label "Amount" ;
    bs:required "true" ;
    bs:range "0.01..1000000.00" .

bs:transaction_status rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Transaction ;
    rdfs:range xsd:string ;
    rdfs:label "Status" ;
    bs:required "true" ;
    bs:enum "{pending,processing,completed,failed,cancelled}" ;
    bs:defaultValue "pending" .

bs:transaction_hops rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Transaction ;
    rdfs:range xsd:integer ;
    rdfs:label "Processing Hops" ;
    bs:defaultValue "0" ;
    bs:range "0..8" ;
    bs:physicsConstraint "doctrine_of_8" .

bs:transaction_ticks rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Transaction ;
    rdfs:range xsd:integer ;
    rdfs:label "Processing Ticks" ;
    bs:defaultValue "0" ;
    bs:range "0..8" .

bs:transaction_user_id rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Transaction ;
    rdfs:range xsd:string ;
    rdfs:label "User ID" ;
    bs:required "true" ;
    bs:accessControl "true" .

# Order Entity
bs:Order rdf:type owl:Class ;
    rdfs:label "Order" ;
    rdfs:comment "A collection of transaction intents" ;
    bs:tableName "orders" ;
    bs:hasOwnership "true" .

bs:order_total rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Order ;
    rdfs:range xsd:decimal ;
    rdfs:label "Order Total" ;
    bs:required "true" ;
    bs:range "0.01..1000000.00" .

bs:order_status rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Order ;
    rdfs:range xsd:string ;
    rdfs:label "Order Status" ;
    bs:required "true" ;
    bs:enum "{draft,submitted,processing,fulfilled,cancelled}" ;
    bs:defaultValue "draft" .

bs:order_user_id rdf:type owl:DatatypeProperty ;
    rdfs:domain bs:Order ;
    rdfs:range xsd:string ;
    rdfs:label "User ID" ;
    bs:required "true" ;
    bs:accessControl "true" .

# ============================================================================
# RELATIONSHIPS - The Forces That Bind Entities
# ============================================================================

# User owns Products
bs:owns rdf:type owl:ObjectProperty ;
    rdfs:domain bs:User ;
    rdfs:range bs:Product ;
    rdfs:label "Owns" ;
    bs:inverse bs:ownedBy .

# User creates Orders
bs:creates rdf:type owl:ObjectProperty ;
    rdfs:domain bs:User ;
    rdfs:range bs:Order ;
    rdfs:label "Creates" ;
    bs:inverse bs:createdBy .

# Order contains Products
bs:contains rdf:type owl:ObjectProperty ;
    rdfs:domain bs:Order ;
    rdfs:range bs:Product ;
    rdfs:label "Contains" ;
    bs:inverse bs:containedIn .

# Transaction references Order
bs:references rdf:type owl:ObjectProperty ;
    rdfs:domain bs:Transaction ;
    rdfs:range bs:Order ;
    rdfs:label "References" ;
    bs:inverse bs:referencedBy .

# Transaction involves Users (buyer and seller)
bs:buyer rdf:type owl:ObjectProperty ;
    rdfs:domain bs:Transaction ;
    rdfs:range bs:User ;
    rdfs:label "Buyer" .

bs:seller rdf:type owl:ObjectProperty ;
    rdfs:domain bs:Transaction ;
    rdfs:range bs:User ;
    rdfs:label "Seller" .

# ============================================================================
# BUSINESS RULES - The Laws of Marketplace Physics
# ============================================================================

bs:TransactionRule001 bs:businessRule "A transaction must not exceed 8 processing hops (Doctrine of 8)" .
bs:TransactionRule002 bs:businessRule "All transactions must be quantum sealed before transmission" .
bs:TransactionRule003 bs:businessRule "Users can only modify transactions they created" .
bs:TransactionRule004 bs:businessRule "Orders must be validated before transaction creation" .
bs:TransactionRule005 bs:businessRule "function:validate_transaction_physics" .
bs:TransactionRule006 bs:businessRule "action:fabricate_mission_crystal_on_transaction_create" .

# Reputation Rules
bs:ReputationRule001 bs:businessRule "Successful transactions increase reputation by 0.1" .
bs:ReputationRule002 bs:businessRule "Failed transactions decrease reputation by 0.5" .
bs:ReputationRule003 bs:businessRule "function:calculate_reputation_score" .

# Performance Rules
bs:PerformanceRule001 bs:businessRule "System must handle 10,000 TPS minimum" .
bs:PerformanceRule002 bs:businessRule "Transaction processing must complete within 64ns" .

# ============================================================================
# SHACL SHAPES - The Validation Physics
# ============================================================================

# User Shape
bs:UserShape rdf:type sh:NodeShape ;
    sh:targetClass bs:User ;
    sh:property [
        sh:path bs:user_email ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:pattern "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$" ;
        sh:message "Must be a valid email address"
    ] ;
    sh:property [
        sh:path bs:user_username ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minLength 3 ;
        sh:maxLength 50 ;
        sh:pattern "^[a-zA-Z0-9_]+$" ;
        sh:message "Username must be 3-50 characters, letters, numbers, and underscores only"
    ] ;
    sh:property [
        sh:path bs:user_reputation_score ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Reputation score must be between 0.0 and 100.0"
    ] .

# Product Shape
bs:ProductShape rdf:type sh:NodeShape ;
    sh:targetClass bs:Product ;
    sh:property [
        sh:path bs:product_name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minLength 1 ;
        sh:maxLength 255 ;
        sh:message "Product name is required and must be 1-255 characters"
    ] ;
    sh:property [
        sh:path bs:product_price ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.01 ;
        sh:maxInclusive 999999.99 ;
        sh:message "Price must be between $0.01 and $999,999.99"
    ] ;
    sh:property [
        sh:path bs:product_category ;
        sh:datatype xsd:string ;
        sh:in ("electronics" "books" "clothing" "home" "sports") ;
        sh:message "Category must be one of: electronics, books, clothing, home, sports"
    ] .

# Transaction Shape - Critical for Marketplace Physics
bs:TransactionShape rdf:type sh:NodeShape ;
    sh:targetClass bs:Transaction ;
    sh:property [
        sh:path bs:transaction_type ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in ("b2b" "g2x" "b2c" "p2p") ;
        sh:message "Transaction type must be one of: b2b, g2x, b2c, p2p"
    ] ;
    sh:property [
        sh:path bs:transaction_amount ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.01 ;
        sh:maxInclusive 1000000.00 ;
        sh:message "Transaction amount must be between $0.01 and $1,000,000.00"
    ] ;
    sh:property [
        sh:path bs:transaction_hops ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:maxInclusive 8 ;
        sh:message "Processing hops must not exceed 8 (Doctrine of 8)"
    ] ;
    sh:property [
        sh:path bs:buyer ;
        sh:class bs:User ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Transaction must have exactly one buyer"
    ] ;
    sh:property [
        sh:path bs:seller ;
        sh:class bs:User ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Transaction must have exactly one seller"
    ] .

# Order Shape
bs:OrderShape rdf:type sh:NodeShape ;
    sh:targetClass bs:Order ;
    sh:property [
        sh:path bs:order_total ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.01 ;
        sh:message "Order total must be at least $0.01"
    ] .

# ============================================================================
# METADATA - Universe Configuration
# ============================================================================

bs:MarketplaceMetadata rdf:type bs:UniverseConfiguration ;
    bs:maxEntities "847" ;
    bs:maxPolicies "2341" ;
    bs:maxFunctions "156" ;
    bs:targetTPS "10000" ;
    bs:successRate "100" ;
    bs:maxExecutionTime "64ns" ;
    bs:quantumSealingRequired "true" ;
    bs:bytestarIntegrationEnabled "true" ;
    bs:deploymentTarget "supabase-nuxt" .