@prefix ethos: <http://bytestar.ai/ethos#> .
@prefix crystal: <http://bytestar.ai/crystal#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# Crystal Type Registry v5 - Complete Definitive Set
# Generated: 2025-08-23
# Status: Crystal-Definitive

crystal:Registry a owl:Ontology ;
    rdfs:label "ByteStar v5 Crystal Type Registry" ;
    rdfs:comment "Complete, closed, and definitive crystal type catalog with CTIDs" ;
    owl:versionInfo "5.0.0" ;
    crystal:status "DEFINITIVE" ;
    crystal:doctrine "8-space-compliant" .

# Base Crystal Class
ethos:Crystal a owl:Class ;
    rdfs:label "Crystal Base Type" ;
    rdfs:comment "Universal parent of all ByteStar crystal types" ;
    crystal:immutable true ;
    crystal:pqcSealed true .

# Domain: Governance & Ontology
crystal:OntologyPackage a owl:Class ;
    rdfs:subClassOf ethos:Crystal ;
    rdfs:label "Ontology Package Crystal" ;
    crystal:extension ".opc" ;
    crystal:ctid "0x7f3d4e8a91b2c5d6e7f8091a2b3c4d5e6f7081929394a5b6c7d8e9fa0b1c2d3e4f" ;
    crystal:encoding "SSZ" ;
    crystal:abis "Wire,Storage" ;
    crystal:hops "1,3,6,8" ;
    crystal:fields [
        crystal:field [ 
            crystal:name "ontologies" ;
            crystal:type "bytes32[]" ;
            crystal:maxLength 256
        ] ;
        crystal:field [
            crystal:name "c14n_digest" ;
            crystal:type "bytes32"
        ] ;
        crystal:field [
            crystal:name "version" ;
            crystal:type "uint32"
        ]
    ] .

