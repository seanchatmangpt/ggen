# Disjointness Declarations
[ a owl:AllDisjointClasses ;
    owl:members (
        crystal:OntologyPackage crystal:SHACLPackage crystal:CanonCrystal
        crystal:PatternRegistry crystal:OrgBinding crystal:Revocation
        crystal:PolycrystalLattice crystal:BuildProvenance crystal:BinaryTransparencyEntry
        crystal:DatasetCrystal crystal:ViewCrystal crystal:PublicMirror
        crystal:DPBudgetToken crystal:RedactionProof crystal:AssetDescriptor
        crystal:Offer crystal:Order crystal:Settlement crystal:PriceFeed
        crystal:UsageMetering crystal:SLA crystal:BridgeProof
        crystal:StreamSegment crystal:Alert crystal:EvidenceCrystal
        crystal:FuzzCorpus crystal:FixtureBundle
    )
] .

# Coverage Axiom
ethos:Crystal owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
        crystal:OntologyPackage crystal:SHACLPackage crystal:CanonCrystal
        crystal:PatternRegistry crystal:OrgBinding crystal:Revocation
        crystal:PolycrystalLattice crystal:BuildProvenance crystal:BinaryTransparencyEntry
        crystal:DatasetCrystal crystal:ViewCrystal crystal:PublicMirror
        crystal:DPBudgetToken crystal:RedactionProof crystal:AssetDescriptor
        crystal:Offer crystal:Order crystal:Settlement crystal:PriceFeed
        crystal:UsageMetering crystal:SLA crystal:BridgeProof
        crystal:StreamSegment crystal:Alert crystal:EvidenceCrystal
        crystal:FuzzCorpus crystal:FixtureBundle
        # Include existing crystals
        crystal:IdentityCrystal crystal:CapabilityCrystal
        crystal:MissionBlueprint crystal:PatternByte
        crystal:AdmissionReceipt crystal:AttestationReceipt
        crystal:CanonReceipt crystal:SovereigntyReceipt
        crystal:TransformReceipt crystal:CommitReceipt
        crystal:PublicationReceipt crystal:TransparencyBundle
        crystal:ABISpec crystal:NIFSecurityReceipt crystal:ABIOKReceipt
        crystal:OracleSet crystal:HealthCapsule
    )
] .

