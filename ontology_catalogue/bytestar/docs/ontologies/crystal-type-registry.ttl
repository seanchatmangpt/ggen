    crystal:encoding "SSZ" ;
    crystal:abis "Wire,Storage" ;
    crystal:hops "1,3,6,8" ;
    crystal:fields [
        crystal:field [
            crystal:name "shapes" ;
            crystal:type "bytes32[]" ;
            crystal:maxLength 512
        ] ;
        crystal:field [
            crystal:name "validation_rules" ;
            crystal:type "bytes32"
        ]
    ] .

