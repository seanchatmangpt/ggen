@prefix : <https://bytestar.org/ontology/bytegen-fabrication#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .
@prefix bc: <https://bytestar.org/ontology/bytecore#> .
@prefix bf: <https://bytestar.org/ontology/byteflow#> .
@prefix dc: <https://bytestar.org/ontology/dark-canon#> .

@base <https://bytestar.org/ontology/bytegen-fabrication> .

<https://bytestar.org/ontology/bytegen-fabrication> rdf:type owl:Ontology ;
    owl:versionIRI <https://bytestar.org/ontology/bytegen-fabrication/1.0> ;
    rdfs:label "ByteGen Fabrication Ontology" ;
    rdfs:comment """
    The ByteGen Fabrication Ontology defines the deterministic transformation process
    from formal TTL specifications to executable, PQC-sealed crystal artifacts.
    
    This ontology embodies the core innovation of the ByteStar AHI paradigm:
    specifications ARE implementations through mathematical fabrication rather 
    than probabilistic translation.
    
    Key Features:
    - ttl2dspy: Zero-entropy compilation pipeline
    - Crystal Sealing: PQC signature validation
    - MAPE Loop: Autonomic Monitor-Analyze-Plan-Execute control
    - Mathematical Proofs: Formal correctness guarantees
    """ ;
    owl:imports <https://bytestar.org/ontology/bytecore> ,
                <https://bytestar.org/ontology/byteflow> ,
                <https://bytestar.org/ontology/dark-canon> .

#################################################################
#    Core Fabrication Classes
#################################################################

:FabricationPipeline a owl:Class ;
    rdfs:label "Fabrication Pipeline" ;
    rdfs:comment """
    The complete ttl2dspy transformation pipeline that converts formal
    specifications into executable crystals with mathematical guarantees.
    """ ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            [ a owl:Restriction ; owl:onProperty :hasStage ; owl:someValuesFrom :ParseStage ]
            [ a owl:Restriction ; owl:onProperty :hasStage ; owl:someValuesFrom :ValidateStage ]
            [ a owl:Restriction ; owl:onProperty :hasStage ; owl:someValuesFrom :OptimizeStage ]
            [ a owl:Restriction ; owl:onProperty :hasStage ; owl:someValuesFrom :GenerateStage ]
            [ a owl:Restriction ; owl:onProperty :hasStage ; owl:someValuesFrom :SealStage ]
        )
    ] .

:FabricationStage a owl:Class ;
    rdfs:label "Fabrication Stage" ;
    rdfs:comment "Abstract base class for all fabrication pipeline stages." .

:ParseStage a owl:Class ;
    rdfs:subClassOf :FabricationStage ;
    rdfs:label "Parse Stage" ;
    rdfs:comment """
    TTL specification parsing with AST generation and semantic validation.
    Ensures complete structural correctness before fabrication.
    """ .

:ValidateStage a owl:Class ;
    rdfs:subClassOf :FabricationStage ;
    rdfs:label "Validate Stage" ;
    rdfs:comment """
    SHACL shape validation and Dark Canon compliance checking.
    Generates mathematical proofs of specification correctness.
    """ .

:OptimizeStage a owl:Class ;
    rdfs:subClassOf :FabricationStage ;
    rdfs:label "Optimize Stage" ;
    rdfs:comment """
    Neural pattern optimization and resource allocation planning.
    Ensures 8-tick execution guarantee through predictive analysis.
    """ .

:GenerateStage a owl:Class ;
    rdfs:subClassOf :FabricationStage ;
    rdfs:label "Generate Stage" ;
    rdfs:comment """
    C structure and executable code generation from optimized patterns.
    Direct ontology-to-implementation materialization.
    """ .

:SealStage a owl:Class ;
    rdfs:subClassOf :FabricationStage ;
    rdfs:label "Seal Stage" ;
    rdfs:comment """
    PQC signature application and tamper-proof crystal packaging.
    Ensures cryptographic authenticity and integrity.
    """ .

#################################################################
#    Crystal Artifact Classes
#################################################################

:ExecutableCrystal a owl:Class ;
    rdfs:label "Executable Crystal" ;
    rdfs:comment """
    The final product of deterministic fabrication: a PQC-sealed,
    mathematically proven, executable artifact that embodies the
    original TTL specification with absolute fidelity.
    """ ;
    owl:hasKey ( :hasSignature :hasChecksum ) .

:CrystalStructure a owl:Class ;
    rdfs:label "Crystal Structure" ;
    rdfs:comment """
    The internal C structure layout of an executable crystal,
    optimized for L1 cache residency and 8-tick execution.
    """ .

:CrystalHeader a owl:Class ;
    rdfs:subClassOf :CrystalStructure ;
    rdfs:label "Crystal Header" ;
    rdfs:comment """
    Crystal metadata including version, signature, checksum,
    pattern ID, and execution constraints.
    """ .

:CrystalPayload a owl:Class ;
    rdfs:subClassOf :CrystalStructure ;
    rdfs:label "Crystal Payload" ;
    rdfs:comment """
    The executable kernel sequence and data pointers that
    implement the original TTL specification.
    """ .

:CrystalProof a owl:Class ;
    rdfs:label "Crystal Proof" ;
    rdfs:comment """
    Mathematical proof of correctness, including SHACL validation
    results and formal verification certificates.
    """ .

#################################################################
#    MAPE Loop Classes
#################################################################

:MAPEController a owl:Class ;
    rdfs:label "MAPE Controller" ;
    rdfs:comment """
    Autonomic Monitor-Analyze-Plan-Execute controller that manages
    the complete fabrication lifecycle with self-optimization.
    """ ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            [ a owl:Restriction ; owl:onProperty :hasMonitor ; owl:exactCardinality 1 ]
            [ a owl:Restriction ; owl:onProperty :hasAnalyzer ; owl:exactCardinality 1 ]
            [ a owl:Restriction ; owl:onProperty :hasPlanner ; owl:exactCardinality 1 ]
            [ a owl:Restriction ; owl:onProperty :hasExecutor ; owl:exactCardinality 1 ]
        )
    ] .

:Monitor a owl:Class ;
    rdfs:label "Monitor" ;
    rdfs:comment """
    Continuous telemetry collection from fabrication processes,
    crystal execution, and system performance metrics.
    """ .

:Analyzer a owl:Class ;
    rdfs:label "Analyzer" ;
    rdfs:comment """
    Neural analysis of collected telemetry to identify optimization
    opportunities and performance bottlenecks.
    """ .

:Planner a owl:Class ;
    rdfs:label "Planner" ;
    rdfs:comment """
    Strategic planning for fabrication optimization, resource
    allocation, and execution path selection.
    """ .

:Executor a owl:Class ;
    rdfs:label "Executor" ;
    rdfs:comment """
    Execution of planned optimizations through fabrication
    parameter adjustment and crystal redeployment.
    """ .

#################################################################
#    Fabrication Properties
#################################################################

:hasStage a owl:ObjectProperty ;
    rdfs:label "has stage" ;
    rdfs:domain :FabricationPipeline ;
    rdfs:range :FabricationStage ;
    rdfs:comment "Associates a fabrication pipeline with its constituent stages." .

:processesSpecification a owl:ObjectProperty ;
    rdfs:label "processes specification" ;
    rdfs:domain :FabricationStage ;
    rdfs:comment "The TTL specification being processed by a fabrication stage." .

:producesArtifact a owl:ObjectProperty ;
    rdfs:label "produces artifact" ;
    rdfs:domain :FabricationStage ;
    rdfs:comment "The intermediate or final artifact produced by a fabrication stage." .

:hasSignature a owl:ObjectProperty ;
    rdfs:label "has signature" ;
    rdfs:domain :ExecutableCrystal ;
    rdfs:comment "PQC signature ensuring crystal authenticity and integrity." .

:hasChecksum a owl:DatatypeProperty ;
    rdfs:label "has checksum" ;
    rdfs:domain :ExecutableCrystal ;
    rdfs:range xsd:string ;
    rdfs:comment "SHA3-512 checksum for crystal integrity verification." .

:hasPatternID a owl:DatatypeProperty ;
    rdfs:label "has pattern ID" ;
    rdfs:domain :ExecutableCrystal ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Canonical pattern identifier (1-43) for crystal classification." .

:hasTickBudget a owl:DatatypeProperty ;
    rdfs:label "has tick budget" ;
    rdfs:domain :ExecutableCrystal ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Maximum CPU cycles allocated for crystal execution (≤8)." .

:hasKernelSequence a owl:ObjectProperty ;
    rdfs:label "has kernel sequence" ;
    rdfs:domain :ExecutableCrystal ;
    rdfs:comment "Ordered sequence of computational kernels for execution." .

#################################################################
#    MAPE Loop Properties
#################################################################

:hasMonitor a owl:ObjectProperty ;
    rdfs:label "has monitor" ;
    rdfs:domain :MAPEController ;
    rdfs:range :Monitor ;
    a owl:FunctionalProperty .

:hasAnalyzer a owl:ObjectProperty ;
    rdfs:label "has analyzer" ;
    rdfs:domain :MAPEController ;
    rdfs:range :Analyzer ;
    a owl:FunctionalProperty .

:hasPlanner a owl:ObjectProperty ;
    rdfs:label "has planner" ;
    rdfs:domain :MAPEController ;
    rdfs:range :Planner ;
    a owl:FunctionalProperty .

:hasExecutor a owl:ObjectProperty ;
    rdfs:label "has executor" ;
    rdfs:domain :MAPEController ;
    rdfs:range :Executor ;
    a owl:FunctionalProperty .

:monitors a owl:ObjectProperty ;
    rdfs:label "monitors" ;
    rdfs:domain :Monitor ;
    rdfs:comment "Entities being monitored for telemetry collection." .

:analyzes a owl:ObjectProperty ;
    rdfs:label "analyzes" ;
    rdfs:domain :Analyzer ;
    rdfs:comment "Telemetry data being analyzed for insights." .

:plansFor a owl:ObjectProperty ;
    rdfs:label "plans for" ;
    rdfs:domain :Planner ;
    rdfs:comment "System components being planned for optimization." .

:executes a owl:ObjectProperty ;
    rdfs:label "executes" ;
    rdfs:domain :Executor ;
    rdfs:comment "Plans being executed through system modifications." .

#################################################################
#    Performance and Quality Properties
#################################################################

:hasPerformanceMetric a owl:ObjectProperty ;
    rdfs:label "has performance metric" ;
    rdfs:comment "Performance measurement associated with fabrication processes." .

:hasThroughput a owl:DatatypeProperty ;
    rdfs:label "has throughput" ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Operations per second capacity." .

:hasLatency a owl:DatatypeProperty ;
    rdfs:label "has latency" ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Response time in microseconds." .

:hasAvailability a owl:DatatypeProperty ;
    rdfs:label "has availability" ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Uptime percentage (0.0-1.0)." .

:hasCorrectnessProof a owl:ObjectProperty ;
    rdfs:label "has correctness proof" ;
    rdfs:domain :ExecutableCrystal ;
    rdfs:range :CrystalProof ;
    rdfs:comment "Mathematical proof of crystal correctness." .

#################################################################
#    Fabrication Process Axioms
#################################################################

# Sequential Stage Processing
owl:propertyChainAxiom ( :hasStage :processesSpecification ) rdfs:subPropertyOf :processesSpecification .

# Crystal Uniqueness Constraint
:ExecutableCrystal owl:hasKey ( :hasSignature :hasChecksum ) .

# MAPE Loop Autonomic Behavior
:MAPEController rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasMonitor ;
    owl:allValuesFrom [
        a owl:Restriction ;
        owl:onProperty :monitors ;
        owl:someValuesFrom :FabricationPipeline
    ]
] .

# Performance Guarantee Constraint
:ExecutableCrystal rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasTickBudget ;
    owl:maxInclusive 8
] .

# Crystal Integrity Constraint
:ExecutableCrystal rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasSignature ;
    owl:cardinality 1
] .

#################################################################
#    SHACL Validation Shapes
#################################################################

:FabricationPipelineShape a shacl:NodeShape ;
    shacl:targetClass :FabricationPipeline ;
    shacl:property [
        shacl:path :hasStage ;
        shacl:class :FabricationStage ;
        shacl:minCount 5 ;
        shacl:maxCount 5 ;
        shacl:message "Fabrication pipeline must have exactly 5 stages: Parse, Validate, Optimize, Generate, Seal"
    ] .

:ExecutableCrystalShape a shacl:NodeShape ;
    shacl:targetClass :ExecutableCrystal ;
    shacl:property [
        shacl:path :hasTickBudget ;
        shacl:datatype xsd:positiveInteger ;
        shacl:maxInclusive 8 ;
        shacl:minInclusive 1 ;
        shacl:message "Crystal execution must respect 8-tick doctrine"
    ] ;
    shacl:property [
        shacl:path :hasSignature ;
        shacl:minCount 1 ;
        shacl:maxCount 1 ;
        shacl:message "Crystal must have exactly one PQC signature"
    ] ;
    shacl:property [
        shacl:path :hasChecksum ;
        shacl:datatype xsd:string ;
        shacl:pattern "^[a-fA-F0-9]{128}$" ;
        shacl:message "Checksum must be valid SHA3-512 hash"
    ] .

:MAPEControllerShape a shacl:NodeShape ;
    shacl:targetClass :MAPEController ;
    shacl:property [
        shacl:path :hasMonitor ;
        shacl:class :Monitor ;
        shacl:minCount 1 ;
        shacl:maxCount 1
    ] ;
    shacl:property [
        shacl:path :hasAnalyzer ;
        shacl:class :Analyzer ;
        shacl:minCount 1 ;
        shacl:maxCount 1
    ] ;
    shacl:property [
        shacl:path :hasPlanner ;
        shacl:class :Planner ;
        shacl:minCount 1 ;
        shacl:maxCount 1
    ] ;
    shacl:property [
        shacl:path :hasExecutor ;
        shacl:class :Executor ;
        shacl:minCount 1 ;
        shacl:maxCount 1
    ] .

#################################################################
#    Individual Instances
#################################################################

:PrimaryFabricationPipeline a :FabricationPipeline ;
    rdfs:label "Primary Fabrication Pipeline" ;
    rdfs:comment "The main ttl2dspy fabrication pipeline for crystal production." ;
    :hasStage :TTLParseStage , :SHACLValidateStage , :NeuralOptimizeStage , 
              :CodeGenerateStage , :PQCSealStage .

:TTLParseStage a :ParseStage ;
    rdfs:label "TTL Parse Stage" .

:SHACLValidateStage a :ValidateStage ;
    rdfs:label "SHACL Validate Stage" .

:NeuralOptimizeStage a :OptimizeStage ;
    rdfs:label "Neural Optimize Stage" .

:CodeGenerateStage a :GenerateStage ;
    rdfs:label "Code Generate Stage" .

:PQCSealStage a :SealStage ;
    rdfs:label "PQC Seal Stage" .

:PrimaryMAPEController a :MAPEController ;
    rdfs:label "Primary MAPE Controller" ;
    rdfs:comment "Main autonomic controller for fabrication pipeline management." ;
    :hasMonitor :FabricationMonitor ;
    :hasAnalyzer :NeuralAnalyzer ;
    :hasPlanner :OptimizationPlanner ;
    :hasExecutor :AdaptiveExecutor .

:FabricationMonitor a :Monitor ;
    rdfs:label "Fabrication Monitor" .

:NeuralAnalyzer a :Analyzer ;
    rdfs:label "Neural Analyzer" .

:OptimizationPlanner a :Planner ;
    rdfs:label "Optimization Planner" .

:AdaptiveExecutor a :Executor ;
    rdfs:label "Adaptive Executor" .