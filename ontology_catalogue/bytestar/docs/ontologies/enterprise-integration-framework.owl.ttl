    rdfs:comment "Duration for which metrics are retained." .

:hasLogRetention a owl:DatatypeProperty ;
    rdfs:label "has log retention" ;
    rdfs:domain :MonitoringPlatform ;
    rdfs:range xsd:duration ;
    rdfs:comment "Duration for which logs are retained." .

:supportsRealTimeMonitoring a owl:DatatypeProperty ;
    rdfs:label "supports real-time monitoring" ;
    rdfs:domain :MonitoringPlatform ;
