#################################################################
#    Performance and Quality Properties
#################################################################

:hasIntegrationLatency a owl:DatatypeProperty ;
    rdfs:label "has integration latency" ;
    rdfs:domain :IntegrationPoint ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Integration latency in milliseconds." .

:hasThroughputCapacity a owl:DatatypeProperty ;
    rdfs:label "has throughput capacity" ;
    rdfs:domain :IntegrationPoint ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Maximum throughput capacity in requests per second." .

:hasAvailability a owl:DatatypeProperty ;
    rdfs:label "has availability" ;
    rdfs:range xsd:decimal ;
    rdfs:comment "System availability percentage (0.0-1.0)." .

:hasReliabilityScore a owl:DatatypeProperty ;
    rdfs:label "has reliability score" ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Integration reliability score (0.0-1.0)." .

:supportsSLA a owl:DatatypeProperty ;
    rdfs:label "supports SLA" ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating SLA support." .

#################################################################
#    Mathematical Constraints and Axioms
#################################################################

# Multi-Tenant Isolation Constraint
:Tenant owl:disjointWith :Tenant .

# Compliance Score Bounds
:ComplianceFramework rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasComplianceScore ;
    owl:minInclusive 0.0
] .

:ComplianceFramework rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasComplianceScore ;
    owl:maxInclusive 1.0
] .

# Availability Bounds
owl:Thing rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasAvailability ;
    owl:minInclusive 0.0
] .

owl:Thing rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasAvailability ;
    owl:maxInclusive 1.0
] .

# Integration Point Uniqueness
:IntegrationPoint owl:hasKey ( :integratesWith ) .

# Tenant Resource Quota Constraint
:Tenant rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasResourceQuota ;
    owl:minInclusive 0.0
] .

#################################################################
#    SHACL Validation Shapes
#################################################################

:IntegrationPointShape a shacl:NodeShape ;
    shacl:targetClass :IntegrationPoint ;
    shacl:property [
        shacl:path :usesAdapter ;
        shacl:class :IntegrationAdapter ;
        shacl:minCount 1 ;
        shacl:message "Integration point must use at least one adapter"
    ] ;
    shacl:property [
        shacl:path :hasIntegrationLatency ;
        shacl:datatype xsd:decimal ;
        shacl:minInclusive 0.0 ;
        shacl:message "Integration latency must be non-negative"
    ] .

:TenantShape a shacl:NodeShape ;
    shacl:targetClass :Tenant ;
    shacl:property [
        shacl:path :hasTenantID ;
        shacl:datatype xsd:string ;
        shacl:minCount 1 ;
        shacl:maxCount 1 ;
        shacl:message "Tenant must have exactly one unique ID"
    ] ;
    shacl:property [
        shacl:path :hasResourceQuota ;
        shacl:datatype xsd:decimal ;
        shacl:minInclusive 0.0 ;
        shacl:message "Resource quota must be non-negative"
    ] .

:ComplianceFrameworkShape a shacl:NodeShape ;
    shacl:targetClass :ComplianceFramework ;
    shacl:property [
        shacl:path :hasComplianceScore ;
        shacl:datatype xsd:decimal ;
        shacl:minInclusive 0.0 ;
        shacl:maxInclusive 1.0 ;
        shacl:message "Compliance score must be between 0.0 and 1.0"
    ] .

:MessageQueueShape a shacl:NodeShape ;
    shacl:targetClass :MessageQueue ;
    shacl:property [
        shacl:path :hasMaxThroughput ;
        shacl:datatype xsd:positiveInteger ;
        shacl:minInclusive 1 ;
        shacl:message "Max throughput must be at least 1 message per second"
    ] .

#################################################################
#    Individual Instances
#################################################################

# Primary Enterprise Integration Framework
:PrimaryIntegrationFramework a :EnterpriseIntegrationFramework ;
    rdfs:label "Primary Enterprise Integration Framework" ;
    rdfs:comment "Main integration framework for ByteStar enterprise deployment." .

# Cloud Platform Instances
:AWSIntegration a :IntegrationPoint ;
    rdfs:label "AWS Integration Point" ;
    rdfs:comment "Integration point for Amazon Web Services." ;
    :integratesWith :AWSPlatform ;
    :hasIntegrationLatency 5.0 ;
    :hasThroughputCapacity 50000 .

:AzureIntegration a :IntegrationPoint ;
    rdfs:label "Azure Integration Point" ;
    rdfs:comment "Integration point for Microsoft Azure." ;
    :integratesWith :AzurePlatform ;
    :hasIntegrationLatency 6.0 ;
    :hasThroughputCapacity 45000 .

