@prefix : <https://bytestar.org/ontology/enterprise-integration#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .
@prefix mac: <https://bytestar.org/ontology/multi-agent-coordination#> .
@prefix ag: <https://bytestar.org/ontology/autonomous-governance#> .
@prefix pqc: <https://bytestar.org/ontology/post-quantum-crypto#> .

@base <https://bytestar.org/ontology/enterprise-integration> .

<https://bytestar.org/ontology/enterprise-integration> rdf:type owl:Ontology ;
    owl:versionIRI <https://bytestar.org/ontology/enterprise-integration/1.0> ;
    rdfs:label "Enterprise Integration Framework Ontology" ;
    rdfs:comment """
    The Enterprise Integration Framework Ontology defines the comprehensive
    mechanisms for seamlessly integrating ByteStar fabric capabilities with
    existing enterprise systems, cloud platforms, and business processes.
    
    This ontology enables Fortune 5 companies to leverage ByteStar's deterministic
    fabrication, post-quantum security, and autonomous governance while maintaining
    compatibility with legacy systems and regulatory compliance requirements.
    
    Integration Domains:
    - Cloud Platform Integration: AWS, Azure, GCP native integration
    - Enterprise System Integration: ERP, CRM, SCM, HRIS systems
    - API Gateway Integration: REST, GraphQL, gRPC, WebSocket protocols
    - Database Integration: SQL, NoSQL, Graph, Time-Series databases
    - Message Queue Integration: Kafka, RabbitMQ, Amazon SQS, Azure Service Bus
    - Identity Provider Integration: Active Directory, LDAP, SAML, OAuth2
    - Monitoring Integration: DataDog, New Relic, Splunk, Elastic Stack
    - CI/CD Integration: Jenkins, GitHub Actions, Azure DevOps, GitLab
    
    Enterprise Features:
    - Multi-Tenant Architecture: Secure isolation and resource partitioning
    - Compliance Framework: SOC2, ISO27001, GDPR, HIPAA, PCI-DSS
    - Audit Logging: Immutable audit trails with PQC signatures
    - Business Intelligence: Real-time analytics and reporting integration
    - Disaster Recovery: Cross-region backup and failover capabilities
    """ ;
    owl:imports <https://bytestar.org/ontology/multi-agent-coordination> ,
                <https://bytestar.org/ontology/autonomous-governance> ,
                <https://bytestar.org/ontology/post-quantum-crypto> .

#################################################################
#    Core Integration Classes
#################################################################

:EnterpriseIntegrationFramework a owl:Class ;
    rdfs:label "Enterprise Integration Framework" ;
    rdfs:comment """
    Comprehensive framework enabling seamless integration between
    ByteStar fabric and enterprise infrastructure, systems, and processes.
    """ .

:IntegrationPoint a owl:Class ;
    rdfs:label "Integration Point" ;
    rdfs:comment """
    Specific interface or connector that enables communication
    between ByteStar components and external enterprise systems.
    """ .

:IntegrationAdapter a owl:Class ;
    rdfs:label "Integration Adapter" ;
    rdfs:comment """
    Specialized component that translates between ByteStar protocols
    and external system interfaces, ensuring seamless communication.
    """ .

:EnterpriseSystem a owl:Class ;
    rdfs:label "Enterprise System" ;
    rdfs:comment """
    External enterprise application or system that integrates
    with ByteStar fabric through defined interfaces.
    """ .

:LegacySystem a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "Legacy System" ;
    rdfs:comment """
    Existing enterprise system that requires special adaptation
    for integration with modern ByteStar capabilities.
    """ .

:ModernSystem a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "Modern System" ;
    rdfs:comment """
    Contemporary enterprise system with modern APIs and
    protocols facilitating straightforward integration.
    """ .

#################################################################
#    Cloud Platform Integration Classes
#################################################################

:CloudPlatform a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "Cloud Platform" ;
    rdfs:comment """
    Major cloud service provider platform offering infrastructure,
    platform, and software services for enterprise deployment.
    """ .

:AWSPlatform a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :CloudPlatform ;
    rdfs:label "AWS Platform" ;
    rdfs:comment """
    Amazon Web Services cloud platform with comprehensive
    integration for ByteStar deployment and services.
    """ .

:AzurePlatform a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :CloudPlatform ;
    rdfs:label "Azure Platform" ;
    rdfs:comment """
    Microsoft Azure cloud platform with enterprise-focused
    integration capabilities for ByteStar deployment.
    """ .

:GCPPlatform a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :CloudPlatform ;
    rdfs:label "GCP Platform" ;
    rdfs:comment """
    Google Cloud Platform with advanced analytics and
    machine learning integration for ByteStar enhancement.
    """ .

:CloudService a owl:Class ;
    rdfs:label "Cloud Service" ;
    rdfs:comment """
    Specific service offered by cloud platforms that
    integrates with ByteStar capabilities.
    """ .

:ComputeService a owl:Class ;
    rdfs:subClassOf :CloudService ;
    rdfs:label "Compute Service" ;
    rdfs:comment """
    Cloud computing service providing virtual machines,
    containers, or serverless execution environments.
    """ .

:StorageService a owl:Class ;
    rdfs:subClassOf :CloudService ;
    rdfs:label "Storage Service" ;
    rdfs:comment """
    Cloud storage service providing object storage,
    block storage, or file system services.
    """ .

:DatabaseService a owl:Class ;
    rdfs:subClassOf :CloudService ;
    rdfs:label "Database Service" ;
    rdfs:comment """
    Managed database service providing relational,
    NoSQL, or specialized database capabilities.
    """ .

:NetworkingService a owl:Class ;
    rdfs:subClassOf :CloudService ;
    rdfs:label "Networking Service" ;
    rdfs:comment """
    Cloud networking service providing VPC, load balancing,
    CDN, or network security capabilities.
    """ .

#################################################################
#    API Integration Classes
#################################################################

:APIGateway a owl:Class ;
    rdfs:label "API Gateway" ;
    rdfs:comment """
    Centralized entry point for API requests that provides
    routing, authentication, rate limiting, and monitoring.
    """ .

:APIProtocol a owl:Class ;
    rdfs:label "API Protocol" ;
    rdfs:comment """
    Communication protocol used for API interactions
    between ByteStar and enterprise systems.
    """ .

:RESTProtocol a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :APIProtocol ;
    rdfs:label "REST Protocol" ;
    rdfs:comment """
    Representational State Transfer protocol for
    HTTP-based API communication.
    """ .

:GraphQLProtocol a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :APIProtocol ;
    rdfs:label "GraphQL Protocol" ;
    rdfs:comment """
    GraphQL query language and runtime for
    flexible API data retrieval.
    """ .

:gRPCProtocol a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :APIProtocol ;
    rdfs:label "gRPC Protocol" ;
    rdfs:comment """
    High-performance RPC framework for
    efficient service-to-service communication.
    """ .

:WebSocketProtocol a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :APIProtocol ;
    rdfs:label "WebSocket Protocol" ;
    rdfs:comment """
    Real-time bidirectional communication protocol
    for interactive applications.
    """ .

:APIEndpoint a owl:Class ;
    rdfs:label "API Endpoint" ;
    rdfs:comment """
    Specific URL and HTTP method combination that
    provides access to particular functionality.
    """ .

:APIAuthentication a owl:Class ;
    rdfs:label "API Authentication" ;
    rdfs:comment """
    Authentication mechanism for verifying identity
    and authorizing API access.
    """ .

#################################################################
#    Database Integration Classes
#################################################################

:DatabaseIntegration a owl:Class ;
    rdfs:label "Database Integration" ;
    rdfs:comment """
    Integration framework for connecting ByteStar
    with various database systems and data stores.
    """ .

:RelationalDatabase a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "Relational Database" ;
    rdfs:comment """
    SQL-based relational database management system
    for structured data storage and retrieval.
    """ .

:NoSQLDatabase a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "NoSQL Database" ;
    rdfs:comment """
    Non-relational database system optimized for
    specific data models and access patterns.
    """ .

:GraphDatabase a owl:Class ;
    rdfs:subClassOf :NoSQLDatabase ;
    rdfs:label "Graph Database" ;
    rdfs:comment """
    Database optimized for storing and querying
    graph-structured data with relationships.
    """ .

:TimeSeriesDatabase a owl:Class ;
    rdfs:subClassOf :NoSQLDatabase ;
    rdfs:label "Time Series Database" ;
    rdfs:comment """
    Database optimized for storing and analyzing
    time-stamped data and metrics.
    """ .

:DocumentDatabase a owl:Class ;
    rdfs:subClassOf :NoSQLDatabase ;
    rdfs:label "Document Database" ;
    rdfs:comment """
    Database storing data in document format
    with flexible schema and structure.
    """ .

:DatabaseConnector a owl:Class ;
    rdfs:subClassOf :IntegrationAdapter ;
    rdfs:label "Database Connector" ;
    rdfs:comment """
    Specialized adapter for connecting ByteStar
    with specific database systems.
    """ .

#################################################################
#    Message Queue Integration Classes
#################################################################

:MessageQueueIntegration a owl:Class ;
    rdfs:label "Message Queue Integration" ;
    rdfs:comment """
    Integration framework for asynchronous messaging
    and event-driven communication with enterprise systems.
    """ .

:MessageQueue a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "Message Queue" ;
    rdfs:comment """
    Messaging middleware that enables asynchronous
    communication between distributed systems.
    """ .

:ApacheKafka a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :MessageQueue ;
    rdfs:label "Apache Kafka" ;
    rdfs:comment """
    Distributed streaming platform for building
    real-time data pipelines and streaming applications.
    """ .

:RabbitMQ a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :MessageQueue ;
    rdfs:label "RabbitMQ" ;
    rdfs:comment """
    Message broker that implements the Advanced Message
    Queuing Protocol (AMQP) for reliable messaging.
    """ .

:AmazonSQS a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :MessageQueue ;
    rdfs:label "Amazon SQS" ;
    rdfs:comment """
    Fully managed message queuing service from
    Amazon Web Services for decoupled applications.
    """ .

:AzureServiceBus a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :MessageQueue ;
    rdfs:label "Azure Service Bus" ;
    rdfs:comment """
    Enterprise message broker service from Microsoft Azure
    for hybrid cloud integration scenarios.
    """ .

:MessageProducer a owl:Class ;
    rdfs:label "Message Producer" ;
    rdfs:comment """
    Component that generates and sends messages
    to message queues or topics.
    """ .

:MessageConsumer a owl:Class ;
    rdfs:label "Message Consumer" ;
    rdfs:comment """
    Component that receives and processes messages
    from message queues or topics.
    """ .

#################################################################
#    Identity and Access Management Classes
#################################################################

:IdentityProvider a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "Identity Provider" ;
    rdfs:comment """
    System that manages user identities and provides
    authentication services for enterprise applications.
    """ .

:ActiveDirectory a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :IdentityProvider ;
    rdfs:label "Active Directory" ;
    rdfs:comment """
    Microsoft's directory service for managing
    user accounts and enterprise authentication.
    """ .

:LDAP a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :IdentityProvider ;
    rdfs:label "LDAP" ;
    rdfs:comment """
    Lightweight Directory Access Protocol for
    accessing and maintaining distributed directories.
    """ .

:SAMLProvider a owl:Class ;
    rdfs:subClassOf :IdentityProvider ;
    rdfs:label "SAML Provider" ;
    rdfs:comment """
    Identity provider supporting Security Assertion
    Markup Language for single sign-on.
    """ .

:OAuth2Provider a owl:Class ;
    rdfs:subClassOf :IdentityProvider ;
    rdfs:label "OAuth2 Provider" ;
    rdfs:comment """
    Identity provider supporting OAuth 2.0 framework
    for secure API access authorization.
    """ .

:SingleSignOn a owl:Class ;
    rdfs:label "Single Sign-On" ;
    rdfs:comment """
    Authentication mechanism allowing users to access
    multiple applications with one set of credentials.
    """ .

:MultiFactor Authentication a owl:Class ;
    rdfs:label "Multi-Factor Authentication" ;
    rdfs:comment """
    Security mechanism requiring multiple forms of
    verification for user authentication.
    """ .

#################################################################
#    Enterprise Application Classes
#################################################################

:ERPSystem a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "ERP System" ;
    rdfs:comment """
    Enterprise Resource Planning system for managing
    business processes and organizational resources.
    """ .

:CRMSystem a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "CRM System" ;
    rdfs:comment """
    Customer Relationship Management system for
    managing customer interactions and relationships.
    """ .

:SCMSystem a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "SCM System" ;
    rdfs:comment """
    Supply Chain Management system for optimizing
    supply chain operations and logistics.
    """ .

:HRISSystem a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "HRIS System" ;
    rdfs:comment """
    Human Resource Information System for managing
    employee data and HR processes.
    """ .

:BusinessIntelligence a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "Business Intelligence" ;
    rdfs:comment """
    System for analyzing business data and providing
    insights for decision-making.
    """ .

:DataWarehouse a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "Data Warehouse" ;
    rdfs:comment """
    Central repository for integrated data from
    multiple sources for analytical processing.
    """ .

#################################################################
#    Multi-Tenancy Classes
#################################################################

:MultiTenantArchitecture a owl:Class ;
    rdfs:label "Multi-Tenant Architecture" ;
    rdfs:comment """
    Architecture pattern enabling multiple tenants to
    share infrastructure while maintaining isolation.
    """ .

:Tenant a owl:Class ;
    rdfs:label "Tenant" ;
    rdfs:comment """
    Distinct customer or organizational unit with
    isolated resources and data in multi-tenant system.
    """ .

:TenantIsolation a owl:Class ;
    rdfs:label "Tenant Isolation" ;
    rdfs:comment """
    Security mechanism ensuring tenants cannot access
    each other's data or resources.
    """ .

:ResourcePartitioning a owl:Class ;
    rdfs:label "Resource Partitioning" ;
    rdfs:comment """
    Mechanism for allocating and isolating computational
    resources between different tenants.
    """ .

:DataIsolation a owl:Class ;
    rdfs:label "Data Isolation" ;
    rdfs:comment """
    Mechanism ensuring tenant data remains separate
    and inaccessible to other tenants.
    """ .

:TenantProvisioning a owl:Class ;
    rdfs:label "Tenant Provisioning" ;
    rdfs:comment """
    Process of creating and configuring resources
    for new tenants in multi-tenant environment.
    """ .

#################################################################
#    Compliance and Audit Classes
#################################################################

:ComplianceFramework a owl:Class ;
    rdfs:label "Compliance Framework" ;
    rdfs:comment """
    Framework ensuring ByteStar operations adhere to
    regulatory requirements and industry standards.
    """ .

:SOC2Compliance a owl:Class ;
    rdfs:subClassOf :ComplianceFramework ;
    rdfs:label "SOC2 Compliance" ;
    rdfs:comment """
    Service Organization Control 2 compliance framework
    for security, availability, and processing integrity.
    """ .

:ISO27001Compliance a owl:Class ;
    rdfs:subClassOf :ComplianceFramework ;
    rdfs:label "ISO 27001 Compliance" ;
    rdfs:comment """
    Information Security Management System standard
    for systematic security management.
    """ .

:GDPRCompliance a owl:Class ;
    rdfs:subClassOf :ComplianceFramework ;
    rdfs:label "GDPR Compliance" ;
    rdfs:comment """
    General Data Protection Regulation compliance
    for protecting EU citizen privacy rights.
    """ .

:HIPAACompliance a owl:Class ;
    rdfs:subClassOf :ComplianceFramework ;
    rdfs:label "HIPAA Compliance" ;
    rdfs:comment """
    Health Insurance Portability and Accountability Act
    compliance for protecting health information.
    """ .

:PCIDSSCompliance a owl:Class ;
    rdfs:subClassOf :ComplianceFramework ;
    rdfs:label "PCI-DSS Compliance" ;
    rdfs:comment """
    Payment Card Industry Data Security Standard
    compliance for protecting payment card data.
    """ .

:AuditTrail a owl:Class ;
    rdfs:label "Audit Trail" ;
    rdfs:comment """
    Immutable record of all system activities and
    changes for compliance and forensic analysis.
    """ .

:ComplianceReport a owl:Class ;
    rdfs:label "Compliance Report" ;
    rdfs:comment """
    Report demonstrating adherence to specific
    compliance requirements and regulations.
    """ .

#################################################################
#    Monitoring and Observability Classes
#################################################################

:MonitoringIntegration a owl:Class ;
    rdfs:label "Monitoring Integration" ;
    rdfs:comment """
    Integration framework for connecting ByteStar
    with enterprise monitoring and observability platforms.
    """ .

:MonitoringPlatform a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "Monitoring Platform" ;
    rdfs:comment """
    Platform for collecting, analyzing, and visualizing
    system metrics and operational data.
    """ .

:DataDog a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :MonitoringPlatform ;
    rdfs:label "DataDog" ;
    rdfs:comment """
    Cloud-based monitoring and analytics platform
    for applications and infrastructure.
    """ .

:NewRelic a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :MonitoringPlatform ;
    rdfs:label "New Relic" ;
    rdfs:comment """
    Application performance monitoring platform
    for modern software development.
    """ .

:Splunk a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :MonitoringPlatform ;
    rdfs:label "Splunk" ;
    rdfs:comment """
    Platform for searching, monitoring, and analyzing
    machine-generated big data.
    """ .

:ElasticStack a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :MonitoringPlatform ;
    rdfs:label "Elastic Stack" ;
    rdfs:comment """
    Collection of open source products for searching,
    analyzing, and visualizing data.
    """ .

:MetricsCollector a owl:Class ;
    rdfs:label "Metrics Collector" ;
    rdfs:comment """
    Component responsible for gathering performance
    and operational metrics from ByteStar systems.
    """ .

:LogAggregator a owl:Class ;
    rdfs:label "Log Aggregator" ;
    rdfs:comment """
    Component collecting and centralizing log data
    from distributed ByteStar components.
    """ .

:AlertingSystem a owl:Class ;
    rdfs:label "Alerting System" ;
    rdfs:comment """
    System for generating and routing alerts based
    on monitoring data and predefined thresholds.
    """ .

#################################################################
#    CI/CD Integration Classes
#################################################################

:CICDIntegration a owl:Class ;
    rdfs:label "CI/CD Integration" ;
    rdfs:comment """
    Integration framework for connecting ByteStar
    with enterprise continuous integration and deployment pipelines.
    """ .

:CICDPlatform a owl:Class ;
    rdfs:subClassOf :EnterpriseSystem ;
    rdfs:label "CI/CD Platform" ;
    rdfs:comment """
    Platform providing continuous integration and
    deployment capabilities for software development.
    """ .

:Jenkins a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :CICDPlatform ;
    rdfs:label "Jenkins" ;
    rdfs:comment """
    Open source automation server for building,
    testing, and deploying software.
    """ .

:GitHubActions a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :CICDPlatform ;
    rdfs:label "GitHub Actions" ;
    rdfs:comment """
    CI/CD platform integrated with GitHub for
    automating software workflows.
    """ .

:AzureDevOps a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :CICDPlatform ;
    rdfs:label "Azure DevOps" ;
    rdfs:comment """
    Microsoft's DevOps platform providing CI/CD,
    repositories, and project management.
    """ .

:GitLab a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :CICDPlatform ;
    rdfs:label "GitLab" ;
    rdfs:comment """
    DevOps platform providing Git repository management
    with integrated CI/CD capabilities.
    """ .

:BuildPipeline a owl:Class ;
    rdfs:label "Build Pipeline" ;
    rdfs:comment """
    Automated pipeline for building, testing, and
    preparing ByteStar applications for deployment.
    """ .

:DeploymentPipeline a owl:Class ;
    rdfs:label "Deployment Pipeline" ;
    rdfs:comment """
    Automated pipeline for deploying ByteStar
    applications to various environments.
    """ .

#################################################################
#    Integration Properties
#################################################################

:integratesWith a owl:ObjectProperty ;
    rdfs:label "integrates with" ;
    rdfs:comment "System or service that integrates with ByteStar." .

:usesAdapter a owl:ObjectProperty ;
    rdfs:label "uses adapter" ;
    rdfs:domain :IntegrationPoint ;
    rdfs:range :IntegrationAdapter ;
    rdfs:comment "Adapter used by the integration point." .

:connectsToSystem a owl:ObjectProperty ;
    rdfs:label "connects to system" ;
    rdfs:domain :IntegrationAdapter ;
    rdfs:range :EnterpriseSystem ;
    rdfs:comment "External system connected by the adapter." .

:providesService a owl:ObjectProperty ;
    rdfs:label "provides service" ;
    rdfs:domain :CloudPlatform ;
    rdfs:range :CloudService ;
    rdfs:comment "Service provided by the cloud platform." .

:implementsProtocol a owl:ObjectProperty ;
    rdfs:label "implements protocol" ;
    rdfs:range :APIProtocol ;
    rdfs:comment "Protocol implemented by the component." .

:hasEndpoint a owl:ObjectProperty ;
    rdfs:label "has endpoint" ;
    rdfs:domain :APIGateway ;
    rdfs:range :APIEndpoint ;
    rdfs:comment "Endpoint managed by the API gateway." .

:authenticatesWith a owl:ObjectProperty ;
    rdfs:label "authenticates with" ;
    rdfs:range :IdentityProvider ;
    rdfs:comment "Identity provider used for authentication." .

:supportsSingleSignOn a owl:DatatypeProperty ;
    rdfs:label "supports single sign-on" ;
    rdfs:domain :IdentityProvider ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating SSO support." .

#################################################################
#    Database Integration Properties
#################################################################

:connectsToDatabase a owl:ObjectProperty ;
    rdfs:label "connects to database" ;
    rdfs:domain :DatabaseConnector ;
    rdfs:range :DatabaseIntegration ;
    rdfs:comment "Database system connected by the connector." .

:supportsTransactions a owl:DatatypeProperty ;
    rdfs:label "supports transactions" ;
    rdfs:domain :RelationalDatabase ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating transaction support." .

:hasSchemaFlexibility a owl:DatatypeProperty ;
    rdfs:label "has schema flexibility" ;
    rdfs:domain :NoSQLDatabase ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating schema flexibility." .

:optimizedForGraphQueries a owl:DatatypeProperty ;
    rdfs:label "optimized for graph queries" ;
    rdfs:domain :GraphDatabase ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating graph query optimization." .

:supportsTimeSeriesAnalysis a owl:DatatypeProperty ;
    rdfs:label "supports time series analysis" ;
    rdfs:domain :TimeSeriesDatabase ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating time series analysis support." .

#################################################################
#    Message Queue Properties
#################################################################

:producesMessages a owl:ObjectProperty ;
    rdfs:label "produces messages" ;
    rdfs:domain :MessageProducer ;
    rdfs:range :MessageQueue ;
    rdfs:comment "Message queue where messages are produced." .

:consumesMessages a owl:ObjectProperty ;
    rdfs:label "consumes messages" ;
    rdfs:domain :MessageConsumer ;
    rdfs:range :MessageQueue ;
    rdfs:comment "Message queue from which messages are consumed." .

:hasMaxThroughput a owl:DatatypeProperty ;
    rdfs:label "has max throughput" ;
    rdfs:domain :MessageQueue ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Maximum message throughput per second." .

:guaranteesDelivery a owl:DatatypeProperty ;
    rdfs:label "guarantees delivery" ;
    rdfs:domain :MessageQueue ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating delivery guarantee." .

:supportsPartitioning a owl:DatatypeProperty ;
    rdfs:label "supports partitioning" ;
    rdfs:domain :MessageQueue ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating message partitioning support." .

#################################################################
#    Multi-Tenancy Properties
#################################################################

:belongsToTenant a owl:ObjectProperty ;
    rdfs:label "belongs to tenant" ;
    rdfs:range :Tenant ;
    rdfs:comment "Tenant that owns or has access to the resource." .

:isolatesTenant a owl:ObjectProperty ;
    rdfs:label "isolates tenant" ;
    rdfs:domain :TenantIsolation ;
    rdfs:range :Tenant ;
    rdfs:comment "Tenant being isolated by the mechanism." .

:partitionsResource a owl:ObjectProperty ;
    rdfs:label "partitions resource" ;
    rdfs:domain :ResourcePartitioning ;
    rdfs:comment "Resource being partitioned between tenants." .

:provisionsTenant a owl:ObjectProperty ;
    rdfs:label "provisions tenant" ;
    rdfs:domain :TenantProvisioning ;
    rdfs:range :Tenant ;
    rdfs:comment "Tenant being provisioned." .

:hasTenantID a owl:DatatypeProperty ;
    rdfs:label "has tenant ID" ;
    rdfs:domain :Tenant ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier for the tenant." .

:hasResourceQuota a owl:DatatypeProperty ;
    rdfs:label "has resource quota" ;
    rdfs:domain :Tenant ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Resource allocation limit for the tenant." .

#################################################################
#    Compliance Properties
#################################################################

:compliesWith a owl:ObjectProperty ;
    rdfs:label "complies with" ;
    rdfs:range :ComplianceFramework ;
    rdfs:comment "Compliance framework that the entity adheres to." .

:generatesDuditTrail a owl:ObjectProperty ;
    rdfs:label "generates audit trail" ;
    rdfs:range :AuditTrail ;
    rdfs:comment "Audit trail generated by the system." .

:producesComplianceReport a owl:ObjectProperty ;
    rdfs:label "produces compliance report" ;
    rdfs:domain :ComplianceFramework ;
    rdfs:range :ComplianceReport ;
    rdfs:comment "Compliance report produced by the framework." .

:hasComplianceScore a owl:DatatypeProperty ;
    rdfs:label "has compliance score" ;
    rdfs:domain :ComplianceFramework ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Compliance adherence score (0.0-1.0)." .

:requiresDataEncryption a owl:DatatypeProperty ;
    rdfs:label "requires data encryption" ;
    rdfs:domain :ComplianceFramework ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating data encryption requirement." .

:requiresAccessLogging a owl:DatatypeProperty ;
    rdfs:label "requires access logging" ;
    rdfs:domain :ComplianceFramework ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating access logging requirement." .

