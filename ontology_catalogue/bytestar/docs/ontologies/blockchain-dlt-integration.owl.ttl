@prefix : <https://bytestar.org/ontology/blockchain-dlt#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .
@prefix pqc: <https://bytestar.org/ontology/post-quantum-crypto#> .
@prefix ag: <https://bytestar.org/ontology/autonomous-governance#> .
@prefix ei: <https://bytestar.org/ontology/enterprise-integration#> .

@base <https://bytestar.org/ontology/blockchain-dlt> .

<https://bytestar.org/ontology/blockchain-dlt> rdf:type owl:Ontology ;
    owl:versionIRI <https://bytestar.org/ontology/blockchain-dlt/1.0> ;
    rdfs:label "Blockchain and Distributed Ledger Technology Integration Ontology" ;
    rdfs:comment """
    The Blockchain and DLT Integration Ontology defines the framework for integrating
    blockchain and distributed ledger technologies with ByteStar fabric while maintaining
    post-quantum security, deterministic performance, and enterprise compliance.
    
    This ontology enables ByteStar to leverage blockchain advantages for trust, immutability,
    and decentralization while addressing scalability, energy efficiency, and quantum
    resistance challenges through innovative architectural patterns.
    
    Blockchain Integration Domains:
    - Public Blockchain Integration: Ethereum, Bitcoin, Solana, Avalanche
    - Private Blockchain Networks: Hyperledger Fabric, R3 Corda, JPM Coin
    - Consortium Blockchain: Multi-party business networks
    - Central Bank Digital Currencies: CBDC integration and compliance
    - Smart Contract Execution: EVM, WASM, and custom runtimes
    - Layer 2 Solutions: Lightning Network, Polygon, Arbitrum, Optimism
    - Cross-Chain Interoperability: Polkadot, Cosmos, bridging protocols
    - DeFi Integration: Decentralized finance protocol interaction
    
    Key Features:
    - Quantum-Resistant Blockchain: Post-quantum signatures and hash functions
    - Deterministic Execution: 8-tick guarantee for smart contract execution
    - Energy-Efficient Consensus: Proof-of-Stake and novel consensus mechanisms
    - Enterprise Privacy: Zero-knowledge proofs and selective disclosure
    - High-Throughput Architecture: >100K TPS with finality guarantees
    - Cross-Chain Bridges: Secure interoperability between networks
    - Regulatory Compliance: CBDC, AML/KYC, and financial regulation support
    """ ;
    owl:imports <https://bytestar.org/ontology/post-quantum-crypto> ,
                <https://bytestar.org/ontology/autonomous-governance> ,
                <https://bytestar.org/ontology/enterprise-integration> .

#################################################################
#    Core Blockchain Classes
#################################################################

:BlockchainNetwork a owl:Class ;
    rdfs:label "Blockchain Network" ;
    rdfs:comment """
    Distributed network of nodes maintaining a shared ledger
    through consensus mechanisms and cryptographic validation.
    """ .

:PublicBlockchain a owl:Class ;
    rdfs:subClassOf :BlockchainNetwork ;
    rdfs:label "Public Blockchain" ;
    rdfs:comment """
    Permissionless blockchain network open to all participants
    with transparent and decentralized governance.
    """ .

:PrivateBlockchain a owl:Class ;
    rdfs:subClassOf :BlockchainNetwork ;
    rdfs:label "Private Blockchain" ;
    rdfs:comment """
    Permissioned blockchain network restricted to specific
    participants with controlled access and governance.
    """ .

:ConsortiumBlockchain a owl:Class ;
    rdfs:subClassOf :BlockchainNetwork ;
    rdfs:label "Consortium Blockchain" ;
    rdfs:comment """
    Semi-decentralized blockchain controlled by a group
    of organizations with shared governance.
    """ .

:HybridBlockchain a owl:Class ;
    rdfs:subClassOf :BlockchainNetwork ;
    rdfs:label "Hybrid Blockchain" ;
    rdfs:comment """
    Blockchain combining public and private elements
    with selective transparency and access control.
    """ .

:QuantumResistantBlockchain a owl:Class ;
    rdfs:subClassOf :BlockchainNetwork ;
    rdfs:label "Quantum-Resistant Blockchain" ;
    rdfs:comment """
    Blockchain using post-quantum cryptographic algorithms
    to resist attacks from quantum computers.
    """ .

#################################################################
#    Specific Blockchain Platform Classes
#################################################################

:Ethereum a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :PublicBlockchain ;
    rdfs:label "Ethereum" ;
    rdfs:comment """
    Programmable blockchain platform with smart contract
    capabilities and Ethereum Virtual Machine.
    """ .

:Bitcoin a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :PublicBlockchain ;
    rdfs:label "Bitcoin" ;
    rdfs:comment """
    First cryptocurrency blockchain focused on
    peer-to-peer value transfer and store of value.
    """ .

:Solana a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :PublicBlockchain ;
    rdfs:label "Solana" ;
    rdfs:comment """
    High-performance blockchain with Proof-of-History
    consensus for fast transaction processing.
    """ .

:Avalanche a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :PublicBlockchain ;
    rdfs:label "Avalanche" ;
    rdfs:comment """
    Platform for decentralized applications with
    sub-second finality and high throughput.
    """ .

:HyperledgerFabric a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :PrivateBlockchain ;
    rdfs:label "Hyperledger Fabric" ;
    rdfs:comment """
    Enterprise-grade permissioned blockchain framework
    with modular architecture and privacy features.
    """ .

:R3Corda a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :PrivateBlockchain ;
    rdfs:label "R3 Corda" ;
    rdfs:comment """
    Distributed ledger platform designed for
    regulated financial institutions.
    """ .

:Polkadot a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :PublicBlockchain ;
    rdfs:label "Polkadot" ;
    rdfs:comment """
    Multi-chain blockchain platform enabling
    cross-chain interoperability and communication.
    """ .

:Cosmos a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :PublicBlockchain ;
    rdfs:label "Cosmos" ;
    rdfs:comment """
    Ecosystem of interoperable blockchains
    connected through Inter-Blockchain Communication.
    """ .

#################################################################
#    Consensus Mechanism Classes
#################################################################

:ConsensusMechanism a owl:Class ;
    rdfs:label "Consensus Mechanism" ;
    rdfs:comment """
    Algorithm used by blockchain networks to achieve
    agreement on transaction validity and block creation.
    """ .

:ProofOfWork a owl:Class ;
    rdfs:subClassOf :ConsensusMechanism ;
    rdfs:label "Proof of Work" ;
    rdfs:comment """
    Consensus mechanism requiring computational work
    to validate transactions and create blocks.
    """ .

:ProofOfStake a owl:Class ;
    rdfs:subClassOf :ConsensusMechanism ;
    rdfs:label "Proof of Stake" ;
    rdfs:comment """
    Consensus mechanism based on validator stake
    rather than computational work.
    """ .

:DelegatedProofOfStake a owl:Class ;
    rdfs:subClassOf :ProofOfStake ;
    rdfs:label "Delegated Proof of Stake" ;
    rdfs:comment """
    Variant of proof of stake with elected validators
    representing token holder interests.
    """ .

:ProofOfAuthority a owl:Class ;
    rdfs:subClassOf :ConsensusMechanism ;
    rdfs:label "Proof of Authority" ;
    rdfs:comment """
    Consensus mechanism with pre-approved validators
    having authority to create blocks.
    """ .

:PracticalByzantineFaultTolerance a owl:Class ;
    rdfs:subClassOf :ConsensusMechanism ;
    rdfs:label "Practical Byzantine Fault Tolerance" ;
    rdfs:comment """
    Consensus algorithm tolerating Byzantine failures
    in partially synchronous networks.
    """ .

:ProofOfHistory a owl:Class ;
    rdfs:subClassOf :ConsensusMechanism ;
    rdfs:label "Proof of History" ;
    rdfs:comment """
    Cryptographic clock providing verifiable ordering
    of events before consensus.
    """ .

:AvalonConsensus a owl:Class ;
    rdfs:subClassOf :ConsensusMechanism ;
    rdfs:label "Avalanche Consensus" ;
    rdfs:comment """
    Metastable consensus protocol achieving high
    throughput and fast finality.
    """ .

#################################################################
#    Smart Contract Classes
#################################################################

:SmartContract a owl:Class ;
    rdfs:label "Smart Contract" ;
    rdfs:comment """
    Self-executing contract with terms directly written
    into code and deployed on blockchain.
    """ .

:SolidityContract a owl:Class ;
    rdfs:subClassOf :SmartContract ;
    rdfs:label "Solidity Contract" ;
    rdfs:comment """
    Smart contract written in Solidity programming
    language for Ethereum Virtual Machine.
    """ .

:WASMContract a owl:Class ;
    rdfs:subClassOf :SmartContract ;
    rdfs:label "WebAssembly Contract" ;
    rdfs:comment """
    Smart contract compiled to WebAssembly bytecode
    for high-performance execution.
    """ .

:ChainCode a owl:Class ;
    rdfs:subClassOf :SmartContract ;
    rdfs:label "Chaincode" ;
    rdfs:comment """
    Smart contract implementation for Hyperledger Fabric
    defining business logic and state transitions.
    """ .

:CorDApp a owl:Class ;
    rdfs:subClassOf :SmartContract ;
    rdfs:label "CorDApp" ;
    rdfs:comment """
    Distributed application running on R3 Corda
    platform with flow-based execution model.
    """ .

:SmartContractRuntime a owl:Class ;
    rdfs:label "Smart Contract Runtime" ;
    rdfs:comment """
    Execution environment for smart contracts providing
    sandboxed and deterministic computation.
    """ .

:EthereumVirtualMachine a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :SmartContractRuntime ;
    rdfs:label "Ethereum Virtual Machine" ;
    rdfs:comment """
    Runtime environment for Ethereum smart contracts
    with deterministic execution and gas metering.
    """ .

#################################################################
#    Layer 2 Solution Classes
#################################################################

:Layer2Solution a owl:Class ;
    rdfs:label "Layer 2 Solution" ;
    rdfs:comment """
    Scaling solution built on top of blockchain
    to increase throughput and reduce transaction costs.
    """ .

:StateChannel a owl:Class ;
    rdfs:subClassOf :Layer2Solution ;
    rdfs:label "State Channel" ;
    rdfs:comment """
    Off-chain scaling solution enabling instant
    transactions between participating parties.
    """ .

:LightningNetwork a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :StateChannel ;
    rdfs:label "Lightning Network" ;
    rdfs:comment """
    Payment channel network for Bitcoin enabling
    instant micropayments with low fees.
    """ .

:Sidechain a owl:Class ;
    rdfs:subClassOf :Layer2Solution ;
    rdfs:label "Sidechain" ;
    rdfs:comment """
    Independent blockchain connected to main chain
    through two-way pegging mechanism.
    """ .

:OptimisticRollup a owl:Class ;
    rdfs:subClassOf :Layer2Solution ;
    rdfs:label "Optimistic Rollup" ;
    rdfs:comment """
    Layer 2 solution assuming transactions are valid
    by default with fraud proofs for disputes.
    """ .

:ZKRollup a owl:Class ;
    rdfs:subClassOf :Layer2Solution ;
    rdfs:label "ZK-Rollup" ;
    rdfs:comment """
    Layer 2 solution using zero-knowledge proofs
    to validate transaction batches.
    """ .

:Polygon a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :Sidechain ;
    rdfs:label "Polygon" ;
    rdfs:comment """
    Multi-chain scaling solution for Ethereum
    with Plasma and PoS bridge implementations.
    """ .

:Arbitrum a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :OptimisticRollup ;
    rdfs:label "Arbitrum" ;
    rdfs:comment """
    Optimistic rollup solution for Ethereum
    with fraud proofs and EVM compatibility.
    """ .

#################################################################
#    Cross-Chain Interoperability Classes
#################################################################

:CrossChainBridge a owl:Class ;
    rdfs:label "Cross-Chain Bridge" ;
    rdfs:comment """
    Protocol enabling asset and data transfer
    between different blockchain networks.
    """ .

:AtomicSwap a owl:Class ;
    rdfs:subClassOf :CrossChainBridge ;
    rdfs:label "Atomic Swap" ;
    rdfs:comment """
    Peer-to-peer exchange of cryptocurrencies
    across different blockchains without intermediaries.
    """ .

:HashedTimelockContract a owl:Class ;
    rdfs:subClassOf :AtomicSwap ;
    rdfs:label "Hashed Timelock Contract" ;
    rdfs:comment """
    Smart contract enabling conditional payments
    with cryptographic hash locks and time limits.
    """ .

:RelayChain a owl:Class ;
    rdfs:label "Relay Chain" ;
    rdfs:comment """
    Central chain coordinating communication
    between multiple parallel blockchains.
    """ .

:Parachain a owl:Class ;
    rdfs:label "Parachain" ;
    rdfs:comment """
    Specialized blockchain connected to relay chain
    for shared security and interoperability.
    """ .

:InterBlockchainCommunication a owl:Class ;
    rdfs:label "Inter-Blockchain Communication" ;
    rdfs:comment """
    Protocol enabling secure and reliable communication
    between heterogeneous blockchain networks.
    """ .

:OracleNetwork a owl:Class ;
    rdfs:label "Oracle Network" ;
    rdfs:comment """
    Decentralized network providing external data
    to blockchain smart contracts.
    """ .

:ChainlinkOracle a owl:Class, owl:NamedIndividual ;
    rdfs:subClassOf :OracleNetwork ;
    rdfs:label "Chainlink Oracle" ;
    rdfs:comment """
    Decentralized oracle network providing
    real-world data to blockchain applications.
    """ .

#################################################################
#    DeFi and Financial Integration Classes
#################################################################

:DecentralizedFinance a owl:Class ;
    rdfs:label "Decentralized Finance" ;
    rdfs:comment """
    Financial system built on blockchain technology
    without traditional intermediaries.
    """ .

:DecentralizedExchange a owl:Class ;
    rdfs:subClassOf :DecentralizedFinance ;
    rdfs:label "Decentralized Exchange" ;
    rdfs:comment """
    Cryptocurrency exchange operating through
    smart contracts without central authority.
    """ .

:AutomatedMarketMaker a owl:Class ;
    rdfs:subClassOf :DecentralizedExchange ;
    rdfs:label "Automated Market Maker" ;
    rdfs:comment """
    Algorithm automatically setting asset prices
    based on supply and demand in liquidity pools.
    """ .

:LendingProtocol a owl:Class ;
    rdfs:subClassOf :DecentralizedFinance ;
    rdfs:label "Lending Protocol" ;
    rdfs:comment """
    Smart contract system enabling decentralized
    borrowing and lending of digital assets.
    """ .

:YieldFarming a owl:Class ;
    rdfs:subClassOf :DecentralizedFinance ;
    rdfs:label "Yield Farming" ;
    rdfs:comment """
    Practice of earning rewards by providing
    liquidity to decentralized finance protocols.
    """ .

:Stablecoin a owl:Class ;
    rdfs:label "Stablecoin" ;
    rdfs:comment """
    Cryptocurrency designed to maintain stable value
    relative to reference asset or currency.
    """ .

:CentralBankDigitalCurrency a owl:Class ;
    rdfs:subClassOf :Stablecoin ;
    rdfs:label "Central Bank Digital Currency" ;
    rdfs:comment """
    Digital currency issued and controlled by
    central bank as legal tender.
    """ .

:AlgorithmicStablecoin a owl:Class ;
    rdfs:subClassOf :Stablecoin ;
    rdfs:label "Algorithmic Stablecoin" ;
    rdfs:comment """
    Stablecoin maintaining price stability through
    algorithmic supply adjustments.
    """ .

#################################################################
#    Blockchain Data Structure Classes
#################################################################

:Block a owl:Class ;
    rdfs:label "Block" ;
    rdfs:comment """
    Data structure containing batch of validated
    transactions linked to previous block.
    """ .

:BlockHeader a owl:Class ;
    rdfs:label "Block Header" ;
    rdfs:comment """
    Metadata section of block containing
    hash references and consensus information.
    """ .

:Transaction a owl:Class ;
    rdfs:label "Transaction" ;
    rdfs:comment """
    Atomic unit of blockchain state change
    cryptographically signed by sender.
    """ .

:TransactionPool a owl:Class ;
    rdfs:label "Transaction Pool" ;
    rdfs:comment """
    Collection of pending transactions waiting
    to be included in next block.
    """ .

:MerkleTree a owl:Class ;
    rdfs:label "Merkle Tree" ;
    rdfs:comment """
    Binary tree of hashes providing efficient
    and tamper-evident transaction summarization.
    """ .

:DigitalSignature a owl:Class ;
    rdfs:label "Digital Signature" ;
    rdfs:comment """
    Cryptographic proof of transaction authenticity
    and sender authorization.
    """ .

:WalletAddress a owl:Class ;
    rdfs:label "Wallet Address" ;
    rdfs:comment """
    Cryptographic identifier for blockchain account
    derived from public key.
    """ .

:PrivateKey a owl:Class ;
    rdfs:label "Private Key" ;
    rdfs:comment """
    Secret cryptographic key used to sign
    transactions and control wallet funds.
    """ .

#################################################################
#    Blockchain Properties
#################################################################

:hasConsensus a owl:ObjectProperty ;
    rdfs:label "has consensus" ;
    rdfs:domain :BlockchainNetwork ;
    rdfs:range :ConsensusMechanism ;
    rdfs:comment "Consensus mechanism used by blockchain network." .

:hasBlockTime a owl:DatatypeProperty ;
    rdfs:label "has block time" ;
    rdfs:domain :BlockchainNetwork ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Average time between blocks in seconds." .

:hasThroughput a owl:DatatypeProperty ;
    rdfs:label "has throughput" ;
    rdfs:domain :BlockchainNetwork ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Transaction throughput in transactions per second." .

:hasFinality a owl:DatatypeProperty ;
    rdfs:label "has finality" ;
    rdfs:domain :BlockchainNetwork ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Time to transaction finality in seconds." .

:hasGasLimit a owl:DatatypeProperty ;
    rdfs:label "has gas limit" ;
    rdfs:domain :Block ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Maximum computational units per block." .

:hasEnergyConsumption a owl:DatatypeProperty ;
    rdfs:label "has energy consumption" ;
    rdfs:domain :ConsensusMechanism ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Energy consumption in kilowatt-hours per transaction." .

:hasNetworkHashRate a owl:DatatypeProperty ;
    rdfs:label "has network hash rate" ;
    rdfs:domain :ProofOfWork ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Total network computational power in hashes per second." .

:hasValidatorCount a owl:DatatypeProperty ;
    rdfs:label "has validator count" ;
    rdfs:domain :ProofOfStake ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Number of active validators in network." .

:hasStakingRequirement a owl:DatatypeProperty ;
    rdfs:label "has staking requirement" ;
    rdfs:domain :ProofOfStake ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Minimum stake required to become validator." .

#################################################################
#    Smart Contract Properties
#################################################################

:deployedOnBlockchain a owl:ObjectProperty ;
    rdfs:label "deployed on blockchain" ;
    rdfs:domain :SmartContract ;
    rdfs:range :BlockchainNetwork ;
    rdfs:comment "Blockchain network where contract is deployed." .

:executedByRuntime a owl:ObjectProperty ;
    rdfs:label "executed by runtime" ;
    rdfs:domain :SmartContract ;
    rdfs:range :SmartContractRuntime ;
    rdfs:comment "Runtime environment executing the contract." .

:hasContractAddress a owl:DatatypeProperty ;
    rdfs:label "has contract address" ;
    rdfs:domain :SmartContract ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique blockchain address of deployed contract." .

:hasGasUsage a owl:DatatypeProperty ;
    rdfs:label "has gas usage" ;
    rdfs:domain :SmartContract ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Computational units consumed by contract execution." .

:hasExecutionTime a owl:DatatypeProperty ;
    rdfs:label "has execution time" ;
    rdfs:domain :SmartContract ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Contract execution time in milliseconds." .

:implementsInterface a owl:ObjectProperty ;
    rdfs:label "implements interface" ;
    rdfs:domain :SmartContract ;
    rdfs:comment "Contract interface implemented." .

:callsContract a owl:ObjectProperty ;
    rdfs:label "calls contract" ;
    rdfs:domain :SmartContract ;
    rdfs:range :SmartContract ;
    rdfs:comment "Contract called by this contract." .

#################################################################
#    Layer 2 Properties
#################################################################

:settlesOnLayer1 a owl:ObjectProperty ;
    rdfs:label "settles on layer 1" ;
    rdfs:domain :Layer2Solution ;
    rdfs:range :BlockchainNetwork ;
    rdfs:comment "Base layer blockchain for settlement." .

:hasScalingFactor a owl:DatatypeProperty ;
    rdfs:label "has scaling factor" ;
    rdfs:domain :Layer2Solution ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Throughput improvement factor over base layer." .

:hasWithdrawalDelay a owl:DatatypeProperty ;
    rdfs:label "has withdrawal delay" ;
    rdfs:domain :Layer2Solution ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Time delay for withdrawing to layer 1 in hours." .

:hasSecurityAssumption a owl:DatatypeProperty ;
    rdfs:label "has security assumption" ;
    rdfs:domain :Layer2Solution ;
    rdfs:range xsd:string ;
    rdfs:comment "Security model and trust assumptions." .

:batchesTransactions a owl:ObjectProperty ;
    rdfs:label "batches transactions" ;
    rdfs:domain :OptimisticRollup ;
    rdfs:comment "Transactions batched for layer 1 submission." .

:generatesFraudProof a owl:ObjectProperty ;
    rdfs:label "generates fraud proof" ;
    rdfs:domain :OptimisticRollup ;
    rdfs:comment "Fraud proof for invalid transaction batch." .

:generatesValidityProof a owl:ObjectProperty ;
    rdfs:label "generates validity proof" ;
    rdfs:domain :ZKRollup ;
    rdfs:comment "Zero-knowledge proof of transaction validity." .

#################################################################
#    Cross-Chain Properties
#################################################################

:bridgesBetween a owl:ObjectProperty ;
    rdfs:label "bridges between" ;
    rdfs:domain :CrossChainBridge ;
    rdfs:range :BlockchainNetwork ;
    rdfs:comment "Blockchain networks connected by bridge." .

:transfersAsset a owl:ObjectProperty ;
    rdfs:label "transfers asset" ;
    rdfs:domain :CrossChainBridge ;
    rdfs:comment "Asset transferred across chains." .

:hasLockTime a owl:DatatypeProperty ;
    rdfs:label "has lock time" ;
    rdfs:domain :HashedTimelockContract ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Time lock duration in hours." .

:hasSecretHash a owl:DatatypeProperty ;
    rdfs:label "has secret hash" ;
    rdfs:domain :HashedTimelockContract ;
    rdfs:range xsd:string ;
    rdfs:comment "Cryptographic hash of secret." .

:coordinatesParachains a owl:ObjectProperty ;
    rdfs:label "coordinates parachains" ;
    rdfs:domain :RelayChain ;
    rdfs:range :Parachain ;
    rdfs:comment "Parachain coordinated by relay chain." .

:providesSharedSecurity a owl:ObjectProperty ;
    rdfs:label "provides shared security" ;
    rdfs:domain :RelayChain ;
    rdfs:range :Parachain ;
    rdfs:comment "Parachain receiving shared security." .

:routesMessage a owl:ObjectProperty ;
    rdfs:label "routes message" ;
    rdfs:domain :InterBlockchainCommunication ;
    rdfs:comment "Cross-chain message being routed." .

#################################################################
#    DeFi Properties
#################################################################

:providesLiquidity a owl:ObjectProperty ;
    rdfs:label "provides liquidity" ;
    rdfs:domain :AutomatedMarketMaker ;
    rdfs:comment "Asset liquidity provided to market." .

:hasLiquidityPool a owl:ObjectProperty ;
    rdfs:label "has liquidity pool" ;
    rdfs:domain :DecentralizedExchange ;
    rdfs:comment "Liquidity pool managed by exchange." .

:hasAnnualPercentageYield a owl:DatatypeProperty ;
    rdfs:label "has annual percentage yield" ;
    rdfs:domain :YieldFarming ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Annual percentage yield offered." .

:hasCollateralRatio a owl:DatatypeProperty ;
    rdfs:label "has collateral ratio" ;
    rdfs:domain :LendingProtocol ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Required collateral ratio for borrowing." .

:pegsToAsset a owl:ObjectProperty ;
    rdfs:label "pegs to asset" ;
    rdfs:domain :Stablecoin ;
    rdfs:comment "Reference asset for price stability." .

:issuedByCentralBank a owl:ObjectProperty ;
    rdfs:label "issued by central bank" ;
    rdfs:domain :CentralBankDigitalCurrency ;
    rdfs:comment "Central bank issuing the CBDC." .

:maintainsPegThrough a owl:ObjectProperty ;
    rdfs:label "maintains peg through" ;
    rdfs:domain :AlgorithmicStablecoin ;
    rdfs:comment "Mechanism maintaining price stability." .

#################################################################
#    Data Structure Properties
#################################################################

:containsTransaction a owl:ObjectProperty ;
    rdfs:label "contains transaction" ;
    rdfs:domain :Block ;
    rdfs:range :Transaction ;
    rdfs:comment "Transaction included in block." .

:hasPreviousBlockHash a owl:DatatypeProperty ;
    rdfs:label "has previous block hash" ;
    rdfs:domain :BlockHeader ;
    rdfs:range xsd:string ;
    rdfs:comment "Hash of previous block in chain." .

:hasBlockHeight a owl:DatatypeProperty ;
    rdfs:label "has block height" ;
    rdfs:domain :Block ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Position of block in blockchain." .

:hasTimestamp a owl:DatatypeProperty ;
    rdfs:label "has timestamp" ;
    rdfs:domain :Block ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Block creation timestamp." .

:hasTransactionHash a owl:DatatypeProperty ;
    rdfs:label "has transaction hash" ;
    rdfs:domain :Transaction ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique cryptographic hash of transaction." .

:hasTransactionFee a owl:DatatypeProperty ;
    rdfs:label "has transaction fee" ;
    rdfs:domain :Transaction ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Fee paid for transaction processing." .

:signedWithPrivateKey a owl:ObjectProperty ;
    rdfs:label "signed with private key" ;
    rdfs:domain :Transaction ;
    rdfs:range :PrivateKey ;
    rdfs:comment "Private key used to sign transaction." .

:hasWalletBalance a owl:DatatypeProperty ;
    rdfs:label "has wallet balance" ;
    rdfs:domain :WalletAddress ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Current balance of wallet address." .

:derivedFromPublicKey a owl:ObjectProperty ;
    rdfs:label "derived from public key" ;
    rdfs:domain :WalletAddress ;
    rdfs:comment "Public key from which address is derived." .

#################################################################
#    ByteStar Integration Properties
#################################################################

:integratesWithByteStarFabric a owl:ObjectProperty ;
    rdfs:label "integrates with ByteStar fabric" ;
    rdfs:comment "Integration point with ByteStar components." .

:usesQuantumResistantCrypto a owl:ObjectProperty ;
    rdfs:label "uses quantum-resistant crypto" ;
    rdfs:range pqc:PostQuantumAlgorithm ;
    rdfs:comment "Post-quantum cryptographic algorithm used." .

:maintainsDeterministicExecution a owl:DatatypeProperty ;
    rdfs:label "maintains deterministic execution" ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating deterministic execution capability." .

:respectsTickDoctrine a owl:DatatypeProperty ;
    rdfs:label "respects tick doctrine" ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating 8-tick doctrine compliance." .

:supportsEnterpriseCompliance a owl:ObjectProperty ;
    rdfs:label "supports enterprise compliance" ;
    rdfs:range ei:ComplianceFramework ;
    rdfs:comment "Compliance framework supported." .

:enablesAutonomousGovernance a owl:ObjectProperty ;
    rdfs:label "enables autonomous governance" ;
    rdfs:range ag:AutonomousGovernanceSystem ;
    rdfs:comment "Autonomous governance capability enabled." .

#################################################################
#    Mathematical Constraints and Axioms
#################################################################

# Block Time Positive Constraint
:BlockchainNetwork rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasBlockTime ;
    owl:minExclusive 0.0
] .

# Throughput Positive Constraint
:BlockchainNetwork rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasThroughput ;
    owl:minInclusive 1
] .

# Energy Consumption Non-Negative
:ConsensusMechanism rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasEnergyConsumption ;
    owl:minInclusive 0.0
] .

# Gas Limit Positive Constraint
:Block rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasGasLimit ;
    owl:minInclusive 1
] .

# Validator Count Minimum
:ProofOfStake rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasValidatorCount ;
    owl:minInclusive 1
] .

# Block Height Sequential
:Block rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasBlockHeight ;
    owl:minInclusive 0
] .

# Transaction Fee Non-Negative
:Transaction rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasTransactionFee ;
    owl:minInclusive 0.0
] .

# Scaling Factor Greater Than 1
:Layer2Solution rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasScalingFactor ;
    owl:minExclusive 1.0
] .

# APY Non-Negative
:YieldFarming rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasAnnualPercentageYield ;
    owl:minInclusive 0.0
] .

# Collateral Ratio Greater Than 1
:LendingProtocol rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :hasCollateralRatio ;
    owl:minExclusive 1.0
] .

#################################################################
#    SHACL Validation Shapes
#################################################################

:BlockchainNetworkShape a shacl:NodeShape ;
    shacl:targetClass :BlockchainNetwork ;
    shacl:property [
        shacl:path :hasConsensus ;
        shacl:class :ConsensusMechanism ;
        shacl:minCount 1 ;
        shacl:maxCount 1 ;
        shacl:message "Blockchain network must have exactly one consensus mechanism"
    ] ;
    shacl:property [
        shacl:path :hasThroughput ;
        shacl:datatype xsd:positiveInteger ;
        shacl:minInclusive 1 ;
        shacl:message "Throughput must be at least 1 TPS"
    ] .

:SmartContractShape a shacl:NodeShape ;
    shacl:targetClass :SmartContract ;
    shacl:property [
        shacl:path :deployedOnBlockchain ;
        shacl:class :BlockchainNetwork ;
        shacl:minCount 1 ;
        shacl:message "Smart contract must be deployed on a blockchain"
    ] ;
    shacl:property [
        shacl:path :hasContractAddress ;
        shacl:datatype xsd:string ;
        shacl:minLength 1 ;
        shacl:message "Contract must have valid address"
    ] .

:BlockShape a shacl:NodeShape ;
    shacl:targetClass :Block ;
    shacl:property [
        shacl:path :hasBlockHeight ;
        shacl:datatype xsd:nonNegativeInteger ;
        shacl:minInclusive 0 ;
        shacl:message "Block height must be non-negative"
    ] ;
    shacl:property [
        shacl:path :containsTransaction ;
        shacl:class :Transaction ;
        shacl:minCount 1 ;
        shacl:message "Block must contain at least one transaction"
    ] .

:TransactionShape a shacl:NodeShape ;
    shacl:targetClass :Transaction ;
    shacl:property [
        shacl:path :hasTransactionHash ;
        shacl:datatype xsd:string ;
        shacl:pattern "^0x[a-fA-F0-9]{64}$" ;
        shacl:message "Transaction hash must be valid hexadecimal"
    ] ;
    shacl:property [
        shacl:path :hasTransactionFee ;
        shacl:datatype xsd:decimal ;
        shacl:minInclusive 0.0 ;
        shacl:message "Transaction fee must be non-negative"
    ] .

:Layer2SolutionShape a shacl:NodeShape ;
    shacl:targetClass :Layer2Solution ;
    shacl:property [
        shacl:path :settlesOnLayer1 ;
        shacl:class :BlockchainNetwork ;
        shacl:minCount 1 ;
        shacl:maxCount 1 ;
        shacl:message "Layer 2 solution must settle on exactly one layer 1"
    ] ;
    shacl:property [
        shacl:path :hasScalingFactor ;
        shacl:datatype xsd:decimal ;
        shacl:minExclusive 1.0 ;
        shacl:message "Scaling factor must be greater than 1.0"
    ] .

#################################################################
#    Individual Instances
#################################################################

# Quantum-Resistant Blockchain
:ByteStarQuantumChain a :QuantumResistantBlockchain ;
    rdfs:label "ByteStar Quantum Chain" ;
    rdfs:comment "ByteStar's post-quantum resistant blockchain." ;
    :hasConsensus :ByteStarConsensus ;
    :hasBlockTime 2.0 ;
    :hasThroughput 100000 ;
    :hasFinality 4.0 ;
    :integratesWithByteStarFabric "Primary fabric integration" ;
    :usesQuantumResistantCrypto pqc:Dilithium3 ;
    :maintainsDeterministicExecution true ;
    :respectsTickDoctrine true .

# Consensus Mechanism
:ByteStarConsensus a :ProofOfStake ;
    rdfs:label "ByteStar Consensus" ;
    rdfs:comment "Custom proof-of-stake consensus for ByteStar chain." ;
    :hasValidatorCount 100 ;
    :hasStakingRequirement 1000000.0 ;
    :hasEnergyConsumption 0.001 .

# Public Blockchain Integrations
:EthereumIntegration a :Ethereum ;
    rdfs:label "Ethereum Integration" ;
    rdfs:comment "Integration with Ethereum mainnet." ;
    :hasConsensus :EthereumPoS ;
    :hasBlockTime 12.0 ;
    :hasThroughput 15 ;
    :hasFinality 384.0 ;
    :integratesWithByteStarFabric "Ethereum bridge integration" .

:SolanaIntegration a :Solana ;
    rdfs:label "Solana Integration" ;
    rdfs:comment "Integration with Solana blockchain." ;
    :hasConsensus :SolanaPoH ;
    :hasBlockTime 0.4 ;
    :hasThroughput 65000 ;
    :hasFinality 2.0 ;
    :integratesWithByteStarFabric "Solana bridge integration" .

# Consensus Mechanisms for Public Chains
:EthereumPoS a :ProofOfStake ;
    rdfs:label "Ethereum Proof of Stake" ;
    rdfs:comment "Ethereum's proof-of-stake consensus mechanism." ;
    :hasValidatorCount 500000 ;
    :hasStakingRequirement 32.0 ;
    :hasEnergyConsumption 0.01 .

:SolanaPoH a :ProofOfHistory ;
    rdfs:label "Solana Proof of History" ;
    rdfs:comment "Solana's proof-of-history consensus mechanism." ;
    :hasValidatorCount 1500 ;
    :hasEnergyConsumption 0.05 .

# Smart Contracts
:ByteStarDEXContract a :SolidityContract ;
    rdfs:label "ByteStar DEX Contract" ;
    rdfs:comment "Decentralized exchange smart contract." ;
    :deployedOnBlockchain :EthereumIntegration ;
    :executedByRuntime :EthereumVirtualMachine ;
    :hasContractAddress "0x1234567890abcdef1234567890abcdef12345678" ;
    :hasGasUsage 500000 ;
    :hasExecutionTime 200.0 ;
    :maintainsDeterministicExecution true .

:ByteStarGovernanceContract a :WASMContract ;
    rdfs:label "ByteStar Governance Contract" ;
    rdfs:comment "Autonomous governance smart contract." ;
    :deployedOnBlockchain :ByteStarQuantumChain ;
    :hasContractAddress "0xabcdef1234567890abcdef1234567890abcdef12" ;
    :hasGasUsage 300000 ;
    :hasExecutionTime 50.0 ;
    :enablesAutonomousGovernance ag:ByteStarGovernanceSystem .

# Layer 2 Solutions
:ByteStarRollup a :ZKRollup ;
    rdfs:label "ByteStar ZK-Rollup" ;
    rdfs:comment "Zero-knowledge rollup for ByteStar scaling." ;
    :settlesOnLayer1 :EthereumIntegration ;
    :hasScalingFactor 100.0 ;
    :hasWithdrawalDelay 1.0 ;
    :hasSecurityAssumption "ZK proof validity" ;
    :generatesValidityProof "ZK-SNARK proofs for transaction batches" ;
    :respectsTickDoctrine true .

:ByteStarStateChannel a :StateChannel ;
    rdfs:label "ByteStar State Channel" ;
    rdfs:comment "State channel for instant ByteStar transactions." ;
    :settlesOnLayer1 :ByteStarQuantumChain ;
    :hasScalingFactor 1000.0 ;
    :hasWithdrawalDelay 0.1 ;
    :hasSecurityAssumption "Honest majority participants" .

# Cross-Chain Bridges
:ByteStarEthereumBridge a :CrossChainBridge ;
    rdfs:label "ByteStar-Ethereum Bridge" ;
    rdfs:comment "Bridge connecting ByteStar and Ethereum chains." ;
    :bridgesBetween :ByteStarQuantumChain , :EthereumIntegration ;
    :transfersAsset "BST tokens and ETH" ;
    :usesQuantumResistantCrypto pqc:Kyber1024 .

:ByteStarAtomicSwap a :HashedTimelockContract ;
    rdfs:label "ByteStar Atomic Swap" ;
    rdfs:comment "Atomic swap implementation for cross-chain trading." ;
    :hasLockTime 24.0 ;
    :hasSecretHash "0x9876543210fedcba9876543210fedcba98765432" ;
    :bridgesBetween :ByteStarQuantumChain , :Bitcoin .

# DeFi Protocols
:ByteStarDEX a :AutomatedMarketMaker ;
    rdfs:label "ByteStar DEX" ;
    rdfs:comment "Decentralized exchange with automated market making." ;
    :hasLiquidityPool "BST-USDC liquidity pool" ;
    :providesLiquidity "BST and USDC tokens" ;
    :maintainsDeterministicExecution true .

:ByteStarLending a :LendingProtocol ;
