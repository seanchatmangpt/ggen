@prefix ba: <http://bytestar.org/ontology/> .
@prefix bam: <http://bytestar.org/ontology/marketplace/> .
@prefix bav: <http://bytestar.org/ontology/marketplace/vector/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix crypto: <http://www.w3.org/2000/10/swap/crypto#> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .

# =============================================================================
# ByteStar N-Dimensional Marketplace Vector Conservation Settlement Mathematics
# Version: 5.0.0 - Marketplace Phase
# =============================================================================

<http://bytestar.org/ontology/marketplace/vector-conservation> a owl:Ontology ;
    owl:versionIRI <http://bytestar.org/ontology/marketplace/vector-conservation/5.0.0> ;
    dct:title "ByteStar Vector Conservation Settlement Mathematics" ;
    dct:description "Mathematical framework for N-dimensional asset trading with vector conservation, settlement validation, and multi-dimensional value preservation" ;
    dct:creator "ByteStar Architecture Team" ;
    dct:created "2025-01-23"^^xsd:date ;
    dct:modified "2025-01-23"^^xsd:date ;
    owl:imports <http://bytestar.org/ontology/core>,
                <http://bytestar.org/ontology/marketplace/core>,
                <http://bytestar.org/ontology/audit-system>,
                <http://bytestar.org/ontology/compliance-framework> .

# =============================================================================
# Core Vector Mathematics Classes
# =============================================================================

bav:VectorSpace a owl:Class ;
    rdfs:label "Vector Space" ;
    rdfs:comment "N-dimensional vector space for marketplace asset representation" ;
    rdfs:subClassOf ba:MathematicalStructure .

bav:AssetVector a owl:Class ;
    rdfs:label "Asset Vector" ;
    rdfs:comment "N-dimensional vector representing marketplace asset with multi-dimensional attributes" ;
    rdfs:subClassOf bav:VectorSpace .

bav:SettlementVector a owl:Class ;
    rdfs:label "Settlement Vector" ;
    rdfs:comment "Vector representation of settlement state in N-dimensional space" ;
    rdfs:subClassOf bav:AssetVector .

bav:ConservationInvariant a owl:Class ;
    rdfs:label "Conservation Invariant" ;
    rdfs:comment "Mathematical invariant ensuring conservation laws in vector transformations" ;
    rdfs:subClassOf ba:MathematicalInvariant .

bav:VectorTransformation a owl:Class ;
    rdfs:label "Vector Transformation" ;
    rdfs:comment "Linear transformation preserving conservation invariants" ;
    rdfs:subClassOf ba:MathematicalTransformation .

bav:SettlementMatrix a owl:Class ;
    rdfs:label "Settlement Matrix" ;
    rdfs:comment "Matrix representation of settlement operations in vector space" ;
    rdfs:subClassOf ba:Matrix .

bav:ConservationLaw a owl:Class ;
    rdfs:label "Conservation Law" ;
    rdfs:comment "Fundamental conservation law governing asset transformations" ;
    rdfs:subClassOf ba:PhysicalLaw .

# =============================================================================
# Settlement Mathematics Core Classes
# =============================================================================

bav:SettlementEquation a owl:Class ;
    rdfs:label "Settlement Equation" ;
    rdfs:comment "Mathematical equation governing settlement calculations" ;
    rdfs:subClassOf ba:MathematicalEquation .

bav:BalanceConstraint a owl:Class ;
    rdfs:label "Balance Constraint" ;
    rdfs:comment "Constraint ensuring balance conservation across transformations" ;
    rdfs:subClassOf ba:Constraint .

bav:ValuePreservation a owl:Class ;
    rdfs:label "Value Preservation" ;
    rdfs:comment "Mechanism ensuring total value preservation in transformations" ;
    rdfs:subClassOf bav:ConservationLaw .

bav:DimensionalConsistency a owl:Class ;
    rdfs:label "Dimensional Consistency" ;
    rdfs:comment "Ensures dimensional consistency across vector operations" ;
    rdfs:subClassOf ba:ConsistencyConstraint .

bav:SettlementProof a owl:Class ;
    rdfs:label "Settlement Proof" ;
    rdfs:comment "Mathematical proof of settlement correctness" ;
    rdfs:subClassOf ba:MathematicalProof .

bav:VectorNorm a owl:Class ;
    rdfs:label "Vector Norm" ;
    rdfs:comment "Norm function for measuring vector magnitudes" ;
    rdfs:subClassOf ba:MathematicalFunction .

bav:InnerProduct a owl:Class ;
    rdfs:label "Inner Product" ;
    rdfs:comment "Inner product operation for vector space computations" ;
    rdfs:subClassOf ba:MathematicalOperation .

# =============================================================================
# Multi-dimensional Trading Structures
# =============================================================================

bav:TradingDimension a owl:Class ;
    rdfs:label "Trading Dimension" ;
    rdfs:comment "Individual dimension in N-dimensional trading space" ;
    rdfs:subClassOf ba:Dimension .

bav:AssetDimension a owl:Class ;
    rdfs:label "Asset Dimension" ;
    rdfs:comment "Dimension representing asset type, value, or property" ;
    rdfs:subClassOf bav:TradingDimension .

bav:TimeDimension a owl:Class ;
    rdfs:label "Time Dimension" ;
    rdfs:comment "Temporal dimension for time-dependent asset values" ;
    rdfs:subClassOf bav:TradingDimension .

bav:RiskDimension a owl:Class ;
    rdfs:label "Risk Dimension" ;
    rdfs:comment "Risk dimension for risk-adjusted asset valuations" ;
    rdfs:subClassOf bav:TradingDimension .

bav:ComplianceDimension a owl:Class ;
    rdfs:label "Compliance Dimension" ;
    rdfs:comment "Dimension tracking regulatory compliance requirements" ;
    rdfs:subClassOf bav:TradingDimension .

bav:LiquidityDimension a owl:Class ;
    rdfs:label "Liquidity Dimension" ;
    rdfs:comment "Dimension representing asset liquidity characteristics" ;
    rdfs:subClassOf bav:TradingDimension .

bav:GeographicDimension a owl:Class ;
    rdfs:label "Geographic Dimension" ;
    rdfs:comment "Spatial dimension for geographic asset distribution" ;
    rdfs:subClassOf bav:TradingDimension .

bav:QualityDimension a owl:Class ;
    rdfs:label "Quality Dimension" ;
    rdfs:comment "Dimension representing asset quality metrics" ;
    rdfs:subClassOf bav:TradingDimension .

# =============================================================================
# Settlement Validation and Verification
# =============================================================================

bav:SettlementValidator a owl:Class ;
    rdfs:label "Settlement Validator" ;
    rdfs:comment "Mathematical validator for settlement correctness" ;
    rdfs:subClassOf ba:Validator .

bav:ConservationValidator a owl:Class ;
    rdfs:label "Conservation Validator" ;
    rdfs:comment "Validator ensuring conservation law compliance" ;
    rdfs:subClassOf bav:SettlementValidator .

bav:DimensionalValidator a owl:Class ;
    rdfs:label "Dimensional Validator" ;
    rdfs:comment "Validator for dimensional consistency checks" ;
    rdfs:subClassOf bav:SettlementValidator .

bav:BalanceValidator a owl:Class ;
    rdfs:label "Balance Validator" ;
    rdfs:comment "Validator ensuring balance equation correctness" ;
    rdfs:subClassOf bav:SettlementValidator .

bav:MathematicalProofEngine a owl:Class ;
    rdfs:label "Mathematical Proof Engine" ;
    rdfs:comment "Engine for generating and validating mathematical proofs" ;
    rdfs:subClassOf ba:ProofEngine .

bav:SettlementVerifier a owl:Class ;
    rdfs:label "Settlement Verifier" ;
    rdfs:comment "Cryptographic verifier for settlement authenticity" ;
    rdfs:subClassOf ba:CryptographicVerifier .

# =============================================================================
# Properties for Vector Mathematics
# =============================================================================

# Vector Properties
bav:vectorDimension a owl:DatatypeProperty ;
    rdfs:label "vector dimension" ;
    rdfs:domain bav:AssetVector ;
    rdfs:range xsd:positiveInteger ;
    rdfs:comment "Number of dimensions in the asset vector" .

bav:vectorComponent a owl:DatatypeProperty ;
    rdfs:label "vector component" ;
    rdfs:domain bav:AssetVector ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Individual component value in the vector" .

bav:vectorMagnitude a owl:DatatypeProperty ;
    rdfs:label "vector magnitude" ;
    rdfs:domain bav:AssetVector ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Euclidean magnitude of the asset vector" .

bav:unitVector a owl:ObjectProperty ;
    rdfs:label "unit vector" ;
    rdfs:domain bav:AssetVector ;
    rdfs:range bav:AssetVector ;
    rdfs:comment "Corresponding unit vector for direction" .

# Conservation Properties
bav:conservedQuantity a owl:DatatypeProperty ;
    rdfs:label "conserved quantity" ;
    rdfs:domain bav:ConservationInvariant ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Numerical value of the conserved quantity" .

bav:conservationPrecision a owl:DatatypeProperty ;
    rdfs:label "conservation precision" ;
    rdfs:domain bav:ConservationLaw ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Required precision for conservation validation (epsilon)" .

bav:toleranceLevel a owl:DatatypeProperty ;
    rdfs:label "tolerance level" ;
    rdfs:domain bav:BalanceConstraint ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Acceptable tolerance level for balance calculations" .

# Settlement Properties
bav:settlementAmount a owl:DatatypeProperty ;
    rdfs:label "settlement amount" ;
    rdfs:domain bav:SettlementVector ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Total settlement amount in base currency" .

bav:settlementTimestamp a owl:DatatypeProperty ;
    rdfs:label "settlement timestamp" ;
    rdfs:domain bav:SettlementVector ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Timestamp of settlement execution" .

bav:settlementStatus a owl:DatatypeProperty ;
    rdfs:label "settlement status" ;
    rdfs:domain bav:SettlementVector ;
    rdfs:range xsd:string ;
    rdfs:comment "Current status of settlement (pending, validated, completed, failed)" .

bav:proofHash a owl:DatatypeProperty ;
    rdfs:label "proof hash" ;
    rdfs:domain bav:SettlementProof ;
    rdfs:range xsd:string ;
    rdfs:comment "Cryptographic hash of the mathematical proof" .

# Dimensional Properties
bav:dimensionName a owl:DatatypeProperty ;
    rdfs:label "dimension name" ;
    rdfs:domain bav:TradingDimension ;
    rdfs:range xsd:string ;
    rdfs:comment "Human-readable name of the trading dimension" .

bav:dimensionWeight a owl:DatatypeProperty ;
    rdfs:label "dimension weight" ;
    rdfs:domain bav:TradingDimension ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Relative weight of this dimension in calculations" .

bav:dimensionScale a owl:DatatypeProperty ;
    rdfs:label "dimension scale" ;
    rdfs:domain bav:TradingDimension ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Scaling factor for dimension normalization" .

bav:dimensionUnit a owl:DatatypeProperty ;
    rdfs:label "dimension unit" ;
    rdfs:domain bav:TradingDimension ;
    rdfs:range xsd:string ;
    rdfs:comment "Unit of measurement for the dimension" .

# Validation Properties
bav:validationThreshold a owl:DatatypeProperty ;
    rdfs:label "validation threshold" ;
    rdfs:domain bav:SettlementValidator ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Threshold value for validation acceptance" .

bav:validationResult a owl:DatatypeProperty ;
    rdfs:label "validation result" ;
    rdfs:domain bav:SettlementValidator ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean result of validation check" .

bav:errorTolerance a owl:DatatypeProperty ;
    rdfs:label "error tolerance" ;
    rdfs:domain bav:SettlementValidator ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Maximum allowable error in calculations" .

# Performance Properties (Doctrine of 8)
bav:computationTicks a owl:DatatypeProperty ;
    rdfs:label "computation ticks" ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Number of computation ticks required (must be ≤8)" .

bav:settlementLatency a owl:DatatypeProperty ;
    rdfs:label "settlement latency" ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Settlement processing latency in milliseconds (must be ≤8ms)" .

# =============================================================================
# Object Properties for Vector Relationships
# =============================================================================

# Vector Relationships
bav:hasComponent a owl:ObjectProperty ;
    rdfs:label "has component" ;
    rdfs:domain bav:AssetVector ;
    rdfs:range bav:TradingDimension ;
    rdfs:comment "Vector has a component in the specified dimension" .

bav:appliesTransformation a owl:ObjectProperty ;
    rdfs:label "applies transformation" ;
    rdfs:domain bav:SettlementVector ;
    rdfs:range bav:VectorTransformation ;
    rdfs:comment "Settlement applies the specified vector transformation" .

bav:preservesInvariant a owl:ObjectProperty ;
    rdfs:label "preserves invariant" ;
    rdfs:domain bav:VectorTransformation ;
    rdfs:range bav:ConservationInvariant ;
    rdfs:comment "Transformation preserves the specified invariant" .

bav:satisfiesConstraint a owl:ObjectProperty ;
    rdfs:label "satisfies constraint" ;
    rdfs:domain bav:SettlementVector ;
    rdfs:range bav:BalanceConstraint ;
    rdfs:comment "Settlement satisfies the balance constraint" .

# Settlement Relationships
bav:validatedBy a owl:ObjectProperty ;
    rdfs:label "validated by" ;
    rdfs:domain bav:SettlementVector ;
    rdfs:range bav:SettlementValidator ;
    rdfs:comment "Settlement is validated by the specified validator" .

bav:provenBy a owl:ObjectProperty ;
    rdfs:label "proven by" ;
    rdfs:domain bav:SettlementVector ;
    rdfs:range bav:SettlementProof ;
    rdfs:comment "Settlement correctness is proven by the mathematical proof" .

bav:operatesInSpace a owl:ObjectProperty ;
    rdfs:label "operates in space" ;
    rdfs:domain bav:AssetVector ;
    rdfs:range bav:VectorSpace ;
    rdfs:comment "Vector operates within the specified vector space" .

# Dimensional Relationships
bav:spansDimensions a owl:ObjectProperty ;
    rdfs:label "spans dimensions" ;
    rdfs:domain bav:VectorSpace ;
    rdfs:range bav:TradingDimension ;
    rdfs:comment "Vector space spans the specified trading dimensions" .

bav:projectsOnto a owl:ObjectProperty ;
    rdfs:label "projects onto" ;
    rdfs:domain bav:AssetVector ;
    rdfs:range bav:TradingDimension ;
    rdfs:comment "Vector projects onto the specified dimension" .

# Conservation Relationships
bav:governedByLaw a owl:ObjectProperty ;
    rdfs:label "governed by law" ;
    rdfs:domain bav:SettlementVector ;
    rdfs:range bav:ConservationLaw ;
    rdfs:comment "Settlement is governed by the conservation law" .

bav:maintainsInvariant a owl:ObjectProperty ;
    rdfs:label "maintains invariant" ;
    rdfs:domain bav:ConservationLaw ;
    rdfs:range bav:ConservationInvariant ;
    rdfs:comment "Conservation law maintains the specified invariant" .

# =============================================================================
# Specific Conservation Law Instances
# =============================================================================

# Energy Conservation for Asset Values
bav:AssetValueConservation a bav:ValuePreservation ;
    rdfs:label "Asset Value Conservation" ;
    rdfs:comment "Conservation law ensuring total asset value is preserved" ;
    bav:conservedQuantity 1.0 ;
    bav:conservationPrecision 1e-12 ;
    bav:computationTicks 3 .

# Momentum Conservation for Trading
bav:TradingMomentumConservation a bav:ConservationLaw ;
    rdfs:label "Trading Momentum Conservation" ;
    rdfs:comment "Conservation of trading momentum in multi-dimensional space" ;
    bav:conservedQuantity 0.0 ;
    bav:conservationPrecision 1e-10 ;
    bav:computationTicks 4 .

# Mass Conservation for Asset Quantities
bav:AssetMassConservation a bav:ConservationLaw ;
    rdfs:label "Asset Mass Conservation" ;
    rdfs:comment "Conservation of asset mass/quantity in transformations" ;
    bav:conservedQuantity 1.0 ;
    bav:conservationPrecision 1e-15 ;
    bav:computationTicks 2 .

# Charge Conservation for Financial Obligations
bav:ObligationConservation a bav:ConservationLaw ;
    rdfs:label "Obligation Conservation" ;
    rdfs:comment "Conservation of financial obligations and liabilities" ;
    bav:conservedQuantity 0.0 ;
    bav:conservationPrecision 1e-9 ;
    bav:computationTicks 3 .

# =============================================================================
# Standard Trading Dimensions
# =============================================================================

# Primary Asset Dimensions
bav:ValueDimension a bav:AssetDimension ;
    rdfs:label "Value Dimension" ;
    rdfs:comment "Primary value dimension for asset pricing" ;
    bav:dimensionName "VALUE" ;
    bav:dimensionWeight 1.0 ;
    bav:dimensionScale 1.0 ;
    bav:dimensionUnit "USD" .

bav:QuantityDimension a bav:AssetDimension ;
    rdfs:label "Quantity Dimension" ;
    rdfs:comment "Asset quantity or volume dimension" ;
    bav:dimensionName "QUANTITY" ;
    bav:dimensionWeight 1.0 ;
    bav:dimensionScale 1.0 ;
    bav:dimensionUnit "UNITS" .

# Temporal Dimensions
bav:ExpirationTimeDimension a bav:TimeDimension ;
    rdfs:label "Expiration Time Dimension" ;
    rdfs:comment "Time dimension for asset expiration" ;
    bav:dimensionName "EXPIRATION_TIME" ;
    bav:dimensionWeight 0.8 ;
    bav:dimensionScale 1.0 ;
    bav:dimensionUnit "SECONDS" .

bav:SettlementTimeDimension a bav:TimeDimension ;
    rdfs:label "Settlement Time Dimension" ;
    rdfs:comment "Time dimension for settlement timing" ;
    bav:dimensionName "SETTLEMENT_TIME" ;
    bav:dimensionWeight 0.9 ;
    bav:dimensionScale 1.0 ;
    bav:dimensionUnit "SECONDS" .

# Risk Dimensions
bav:CreditRiskDimension a bav:RiskDimension ;
    rdfs:label "Credit Risk Dimension" ;
    rdfs:comment "Credit risk assessment dimension" ;
    bav:dimensionName "CREDIT_RISK" ;
    bav:dimensionWeight 0.7 ;
    bav:dimensionScale 1.0 ;
    bav:dimensionUnit "RISK_SCORE" .

bav:MarketRiskDimension a bav:RiskDimension ;
    rdfs:label "Market Risk Dimension" ;
    rdfs:comment "Market risk exposure dimension" ;
    bav:dimensionName "MARKET_RISK" ;
    bav:dimensionWeight 0.8 ;
    bav:dimensionScale 1.0 ;
    bav:dimensionUnit "VOLATILITY" .

# Compliance Dimensions
bav:AMLComplianceDimension a bav:ComplianceDimension ;
    rdfs:label "AML Compliance Dimension" ;
    rdfs:comment "Anti-Money Laundering compliance dimension" ;
    bav:dimensionName "AML_COMPLIANCE" ;
    bav:dimensionWeight 1.0 ;
    bav:dimensionScale 1.0 ;
    bav:dimensionUnit "COMPLIANCE_SCORE" .

bav:KYCComplianceDimension a bav:ComplianceDimension ;
    rdfs:label "KYC Compliance Dimension" ;
    rdfs:comment "Know Your Customer compliance dimension" ;
    bav:dimensionName "KYC_COMPLIANCE" ;
    bav:dimensionWeight 1.0 ;
    bav:dimensionScale 1.0 ;
    bav:dimensionUnit "COMPLIANCE_SCORE" .

# =============================================================================
# Settlement Validation Instances
# =============================================================================

# Primary Validators
bav:EnergyConservationValidator a bav:ConservationValidator ;
    rdfs:label "Energy Conservation Validator" ;
    rdfs:comment "Validates energy conservation in asset transformations" ;
    bav:validationThreshold 1e-12 ;
    bav:errorTolerance 1e-15 ;
    bav:computationTicks 2 .

bav:MomentumConservationValidator a bav:ConservationValidator ;
    rdfs:label "Momentum Conservation Validator" ;
    rdfs:comment "Validates momentum conservation in trading operations" ;
    bav:validationThreshold 1e-10 ;
    bav:errorTolerance 1e-12 ;
    bav:computationTicks 3 .

bav:MassConservationValidator a bav:ConservationValidator ;
    rdfs:label "Mass Conservation Validator" ;
    rdfs:comment "Validates mass conservation for asset quantities" ;
    bav:validationThreshold 1e-15 ;
    bav:errorTolerance 1e-18 ;
    bav:computationTicks 1 .

# Dimensional Validators
bav:DimensionalConsistencyValidator a bav:DimensionalValidator ;
    rdfs:label "Dimensional Consistency Validator" ;
    rdfs:comment "Validates dimensional consistency across operations" ;
    bav:validationThreshold 1e-8 ;
    bav:errorTolerance 1e-10 ;
    bav:computationTicks 2 .

bav:UnitConsistencyValidator a bav:DimensionalValidator ;
    rdfs:label "Unit Consistency Validator" ;
    rdfs:comment "Validates unit consistency in dimensional calculations" ;
    bav:validationThreshold 1e-6 ;
    bav:errorTolerance 1e-8 ;
    bav:computationTicks 1 .

# Balance Validators
bav:AssetBalanceValidator a bav:BalanceValidator ;
    rdfs:label "Asset Balance Validator" ;
    rdfs:comment "Validates asset balance equations" ;
    bav:validationThreshold 1e-9 ;
    bav:toleranceLevel 1e-12 ;
    bav:computationTicks 3 .

bav:LiabilityBalanceValidator a bav:BalanceValidator ;
    rdfs:label "Liability Balance Validator" ;
    rdfs:comment "Validates liability balance equations" ;
    bav:validationThreshold 1e-9 ;
    bav:toleranceLevel 1e-12 ;
    bav:computationTicks 3 .

# =============================================================================
# SHACL Validation Shapes
# =============================================================================

bav:AssetVectorShape a sh:NodeShape ;
    sh:targetClass bav:AssetVector ;
    sh:property [
        sh:path bav:vectorDimension ;
        sh:datatype xsd:positiveInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 1 ;
        sh:maxInclusive 1024 ;
        sh:message "Asset vector must have between 1 and 1024 dimensions" ;
    ] ;
    sh:property [
        sh:path bav:vectorMagnitude ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:message "Vector magnitude must be non-negative" ;
    ] ;
    sh:property [
        sh:path bav:hasComponent ;
        sh:class bav:TradingDimension ;
        sh:minCount 1 ;
        sh:message "Asset vector must have at least one component" ;
    ] .

bav:SettlementVectorShape a sh:NodeShape ;
    sh:targetClass bav:SettlementVector ;
    sh:property [
        sh:path bav:settlementAmount ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:message "Settlement amount must be non-negative" ;
    ] ;
    sh:property [
        sh:path bav:settlementStatus ;
        sh:datatype xsd:string ;
        sh:in ( "pending" "validating" "validated" "completed" "failed" "rejected" ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Settlement status must be one of: pending, validating, validated, completed, failed, rejected" ;
    ] ;
    sh:property [
        sh:path bav:settlementTimestamp ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .

bav:ConservationLawShape a sh:NodeShape ;
    sh:targetClass bav:ConservationLaw ;
    sh:property [
        sh:path bav:conservedQuantity ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path bav:conservationPrecision ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minExclusive 0.0 ;
        sh:maxInclusive 1e-6 ;
        sh:message "Conservation precision must be positive and ≤ 1e-6" ;
    ] ;
    sh:property [
        sh:path bav:computationTicks ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxInclusive 8 ;
        sh:message "Computation must comply with Doctrine of 8 (≤8 ticks)" ;
    ] .

bav:TradingDimensionShape a sh:NodeShape ;
    sh:targetClass bav:TradingDimension ;
    sh:property [
        sh:path bav:dimensionName ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:pattern "^[A-Z_]+$" ;
        sh:message "Dimension name must be uppercase with underscores only" ;
    ] ;
    sh:property [
        sh:path bav:dimensionWeight ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "Dimension weight must be between 0.0 and 1.0" ;
    ] ;
    sh:property [
        sh:path bav:dimensionScale ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minExclusive 0.0 ;
        sh:message "Dimension scale must be positive" ;
    ] ;
    sh:property [
        sh:path bav:dimensionUnit ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .

bav:SettlementValidatorShape a sh:NodeShape ;
    sh:targetClass bav:SettlementValidator ;
    sh:property [
        sh:path bav:validationThreshold ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minExclusive 0.0 ;
        sh:message "Validation threshold must be positive" ;
    ] ;
    sh:property [
        sh:path bav:errorTolerance ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minExclusive 0.0 ;
        sh:message "Error tolerance must be positive" ;
    ] ;
    sh:property [
        sh:path bav:computationTicks ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxInclusive 8 ;
        sh:message "Validation must comply with Doctrine of 8 (≤8 ticks)" ;
    ] .

bav:PerformanceComplianceShape a sh:NodeShape ;
    sh:targetClass bav:SettlementVector ;
    sh:property [
        sh:path bav:computationTicks ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxInclusive 8 ;
        sh:message "Settlement computation must comply with Doctrine of 8 (≤8 ticks)" ;
    ] ;
    sh:property [
        sh:path bav:settlementLatency ;
        sh:datatype xsd:decimal ;
        sh:maxInclusive 8.0 ;
        sh:message "Settlement latency must comply with Doctrine of 8 (≤8ms)" ;
    ] .

# Advanced Validation Rules
bav:ConservationComplianceShape a sh:NodeShape ;
    sh:targetClass bav:SettlementVector ;
    sh:sparql [
        sh:message "Settlement must preserve all conservation laws" ;
        sh:select """
            SELECT $this
            WHERE {
                $this bav:governedByLaw ?law .
                ?law bav:conservedQuantity ?expected .
                $this bav:conservedQuantity ?actual .
                ?law bav:conservationPrecision ?precision .
                FILTER(abs(?actual - ?expected) > ?precision)
            }
        """ ;
    ] .

bav:VectorSpaceConsistencyShape a sh:NodeShape ;
    sh:targetClass bav:AssetVector ;
    sh:sparql [
        sh:message "Vector must be consistent with its vector space dimensions" ;
        sh:select """
            SELECT $this
            WHERE {
                $this bav:operatesInSpace ?space .
                $this bav:vectorDimension ?vectorDim .
                ?space bav:spansDimensions ?dimension .
                {
                    SELECT ?space (COUNT(?dimension) AS ?spaceDim)
                    WHERE {
                        ?space bav:spansDimensions ?dimension .
                    }
                    GROUP BY ?space
                }
                FILTER(?vectorDim != ?spaceDim)
            }
        """ ;
    ] .

bav:BalanceEquationShape a sh:NodeShape ;
    sh:targetClass bav:SettlementVector ;
    sh:sparql [
        sh:message "Settlement must satisfy balance equations" ;
        sh:select """
            SELECT $this
            WHERE {
                $this bav:satisfiesConstraint ?constraint .
                ?constraint bav:toleranceLevel ?tolerance .
                # In practice, would validate actual balance equation here
                # This is a simplified check
                $this bav:settlementAmount ?amount .
                FILTER(?amount < 0)
            }
        """ ;
    ] .

# =============================================================================
# Mathematical Functions and Algorithms
# =============================================================================

# Standard vector operations
bav:dotProduct a ba:MathematicalFunction ;
    rdfs:label "Dot Product" ;
    rdfs:comment "Computes dot product of two vectors" ;
    ba:functionSignature "(Vector, Vector) -> Scalar" ;
    bav:computationTicks 2 .

bav:crossProduct a ba:MathematicalFunction ;
    rdfs:label "Cross Product" ;
    rdfs:comment "Computes cross product of two vectors" ;
    ba:functionSignature "(Vector, Vector) -> Vector" ;
    bav:computationTicks 3 .

bav:vectorNorm a ba:MathematicalFunction ;
    rdfs:label "Vector Norm" ;
    rdfs:comment "Computes Euclidean norm of a vector" ;
    ba:functionSignature "(Vector) -> Scalar" ;
    bav:computationTicks 2 .

bav:matrixMultiplication a ba:MathematicalFunction ;
    rdfs:label "Matrix Multiplication" ;
    rdfs:comment "Multiplies two matrices or matrix and vector" ;
    ba:functionSignature "(Matrix, Matrix) -> Matrix | (Matrix, Vector) -> Vector" ;
    bav:computationTicks 4 .

# Settlement-specific functions
bav:settlementFunction a ba:MathematicalFunction ;
    rdfs:label "Settlement Function" ;
    rdfs:comment "Computes optimal settlement configuration" ;
    ba:functionSignature "(AssetVector[], ConstraintSet) -> SettlementVector" ;
    bav:computationTicks 8 .

bav:conservationValidator a ba:MathematicalFunction ;
    rdfs:label "Conservation Validator" ;
    rdfs:comment "Validates conservation law compliance" ;
    ba:functionSignature "(SettlementVector, ConservationLaw[]) -> Boolean" ;
    bav:computationTicks 3 .

# =============================================================================
# Integration with Marketplace Core
# =============================================================================

# Link to marketplace entities
bam:MarketplaceAsset bav:representedBy bav:AssetVector .
bam:TradingTransaction bav:settledBy bav:SettlementVector .
bam:TradeExecution bav:validatedBy bav:SettlementValidator .

# Link to audit system
baa:AuditEvent bav:recordsSettlement bav:SettlementVector .
baa:AuditTrail bav:tracksConservation bav:ConservationInvariant .

# Link to compliance framework
bac:ComplianceControl bav:enforcesConservation bav:ConservationLaw .
bac:ComplianceValidation bav:utilizesValidator bav:SettlementValidator .

# =============================================================================
# Performance Metrics
# =============================================================================

bav:SettlementLatencyMetric a ba:PerformanceMetric ;
    rdfs:label "Settlement Latency Metric" ;
    rdfs:comment "End-to-end latency for settlement processing" ;
    ba:targetValue 5.0 ;
    ba:maxValue 8.0 ;
    ba:unit "milliseconds" ;
    ba:calculationMethod "settlement_end_time - settlement_start_time" .

bav:ConservationAccuracyMetric a ba:QualityMetric ;
    rdfs:label "Conservation Accuracy Metric" ;
    rdfs:comment "Accuracy of conservation law enforcement" ;
    ba:targetValue 99.9999 ;
    ba:unit "percentage" ;
    ba:calculationMethod "validated_conservations / total_conservations * 100" .

bav:DimensionalConsistencyMetric a ba:QualityMetric ;
    rdfs:label "Dimensional Consistency Metric" ;
    rdfs:comment "Consistency of dimensional calculations" ;
    ba:targetValue 100.0 ;
    ba:unit "percentage" ;
    ba:calculationMethod "consistent_dimensions / total_dimensions * 100" .

# =============================================================================
# End of Ontology
# =============================================================================