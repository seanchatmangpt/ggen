#    Object Properties
#################################################################

###  http://bytestar.org/ontology/byteethos-governance#hasPolicy
:hasPolicy rdf:type owl:ObjectProperty ;
          rdfs:domain be:GovernanceSubject ;
          rdfs:range :Policy ;
          rdfs:label "has policy"@en ;
          rdfs:comment "Associates a governance subject with applicable policies."@en .

###  http://bytestar.org/ontology/byteethos-governance#enforces
:enforces rdf:type owl:ObjectProperty ;
         rdfs:domain :PolicyEngine ;
         rdfs:range :Policy ;
         rdfs:label "enforces"@en ;
         rdfs:comment "Indicates that a policy engine enforces specific policies."@en .

###  http://bytestar.org/ontology/byteethos-governance#violates
:violates rdf:type owl:ObjectProperty ;
         rdfs:domain ba:Operation ;
         rdfs:range :Policy ;
         rdfs:label "violates"@en ;
         rdfs:comment "Indicates that an operation violates a specific policy."@en .

###  http://bytestar.org/ontology/byteethos-governance#triggersEnforcement
:triggersEnforcement rdf:type owl:ObjectProperty ;
                    rdfs:domain :Policy ;
                    rdfs:range :EnforcementAction ;
                    rdfs:label "triggers enforcement"@en ;
                    rdfs:comment "Indicates enforcement actions triggered by policy conditions."@en .

###  http://bytestar.org/ontology/byteethos-governance#hasRole
:hasRole rdf:type owl:ObjectProperty ;
        rdfs:domain :Subject ;
        rdfs:range :Role ;
        rdfs:label "has role"@en ;
        rdfs:comment "Associates a subject with governance roles."@en .

###  http://bytestar.org/ontology/byteethos-governance#hasPermission
:hasPermission rdf:type owl:ObjectProperty ;
              rdfs:domain :Role ;
              rdfs:range :Permission ;
              rdfs:label "has permission"@en ;
              rdfs:comment "Associates a role with specific permissions."@en .

###  http://bytestar.org/ontology/byteethos-governance#managesRisk
:managesRisk rdf:type owl:ObjectProperty ;
            rdfs:domain :MitigationStrategy ;
            rdfs:range :Risk ;
            rdfs:label "manages risk"@en ;
            rdfs:comment "Associates mitigation strategies with managed risks."@en .

###  http://bytestar.org/ontology/byteethos-governance#hasAuditTrail
:hasAuditTrail rdf:type owl:ObjectProperty ;
              rdfs:domain be:GovernanceSubject ;
              rdfs:range :AuditTrail ;
              rdfs:label "has audit trail"@en ;
              rdfs:comment "Associates subjects with their audit trails."@en .

###  http://bytestar.org/ontology/byteethos-governance#compliesWith
:compliesWith rdf:type owl:ObjectProperty ;
             rdfs:domain ba:Operation ;
             rdfs:range :RegulatoryFramework ;
             rdfs:label "complies with"@en ;
             rdfs:comment "Indicates compliance with regulatory frameworks."@en .

###  http://bytestar.org/ontology/byteethos-governance#executesContract
:executesContract rdf:type owl:ObjectProperty ;
                 rdfs:domain :AutomatedGovernance ;
                 rdfs:range :SmartContract ;
                 rdfs:label "executes contract"@en ;
                 rdfs:comment "Associates automated governance with executed smart contracts."@en .

###  http://bytestar.org/ontology/byteethos-governance#hasComplianceStatus
:hasComplianceStatus rdf:type owl:ObjectProperty ,
                              owl:FunctionalProperty ;
                    rdfs:domain ba:Operation ;
                    rdfs:range :ComplianceStatus ;
                    rdfs:label "has compliance status"@en ;
                    rdfs:comment "Associates operations with their compliance status."@en .

###  http://bytestar.org/ontology/byteethos-governance#requiresApproval
:requiresApproval rdf:type owl:ObjectProperty ;
                 rdfs:domain :Policy ;
                 rdfs:range :ApprovalProcess ;
                 rdfs:label "requires approval"@en ;
                 rdfs:comment "Indicates policies that require approval processes."@en .

###  http://bytestar.org/ontology/byteethos-governance#implementsFramework
:implementsFramework rdf:type owl:ObjectProperty ;
                    rdfs:domain :Policy ;
                    rdfs:range :RegulatoryFramework ;
                    rdfs:label "implements framework"@en ;
                    rdfs:comment "Associates policies with implemented regulatory frameworks."@en .

#################################################################
#    Data Properties
#################################################################

###  http://bytestar.org/ontology/byteethos-governance#policyId
:policyId rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
         rdfs:domain :Policy ;
         rdfs:range xsd:string ;
         rdfs:label "policy ID"@en ;
         rdfs:comment "Unique identifier for a governance policy."@en .

###  http://bytestar.org/ontology/byteethos-governance#policyVersion
:policyVersion rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
              rdfs:domain :Policy ;
              rdfs:range xsd:string ;
              rdfs:label "policy version"@en ;
              rdfs:comment "Version identifier for policy management."@en .

###  http://bytestar.org/ontology/byteethos-governance#effectiveDate
:effectiveDate rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
              rdfs:domain :Policy ;
              rdfs:range xsd:dateTime ;
              rdfs:label "effective date"@en ;
              rdfs:comment "Date when the policy becomes effective."@en .

###  http://bytestar.org/ontology/byteethos-governance#expirationDate
:expirationDate rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
               rdfs:domain :Policy ;
               rdfs:range xsd:dateTime ;
               rdfs:label "expiration date"@en ;
               rdfs:comment "Date when the policy expires."@en .

###  http://bytestar.org/ontology/byteethos-governance#severity
:severity rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
         rdfs:domain :Policy ;
         rdfs:range xsd:string ;
         rdfs:label "severity"@en ;
         rdfs:comment "Severity level of policy violations (LOW, MEDIUM, HIGH, CRITICAL)."@en .

###  http://bytestar.org/ontology/byteethos-governance#complianceScore
:complianceScore rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                rdfs:domain :ComplianceStatus ;
                rdfs:range xsd:decimal ;
                rdfs:label "compliance score"@en ;
                rdfs:comment "Numerical compliance score (0.0 to 1.0)."@en .

###  http://bytestar.org/ontology/byteethos-governance#riskLevel
:riskLevel rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:label "risk level"@en ;
          rdfs:comment "Risk level classification (LOW, MEDIUM, HIGH, CRITICAL)."@en .

###  http://bytestar.org/ontology/byteethos-governance#auditTimestamp
:auditTimestamp rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
               rdfs:domain :AuditRecord ;
               rdfs:range xsd:dateTime ;
               rdfs:label "audit timestamp"@en ;
               rdfs:comment "Timestamp when the audit record was created."@en .

###  http://bytestar.org/ontology/byteethos-governance#isActive
:isActive rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
         rdfs:domain :Policy ;
         rdfs:range xsd:boolean ;
         rdfs:label "is active"@en ;
         rdfs:comment "Indicates whether the policy is currently active."@en .

###  http://bytestar.org/ontology/byteethos-governance#evaluationTime
:evaluationTime rdf:type owl:DatatypeProperty ;
               rdfs:domain :PolicyEngine ;
               rdfs:range xsd:long ;
               rdfs:label "evaluation time"@en ;
               rdfs:comment "Time taken to evaluate policies in CPU ticks."@en .

###  http://bytestar.org/ontology/byteethos-governance#maxEvaluationTicks
:maxEvaluationTicks rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                   rdfs:domain :GovernancePerformance ;
                   rdfs:range xsd:nonNegativeInteger ;
                   rdfs:label "max evaluation ticks"@en ;
                   rdfs:comment "Maximum CPU ticks allowed for governance evaluation."@en .

#################################################################
#    Individuals - Standard Governance Components
#################################################################

###  http://bytestar.org/ontology/byteethos-governance#MasterPolicyEngine
:MasterPolicyEngine rdf:type owl:NamedIndividual ,
                             :PolicyEngine ;
                   rdfs:label "Master Policy Engine"@en ;
                   rdfs:comment "The primary policy enforcement engine for ByteStar."@en ;
                   :maxEvaluationTicks "8"^^xsd:nonNegativeInteger .

###  http://bytestar.org/ontology/byteethos-governance#SystemAdministrator
:SystemAdministrator rdf:type owl:NamedIndividual ,
                              :Role ;
                    rdfs:label "System Administrator"@en ;
                    rdfs:comment "Role with full system administration privileges."@en .

###  http://bytestar.org/ontology/byteethos-governance#ComplianceOfficer
:ComplianceOfficer rdf:type owl:NamedIndividual ,
                            :Role ;
                  rdfs:label "Compliance Officer"@en ;
                  rdfs:comment "Role responsible for compliance monitoring and reporting."@en .

###  http://bytestar.org/ontology/byteethos-governance#PolicyAdministrator
:PolicyAdministrator rdf:type owl:NamedIndividual ,
                              :Role ;
                    rdfs:label "Policy Administrator"@en ;
                    rdfs:comment "Role responsible for policy management and lifecycle."@en .

###  http://bytestar.org/ontology/byteethos-governance#SecurityOfficer
:SecurityOfficer rdf:type owl:NamedIndividual ,
                          :Role ;
                rdfs:label "Security Officer"@en ;
                rdfs:comment "Role responsible for security governance and risk management."@en .

###  http://bytestar.org/ontology/byteethos-governance#StandardComplianceGate
:StandardComplianceGate rdf:type owl:NamedIndividual ,
                                 :ComplianceGate ;
                       rdfs:label "Standard Compliance Gate"@en ;
                       rdfs:comment "Default compliance gate for standard operations."@en .

###  http://bytestar.org/ontology/byteethos-governance#MasterAuditTrail
:MasterAuditTrail rdf:type owl:NamedIndividual ,
                           :AuditTrail ;
                 rdfs:label "Master Audit Trail"@en ;
                 rdfs:comment "Primary audit trail for all governance activities."@en .

#################################################################
#    SHACL Shapes for Validation
#################################################################

###  http://bytestar.org/ontology/byteethos-governance#PolicyShape
:PolicyShape rdf:type sh:NodeShape ;
            sh:targetClass :Policy ;
            rdfs:label "Policy Shape"@en ;
            rdfs:comment "Validates governance policy properties and constraints."@en ;
            sh:property [
                sh:path :policyId ;
                sh:datatype xsd:string ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
                sh:pattern "^POL-[A-Z0-9]{8}$" ;
                sh:message "Policy must have unique ID in format POL-XXXXXXXX."@en
            ] ;
            sh:property [
                sh:path :policyVersion ;
                sh:datatype xsd:string ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
                sh:pattern "^\\d+\\.\\d+\\.\\d+$" ;
                sh:message "Policy must have semantic version (major.minor.patch)."@en
            ] ;
            sh:property [
                sh:path :effectiveDate ;
                sh:datatype xsd:dateTime ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
                sh:message "Policy must have effective date."@en
            ] ;
            sh:property [
                sh:path :severity ;
                sh:datatype xsd:string ;
                sh:in ("LOW" "MEDIUM" "HIGH" "CRITICAL") ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
                sh:message "Policy must have severity level: LOW, MEDIUM, HIGH, or CRITICAL."@en
            ] ;
            sh:property [
                sh:path :isActive ;
                sh:datatype xsd:boolean ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
                sh:message "Policy must have active status."@en
            ] .

###  http://bytestar.org/ontology/byteethos-governance#PolicyEngineShape
:PolicyEngineShape rdf:type sh:NodeShape ;
                  sh:targetClass :PolicyEngine ;
                  rdfs:label "Policy Engine Shape"@en ;
                  rdfs:comment "Validates policy engine performance constraints."@en ;
                  sh:property [
                      sh:path :evaluationTime ;
                      sh:datatype xsd:long ;
                      sh:maxInclusive 8 ;
                      sh:message "Policy evaluation must complete within 8 ticks (Doctrine of 8)."@en
                  ] ;
                  sh:property [
                      sh:path :maxEvaluationTicks ;
                      sh:datatype xsd:nonNegativeInteger ;
                      sh:hasValue 8 ;
                      sh:message "Policy engine must enforce 8-tick maximum."@en
                  ] .

###  http://bytestar.org/ontology/byteethos-governance#ComplianceStatusShape
:ComplianceStatusShape rdf:type sh:NodeShape ;
                      sh:targetClass :ComplianceStatus ;
                      rdfs:label "Compliance Status Shape"@en ;
                      rdfs:comment "Validates compliance status properties."@en ;
                      sh:property [
                          sh:path :complianceScore ;
                          sh:datatype xsd:decimal ;
                          sh:minInclusive 0.0 ;
                          sh:maxInclusive 1.0 ;
                          sh:minCount 1 ;
                          sh:maxCount 1 ;
                          sh:message "Compliance score must be between 0.0 and 1.0."@en
                      ] .

###  http://bytestar.org/ontology/byteethos-governance#RoleShape
:RoleShape rdf:type sh:NodeShape ;
          sh:targetClass :Role ;
          rdfs:label "Role Shape"@en ;
          rdfs:comment "Validates governance role properties."@en ;
          sh:property [
              sh:path :hasPermission ;
              sh:class :Permission ;
              sh:minCount 1 ;
              sh:message "Role must have at least one permission."@en
          ] .

###  http://bytestar.org/ontology/byteethos-governance#AuditRecordShape
:AuditRecordShape rdf:type sh:NodeShape ;
                 sh:targetClass :AuditRecord ;
                 rdfs:label "Audit Record Shape"@en ;
                 rdfs:comment "Validates audit record immutability and completeness."@en ;
                 sh:property [
                     sh:path :auditTimestamp ;
                     sh:datatype xsd:dateTime ;
                     sh:minCount 1 ;
                     sh:maxCount 1 ;
                     sh:message "Audit record must have timestamp."@en
                 ] ;
                 sh:property [
                     sh:path prov:wasAssociatedWith ;
                     sh:minCount 1 ;
                     sh:message "Audit record must identify responsible actor."@en
                 ] .

###  http://bytestar.org/ontology/byteethos-governance#RiskShape
:RiskShape rdf:type sh:NodeShape ;
          sh:targetClass :Risk ;
          rdfs:label "Risk Shape"@en ;
          rdfs:comment "Validates risk classification and assessment."@en ;
          sh:property [
              sh:path :riskLevel ;
              sh:datatype xsd:string ;
              sh:in ("LOW" "MEDIUM" "HIGH" "CRITICAL") ;
              sh:minCount 1 ;
              sh:maxCount 1 ;
              sh:message "Risk must have level: LOW, MEDIUM, HIGH, or CRITICAL."@en
          ] .

#################################################################
#    Axioms and Rules
#################################################################

# Axiom: All policies must be enforced by policy engines
:Policy rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty [owl:inverseOf :enforces] ;
    owl:someValuesFrom :PolicyEngine
] .

# Axiom: Policy violations trigger enforcement actions
[] rdf:type owl:Class ;
   owl:equivalentClass [
       rdf:type owl:Class ;
       owl:intersectionOf (
           ba:Operation
           [
               rdf:type owl:Restriction ;
               owl:onProperty :violates ;
               owl:someValuesFrom :Policy
           ]
       )
   ] ;
   rdfs:subClassOf [
       rdf:type owl:Restriction ;
       owl:onProperty [owl:inverseOf :triggersEnforcement] ;
       owl:someValuesFrom :EnforcementAction
   ] .

# Axiom: Active policies have effective dates in the past
:Policy rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :isActive ;
    owl:hasValue "true"^^xsd:boolean
] ,
[
    rdf:type owl:Restriction ;
    owl:onProperty :effectiveDate ;
    owl:someValuesFrom [
        rdf:type rdfs:Datatype ;
        owl:onDatatype xsd:dateTime ;
        owl:withRestrictions (
            [ owl:maxInclusive "2025-08-23T23:59:59Z"^^xsd:dateTime ]
        )
    ]
] .

# Axiom: Subjects with roles inherit permissions
:Subject rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasRole ;
    owl:someValuesFrom [
        rdf:type owl:Restriction ;
        owl:onProperty :hasPermission ;
        owl:someValuesFrom :Permission
    ]
] .

# Axiom: Policy engines operate under Doctrine of 8
:PolicyEngine rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :maxEvaluationTicks ;
    owl:hasValue "8"^^xsd:nonNegativeInteger
] .

# Axiom: Smart contracts implement deterministic execution
:SmartContract rdfs:subClassOf det:DeterministicOperation .

# Axiom: Audit records are immutable
:AuditRecord rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty prov:generatedAtTime ;
    owl:cardinality 1
] .

#################################################################
#    SPARQL Queries for Governance Management
#################################################################

# Query 1: Find active policies by severity
:findActivePoliciesBySeverityQuery rdf:type sp:Query ;
    rdfs:label "Find Active Policies by Severity"@en ;
    sp:text """
    PREFIX : <http://bytestar.org/ontology/byteethos-governance#>
    
    SELECT ?policy ?policyId ?severity ?effectiveDate ?version WHERE {
        ?policy a :Policy ;
                :policyId ?policyId ;
                :severity ?severity ;
                :effectiveDate ?effectiveDate ;
                :policyVersion ?version ;
                :isActive true .
    }
    ORDER BY DESC(?severity) ?effectiveDate
    """ .

# Query 2: Monitor policy violations and enforcement actions
:policyViolationMonitorQuery rdf:type sp:Query ;
    rdfs:label "Monitor Policy Violations"@en ;
    sp:text """
    PREFIX : <http://bytestar.org/ontology/byteethos-governance#>
    PREFIX ba: <http://bytestar.org/ontology/byteactor#>
    
    SELECT ?operation ?policy ?severity ?enforcement ?timestamp WHERE {
        ?operation :violates ?policy .
        ?policy :severity ?severity ;
                :triggersEnforcement ?enforcement .
        OPTIONAL { ?operation prov:generatedAtTime ?timestamp }
    }
    ORDER BY DESC(?severity) ?timestamp
    """ .

# Query 3: Compliance status dashboard
:complianceStatusDashboardQuery rdf:type sp:Query ;
    rdfs:label "Compliance Status Dashboard"@en ;
    sp:text """
    PREFIX : <http://bytestar.org/ontology/byteethos-governance#>
    PREFIX ba: <http://bytestar.org/ontology/byteactor#>
    
    SELECT ?framework (COUNT(?operation) AS ?totalOps) 
           (AVG(?score) AS ?avgScore) 
           (MIN(?score) AS ?minScore) WHERE {
        ?operation :hasComplianceStatus ?status ;
                   :compliesWith ?framework .
        ?status :complianceScore ?score .
    }
    GROUP BY ?framework
    ORDER BY ?avgScore
    """ .

# Query 4: Risk assessment summary
:riskAssessmentSummaryQuery rdf:type sp:Query ;
    rdfs:label "Risk Assessment Summary"@en ;
    sp:text """
    PREFIX : <http://bytestar.org/ontology/byteethos-governance#>
    
    SELECT ?riskLevel (COUNT(?risk) AS ?riskCount) WHERE {
        ?risk a :Risk ;
              :riskLevel ?riskLevel .
    }
    GROUP BY ?riskLevel
    ORDER BY ?riskLevel
    """ .

# Query 5: Audit trail analysis
:auditTrailAnalysisQuery rdf:type sp:Query ;
    rdfs:label "Audit Trail Analysis"@en ;
    sp:text """
    PREFIX : <http://bytestar.org/ontology/byteethos-governance#>
    PREFIX prov: <http://www.w3.org/ns/prov#>
    
    SELECT ?actor (COUNT(?record) AS ?activityCount) 
           ?latestActivity WHERE {
        ?record a :AuditRecord ;
                prov:wasAssociatedWith ?actor ;
                :auditTimestamp ?timestamp .
        {
            SELECT ?actor (MAX(?timestamp) AS ?latestActivity) WHERE {
                ?record prov:wasAssociatedWith ?actor ;
                        :auditTimestamp ?timestamp .
            }
            GROUP BY ?actor
        }
    }
    GROUP BY ?actor ?latestActivity
    ORDER BY DESC(?activityCount)
    """ .

# Query 6: Policy performance analysis under Doctrine of 8
:policyPerformanceAnalysisQuery rdf:type sp:Query ;
    rdfs:label "Policy Performance Analysis"@en ;
    sp:text """
    PREFIX : <http://bytestar.org/ontology/byteethos-governance#>
    PREFIX doe: <http://bytestar.org/ontology/doctrine-of-8#>
    
    SELECT ?engine ?evaluationTime ?violation WHERE {
        ?engine a :PolicyEngine ;
                :evaluationTime ?evaluationTime .
        BIND(IF(?evaluationTime > 8, "VIOLATION", "COMPLIANT") AS ?violation)
    }
    ORDER BY DESC(?evaluationTime)
    """ .

#################################################################
#    Regulatory Compliance Mappings
#################################################################

# SOX Compliance Mappings
:SOXFinancialReporting rdf:type owl:NamedIndividual ,
                                :Policy ;
                       :policyId "POL-SOX00001" ;
                       :policyVersion "1.0.0" ;
                       :implementsFramework :SOXCompliance ;
                       :severity "CRITICAL" ;
                       :isActive "true"^^xsd:boolean .

:SOXInternalControls rdf:type owl:NamedIndividual ,
                              :Policy ;
                     :policyId "POL-SOX00002" ;
                     :policyVersion "1.0.0" ;
                     :implementsFramework :SOXCompliance ;
                     :severity "HIGH" ;
                     :isActive "true"^^xsd:boolean .

# GDPR Compliance Mappings
:GDPRDataProtection rdf:type owl:NamedIndividual ,
                             :Policy ;
                    :policyId "POL-GDPR0001" ;
                    :policyVersion "1.0.0" ;
                    :implementsFramework :GDPRCompliance ;
                    :severity "CRITICAL" ;
                    :isActive "true"^^xsd:boolean .

:GDPRConsentManagement rdf:type owl:NamedIndividual ,
                                :Policy ;
                       :policyId "POL-GDPR0002" ;
                       :policyVersion "1.0.0" ;
                       :implementsFramework :GDPRCompliance ;
                       :severity "HIGH" ;
                       :isActive "true"^^xsd:boolean .

# HIPAA Compliance Mappings
:HIPAADataSecurity rdf:type owl:NamedIndividual ,
                            :Policy ;
                   :policyId "POL-HIPAA001" ;
                   :policyVersion "1.0.0" ;
                   :implementsFramework :HIPAACompliance ;
                   :severity "CRITICAL" ;
                   :isActive "true"^^xsd:boolean .

# PCI DSS Compliance Mappings
:PCIDSSDataProtection rdf:type owl:NamedIndividual ,
                               :Policy ;
                      :policyId "POL-PCI00001" ;
                      :policyVersion "1.0.0" ;
                      :implementsFramework :PCIDSSCompliance ;
                      :severity "CRITICAL" ;
                      :isActive "true"^^xsd:boolean .

#################################################################
