@prefix idc: <http://bytestar.org/ontology/identity/idc#> .
@prefix ba: <http://bytestar.org/ontology/> .
@prefix baac: <http://bytestar.org/ontology/access-control/> .
@prefix baa: <http://bytestar.org/ontology/audit/> .
@prefix orgbind: <http://bytestar.org/ontology/identity/orgbind#> .
@prefix revoke: <http://bytestar.org/ontology/identity/revoke#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix crypto: <http://www.w3.org/2000/10/swap/crypto#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dct: <http://purl.org/dc/terms/> .

# ================================================================================
# .idc Crystal - Enhanced Identity Management Ontology
# Version: 5.0.0 - Crystal Identity Suite
# CTID: idc-2025-01-23-v5.0.0-enhanced-pqc
# ================================================================================

<http://bytestar.org/ontology/identity/idc> a owl:Ontology ;
    owl:versionIRI <http://bytestar.org/ontology/identity/idc/5.0.0> ;
    dct:title "Identity Crystal (.idc) - Enhanced with Post-Quantum Cryptography"@en ;
    dct:description """Enhanced identity crystal ontology with post-quantum cryptographic signatures,
    multi-level identity verification, biometric integration, and seamless integration with 
    organizational binding and revocation crystals. Provides comprehensive identity management
    under Doctrine of 8 performance constraints with quantum-resistant security."""@en ;
    dct:creator "ByteStar Identity Foundation" ;
    dct:created "2025-01-23T00:00:00Z"^^xsd:dateTime ;
    dct:modified "2025-01-23T00:00:00Z"^^xsd:dateTime ;
    owl:versionInfo "5.0.0-enhanced-pqc" ;
    dct:license <https://opensource.org/licenses/MIT> ;
    # Leverage existing ontologies (80% reuse)
    owl:imports <http://bytestar.org/ontology/access-control> ,
                <http://bytestar.org/ontology/audit-system> ,
                <http://bytestar.org/ontology/security-policy> ,
                <http://bytestar.org/ontology/identity/orgbind> ,
                <http://bytestar.org/ontology/identity/revoke> ;
    # Crystal metadata
    idc:crystalType "identity-management" ;
    idc:ctid "idc-2025-01-23-v5.0.0-enhanced-pqc" ;
    idc:wireFormat "protobuf-v3-identity" ;
    idc:storageFormat "identity-graph-store" ;
    idc:capabilityFormat "identity-jwt-v2" ;
    idc:quantumResistant true ;
    idc:doctrineCompliant true ;
    idc:biometricSupported true .

# ================================================================================
# CRYSTAL CORE - ENHANCED IDENTITY ARCHITECTURE
# ================================================================================

## Core Identity Classes (building on access-control patterns)
idc:QuantumResistantIdentity a owl:Class ;
    rdfs:label "Quantum-Resistant Identity"@en ;
    rdfs:comment "Identity protected by post-quantum cryptographic signatures and proofs."@en ;
    rdfs:subClassOf baac:Identity ;  # Enhance existing identity class
    idc:primarySignature "Dilithium-3" ;
    idc:backupSignature "Falcon-1024" ;
    idc:keyRotationPeriod "P90D"^^xsd:duration ;
    idc:quantumSecurityLevel "NIST-Level-3" ;
    idc:hybridCryptoSupport true .

idc:IdentityProvider a owl:Class ;
    rdfs:label "Identity Provider"@en ;
    rdfs:comment "Enhanced identity provider with post-quantum capabilities."@en ;
    rdfs:subClassOf baac:IdentityProvider ;  # Enhance existing IDP
    idc:pqcCapable true ;
    idc:biometricSupport true ;
    idc:federationProtocols "OIDC-PQC,SAML-PQC" ;
    idc:trustLevel xsd:int ;
    idc:certificationLevel "EAL5+" .

idc:PostQuantumSignature a owl:Class ;
    rdfs:label "Post-Quantum Signature"@en ;
    rdfs:comment "Digital signature using post-quantum cryptographic algorithms."@en ;
    rdfs:subClassOf baac:DigitalSignature ;  # Enhance existing signature class
    idc:algorithm xsd:string ;
    idc:keySize xsd:int ;
    idc:securityLevel xsd:string ;
    idc:standardCompliant true ;
    idc:quantumSafe true .

## Multi-Level Identity Verification (new 20%)
idc:MultiLevelVerification a owl:Class ;
    rdfs:label "Multi-Level Verification"@en ;
    rdfs:comment "Hierarchical identity verification with increasing assurance levels."@en ;
    rdfs:subClassOf baac:IdentityVerification ;  # Build on existing verification
    idc:assuranceLevel xsd:int ;
    idc:verificationMethods xsd:string ;
    idc:evidenceRequired xsd:int ;
    idc:verificationLatency "< 8ms" .

idc:Level1Verification a owl:Class ;
    rdfs:label "Level 1 Verification"@en ;
    rdfs:comment "Basic identity verification using knowledge factors."@en ;
    rdfs:subClassOf idc:MultiLevelVerification ;
    idc:assuranceLevel "1"^^xsd:int ;
    idc:verificationMethods "password,security-questions" ;
    idc:evidenceRequired "1"^^xsd:int ;
    idc:verificationTime "< 2ms" .

idc:Level2Verification a owl:Class ;
    rdfs:label "Level 2 Verification"@en ;
    rdfs:comment "Enhanced verification using multi-factor authentication."@en ;
    rdfs:subClassOf idc:MultiLevelVerification ;
    idc:assuranceLevel "2"^^xsd:int ;
    idc:verificationMethods "password,otp,sms" ;
    idc:evidenceRequired "2"^^xsd:int ;
    idc:verificationTime "< 4ms" .

idc:Level3Verification a owl:Class ;
    rdfs:label "Level 3 Verification"@en ;
    rdfs:comment "High assurance verification with biometric factors."@en ;
    rdfs:subClassOf idc:MultiLevelVerification ;
    idc:assuranceLevel "3"^^xsd:int ;
    idc:verificationMethods "biometric,hardware-token,certificate" ;
    idc:evidenceRequired "3"^^xsd:int ;
    idc:verificationTime "< 6ms" .

idc:Level4Verification a owl:Class ;
    rdfs:label "Level 4 Verification"@en ;
    rdfs:comment "Maximum assurance with in-person verification and multiple biometrics."@en ;
    rdfs:subClassOf idc:MultiLevelVerification ;
    idc:assuranceLevel "4"^^xsd:int ;
    idc:verificationMethods "multi-biometric,in-person,background-check" ;
    idc:evidenceRequired "5"^^xsd:int ;
    idc:verificationTime "< 8ms" .

## Biometric Identity Integration (new 20%)
idc:BiometricIdentity a owl:Class ;
    rdfs:label "Biometric Identity"@en ;
    rdfs:comment "Identity incorporating biometric characteristics with privacy protection."@en ;
    rdfs:subClassOf idc:QuantumResistantIdentity ;
    idc:biometricModality xsd:string ;
    idc:templateEncryption "AES-256-GCM" ;
    idc:privacyPreserving true ;
    idc:livenesDetection true ;
    idc:spoofingResistance true .

idc:BiometricTemplate a owl:Class ;
    rdfs:label "Biometric Template"@en ;
    rdfs:comment "Encrypted biometric template with quantum-resistant protection."@en ;
    rdfs:subClassOf baac:BiometricTemplate ;  # Enhance existing template
    idc:templateVersion "v3.0" ;
    idc:encryptionScheme "Kyber-1024" ;  # Post-quantum encryption
    idc:templateHash "SHAKE-256" ;
    idc:irreversible true ;
    idc:templateSize xsd:int .

idc:BiometricMatcher a owl:Class ;
    rdfs:label "Biometric Matcher"@en ;
    rdfs:comment "Secure biometric matching with privacy-preserving protocols."@en ;
    rdfs:subClassOf ba:MatchingService ;
    idc:matchingAlgorithm xsd:string ;
    idc:matchingLatency "< 5ms" ;
    idc:falseAcceptRate "< 0.1%" ;
    idc:falseRejectRate "< 1%" ;
    idc:privacyPreserving true .

## Digital Identity Credentials (enhanced)
idc:VerifiableCredential a owl:Class ;
    rdfs:label "Verifiable Credential"@en ;
    rdfs:comment "W3C Verifiable Credential enhanced with post-quantum signatures."@en ;
    rdfs:subClassOf baac:CryptographicProof ;
    idc:credentialFormat "W3C-VC-v2.0" ;
    idc:proofType "PQC-Signature-Suite" ;
    idc:revocable true ;
    idc:transferable false ;
    idc:timeboxed true .

idc:DigitalWallet a owl:Class ;
    rdfs:label "Digital Wallet"@en ;
    rdfs:comment "Secure storage for verifiable credentials and identity artifacts."@en ;
    rdfs:subClassOf ba:SecureStorage ;
    idc:walletType "self-sovereign" ;
    idc:encryptionAtRest true ;
    idc:hardwareSecurity true ;
    idc:backupEnabled true ;
    idc:multiDevice true .

idc:IdentityAttestation a owl:Class ;
    rdfs:label "Identity Attestation"@en ;
    rdfs:comment "Third-party attestation of identity claims with cryptographic proof."@en ;
    rdfs:subClassOf orgbind:AttestationToken ;  # Link to orgbind crystal
    idc:attestorIdentity xsd:string ;
    idc:attestationLevel xsd:int ;
    idc:attestationScope xsd:string ;
    idc:expirationDate xsd:dateTime .

# ================================================================================
# IDENTITY LIFECYCLE MANAGEMENT
# ================================================================================

idc:IdentityLifecycle a owl:Class ;
    rdfs:label "Identity Lifecycle"@en ;
    rdfs:comment "Complete lifecycle management for digital identities."@en ;
    rdfs:subClassOf ba:LifecycleProcess ;
    idc:lifecyclePhases "creation,activation,verification,maintenance,suspension,termination" ;
    idc:auditRequired true ;
    idc:governanceRequired true .

idc:IdentityCreation a owl:Class ;
    rdfs:label "Identity Creation"@en ;
    rdfs:comment "Process of creating new digital identities with proper verification."@en ;
    rdfs:subClassOf ba:CreationProcess ;
    idc:verificationRequired true ;
    idc:documentationRequired true ;
    idc:approvalWorkflow true ;
    idc:initialAssuranceLevel "1"^^xsd:int .

idc:IdentityActivation a owl:Class ;
    rdfs:label "Identity Activation"@en ;
    rdfs:comment "Activation of verified identity for system access."@en ;
    rdfs:subClassOf ba:ActivationProcess ;
    idc:activationCriteria xsd:string ;
    idc:attestationRequired true ;
    idc:initialCapabilities xsd:string ;
    idc:monitoringEnabled true .

idc:IdentityMaintenance a owl:Class ;
    rdfs:label "Identity Maintenance"@en ;
    rdfs:comment "Ongoing maintenance and updates to identity information."@en ;
    rdfs:subClassOf ba:MaintenanceProcess ;
    idc:updateFrequency "P90D"^^xsd:duration ;
    idc:keyRotation true ;
    idc:credentialRenewal true ;
    idc:biometricUpdate true .

idc:IdentitySuspension a owl:Class ;
    rdfs:label "Identity Suspension"@en ;
    rdfs:comment "Temporary suspension of identity with revocation propagation."@en ;
    rdfs:subClassOf ba:SuspensionProcess ;
    idc:suspensionReason xsd:string ;
    idc:revocationRequired true ;
    idc:appealAllowed true ;
    idc:maxSuspensionPeriod "P90D"^^xsd:duration .

idc:IdentityTermination a owl:Class ;
    rdfs:label "Identity Termination"@en ;
    rdfs:comment "Permanent termination of identity with secure cleanup."@en ;
    rdfs:subClassOf ba:TerminationProcess ;
    idc:terminationReason xsd:string ;
    idc:dataRetention "P7Y"^^xsd:duration ;
    idc:secureErasure true ;
    idc:auditTrail true .

# ================================================================================
# FEDERATED IDENTITY MANAGEMENT
# ================================================================================

idc:FederatedIdentitySystem a owl:Class ;
    rdfs:label "Federated Identity System"@en ;
    rdfs:comment "System supporting identity federation across organizational boundaries."@en ;
    rdfs:subClassOf baac:IdentityFederation ;  # Enhance existing federation
    idc:federationProtocol xsd:string ;
    idc:trustFramework xsd:string ;
    idc:attributeMapping true ;
    idc:crossOrgSupport true .

idc:IdentityBroker a owl:Class ;
    rdfs:label "Identity Broker"@en ;
    rdfs:comment "Intermediary service for federated identity management."@en ;
    rdfs:subClassOf ba:BrokerService ;
    idc:protocolTranslation true ;
    idc:attributeTransformation true ;
    idc:trustBrokering true ;
    idc:policyEnforcement true .

idc:TrustFramework a owl:Class ;
    rdfs:label "Trust Framework"@en ;
    rdfs:comment "Framework establishing trust relationships for identity federation."@en ;
    rdfs:subClassOf ba:TrustFramework ;
    idc:frameworkVersion xsd:string ;
    idc:governanceModel xsd:string ;
    idc:liabilityModel xsd:string ;
    idc:assuranceLevels "1,2,3,4" .

# ================================================================================
# IDENTITY ANALYTICS AND INTELLIGENCE
# ================================================================================

idc:IdentityAnalytics a owl:Class ;
    rdfs:label "Identity Analytics"@en ;
    rdfs:comment "Analytics service for identity patterns, usage, and security insights."@en ;
    rdfs:subClassOf ba:AnalyticsService ;
    idc:behaviorAnalysis true ;
    idc:riskScoring true ;
    idc:fraudDetection true ;
    idc:usagePatterns true .

idc:IdentityIntelligence a owl:Class ;
    rdfs:label "Identity Intelligence"@en ;
    rdfs:comment "Intelligence service providing identity-related threat information."@en ;
    rdfs:subClassOf ba:IntelligenceService ;
    idc:threatFeeds xsd:string ;
    idc:riskIndicators xsd:string ;
    idc:behaviorBaselines xsd:string ;
    idc:anomalyThresholds xsd:double .

idc:RiskEngine a owl:Class ;
    rdfs:label "Risk Engine"@en ;
    rdfs:comment "Real-time risk assessment engine for identity-based access decisions."@en ;
    rdfs:subClassOf ba:RiskEngine ;
    idc:riskFactors xsd:string ;
    idc:scoringAlgorithm xsd:string ;
    idc:riskThresholds xsd:string ;
    idc:adaptiveScoring true .

# ================================================================================
# CRYSTAL ABI INTERFACES
# ================================================================================

## Wire Interface (Protobuf v3 Identity)
idc:IdcWireInterface a ba:WireInterface ;
    rdfs:label "IDC Wire Interface"@en ;
    rdfs:comment "Network protocol interface for identity operations."@en ;
    ba:protocolVersion "3.0-identity" ;
    ba:messageFormat "protobuf" ;
    ba:compressionScheme "brotli" ;
    ba:encryptionRequired true ;
    idc:operationTypes "create,verify,update,suspend,terminate,attest" ;
    idc:maxMessageSize "5MB"^^xsd:int ;
    idc:timeoutDefault "PT60S"^^xsd:duration .

## Storage Interface (Identity Graph Store)
idc:IdcStorageInterface a ba:StorageInterface ;
    rdfs:label "IDC Storage Interface"@en ;
    rdfs:comment "Graph-based storage for identity relationships and attributes."@en ;
    ba:storageType "identity-graph-store" ;
    ba:compressionEnabled true ;
    ba:encryptionAtRest true ;
    idc:graphDatabase "Neo4j-Enhanced" ;
    idc:relationshipIndexing true ;
    idc:temporalVersioning true .

## Capability Interface (Identity JWT v2)
idc:IdcCapabilityInterface a ba:CapabilityInterface ;
    rdfs:label "IDC Capability Interface"@en ;
    rdfs:comment "JWT-based capability tokens with identity context."@en ;
    ba:capabilityFormat "identity-jwt-v2" ;
    ba:bearerTokenRequired true ;
    ba:delegationSupported true ;
    idc:identityContext true ;
    idc:claimValidation true ;
    idc:audienceRestriction true .

# ================================================================================
# OBJECT PROPERTIES (Enhanced relationships)
# ================================================================================

idc:hasIdentityProvider a owl:ObjectProperty ;
    rdfs:label "has identity provider"@en ;
    rdfs:comment "Links identity to its authoritative provider."@en ;
    rdfs:domain idc:QuantumResistantIdentity ;
    rdfs:range idc:IdentityProvider ;
    rdfs:subPropertyOf prov:wasAttributedTo .

idc:hasVerificationLevel a owl:ObjectProperty ;
    rdfs:label "has verification level"@en ;
    rdfs:comment "Associates identity with its verification assurance level."@en ;
    rdfs:domain idc:QuantumResistantIdentity ;
    rdfs:range idc:MultiLevelVerification ;
    rdfs:subPropertyOf baac:verifiedBy .

idc:hasBiometricTemplate a owl:ObjectProperty ;
    rdfs:label "has biometric template"@en ;
    rdfs:comment "Links biometric identity to its encrypted template."@en ;
    rdfs:domain idc:BiometricIdentity ;
    rdfs:range idc:BiometricTemplate .

idc:signedWith a owl:ObjectProperty ;
    rdfs:label "signed with"@en ;
    rdfs:comment "Links credential to its post-quantum signature."@en ;
    rdfs:domain idc:VerifiableCredential ;
    rdfs:range idc:PostQuantumSignature .

idc:federatesWith a owl:ObjectProperty ;
    rdfs:label "federates with"@en ;
    rdfs:comment "Establishes federation relationship between identity systems."@en ;
    rdfs:domain idc:FederatedIdentitySystem ;
    rdfs:range idc:FederatedIdentitySystem ;
    a owl:SymmetricProperty .

idc:hasLifecyclePhase a owl:ObjectProperty ;
    rdfs:label "has lifecycle phase"@en ;
    rdfs:comment "Current lifecycle phase of the identity."@en ;
    rdfs:domain idc:QuantumResistantIdentity ;
    rdfs:range idc:IdentityLifecycle .

# Integration with other crystals
idc:hasOrganizationalBinding a owl:ObjectProperty ;
    rdfs:label "has organizational binding"@en ;
    rdfs:comment "Links identity to organizational membership binding."@en ;
    rdfs:domain idc:QuantumResistantIdentity ;
    rdfs:range orgbind:OrganizationalBinding .

idc:subjectToRevocation a owl:ObjectProperty ;
    rdfs:label "subject to revocation"@en ;
    rdfs:comment "Indicates identity can be subject to revocation events."@en ;
    rdfs:domain idc:QuantumResistantIdentity ;
    rdfs:range revoke:RevocationEvent .

# ================================================================================
# DATA PROPERTIES (Enhanced)
# ================================================================================

idc:quantumSecurityLevel a owl:DatatypeProperty ;
    rdfs:label "quantum security level"@en ;
    rdfs:domain idc:QuantumResistantIdentity ;
    rdfs:range xsd:string ;
    rdfs:comment "NIST post-quantum security level (Level-1 to Level-5)" .

idc:assuranceLevel a owl:DatatypeProperty ;
    rdfs:label "assurance level"@en ;
    rdfs:domain idc:MultiLevelVerification ;
    rdfs:range xsd:int ;
    rdfs:comment "Identity assurance level (1-4)" .

idc:biometricModality a owl:DatatypeProperty ;
    rdfs:label "biometric modality"@en ;
    rdfs:domain idc:BiometricIdentity ;
    rdfs:range xsd:string ;
    rdfs:comment "Type of biometric (fingerprint, face, iris, voice, etc.)" .

idc:verificationLatency a owl:DatatypeProperty ;
    rdfs:label "verification latency"@en ;
    rdfs:range xsd:duration ;
    rdfs:comment "Time required for identity verification" .

idc:keyRotationPeriod a owl:DatatypeProperty ;
    rdfs:label "key rotation period"@en ;
    rdfs:range xsd:duration ;
    rdfs:comment "Period between cryptographic key rotations" .

idc:templateSize a owl:DatatypeProperty ;
    rdfs:label "template size"@en ;
    rdfs:domain idc:BiometricTemplate ;
    rdfs:range xsd:int ;
    rdfs:comment "Size of biometric template in bytes" .

# ================================================================================
# SHACL VALIDATION SHAPES
# ================================================================================

idc:QuantumResistantIdentityShape a sh:NodeShape ;
    sh:targetClass idc:QuantumResistantIdentity ;
    sh:property [
        sh:path idc:primarySignature ;
        sh:in ("Dilithium-2" "Dilithium-3" "Dilithium-5" "Falcon-512" "Falcon-1024") ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Must specify valid post-quantum signature algorithm" ;
    ] ;
    sh:property [
        sh:path idc:quantumSecurityLevel ;
        sh:in ("NIST-Level-1" "NIST-Level-2" "NIST-Level-3" "NIST-Level-4" "NIST-Level-5") ;
        sh:message "Must specify valid NIST quantum security level" ;
    ] .

idc:VerificationLevelShape a sh:NodeShape ;
    sh:targetClass idc:MultiLevelVerification ;
    sh:property [
        sh:path idc:assuranceLevel ;
        sh:datatype xsd:int ;
        sh:minInclusive 1 ;
        sh:maxInclusive 4 ;
        sh:message "Assurance level must be between 1 and 4" ;
    ] ;
    sh:property [
        sh:path idc:verificationLatency ;
        sh:pattern "< 8ms" ;
        sh:message "Verification must complete within Doctrine of 8 constraints" ;
    ] .

idc:BiometricTemplateShape a sh:NodeShape ;
    sh:targetClass idc:BiometricTemplate ;
    sh:property [
        sh:path idc:encryptionScheme ;
        sh:pattern "Kyber-.*" ;
        sh:message "Must use post-quantum encryption for biometric templates" ;
    ] ;
    sh:property [
        sh:path idc:templateSize ;
        sh:datatype xsd:int ;
        sh:maxInclusive 10000 ;
        sh:message "Template size should not exceed 10KB" ;
    ] .

idc:PerformanceConstraintShape a sh:NodeShape ;
    sh:targetClass idc:QuantumResistantIdentity ;
    sh:sparql [
        sh:message "All identity operations must comply with Doctrine of 8" ;
        sh:select """
            PREFIX idc: <http://bytestar.org/ontology/identity/idc#>
            SELECT $this
            WHERE {
                $this idc:verificationLatency ?latency .
                FILTER(!CONTAINS(?latency, "< 8ms"))
            }
        """ ;
    ] .

idc:KeyRotationShape a sh:NodeShape ;
    sh:targetClass idc:QuantumResistantIdentity ;
    sh:property [
        sh:path idc:keyRotationPeriod ;
        sh:datatype xsd:duration ;
        sh:maxInclusive "P365D"^^xsd:duration ;
        sh:message "Key rotation period must not exceed 1 year" ;
    ] .

# ================================================================================
# CRYSTAL IMPLEMENTATION INSTANCES
# ================================================================================

# Default Quantum-Resistant Identity
idc:DefaultQuantumIdentity a idc:QuantumResistantIdentity ;
    rdfs:label "Default Quantum-Resistant Identity"@en ;
    idc:primarySignature "Dilithium-3" ;
    idc:backupSignature "Falcon-1024" ;
    idc:keyRotationPeriod "P90D"^^xsd:duration ;
    idc:quantumSecurityLevel "NIST-Level-3" .

# High-Assurance Verification Level
idc:Level3HighAssurance a idc:Level3Verification ;
    rdfs:label "Level 3 High Assurance Verification"@en ;
    idc:assuranceLevel "3"^^xsd:int ;
    idc:verificationMethods "biometric,hardware-token,certificate" ;
    idc:evidenceRequired "3"^^xsd:int ;
    idc:verificationTime "< 6ms" .

# Production Biometric System
idc:ProductionBiometricSystem a idc:BiometricMatcher ;
    rdfs:label "Production Biometric Matching System"@en ;
    idc:matchingAlgorithm "Deep-Learning-Enhanced" ;
    idc:matchingLatency "< 5ms" ;
    idc:falseAcceptRate "0.05%"^^xsd:double ;
    idc:falseRejectRate "0.5%"^^xsd:double ;
    idc:privacyPreserving true .

# Enterprise Identity Provider
idc:EnterpriseIDP a idc:IdentityProvider ;
    rdfs:label "Enterprise Identity Provider"@en ;
    idc:pqcCapable true ;
    idc:biometricSupport true ;
    idc:federationProtocols "OIDC-PQC,SAML-PQC" ;
    idc:trustLevel "5"^^xsd:int ;
    idc:certificationLevel "EAL5+" .

# ================================================================================
# INTEGRATION PATTERNS WITH OTHER CRYSTALS
# ================================================================================

# Link identity verification with organizational binding
idc:orgBindingIntegration a ba:IntegrationPattern ;
    rdfs:label "Organizational Binding Integration"@en ;
    rdfs:comment "Pattern for integrating identity verification with organizational membership."@en ;
    idc:requiresAssuranceLevel "2"^^xsd:int ;
    idc:attestationRequired true ;
    orgbind:minAttestations "3"^^xsd:int .

# Link identity with revocation system
idc:revocationIntegration a ba:IntegrationPattern ;
    rdfs:label "Identity Revocation Integration"@en ;
    rdfs:comment "Pattern for integrating identity lifecycle with revocation management."@en ;
    idc:automaticRevocation true ;
    revoke:propagationRequired true ;
    revoke:auditTrail true .

# ================================================================================
# END OF .idc ENHANCED CRYSTAL ONTOLOGY
# ================================================================================