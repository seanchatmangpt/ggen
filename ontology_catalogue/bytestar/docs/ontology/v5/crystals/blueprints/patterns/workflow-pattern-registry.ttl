@prefix wpr: <https://bytestar.org/ontology/v5/crystals/blueprints/workflow-pattern-registry#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bcore: <https://bytestar.org/ontology/bytestar-core#> .
@prefix yawl: <http://yawl.org/ontology#> .
@prefix pcl: <https://bytestar.org/ontology/v5/crystals/blueprints/polycrystal-lattice#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<https://bytestar.org/ontology/v5/crystals/blueprints/workflow-pattern-registry>
  a owl:Ontology ;
  rdfs:label "43 Workflow Pattern Registry with Capability Mappings" ;
  rdfs:comment "Complete registry of 43 canonical workflow patterns with crystal capability mappings, extending YAWL's 20 patterns with ByteStar-specific patterns." ;
  owl:imports 
    <https://bytestar.org/ontology/bytestar-core> ,
    <http://yawl.org/ontology> ,
    <https://bytestar.org/ontology/v5/crystals/blueprints/polycrystal-lattice> ;
  owl:versionInfo "5.0.0" ;
  wpr:patternCount "43"^^xsd:integer ;
  wpr:yawlExtended "true"^^xsd:boolean .

#################################################################
# Core Pattern Registry Structure
#################################################################

wpr:WorkflowPatternRegistry a owl:Class ;
  rdfs:label "Workflow Pattern Registry" ;
  rdfs:comment "Central registry containing all 43 canonical workflow patterns with capability mappings." ;
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty wpr:containsPattern ;
    owl:cardinality "43"^^xsd:nonNegativeInteger
  ] .

wpr:CrystalWorkflowPattern a owl:Class ;
  rdfs:label "Crystal Workflow Pattern" ;
  rdfs:comment "Enhanced workflow pattern with crystal structure integration and capability mappings." ;
  rdfs:subClassOf bcore:Pattern ;
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty wpr:hasCapabilityMapping ;
    owl:minCardinality "1"^^xsd:nonNegativeInteger
  ] ;
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty wpr:hasPatternId ;
    owl:cardinality "1"^^xsd:nonNegativeInteger
  ] .

wpr:CapabilityMapping a owl:Class ;
  rdfs:label "Capability Mapping" ;
  rdfs:comment "Maps workflow patterns to required and provided capabilities." ;
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty wpr:requiresCapability ;
    owl:minCardinality "1"^^xsd:nonNegativeInteger
  ] ;
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty wpr:providesCapability ;
    owl:minCardinality "1"^^xsd:nonNegativeInteger
  ] .

#################################################################
# Pattern Categories (Extended from YAWL)
#################################################################

wpr:PatternCategory a owl:Class ;
  rdfs:label "Pattern Category" ;
  rdfs:comment "Extended categorization including ByteStar-specific pattern types." .

# YAWL-derived categories
wpr:BasicControlFlow a wpr:PatternCategory ;
  rdfs:label "Basic Control Flow Patterns" .

wpr:AdvancedBranchingSynchronization a wpr:PatternCategory ;
  rdfs:label "Advanced Branching and Synchronization Patterns" .

wpr:Structural a wpr:PatternCategory ;
  rdfs:label "Structural Patterns" .

wpr:MultipleInstances a wpr:PatternCategory ;
  rdfs:label "Patterns involving Multiple Instances" .

wpr:StateBased a wpr:PatternCategory ;
  rdfs:label "State-based Patterns" .

wpr:Cancellation a wpr:PatternCategory ;
  rdfs:label "Cancellation Patterns" .

# ByteStar-specific categories
wpr:CrystalOrchestration a wpr:PatternCategory ;
  rdfs:label "Crystal Orchestration Patterns" .

wpr:MemoryResident a wpr:PatternCategory ;
  rdfs:label "Memory-Resident Patterns" .

wpr:FaultTolerant a wpr:PatternCategory ;
  rdfs:label "Fault-Tolerant Patterns" .

wpr:PerformanceOptimized a wpr:PatternCategory ;
  rdfs:label "Performance-Optimized Patterns" .

wpr:SecurityCompliant a wpr:PatternCategory ;
  rdfs:label "Security-Compliant Patterns" .

#################################################################
# 43 Canonical Workflow Patterns (P01-P43)
#################################################################

# YAWL Base Patterns (P01-P20) - Extended with Crystal Capabilities
wpr:P01_Sequence a wpr:CrystalWorkflowPattern ;
  rdfs:label "P01: Sequence" ;
  wpr:patternId "P01" ;
  wpr:category wpr:BasicControlFlow ;
  wpr:yawlEquivalent yawl:P1_Sequence ;
  wpr:crystalComplexity "1"^^xsd:integer ;
  wpr:hamHopRequired pcl:Hop1 .

