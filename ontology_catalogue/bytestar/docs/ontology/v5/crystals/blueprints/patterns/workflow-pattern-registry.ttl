#################################################################
# Object Properties
#################################################################

wpr:containsPattern a owl:ObjectProperty ;
  rdfs:label "contains pattern" ;
  rdfs:domain wpr:WorkflowPatternRegistry ;
  rdfs:range wpr:CrystalWorkflowPattern .

wpr:hasCapabilityMapping a owl:ObjectProperty ;
  rdfs:label "has capability mapping" ;
  rdfs:domain wpr:CrystalWorkflowPattern ;
  rdfs:range wpr:CapabilityMapping .

wpr:category a owl:ObjectProperty ;
  rdfs:label "has category" ;
  rdfs:domain wpr:CrystalWorkflowPattern ;
  rdfs:range wpr:PatternCategory .

wpr:yawlEquivalent a owl:ObjectProperty ;
  rdfs:label "YAWL equivalent" ;
  rdfs:domain wpr:CrystalWorkflowPattern ;
  rdfs:range yawl:Pattern .

wpr:hamHopRequired a owl:ObjectProperty ;
  rdfs:label "HAM hop required" ;
  rdfs:domain wpr:CrystalWorkflowPattern ;
  rdfs:range pcl:HAMHop .

wpr:requiresCapability a owl:ObjectProperty ;
  rdfs:label "requires capability" ;
  rdfs:domain wpr:CapabilityMapping ;
  rdfs:range pcl:WorkflowCapability .

wpr:providesCapability a owl:ObjectProperty ;
  rdfs:label "provides capability" ;
  rdfs:domain wpr:CapabilityMapping ;
  rdfs:range pcl:WorkflowCapability .

#################################################################
# Data Properties
#################################################################

wpr:patternCount a owl:DatatypeProperty ;
  rdfs:label "pattern count" ;
  rdfs:range xsd:integer .

wpr:yawlExtended a owl:DatatypeProperty ;
  rdfs:label "YAWL extended" ;
  rdfs:range xsd:boolean .

wpr:patternId a owl:DatatypeProperty ;
  rdfs:label "pattern ID" ;
  rdfs:range xsd:string .

wpr:crystalComplexity a owl:DatatypeProperty ;
  rdfs:label "crystal complexity" ;
  rdfs:range xsd:integer ;
  rdfs:comment "Complexity rating from 1-8 for crystal formation requirements." .

wpr:hasPatternId a owl:DatatypeProperty ;
  rdfs:label "has pattern ID" ;
  rdfs:range xsd:string .