@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

#################################################################
# HOP×TYPE ADMISSION MATRIX (HAM)
# Complete machine-readable admission control system for ByteStar
# 8-Hop execution model with closed-world SHACL constraints
#################################################################

<http://bytestar.org/ontology/ham> a owl:Ontology ;
    dct:title "ByteStar Hop×Type Admission Matrix (HAM): Complete Type Admission Control System"@en ;
    dct:description """The comprehensive Hop×Type Admission Matrix (HAM) that defines precise
    admission control rules for all 8 hops in the ByteStar execution model. Leverages existing
    crystal specifications to create closed-world constraints with zero ambiguity.
    
    HAM provides:
    1. Hop-1/3: Governance + Blueprint type admission (80% reuse of existing ontologies)
    2. Hop-2/4: Identity/Policy/Budget type admission (leverages security-policy ontology)
    3. Hop-5: Execution input/output type admission (uses execution-physics + byteflow)
    4. Hop-6: Finalization type admission (integrates performance-measurement)
    5. Hop-7: Publication type admission (extends meta-ontology patterns)
    6. Hop-8: Audit/Ops type admission (comprehensive operational control)
    
    Each hop has disjoint partitions with No-Blob rejection rules and cross-hop
    dependency validation using SHACL closed shapes for zero admission ambiguity."""@en ;
    dct:creator "ByteStar HAM Architecture Team"@en ;
    dct:created "2025-08-23T00:00:00Z"^^xsd:dateTime ;
    dct:modified "2025-08-23T00:00:00Z"^^xsd:dateTime ;
    owl:versionInfo "5.0.0-ham-complete"@en ;
    dct:license <https://opensource.org/licenses/MIT> ;
    rdfs:seeAlso <http://bytestar.org/docs/ham-specification> ;
    owl:imports <http://bytestar.org/ontology/byteactor> ,
                <http://bytestar.org/ontology/byteethos> ,
                <http://bytestar.org/ontology/byteflow> ,
                <http://bytestar.org/ontology/bytecore> ,
                <http://bytestar.org/ontology/bytepqc> ,
                <http://bytestar.org/ontology/doctrine-of-8> ,
                <http://bytestar.org/ontology/deterministic-execution> ,
                <http://bytestar.org/ontology/zero-tick-rejection> ,
                <http://bytestar.org/ontology/execution-physics> ,
                <http://bytestar.org/ontology/performance-measurement> ,
                <http://bytestar.org/ontology/security-policy> ,
                <https://bytestar.io/ontology/meta/> ,
                <http://byteactor.org/ontology> .

#################################################################
# CORE HAM CLASSES - ADMISSION CONTROL FRAMEWORK
#################################################################

###  HAM Core Admission Controller
ham:HopAdmissionMatrix a owl:Class ;
    rdfs:label "Hop Admission Matrix"@en ;
    rdfs:comment """The complete 8×N matrix defining type admission rules for each hop
    in the ByteStar execution model. Implements closed-world assumption with disjoint
    type partitions and No-Blob rejection."""@en ;
    rdfs:subClassOf be:GovernanceFramework ,
                    sec:SecurityControl ,
                    doe:PerformanceConstraint .

ham:HopTypeAdmissionRule a owl:Class ;
    rdfs:label "Hop Type Admission Rule"@en ;
    rdfs:comment """A specific rule defining which types are admitted, rejected, or 
    conditionally accepted at a particular hop."""@en ;
    rdfs:subClassOf sec:SecurityPolicy ,
                    doe:ExecutionConstraint .

ham:AdmissionDecision a owl:Class ;
    rdfs:label "Admission Decision"@en ;
    rdfs:comment "The outcome of applying HAM rules: ADMIT, REJECT, or CONDITIONAL."@en ;
    owl:oneOf ( ham:ADMIT ham:REJECT ham:CONDITIONAL ) .

ham:HopExecutionPoint a owl:Class ;
    rdfs:label "Hop Execution Point"@en ;
    rdfs:comment """A specific point in the 8-hop execution model where admission
    control is enforced."""@en ;
    rdfs:subClassOf exec:ExecutionPoint ,
                    doe:TickBoundary .

ham:TypeClassification a owl:Class ;
    rdfs:label "Type Classification"@en ;
    rdfs:comment """Classification system for all types in ByteStar, enabling
    precise admission control at each hop."""@en ;
    rdfs:subClassOf meta:ConceptualModel .

#################################################################
# 8-HOP EXECUTION MODEL CLASSES
#################################################################

###  Hop-1: Governance Inception
ham:Hop1GovernanceInception a owl:Class ;
    rdfs:label "Hop-1: Governance Inception"@en ;
    rdfs:comment """First hop: Governance rule initialization and system bootstrap.
    Admits governance frameworks, ethical guidelines, and foundational policies."""@en ;
    rdfs:subClassOf ham:HopExecutionPoint ;
    ham:hopNumber "1"^^xsd:integer ;
    ham:executionPhase "governance-inception" ;
    ham:maxTickAllowance "1"^^xsd:integer .

###  Hop-2: Identity & Policy Formation  
ham:Hop2IdentityPolicy a owl:Class ;
    rdfs:label "Hop-2: Identity & Policy Formation"@en ;
    rdfs:comment """Second hop: Identity establishment and policy instantiation.
    Admits identity credentials, security policies, and authorization frameworks."""@en ;
    rdfs:subClassOf ham:HopExecutionPoint ;
    ham:hopNumber "2"^^xsd:integer ;
    ham:executionPhase "identity-policy" ;
    ham:maxTickAllowance "1"^^xsd:integer .

###  Hop-3: Blueprint Crystallization
ham:Hop3BlueprintCrystal a owl:Class ;
    rdfs:label "Hop-3: Blueprint Crystallization"@en ;
    rdfs:comment """Third hop: System blueprint materialization and architectural planning.
    Admits architectural patterns, design blueprints, and structural specifications."""@en ;
    rdfs:subClassOf ham:HopExecutionPoint ;
    ham:hopNumber "3"^^xsd:integer ;
    ham:executionPhase "blueprint-crystallization" ;
    ham:maxTickAllowance "1"^^xsd:integer .

###  Hop-4: Budget & Resource Allocation
ham:Hop4BudgetAllocation a owl:Class ;
    rdfs:label "Hop-4: Budget & Resource Allocation"@en ;
    rdfs:comment """Fourth hop: Resource budget allocation and capacity planning.
    Admits budget constraints, resource allocators, and capacity models."""@en ;
    rdfs:subClassOf ham:HopExecutionPoint ;
    ham:hopNumber "4"^^xsd:integer ;
    ham:executionPhase "budget-allocation" ;
    ham:maxTickAllowance "1"^^xsd:integer .

###  Hop-5: Execution Physics
ham:Hop5ExecutionPhysics a owl:Class ;
    rdfs:label "Hop-5: Execution Physics"@en ;
    rdfs:comment """Fifth hop: Core execution engine and computational physics.
    Admits execution contexts, computational processes, and data transformations."""@en ;
    rdfs:subClassOf ham:HopExecutionPoint ;
    ham:hopNumber "5"^^xsd:integer ;
    ham:executionPhase "execution-physics" ;
    ham:maxTickAllowance "1"^^xsd:integer .

###  Hop-6: Finalization & Validation
ham:Hop6Finalization a owl:Class ;
    rdfs:label "Hop-6: Finalization & Validation"@en ;
    rdfs:comment """Sixth hop: Result finalization and validation processes.
    Admits validators, finalizers, and consistency checkers."""@en ;
    rdfs:subClassOf ham:HopExecutionPoint ;
    ham:hopNumber "6"^^xsd:integer ;
    ham:executionPhase "finalization-validation" ;
    ham:maxTickAllowance "1"^^xsd:integer .

###  Hop-7: Publication & Dissemination
ham:Hop7Publication a owl:Class ;
    rdfs:label "Hop-7: Publication & Dissemination"@en ;
    rdfs:comment """Seventh hop: Result publication and knowledge dissemination.
    Admits publishers, distributors, and knowledge management systems."""@en ;
    rdfs:subClassOf ham:HopExecutionPoint ;
    ham:hopNumber "7"^^xsd:integer ;
    ham:executionPhase "publication-dissemination" ;
    ham:maxTickAllowance "1"^^xsd:integer .

###  Hop-8: Audit & Operations
ham:Hop8AuditOps a owl:Class ;
    rdfs:label "Hop-8: Audit & Operations"@en ;
    rdfs:comment """Eighth hop: System audit and operational monitoring.
    Admits auditors, monitors, and operational control systems."""@en ;
    rdfs:subClassOf ham:HopExecutionPoint ;
    ham:hopNumber "8"^^xsd:integer ;
    ham:executionPhase "audit-operations" ;
    ham:maxTickAllowance "1"^^xsd:integer .

#################################################################
# HOP-1/3: GOVERNANCE + BLUEPRINT TYPE CONSTRAINTS
# Leverages ByteEthos governance + architectural patterns
#################################################################

###  Hop-1 Admitted Types (Governance Inception)
ham:Hop1AdmittedTypes a owl:Class ;
    rdfs:label "Hop-1 Admitted Types"@en ;
    rdfs:comment "Types admitted during governance inception phase."@en ;
    owl:unionOf (
        be:EthicalFramework
        be:GovernanceRule
        be:GovernanceStructure
        be:EthicalPrinciple
        be:GovernancePolicy
        be:DecisionFramework
        be:EthicalGuideline
        be:ResponsibilityModel
        be:AccountabilityFramework
        doe:DoctrineOfEightLaw
        doe:PerformanceConstraint
        sec:SecurityPolicy
        sec:ComplianceFramework
    ) .

###  Hop-3 Admitted Types (Blueprint Crystallization)
ham:Hop3AdmittedTypes a owl:Class ;
    rdfs:label "Hop-3 Admitted Types"@en ;
    rdfs:comment "Types admitted during blueprint crystallization phase."@en ;
    owl:unionOf (
        ba:SystemArchitecture
        ba:ArchitecturalPattern
        ba:SystemBlueprint
        ba:DesignPattern
        ba:ComponentSpec
        ba:InterfaceSpec
        ba:SystemTopology
        orch:WorkflowPattern
        orch:WorkflowTemplate
        orch:OrchestrationPattern
        orch:ServiceArchitecture
        meta:ConceptualModel
        meta:OntologyPattern
        meta:StructuralAnalysis
    ) .

#################################################################
# HOP-2/4: IDENTITY/POLICY/BUDGET TYPE CONSTRAINTS
# Leverages security-policy + resource management ontologies  
#################################################################

