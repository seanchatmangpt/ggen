ham:Hop2AdmittedTypes a owl:Class ;
    rdfs:label "Hop-2 Admitted Types"@en ;
    rdfs:comment "Types admitted during identity and policy formation phase."@en ;
    owl:unionOf (
        sec:SecurityPolicy
        sec:ThreatModel
        sec:SecurityControl
        sec:CryptographicPolicy
        sec:KeyManagementPolicy
        sec:IdentityManagement
        sec:AccessControl
        sec:AuthenticationSystem
        sec:AuthorizationFramework
        sec:QuantumResistantSecurity
        sec:ZeroTrustArchitecture
        bp:PostQuantumCryptography
        bp:CryptographicAlgorithm
        bp:KeyExchangeMechanism
        bp:DigitalSignature
    ) .

###  Hop-4 Admitted Types (Budget & Resource Allocation)
ham:Hop4AdmittedTypes a owl:Class ;
    rdfs:label "Hop-4 Admitted Types"@en ;
    rdfs:comment "Types admitted during budget and resource allocation phase."@en ;
    owl:unionOf (
        orch:ResourceOrchestrator
        orch:ComputeResource
        orch:StorageResource
        orch:NetworkResource
        orch:ServiceResource
        orch:ActorResource
        orch:ResourceUtilizationMetric
        exec:ResourceConstraint
        exec:CapacityModel
        exec:AllocationStrategy
        perf:PerformanceBudget
        perf:ResourceBudget
        perf:CostModel
        doe:ResourceLimit
        doe:CapacityConstraint
    ) .

#################################################################
# HOP-5: EXECUTION INPUT/OUTPUT TYPE CONSTRAINTS
# Uses execution-physics + byteflow orchestration patterns
#################################################################

###  Hop-5 Admitted Types (Execution Physics)
ham:Hop5AdmittedTypes a owl:Class ;
    rdfs:label "Hop-5 Admitted Types"@en ;
