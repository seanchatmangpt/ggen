# HOP-8: AUDIT/OPS TYPE CONSTRAINTS
# Comprehensive operational control + monitoring systems
#################################################################

###  Hop-8 Admitted Types (Audit & Operations)
ham:Hop8AdmittedTypes a owl:Class ;
    rdfs:label "Hop-8 Admitted Types"@en ;
    rdfs:comment "Types admitted during audit and operations phase."@en ;
    owl:unionOf (
        sec:SecurityOperationsCenter
        sec:ThreatIntelligence
        sec:IncidentResponse
        sec:SecurityAuditing
        sec:VulnerabilityManagement
        perf:PerformanceMonitor
        perf:SystemMonitor
        perf:OperationalMetric
        perf:AuditTrail
        orch:OrchestrationMonitor
        orch:PerformanceOptimizer
        orch:FaultTolerantOrchestrator
        exec:ExecutionMonitor
        exec:SystemDiagnostics
        meta:SelfReflectionCapability
        meta:IntrospectionProcess
        meta:SelfAnalysis
        meta:PerformanceAnalysis
        meta:UsageAnalysis
        be:SystemAuditor
        be:ComplianceMonitor
        be:EthicalAuditing
        ztr:RejectionAnalyzer
        doe:PerformanceAnalyzer
    ) .

#################################################################
# NO-BLOB REJECTION RULES
# Explicit rejection of untyped or blob data at all hops
#################################################################

###  Universal Blob Rejection Types
ham:UniversallyRejectedTypes a owl:Class ;
    rdfs:label "Universally Rejected Types"@en ;
    rdfs:comment """Types that are rejected at ALL hops to maintain type safety
    and prevent blob data from entering the execution pipeline."""@en ;
    owl:unionOf (
        ham:UntypedBlob
        ham:BinaryBlob  
        ham:GenericData
        ham:UnstructuredData
        ham:AmbiguousType
        ham:PolymorphicBlob
        ham:SerializedBlob
        ham:OpaqueData
        ham:LegacyBlob
        ham:UnvalidatedInput
    ) .

###  Blob Types for Explicit Rejection
ham:UntypedBlob a owl:Class ;
    rdfs:label "Untyped Blob"@en ;
    rdfs:comment "Data without explicit type information - REJECTED"@en ;
    owl:disjointWith ham:Hop1AdmittedTypes, ham:Hop2AdmittedTypes, 
                     ham:Hop3AdmittedTypes, ham:Hop4AdmittedTypes,
                     ham:Hop5AdmittedTypes, ham:Hop6AdmittedTypes,
                     ham:Hop7AdmittedTypes, ham:Hop8AdmittedTypes .

ham:BinaryBlob a owl:Class ;
    rdfs:label "Binary Blob"@en ;
    rdfs:comment "Opaque binary data without semantic structure - REJECTED"@en ;
    owl:disjointWith ham:Hop1AdmittedTypes, ham:Hop2AdmittedTypes,
                     ham:Hop3AdmittedTypes, ham:Hop4AdmittedTypes,
                     ham:Hop5AdmittedTypes, ham:Hop6AdmittedTypes,
                     ham:Hop7AdmittedTypes, ham:Hop8AdmittedTypes .

ham:GenericData a owl:Class ;
    rdfs:label "Generic Data"@en ;
    rdfs:comment "Overly generic data types without specific semantics - REJECTED"@en ;
    owl:disjointWith ham:Hop1AdmittedTypes, ham:Hop2AdmittedTypes,
                     ham:Hop3AdmittedTypes, ham:Hop4AdmittedTypes,
                     ham:Hop5AdmittedTypes, ham:Hop6AdmittedTypes,
                     ham:Hop7AdmittedTypes, ham:Hop8AdmittedTypes .

#################################################################
# CROSS-HOP DEPENDENCY VALIDATION
# Rules ensuring proper flow dependencies between hops
#################################################################

###  Cross-Hop Dependency Rules
ham:CrossHopDependency a owl:Class ;
    rdfs:label "Cross-Hop Dependency"@en ;
    rdfs:comment """Dependency relationship between types admitted at different hops,
    ensuring proper execution flow and data dependencies."""@en ;
    rdfs:subClassOf ham:HopTypeAdmissionRule .

###  Specific Dependency Rules
ham:GovernanceBlueprintDependency a owl:Class ;
    rdfs:label "Governance-Blueprint Dependency"@en ;
    rdfs:comment "Blueprint types (Hop-3) must depend on governance types (Hop-1)"@en ;
    rdfs:subClassOf ham:CrossHopDependency ;
    ham:requiresSourceHop ham:Hop1GovernanceInception ;
    ham:requiresTargetHop ham:Hop3BlueprintCrystal .

ham:IdentityExecutionDependency a owl:Class ;
    rdfs:label "Identity-Execution Dependency"@en ;
    rdfs:comment "Execution types (Hop-5) must have identity/policy foundation (Hop-2)"@en ;
    rdfs:subClassOf ham:CrossHopDependency ;
    ham:requiresSourceHop ham:Hop2IdentityPolicy ;
    ham:requiresTargetHop ham:Hop5ExecutionPhysics .

ham:BudgetExecutionDependency a owl:Class ;
    rdfs:label "Budget-Execution Dependency"@en ;
    rdfs:comment "Execution types (Hop-5) must respect budget constraints (Hop-4)"@en ;
    rdfs:subClassOf ham:CrossHopDependency ;
    ham:requiresSourceHop ham:Hop4BudgetAllocation ;
    ham:requiresTargetHop ham:Hop5ExecutionPhysics .

ham:ExecutionFinalizationDependency a owl:Class ;
    rdfs:label "Execution-Finalization Dependency"@en ;
    rdfs:comment "Finalization types (Hop-6) must process execution outputs (Hop-5)"@en ;
    rdfs:subClassOf ham:CrossHopDependency ;
    ham:requiresSourceHop ham:Hop5ExecutionPhysics ;
    ham:requiresTargetHop ham:Hop6Finalization .

ham:FinalizationPublicationDependency a owl:Class ;
    rdfs:label "Finalization-Publication Dependency"@en ;
    rdfs:comment "Publication types (Hop-7) must use finalized results (Hop-6)"@en ;
    rdfs:subClassOf ham:CrossHopDependency ;
    ham:requiresSourceHop ham:Hop6Finalization ;
    ham:requiresTargetHop ham:Hop7Publication .

ham:PublicationAuditDependency a owl:Class ;
    rdfs:label "Publication-Audit Dependency"@en ;
    rdfs:comment "Audit types (Hop-8) must monitor all published results (Hop-7)"@en ;
    rdfs:subClassOf ham:CrossHopDependency ;
    ham:requiresSourceHop ham:Hop7Publication ;
    ham:requiresTargetHop ham:Hop8AuditOps .

#################################################################
# OBJECT PROPERTIES - HAM RELATIONSHIPS
#################################################################

###  Core HAM Properties
ham:admitsType a owl:ObjectProperty ;
    rdfs:label "admits type"@en ;
    rdfs:comment "Indicates that a hop admits a specific type for processing."@en ;
    rdfs:domain ham:HopExecutionPoint ;
    rdfs:range owl:Class .

ham:rejectsType a owl:ObjectProperty ;
    rdfs:label "rejects type"@en ;
    rdfs:comment "Indicates that a hop explicitly rejects a specific type."@en ;
    rdfs:domain ham:HopExecutionPoint ;
    rdfs:range owl:Class .

ham:hasAdmissionRule a owl:ObjectProperty ;
    rdfs:label "has admission rule"@en ;
    rdfs:comment "Associates a hop with its admission control rules."@en ;
    rdfs:domain ham:HopExecutionPoint ;
    rdfs:range ham:HopTypeAdmissionRule .

ham:requiresSourceHop a owl:ObjectProperty ;
    rdfs:label "requires source hop"@en ;
    rdfs:comment "Specifies the source hop in a dependency relationship."@en ;
    rdfs:domain ham:CrossHopDependency ;
    rdfs:range ham:HopExecutionPoint .

ham:requiresTargetHop a owl:ObjectProperty ;
    rdfs:label "requires target hop"@en ;
    rdfs:comment "Specifies the target hop in a dependency relationship."@en ;
    rdfs:domain ham:CrossHopDependency ;
    rdfs:range ham:HopExecutionPoint .

ham:hasAdmissionDecision a owl:ObjectProperty ;
    rdfs:label "has admission decision"@en ;
    rdfs:comment "The decision made by HAM for a specific type at a hop."@en ;
    rdfs:domain ham:HopTypeAdmissionRule ;
    rdfs:range ham:AdmissionDecision .

ham:constrainedBy a owl:ObjectProperty ;
    rdfs:label "constrained by"@en ;
    rdfs:comment "Indicates constraints applied to admission decisions."@en ;
    rdfs:domain ham:HopTypeAdmissionRule ;
    rdfs:range doe:PerformanceConstraint .

#################################################################
# DATA PROPERTIES - HAM ATTRIBUTES
#################################################################

###  Hop Identification Properties
ham:hopNumber a owl:DatatypeProperty ;
    rdfs:label "hop number"@en ;
    rdfs:comment "The numerical identifier for a hop (1-8)."@en ;
    rdfs:domain ham:HopExecutionPoint ;
    rdfs:range xsd:integer .

ham:executionPhase a owl:DatatypeProperty ;
    rdfs:label "execution phase"@en ;
    rdfs:comment "The name of the execution phase for a hop."@en ;
    rdfs:domain ham:HopExecutionPoint ;
    rdfs:range xsd:string .

ham:maxTickAllowance a owl:DatatypeProperty ;
    rdfs:label "max tick allowance"@en ;
    rdfs:comment "Maximum ticks allowed for admission processing at this hop."@en ;
    rdfs:domain ham:HopExecutionPoint ;
    rdfs:range xsd:integer .

###  Admission Rule Properties
ham:admissionPriority a owl:DatatypeProperty ;
    rdfs:label "admission priority"@en ;
    rdfs:comment "Priority level for admission rule processing (1-10)."@en ;
    rdfs:domain ham:HopTypeAdmissionRule ;
    rdfs:range xsd:integer .

ham:rejectionReason a owl:DatatypeProperty ;
    rdfs:label "rejection reason"@en ;
    rdfs:comment "Explanation for why a type was rejected at a hop."@en ;
    rdfs:domain ham:HopTypeAdmissionRule ;
    rdfs:range xsd:string .

ham:conditionalRequirement a owl:DatatypeProperty ;
    rdfs:label "conditional requirement"@en ;
    rdfs:comment "Additional requirement for conditional admission."@en ;
    rdfs:domain ham:HopTypeAdmissionRule ;
    rdfs:range xsd:string .

###  Performance Properties  
ham:admissionLatency a owl:DatatypeProperty ;
    rdfs:label "admission latency"@en ;
    rdfs:comment "Time taken to make admission decision (in ticks)."@en ;
    rdfs:domain ham:HopTypeAdmissionRule ;
    rdfs:range xsd:decimal .

ham:throughputLimit a owl:DatatypeProperty ;
    rdfs:label "throughput limit"@en ;
    rdfs:comment "Maximum types processed per tick at this hop."@en ;
    rdfs:domain ham:HopExecutionPoint ;
    rdfs:range xsd:integer .

#################################################################
# HAM DECISION INDIVIDUALS
#################################################################

###  Admission Decisions
ham:ADMIT a ham:AdmissionDecision ;
    rdfs:label "ADMIT"@en ;
    rdfs:comment "Type is admitted for processing at this hop."@en .

ham:REJECT a ham:AdmissionDecision ;
    rdfs:label "REJECT"@en ;
    rdfs:comment "Type is explicitly rejected and cannot proceed."@en .

ham:CONDITIONAL a ham:AdmissionDecision ;
    rdfs:label "CONDITIONAL"@en ;
    rdfs:comment "Type is conditionally admitted pending additional validation."@en .

#################################################################
# SHACL VALIDATION SHAPES - CLOSED WORLD CONSTRAINTS
#################################################################

###  HAM Matrix Validation Shape
ham:HopAdmissionMatrixShape a sh:NodeShape ;
    sh:targetClass ham:HopAdmissionMatrix ;
    rdfs:label "HAM Matrix Validation"@en ;
    rdfs:comment "Validates complete HAM matrix structure and consistency."@en ;
    sh:property [
        sh:path ham:hasAdmissionRule ;
        sh:class ham:HopTypeAdmissionRule ;
        sh:minCount 8 ;  # Must have rules for all 8 hops
        sh:message "HAM matrix must define admission rules for all 8 hops"@en
    ] ;
    sh:closed true .

###  Hop Execution Point Shape - Closed World
ham:HopExecutionPointShape a sh:NodeShape ;
    sh:targetClass ham:HopExecutionPoint ;
    rdfs:label "Hop Execution Point Validation"@en ;
    sh:property [
        sh:path ham:hopNumber ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:maxInclusive 8 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Hop number must be exactly one integer between 1 and 8"@en
    ] ;
    sh:property [
        sh:path ham:maxTickAllowance ;
        sh:datatype xsd:integer ;
        sh:hasValue 1 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Each hop must have exactly 1 tick allowance (Doctrine of 8)"@en
    ] ;
    sh:property [
        sh:path ham:executionPhase ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Each hop must have exactly one execution phase name"@en
    ] ;
    sh:closed true .

###  Hop-1 Admission Constraints (Governance)
ham:Hop1AdmissionShape a sh:NodeShape ;
    sh:targetClass ham:Hop1GovernanceInception ;
    rdfs:label "Hop-1 Governance Admission Constraints"@en ;
    sh:property [
        sh:path ham:admitsType ;
        sh:class ham:Hop1AdmittedTypes ;
        sh:message "Hop-1 can only admit governance and ethical framework types"@en
    ] ;
    sh:property [
        sh:path ham:rejectsType ;
        sh:class ham:UniversallyRejectedTypes ;
        sh:minCount 1 ;
        sh:message "Hop-1 must explicitly reject all blob types"@en
    ] ;
    sh:closed true .

###  Hop-2 Admission Constraints (Identity/Policy)
ham:Hop2AdmissionShape a sh:NodeShape ;
    sh:targetClass ham:Hop2IdentityPolicy ;
    rdfs:label "Hop-2 Identity/Policy Admission Constraints"@en ;
    sh:property [
        sh:path ham:admitsType ;
        sh:class ham:Hop2AdmittedTypes ;
        sh:message "Hop-2 can only admit security policy and identity types"@en
    ] ;
    sh:property [
        sh:path ham:rejectsType ;
        sh:class ham:UniversallyRejectedTypes ;
        sh:minCount 1 ;
        sh:message "Hop-2 must explicitly reject all blob types"@en
    ] ;
    sh:closed true .

###  Hop-3 Admission Constraints (Blueprint)
ham:Hop3AdmissionShape a sh:NodeShape ;
    sh:targetClass ham:Hop3BlueprintCrystal ;
    rdfs:label "Hop-3 Blueprint Admission Constraints"@en ;
    sh:property [
        sh:path ham:admitsType ;
        sh:class ham:Hop3AdmittedTypes ;
        sh:message "Hop-3 can only admit architectural and blueprint types"@en
    ] ;
    sh:property [
        sh:path ham:rejectsType ;
        sh:class ham:UniversallyRejectedTypes ;
        sh:minCount 1 ;
        sh:message "Hop-3 must explicitly reject all blob types"@en
    ] ;
    sh:closed true .

###  Hop-4 Admission Constraints (Budget/Resources)
ham:Hop4AdmissionShape a sh:NodeShape ;
    sh:targetClass ham:Hop4BudgetAllocation ;
    rdfs:label "Hop-4 Budget/Resource Admission Constraints"@en ;
    sh:property [
        sh:path ham:admitsType ;
        sh:class ham:Hop4AdmittedTypes ;
        sh:message "Hop-4 can only admit budget and resource allocation types"@en
    ] ;
    sh:property [
        sh:path ham:rejectsType ;
        sh:class ham:UniversallyRejectedTypes ;
        sh:minCount 1 ;
        sh:message "Hop-4 must explicitly reject all blob types"@en
    ] ;
    sh:closed true .

###  Hop-5 Admission Constraints (Execution)
ham:Hop5AdmissionShape a sh:NodeShape ;
    sh:targetClass ham:Hop5ExecutionPhysics ;
    rdfs:label "Hop-5 Execution Admission Constraints"@en ;
    sh:property [
        sh:path ham:admitsType ;
        sh:class ham:Hop5AdmittedTypes ;
        sh:message "Hop-5 can only admit execution and computational types"@en
    ] ;
    sh:property [
        sh:path ham:rejectsType ;
        sh:class ham:UniversallyRejectedTypes ;
        sh:minCount 1 ;
        sh:message "Hop-5 must explicitly reject all blob types"@en
    ] ;
    sh:closed true .

###  Hop-6 Admission Constraints (Finalization)
ham:Hop6AdmissionShape a sh:NodeShape ;
    sh:targetClass ham:Hop6Finalization ;
    rdfs:label "Hop-6 Finalization Admission Constraints"@en ;
    sh:property [
        sh:path ham:admitsType ;
        sh:class ham:Hop6AdmittedTypes ;
        sh:message "Hop-6 can only admit validation and finalization types"@en
    ] ;
    sh:property [
        sh:path ham:rejectsType ;
        sh:class ham:UniversallyRejectedTypes ;
        sh:minCount 1 ;
        sh:message "Hop-6 must explicitly reject all blob types"@en
    ] ;
    sh:closed true .

###  Hop-7 Admission Constraints (Publication)
ham:Hop7AdmissionShape a sh:NodeShape ;
    sh:targetClass ham:Hop7Publication ;
    rdfs:label "Hop-7 Publication Admission Constraints"@en ;
    sh:property [
        sh:path ham:admitsType ;
        sh:class ham:Hop7AdmittedTypes ;
        sh:message "Hop-7 can only admit publication and dissemination types"@en
    ] ;
    sh:property [
        sh:path ham:rejectsType ;
        sh:class ham:UniversallyRejectedTypes ;
        sh:minCount 1 ;
        sh:message "Hop-7 must explicitly reject all blob types"@en
    ] ;
    sh:closed true .

###  Hop-8 Admission Constraints (Audit/Ops)
ham:Hop8AdmissionShape a sh:NodeShape ;
    sh:targetClass ham:Hop8AuditOps ;
    rdfs:label "Hop-8 Audit/Operations Admission Constraints"@en ;
    sh:property [
        sh:path ham:admitsType ;
        sh:class ham:Hop8AdmittedTypes ;
        sh:message "Hop-8 can only admit audit and operational types"@en
    ] ;
    sh:property [
        sh:path ham:rejectsType ;
        sh:class ham:UniversallyRejectedTypes ;
        sh:minCount 1 ;
        sh:message "Hop-8 must explicitly reject all blob types"@en
    ] ;
    sh:closed true .

###  Cross-Hop Dependency Validation
ham:CrossHopDependencyShape a sh:NodeShape ;
    sh:targetClass ham:CrossHopDependency ;
    rdfs:label "Cross-Hop Dependency Validation"@en ;
    sh:property [
        sh:path ham:requiresSourceHop ;
        sh:class ham:HopExecutionPoint ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Cross-hop dependency must specify exactly one source hop"@en
    ] ;
    sh:property [
        sh:path ham:requiresTargetHop ;
        sh:class ham:HopExecutionPoint ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Cross-hop dependency must specify exactly one target hop"@en
    ] ;
    sh:closed true .

###  No-Blob Rejection Validation
ham:BlobRejectionShape a sh:NodeShape ;
    sh:targetClass ham:UniversallyRejectedTypes ;
    rdfs:label "Blob Rejection Validation"@en ;
    sh:property [
        sh:path owl:disjointWith ;
        sh:hasValue ham:Hop1AdmittedTypes, ham:Hop2AdmittedTypes,
                    ham:Hop3AdmittedTypes, ham:Hop4AdmittedTypes,
                    ham:Hop5AdmittedTypes, ham:Hop6AdmittedTypes,
                    ham:Hop7AdmittedTypes, ham:Hop8AdmittedTypes ;
        sh:minCount 8 ;
        sh:message "Blob types must be disjoint with all hop admission types"@en
    ] ;
    sh:closed true .

###  Type Disjointness Validation
ham:TypeDisjointnessShape a sh:NodeShape ;
    sh:targetNode ham:Hop1AdmittedTypes, ham:Hop2AdmittedTypes,
                  ham:Hop3AdmittedTypes, ham:Hop4AdmittedTypes,
                  ham:Hop5AdmittedTypes, ham:Hop6AdmittedTypes,
                  ham:Hop7AdmittedTypes, ham:Hop8AdmittedTypes ;
    rdfs:label "Type Disjointness Validation"@en ;
    sh:sparql [
        sh:message "Admitted type sets must have minimal overlap to ensure clear boundaries"@en ;
        sh:select """
            SELECT ?type1 ?type2 WHERE {
                ?type1 owl:unionOf ?list1 .
                ?type2 owl:unionOf ?list2 .
                FILTER(?type1 != ?type2)
                ?list1 rdf:rest*/rdf:first ?member .
                ?list2 rdf:rest*/rdf:first ?member .
            }
        """ ;
    ] ;
    sh:closed true .

#################################################################
# HAM MATRIX INSTANCES - COMPLETE ADMISSION CONTROL
#################################################################

###  Main HAM Matrix Instance
ham:ByteStarHAMMatrix a ham:HopAdmissionMatrix ;
    rdfs:label "ByteStar Complete HAM Matrix"@en ;
    rdfs:comment """The primary Hop×Type Admission Matrix for ByteStar providing
    complete type admission control across all 8 execution hops."""@en ;
    ham:hasAdmissionRule ham:Hop1GovernanceAdmissionRule ,
                        ham:Hop2IdentityAdmissionRule ,
                        ham:Hop3BlueprintAdmissionRule ,
                        ham:Hop4BudgetAdmissionRule ,
                        ham:Hop5ExecutionAdmissionRule ,
                        ham:Hop6FinalizationAdmissionRule ,
                        ham:Hop7PublicationAdmissionRule ,
                        ham:Hop8AuditAdmissionRule .

###  Individual Hop Admission Rules
ham:Hop1GovernanceAdmissionRule a ham:HopTypeAdmissionRule ;
    rdfs:label "Hop-1 Governance Admission Rule"@en ;
    ham:hasAdmissionDecision ham:ADMIT ;
    ham:admissionPriority 10 ;
    ham:admissionLatency 0.1 .

ham:Hop2IdentityAdmissionRule a ham:HopTypeAdmissionRule ;
    rdfs:label "Hop-2 Identity/Policy Admission Rule"@en ;
    ham:hasAdmissionDecision ham:ADMIT ;
    ham:admissionPriority 9 ;
    ham:admissionLatency 0.2 .

ham:Hop3BlueprintAdmissionRule a ham:HopTypeAdmissionRule ;
    rdfs:label "Hop-3 Blueprint Admission Rule"@en ;
    ham:hasAdmissionDecision ham:ADMIT ;
    ham:admissionPriority 8 ;
    ham:admissionLatency 0.3 .

ham:Hop4BudgetAdmissionRule a ham:HopTypeAdmissionRule ;
    rdfs:label "Hop-4 Budget/Resource Admission Rule"@en ;
    ham:hasAdmissionDecision ham:ADMIT ;
    ham:admissionPriority 7 ;
    ham:admissionLatency 0.2 .

ham:Hop5ExecutionAdmissionRule a ham:HopTypeAdmissionRule ;
    rdfs:label "Hop-5 Execution Admission Rule"@en ;
    ham:hasAdmissionDecision ham:ADMIT ;
    ham:admissionPriority 10 ;
    ham:admissionLatency 0.4 .

ham:Hop6FinalizationAdmissionRule a ham:HopTypeAdmissionRule ;
    rdfs:label "Hop-6 Finalization Admission Rule"@en ;
    ham:hasAdmissionDecision ham:ADMIT ;
    ham:admissionPriority 9 ;
    ham:admissionLatency 0.3 .

ham:Hop7PublicationAdmissionRule a ham:HopTypeAdmissionRule ;
    rdfs:label "Hop-7 Publication Admission Rule"@en ;
    ham:hasAdmissionDecision ham:ADMIT ;
    ham:admissionPriority 6 ;
    ham:admissionLatency 0.2 .

ham:Hop8AuditAdmissionRule a ham:HopTypeAdmissionRule ;
    rdfs:label "Hop-8 Audit/Operations Admission Rule"@en ;
    ham:hasAdmissionDecision ham:ADMIT ;
    ham:admissionPriority 8 ;
    ham:admissionLatency 0.1 .

###  Hop Execution Point Instances
ham:ByteStarHop1 a ham:Hop1GovernanceInception ;
    ham:hopNumber 1 ;
    ham:executionPhase "governance-inception" ;
    ham:maxTickAllowance 1 ;
    ham:throughputLimit 1000 ;
    ham:admitsType be:EthicalFramework, be:GovernanceRule, doe:DoctrineOfEightLaw ;
    ham:rejectsType ham:UntypedBlob, ham:BinaryBlob, ham:GenericData .

ham:ByteStarHop2 a ham:Hop2IdentityPolicy ;
    ham:hopNumber 2 ;
    ham:executionPhase "identity-policy" ;
    ham:maxTickAllowance 1 ;
    ham:throughputLimit 800 ;
    ham:admitsType sec:SecurityPolicy, sec:CryptographicPolicy, bp:PostQuantumCryptography ;
    ham:rejectsType ham:UntypedBlob, ham:BinaryBlob, ham:GenericData .

ham:ByteStarHop3 a ham:Hop3BlueprintCrystal ;
    ham:hopNumber 3 ;
    ham:executionPhase "blueprint-crystallization" ;
    ham:maxTickAllowance 1 ;
    ham:throughputLimit 600 ;
    ham:admitsType ba:SystemArchitecture, orch:WorkflowPattern, meta:ConceptualModel ;
    ham:rejectsType ham:UntypedBlob, ham:BinaryBlob, ham:GenericData .

ham:ByteStarHop4 a ham:Hop4BudgetAllocation ;
    ham:hopNumber 4 ;
    ham:executionPhase "budget-allocation" ;
    ham:maxTickAllowance 1 ;
    ham:throughputLimit 500 ;
    ham:admitsType orch:ResourceOrchestrator, exec:ResourceConstraint, perf:PerformanceBudget ;
    ham:rejectsType ham:UntypedBlob, ham:BinaryBlob, ham:GenericData .

ham:ByteStarHop5 a ham:Hop5ExecutionPhysics ;
    ham:hopNumber 5 ;
    ham:executionPhase "execution-physics" ;
    ham:maxTickAllowance 1 ;
    ham:throughputLimit 2000 ;
    ham:admitsType exec:ExecutionContext, bf:ByteFlowExecution, ba:ByteActor ;
    ham:rejectsType ham:UntypedBlob, ham:BinaryBlob, ham:GenericData .

ham:ByteStarHop6 a ham:Hop6Finalization ;
    ham:hopNumber 6 ;
    ham:executionPhase "finalization-validation" ;
    ham:maxTickAllowance 1 ;
    ham:throughputLimit 1200 ;
    ham:admitsType perf:PerformanceValidator, meta:ValidationProcess, exec:ValidationProcess ;
    ham:rejectsType ham:UntypedBlob, ham:BinaryBlob, ham:GenericData .

ham:ByteStarHop7 a ham:Hop7Publication ;
    ham:hopNumber 7 ;
    ham:executionPhase "publication-dissemination" ;
    ham:maxTickAllowance 1 ;
    ham:throughputLimit 400 ;
    ham:admitsType meta:MetaKnowledge, perf:PerformanceReport, orch:WorkflowRepository ;
    ham:rejectsType ham:UntypedBlob, ham:BinaryBlob, ham:GenericData .

ham:ByteStarHop8 a ham:Hop8AuditOps ;
    ham:hopNumber 8 ;
    ham:executionPhase "audit-operations" ;
    ham:maxTickAllowance 1 ;
    ham:throughputLimit 300 ;
    ham:admitsType sec:SecurityOperationsCenter, meta:SelfReflectionCapability, be:SystemAuditor ;
    ham:rejectsType ham:UntypedBlob, ham:BinaryBlob, ham:GenericData .

