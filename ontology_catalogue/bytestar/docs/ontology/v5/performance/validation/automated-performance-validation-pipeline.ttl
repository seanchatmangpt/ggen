# Example validation result
:ExampleValidationResult rdf:type owl:NamedIndividual ,
                                  :ValidationResult ;
                        rdfs:label "Example Comprehensive Validation Result"@en ;
                        :validationScore "0.93"^^xsd:double ; # 93% validation score
                        :confidenceLevel "0.95"^^xsd:double ; # 95% confidence
                        dct:created "2025-08-23T12:00:00Z"^^xsd:dateTime .

# Example validation alert
:ExampleValidationAlert rdf:type owl:NamedIndividual ,
                                 :ValidationAlert ;
                       rdfs:label "Example Critical Validation Alert"@en ;
                       :alertSeverity "CRITICAL" ;
                       dct:description "Critical performance regression detected in crystal operations"@en ;
                       dct:created "2025-08-23T12:00:01Z"^^xsd:dateTime .

# Example stage result
:ExampleStageResult rdf:type owl:NamedIndividual ,
                             :StageResult ;
                   rdfs:label "Example Constant-Time Validation Stage Result"@en ;
                   :validationScore "0.98"^^xsd:double ; # 98% stage score
                   :executionTime "PT4M30S"^^xsd:duration ; # 4.5 minute execution
                   dct:created "2025-08-23T12:00:02Z"^^xsd:dateTime .