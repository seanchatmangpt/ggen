@prefix ba: <http://bytestar.ai/ontology/> .
@prefix sre: <http://bytestar.ai/ontology/sre/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix doe: <http://bytestar.ai/ontology/doctrine-of-8/> .

# ============================================
# ByteStar SRE Integration Ontology
# ============================================
# Comprehensive Site Reliability Engineering integration framework
# connecting disaster recovery, observability, upgrades, capacity planning,
# audit, and performance systems into unified operational workflows

sre:sre-integration-ontology a owl:Ontology ;
    dct:title "ByteStar SRE Integration Ontology" ;
    dct:description "Unified Site Reliability Engineering framework integrating all operational systems for comprehensive reliability, observability, and automation" ;
    dct:version "5.0.0" ;
    dct:created "2025-01-XX"^^xsd:date ;
    dct:creator "ByteStar SRE Team" ;
    owl:versionInfo "Phase 5 - Operations Framework" ;
    dct:subject "SRE, Integration, Reliability, Operations, Automation" ;
    owl:imports ba:disaster-recovery-ontology ,
                ba:observability-ontology ,
                ba:zero-downtime-upgrades ,
                ba:capacity-planning-ontology ,
                ba:performance-measurement ,
                ba:audit-system .

# ============================================
# CORE SRE INTEGRATION CLASSES
# ============================================

# Main SRE Architecture
sre:SREPlatform a owl:Class ;
    rdfs:label "SRE Platform" ;
    rdfs:comment "Unified Site Reliability Engineering platform integrating all operational systems" ;
    rdfs:subClassOf ba:IntegrationPlatform ;
    skos:definition "SRE platform provides unified orchestration and management of all reliability, observability, and operational systems" .

sre:ReliabilityEngineering a owl:Class ;
    rdfs:label "Reliability Engineering" ;
    rdfs:comment "Engineering discipline focused on system reliability and availability" ;
    rdfs:subClassOf ba:EngineeringDiscipline ;
    skos:definition "Reliability engineering applies engineering principles to ensure systems meet reliability and availability requirements" .

sre:OperationalWorkflow a owl:Class ;
    rdfs:label "Operational Workflow" ;
    rdfs:comment "Automated workflow for operational procedures and incident response" ;
    rdfs:subClassOf ba:AutomationWorkflow ;
    skos:definition "Operational workflow orchestrates complex procedures across multiple operational systems" .

sre:SREOrchestrator a owl:Class ;
    rdfs:label "SRE Orchestrator" ;
    rdfs:comment "Central orchestration engine for SRE operations" ;
    rdfs:subClassOf ba:OrchestrationEngine ;
    skos:definition "SRE orchestrator coordinates activities across disaster recovery, monitoring, capacity planning, and upgrade systems" .

# ============================================
# SERVICE LEVEL OBJECTIVES FRAMEWORK
# ============================================

sre:ServiceLevelObjective a owl:Class ;
    rdfs:label "Service Level Objective (SLO)" ;
    rdfs:comment "Target reliability level for a service or system component" ;
    rdfs:subClassOf ba:ReliabilityTarget ;
    skos:definition "SLO defines specific, measurable reliability targets that balance user expectations with engineering effort" .

sre:ServiceLevelIndicator a owl:Class ;
    rdfs:label "Service Level Indicator (SLI)" ;
    rdfs:comment "Quantitative measure of service reliability" ;
    rdfs:subClassOf ba:ReliabilityMetric ;
    skos:definition "SLI provides quantitative measurement of key service reliability characteristics" .

sre:ErrorBudget a owl:Class ;
    rdfs:label "Error Budget" ;
    rdfs:comment "Allowable amount of unreliability based on SLO targets" ;
    rdfs:subClassOf ba:ReliabilityAllowance ;
    skos:definition "Error budget quantifies acceptable service unreliability, enabling balance between reliability and feature velocity" .

sre:ErrorBudgetPolicy a owl:Class ;
    rdfs:label "Error Budget Policy" ;
    rdfs:comment "Policy governing actions when error budget is exhausted" ;
    rdfs:subClassOf ba:ReliabilityPolicy ;
    skos:definition "Error budget policy defines escalation procedures and restrictions when error budget consumption exceeds thresholds" .

sre:SLOBurnRate a owl:Class ;
    rdfs:label "SLO Burn Rate" ;
    rdfs:comment "Rate at which error budget is being consumed" ;
    rdfs:subClassOf sre:ServiceLevelIndicator ;
    skos:definition "SLO burn rate measures the rate of error budget consumption, enabling proactive reliability management" .

# ============================================
# INTEGRATED INCIDENT MANAGEMENT
# ============================================

sre:IncidentManagement a owl:Class ;
    rdfs:label "Incident Management" ;
    rdfs:comment "Comprehensive incident detection, response, and resolution system" ;
    rdfs:subClassOf ba:ManagementSystem ;
    skos:definition "Incident management coordinates detection, response, communication, and resolution of service disruptions" .

sre:IncidentDetection a owl:Class ;
    rdfs:label "Incident Detection" ;
    rdfs:comment "Automated system for detecting service incidents" ;
    rdfs:subClassOf ba:DetectionSystem ;
    skos:definition "Incident detection automatically identifies service disruptions through monitoring, alerting, and anomaly detection" .

sre:IncidentResponse a owl:Class ;
    rdfs:label "Incident Response" ;
    rdfs:comment "Coordinated response to service incidents" ;
    rdfs:subClassOf ba:ResponseSystem ;
    skos:definition "Incident response orchestrates technical and communication activities to restore service during incidents" .

sre:PostIncidentReview a owl:Class ;
    rdfs:label "Post Incident Review" ;
    rdfs:comment "Structured review process for learning from incidents" ;
    rdfs:subClassOf ba:ReviewProcess ;
    skos:definition "Post incident review analyzes incidents to identify root causes and prevent future occurrences" .

sre:BlamelessPostmortem a owl:Class ;
    rdfs:label "Blameless Postmortem" ;
    rdfs:comment "Blameless analysis of incidents focused on system improvement" ;
    rdfs:subClassOf sre:PostIncidentReview ;
    skos:definition "Blameless postmortem emphasizes system factors over individual blame to encourage honest incident analysis" .

sre:IncidentEscalation a owl:Class ;
    rdfs:label "Incident Escalation" ;
    rdfs:comment "Escalation procedures for incident severity and duration" ;
    rdfs:subClassOf ba:EscalationProcedure ;
    skos:definition "Incident escalation ensures appropriate expertise and management involvement based on incident characteristics" .

# ============================================
# TOIL AUTOMATION AND OPTIMIZATION
# ============================================

sre:ToilManagement a owl:Class ;
    rdfs:label "Toil Management" ;
    rdfs:comment "System for identifying and eliminating repetitive operational work" ;
    rdfs:subClassOf ba:OptimizationSystem ;
    skos:definition "Toil management identifies repetitive operational tasks and prioritizes automation to improve efficiency" .

sre:ToilIdentification a owl:Class ;
    rdfs:label "Toil Identification" ;
    rdfs:comment "Process for identifying toil in operational workflows" ;
    rdfs:subClassOf ba:AnalysisProcess ;
    skos:definition "Toil identification systematically analyzes operational activities to identify automation opportunities" .

sre:AutomationPipeline a owl:Class ;
    rdfs:label "Automation Pipeline" ;
    rdfs:comment "Pipeline for developing and deploying operational automation" ;
    rdfs:subClassOf ba:AutomationFramework ;
    skos:definition "Automation pipeline streamlines creation, testing, and deployment of operational automation solutions" .

sre:OperationalEfficiency a owl:Class ;
    rdfs:label "Operational Efficiency" ;
    rdfs:comment "Metrics and optimization for operational efficiency" ;
    rdfs:subClassOf ba:EfficiencyMetrics ;
    skos:definition "Operational efficiency measures and optimizes the effectiveness of operational processes and automation" .

sre:RunbookAutomation a owl:Class ;
    rdfs:label "Runbook Automation" ;
    rdfs:comment "Automated execution of operational runbooks" ;
    rdfs:subClassOf sre:AutomationPipeline ;
    skos:definition "Runbook automation converts manual operational procedures into automated workflows" .

# ============================================
# CHANGE MANAGEMENT INTEGRATION
# ============================================

sre:ChangeManagement a owl:Class ;
    rdfs:label "Change Management" ;
    rdfs:comment "Integrated change management across all operational systems" ;
    rdfs:subClassOf ba:ManagementSystem ;
    skos:definition "Change management coordinates and controls modifications across infrastructure, applications, and operational procedures" .

sre:ChangeApproval a owl:Class ;
    rdfs:label "Change Approval" ;
    rdfs:comment "Approval process for operational changes" ;
    rdfs:subClassOf ba:ApprovalProcess ;
    skos:definition "Change approval ensures changes meet reliability, security, and operational requirements before implementation" .

sre:RiskAssessment a owl:Class ;
    rdfs:label "Risk Assessment" ;
    rdfs:comment "Assessment of risks associated with operational changes" ;
    rdfs:subClassOf ba:RiskAnalysis ;
    skos:definition "Risk assessment evaluates potential impact and likelihood of negative outcomes from proposed changes" .

sre:ChangeOrchestration a owl:Class ;
    rdfs:label "Change Orchestration" ;
    rdfs:comment "Orchestration of complex changes across multiple systems" ;
    rdfs:subClassOf ba:OrchestrationEngine ;
    skos:definition "Change orchestration coordinates interdependent changes across disaster recovery, upgrades, capacity, and monitoring systems" .

sre:ChangeValidation a owl:Class ;
    rdfs:label "Change Validation" ;
    rdfs:comment "Validation of change success and impact" ;
    rdfs:subClassOf ba:ValidationSystem ;
    skos:definition "Change validation verifies that changes achieve intended outcomes without negative side effects" .

# ============================================
# UNIFIED MONITORING AND ALERTING
# ============================================

sre:UnifiedMonitoring a owl:Class ;
    rdfs:label "Unified Monitoring" ;
    rdfs:comment "Integrated monitoring across all operational systems" ;
    rdfs:subClassOf ba:MonitoringSystem ;
    skos:definition "Unified monitoring provides centralized visibility into system health, performance, and reliability metrics" .

sre:AlertCorrelation a owl:Class ;
    rdfs:label "Alert Correlation" ;
    rdfs:comment "Correlation of alerts across different operational systems" ;
    rdfs:subClassOf ba:CorrelationEngine ;
    skos:definition "Alert correlation reduces noise by identifying related alerts and providing unified incident context" .

sre:IntelligentAlerting a owl:Class ;
    rdfs:label "Intelligent Alerting" ;
    rdfs:comment "AI-driven alerting with context and prioritization" ;
    rdfs:subClassOf ba:IntelligentSystem ;
    skos:definition "Intelligent alerting uses machine learning to improve alert accuracy, reduce false positives, and provide context" .

sre:MonitoringStrategy a owl:Class ;
    rdfs:label "Monitoring Strategy" ;
    rdfs:comment "Comprehensive strategy for system monitoring and observability" ;
    rdfs:subClassOf ba:Strategy ;
    skos:definition "Monitoring strategy defines what to monitor, how to measure it, and how to respond to different conditions" .

sre:ObservabilityPlatform a owl:Class ;
    rdfs:label "Observability Platform" ;
    rdfs:comment "Unified platform for metrics, logs, traces, and analytics" ;
    rdfs:subClassOf ba:IntegrationPlatform ;
    skos:definition "Observability platform integrates telemetry data from all systems to provide comprehensive system visibility" .

# ============================================
# RELIABILITY TESTING FRAMEWORK
# ============================================

sre:ReliabilityTesting a owl:Class ;
    rdfs:label "Reliability Testing" ;
    rdfs:comment "Comprehensive testing framework for system reliability" ;
    rdfs:subClassOf ba:TestingFramework ;
    skos:definition "Reliability testing validates system behavior under normal and failure conditions" .

sre:ChaosEngineering a owl:Class ;
    rdfs:label "Chaos Engineering" ;
    rdfs:comment "Controlled failure injection to test system resilience" ;
    rdfs:subClassOf sre:ReliabilityTesting ;
    skos:definition "Chaos engineering proactively introduces failures to identify weaknesses and improve system resilience" .

sre:DisasterRecoveryTesting a owl:Class ;
    rdfs:label "Disaster Recovery Testing" ;
    rdfs:comment "Testing of disaster recovery procedures and capabilities" ;
    rdfs:subClassOf sre:ReliabilityTesting ;
    skos:definition "Disaster recovery testing validates the effectiveness of disaster recovery plans and procedures" .

sre:LoadTesting a owl:Class ;
    rdfs:label "Load Testing" ;
    rdfs:comment "Testing system behavior under various load conditions" ;
    rdfs:subClassOf sre:ReliabilityTesting ;
    skos:definition "Load testing validates system performance and reliability under expected and peak load conditions" .

sre:FailureModeTesting a owl:Class ;
    rdfs:label "Failure Mode Testing" ;
    rdfs:comment "Testing specific failure scenarios and recovery procedures" ;
    rdfs:subClassOf sre:ReliabilityTesting ;
    skos:definition "Failure mode testing validates system behavior and recovery for specific failure scenarios" .

# ============================================
# CAPACITY AND PERFORMANCE INTEGRATION
# ============================================

sre:CapacityReliability a owl:Class ;
    rdfs:label "Capacity Reliability" ;
    rdfs:comment "Integration of capacity planning with reliability targets" ;
    rdfs:subClassOf ba:IntegrationFramework ;
    skos:definition "Capacity reliability ensures sufficient capacity exists to meet reliability objectives under all conditions" .

sre:PerformanceReliability a owl:Class ;
    rdfs:label "Performance Reliability" ;
    rdfs:comment "Integration of performance monitoring with reliability management" ;
    rdfs:subClassOf ba:IntegrationFramework ;
    skos:definition "Performance reliability monitors and manages performance to ensure it meets reliability requirements" .

sre:ResourceReliability a owl:Class ;
    rdfs:label "Resource Reliability" ;
    rdfs:comment "Reliability management for infrastructure resources" ;
    rdfs:subClassOf ba:ReliabilityManagement ;
    skos:definition "Resource reliability ensures infrastructure resources meet availability and performance reliability requirements" .

sre:ScalabilityReliability a owl:Class ;
    rdfs:label "Scalability Reliability" ;
    rdfs:comment "Reliable scaling of resources based on demand" ;
    rdfs:subClassOf ba:ScalabilityFramework ;
    skos:definition "Scalability reliability ensures scaling operations maintain system reliability and performance" .

# ============================================
# CORE PROPERTIES
# ============================================

# SLO Properties
sre:sloTarget a owl:DatatypeProperty ;
    rdfs:label "SLO target" ;
    rdfs:comment "Target reliability percentage for SLO" ;
    rdfs:domain sre:ServiceLevelObjective ;
    rdfs:range xsd:decimal .

sre:sliValue a owl:DatatypeProperty ;
    rdfs:label "SLI value" ;
    rdfs:comment "Current measured value of SLI" ;
    rdfs:domain sre:ServiceLevelIndicator ;
    rdfs:range xsd:decimal .

sre:errorBudget a owl:DatatypeProperty ;
    rdfs:label "error budget" ;
    rdfs:comment "Current error budget remaining" ;
    rdfs:domain sre:ErrorBudget ;
    rdfs:range xsd:decimal .

sre:burnRate a owl:DatatypeProperty ;
    rdfs:label "burn rate" ;
    rdfs:comment "Current error budget burn rate" ;
    rdfs:domain sre:SLOBurnRate ;
    rdfs:range xsd:decimal .

# Incident Properties
sre:incidentSeverity a owl:DatatypeProperty ;
    rdfs:label "incident severity" ;
    rdfs:comment "Severity level of incident" ;
    rdfs:domain sre:IncidentManagement ;
    rdfs:range xsd:string .

sre:detectionTime a owl:DatatypeProperty ;
    rdfs:label "detection time" ;
    rdfs:comment "Time to detect incident after occurrence" ;
    rdfs:domain sre:IncidentDetection ;
    rdfs:range xsd:duration .

sre:responseTime a owl:DatatypeProperty ;
    rdfs:label "response time" ;
    rdfs:comment "Time to begin incident response" ;
    rdfs:domain sre:IncidentResponse ;
    rdfs:range xsd:duration .

sre:resolutionTime a owl:DatatypeProperty ;
    rdfs:label "resolution time" ;
    rdfs:comment "Total time to resolve incident" ;
    rdfs:domain sre:IncidentManagement ;
    rdfs:range xsd:duration .

# Toil Properties
sre:toilPercentage a owl:DatatypeProperty ;
    rdfs:label "toil percentage" ;
    rdfs:comment "Percentage of operational work that is toil" ;
    rdfs:domain sre:ToilManagement ;
    rdfs:range xsd:decimal .

sre:automationCoverage a owl:DatatypeProperty ;
    rdfs:label "automation coverage" ;
    rdfs:comment "Percentage of operational tasks automated" ;
    rdfs:domain sre:AutomationPipeline ;
    rdfs:range xsd:decimal .

sre:efficiencyGain a owl:DatatypeProperty ;
    rdfs:label "efficiency gain" ;
    rdfs:comment "Efficiency improvement from automation" ;
    rdfs:domain sre:OperationalEfficiency ;
    rdfs:range xsd:decimal .

# Change Management Properties
sre:changeRisk a owl:DatatypeProperty ;
    rdfs:label "change risk" ;
    rdfs:comment "Risk level of proposed change" ;
    rdfs:domain sre:RiskAssessment ;
    rdfs:range xsd:string .

sre:rollbackProbability a owl:DatatypeProperty ;
    rdfs:label "rollback probability" ;
    rdfs:comment "Probability that change will require rollback" ;
    rdfs:domain sre:RiskAssessment ;
    rdfs:range xsd:decimal .

sre:changeSuccessRate a owl:DatatypeProperty ;
    rdfs:label "change success rate" ;
    rdfs:comment "Historical success rate for similar changes" ;
    rdfs:domain sre:ChangeManagement ;
    rdfs:range xsd:decimal .

# Testing Properties
sre:testCoverage a owl:DatatypeProperty ;
    rdfs:label "test coverage" ;
    rdfs:comment "Coverage of reliability testing" ;
    rdfs:domain sre:ReliabilityTesting ;
    rdfs:range xsd:decimal .

sre:chaosExperimentCount a owl:DatatypeProperty ;
    rdfs:label "chaos experiment count" ;
    rdfs:comment "Number of chaos engineering experiments performed" ;
    rdfs:domain sre:ChaosEngineering ;
    rdfs:range xsd:int .

sre:failureRecoveryTime a owl:DatatypeProperty ;
    rdfs:label "failure recovery time" ;
    rdfs:comment "Time to recover from induced failure" ;
    rdfs:domain sre:FailureModeTesting ;
    rdfs:range xsd:duration .

# ============================================
# OBJECT PROPERTIES
# ============================================

# SRE Platform Relationships
sre:integrates a owl:ObjectProperty ;
    rdfs:label "integrates" ;
    rdfs:comment "System integrated by SRE platform" ;
    rdfs:domain sre:SREPlatform ;
    rdfs:range ba:System .

sre:orchestrates a owl:ObjectProperty ;
    rdfs:label "orchestrates" ;
    rdfs:comment "Workflow orchestrated by SRE orchestrator" ;
    rdfs:domain sre:SREOrchestrator ;
    rdfs:range sre:OperationalWorkflow .

# SLO Relationships
sre:measures a owl:ObjectProperty ;
    rdfs:label "measures" ;
    rdfs:comment "Service measured by SLI" ;
    rdfs:domain sre:ServiceLevelIndicator ;
    rdfs:range ba:Service .

sre:targets a owl:ObjectProperty ;
    rdfs:label "targets" ;
    rdfs:comment "Service targeted by SLO" ;
    rdfs:domain sre:ServiceLevelObjective ;
    rdfs:range ba:Service .

sre:consumes a owl:ObjectProperty ;
    rdfs:label "consumes" ;
    rdfs:comment "Error budget consumed by incident" ;
    rdfs:domain sre:IncidentManagement ;
    rdfs:range sre:ErrorBudget .

# Incident Relationships
sre:detects a owl:ObjectProperty ;
    rdfs:label "detects" ;
    rdfs:comment "Incident detected by detection system" ;
    rdfs:domain sre:IncidentDetection ;
    rdfs:range sre:IncidentManagement .

sre:responds a owl:ObjectProperty ;
    rdfs:label "responds" ;
    rdfs:comment "Incident handled by response system" ;
    rdfs:domain sre:IncidentResponse ;
    rdfs:range sre:IncidentManagement .

sre:escalates a owl:ObjectProperty ;
    rdfs:label "escalates" ;
    rdfs:comment "Incident escalated to higher level" ;
    rdfs:domain sre:IncidentEscalation ;
    rdfs:range sre:IncidentManagement .

# Change Management Relationships
sre:approves a owl:ObjectProperty ;
    rdfs:label "approves" ;
    rdfs:comment "Change approved by approval process" ;
    rdfs:domain sre:ChangeApproval ;
    rdfs:range sre:ChangeManagement .

sre:assesses a owl:ObjectProperty ;
    rdfs:label "assesses" ;
    rdfs:comment "Change assessed by risk assessment" ;
    rdfs:domain sre:RiskAssessment ;
    rdfs:range sre:ChangeManagement .

sre:validates a owl:ObjectProperty ;
    rdfs:label "validates" ;
    rdfs:comment "Change validated by validation system" ;
    rdfs:domain sre:ChangeValidation ;
    rdfs:range sre:ChangeManagement .

# Testing Relationships
sre:tests a owl:ObjectProperty ;
    rdfs:label "tests" ;
    rdfs:comment "System tested by reliability testing" ;
    rdfs:domain sre:ReliabilityTesting ;
    rdfs:range ba:System .

sre:injects a owl:ObjectProperty ;
    rdfs:label "injects" ;
    rdfs:comment "Failure injected by chaos engineering" ;
    rdfs:domain sre:ChaosEngineering ;
    rdfs:range ba:Failure .

# Integration Relationships
sre:coordinates a owl:ObjectProperty ;
    rdfs:label "coordinates" ;
    rdfs:comment "Activity coordinated by SRE system" ;
    rdfs:domain sre:SREPlatform ;
    rdfs:range ba:Activity .

sre:automates a owl:ObjectProperty ;
    rdfs:label "automates" ;
    rdfs:comment "Process automated by automation pipeline" ;
    rdfs:domain sre:AutomationPipeline ;
    rdfs:range ba:Process .

# ============================================
# SHACL VALIDATION SHAPES
# ============================================

sre:SLOTargetShape a sh:NodeShape ;
    sh:targetClass sre:ServiceLevelObjective ;
    rdfs:label "SLO Target Validation" ;
    rdfs:comment "Validates SLO targets are realistic and measurable" ;
    sh:property [
        sh:path sre:sloTarget ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.9 ; # Minimum 90% SLO
        sh:maxInclusive 1.0 ;
        sh:message "SLO target must be between 90% and 100%"
    ] ;
    sh:property [
        sh:path sre:targets ;
        sh:class ba:Service ;
        sh:minCount 1 ;
        sh:message "SLO must target at least one service"
    ] .

sre:ErrorBudgetShape a sh:NodeShape ;
    sh:targetClass sre:ErrorBudget ;
    rdfs:label "Error Budget Validation" ;
    rdfs:comment "Validates error budget calculations and consumption" ;
    sh:property [
        sh:path sre:errorBudget ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Error budget must be between 0% and 100%"
    ] .

sre:IncidentResponseShape a sh:NodeShape ;
    sh:targetClass sre:IncidentResponse ;
    rdfs:label "Incident Response Validation" ;
    rdfs:comment "Validates incident response time requirements" ;
    sh:property [
        sh:path sre:responseTime ;
        sh:datatype xsd:duration ;
        sh:maxInclusive "PT15M"^^xsd:duration ; # Maximum 15 minutes
        sh:message "Incident response time must not exceed 15 minutes"
    ] .

sre:ToilThresholdShape a sh:NodeShape ;
    sh:targetClass sre:ToilManagement ;
    rdfs:label "Toil Threshold Validation" ;
    rdfs:comment "Validates toil levels are within acceptable limits" ;
    sh:property [
        sh:path sre:toilPercentage ;
        sh:datatype xsd:decimal ;
        sh:maxInclusive 0.5 ; # Maximum 50% toil
        sh:message "Toil must not exceed 50% of operational work"
    ] .

sre:ChangeRiskShape a sh:NodeShape ;
    sh:targetClass sre:RiskAssessment ;
    rdfs:label "Change Risk Validation" ;
    rdfs:comment "Validates change risk assessments" ;
    sh:property [
        sh:path sre:changeRisk ;
        sh:datatype xsd:string ;
        sh:in ("LOW" "MEDIUM" "HIGH" "CRITICAL") ;
        sh:message "Change risk must be LOW, MEDIUM, HIGH, or CRITICAL"
    ] ;
    sh:property [
        sh:path sre:rollbackProbability ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "Rollback probability must be between 0.0 and 1.0"
    ] .

# ============================================
# INSTANCES AND EXAMPLES
# ============================================

# Main ByteStar SRE Platform
sre:ByteStarSREPlatform a sre:SREPlatform ;
    rdfs:label "ByteStar SRE Platform" ;
    rdfs:comment "Central SRE platform for ByteStar operations" ;
    ba:operationalStatus "ACTIVE" .

# SRE Orchestrator
sre:ByteStarSREOrchestrator a sre:SREOrchestrator ;
    rdfs:label "ByteStar SRE Orchestrator" ;
    rdfs:comment "Central orchestrator for SRE workflows" ;
    sre:orchestrates sre:ByteStarIncidentWorkflow, sre:ByteStarChangeWorkflow .

# Service Level Objectives
sre:ByteStarAvailabilitySLO a sre:ServiceLevelObjective ;
    rdfs:label "ByteStar Availability SLO" ;
    rdfs:comment "99.9% availability SLO for core services" ;
    sre:sloTarget 0.999 ;
    sre:targets sre:ByteStarCoreService .

sre:ByteStarLatencySLO a sre:ServiceLevelObjective ;
    rdfs:label "ByteStar Latency SLO" ;
    rdfs:comment "95th percentile latency SLO under 8ms" ;
    sre:sloTarget 8.0 ; # 8ms P95 latency
    sre:targets sre:ByteStarCoreService .

# Service Level Indicators
sre:ByteStarAvailabilitySLI a sre:ServiceLevelIndicator ;
    rdfs:label "ByteStar Availability SLI" ;
    rdfs:comment "Current availability measurement" ;
    sre:sliValue 0.9995 ; # 99.95% current availability
    sre:measures sre:ByteStarCoreService .

# Error Budget
sre:ByteStarErrorBudget a sre:ErrorBudget ;
    rdfs:label "ByteStar Error Budget" ;
    rdfs:comment "Monthly error budget for core services" ;
    sre:errorBudget 0.65 ; # 65% error budget remaining
    sre:burnRate 0.05 . # 5% burn rate

# Incident Management
sre:ByteStarIncidentManagement a sre:IncidentManagement ;
    rdfs:label "ByteStar Incident Management" ;
    rdfs:comment "Comprehensive incident management system" ;
    sre:incidentSeverity "MEDIUM" ;
    sre:resolutionTime "PT45M"^^xsd:duration .

sre:ByteStarIncidentDetection a sre:IncidentDetection ;
    rdfs:label "ByteStar Incident Detection" ;
    rdfs:comment "Automated incident detection system" ;
    sre:detectionTime "PT2M"^^xsd:duration .

sre:ByteStarIncidentResponse a sre:IncidentResponse ;
    rdfs:label "ByteStar Incident Response" ;
    rdfs:comment "Coordinated incident response system" ;
    sre:responseTime "PT5M"^^xsd:duration .

# Toil Management
sre:ByteStarToilManagement a sre:ToilManagement ;
    rdfs:label "ByteStar Toil Management" ;
    rdfs:comment "Toil identification and automation system" ;
    sre:toilPercentage 0.25 ; # 25% toil
    sre:automationCoverage 0.75 . # 75% automation coverage

# Change Management
sre:ByteStarChangeManagement a sre:ChangeManagement ;
    rdfs:label "ByteStar Change Management" ;
    rdfs:comment "Integrated change management system" ;
    sre:changeSuccessRate 0.95 . # 95% success rate

sre:ByteStarRiskAssessment a sre:RiskAssessment ;
    rdfs:label "ByteStar Risk Assessment" ;
    rdfs:comment "Change risk assessment system" ;
    sre:changeRisk "MEDIUM" ;
    sre:rollbackProbability 0.05 . # 5% rollback probability

# Reliability Testing
sre:ByteStarChaosEngineering a sre:ChaosEngineering ;
    rdfs:label "ByteStar Chaos Engineering" ;
    rdfs:comment "Chaos engineering for resilience testing" ;
    sre:chaosExperimentCount 24 ; # 24 experiments this quarter
    sre:testCoverage 0.80 . # 80% test coverage

# Operational Workflows
sre:ByteStarIncidentWorkflow a sre:OperationalWorkflow ;
    rdfs:label "ByteStar Incident Workflow" ;
    rdfs:comment "Automated incident response workflow" .

sre:ByteStarChangeWorkflow a sre:OperationalWorkflow ;
    rdfs:label "ByteStar Change Workflow" ;
    rdfs:comment "Automated change management workflow" .

# Service Definition
sre:ByteStarCoreService a ba:Service ;
    rdfs:label "ByteStar Core Service" ;
    rdfs:comment "Primary ByteStar platform services" .