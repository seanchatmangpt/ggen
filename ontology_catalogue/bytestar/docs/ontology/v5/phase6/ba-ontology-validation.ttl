    rdfs:range xsd:nonNegativeInteger .

ba-val:qualityScore
    a owl:DatatypeProperty ;
    rdfs:label "quality score" ;
    rdfs:comment "Overall quality score" ;
    rdfs:range xsd:decimal .

ba-val:efficiencyScore
    a owl:DatatypeProperty ;
    rdfs:label "efficiency score" ;
    rdfs:comment "Validation efficiency score" ;
    rdfs:range xsd:decimal .

# ============================================================================
# SHACL SHAPES FOR VALIDATION FRAMEWORK
# ============================================================================

## Validation Framework Shape
ba-val:ValidationFrameworkShape
    a sh:NodeShape ;
    sh:targetClass ba-val:ValidationFramework ;
    sh:property [
        sh:path ba-val:hasValidationLevel ;
        sh:class ba-val:ValidationLevel ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Validation framework must have at least one validation level"
    ] ;
    sh:property [
        sh:path ba-val:hasValidationStrategy ;
        sh:class ba-val:ValidationStrategy ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Validation framework must have at least one validation strategy"
    ] .

## Validation Rule Shape
ba-val:ValidationRuleShape
    a sh:NodeShape ;
    sh:targetClass ba-val:ValidationRule ;
    sh:property [
        sh:path ba-val:hasRuleType ;
        sh:class ba-val:RuleType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Validation rule must have exactly one rule type"
    ] ;
    sh:property [
        sh:path ba-val:hasSeverity ;
        sh:class ba-val:ValidationSeverity ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Validation rule must have exactly one severity level"
    ] .

## Validation Process Shape
ba-val:ValidationProcessShape
    a sh:NodeShape ;
    sh:targetClass ba-val:ValidationProcess ;
    sh:property [
        sh:path ba-val:hasValidationStep ;
        sh:class ba-val:ValidationStep ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Validation process must have at least one validation step"
    ] ;
    sh:property [
        sh:path ba-val:producesReport ;
        sh:class ba-val:ValidationReport ;
        sh:maxCount 1 ;
        sh:severity sh:Warning ;
        sh:message "Validation process should produce a validation report"
    ] .

## Validation Result Shape
ba-val:ValidationResultShape
    a sh:NodeShape ;
    sh:targetClass ba-val:ValidationResult ;
    sh:property [
        sh:path ba-val:hasResultStatus ;
        sh:class ba-val:ValidationStatus ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Validation result must have exactly one result status"
    ] ;
    sh:property [
        sh:path ba-val:validationTimestamp ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message "Validation result must have exactly one timestamp"
    ] .

## Quality Metrics Shape
ba-val:QualityMetricsShape
    a sh:NodeShape ;
    sh:targetClass ba-val:QualityMetrics ;
    sh:property [
        sh:path ba-val:qualityScore ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:severity sh:Violation ;
        sh:message "Quality score must be between 0.0 and 1.0"
    ] ;
    sh:property [
        sh:path ba-val:hasQualityDimension ;
        sh:class ba-val:QualityDimension ;
        sh:minCount 1 ;
        sh:severity sh:Warning ;
        sh:message "Quality metrics should have at least one quality dimension"
    ] .

# ============================================================================
# VALIDATION FRAMEWORK INSTANCES
# ============================================================================

## Default Validation Framework
ba-val:DefaultValidationFramework
    a ba-val:ValidationFramework ;
    rdfs:label "Default ByteStar Validation Framework" ;
    rdfs:comment "Default comprehensive validation framework for ByteStar ontologies" ;
    ba-val:hasValidationLevel 
        ba-val:SyntaxValidation ,
        ba-val:SemanticValidation ,
        ba-val:PragmaticValidation ,
        ba-val:ConsistencyValidation ;
    ba-val:hasValidationStrategy 
        ba-val:ContinuousValidation ,
        ba-val:BatchValidation ,
        ba-val:IncrementalValidation .

## Core Validation Workflow
ba-val:CoreValidationWorkflow
    a ba-val:ValidationWorkflow ;
    rdfs:label "Core Validation Workflow" ;
    rdfs:comment "Core automated validation workflow for ByteStar" ;
    ba-val:hasWorkflowTrigger 
        ba-val:OntologyChange ,
        ba-val:ScheduledValidation ;
    ba-val:hasWorkflowAction 
        ba-val:RunValidation ,
        ba-val:GenerateReport ,
        ba-val:UpdateMetrics .

# ============================================================================
# END OF ONTOLOGY
# ============================================================================