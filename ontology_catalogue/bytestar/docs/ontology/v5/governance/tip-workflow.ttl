# 15. GOVERNANCE AUTHORITY INSTANCES
# Concrete instances of governance authorities and roles
# ===================================================================

## Core Governance Authorities

tip:TechnicalGovernanceAuthority a tip:TechnicalLead ;
    rdfs:label "Technical Governance Authority" ;
    rdfs:comment "Primary technical authority for type system governance" ;
    foaf:name "Technical Governance Lead" ;
    crypto:hasPublicKey "04a1b2c3d4e5f6..."^^xsd:hexBinary .

tip:SecurityGovernanceAuthority a tip:SecurityAuditor ;
    rdfs:label "Security Governance Authority" ;
    rdfs:comment "Primary security authority for type system governance" ;
    foaf:name "Security Governance Lead" ;
    crypto:hasPublicKey "04f6e5d4c3b2a1..."^^xsd:hexBinary .

tip:CommunityGovernanceAuthority a tip:GovernanceMaintainer ;
    rdfs:label "Community Governance Authority" ;
    rdfs:comment "Primary community representative in governance" ;
    foaf:name "Community Governance Lead" ;
    crypto:hasPublicKey "04123456789abc..."^^xsd:hexBinary .

## Default Quorum Configuration

tip:DefaultOfflineQuorum a tip:OfflineQuorum ;
    rdfs:label "Default Offline Quorum" ;
    rdfs:comment "Default 2-of-3 offline quorum configuration for TIPs" ;
    tip:quorumThreshold 2 ;
    tip:signaturesRequired 3 .

