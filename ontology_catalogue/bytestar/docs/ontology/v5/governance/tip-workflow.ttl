tip:ExampleTIP001 a tip:TypeIntroductionProposal ;
    rdfs:label "TIP-001: Optional Type Extension" ;
    rdfs:comment "Example TIP for introducing optional type extensions" ;
    tip:tipNumber 1 ;
    tip:tipTitle "Introduce Optional Type Extension Mechanism" ;
    tip:tipVersion "1.0.0" ;
    tip:submissionDate "2025-08-23T10:00:00Z"^^xsd:dateTime ;
    tip:reviewDeadline "2025-09-06T23:59:59Z"^^xsd:dateTime ;
    dao:proposedBy tip:ExampleProposer ;
    dao:hasProposalState tip:DraftTIP ;
    tip:hasCrystalType tip:OptionalTypeExtension ;
    tip:requiresQuorum tip:DefaultOfflineQuorum .

