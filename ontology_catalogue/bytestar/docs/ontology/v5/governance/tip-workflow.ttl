tip:OptionalTypeExtension a tip:CrystalTypeDefinition ;
    rdfs:label "Optional Type Extension" ;
    rdfs:comment "Crystal type definition for optional type extension mechanism" ;
    dc:description "Allows types to declare optional extensions that can be dynamically loaded" .

## Example Impact Assessment

tip:ExampleImpactAssessment a tip:ImpactAssessment ;
    rdfs:label "Impact Assessment for TIP-001" ;
    rdfs:comment "Assessment of impact for optional type extension proposal" ;
    tip:hasImpactCategory tip:MinorImpact ;
    tip:impactScore "25.0"^^xsd:decimal ;
    tip:breakingChangeCount 0 ;
    tip:affectedComponents 12 .

