@prefix tip: <https://bytestar.org/ontology/governance/tip#> .
@prefix ba-meta: <https://bytestar.io/ontology/meta/> .
@prefix ba-gov: <https://bytestar.org/ontology/bytestar-governance#> .
@prefix ov: <https://byteactor.org/ontology/versioning/> .
@prefix dao: <http://bytestar.ethos/dao-governance#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix crypto: <https://w3id.org/security#> .

# ===================================================================
# TYPE INTRODUCTION PROPOSAL (TIP) GOVERNANCE SYSTEM
# Complete governance workflow for crystal type evolution with
# cryptographic integrity and transparent decision-making
# ===================================================================

<https://bytestar.org/ontology/governance/tip>
    a owl:Ontology ;
    dc:title "Type Introduction Proposal (TIP) Governance System" ;
    dc:description """Comprehensive governance framework for managing crystal type evolution 
                      through cryptographically verified proposals with offline quorum signatures, 
                      impact assessment, binary transparency, and automated migration paths.""" ;
    dc:creator "ByteStar Governance Authority" ;
    dc:created "2025-08-23"^^xsd:date ;
    dc:version "1.0.0" ;
    owl:versionIRI <https://bytestar.org/ontology/governance/tip/1.0.0> ;
    owl:imports <https://bytestar.io/ontology/meta/>,
                <https://bytestar.org/ontology/bytestar-governance>,
                <https://byteactor.org/ontology/versioning/>,
                <http://bytestar.ethos/dao-governance> ;
    rdfs:seeAlso <https://bytestar.org/docs/tip-governance> .

# ===================================================================
# 1. CORE TIP GOVERNANCE CLASSES
# Foundation classes for TIP governance workflow
# ===================================================================

## Primary TIP Classes

tip:TypeIntroductionProposal a owl:Class ;
    rdfs:label "Type Introduction Proposal" ;
    rdfs:comment """A formal proposal for introducing new crystal types or modifying 
                    existing ones within the ByteStar ecosystem. Requires cryptographic 
                    validation and quorum approval.""" ;
    rdfs:subClassOf dao:Proposal,
                    ba-meta:EvolutionPattern ;
    owl:equivalentClass [
        a owl:Restriction ;
        owl:onProperty tip:hasCrystalType ;
        owl:someValuesFrom tip:CrystalTypeDefinition
    ] .

tip:CrystalTypeDefinition a owl:Class ;
    rdfs:label "Crystal Type Definition" ;
    rdfs:comment """Formal specification of a crystal type including its structure, 
                    behavior, interfaces, and compatibility requirements.""" ;
    rdfs:subClassOf ba-meta:ConceptualModel .

tip:TIPGovernanceAuthority a owl:Class ;
    rdfs:label "TIP Governance Authority" ;
    rdfs:comment """Authority body responsible for overseeing TIP governance processes 
                    and maintaining cryptographic integrity of decisions.""" ;
    rdfs:subClassOf dao:GovernanceAuthority,
                    ba-gov:Validator .

tip:QuorumSignature a owl:Class ;
    rdfs:label "Quorum Signature" ;
    rdfs:comment """Cryptographic signature from governance authority member, 
                    part of offline 2-of-3 quorum requirement.""" ;
    rdfs:subClassOf crypto:Signature .

tip:OfflineQuorum a owl:Class ;
    rdfs:label "Offline Quorum" ;
    rdfs:comment """Collection of offline cryptographic signatures meeting 
                    the 2-of-3 threshold requirement for proposal approval.""" ;
    rdfs:subClassOf dao:QuorumRequirement .

## TIP Workflow States

tip:TIPStatus a owl:Class ;
    rdfs:label "TIP Status" ;
    rdfs:comment "Current status of a Type Introduction Proposal in its lifecycle." ;
    rdfs:subClassOf dao:ProposalState .

tip:DraftTIP a owl:Class ;
    rdfs:label "Draft TIP" ;
    rdfs:comment "TIP in draft stage, undergoing initial review and feedback." ;
    rdfs:subClassOf tip:TIPStatus .

tip:UnderReview a owl:Class ;
    rdfs:label "Under Review" ;
    rdfs:comment "TIP undergoing formal technical and impact assessment." ;
    rdfs:subClassOf tip:TIPStatus .

tip:AwaitingSignatures a owl:Class ;
    rdfs:label "Awaiting Signatures" ;
    rdfs:comment "TIP approved for voting, waiting for offline quorum signatures." ;
    rdfs:subClassOf tip:TIPStatus .

tip:Active a owl:Class ;
    rdfs:label "Active" ;
    rdfs:comment "TIP has quorum signatures and is open for community voting." ;
    rdfs:subClassOf tip:TIPStatus .

tip:Approved a owl:Class ;
    rdfs:label "Approved" ;
    rdfs:comment "TIP has been approved by community vote and quorum signatures." ;
    rdfs:subClassOf tip:TIPStatus .

tip:Rejected a owl:Class ;
    rdfs:label "Rejected" ;
    rdfs:comment "TIP has been rejected by community vote or governance authority." ;
    rdfs:subClassOf tip:TIPStatus .

tip:Implemented a owl:Class ;
    rdfs:label "Implemented" ;
    rdfs:comment "TIP has been successfully implemented in the system." ;
    rdfs:subClassOf tip:TIPStatus .

tip:Withdrawn a owl:Class ;
    rdfs:label "Withdrawn" ;
    rdfs:comment "TIP has been withdrawn by the proposer." ;
    rdfs:subClassOf tip:TIPStatus .

# ===================================================================
# 2. PROPOSAL FORMAT AND REQUIREMENTS
# Structured format for TIP submissions with validation
# ===================================================================

## TIP Structure Components

tip:TIPHeader a owl:Class ;
    rdfs:label "TIP Header" ;
    rdfs:comment "Header section containing TIP metadata and identifiers." ;
    rdfs:subClassOf owl:Thing .

tip:TIPSpecification a owl:Class ;
    rdfs:label "TIP Specification" ;
    rdfs:comment "Technical specification section defining the proposed type changes." ;
    rdfs:subClassOf ba-meta:ConceptualModel .

tip:ImpactAssessment a owl:Class ;
    rdfs:label "Impact Assessment" ;
    rdfs:comment "Assessment of the proposal's impact on existing systems and types." ;
    rdfs:subClassOf ba-meta:Assessment .

tip:BackwardCompatibilityAnalysis a owl:Class ;
    rdfs:label "Backward Compatibility Analysis" ;
    rdfs:comment "Analysis of backward compatibility implications." ;
    rdfs:subClassOf tip:ImpactAssessment .

tip:SecurityAnalysis a owl:Class ;
    rdfs:label "Security Analysis" ;
    rdfs:comment "Security implications and threat analysis for the proposed changes." ;
    rdfs:subClassOf tip:ImpactAssessment .

tip:PerformanceAnalysis a owl:Class ;
    rdfs:label "Performance Analysis" ;
    rdfs:comment "Performance impact analysis for the proposed changes." ;
    rdfs:subClassOf tip:ImpactAssessment .

tip:MigrationPlan a owl:Class ;
    rdfs:label "Migration Plan" ;
    rdfs:comment "Plan for migrating existing types to support new changes." ;
    rdfs:subClassOf ov:MigrationPath .

tip:TestPlan a owl:Class ;
    rdfs:label "Test Plan" ;
    rdfs:comment "Comprehensive testing plan for validating the proposed changes." ;
    rdfs:subClassOf ov:MigrationTest .

## Requirement Classifications

tip:TIPRequirementLevel a owl:Class ;
    rdfs:label "TIP Requirement Level" ;
    rdfs:comment "Classification of requirement importance levels." ;
    rdfs:subClassOf skos:Concept .

tip:MandatoryRequirement a owl:Class ;
    rdfs:label "Mandatory Requirement" ;
    rdfs:comment "Requirements that must be met for TIP approval." ;
    rdfs:subClassOf tip:TIPRequirementLevel .

tip:RecommendedRequirement a owl:Class ;
    rdfs:label "Recommended Requirement" ;
    rdfs:comment "Requirements that are strongly recommended but not mandatory." ;
    rdfs:subClassOf tip:TIPRequirementLevel .

tip:OptionalRequirement a owl:Class ;
    rdfs:label "Optional Requirement" ;
    rdfs:comment "Requirements that may enhance the proposal but are not required." ;
    rdfs:subClassOf tip:TIPRequirementLevel .

# ===================================================================
# 3. OFFLINE QUORUM SIGNATURE SYSTEM
# 2-of-3 offline signature validation framework
# ===================================================================

## Signature Authority Framework

tip:SigningAuthority a owl:Class ;
    rdfs:label "Signing Authority" ;
    rdfs:comment "Authorized entity capable of providing quorum signatures." ;
    rdfs:subClassOf foaf:Agent .

tip:GovernanceMaintainer a owl:Class ;
    rdfs:label "Governance Maintainer" ;
    rdfs:comment "Core maintainer with governance signing authority." ;
    rdfs:subClassOf tip:SigningAuthority .

tip:TechnicalLead a owl:Class ;
    rdfs:label "Technical Lead" ;
    rdfs:comment "Technical leadership with signing authority for technical proposals." ;
    rdfs:subClassOf tip:SigningAuthority .

tip:SecurityAuditor a owl:Class ;
    rdfs:label "Security Auditor" ;
    rdfs:comment "Security expert with authority to sign security-related proposals." ;
    rdfs:subClassOf tip:SigningAuthority .

## Cryptographic Signature Framework

tip:OfflineSignatureSet a owl:Class ;
    rdfs:label "Offline Signature Set" ;
    rdfs:comment "Collection of offline signatures for a TIP proposal." ;
    rdfs:subClassOf crypto:SignatureSet .

tip:ThresholdSignature a owl:Class ;
    rdfs:label "Threshold Signature" ;
    rdfs:comment "Signature scheme requiring minimum threshold (2-of-3) for validity." ;
    rdfs:subClassOf tip:OfflineSignatureSet .

tip:MultiSignature a owl:Class ;
    rdfs:label "Multi-Signature" ;
    rdfs:comment "Cryptographic multi-signature combining multiple authority signatures." ;
    rdfs:subClassOf tip:ThresholdSignature .

tip:SignatureChain a owl:Class ;
    rdfs:label "Signature Chain" ;
    rdfs:comment "Chain of signatures creating tamper-evident proposal history." ;
    rdfs:subClassOf crypto:SignatureChain .

## Signature Validation

tip:SignatureValidator a owl:Class ;
    rdfs:label "Signature Validator" ;
    rdfs:comment "Component responsible for validating cryptographic signatures." ;
    rdfs:subClassOf ba-meta:ValidationProcess .

tip:QuorumValidator a owl:Class ;
    rdfs:label "Quorum Validator" ;
    rdfs:comment "Specialized validator for checking quorum signature requirements." ;
    rdfs:subClassOf tip:SignatureValidator .

tip:SignatureVerificationResult a owl:Class ;
    rdfs:label "Signature Verification Result" ;
    rdfs:comment "Result of signature validation process." ;
    rdfs:subClassOf ba-meta:ValidationResult .

# ===================================================================
# 4. IMPACT ASSESSMENT AND REASONING VALIDATION
# Automated and manual assessment of proposal impacts
# ===================================================================

## Impact Assessment Framework

tip:ImpactAssessmentEngine a owl:Class ;
    rdfs:label "Impact Assessment Engine" ;
    rdfs:comment "Automated engine for analyzing proposal impacts on the system." ;
    rdfs:subClassOf ba-meta:MetaReasoner .

tip:BreakingChangeDetector a owl:Class ;
    rdfs:label "Breaking Change Detector" ;
    rdfs:comment "Component that identifies breaking changes in proposals." ;
    rdfs:subClassOf tip:ImpactAssessmentEngine .

tip:DependencyAnalyzer a owl:Class ;
    rdfs:label "Dependency Analyzer" ;
    rdfs:comment "Analyzes dependencies and potential cascade effects." ;
    rdfs:subClassOf tip:ImpactAssessmentEngine .

tip:CompatibilityChecker a owl:Class ;
    rdfs:label "Compatibility Checker" ;
    rdfs:comment "Checks compatibility with existing crystal types and systems." ;
    rdfs:subClassOf tip:ImpactAssessmentEngine .

## Impact Categories

tip:ImpactCategory a owl:Class ;
    rdfs:label "Impact Category" ;
    rdfs:comment "Category classification for different types of impacts." ;
    rdfs:subClassOf skos:Concept .

tip:CriticalImpact a owl:Class ;
    rdfs:label "Critical Impact" ;
    rdfs:comment "High-severity impact requiring immediate attention and mitigation." ;
    rdfs:subClassOf tip:ImpactCategory .

tip:ModerateImpact a owl:Class ;
    rdfs:label "Moderate Impact" ;
    rdfs:comment "Medium-severity impact requiring consideration and planning." ;
    rdfs:subClassOf tip:ImpactCategory .

tip:MinorImpact a owl:Class ;
    rdfs:label "Minor Impact" ;
    rdfs:comment "Low-severity impact with minimal system disruption." ;
    rdfs:subClassOf tip:ImpactCategory .

tip:NoImpact a owl:Class ;
    rdfs:label "No Impact" ;
    rdfs:comment "Change with no significant impact on existing systems." ;
    rdfs:subClassOf tip:ImpactCategory .

## Reasoning Validation

tip:ReasoningEngine a owl:Class ;
    rdfs:label "Reasoning Engine" ;
    rdfs:comment "Engine for validating logical reasoning in proposals." ;
    rdfs:subClassOf ba-meta:MetaReasoner .

tip:LogicalConsistencyChecker a owl:Class ;
    rdfs:label "Logical Consistency Checker" ;
    rdfs:comment "Validates logical consistency of proposed changes." ;
    rdfs:subClassOf tip:ReasoningEngine .

tip:SemanticValidator a owl:Class ;
    rdfs:label "Semantic Validator" ;
    rdfs:comment "Validates semantic correctness of type definitions." ;
    rdfs:subClassOf tip:ReasoningEngine .

tip:ConstraintValidator a owl:Class ;
    rdfs:label "Constraint Validator" ;
    rdfs:comment "Validates that proposals satisfy system constraints." ;
    rdfs:subClassOf tip:ReasoningEngine .

# ===================================================================
# 5. BINARY TRANSPARENCY LOG INTEGRATION
# Immutable transparency log for governance decisions
# ===================================================================

## Transparency Log Framework

tip:TransparencyLog a owl:Class ;
    rdfs:label "Transparency Log" ;
    rdfs:comment "Immutable log of all governance decisions and their cryptographic proofs." ;
    rdfs:subClassOf prov:Activity .

tip:TIPLogEntry a owl:Class ;
    rdfs:label "TIP Log Entry" ;
    rdfs:comment "Individual entry in the transparency log for a TIP decision." ;
    rdfs:subClassOf prov:ActivityExecution .

tip:LogAnchor a owl:Class ;
    rdfs:label "Log Anchor" ;
    rdfs:comment "Cryptographic anchor point in the transparency log." ;
    rdfs:subClassOf crypto:MerkleTreeRoot .

tip:ProofOfInclusion a owl:Class ;
    rdfs:label "Proof of Inclusion" ;
    rdfs:comment "Cryptographic proof that an entry is included in the transparency log." ;
    rdfs:subClassOf crypto:MerkleProof .

## Binary Transparency Integration

tip:CertificateTransparency a owl:Class ;
    rdfs:label "Certificate Transparency" ;
    rdfs:comment "Certificate transparency mechanism for TIP governance certificates." ;
    rdfs:subClassOf tip:TransparencyLog .

tip:GovernanceCertificate a owl:Class ;
    rdfs:label "Governance Certificate" ;
    rdfs:comment "Certificate representing approved governance decisions." ;
    rdfs:subClassOf crypto:Certificate .

tip:TIPCertificate a owl:Class ;
    rdfs:label "TIP Certificate" ;
    rdfs:comment "Certificate specifically for approved TIP proposals." ;
    rdfs:subClassOf tip:GovernanceCertificate .

tip:TransparencyMonitor a owl:Class ;
    rdfs:label "Transparency Monitor" ;
    rdfs:comment "Component that monitors transparency log integrity." ;
    rdfs:subClassOf ba-meta:ValidationProcess .

# ===================================================================
# 6. BREAKING CHANGE MANAGEMENT
# Framework for managing breaking changes and version transitions
# ===================================================================

## Breaking Change Framework

tip:BreakingChangeManager a owl:Class ;
    rdfs:label "Breaking Change Manager" ;
    rdfs:comment "Component managing the lifecycle of breaking changes." ;
    rdfs:subClassOf ov:ChangeOperation .

tip:BreakingChangeCategory a owl:Class ;
    rdfs:label "Breaking Change Category" ;
    rdfs:comment "Classification of different types of breaking changes." ;
    rdfs:subClassOf ov:BreakingChange .

tip:APIBreakingChange a owl:Class ;
    rdfs:label "API Breaking Change" ;
    rdfs:comment "Breaking change affecting public APIs." ;
    rdfs:subClassOf tip:BreakingChangeCategory .

tip:TypeSignatureBreakingChange a owl:Class ;
    rdfs:label "Type Signature Breaking Change" ;
    rdfs:comment "Breaking change affecting type signatures." ;
    rdfs:subClassOf tip:BreakingChangeCategory .

tip:SemanticBreakingChange a owl:Class ;
    rdfs:label "Semantic Breaking Change" ;
    rdfs:comment "Breaking change affecting semantic meaning." ;
    rdfs:subClassOf tip:BreakingChangeCategory .

## Change Management Process

tip:DeprecationPlan a owl:Class ;
    rdfs:label "Deprecation Plan" ;
    rdfs:comment "Plan for deprecating old interfaces before breaking changes." ;
    rdfs:subClassOf ov:MigrationStrategy .

tip:MigrationWindow a owl:Class ;
    rdfs:label "Migration Window" ;
    rdfs:comment "Time window during which migration must be completed." ;
    rdfs:subClassOf time:Interval .

tip:BackwardCompatibilityShim a owl:Class ;
    rdfs:label "Backward Compatibility Shim" ;
    rdfs:comment "Temporary compatibility layer during migration." ;
    rdfs:subClassOf ov:TransformationScript .

tip:VersionTransition a owl:Class ;
    rdfs:label "Version Transition" ;
    rdfs:comment "Managed transition between incompatible versions." ;
    rdfs:subClassOf ov:MigrationPath .

# ===================================================================
# 7. AUTOMATED MIGRATION TOOLING
# Tools and processes for automated migration
# ===================================================================

## Migration Automation

tip:AutomatedMigrationTool a owl:Class ;
    rdfs:label "Automated Migration Tool" ;
    rdfs:comment "Tool for automatically migrating crystal types and code." ;
    rdfs:subClassOf ov:TransformationScript .

tip:TypeMigrator a owl:Class ;
    rdfs:label "Type Migrator" ;
    rdfs:comment "Specialized tool for migrating type definitions." ;
    rdfs:subClassOf tip:AutomatedMigrationTool .

tip:CodeTransformer a owl:Class ;
    rdfs:label "Code Transformer" ;
    rdfs:comment "Tool for transforming code to work with new types." ;
    rdfs:subClassOf tip:AutomatedMigrationTool .

tip:ConfigurationMigrator a owl:Class ;
    rdfs:label "Configuration Migrator" ;
    rdfs:comment "Tool for migrating configuration files and settings." ;
    rdfs:subClassOf tip:AutomatedMigrationTool .

## Migration Validation

tip:MigrationValidator a owl:Class ;
    rdfs:label "Migration Validator" ;
    rdfs:comment "Tool for validating migration correctness." ;
    rdfs:subClassOf ov:MigrationValidation .

tip:RegressionTester a owl:Class ;
    rdfs:label "Regression Tester" ;
    rdfs:comment "Tool for testing for regressions after migration." ;
    rdfs:subClassOf tip:MigrationValidator .

tip:CompatibilityTester a owl:Class ;
    rdfs:label "Compatibility Tester" ;
    rdfs:comment "Tool for testing compatibility after migration." ;
    rdfs:subClassOf tip:MigrationValidator .

# ===================================================================
# 8. VERSION SAFETY GUARANTEES
# Safety mechanisms and guarantees for version transitions
# ===================================================================

## Safety Framework

tip:SafetyGuarantee a owl:Class ;
    rdfs:label "Safety Guarantee" ;
    rdfs:comment "Formal guarantee about system safety during transitions." ;
    rdfs:subClassOf ba-meta:Constraint .

tip:TypeSafety a owl:Class ;
    rdfs:label "Type Safety" ;
    rdfs:comment "Guarantee that type operations remain safe during transitions." ;
    rdfs:subClassOf tip:SafetyGuarantee .

tip:MemorySafety a owl:Class ;
    rdfs:label "Memory Safety" ;
    rdfs:comment "Guarantee that memory operations remain safe during transitions." ;
    rdfs:subClassOf tip:SafetyGuarantee .

tip:ConcurrencySafety a owl:Class ;
    rdfs:label "Concurrency Safety" ;
    rdfs:comment "Guarantee that concurrent operations remain safe during transitions." ;
    rdfs:subClassOf tip:SafetyGuarantee .

## Safety Verification

tip:SafetyVerifier a owl:Class ;
    rdfs:label "Safety Verifier" ;
    rdfs:comment "Component that verifies safety guarantees are maintained." ;
    rdfs:subClassOf ba-meta:ValidationProcess .

tip:FormalVerifier a owl:Class ;
    rdfs:label "Formal Verifier" ;
    rdfs:comment "Formal verification component for safety properties." ;
    rdfs:subClassOf tip:SafetyVerifier .

tip:StaticAnalyzer a owl:Class ;
    rdfs:label "Static Analyzer" ;
    rdfs:comment "Static analysis component for safety verification." ;
    rdfs:subClassOf tip:SafetyVerifier .

tip:DynamicChecker a owl:Class ;
    rdfs:label "Dynamic Checker" ;
    rdfs:comment "Dynamic checking component for runtime safety." ;
    rdfs:subClassOf tip:SafetyVerifier .

# ===================================================================
# 9. PROPERTIES - CORE TIP RELATIONSHIPS
# Object and data properties for TIP governance
# ===================================================================

## Core TIP Properties

tip:hasCrystalType a owl:ObjectProperty ;
    rdfs:label "has crystal type" ;
    rdfs:comment "Associates a TIP with the crystal type it defines or modifies." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range tip:CrystalTypeDefinition .

tip:hasQuorumSignature a owl:ObjectProperty ;
    rdfs:label "has quorum signature" ;
    rdfs:comment "Associates a TIP with quorum signatures." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range tip:QuorumSignature .

tip:requiresQuorum a owl:ObjectProperty ;
    rdfs:label "requires quorum" ;
    rdfs:comment "Specifies the quorum requirement for a TIP." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range tip:OfflineQuorum .

tip:hasImpactAssessment a owl:ObjectProperty ;
    rdfs:label "has impact assessment" ;
    rdfs:comment "Associates a TIP with its impact assessment." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range tip:ImpactAssessment .

tip:hasMigrationPlan a owl:ObjectProperty ;
    rdfs:label "has migration plan" ;
    rdfs:comment "Associates a TIP with its migration plan." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range tip:MigrationPlan .

## Signature Properties

tip:signedBy a owl:ObjectProperty ;
    rdfs:label "signed by" ;
    rdfs:comment "Identifies who signed a quorum signature." ;
    rdfs:domain tip:QuorumSignature ;
    rdfs:range tip:SigningAuthority .

tip:hasSignatureChain a owl:ObjectProperty ;
    rdfs:label "has signature chain" ;
    rdfs:comment "Associates a TIP with its signature chain." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range tip:SignatureChain .

tip:validatedBy a owl:ObjectProperty ;
    rdfs:label "validated by" ;
    rdfs:comment "Identifies the validator that validated a signature." ;
    rdfs:domain tip:QuorumSignature ;
    rdfs:range tip:SignatureValidator .

## Transparency Log Properties

tip:anchoredIn a owl:ObjectProperty ;
    rdfs:label "anchored in" ;
    rdfs:comment "Associates a TIP with its transparency log anchor." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range tip:LogAnchor .

tip:hasLogEntry a owl:ObjectProperty ;
    rdfs:label "has log entry" ;
    rdfs:comment "Associates a TIP with its transparency log entry." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range tip:TIPLogEntry .

tip:hasProofOfInclusion a owl:ObjectProperty ;
    rdfs:label "has proof of inclusion" ;
    rdfs:comment "Associates a log entry with its proof of inclusion." ;
    rdfs:domain tip:TIPLogEntry ;
    rdfs:range tip:ProofOfInclusion .

## Impact and Safety Properties

tip:hasImpactCategory a owl:ObjectProperty ;
    rdfs:label "has impact category" ;
    rdfs:comment "Classifies the impact level of a proposal." ;
    rdfs:domain tip:ImpactAssessment ;
    rdfs:range tip:ImpactCategory .

tip:identifiesBreakingChange a owl:ObjectProperty ;
    rdfs:label "identifies breaking change" ;
    rdfs:comment "Identifies breaking changes in a proposal." ;
    rdfs:domain tip:ImpactAssessment ;
    rdfs:range tip:BreakingChangeCategory .

tip:hasSafetyGuarantee a owl:ObjectProperty ;
    rdfs:label "has safety guarantee" ;
    rdfs:comment "Associates a TIP with safety guarantees." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range tip:SafetyGuarantee .

tip:verifiedBy a owl:ObjectProperty ;
    rdfs:label "verified by" ;
    rdfs:comment "Identifies the verifier that verified safety properties." ;
    rdfs:domain tip:SafetyGuarantee ;
    rdfs:range tip:SafetyVerifier .

# ===================================================================
# 10. DATA PROPERTIES - TIP METADATA AND METRICS
# Data properties for TIP governance metadata
# ===================================================================

## TIP Identification

tip:tipNumber a owl:DatatypeProperty ;
    rdfs:label "TIP number" ;
    rdfs:comment "Unique numerical identifier for the TIP." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range xsd:positiveInteger .

tip:tipTitle a owl:DatatypeProperty ;
    rdfs:label "TIP title" ;
    rdfs:comment "Title of the Type Introduction Proposal." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range xsd:string .

tip:tipVersion a owl:DatatypeProperty ;
    rdfs:label "TIP version" ;
    rdfs:comment "Version number of the TIP document." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range xsd:string .

## TIP Lifecycle

tip:submissionDate a owl:DatatypeProperty ;
    rdfs:label "submission date" ;
    rdfs:comment "Date when the TIP was submitted." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range xsd:dateTime .

tip:reviewDeadline a owl:DatatypeProperty ;
    rdfs:label "review deadline" ;
    rdfs:comment "Deadline for initial review phase." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range xsd:dateTime .

tip:votingStartDate a owl:DatatypeProperty ;
    rdfs:label "voting start date" ;
    rdfs:comment "Date when voting on the TIP begins." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range xsd:dateTime .

tip:votingEndDate a owl:DatatypeProperty ;
    rdfs:label "voting end date" ;
    rdfs:comment "Date when voting on the TIP ends." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range xsd:dateTime .

tip:implementationDeadline a owl:DatatypeProperty ;
    rdfs:label "implementation deadline" ;
    rdfs:comment "Target deadline for TIP implementation." ;
    rdfs:domain tip:TypeIntroductionProposal ;
    rdfs:range xsd:dateTime .

## Signature Metadata

tip:signatureTimestamp a owl:DatatypeProperty ;
    rdfs:label "signature timestamp" ;
    rdfs:comment "Timestamp when the signature was created." ;
    rdfs:domain tip:QuorumSignature ;
    rdfs:range xsd:dateTime .

tip:signatureHash a owl:DatatypeProperty ;
    rdfs:label "signature hash" ;
    rdfs:comment "Cryptographic hash of the signature." ;
    rdfs:domain tip:QuorumSignature ;
    rdfs:range xsd:hexBinary .

tip:quorumThreshold a owl:DatatypeProperty ;
    rdfs:label "quorum threshold" ;
    rdfs:comment "Minimum number of signatures required for quorum." ;
    rdfs:domain tip:OfflineQuorum ;
    rdfs:range xsd:positiveInteger .

tip:signaturesRequired a owl:DatatypeProperty ;
    rdfs:label "signatures required" ;
    rdfs:comment "Total number of signatures required." ;
    rdfs:domain tip:OfflineQuorum ;
    rdfs:range xsd:positiveInteger .

tip:signaturesReceived a owl:DatatypeProperty ;
    rdfs:label "signatures received" ;
    rdfs:comment "Number of valid signatures received." ;
    rdfs:domain tip:OfflineQuorum ;
    rdfs:range xsd:nonNegativeInteger .

## Impact Metrics

tip:impactScore a owl:DatatypeProperty ;
    rdfs:label "impact score" ;
    rdfs:comment "Numerical score representing impact severity (0-100)." ;
    rdfs:domain tip:ImpactAssessment ;
    rdfs:range [ a rdfs:Datatype ;
                owl:onDatatype xsd:decimal ;
                owl:withRestrictions (
                    [ xsd:minInclusive "0.0"^^xsd:decimal ]
                    [ xsd:maxInclusive "100.0"^^xsd:decimal ]
                ) ] .

tip:breakingChangeCount a owl:DatatypeProperty ;
    rdfs:label "breaking change count" ;
    rdfs:comment "Number of breaking changes identified." ;
    rdfs:domain tip:ImpactAssessment ;
    rdfs:range xsd:nonNegativeInteger .

tip:affectedComponents a owl:DatatypeProperty ;
    rdfs:label "affected components" ;
    rdfs:comment "Number of system components affected by the change." ;
    rdfs:domain tip:ImpactAssessment ;
    rdfs:range xsd:nonNegativeInteger .

## Migration Metrics

tip:migrationComplexity a owl:DatatypeProperty ;
    rdfs:label "migration complexity" ;
    rdfs:comment "Complexity score for migration (1-10)." ;
    rdfs:domain tip:MigrationPlan ;
    rdfs:range [ a rdfs:Datatype ;
                owl:onDatatype xsd:integer ;
                owl:withRestrictions (
                    [ xsd:minInclusive 1 ]
                    [ xsd:maxInclusive 10 ]
                ) ] .

tip:estimatedMigrationTime a owl:DatatypeProperty ;
    rdfs:label "estimated migration time" ;
    rdfs:comment "Estimated time required for migration in hours." ;
    rdfs:domain tip:MigrationPlan ;
    rdfs:range xsd:decimal .

tip:automationLevel a owl:DatatypeProperty ;
    rdfs:label "automation level" ;
    rdfs:comment "Percentage of migration that can be automated (0-100)." ;
    rdfs:domain tip:MigrationPlan ;
    rdfs:range [ a rdfs:Datatype ;
                owl:onDatatype xsd:decimal ;
                owl:withRestrictions (
                    [ xsd:minInclusive "0.0"^^xsd:decimal ]
                    [ xsd:maxInclusive "100.0"^^xsd:decimal ]
                ) ] .

## Transparency Log Metadata

tip:logSequenceNumber a owl:DatatypeProperty ;
    rdfs:label "log sequence number" ;
    rdfs:comment "Sequence number of entry in transparency log." ;
    rdfs:domain tip:TIPLogEntry ;
    rdfs:range xsd:positiveInteger .

tip:merkleTreeHash a owl:DatatypeProperty ;
    rdfs:label "merkle tree hash" ;
    rdfs:comment "Hash of the Merkle tree root at time of entry." ;
    rdfs:domain tip:TIPLogEntry ;
    rdfs:range xsd:hexBinary .

tip:inclusionProof a owl:DatatypeProperty ;
    rdfs:label "inclusion proof" ;
    rdfs:comment "Cryptographic proof of inclusion in transparency log." ;
    rdfs:domain tip:ProofOfInclusion ;
    rdfs:range xsd:hexBinary .

# ===================================================================
# 11. SHACL VALIDATION SHAPES
# Validation constraints for TIP governance integrity
# ===================================================================

## TIP Structure Validation

tip:TypeIntroductionProposalShape a sh:NodeShape ;
    sh:targetClass tip:TypeIntroductionProposal ;
    sh:property [
        sh:path tip:tipNumber ;
        sh:datatype xsd:positiveInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "TIP must have exactly one unique tip number" ;
    ] ;
    sh:property [
        sh:path tip:tipTitle ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minLength 10 ;
        sh:maxLength 200 ;
        sh:message "TIP must have a title between 10-200 characters" ;
    ] ;
    sh:property [
        sh:path tip:hasCrystalType ;
        sh:class tip:CrystalTypeDefinition ;
        sh:minCount 1 ;
        sh:message "TIP must define at least one crystal type" ;
    ] ;
    sh:property [
        sh:path tip:hasImpactAssessment ;
        sh:class tip:ImpactAssessment ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "TIP must have exactly one impact assessment" ;
    ] ;
    sh:property [
        sh:path tip:requiresQuorum ;
        sh:class tip:OfflineQuorum ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "TIP must specify exactly one quorum requirement" ;
    ] .

## Quorum Signature Validation

tip:OfflineQuorumShape a sh:NodeShape ;
    sh:targetClass tip:OfflineQuorum ;
    sh:property [
        sh:path tip:quorumThreshold ;
        sh:datatype xsd:positiveInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 2 ;
        sh:maxInclusive 3 ;
        sh:message "Quorum threshold must be between 2 and 3" ;
    ] ;
    sh:property [
        sh:path tip:signaturesRequired ;
        sh:datatype xsd:positiveInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:hasValue 3 ;
        sh:message "Exactly 3 signatures are required for quorum" ;
    ] .

tip:QuorumSignatureShape a sh:NodeShape ;
    sh:targetClass tip:QuorumSignature ;
    sh:property [
        sh:path tip:signedBy ;
        sh:class tip:SigningAuthority ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Signature must be signed by exactly one authority" ;
    ] ;
    sh:property [
        sh:path tip:signatureTimestamp ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Signature must have exactly one timestamp" ;
    ] ;
    sh:property [
        sh:path tip:signatureHash ;
        sh:datatype xsd:hexBinary ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minLength 64 ;
        sh:maxLength 128 ;
        sh:message "Signature hash must be 64-128 hex characters" ;
    ] .

## Impact Assessment Validation

tip:ImpactAssessmentShape a sh:NodeShape ;
    sh:targetClass tip:ImpactAssessment ;
    sh:property [
        sh:path tip:hasImpactCategory ;
        sh:class tip:ImpactCategory ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Impact assessment must have exactly one impact category" ;
    ] ;
    sh:property [
        sh:path tip:impactScore ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Impact score must be between 0 and 100" ;
    ] ;
    sh:property [
        sh:path tip:breakingChangeCount ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Must specify number of breaking changes (0 or more)" ;
    ] .

## Migration Plan Validation

tip:MigrationPlanShape a sh:NodeShape ;
    sh:targetClass tip:MigrationPlan ;
    sh:property [
        sh:path tip:migrationComplexity ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 1 ;
        sh:maxInclusive 10 ;
        sh:message "Migration complexity must be rated 1-10" ;
    ] ;
    sh:property [
        sh:path tip:estimatedMigrationTime ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:message "Estimated migration time must be non-negative" ;
    ] ;
    sh:property [
        sh:path tip:automationLevel ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Automation level must be 0-100 percent" ;
    ] .

## Transparency Log Validation

tip:TIPLogEntryShape a sh:NodeShape ;
    sh:targetClass tip:TIPLogEntry ;
    sh:property [
        sh:path tip:logSequenceNumber ;
        sh:datatype xsd:positiveInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Log entry must have exactly one sequence number" ;
    ] ;
    sh:property [
        sh:path tip:merkleTreeHash ;
        sh:datatype xsd:hexBinary ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minLength 64 ;
        sh:maxLength 64 ;
        sh:message "Merkle tree hash must be exactly 64 hex characters" ;
    ] ;
    sh:property [
        sh:path tip:hasProofOfInclusion ;
        sh:class tip:ProofOfInclusion ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "Log entry must have exactly one proof of inclusion" ;
    ] .

# ===================================================================
# 12. COMPLEX SPARQL CONSTRAINTS
# Advanced validation rules using SPARQL
# ===================================================================

## Quorum Signature Validation Constraint

tip:QuorumSignatureValidityConstraint a sh:NodeShape ;
    sh:targetClass tip:TypeIntroductionProposal ;
    sh:sparql [
        sh:message "TIP must have at least 2 valid signatures from different authorities" ;
        sh:prefixes tip: ;
        sh:select """
            SELECT $this WHERE {
                $this tip:hasQuorumSignature ?sig1, ?sig2 .
                ?sig1 tip:signedBy ?auth1 .
                ?sig2 tip:signedBy ?auth2 .
                FILTER (?sig1 != ?sig2 && ?auth1 != ?auth2)
            }
            HAVING (COUNT(DISTINCT ?sig1) < 2)
        """ ;
    ] .

## Breaking Change Impact Consistency Constraint

tip:BreakingChangeConsistencyConstraint a sh:NodeShape ;
    sh:targetClass tip:ImpactAssessment ;
    sh:sparql [
        sh:message "Breaking change count must match identified breaking changes" ;
        sh:prefixes tip: ;
        sh:select """
            SELECT $this WHERE {
                $this tip:breakingChangeCount ?count .
                {
                    SELECT $this (COUNT(?change) AS ?actualCount) WHERE {
                        $this tip:identifiesBreakingChange ?change .
                    }
                    GROUP BY $this
                }
                FILTER (?count != ?actualCount)
            }
        """ ;
    ] .

## Migration Automation Level Constraint

tip:MigrationAutomationConstraint a sh:NodeShape ;
    sh:targetClass tip:MigrationPlan ;
    sh:sparql [
        sh:message "High complexity migrations should have lower automation levels" ;
        sh:prefixes tip: ;
        sh:select """
            SELECT $this WHERE {
                $this tip:migrationComplexity ?complexity ;
                      tip:automationLevel ?automation .
                FILTER (?complexity >= 8 && ?automation > 50.0)
            }
        """ ;
    ] .

## Temporal Consistency Constraint

tip:TemporalConsistencyConstraint a sh:NodeShape ;
    sh:targetClass tip:TypeIntroductionProposal ;
    sh:sparql [
        sh:message "Voting start date must be after submission date" ;
        sh:prefixes tip: ;
        sh:select """
            SELECT $this WHERE {
                $this tip:submissionDate ?submitDate ;
                      tip:votingStartDate ?voteDate .
                FILTER (?voteDate <= ?submitDate)
            }
        """ ;
    ] .

# ===================================================================
# 13. GOVERNANCE WORKFLOW RULES
# Formal rules governing the TIP lifecycle
# ===================================================================

## Status Transition Rules

[ a owl:Class ;
  rdfs:comment "Rule: TIP can only move to UnderReview from DraftTIP" ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
      tip:TypeIntroductionProposal
      [ a owl:Restriction ;
        owl:onProperty dao:hasProposalState ;
        owl:hasValue tip:UnderReview ]
    )
  ]
] rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty dao:hasProposalState ;
  owl:someValuesFrom tip:DraftTIP
] .

[ a owl:Class ;
  rdfs:comment "Rule: TIP requires complete impact assessment before voting" ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
      tip:TypeIntroductionProposal
      [ a owl:Restriction ;
        owl:onProperty dao:hasProposalState ;
        owl:hasValue tip:Active ]
    )
  ]
] rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty tip:hasImpactAssessment ;
  owl:someValuesFrom tip:ImpactAssessment
] .

## Quorum Requirements Rule

[ a owl:Class ;
  rdfs:comment "Rule: Active TIP must have valid quorum signatures" ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
      tip:TypeIntroductionProposal
      [ a owl:Restriction ;
        owl:onProperty dao:hasProposalState ;
        owl:hasValue tip:Active ]
    )
  ]
] rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty tip:hasQuorumSignature ;
  owl:minQualifiedCardinality 2 ;
  owl:onClass tip:QuorumSignature
] .

## Breaking Change Approval Rule

[ a owl:Class ;
  rdfs:comment "Rule: Breaking changes require higher approval threshold" ;
  owl:equivalentClass [
    a owl:Class ;
    owl:intersectionOf (
      tip:TypeIntroductionProposal
      [ a owl:Restriction ;
        owl:onProperty tip:hasImpactAssessment ;
        owl:someValuesFrom [
          a owl:Restriction ;
          owl:onProperty tip:breakingChangeCount ;
          owl:someValuesFrom [
            a rdfs:Datatype ;
            owl:onDatatype xsd:nonNegativeInteger ;
            owl:withRestrictions (
              [ xsd:minInclusive 1 ]
            )
          ]
        ]
      ]
    )
  ]
] rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty dao:hasApprovalThreshold ;
  owl:someValuesFrom [
    a rdfs:Datatype ;
    owl:onDatatype xsd:decimal ;
    owl:withRestrictions (
      [ xsd:minInclusive "0.67"^^xsd:decimal ]
    )
  ]
] .

# ===================================================================
# 14. INTEGRATION WITH EXISTING ONTOLOGIES
# Mappings and integration points with existing governance systems
# ===================================================================

## DAO Governance Integration

tip:TIPGovernanceDAO a dao:DAO ;
    rdfs:label "TIP Governance DAO" ;
    rdfs:comment "DAO specifically for governing Type Introduction Proposals" ;
    dao:hasGovernanceToken tip:TIPGovernanceToken ;
    dao:hasQuorumThreshold "0.6"^^xsd:decimal ;
    dao:hasAdminCouncil tip:CoreMaintainerCouncil .

tip:TIPGovernanceToken a dao:GovernanceToken ;
    rdfs:label "TIP Governance Token" ;
    rdfs:comment "Token for participating in TIP governance decisions" ;
    dao:hasTotalSupply 1000000 .

tip:CoreMaintainerCouncil a foaf:Group ;
    rdfs:label "Core Maintainer Council" ;
    rdfs:comment "Council of core maintainers with special governance authority" .

## Versioning System Integration

tip:TIPVersionControl a ov:VersionControlOperation ;
    rdfs:label "TIP Version Control" ;
    rdfs:comment "Version control system specifically for TIP management" ;
    ov:manages tip:TypeIntroductionProposal .

## Meta-Ontology Integration

tip:TIPMetaGovernance a ba-meta:SelfReflectionCapability ;
    rdfs:label "TIP Meta-Governance" ;
    rdfs:comment "Meta-governance capability for self-improving TIP processes" ;
    ba-meta:reflects tip:TypeIntroductionProposal ;
    ba-meta:hasLearningCapability tip:GovernanceLearningAlgorithm .

tip:GovernanceLearningAlgorithm a ba-meta:LearningAlgorithm ;
    rdfs:label "Governance Learning Algorithm" ;
    rdfs:comment "Algorithm for improving governance processes based on outcomes" ;
    ba-meta:hasLearningRate "0.05"^^xsd:decimal .

