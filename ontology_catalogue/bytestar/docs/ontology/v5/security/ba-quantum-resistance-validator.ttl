# ByteStar Quantum Resistance Validator Ontology
# Comprehensive quantum resistance validation across all crystal implementations
# Version: 5.0.0 - Security Domain
# Classification: Post-Quantum Security Validation Framework
# Dependencies: All security frameworks, PQC implementations

@prefix : <https://w3id.org/bytestar/ontology/security/quantum-resistance#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

# Import existing ByteStar ontologies (80% reuse)
@prefix sp: <https://w3id.org/bytestar/ontology/security/policy#> .
@prefix pqc: <https://w3id.org/bytestar/ontology/security/pqc-validation#> .
@prefix scr: <https://w3id.org/bytestar/ontology/security/sidechannel-resistance#> .
@prefix sct: <https://w3id.org/bytestar/ontology/security/sidechannel-testing#> .
@prefix ctv: <https://w3id.org/bytestar/ontology/security/constant-time-validator#> .
@prefix hti: <https://w3id.org/bytestar/ontology/security/hsm-tee-integration#> .
@prefix obs: <https://w3id.org/bytestar/ontology/security/oracle-benchmark#> .
@prefix doe: <https://w3id.org/bytestar/ontology/doctrine#> .
@prefix ba: <https://w3id.org/bytestar/ontology/core#> .

# Ontology Declaration
<https://w3id.org/bytestar/ontology/security/quantum-resistance> 
    rdf:type owl:Ontology ;
    dcterms:title "ByteStar Quantum Resistance Validator"@en ;
    dcterms:description "Comprehensive quantum resistance validation framework for all ByteStar crystal implementations with formal security proofs"@en ;
    dcterms:version "5.0.0" ;
    dcterms:created "2025-08-23"^^xsd:date ;
    dcterms:creator "ByteStar Security Architecture Team" ;
    owl:imports <https://w3id.org/bytestar/ontology/security/pqc-validation>,
                <https://w3id.org/bytestar/ontology/security/sidechannel-resistance>,
                <https://w3id.org/bytestar/ontology/security/oracle-benchmark>,
                <https://w3id.org/bytestar/ontology/security/policy>,
                <https://w3id.org/bytestar/ontology/doctrine> .

# ===== QUANTUM RESISTANCE VALIDATION FRAMEWORK =====

:QuantumResistanceValidator rdf:type owl:Class ;
                            rdfs:subClassOf pqc:PQCValidationFramework ;
                            rdfs:label "Quantum Resistance Validator"@en ;
                            rdfs:comment "Comprehensive framework for validating quantum resistance across all ByteStar crystal types"@en ;
                            :validatesCrystalType ba:TaskCrystal , ba:ResultCrystal , ba:GovernanceCrystal ,
                                                 ba:CapabilityCrystal , ba:InvariantCrystal , ba:DataCrystal ;
                            :operatesWithinConstraint doe:EightTickConstraint ;
                            :hasValidationLevel :NIST_Level1 , :NIST_Level3 , :NIST_Level5 ;
                            :providesAssurance :QuantumResistance , :ClassicalSecurity , :HybridSecurity ;
                            :hasSecurityMargin "128"^^xsd:positiveInteger . # security margin in bits

:CrystalQuantumValidator rdf:type owl:Class ;
                         rdfs:subClassOf :QuantumResistanceValidator ;
                         rdfs:label "Crystal Quantum Validator"@en ;
                         rdfs:comment "Specialized quantum resistance validation for each crystal type"@en ;
                         :analyzesCryptographicBinding :SignatureBinding , :EncryptionBinding , :AuthenticationBinding ;
                         :validatesTransition :LegacyToPQC , :HybridMode , :PurePQC ;
                         :checksCompatibility :BackwardCompatibility , :ForwardCompatibility , :CrossCompatibility ;
                         :hasValidationAccuracy "0.9999"^^xsd:decimal .

:QuantumSecurityAnalyzer rdf:type owl:Class ;
                         rdfs:subClassOf :QuantumResistanceValidator ;
                         rdfs:label "Quantum Security Analyzer"@en ;
                         rdfs:comment "Advanced analysis engine for quantum security properties"@en ;
                         :usesQuantumModel :QuantumCircuitModel , :AdiabaticQuantumModel , :MeasurementBasedModel ;
                         :analyzesComplexity :TimeComplexity , :SpaceComplexity , :QuantumComplexity ;
                         :providesReduction :ClassicalReduction , :QuantumReduction , :PostQuantumReduction ;
                         :hasQuantumAdvantage "false"^^xsd:boolean .

# ===== CRYSTAL-SPECIFIC QUANTUM VALIDATION =====

:TaskCrystalQuantumValidator rdf:type owl:Class ;
                             rdfs:subClassOf :CrystalQuantumValidator ;
                             rdfs:label "Task Crystal Quantum Validator"@en ;
                             rdfs:comment "Quantum resistance validation for Task Crystal implementations"@en ;
                             :validatesField :TaskHeader , :TaskMetadata , :TaskSignature , :TaskEncryption ;
                             :checksAlgorithm :Kyber1024 , :Dilithium5 , :SPHINCS_Plus_SHA256_256s ;
                             :hasPerformanceTarget "8"^^xsd:positiveInteger ; # ticks
                             :providesAttestation :QuantumSafeAttestation .

:ResultCrystalQuantumValidator rdf:type owl:Class ;
                               rdfs:subClassOf :CrystalQuantumValidator ;
                               rdfs:label "Result Crystal Quantum Validator"@en ;
                               rdfs:comment "Quantum resistance validation for Result Crystal implementations"@en ;
                               :validatesField :ResultHeader , :ResultData , :ResultSignature , :ResultIntegrity ;
                               :checksAlgorithm :Kyber1024 , :Dilithium5 , :Falcon1024 ;
                               :hasPerformanceTarget "8"^^xsd:positiveInteger ; # ticks
                               :providesAttestation :QuantumSafeExecution .

:GovernanceCrystalQuantumValidator rdf:type owl:Class ;
                                   rdfs:subClassOf :CrystalQuantumValidator ;
                                   rdfs:label "Governance Crystal Quantum Validator"@en ;
                                   rdfs:comment "Quantum resistance validation for Governance Crystal implementations"@en ;
                                   :validatesField :PolicySignature , :ComplianceProof , :AuditSignature ;
                                   :checksAlgorithm :Dilithium5 , :SPHINCS_Plus_SHA256_256s ;
                                   :hasPerformanceTarget "8"^^xsd:positiveInteger ; # ticks
                                   :providesAttestation :QuantumSafeGovernance .

:CapabilityCrystalQuantumValidator rdf:type owl:Class ;
                                   rdfs:subClassOf :CrystalQuantumValidator ;
                                   rdfs:label "Capability Crystal Quantum Validator"@en ;
                                   rdfs:comment "Quantum resistance validation for Capability Crystal implementations"@en ;
                                   :validatesField :CapabilityToken , :PermissionSignature , :DelegationProof ;
                                   :checksAlgorithm :Kyber1024 , :Dilithium5 , :Falcon1024 ;
                                   :hasPerformanceTarget "8"^^xsd:positiveInteger ; # ticks
                                   :providesAttestation :QuantumSafeCapability .

:InvariantCrystalQuantumValidator rdf:type owl:Class ;
                                  rdfs:subClassOf :CrystalQuantumValidator ;
                                  rdfs:label "Invariant Crystal Quantum Validator"@en ;
                                  rdfs:comment "Quantum resistance validation for Invariant Crystal implementations"@en ;
                                  :validatesField :InvariantProof , :ConsistencySignature , :StateTransition ;
                                  :checksAlgorithm :SPHINCS_Plus_SHA256_256s , :Dilithium5 ;
                                  :hasPerformanceTarget "8"^^xsd:positiveInteger ; # ticks
                                  :providesAttestation :QuantumSafeInvariant .

# ===== POST-QUANTUM ALGORITHM VALIDATION =====

:PQCAlgorithmValidator rdf:type owl:Class ;
                       rdfs:subClassOf pqc:PQCAlgorithmValidation ;
                       rdfs:label "PQC Algorithm Validator"@en ;
                       rdfs:comment "Comprehensive validation of post-quantum cryptographic algorithms"@en ;
                       :validatesFamily :LatticeBased , :CodeBased , :MultivariateBased , :HashBased , :IsogenyBased ;
                       :checksProperty :QuantumHardness , :ClassicalHardness , :ImplementationSecurity ;
                       :hasSecurityLevel :NIST_Level1 , :NIST_Level3 , :NIST_Level5 ;
                       :providesAnalysis :SecurityAnalysis , :PerformanceAnalysis , :ImplementationAnalysis .

:KyberValidator rdf:type owl:Class ;
                rdfs:subClassOf :PQCAlgorithmValidator ;
                rdfs:label "Kyber Validator"@en ;
                rdfs:comment "NIST Kyber KEM algorithm validation"@en ;
                :validatesVariant :Kyber512 , :Kyber768 , :Kyber1024 ;
                :checksHardness :ModuleLWE , :LWE , :SVP ;
                :hasLatticeParameters :n , :k , :q , :eta1 , :eta2 , :du , :dv ;
                :providesSecurityReduction :ModuleLWE_to_LWE , :LWE_to_SVP ;
                :hasQuantumSecurityLevel "128"^^xsd:positiveInteger , "192"^^xsd:positiveInteger , "256"^^xsd:positiveInteger .

:DilithiumValidator rdf:type owl:Class ;
                    rdfs:subClassOf :PQCAlgorithmValidator ;
                    rdfs:label "Dilithium Validator"@en ;
                    rdfs:comment "NIST Dilithium signature algorithm validation"@en ;
                    :validatesVariant :Dilithium2 , :Dilithium3 , :Dilithium5 ;
                    :checksHardness :SIS , :ModuleLWE , :ModuleSIS ;
                    :hasLatticeParameters :n , :k , :l , :eta , :tau , :beta , :gamma1 , :gamma2 ;
                    :providesSecurityReduction :SIS_to_SVP , :MLWE_to_LWE ;
                    :hasQuantumSecurityLevel "128"^^xsd:positiveInteger , "192"^^xsd:positiveInteger , "256"^^xsd:positiveInteger .

:FalconValidator rdf:type owl:Class ;
                 rdfs:subClassOf :PQCAlgorithmValidator ;
                 rdfs:label "Falcon Validator"@en ;
                 rdfs:comment "NIST Falcon signature algorithm validation"@en ;
                 :validatesVariant :Falcon512 , :Falcon1024 ;
                 :checksHardness :NTRU , :SIS , :SVP ;
                 :hasLatticeParameters :n , :q , :sigma , :M ;
                 :providesSecurityReduction :NTRU_to_SVP , :SIS_to_SVP ;
                 :hasQuantumSecurityLevel "103"^^xsd:positiveInteger , "158"^^xsd:positiveInteger ;
                 :hasCompactSignature "true"^^xsd:boolean .

:SPHINCSPlusValidator rdf:type owl:Class ;
                      rdfs:subClassOf :PQCAlgorithmValidator ;
                      rdfs:label "SPHINCS+ Validator"@en ;
                      rdfs:comment "NIST SPHINCS+ hash-based signature algorithm validation"@en ;
                      :validatesVariant :SPHINCS_Plus_SHA256_128s , :SPHINCS_Plus_SHA256_256s ;
                      :checksHardness :HashFunction , :OneWayFunction , :CollisionResistance ;
                      :hasParameters :n , :h , :d , :a , :k , :w ;
                      :providesSecurityReduction :HashSecurity , :PreimageResistance ;
                      :hasQuantumSecurityLevel "128"^^xsd:positiveInteger , "256"^^xsd:positiveInteger ;
                      :hasStatelessSecurity "true"^^xsd:boolean .

# ===== QUANTUM ATTACK SIMULATION =====

:QuantumAttackSimulator rdf:type owl:Class ;
                        rdfs:subClassOf obs:AttackSimulationFramework ;
                        rdfs:label "Quantum Attack Simulator"@en ;
                        rdfs:comment "Simulation framework for quantum attacks on cryptographic systems"@en ;
                        :simulatesAlgorithm :Shors , :Grovers , :Simons , :BernsteinVazirani , :DeutschJozsa ;
                        :hasQuantumResources :Qubits , :QuantumGates , :QuantumTime , :QuantumMemory ;
                        :modelsPlatform :QuantumCircuitModel , :AdiabaticModel , :TopologicalModel ;
                        :hasQuantumAdvantage "true"^^xsd:boolean ;
                        :providesComplexity :QuantumComplexity , :ClassicalComplexity .

:ShorsAlgorithmSimulator rdf:type owl:Class ;
                         rdfs:subClassOf :QuantumAttackSimulator ;
                         rdfs:label "Shor's Algorithm Simulator"@en ;
                         rdfs:comment "Simulation of Shor's quantum factoring algorithm"@en ;
                         :attacksAlgorithm :RSA , :DiffieHellman , :ECDH , :DSA , :ECDSA ;
                         :requiresQubits "4096"^^xsd:positiveInteger ; # for RSA-2048
                         :hasTimeComplexity "O(n^3)"^^xsd:string ;
                         :providesSpeedup :ExponentialSpeedup ;
                         :breaksClassicalCrypto "true"^^xsd:boolean .

:GroversAlgorithmSimulator rdf:type owl:Class ;
                           rdfs:subClassOf :QuantumAttackSimulator ;
                           rdfs:label "Grover's Algorithm Simulator"@en ;
                           rdfs:comment "Simulation of Grover's quantum search algorithm"@en ;
                           :attacksAlgorithm :AES , :SHA256 , :SHA3 , :SymmetricCrypto ;
                           :requiresQubits "256"^^xsd:positiveInteger ; # for AES-256
                           :hasTimeComplexity "O(sqrt(N))"^^xsd:string ;
                           :providesSpeedup :QuadraticSpeedup ;
                           :reducesSecurityLevel "50"^^xsd:positiveInteger . # percentage

:QuantumPeriodFinding rdf:type owl:Class ;
                      rdfs:subClassOf :QuantumAttackSimulator ;
                      rdfs:label "Quantum Period Finding"@en ;
                      rdfs:comment "Quantum period finding algorithm for cryptanalysis"@en ;
                      :attacksAlgorithm :RSA , :DiscreteLogarithm , :EllipticCurveDiscreteLorg ;
                      :usesQuantumFourierTransform "true"^^xsd:boolean ;
                      :hasQuantumParallelism "true"^^xsd:boolean ;
                      :providesExponentialSpeedup "true"^^xsd:boolean .

# ===== HYBRID CRYPTOGRAPHY VALIDATION =====

:HybridCryptographyValidator rdf:type owl:Class ;
                             rdfs:subClassOf :QuantumResistanceValidator ;
                             rdfs:label "Hybrid Cryptography Validator"@en ;
                             rdfs:comment "Validation of hybrid classical-quantum cryptographic systems"@en ;
                             :combinesAlgorithm :ClassicalAlgorithm , :PostQuantumAlgorithm ;
                             :providesTransition :GradualTransition , :ImmediateTransition ;
                             :hasCompositionMode :Parallel , :Sequential , :Nested ;
                             :maintainsCompatibility :BackwardCompatibility , :ForwardCompatibility ;
                             :hasSecurityLevel :MinimumSecurity , :MaximumSecurity .

:X25519KyberHybrid rdf:type owl:Class ;
                   rdfs:subClassOf :HybridCryptographyValidator ;
                   rdfs:label "X25519-Kyber Hybrid"@en ;
                   rdfs:comment "Hybrid key exchange combining X25519 and Kyber"@en ;
                   :combinesAlgorithm :X25519 , :Kyber768 ;
                   :providesProperty :PerfectForwardSecrecy , :QuantumResistance ;
                   :hasKeySize "64"^^xsd:positiveInteger ; # bytes (32 + 32)
                   :usesKDF :HKDF_SHA256 ;
                   :hasQuantumSecurity "128"^^xsd:positiveInteger . # bits

:RSADilithiumHybrid rdf:type owl:Class ;
                    rdfs:subClassOf :HybridCryptographyValidator ;
                    rdfs:label "RSA-Dilithium Hybrid"@en ;
                    rdfs:comment "Hybrid signature combining RSA and Dilithium"@en ;
                    :combinesAlgorithm :RSA2048 , :Dilithium3 ;
                    :providesProperty :ClassicalSecurity , :QuantumResistance ;
                    :hasSignatureSize "4000"^^xsd:positiveInteger ; # bytes
                    :usesHashFunction :SHA256 ;
                    :hasQuantumSecurity "192"^^xsd:positiveInteger . # bits

# ===== CRYPTANALYSIS RESISTANCE =====

:CryptanalysisResistanceValidator rdf:type owl:Class ;
                                  rdfs:subClassOf :QuantumResistanceValidator ;
                                  rdfs:label "Cryptanalysis Resistance Validator"@en ;
                                  rdfs:comment "Validation of resistance against various cryptanalytic attacks"@en ;
                                  :validatesAgainst :ClassicalCryptanalysis , :QuantumCryptanalysis ,
                                                   :AlgebraicAttacks , :LatticeAttacks , :StatisticalAttacks ;
                                  :checksHardness :ComputationalHardness , :InformationTheoreticHardness ;
                                  :providesReduction :TightReduction , :LooseReduction ;
                                  :hasSecurityProof :ProvenSecure , :HeuristicallySeccure .

:LatticeAttackValidator rdf:type owl:Class ;
                        rdfs:subClassOf :CryptanalysisResistanceValidator ;
                        rdfs:label "Lattice Attack Validator"@en ;
                        rdfs:comment "Validation against lattice-based cryptanalytic attacks"@en ;
                        :validatesAgainst :LLL , :BKZ , :Sieve , :Enum , :SVP , :CVP ;
                        :checksComplexity :LatticeComplexity , :BKZComplexity , :SieveComplexity ;
                        :hasSecurityEstimate :CoreSVP , :BKZ2_0 , :ProgressiveBKZ ;
                        :providesMargin :SecurityMargin , :QuantumMargin .

:AlgebraicAttackValidator rdf:type owl:Class ;
                          rdfs:subClassOf :CryptanalysisResistanceValidator ;
                          rdfs:label "Algebraic Attack Validator"@en ;
                          rdfs:comment "Validation against algebraic cryptanalytic attacks"@en ;
                          :validatesAgainst :Groebner , :LinearAlgebra , :F4 , :F5 , :XL , :Macaulay ;
                          :checksComplexity :PolynomialSystemComplexity , :FieldComplexity ;
                          :hasAlgebraicImmunity :LinearAlgebra , :QuadraticForms , :HigherDegree ;
                          :providesDegreeEstimate :RegularityDegree , :SolvesDegree .

# ===== PERFORMANCE ANALYSIS =====

:QuantumPerformanceAnalyzer rdf:type owl:Class ;
                            rdfs:subClassOf ba:PerformanceAnalyzer ;
                            rdfs:label "Quantum Performance Analyzer"@en ;
                            rdfs:comment "Performance analysis of quantum-resistant implementations"@en ;
                            :analyzesMetric :KeyGenerationTime , :SigningTime , :VerificationTime ,
                                          :EncapsulationTime , :DecapsulationTime ;
                            :operatesWithinConstraint doe:EightTickConstraint ;
                            :hasPerformanceTarget :Throughput , :Latency , :MemoryUsage , :CodeSize ;
                            :providesComparison :ClassicalVsPQC , :PQCVsPQC , :HybridVsPure .

:PQCPerformanceBenchmark rdf:type owl:Class ;
                         rdfs:subClassOf :QuantumPerformanceAnalyzer ;
                         rdfs:label "PQC Performance Benchmark"@en ;
                         rdfs:comment "Comprehensive performance benchmarking of PQC algorithms"@en ;
                         :benchmarksOperation :KeyGeneration , :Signing , :Verification , :Encryption , :Decryption ;
                         :measuresPlatform :Intel , :AMD , :ARM , :RISC_V ;
                         :hasOptimization :Reference , :Optimized , :AVX2 , :AVX512 , :NEON ;
                         :providesMetrics :CyclesPerOperation , :OperationsPerSecond , :BytesPerSecond .

# ===== COMPLIANCE AND CERTIFICATION =====

:QuantumReadinessValidator rdf:type owl:Class ;
                           rdfs:subClassOf sp:ComplianceValidator ;
                           rdfs:label "Quantum Readiness Validator"@en ;
                           rdfs:comment "Validation of quantum readiness and compliance"@en ;
                           :checksReadiness :AlgorithmReadiness , :ImplementationReadiness , :DeploymentReadiness ;
                           :validatesStandard :NIST_PQC , :FIPS_203 , :FIPS_204 , :FIPS_205 ;
                           :hasTransitionPlan :PhaseOut , :PhaseIn , :Parallel , :Migration ;
                           :providesTimeline :ImmediateRisk , :NearTerm , :LongTerm .

:NISTPostQuantumValidator rdf:type owl:Class ;
                          rdfs:subClassOf :QuantumReadinessValidator ;
                          rdfs:label "NIST Post-Quantum Validator"@en ;
                          rdfs:comment "NIST post-quantum cryptography standard validation"@en ;
                          :validatesStandard :FIPS_203_Kyber , :FIPS_204_Dilithium , :FIPS_205_SPHINCS_Plus ;
                          :checksCompliance :ParameterSets , :TestVectors , :SecurityLevels ;
                          :hasNISTLevel :Level1 , :Level3 , :Level5 ;
                          :providesAttestation :NISTCompliant , :FIPSApproved .

# ===== QUANTUM THREAT MODELING =====

:QuantumThreatModel rdf:type owl:Class ;
                    rdfs:subClassOf sp:ThreatModel ;
                    rdfs:label "Quantum Threat Model"@en ;
                    rdfs:comment "Comprehensive threat modeling for quantum computing risks"@en ;
                    :modelsThreat :NISQ , :UniversalQuantumComputer , :CryptanalyticallyRelevantQuantumComputer ;
                    :hasTimeframe :Current , :NearTerm , :MidTerm , :LongTerm ;
                    :assessesCapability :QuantumSupremacy , :QuantumAdvantage , :CryptographicRelevance ;
                    :providesRiskLevel :Low , :Medium , :High , :Critical .

:CRQCThreatModel rdf:type owl:Class ;
                 rdfs:subClassOf :QuantumThreatModel ;
                 rdfs:label "CRQC Threat Model"@en ;
                 rdfs:comment "Cryptographically Relevant Quantum Computer threat model"@en ;
                 :requiresQubits "4096"^^xsd:positiveInteger ; # logical qubits
                 :hasCoherenceTime "1000"^^xsd:positiveInteger ; # seconds
                 :hasGateCount "10000000000"^^xsd:positiveInteger ; # gates
                 :breaksAlgorithm :RSA , :ECDH , :DSA , :ECDSA ;
                 :hasTimeEstimate "2030-2040"^^xsd:string .

:NISQThreatModel rdf:type owl:Class ;
                 rdfs:subClassOf :QuantumThreatModel ;
                 rdfs:label "NISQ Threat Model"@en ;
                 rdfs:comment "Noisy Intermediate-Scale Quantum computer threat model"@en ;
                 :hasQubits "1000"^^xsd:positiveInteger ;
                 :hasNoiseLevel "0.001"^^xsd:decimal ; # error rate
                 :hasLimitedCoherence "true"^^xsd:boolean ;
                 :breaksLimitedCrypto "false"^^xsd:boolean ;
                 :hasCurrentRelevance "true"^^xsd:boolean .

# ===== SECURITY PROOFS AND FORMAL VERIFICATION =====

:QuantumSecurityProof rdf:type owl:Class ;
                      rdfs:subClassOf sp:SecurityProof ;
                      rdfs:label "Quantum Security Proof"@en ;
                      rdfs:comment "Formal security proofs for quantum resistance"@en ;
                      :providesProof :ReductionProof , :GameBasedProof , :SimulationProof ;
                      :hasSecurityNotion :IND_CCA , :EUF_CMA , :OW_CPA , :IND_CPA ;
                      :usesModel :RandomOracleModel , :StandardModel , :QuantumRandomOracleModel ;
                      :hasSecurityLevel :Tight , :Loose , :Asymptotic , :Concrete .

:LatticeSecurityProof rdf:type owl:Class ;
                      rdfs:subClassOf :QuantumSecurityProof ;
                      rdfs:label "Lattice Security Proof"@en ;
                      rdfs:comment "Security proofs for lattice-based cryptography"@en ;
                      :reducesTo :LWE , :SIS , :NTRU , :SVP , :CVP ;
                      :hasReductionType :WorstCase , :AverageCase , :RandomSelfReducible ;
                      :providesApproximationFactor :Polynomial , :Subexponential , :Exponential ;
                      :hasQuantumReduction "true"^^xsd:boolean .

:HashSecurityProof rdf:type owl:Class ;
                   rdfs:subClassOf :QuantumSecurityProof ;
                   rdfs:label "Hash Security Proof"@en ;
                   rdfs:comment "Security proofs for hash-based cryptography"@en ;
                   :reducesTo :HashFunction , :OneWayFunction , :CollisionResistance , :PreimageResistance ;
                   :hasSecurityLevel :InformationTheoretic , :ComputationalSecurity ;
                   :providesQuantumSecurity "true"^^xsd:boolean ;
                   :isStateless "true"^^xsd:boolean .

# ===== INTEGRATION TESTING =====

:QuantumIntegrationTester rdf:type owl:Class ;
                          rdfs:subClassOf sct:TestExecutionEngine ;
                          rdfs:label "Quantum Integration Tester"@en ;
                          rdfs:comment "Integration testing framework for quantum-resistant implementations"@en ;
                          :testsIntegration :CrystalIntegration , :SystemIntegration , :APIIntegration ;
                          :operatesWithinConstraint doe:EightTickConstraint ;
                          :hasTestCoverage "0.99"^^xsd:decimal ;
                          :providesRegression "true"^^xsd:boolean ;
                          :supportsAutomation "true"^^xsd:boolean .

:CrystalQuantumIntegration rdf:type owl:Class ;
                           rdfs:subClassOf :QuantumIntegrationTester ;
                           rdfs:label "Crystal Quantum Integration"@en ;
                           rdfs:comment "Integration testing of quantum-resistant cryptography with crystals"@en ;
                           :testsCrystalType ba:TaskCrystal , ba:ResultCrystal , ba:GovernanceCrystal ,
                                           ba:CapabilityCrystal , ba:InvariantCrystal ;
                           :checksInteroperability :CrystalToCrystal , :CrystalToSystem , :SystemToCrystal ;
                           :validatesPerformance :Throughput , :Latency , :ResourceUsage ;
                           :hasPerformanceTarget "8"^^xsd:positiveInteger . # ticks

# ===== SHACL VALIDATION SHAPES =====

:QuantumResistanceValidatorShape rdf:type sh:NodeShape ;
                                sh:targetClass :QuantumResistanceValidator ;
                                sh:property [
                                    sh:path :hasSecurityMargin ;
                                    sh:datatype xsd:positiveInteger ;
                                    sh:minInclusive 80 ;
                                    sh:maxInclusive 512 ;
                                    sh:minCount 1 ;
                                    sh:maxCount 1 ;
                                ] ;
                                sh:property [
                                    sh:path :operatesWithinConstraint ;
                                    sh:hasValue doe:EightTickConstraint ;
                                    sh:minCount 1 ;
                                    sh:maxCount 1 ;
                                ] .

:PQCAlgorithmValidatorShape rdf:type sh:NodeShape ;
                           sh:targetClass :PQCAlgorithmValidator ;
                           sh:property [
                               sh:path :hasQuantumSecurityLevel ;
                               sh:datatype xsd:positiveInteger ;
                               sh:minInclusive 80 ;
                               sh:maxInclusive 512 ;
                               sh:minCount 1 ;
                               sh:maxCount 3 ;
                           ] .

# ===== PROPERTIES =====

:validatesCrystalType rdf:type owl:ObjectProperty ;
                      rdfs:domain :QuantumResistanceValidator ;
                      rdfs:range ba:CrystalType ;
                      rdfs:label "validates crystal type"@en .

:validatesField rdf:type owl:ObjectProperty ;
                rdfs:domain :CrystalQuantumValidator ;
                rdfs:range :CrystalField ;
                rdfs:label "validates field"@en .

:checksAlgorithm rdf:type owl:ObjectProperty ;
                 rdfs:domain :CrystalQuantumValidator ;
                 rdfs:range :CryptographicAlgorithm ;
                 rdfs:label "checks algorithm"@en .

:validatesVariant rdf:type owl:ObjectProperty ;
                  rdfs:domain :PQCAlgorithmValidator ;
                  rdfs:range :AlgorithmVariant ;
                  rdfs:label "validates variant"@en .

:checksHardness rdf:type owl:ObjectProperty ;
                rdfs:domain :PQCAlgorithmValidator ;
                rdfs:range :MathematicalProblem ;
                rdfs:label "checks hardness"@en .

:simulatesAlgorithm rdf:type owl:ObjectProperty ;
                    rdfs:domain :QuantumAttackSimulator ;
                    rdfs:range :QuantumAlgorithm ;
                    rdfs:label "simulates algorithm"@en .

:attacksAlgorithm rdf:type owl:ObjectProperty ;
                  rdfs:domain :QuantumAttackSimulator ;
                  rdfs:range :CryptographicAlgorithm ;
                  rdfs:label "attacks algorithm"@en .

:combinesAlgorithm rdf:type owl:ObjectProperty ;
                   rdfs:domain :HybridCryptographyValidator ;
                   rdfs:range :CryptographicAlgorithm ;
                   rdfs:label "combines algorithm"@en .

:hasSecurityMargin rdf:type owl:DatatypeProperty ;
                   rdfs:domain :QuantumResistanceValidator ;
                   rdfs:range xsd:positiveInteger ;
                   rdfs:label "has security margin"@en .

:hasValidationAccuracy rdf:type owl:DatatypeProperty ;
                       rdfs:domain :CrystalQuantumValidator ;
                       rdfs:range xsd:decimal ;
                       rdfs:label "has validation accuracy"@en .

:hasQuantumSecurityLevel rdf:type owl:DatatypeProperty ;
                         rdfs:domain :PQCAlgorithmValidator ;
                         rdfs:range xsd:positiveInteger ;
                         rdfs:label "has quantum security level"@en .

:requiresQubits rdf:type owl:DatatypeProperty ;
                rdfs:domain :QuantumAttackSimulator ;
                rdfs:range xsd:positiveInteger ;
                rdfs:label "requires qubits"@en .

:hasQuantumAdvantage rdf:type owl:DatatypeProperty ;
                     rdfs:domain :QuantumAttackSimulator ;
                     rdfs:range xsd:boolean ;
                     rdfs:label "has quantum advantage"@en .

# ===== INDIVIDUALS =====

# Security Levels
:NIST_Level1 rdf:type :SecurityLevel ;
             rdfs:label "NIST Security Level 1"@en ;
             :equivalentTo "AES-128" ;
             :hasQuantumSecurity "128"^^xsd:positiveInteger .

:NIST_Level3 rdf:type :SecurityLevel ;
             rdfs:label "NIST Security Level 3"@en ;
             :equivalentTo "AES-192" ;
             :hasQuantumSecurity "192"^^xsd:positiveInteger .

:NIST_Level5 rdf:type :SecurityLevel ;
             rdfs:label "NIST Security Level 5"@en ;
             :equivalentTo "AES-256" ;
             :hasQuantumSecurity "256"^^xsd:positiveInteger .

# Quantum Algorithms
:Shors rdf:type :QuantumAlgorithm ;
       rdfs:label "Shor's Algorithm"@en ;
       :hasComplexity "O(n^3)" ;
       :breaksRSA "true"^^xsd:boolean .

:Grovers rdf:type :QuantumAlgorithm ;
         rdfs:label "Grover's Algorithm"@en ;
         :hasComplexity "O(sqrt(N))" ;
         :reducesSymmetricSecurity "50"^^xsd:positiveInteger .

# Mathematical Problems
:ModuleLWE rdf:type :MathematicalProblem ;
           rdfs:label "Module Learning With Errors"@en ;
           :isQuantumHard "true"^^xsd:boolean .

:SIS rdf:type :MathematicalProblem ;
     rdfs:label "Short Integer Solution"@en ;
     :isQuantumHard "true"^^xsd:boolean .

:SVP rdf:type :MathematicalProblem ;
     rdfs:label "Shortest Vector Problem"@en ;
     :isQuantumHard "true"^^xsd:boolean .

# Crystal Fields
:TaskSignature rdf:type :CrystalField ;
               rdfs:label "Task Signature"@en ;
               :requiredAlgorithm :Dilithium5 .

:ResultIntegrity rdf:type :CrystalField ;
                 rdfs:label "Result Integrity"@en ;
                 :requiredAlgorithm :SPHINCS_Plus_SHA256_256s .

:CapabilityToken rdf:type :CrystalField ;
                 rdfs:label "Capability Token"@en ;
                 :requiredAlgorithm :Kyber1024 .

# ===== END OF ONTOLOGY =====