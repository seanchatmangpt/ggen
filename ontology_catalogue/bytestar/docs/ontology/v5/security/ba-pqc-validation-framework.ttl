#    Documentation and Metadata
#################################################################

:PQCValidationDocumentation rdf:type owl:Class ;
    rdfs:label "PQC Validation Documentation"@en ;
    rdfs:comment """Comprehensive documentation for the PQC validation framework
    covering implementation guidelines, security requirements, and validation procedures."""@en ;
    dct:creator "ByteStar Quantum Security Team"@en ;
    dct:created "2025-08-23T00:00:00Z"^^xsd:dateTime ;
    prov:wasGeneratedBy :PQCValidationDevelopmentActivity .

:PQCValidationDevelopmentActivity rdf:type prov:Activity ;
    rdfs:label "PQC Validation Development Activity"@en ;
    rdfs:comment "Development activity for creating the PQC validation framework."@en ;
    prov:startedAtTime "2025-06-01T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2025-08-23T00:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith :ByteStarQuantumSecurityTeam .

:ByteStarQuantumSecurityTeam rdf:type prov:Agent ,
                                     foaf:Organization ;
    rdfs:label "ByteStar Quantum Security Team"@en ;
    foaf:name "ByteStar Quantum Security Team"@en .

