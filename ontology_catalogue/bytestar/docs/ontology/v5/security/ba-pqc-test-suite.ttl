#    Documentation and Metadata
#################################################################

:PQCTestSuiteDocumentation rdf:type owl:Class ;
    rdfs:label "PQC Test Suite Documentation"@en ;
    rdfs:comment """Documentation for the PQC test suite framework
    covering testing methodologies, validation procedures, and compliance requirements."""@en ;
    dct:creator "ByteStar PQC Testing Team"@en ;
    dct:created "2025-08-23T00:00:00Z"^^xsd:dateTime ;
    prov:wasGeneratedBy :PQCTestSuiteDevelopment .

:PQCTestSuiteDevelopment rdf:type prov:Activity ;
    rdfs:label "PQC Test Suite Development"@en ;
    rdfs:comment "Development activity for creating the PQC test suite framework."@en ;
    prov:startedAtTime "2025-02-01T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2025-08-23T00:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith :ByteStarPQCTestingTeam .

:ByteStarPQCTestingTeam rdf:type prov:Agent ,
                                foaf:Organization ;
    rdfs:label "ByteStar PQC Testing Team"@en ;
    foaf:name "ByteStar PQC Testing Team"@en .

#################################################################
#    End of PQC Test Suite Ontology
