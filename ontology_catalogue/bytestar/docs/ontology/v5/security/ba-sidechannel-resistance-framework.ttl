#    Documentation and Metadata
#################################################################

:SideChannelFrameworkDocumentation rdf:type owl:Class ;
    rdfs:label "Side-Channel Framework Documentation"@en ;
    rdfs:comment """Comprehensive documentation for the side-channel resistance framework
    covering implementation guidelines, testing procedures, and countermeasure deployment."""@en ;
    dct:creator "ByteStar Side-Channel Security Team"@en ;
    dct:created "2025-08-23T00:00:00Z"^^xsd:dateTime ;
    prov:wasGeneratedBy :SideChannelFrameworkDevelopment .

:SideChannelFrameworkDevelopment rdf:type prov:Activity ;
    rdfs:label "Side-Channel Framework Development"@en ;
    rdfs:comment "Development activity for creating the side-channel resistance framework."@en ;
    prov:startedAtTime "2025-05-01T00:00:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2025-08-23T00:00:00Z"^^xsd:dateTime ;
    prov:wasAssociatedWith :ByteStarSideChannelTeam .

:ByteStarSideChannelTeam rdf:type prov:Agent ,
                                 foaf:Organization ;
    rdfs:label "ByteStar Side-Channel Security Team"@en ;
    foaf:name "ByteStar Side-Channel Security Team"@en .

