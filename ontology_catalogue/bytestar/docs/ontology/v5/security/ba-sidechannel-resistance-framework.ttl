                        rdfs:comment "Boolean indicating side-channel resistance."@en .

###  http://bytestar.org/ontology/security/sidechannel#hasLeakageMeasurement
:hasLeakageMeasurement rdf:type owl:DatatypeProperty ;
                       rdfs:domain :InformationLeakage ;
                       rdfs:range xsd:decimal ;
                       rdfs:label "has leakage measurement"@en ;
                       rdfs:comment "Quantified measurement of leakage amount."@en .

#################################################################
#    Side-Channel Framework Instances and Examples
#################################################################

###  Master Side-Channel Resistance Framework
:MasterSideChannelFramework rdf:type :SideChannelResistanceFramework ;
                            rdfs:label "Master Side-Channel Resistance Framework"@en ;
                            rdfs:comment "Primary framework for side-channel protection across ByteStar."@en ;
                            :protectsAgainst :TimingAttack , :PowerAnalysisAttack , :ElectromagneticAttack ,
                                           :CacheAttack , :FaultInjectionAttack ;
                            :hasProtectionLevel :HardwareLevel ;
                            :operatesWithinConstraint doe:EightTickConstraint ;
                            :integratesWithZeroTick ztr:InstantRejection ;
                            :providesRealTimeProtection "true"^^xsd:boolean .

###  Crystal-Specific Side-Channel Protection
:ByteActorSideChannelProtection rdf:type :SideChannelResistance ;
                                rdfs:label "ByteActor Side-Channel Protection"@en ;
                                rdfs:comment "Side-channel protection for ByteActor kernels."@en ;
                                :hasResistanceLevel "Maximum" ;
                                :hasFormalProof "true"^^xsd:boolean ;
                                :isVerifiable "true"^^xsd:boolean ;
                                :hasCountermeasureEffectiveness "9.9"^^xsd:decimal .

:ByteCoreSideChannelProtection rdf:type :SideChannelResistance ;
                               rdfs:label "ByteCore Side-Channel Protection"@en ;
                               rdfs:comment "Side-channel protection for ByteCore operations."@en ;
                               :hasResistanceLevel "Maximum" ;
                               :hasFormalProof "true"^^xsd:boolean ;
                               :isVerifiable "true"^^xsd:boolean ;
                               :hasCountermeasureEffectiveness "9.8"^^xsd:decimal .

###  Timing Analysis System
:PrimaryTimingAnalyzer rdf:type :TimingAnalyzer ;
                       rdfs:label "Primary Timing Analyzer"@en ;
                       rdfs:comment "Main timing analysis system for detecting timing leakage."@en ;
                       :analyzes :TimingLeakage ;
                       :hasPrecision "nanoseconds" ;
                       :hasStatisticalPower "99.99"^^xsd:decimal ;
                       :detectsVariations "0.001"^^xsd:decimal ;
                       :hasDetectionAccuracy "99.9"^^xsd:decimal .

###  Power Analysis System
:PrimaryPowerAnalyzer rdf:type :PowerAnalyzer ;
                      rdfs:label "Primary Power Analyzer"@en ;
                      rdfs:comment "Main power analysis system for detecting power leakage."@en ;
                      :analyzes :PowerLeakage ;
                      :hasSamplingRate "1GS/s" ;
                      :hasResolution "16bit" ;
                      :hasDetectionAccuracy "99.8"^^xsd:decimal .

###  Electromagnetic Analysis System
:PrimaryEMAnalyzer rdf:type :ElectromagneticAnalyzer ;
                   rdfs:label "Primary EM Analyzer"@en ;
                   rdfs:comment "Main EM analysis system for detecting EM leakage."@en ;
                   :analyzes :ElectromagneticLeakage ;
                   :hasFrequencyRange "10kHz-10GHz" ;
                   :hasBandwidth "1GHz" ;
                   :hasDetectionAccuracy "99.7"^^xsd:decimal .

###  Real-Time Monitoring System
:MasterRealTimeMonitor rdf:type :RealTimeMonitor ;
                       rdfs:label "Master Real-Time Monitor"@en ;
                       rdfs:comment "Primary real-time side-channel monitoring system."@en ;
                       :monitorsInRealTime "true"^^xsd:boolean ;
                       :hasResponseTime "nanoseconds" ;
                       :hasResponseTimeNanoseconds 50 ;
                       :detects :TimingAttack , :PowerAnalysisAttack , :CacheAttack ;
                       :triggersResponse :ImmediateCountermeasure ;
                       :operatesWithinConstraint doe:EightTickConstraint .

#################################################################
#    SHACL Validation Shapes for Side-Channel Framework
#################################################################

###  Constant-Time Execution Shape
:ConstantTimeExecutionShape rdf:type sh:NodeShape ;
                           sh:targetClass :ConstantTimeExecution ;
                           rdfs:label "Constant-Time Execution Shape"@en ;
                           rdfs:comment "Validation shape for constant-time execution requirements."@en ;
                           sh:property [
                               sh:path :hasTimingVariance ;
                               sh:datatype xsd:decimal ;
                               sh:hasValue "0.0"^^xsd:decimal ;
                               sh:minCount 1 ;
                               sh:maxCount 1 ;
                               sh:message "Constant-time execution must have zero timing variance"@en ;
                               sh:severity sh:Violation
                           ] ;
                           sh:property [
                               sh:path :isConstantTime ;
                               sh:datatype xsd:boolean ;
                               sh:hasValue "true"^^xsd:boolean ;
                               sh:minCount 1 ;
                               sh:message "Must be constant-time execution"@en
                           ] .

###  Side-Channel Resistance Shape
:SideChannelResistanceShape rdf:type sh:NodeShape ;
                           sh:targetClass :SideChannelResistance ;
                           rdfs:label "Side-Channel Resistance Shape"@en ;
                           rdfs:comment "Validation shape for side-channel resistance requirements."@en ;
                           sh:property [
                               sh:path :isSideChannelResistant ;
                               sh:datatype xsd:boolean ;
                               sh:hasValue "true"^^xsd:boolean ;
                               sh:minCount 1 ;
                               sh:message "Must provide side-channel resistance"@en
                           ] ;
                           sh:property [
                               sh:path :hasResistanceLevel ;
                               sh:datatype xsd:string ;
                               sh:in ( "Basic" "Enhanced" "Advanced" "Maximum" ) ;
                               sh:minCount 1 ;
                               sh:message "Must have valid resistance level"@en
                           ] .

###  Detection Accuracy Shape
:DetectionAccuracyShape rdf:type sh:NodeShape ;
                       sh:targetClass :SideChannelDetector ;
                       rdfs:label "Detection Accuracy Shape"@en ;
                       rdfs:comment "Validation shape for detection accuracy requirements."@en ;
                       sh:property [
                           sh:path :hasDetectionAccuracy ;
                           sh:datatype xsd:decimal ;
                           sh:minInclusive "95.0"^^xsd:decimal ;
                           sh:maxInclusive "100.0"^^xsd:decimal ;
                           sh:minCount 1 ;
                           sh:message "Detection accuracy must be at least 95%"@en
                       ] .

###  Real-Time Response Shape
:RealTimeResponseShape rdf:type sh:NodeShape ;
                      sh:targetClass :RealTimeMonitor ;
                      rdfs:label "Real-Time Response Shape"@en ;
                      rdfs:comment "Validation shape for real-time response requirements."@en ;
                      sh:property [
                          sh:path :hasResponseTimeNanoseconds ;
                          sh:datatype xsd:nonNegativeInteger ;
                          sh:maxInclusive 100 ;
                          sh:minCount 1 ;
                          sh:message "Response time must be ≤100 nanoseconds"@en
                      ] ;
                      sh:property [
                          sh:path :monitorsInRealTime ;
                          sh:datatype xsd:boolean ;
                          sh:hasValue "true"^^xsd:boolean ;
                          sh:message "Must monitor in real-time"@en
                      ] .

#################################################################
#    Integration Axioms and Constraints
#################################################################

# Axiom: All ByteStar kernels must be constant-time
ba:Kernel rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :isConstantTime ;
    owl:hasValue "true"^^xsd:boolean
] .

# Axiom: All crystal components must have side-channel resistance
ba:CrystalComponent rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :isSideChannelResistant ;
    owl:hasValue "true"^^xsd:boolean
] .

# Axiom: All operations must have timing variance of zero
ba:Operation rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :hasTimingVariance ;
    owl:hasValue "0.0"^^xsd:decimal
] .

# Axiom: Side-channel countermeasures must be hardware-implemented for maximum security
:SideChannelCountermeasure rdfs:subClassOf [
    rdf:type owl:Restriction ;
    owl:onProperty :isHardwareImplemented ;
    owl:hasValue "true"^^xsd:boolean
] .

