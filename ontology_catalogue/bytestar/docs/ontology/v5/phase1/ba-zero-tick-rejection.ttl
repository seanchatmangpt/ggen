    rdfs:label "Zero-Tick Rejection Metadata"@en ;
    rdfs:comment "Metadata about the zero-tick rejection ontology."@en ;
    dct:creator "ByteStar Performance Engineering Team"@en ;
    dct:contributor "Hardware Architecture Division"@en ,
                    "Security Engineering Team"@en ,
                    "Validation Framework Team"@en ;
