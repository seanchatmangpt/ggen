@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix ba: <https://bytestar.ai/ontology/v5/core#> .
@prefix ba-onto: <https://bytestar.ai/ontology/v5/ontology-as-algorithm#> .
@prefix ba-exec: <https://bytestar.ai/ontology/v5/execution#> .
@prefix dflss: <https://bytestar.ai/ontology/v5/dflss#> .

# =============================================================================
# ByteStar Ontology-as-Algorithm Core Definition
# =============================================================================
# This ontology establishes that ByteStar ontologies ARE executable algorithms,
# not descriptions of systems. They execute deterministically with provable
# guarantees, machine-readable specifications, and complete elimination of
# human interpretation ambiguity.
# =============================================================================

<https://bytestar.ai/ontology/v5/ontology-as-algorithm> a owl:Ontology ;
    rdfs:label "ByteStar Ontology-as-Algorithm Core"@en ;
    rdfs:comment """
    Foundational ontology defining how ByteStar ontologies function as executable 
    algorithms rather than documentation. Establishes deterministic execution 
    properties, algorithm guarantees, and machine-readable specifications that 
    eliminate human interpretation.
    """@en ;
    owl:versionInfo "5.0.0-phase1" ;
    owl:imports <https://bytestar.ai/ontology/v5/core> ,
                <https://bytestar.ai/ontology/v5/execution> ,
                <https://bytestar.ai/ontology/v5/dflss> ;
    ba:doctrineCompliant "8" ;
    ba:executionDeterministic true ;
    ba:humanInterpretationEliminated true .

# =============================================================================
# Core Algorithm Classes
# =============================================================================

ba-onto:ExecutableOntology a owl:Class ;
    rdfs:label "Executable Ontology"@en ;
    rdfs:comment """
    An ontology that IS an algorithm - not a description of one. 
    Must be directly executable with deterministic outputs.
    """@en ;
    rdfs:subClassOf ba:Algorithm ,
                    prov:SoftwareAgent ;
    ba:executionGuarantee "deterministic" ;
    ba:interpretationMode "machine-only" .

ba-onto:AlgorithmicTriple a owl:Class ;
    rdfs:label "Algorithmic Triple"@en ;
    rdfs:comment """
    RDF triple that represents an executable operation rather than 
    static data. Each triple corresponds to a computational step.
    """@en ;
    rdfs:subClassOf rdf:Statement ,
                    ba:ExecutableUnit ;
    ba:executionOrder xsd:positiveInteger ;
    ba:deterministic true .

ba-onto:StateTransformationFunction a owl:Class ;
    rdfs:label "State Transformation Function"@en ;
    rdfs:comment """
    Pure function that transforms system state deterministically.
    Core primitive of ontology execution.
    """@en ;
    rdfs:subClassOf ba:Function ;
    ba:purity "pure" ;
    ba:sideEffects "none" ;
    ba:executionTime ba:BoundedConstant .

ba-onto:ExecutionTrace a owl:Class ;
    rdfs:label "Execution Trace"@en ;
    rdfs:comment """
    Complete record of ontology algorithm execution including
    all state transitions and proof generation.
    """@en ;
    rdfs:subClassOf prov:Activity ;
    ba:completeness "total" ;
    ba:verifiable true .

ba-onto:AlgorithmicProof a owl:Class ;
    rdfs:label "Algorithmic Proof"@en ;
    rdfs:comment """
    Mathematical proof of algorithm correctness, termination,
    and property preservation.
    """@en ;
    rdfs:subClassOf ba:Proof ;
    ba:proofType ba:Constructive ;
    ba:mechanicallyVerifiable true .

# =============================================================================
# Algorithm Properties and Constraints
# =============================================================================

ba-onto:hasExecutionGuarantee a owl:ObjectProperty ;
    rdfs:label "has execution guarantee"@en ;
    rdfs:comment "Specifies the execution guarantee provided by the algorithm"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range ba-onto:ExecutionGuarantee .

ba-onto:hasInputSpecification a owl:ObjectProperty ;
    rdfs:label "has input specification"@en ;
    rdfs:comment "Complete formal specification of algorithm inputs"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range ba-onto:InputSpecification .

ba-onto:hasOutputSpecification a owl:ObjectProperty ;
    rdfs:label "has output specification"@en ;
    rdfs:comment "Complete formal specification of algorithm outputs"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range ba-onto:OutputSpecification .

ba-onto:hasStateTransformation a owl:ObjectProperty ;
    rdfs:label "has state transformation"@en ;
    rdfs:comment "State transformation function applied during execution"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range ba-onto:StateTransformationFunction .

ba-onto:generatesTrace a owl:ObjectProperty ;
    rdfs:label "generates trace"@en ;
    rdfs:comment "Execution trace generated during algorithm execution"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range ba-onto:ExecutionTrace .

ba-onto:generatesProof a owl:ObjectProperty ;
    rdfs:label "generates proof"@en ;
    rdfs:comment "Mathematical proof generated during execution"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range ba-onto:AlgorithmicProof .

# =============================================================================
# Execution Guarantee Types
# =============================================================================

ba-onto:ExecutionGuarantee a owl:Class ;
    rdfs:label "Execution Guarantee"@en ;
    rdfs:comment "Type of guarantee provided by algorithm execution"@en .

ba-onto:DeterministicExecution a ba-onto:ExecutionGuarantee ;
    rdfs:label "Deterministic Execution"@en ;
    rdfs:comment "Algorithm always produces the same output for same input"@en .

ba-onto:TerminationGuaranteed a ba-onto:ExecutionGuarantee ;
    rdfs:label "Termination Guaranteed"@en ;
    rdfs:comment "Algorithm is guaranteed to terminate in finite time"@en .

ba-onto:ResourceBounded a ba-onto:ExecutionGuarantee ;
    rdfs:label "Resource Bounded"@en ;
    rdfs:comment "Algorithm resource usage is bounded by Doctrine of 8"@en ;
    ba:maxTicks "8"^^xsd:positiveInteger .

ba-onto:PropertyPreserving a ba-onto:ExecutionGuarantee ;
    rdfs:label "Property Preserving"@en ;
    rdfs:comment "Algorithm preserves specified system properties"@en .

# =============================================================================
# Input/Output Specifications
# =============================================================================

ba-onto:InputSpecification a owl:Class ;
    rdfs:label "Input Specification"@en ;
    rdfs:comment "Formal specification of algorithm input requirements"@en ;
    rdfs:subClassOf ba:Specification .

ba-onto:OutputSpecification a owl:Class ;
    rdfs:label "Output Specification"@en ;
    rdfs:comment "Formal specification of algorithm output guarantees"@en ;
    rdfs:subClassOf ba:Specification .

ba-onto:hasTypeConstraint a owl:ObjectProperty ;
    rdfs:label "has type constraint"@en ;
    rdfs:comment "Type constraint on input/output values"@en ;
    rdfs:range rdfs:Datatype .

ba-onto:hasValueConstraint a owl:ObjectProperty ;
    rdfs:label "has value constraint"@en ;
    rdfs:comment "Value constraint expressed as SHACL shape"@en ;
    rdfs:range sh:Shape .

ba-onto:hasSemanticConstraint a owl:ObjectProperty ;
    rdfs:label "has semantic constraint"@en ;
    rdfs:comment "Semantic constraint on interpretation"@en ;
    rdfs:range ba:SemanticConstraint .

# =============================================================================
# SHACL Shapes for Algorithm Validation
# =============================================================================

ba-onto:ExecutableOntologyShape a sh:NodeShape ;
    rdfs:label "Executable Ontology Shape"@en ;
    sh:targetClass ba-onto:ExecutableOntology ;
    sh:property [
        sh:path ba-onto:hasExecutionGuarantee ;
        sh:minCount 1 ;
        sh:class ba-onto:ExecutionGuarantee ;
    ] ;
    sh:property [
        sh:path ba-onto:hasInputSpecification ;
        sh:minCount 1 ;
        sh:class ba-onto:InputSpecification ;
    ] ;
    sh:property [
        sh:path ba-onto:hasOutputSpecification ;
        sh:minCount 1 ;
        sh:class ba-onto:OutputSpecification ;
    ] ;
    sh:property [
        sh:path ba:executionTime ;
        sh:maxInclusive 8 ;
        sh:datatype xsd:positiveInteger ;
    ] .

ba-onto:AlgorithmicTripleShape a sh:NodeShape ;
    rdfs:label "Algorithmic Triple Shape"@en ;
    sh:targetClass ba-onto:AlgorithmicTriple ;
    sh:property [
        sh:path ba:executionOrder ;
        sh:minCount 1 ;
        sh:datatype xsd:positiveInteger ;
    ] ;
    sh:property [
        sh:path ba:deterministic ;
        sh:hasValue true ;
    ] .

ba-onto:StateTransformationShape a sh:NodeShape ;
    rdfs:label "State Transformation Function Shape"@en ;
    sh:targetClass ba-onto:StateTransformationFunction ;
    sh:property [
        sh:path ba:purity ;
        sh:hasValue "pure" ;
    ] ;
    sh:property [
        sh:path ba:sideEffects ;
        sh:hasValue "none" ;
    ] .

# =============================================================================
# DfLSS Integration
# =============================================================================

ba-onto:hasDfLSSMapping a owl:ObjectProperty ;
    rdfs:label "has DfLSS mapping"@en ;
    rdfs:comment "Maps ontology elements to DfLSS methodology phases"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range dflss:Phase .

ba-onto:DfLSSDefinePhase a dflss:Phase ;
    rdfs:label "DfLSS Define Phase"@en ;
    rdfs:comment "Define phase maps to input specification"@en ;
    ba-onto:mapsToSpecification ba-onto:InputSpecification .

ba-onto:DfLSSMeasurePhase a dflss:Phase ;
    rdfs:label "DfLSS Measure Phase"@en ;
    rdfs:comment "Measure phase maps to execution trace generation"@en ;
    ba-onto:mapsToTrace ba-onto:ExecutionTrace .

ba-onto:DfLSSAnalyzePhase a dflss:Phase ;
    rdfs:label "DfLSS Analyze Phase"@en ;
    rdfs:comment "Analyze phase maps to state transformation"@en ;
    ba-onto:mapsToTransformation ba-onto:StateTransformationFunction .

ba-onto:DfLSSImprovePhase a dflss:Phase ;
    rdfs:label "DfLSS Improve Phase"@en ;
    rdfs:comment "Improve phase maps to algorithm optimization"@en ;
    ba-onto:mapsToOptimization ba:Optimization .

ba-onto:DfLSSControlPhase a dflss:Phase ;
    rdfs:label "DfLSS Control Phase"@en ;
    rdfs:comment "Control phase maps to proof generation"@en ;
    ba-onto:mapsToProof ba-onto:AlgorithmicProof .

# =============================================================================
# Performance Constraints (Doctrine of 8)
# =============================================================================

ba-onto:DoctrineCompliantExecution a owl:Class ;
    rdfs:label "Doctrine Compliant Execution"@en ;
    rdfs:comment "Execution that adheres to Doctrine of 8 constraints"@en ;
    rdfs:subClassOf ba-onto:ExecutableOntology ;
    ba:maxExecutionTicks "8"^^xsd:positiveInteger ;
    ba:maxMemoryUnits "8"^^xsd:positiveInteger ;
    ba:maxComplexityOrder "8"^^xsd:positiveInteger .

ba-onto:hasComplexityBound a owl:DatatypeProperty ;
    rdfs:label "has complexity bound"@en ;
    rdfs:comment "Maximum algorithmic complexity (must be ≤ 8)"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range xsd:positiveInteger ;
    ba:maxValue 8 .

ba-onto:hasTimeBound a owl:DatatypeProperty ;
    rdfs:label "has time bound"@en ;
    rdfs:comment "Maximum execution time in ticks (must be ≤ 8)"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range xsd:positiveInteger ;
    ba:maxValue 8 .

ba-onto:hasSpaceBound a owl:DatatypeProperty ;
    rdfs:label "has space bound"@en ;
    rdfs:comment "Maximum memory usage in units (must be ≤ 8)"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range xsd:positiveInteger ;
    ba:maxValue 8 .

# =============================================================================
# Machine-Readable Specifications
# =============================================================================

ba-onto:MachineReadableSpec a owl:Class ;
    rdfs:label "Machine Readable Specification"@en ;
    rdfs:comment """
    Specification that eliminates human interpretation ambiguity.
    Must be directly executable by machine without human intervention.
    """@en ;
    rdfs:subClassOf ba:Specification ;
    ba:humanInterpretationRequired false ;
    ba:ambiguityLevel "zero" .

ba-onto:hasExecutableSemantics a owl:ObjectProperty ;
    rdfs:label "has executable semantics"@en ;
    rdfs:comment "Formal executable semantics specification"@en ;
    rdfs:domain ba-onto:MachineReadableSpec ;
    rdfs:range ba:ExecutableSemantics .

ba-onto:hasValidationRules a owl:ObjectProperty ;
    rdfs:label "has validation rules"@en ;
    rdfs:comment "SHACL-based validation rules for machine checking"@en ;
    rdfs:domain ba-onto:MachineReadableSpec ;
    rdfs:range sh:Shape .

ba-onto:eliminatesAmbiguity a owl:DatatypeProperty ;
    rdfs:label "eliminates ambiguity"@en ;
    rdfs:comment "Boolean indicating complete ambiguity elimination"@en ;
    rdfs:domain ba-onto:MachineReadableSpec ;
    rdfs:range xsd:boolean .

# =============================================================================
# Axioms and Inference Rules
# =============================================================================

# Axiom: Every ExecutableOntology must be deterministic
[] a owl:Axiom ;
   owl:annotatedSource ba-onto:ExecutableOntology ;
   owl:annotatedProperty ba:deterministic ;
   owl:annotatedTarget true ;
   rdfs:comment "All executable ontologies must be deterministic" .

# Axiom: Execution traces must be complete
[] a owl:Axiom ;
   owl:annotatedSource ba-onto:ExecutionTrace ;
   owl:annotatedProperty ba:completeness ;
   owl:annotatedTarget "total" ;
   rdfs:comment "All execution traces must be complete records" .

# Axiom: State transformations must be pure
[] a owl:Axiom ;
   owl:annotatedSource ba-onto:StateTransformationFunction ;
   owl:annotatedProperty ba:purity ;
   owl:annotatedTarget "pure" ;
   rdfs:comment "All state transformations must be pure functions" .

# Rule: If ontology is executable, it generates proofs
[] a owl:Class ;
   owl:intersectionOf (
       ba-onto:ExecutableOntology
       [ a owl:Restriction ;
         owl:onProperty ba-onto:generatesProof ;
         owl:minCardinality 1 ]
   ) ;
   owl:equivalentClass ba-onto:ExecutableOntology .

# =============================================================================
# Integration Points
# =============================================================================

ba-onto:integratesWithByteCore a owl:ObjectProperty ;
    rdfs:label "integrates with ByteCore"@en ;
    rdfs:comment "Integration point with ByteCore execution engine"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range ba:ByteCore .

ba-onto:integratesWithByteFlow a owl:ObjectProperty ;
    rdfs:label "integrates with ByteFlow"@en ;
    rdfs:comment "Integration point with ByteFlow orchestration"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range ba:ByteFlow .

ba-onto:integratesWithByteEthos a owl:ObjectProperty ;
    rdfs:label "integrates with ByteEthos"@en ;
    rdfs:comment "Integration point with ByteEthos governance"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range ba:ByteEthos .

# =============================================================================
# Validation and Compliance
# =============================================================================

ba-onto:ComplianceValidator a owl:Class ;
    rdfs:label "Compliance Validator"@en ;
    rdfs:comment "Validates ontology compliance with algorithm requirements"@en ;
    rdfs:subClassOf ba:Validator ;
    ba:validatesCompliance ba-onto:ExecutableOntology .

ba-onto:AlgorithmicIntegrityCheck a owl:Class ;
    rdfs:label "Algorithmic Integrity Check"@en ;
    rdfs:comment "Verifies algorithmic properties are preserved"@en ;
    rdfs:subClassOf ba:IntegrityCheck ;
    ba:checksProperty ba:Deterministic ,
                     ba:Terminating ,
                     ba:ResourceBounded .

# =============================================================================
# Meta-Level Specifications
# =============================================================================

ba-onto:isMetaAlgorithm a owl:DatatypeProperty ;
    rdfs:label "is meta algorithm"@en ;
    rdfs:comment "Boolean indicating if ontology operates on other ontologies"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range xsd:boolean .

ba-onto:hasMetaLevel a owl:DatatypeProperty ;
    rdfs:label "has meta level"@en ;
    rdfs:comment "Meta-level of the ontology (0=object, 1=meta, etc.)"@en ;
    rdfs:domain ba-onto:ExecutableOntology ;
    rdfs:range xsd:nonNegativeInteger ;
    ba:maxValue 3 .

# =============================================================================
# Documentation and Metadata
# =============================================================================

ba-onto:version "5.0.0-phase1" ;
ba-onto:specificationLevel "foundational" ;
ba-onto:implementationStatus "active" ;
ba-onto:complianceLevel "doctrine-8" ;
ba-onto:validationStatus "shacl-validated" ;
ba-onto:integrationPoints "bytecore,byteflow,byteethos" ;
ba-onto:eliminatesAmbiguity true ;
ba-onto:deterministicExecution true ;
ba-onto:humanInterpretationRequired false .