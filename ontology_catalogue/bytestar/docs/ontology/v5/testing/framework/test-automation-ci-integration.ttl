                       ba-fuzz:DataCrystalFuzzer ,
                       ba-fuzz:ViewCrystalFuzzer ;
    ba-ci:stageDuration "PT30M"^^xsd:duration ;
    ba-ci:parallelismLevel 8 ;
    rdfs:comment "CI stage executing property-based fuzz testing" .

ba-ci:ByteStarComplianceValidationStage a ba-ci:ComplianceValidationStage ;
    rdfs:label "ByteStar Compliance Validation Stage" ;
    ba-ci:executesTest ba-bound:HAMBoundary ,
