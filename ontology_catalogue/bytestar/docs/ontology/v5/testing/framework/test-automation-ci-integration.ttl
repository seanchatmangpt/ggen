@prefix ba: <https://bytestar.org/ontology/> .
@prefix ba-ci: <https://bytestar.org/ontology/testing/ci/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# ==============================================================================
# Test Automation Framework with CI Integration - Comprehensive Testing
# ==============================================================================

ba-ci:test-automation-ci-integration a owl:Ontology ;
    dc:title "ByteStar Test Automation Framework with CI Integration" ;
    dc:description "Comprehensive framework for test automation with continuous integration that orchestrates all testing components including golden oracles, fuzz testing, fixtures, negative testing, and boundary testing within CI/CD pipelines" ;
    dc:creator "ByteStar Testing Foundation" ;
    dcterms:created "2025-08-23"^^xsd:date ;
    dcterms:modified "2025-08-23"^^xsd:date ;
    owl:versionInfo "5.0.0" ;
    vann:preferredNamespacePrefix "ba-ci" ;
    vann:preferredNamespaceUri "https://bytestar.org/ontology/testing/ci/" ;
    rdfs:comment "This framework integrates all testing components into a unified CI/CD pipeline that automatically executes comprehensive testing workflows including golden oracles, fuzz testing, fixtures, negative testing, and boundary testing." ;
    
    # Import existing ontologies for 80% reuse
    owl:imports <https://bytestar.org/ontology/ba-quality-assurance.ttl> ,
                <https://bytestar.org/ontology/ba-ontology-validation.ttl> ,
                <https://bytestar.org/ontology/v5/crystals/blueprints/crystal-blueprint-integration.ttl> ,
                <https://bytestar.org/ontology/testing/golden-oracle/> ,
                <https://bytestar.org/ontology/testing/fuzz/> ,
                <https://bytestar.org/ontology/testing/e2e/> ,
                <https://bytestar.org/ontology/testing/negative/> ,
                <https://bytestar.org/ontology/testing/boundary/> .

# ==============================================================================
# Test Automation CI Framework Core Classes
# ==============================================================================

ba-ci:TestAutomationCIFramework a owl:Class ;
    rdfs:label "Test Automation CI Framework" ;
    rdfs:comment "Core framework orchestrating automated testing within CI/CD pipelines" ;
    rdfs:subClassOf ba:TestAutomationPipeline ;
    skos:definition "A comprehensive framework that integrates all testing components into unified CI/CD pipelines for automated, continuous testing across all crystal types and system components" .

ba-ci:CIPipeline a owl:Class ;
    rdfs:label "CI Pipeline" ;
    rdfs:comment "Continuous integration pipeline that orchestrates testing workflows" ;
    rdfs:subClassOf ba:TestAutomationPipeline ;
    skos:definition "A continuous integration pipeline that automatically triggers and orchestrates comprehensive testing workflows including multiple testing strategies and validation phases" .

ba-ci:TestStage a owl:Class ;
    rdfs:label "Test Stage" ;
    rdfs:comment "Individual stage within CI pipeline that executes specific testing activities" ;
    rdfs:subClassOf ba:ProcessStep ;
    skos:definition "A specific stage within the CI pipeline that executes particular testing activities such as golden oracle validation, fuzz testing, or boundary testing" .

ba-ci:TestOrchestrator a owl:Class ;
    rdfs:label "Test Orchestrator" ;
    rdfs:comment "Component that coordinates and manages test execution across stages" ;
    rdfs:subClassOf ba:AutomatedTestingFramework ;
    skos:definition "A component responsible for coordinating test execution, managing dependencies between test stages, and ensuring proper sequencing of testing activities" .

ba-ci:TestArtifactManager a owl:Class ;
    rdfs:label "Test Artifact Manager" ;
    rdfs:comment "Component that manages test artifacts and results throughout pipeline" ;
    rdfs:subClassOf ba:TestDataManagement ;
    skos:definition "A component that manages the lifecycle of test artifacts including test data, results, reports, and evidence throughout the CI pipeline" .

ba-ci:QualityGateManager a owl:Class ;
    rdfs:label "Quality Gate Manager" ;
    rdfs:comment "Component that enforces quality gates and approval criteria" ;
    rdfs:subClassOf ba:QualityGate ;
    skos:definition "A component that enforces quality gates, validates approval criteria, and controls pipeline progression based on test results and quality metrics" .

# ==============================================================================
# CI Pipeline Stages and Testing Integration
# ==============================================================================

ba-ci:GoldenOracleStage a owl:Class ;
    rdfs:label "Golden Oracle Stage" ;
    rdfs:comment "CI stage that executes golden oracle validation tests" ;
    rdfs:subClassOf ba-ci:TestStage ;
    skos:definition "CI pipeline stage that executes golden oracle tests to validate system behavior against known-good reference outputs" .

ba-ci:FuzzTestingStage a owl:Class ;
    rdfs:label "Fuzz Testing Stage" ;
    rdfs:comment "CI stage that executes property-based fuzz testing" ;
    rdfs:subClassOf ba-ci:TestStage ;
    skos:definition "CI pipeline stage that executes property-based fuzz testing to discover edge cases and validate system properties" .

ba-ci:E2ETestingStage a owl:Class ;
    rdfs:label "End-to-End Testing Stage" ;
    rdfs:comment "CI stage that executes end-to-end integration tests with fixtures" ;
    rdfs:subClassOf ba-ci:TestStage ;
    skos:definition "CI pipeline stage that executes end-to-end integration tests using comprehensive fixture bundles" .

ba-ci:NegativeTestingStage a owl:Class ;
    rdfs:label "Negative Testing Stage" ;
    rdfs:comment "CI stage that executes negative tests and rejection path validation" ;
    rdfs:subClassOf ba-ci:TestStage ;
    skos:definition "CI pipeline stage that executes negative tests to validate error handling and rejection paths" .

ba-ci:BoundaryTestingStage a owl:Class ;
    rdfs:label "Boundary Testing Stage" ;
    rdfs:comment "CI stage that executes boundary value testing" ;
    rdfs:subClassOf ba-ci:TestStage ;
    skos:definition "CI pipeline stage that executes boundary value tests to validate system behavior at constraint limits and edge conditions" .

ba-ci:PerformanceTestingStage a owl:Class ;
    rdfs:label "Performance Testing Stage" ;
    rdfs:comment "CI stage that executes performance and load testing" ;
    rdfs:subClassOf ba-ci:TestStage ;
    skos:definition "CI pipeline stage that executes performance testing including load testing, stress testing, and performance benchmarking" .

ba-ci:SecurityTestingStage a owl:Class ;
    rdfs:label "Security Testing Stage" ;
    rdfs:comment "CI stage that executes security validation and vulnerability testing" ;
    rdfs:subClassOf ba-ci:TestStage ;
    skos:definition "CI pipeline stage that executes security testing including vulnerability assessment and penetration testing" .

ba-ci:ComplianceValidationStage a owl:Class ;
    rdfs:label "Compliance Validation Stage" ;
    rdfs:comment "CI stage that validates HAM compliance and Doctrine of 8 adherence" ;
    rdfs:subClassOf ba-ci:TestStage ;
    skos:definition "CI pipeline stage that validates compliance with Hardware Abstraction Model constraints and Doctrine of 8 requirements" .

# ==============================================================================
# Pipeline Triggers and Automation
# ==============================================================================

ba-ci:PipelineTrigger a owl:Class ;
    rdfs:label "Pipeline Trigger" ;
    rdfs:comment "Event or condition that triggers CI pipeline execution" ;
    rdfs:subClassOf ba:Trigger ;
    skos:definition "An event or condition that automatically triggers the execution of the CI testing pipeline" .

ba-ci:CodeCommitTrigger a owl:Class ;
    rdfs:label "Code Commit Trigger" ;
    rdfs:comment "Trigger activated by code repository commits" ;
    rdfs:subClassOf ba-ci:PipelineTrigger ;
    skos:definition "Trigger that activates the CI pipeline when code changes are committed to the repository" .

ba-ci:ScheduledTrigger a owl:Class ;
    rdfs:label "Scheduled Trigger" ;
    rdfs:comment "Trigger activated on scheduled intervals" ;
    rdfs:subClassOf ba-ci:PipelineTrigger ;
    skos:definition "Trigger that activates the CI pipeline at regular scheduled intervals for periodic testing" .

ba-ci:PullRequestTrigger a owl:Class ;
    rdfs:label "Pull Request Trigger" ;
    rdfs:comment "Trigger activated by pull request creation or updates" ;
    rdfs:subClassOf ba-ci:PipelineTrigger ;
    skos:definition "Trigger that activates the CI pipeline when pull requests are created or updated" .

ba-ci:DependencyUpdateTrigger a owl:Class ;
    rdfs:label "Dependency Update Trigger" ;
    rdfs:comment "Trigger activated by dependency or ontology updates" ;
    rdfs:subClassOf ba-ci:PipelineTrigger ;
    skos:definition "Trigger that activates the CI pipeline when dependencies or ontologies are updated" .

ba-ci:ManualTrigger a owl:Class ;
    rdfs:label "Manual Trigger" ;
    rdfs:comment "Trigger activated manually by authorized users" ;
    rdfs:subClassOf ba-ci:PipelineTrigger ;
    skos:definition "Trigger that allows authorized users to manually activate the CI pipeline for ad-hoc testing" .

# ==============================================================================
# Test Execution Strategies
# ==============================================================================

ba-ci:ParallelExecution a owl:Class ;
    rdfs:label "Parallel Execution" ;
    rdfs:comment "Strategy that executes test stages in parallel" ;
    rdfs:subClassOf ba:TestingStrategy ;
    skos:definition "Execution strategy that runs multiple test stages simultaneously to reduce overall pipeline execution time" .

ba-ci:SequentialExecution a owl:Class ;
    rdfs:label "Sequential Execution" ;
    rdfs:comment "Strategy that executes test stages sequentially" ;
    rdfs:subClassOf ba:TestingStrategy ;
    skos:definition "Execution strategy that runs test stages one after another in a predefined sequence" .

ba-ci:AdaptiveExecution a owl:Class ;
    rdfs:label "Adaptive Execution" ;
    rdfs:comment "Strategy that adapts execution based on test results and conditions" ;
    rdfs:subClassOf ba:TestingStrategy ;
    skos:definition "Execution strategy that dynamically adapts test execution based on intermediate results, system conditions, and risk assessment" .

ba-ci:FailFastExecution a owl:Class ;
    rdfs:label "Fail Fast Execution" ;
    rdfs:comment "Strategy that stops execution immediately upon first failure" ;
    rdfs:subClassOf ba:TestingStrategy ;
    skos:definition "Execution strategy that terminates pipeline execution immediately when the first critical failure is detected" .

ba-ci:ContinueOnFailure a owl:Class ;
    rdfs:label "Continue On Failure" ;
    rdfs:comment "Strategy that continues execution despite non-critical failures" ;
    rdfs:subClassOf ba:TestingStrategy ;
    skos:definition "Execution strategy that continues pipeline execution even when non-critical failures occur, collecting all results" .

# ==============================================================================
# CI Integration Components
# ==============================================================================

ba-ci:VersionControlIntegration a owl:Class ;
    rdfs:label "Version Control Integration" ;
    rdfs:comment "Component that integrates with version control systems" ;
    rdfs:subClassOf ba-ci:TestOrchestrator ;
    skos:definition "Component that integrates the CI pipeline with version control systems for automatic triggering and status reporting" .

ba-ci:ArtifactRepository a owl:Class ;
    rdfs:label "Artifact Repository" ;
    rdfs:comment "Repository for storing and managing test artifacts" ;
    rdfs:subClassOf ba-ci:TestArtifactManager ;
    skos:definition "Repository system for storing, versioning, and managing test artifacts including test data, results, and generated reports" .

ba-ci:NotificationSystem a owl:Class ;
    rdfs:label "Notification System" ;
    rdfs:comment "System that sends notifications about pipeline status and results" ;
    rdfs:subClassOf ba-ci:TestOrchestrator ;
    skos:definition "System that sends automated notifications about pipeline execution status, test results, and quality gate decisions to stakeholders" .

ba-ci:MetricsCollector a owl:Class ;
    rdfs:label "Metrics Collector" ;
    rdfs:comment "Component that collects and aggregates testing metrics" ;
    rdfs:subClassOf ba:QualityMetricsCollection ;
    skos:definition "Component that collects, aggregates, and analyzes testing metrics from all pipeline stages for quality assessment" .

ba-ci:ReportGenerator a owl:Class ;
    rdfs:label "Report Generator" ;
    rdfs:comment "Component that generates comprehensive testing reports" ;
    rdfs:subClassOf ba:QualityReporting ;
    skos:definition "Component that generates comprehensive testing reports including results summaries, trend analysis, and compliance documentation" .

# ==============================================================================
# Quality Gates and Approval Criteria
# ==============================================================================

ba-ci:CoverageQualityGate a owl:Class ;
    rdfs:label "Coverage Quality Gate" ;
    rdfs:comment "Quality gate that enforces test coverage requirements" ;
    rdfs:subClassOf ba-ci:QualityGateManager ;
    skos:definition "Quality gate that validates test coverage meets minimum requirements across all testing dimensions" .

ba-ci:PerformanceQualityGate a owl:Class ;
    rdfs:label "Performance Quality Gate" ;
    rdfs:comment "Quality gate that enforces performance requirements" ;
    rdfs:subClassOf ba-ci:QualityGateManager ;
    skos:definition "Quality gate that validates system performance meets requirements including Doctrine of 8 compliance" .

ba-ci:SecurityQualityGate a owl:Class ;
    rdfs:label "Security Quality Gate" ;
    rdfs:comment "Quality gate that enforces security requirements" ;
    rdfs:subClassOf ba-ci:QualityGateManager ;
    skos:definition "Quality gate that validates security requirements are met and no critical vulnerabilities are present" .

ba-ci:ComplianceQualityGate a owl:Class ;
    rdfs:label "Compliance Quality Gate" ;
    rdfs:comment "Quality gate that enforces regulatory and standard compliance" ;
    rdfs:subClassOf ba-ci:QualityGateManager ;
    skos:definition "Quality gate that validates adherence to regulatory requirements and industry standards" .

ba-ci:HAMComplianceQualityGate a owl:Class ;
    rdfs:label "HAM Compliance Quality Gate" ;
    rdfs:comment "Quality gate that enforces Hardware Abstraction Model compliance" ;
    rdfs:subClassOf ba-ci:ComplianceQualityGate ;
    skos:definition "Quality gate that validates compliance with Hardware Abstraction Model constraints for all memory hierarchy levels" .

# ==============================================================================
# Pipeline Status and Results
# ==============================================================================

ba-ci:PipelineExecution a owl:Class ;
    rdfs:label "Pipeline Execution" ;
    rdfs:comment "Instance of pipeline execution with results and metrics" ;
    rdfs:subClassOf ba:TestResult ;
    skos:definition "A complete instance of pipeline execution including all stages, results, metrics, and artifacts" .

ba-ci:ExecutionStatus a owl:Class ;
    rdfs:label "Execution Status" ;
    rdfs:comment "Status of pipeline or stage execution" ;
    rdfs:subClassOf skos:Concept ;
    skos:definition "The current status of pipeline or stage execution indicating progress and outcome" .

ba-ci:Success a ba-ci:ExecutionStatus ;
    rdfs:label "Success" ;
    rdfs:comment "Successful execution status" .

ba-ci:Failed a ba-ci:ExecutionStatus ;
    rdfs:label "Failed" ;
    rdfs:comment "Failed execution status" .

ba-ci:InProgress a ba-ci:ExecutionStatus ;
    rdfs:label "In Progress" ;
    rdfs:comment "Execution currently in progress" .

ba-ci:Cancelled a ba-ci:ExecutionStatus ;
    rdfs:label "Cancelled" ;
    rdfs:comment "Execution cancelled by user or system" .

ba-ci:Pending a ba-ci:ExecutionStatus ;
    rdfs:label "Pending" ;
    rdfs:comment "Execution pending approval or resources" .

ba-ci:StageResult a owl:Class ;
    rdfs:label "Stage Result" ;
    rdfs:comment "Result of individual pipeline stage execution" ;
    rdfs:subClassOf ba:TestResult ;
    skos:definition "Detailed result of an individual pipeline stage including metrics, artifacts, and quality assessments" .

# ==============================================================================
# Properties for CI Framework
# ==============================================================================

ba-ci:hasStage a owl:ObjectProperty ;
    rdfs:label "has stage" ;
    rdfs:comment "Associates pipeline with stages it contains" ;
    rdfs:domain ba-ci:CIPipeline ;
    rdfs:range ba-ci:TestStage ;
    skos:definition "Links a CI pipeline to the test stages it contains" .

ba-ci:triggeredBy a owl:ObjectProperty ;
    rdfs:label "triggered by" ;
    rdfs:comment "Associates pipeline with triggers that activate it" ;
    rdfs:domain ba-ci:CIPipeline ;
    rdfs:range ba-ci:PipelineTrigger ;
    skos:definition "Links a CI pipeline to the triggers that can activate it" .

ba-ci:executesTest a owl:ObjectProperty ;
    rdfs:label "executes test" ;
    rdfs:comment "Associates stage with test types it executes" ;
    rdfs:domain ba-ci:TestStage ;
    rdfs:range ba:TestCase ;
    skos:definition "Links a test stage to the specific test types it executes" .

ba-ci:hasExecutionStrategy a owl:ObjectProperty ;
    rdfs:label "has execution strategy" ;
    rdfs:comment "Associates pipeline with execution strategy" ;
    rdfs:domain ba-ci:CIPipeline ;
    rdfs:range ba:TestingStrategy ;
    skos:definition "Links a CI pipeline to the execution strategy it employs" .

ba-ci:enforcesQualityGate a owl:ObjectProperty ;
    rdfs:label "enforces quality gate" ;
    rdfs:comment "Associates pipeline with quality gates it enforces" ;
    rdfs:domain ba-ci:CIPipeline ;
    rdfs:range ba-ci:QualityGateManager ;
    skos:definition "Links a CI pipeline to the quality gates it enforces" .

ba-ci:producesArtifact a owl:ObjectProperty ;
    rdfs:label "produces artifact" ;
    rdfs:comment "Associates stage with artifacts it produces" ;
    rdfs:domain ba-ci:TestStage ;
    rdfs:range ba:TestData ;
    skos:definition "Links a test stage to the artifacts it produces" .

ba-ci:hasExecutionStatus a owl:ObjectProperty ;
    rdfs:label "has execution status" ;
    rdfs:comment "Associates execution with its status" ;
    rdfs:domain ba-ci:PipelineExecution ;
    rdfs:range ba-ci:ExecutionStatus ;
    skos:definition "Links a pipeline execution to its current status" .

ba-ci:dependsOnStage a owl:ObjectProperty ;
    rdfs:label "depends on stage" ;
    rdfs:comment "Associates stage with stages it depends on" ;
    rdfs:domain ba-ci:TestStage ;
    rdfs:range ba-ci:TestStage ;
    skos:definition "Links a test stage to other stages it depends on for execution" .

# ==============================================================================
# Datatype Properties for CI Framework
# ==============================================================================

ba-ci:executionId a owl:DatatypeProperty ;
    rdfs:label "execution ID" ;
    rdfs:comment "Unique identifier for pipeline execution" ;
    rdfs:domain ba-ci:PipelineExecution ;
    rdfs:range xsd:string ;
    skos:definition "Unique identifier for a specific pipeline execution instance" .

ba-ci:startTime a owl:DatatypeProperty ;
    rdfs:label "start time" ;
    rdfs:comment "Start time of execution" ;
    rdfs:domain ba-ci:PipelineExecution ;
    rdfs:range xsd:dateTime ;
    skos:definition "ISO 8601 timestamp indicating when execution started" .

ba-ci:endTime a owl:DatatypeProperty ;
    rdfs:label "end time" ;
    rdfs:comment "End time of execution" ;
    rdfs:domain ba-ci:PipelineExecution ;
    rdfs:range xsd:dateTime ;
    skos:definition "ISO 8601 timestamp indicating when execution completed" .

ba-ci:executionDuration a owl:DatatypeProperty ;
    rdfs:label "execution duration" ;
    rdfs:comment "Total duration of execution" ;
    rdfs:domain ba-ci:PipelineExecution ;
    rdfs:range xsd:duration ;
    skos:definition "Total duration of pipeline execution" .

ba-ci:stageDuration a owl:DatatypeProperty ;
    rdfs:label "stage duration" ;
    rdfs:comment "Duration of stage execution" ;
    rdfs:domain ba-ci:StageResult ;
    rdfs:range xsd:duration ;
    skos:definition "Duration of individual stage execution" .

ba-ci:passRate a owl:DatatypeProperty ;
    rdfs:label "pass rate" ;
    rdfs:comment "Percentage of tests that passed" ;
    rdfs:domain ba-ci:StageResult ;
    rdfs:range xsd:decimal ;
    skos:definition "Percentage (0.0-100.0) of tests that passed in the stage" .

ba-ci:coverageAchieved a owl:DatatypeProperty ;
    rdfs:label "coverage achieved" ;
    rdfs:comment "Test coverage percentage achieved" ;
    rdfs:domain ba-ci:StageResult ;
    rdfs:range xsd:decimal ;
    skos:definition "Test coverage percentage achieved by the stage" .

ba-ci:parallelismLevel a owl:DatatypeProperty ;
    rdfs:label "parallelism level" ;
    rdfs:comment "Level of parallel execution" ;
    rdfs:domain ba-ci:ParallelExecution ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "Number of parallel execution threads or processes" .

ba-ci:retryCount a owl:DatatypeProperty ;
    rdfs:label "retry count" ;
    rdfs:comment "Number of execution retries" ;
    rdfs:domain ba-ci:PipelineExecution ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "Number of times execution was retried due to failures" .

ba-ci:artifactCount a owl:DatatypeProperty ;
    rdfs:label "artifact count" ;
    rdfs:comment "Number of artifacts produced" ;
    rdfs:domain ba-ci:StageResult ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "Number of test artifacts produced by the stage" .

# ==============================================================================
# SHACL Validation Shapes for CI Framework
# ==============================================================================

ba-ci:TestAutomationCIFrameworkShape a sh:NodeShape ;
    sh:targetClass ba-ci:TestAutomationCIFramework ;
    sh:property [
        sh:path ba-ci:hasStage ;
        sh:class ba-ci:TestStage ;
        sh:minCount 1 ;
        sh:message "TestAutomationCIFramework must have at least one test stage" ;
    ] .

ba-ci:CIPipelineShape a sh:NodeShape ;
    sh:targetClass ba-ci:CIPipeline ;
    sh:property [
        sh:path ba-ci:hasStage ;
        sh:class ba-ci:TestStage ;
        sh:minCount 1 ;
        sh:message "CIPipeline must have at least one test stage" ;
    ] ;
    sh:property [
        sh:path ba-ci:triggeredBy ;
        sh:class ba-ci:PipelineTrigger ;
        sh:minCount 1 ;
        sh:message "CIPipeline must have at least one trigger" ;
    ] ;
    sh:property [
        sh:path ba-ci:hasExecutionStrategy ;
        sh:class ba:TestingStrategy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "CIPipeline must have exactly one execution strategy" ;
    ] .

ba-ci:PipelineExecutionShape a sh:NodeShape ;
    sh:targetClass ba-ci:PipelineExecution ;
    sh:property [
        sh:path ba-ci:executionId ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "PipelineExecution must have exactly one execution ID" ;
    ] ;
    sh:property [
        sh:path ba-ci:startTime ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "PipelineExecution must have exactly one start time" ;
    ] ;
    sh:property [
        sh:path ba-ci:hasExecutionStatus ;
        sh:class ba-ci:ExecutionStatus ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "PipelineExecution must have exactly one execution status" ;
    ] .

ba-ci:QualityGateManagerShape a sh:NodeShape ;
    sh:targetClass ba-ci:QualityGateManager ;
    sh:property [
        sh:path ba:hasQualityStandard ;
        sh:class ba:QualityStandard ;
        sh:minCount 1 ;
        sh:message "QualityGateManager must enforce at least one quality standard" ;
    ] .

ba-ci:HAMComplianceQualityGateShape a sh:NodeShape ;
    sh:targetClass ba-ci:HAMComplianceQualityGate ;
    sh:property [
        sh:path ba:performanceThreshold ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:message "HAMComplianceQualityGate must have performance thresholds" ;
    ] .

# ==============================================================================
# CI Framework Axioms and Rules
# ==============================================================================

# Axiom: All CI pipelines must have stages
ba-ci:CIPipeline rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-ci:hasStage ;
    owl:minCardinality 1
] .

# Axiom: All pipelines must have execution strategies
ba-ci:CIPipeline rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-ci:hasExecutionStrategy ;
    owl:cardinality 1
] .

# Axiom: Pipeline executions must have unique IDs
ba-ci:PipelineExecution rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-ci:executionId ;
    owl:cardinality 1
] .

# Axiom: HAM compliance gates enforce specific thresholds
ba-ci:HAMComplianceQualityGate rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba:performanceThreshold ;
    owl:minCardinality 1
] .

# Axiom: Quality gates must enforce standards
ba-ci:QualityGateManager rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba:hasQualityStandard ;
    owl:minCardinality 1
] .

# ==============================================================================
# Integration with ByteStar Testing Framework
# ==============================================================================

# Integration with quality assurance
ba-ci:TestAutomationCIFramework rdfs:subClassOf ba:QualityAssuranceFramework .

# Integration with test automation
ba-ci:CIPipeline rdfs:subClassOf ba:TestAutomationPipeline .

# Integration with continuous integration
ba-ci:TestStage rdfs:subClassOf ba:ContinuousIntegrationTesting .

# Integration with quality gates
ba-ci:QualityGateManager rdfs:subClassOf ba:QualityGate .

# ==============================================================================
# Comprehensive CI Framework Instance
# ==============================================================================

ba-ci:ByteStarTestAutomationCIFramework a ba-ci:TestAutomationCIFramework ;
    rdfs:label "ByteStar Test Automation CI Framework" ;
    rdfs:comment "Production instance of comprehensive test automation CI framework for ByteStar ecosystem" ;
    
    # CI pipeline integration
    ba-ci:hasStage ba-ci:ByteStarGoldenOracleStage ,
                   ba-ci:ByteStarFuzzTestingStage ,
                   ba-ci:ByteStarE2ETestingStage ,
                   ba-ci:ByteStarNegativeTestingStage ,
                   ba-ci:ByteStarBoundaryTestingStage ,
                   ba-ci:ByteStarPerformanceTestingStage ,
                   ba-ci:ByteStarSecurityTestingStage ,
                   ba-ci:ByteStarComplianceValidationStage ;
    
    # Quality gates
    ba-ci:enforcesQualityGate ba-ci:ByteStarCoverageQualityGate ,
                              ba-ci:ByteStarPerformanceQualityGate ,
                              ba-ci:ByteStarSecurityQualityGate ,
                              ba-ci:ByteStarHAMComplianceQualityGate ;
    
    # Execution strategy
    ba-ci:hasExecutionStrategy ba-ci:ByteStarAdaptiveExecution ;
    
    # Triggers
    ba-ci:triggeredBy ba-ci:ByteStarCodeCommitTrigger ,
                      ba-ci:ByteStarPullRequestTrigger ,
                      ba-ci:ByteStarScheduledTrigger ;
    
    skos:definition "Comprehensive test automation CI framework that orchestrates all testing components within unified CI/CD pipelines for the ByteStar ecosystem" .

# CI Pipeline instance
ba-ci:ByteStarMainCIPipeline a ba-ci:CIPipeline ;
    rdfs:label "ByteStar Main CI Pipeline" ;
    rdfs:comment "Main CI pipeline orchestrating comprehensive testing for ByteStar" ;
    
    # Pipeline stages
    ba-ci:hasStage ba-ci:ByteStarGoldenOracleStage ,
                   ba-ci:ByteStarFuzzTestingStage ,
                   ba-ci:ByteStarE2ETestingStage ,
                   ba-ci:ByteStarNegativeTestingStage ,
                   ba-ci:ByteStarBoundaryTestingStage ,
                   ba-ci:ByteStarComplianceValidationStage ;
    
    # Execution strategy
    ba-ci:hasExecutionStrategy ba-ci:ByteStarParallelExecution ;
    
    # Quality gates
    ba-ci:enforcesQualityGate ba-ci:ByteStarHAMComplianceQualityGate ;
    
    # Triggers
    ba-ci:triggeredBy ba-ci:ByteStarCodeCommitTrigger ,
                      ba-ci:ByteStarPullRequestTrigger ;
    
    rdfs:comment "Main CI pipeline that executes comprehensive testing workflow for ByteStar codebase changes" .

# Test stage instances
ba-ci:ByteStarGoldenOracleStage a ba-ci:GoldenOracleStage ;
    rdfs:label "ByteStar Golden Oracle Stage" ;
    ba-ci:executesTest ba-oracle:TaskCrystalOracle ,
                       ba-oracle:DataCrystalOracle ,
                       ba-oracle:ViewCrystalOracle ,
                       ba-oracle:PublicMirrorCrystalOracle ,
                       ba-oracle:PolycrystalLatticeOracle ;
    ba-ci:stageDuration "PT15M"^^xsd:duration ;
    rdfs:comment "CI stage executing golden oracle validation tests" .

ba-ci:ByteStarFuzzTestingStage a ba-ci:FuzzTestingStage ;
    rdfs:label "ByteStar Fuzz Testing Stage" ;
