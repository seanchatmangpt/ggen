                       ba-bound:Hop1Boundary ,
                       ba-bound:Hop3Boundary ,
                       ba-bound:Hop5Boundary ;
    ba-ci:stageDuration "PT10M"^^xsd:duration ;
    rdfs:comment "CI stage validating HAM compliance and Doctrine of 8 adherence" .

# Quality gate instances
ba-ci:ByteStarCoverageQualityGate a ba-ci:CoverageQualityGate ;
    rdfs:label "ByteStar Coverage Quality Gate" ;
    ba:hasQualityStandard ba:ByteStarCodeQualityStandard ;
    ba:coveragePercentage 85.0 ;
    rdfs:comment "Quality gate enforcing minimum 85% test coverage" .

ba-ci:ByteStarHAMComplianceQualityGate a ba-ci:HAMComplianceQualityGate ;
    rdfs:label "ByteStar HAM Compliance Quality Gate" ;
    ba:performanceThreshold 1.0 ;  # Hop 1
    ba:hasQualityStandard ba:ByteStarPerformanceStandard ;
    rdfs:comment "Quality gate enforcing Hardware Abstraction Model compliance" .

