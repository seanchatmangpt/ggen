    ba-bound:faultDetectionRate 0.87 ;
    rdfs:comment "Effectiveness metrics for ByteStar boundary fault detection" .

# Risk assessment instances
ba-bound:ByteStarCriticalBoundaryRisk a ba-bound:BoundaryRiskAssessment ;
    rdfs:label "ByteStar Critical Boundary Risk" ;
    ba-bound:assessesRisk ba-bound:ByteStarDoctrineOf8TimeBoundary ,
                          ba-bound:ByteStarHop1LatencyBoundary ;
    ba-bound:riskScore 0.92 ;
    rdfs:comment "Risk assessment for critical ByteStar boundary conditions" .

