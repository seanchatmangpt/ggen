# Boundary test case instances
ba-bound:ByteStarTaskCrystalExecutionLimitTest a ba-bound:TaskCrystalBoundaryTest ;
    rdfs:label "ByteStar Task Crystal Execution Limit Test" ;
    ba-bound:testsBoundary ba-bound:ByteStarTaskCrystalExecutionBoundary ;
    ba-bound:testValueBelow 7.9 ;
    ba-bound:testValueAt 8.0 ;
    ba-bound:testValueAbove 8.1 ;
    rdfs:comment "Boundary test for Task Crystal execution time limits" .

ba-bound:ByteStarDoctrineOf8ComplianceTest a ba-bound:DoctrineOf8Boundary ;
    rdfs:label "ByteStar Doctrine of 8 Compliance Test" ;
    ba-bound:testsBoundary ba-bound:ByteStarDoctrineOf8TimeBoundary ;
    ba-bound:testValueBelow 7.999 ;
    ba-bound:testValueAt 8.0 ;
    ba-bound:testValueAbove 8.001 ;
    rdfs:comment "Boundary test for Doctrine of 8 time constraint compliance" .

ba-bound:ByteStarHop1LatencyComplianceTest a ba-bound:Hop1Boundary ;
