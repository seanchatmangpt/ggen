    ba-bound:testsBoundary ba-bound:ByteStarHop1LatencyBoundary ;
    ba-bound:testValueBelow 0.99 ;
    ba-bound:testValueAt 1.0 ;
    ba-bound:testValueAbove 1.01 ;
    rdfs:comment "Boundary test for L1 cache latency constraint compliance" .

# Coverage and effectiveness measures
ba-bound:ByteStarBoundaryCoverage a ba-bound:BoundaryCoverage ;
    rdfs:label "ByteStar Boundary Coverage" ;
    ba-bound:measuresCoverage ba-bound:ByteStarTaskCrystalExecutionBoundary ,
                              ba-bound:ByteStarDataCrystalSizeBoundary ,
