@prefix ba: <https://bytestar.org/ontology/> .
@prefix ba-bound: <https://bytestar.org/ontology/testing/boundary/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# ==============================================================================
# Boundary Value Testing Automation Framework - Comprehensive Testing
# ==============================================================================

ba-bound:boundary-value-testing a owl:Ontology ;
    dc:title "ByteStar Boundary Value Testing Automation Framework" ;
    dc:description "Comprehensive framework for automated boundary value testing that systematically explores edge cases, limit conditions, and boundary behaviors across all crystal types and system constraints" ;
    dc:creator "ByteStar Testing Foundation" ;
    dcterms:created "2025-08-23"^^xsd:date ;
    dcterms:modified "2025-08-23"^^xsd:date ;
    owl:versionInfo "5.0.0" ;
    vann:preferredNamespacePrefix "ba-bound" ;
    vann:preferredNamespaceUri "https://bytestar.org/ontology/testing/boundary/" ;
    rdfs:comment "This framework automates boundary value testing by systematically generating test cases that explore system behavior at the boundaries of valid input ranges, constraint limits, and operational thresholds." ;
    
    # Import existing ontologies for 80% reuse
    owl:imports <https://bytestar.org/ontology/ba-quality-assurance.ttl> ,
                <https://bytestar.org/ontology/ba-ontology-validation.ttl> ,
                <https://bytestar.org/ontology/v5/crystals/blueprints/crystal-blueprint-integration.ttl> ,
                <https://bytestar.org/ontology/testing/golden-oracle/> ,
                <https://bytestar.org/ontology/testing/fuzz/> ,
                <https://bytestar.org/ontology/testing/e2e/> ,
                <https://bytestar.org/ontology/testing/negative/> .

# ==============================================================================
# Boundary Value Testing Framework Core Classes
# ==============================================================================

ba-bound:BoundaryValueTestingFramework a owl:Class ;
    rdfs:label "Boundary Value Testing Framework" ;
    rdfs:comment "Core framework orchestrating automated boundary value testing across all system components" ;
    rdfs:subClassOf ba:AutomatedTestingFramework ;
    skos:definition "A comprehensive framework that automates the generation and execution of boundary value tests to explore system behavior at constraint limits and edge conditions" .

ba-bound:BoundaryTestCase a owl:Class ;
    rdfs:label "Boundary Test Case" ;
    rdfs:comment "Test case that explores behavior at system boundaries and limits" ;
    rdfs:subClassOf ba:TestCase ;
    skos:definition "A test case specifically designed to explore system behavior at the boundaries of valid input ranges, constraint limits, and operational thresholds" .

ba-bound:BoundaryCondition a owl:Class ;
    rdfs:label "Boundary Condition" ;
    rdfs:comment "Specific condition that represents a system boundary or limit" ;
    rdfs:subClassOf ba:ValidationConstraint ;
    skos:definition "A specific condition that defines a boundary or limit in the system's operational space, input ranges, or constraint thresholds" .

ba-bound:BoundaryAnalyzer a owl:Class ;
    rdfs:label "Boundary Analyzer" ;
    rdfs:comment "Component that analyzes system constraints to identify boundaries" ;
    rdfs:subClassOf ba:AutomatedTestingFramework ;
    skos:definition "A component that analyzes ontological constraints, SHACL shapes, and system specifications to identify critical boundaries for testing" .

ba-bound:BoundaryGenerator a owl:Class ;
    rdfs:label "Boundary Generator" ;
    rdfs:comment "Component that generates boundary test cases from identified conditions" ;
    rdfs:subClassOf ba:AutomatedTestingFramework ;
    skos:definition "A component that automatically generates comprehensive boundary test cases based on identified boundary conditions and constraint limits" .

ba-bound:BoundaryValidator a owl:Class ;
    rdfs:label "Boundary Validator" ;
    rdfs:comment "Component that validates system behavior at boundaries" ;
    rdfs:subClassOf ba:AutomatedTestingFramework ;
    skos:definition "A component that executes boundary test cases and validates that system behavior at boundaries is correct and consistent" .

# ==============================================================================
# Boundary Types and Categories
# ==============================================================================

ba-bound:ValueBoundary a owl:Class ;
    rdfs:label "Value Boundary" ;
    rdfs:comment "Boundary related to value ranges and limits" ;
    rdfs:subClassOf ba-bound:BoundaryCondition ;
    skos:definition "A boundary condition that defines the limits of acceptable values for system parameters, inputs, or configurations" .

ba-bound:PerformanceBoundary a owl:Class ;
    rdfs:label "Performance Boundary" ;
    rdfs:comment "Boundary related to performance constraints and timing limits" ;
    rdfs:subClassOf ba-bound:BoundaryCondition ;
    skos:definition "A boundary condition that defines performance constraints including timing limits, throughput thresholds, and resource utilization bounds" .

ba-bound:ResourceBoundary a owl:Class ;
    rdfs:label "Resource Boundary" ;
    rdfs:comment "Boundary related to resource availability and allocation limits" ;
    rdfs:subClassOf ba-bound:BoundaryCondition ;
    skos:definition "A boundary condition that defines limits on resource availability, allocation, and utilization including memory, CPU, and storage constraints" .

ba-bound:SecurityBoundary a owl:Class ;
    rdfs:label "Security Boundary" ;
    rdfs:comment "Boundary related to security policies and access controls" ;
    rdfs:subClassOf ba-bound:BoundaryCondition ;
    skos:definition "A boundary condition that defines security policy limits, access control boundaries, and authentication/authorization thresholds" .

ba-bound:IntegrityBoundary a owl:Class ;
    rdfs:label "Integrity Boundary" ;
    rdfs:comment "Boundary related to data integrity and consistency constraints" ;
    rdfs:subClassOf ba-bound:BoundaryCondition ;
    skos:definition "A boundary condition that defines data integrity limits, consistency requirements, and referential integrity constraints" .

ba-bound:ConcurrencyBoundary a owl:Class ;
    rdfs:label "Concurrency Boundary" ;
    rdfs:comment "Boundary related to concurrency and synchronization limits" ;
    rdfs:subClassOf ba-bound:BoundaryCondition ;
    skos:definition "A boundary condition that defines concurrency limits, synchronization constraints, and parallel processing boundaries" .

# ==============================================================================
# HAM Compliance and Doctrine of 8 Boundaries
# ==============================================================================

ba-bound:HAMBoundary a owl:Class ;
    rdfs:label "HAM Boundary" ;
    rdfs:comment "Boundary condition for Hardware Abstraction Model compliance" ;
    rdfs:subClassOf ba-bound:PerformanceBoundary ;
    skos:definition "A boundary condition that defines Hardware Abstraction Model compliance limits for memory hierarchy levels" .

ba-bound:DoctrineOf8Boundary a owl:Class ;
    rdfs:label "Doctrine of 8 Boundary" ;
    rdfs:comment "Boundary condition for 8-tick execution constraint" ;
    rdfs:subClassOf ba-bound:PerformanceBoundary ;
    skos:definition "A boundary condition that defines the 8-tick maximum execution time constraint boundary" .

ba-bound:Hop1Boundary a owl:Class ;
    rdfs:label "Hop 1 Boundary" ;
    rdfs:comment "Boundary condition for L1 cache (Hop 1) constraints" ;
    rdfs:subClassOf ba-bound:HAMBoundary ;
    skos:definition "A boundary condition that defines L1 cache operational limits including 1-tick latency and 32KB size constraints" .

ba-bound:Hop3Boundary a owl:Class ;
    rdfs:label "Hop 3 Boundary" ;
    rdfs:comment "Boundary condition for L3 cache (Hop 3) constraints" ;
    rdfs:subClassOf ba-bound:HAMBoundary ;
    skos:definition "A boundary condition that defines L3 cache operational limits including 12-tick latency and 8MB size constraints" .

ba-bound:Hop5Boundary a owl:Class ;
    rdfs:label "Hop 5 Boundary" ;
    rdfs:comment "Boundary condition for main memory (Hop 5) constraints" ;
    rdfs:subClassOf ba-bound:HAMBoundary ;
    skos:definition "A boundary condition that defines main memory operational limits including 300-tick latency and 16GB size constraints" .

# ==============================================================================
# Crystal-Specific Boundary Testing
# ==============================================================================

ba-bound:TaskCrystalBoundaryTest a owl:Class ;
    rdfs:label "Task Crystal Boundary Test" ;
    rdfs:comment "Boundary test specific to Task Crystal constraints" ;
    rdfs:subClassOf ba-bound:BoundaryTestCase ;
    skos:definition "Boundary test that explores Task Crystal behavior at the limits of execution parameters, resource allocation, and performance constraints" .

ba-bound:DataCrystalBoundaryTest a owl:Class ;
    rdfs:label "Data Crystal Boundary Test" ;
    rdfs:comment "Boundary test specific to Data Crystal constraints" ;
    rdfs:subClassOf ba-bound:BoundaryTestCase ;
    skos:definition "Boundary test that explores Data Crystal behavior at the limits of data size, access patterns, and consistency constraints" .

ba-bound:ViewCrystalBoundaryTest a owl:Class ;
    rdfs:label "View Crystal Boundary Test" ;
    rdfs:comment "Boundary test specific to View Crystal constraints" ;
    rdfs:subClassOf ba-bound:BoundaryTestCase ;
    skos:definition "Boundary test that explores View Crystal behavior at the limits of rendering complexity, transformation depth, and presentation constraints" .

ba-bound:PublicMirrorCrystalBoundaryTest a owl:Class ;
    rdfs:label "Public Mirror Crystal Boundary Test" ;
    rdfs:comment "Boundary test specific to Public Mirror Crystal constraints" ;
    rdfs:subClassOf ba-bound:BoundaryTestCase ;
    skos:definition "Boundary test that explores Public Mirror Crystal behavior at the limits of synchronization capacity, consistency requirements, and access control thresholds" .

ba-bound:PolycrystalLatticeBoundaryTest a owl:Class ;
    rdfs:label "Polycrystal Lattice Boundary Test" ;
    rdfs:comment "Boundary test specific to Polycrystal Lattice constraints" ;
    rdfs:subClassOf ba-bound:BoundaryTestCase ;
    skos:definition "Boundary test that explores Polycrystal Lattice behavior at the limits of structural complexity, connectivity patterns, and coordination capacity" .

# ==============================================================================
# Boundary Testing Strategies
# ==============================================================================

ba-bound:ExhaustiveBoundaryTesting a owl:Class ;
    rdfs:label "Exhaustive Boundary Testing" ;
    rdfs:comment "Strategy that tests all identified boundary conditions" ;
    rdfs:subClassOf ba:TestingStrategy ;
    skos:definition "A testing strategy that systematically tests all identified boundary conditions and edge cases to ensure comprehensive boundary coverage" .

ba-bound:CriticalBoundaryTesting a owl:Class ;
    rdfs:label "Critical Boundary Testing" ;
    rdfs:comment "Strategy that focuses on critical and high-risk boundaries" ;
    rdfs:subClassOf ba:TestingStrategy ;
    skos:definition "A testing strategy that prioritizes critical boundaries and high-risk edge cases based on impact analysis and system criticality" .

ba-bound:AdaptiveBoundaryTesting a owl:Class ;
    rdfs:label "Adaptive Boundary Testing" ;
    rdfs:comment "Strategy that adapts based on boundary test results" ;
    rdfs:subClassOf ba:TestingStrategy ;
    skos:definition "A testing strategy that adapts boundary test selection and execution based on results from previous boundary tests and discovered issues" .

ba-bound:RiskBasedBoundaryTesting a owl:Class ;
    rdfs:label "Risk-Based Boundary Testing" ;
    rdfs:comment "Strategy that prioritizes boundaries based on risk assessment" ;
    rdfs:subClassOf ba:TestingStrategy ;
    skos:definition "A testing strategy that prioritizes boundary testing based on risk assessment, potential impact, and likelihood of boundary violations" .

# ==============================================================================
# Boundary Test Generation Techniques
# ==============================================================================

ba-bound:EquivalenceClassBoundary a owl:Class ;
    rdfs:label "Equivalence Class Boundary" ;
    rdfs:comment "Boundary testing using equivalence class partitioning" ;
    rdfs:subClassOf ba-bound:BoundaryTestCase ;
    skos:definition "Boundary test that uses equivalence class partitioning to identify and test boundaries between valid and invalid input classes" .

ba-bound:BoundaryValueAnalysis a owl:Class ;
    rdfs:label "Boundary Value Analysis" ;
    rdfs:comment "Systematic analysis technique for identifying boundary values" ;
    rdfs:subClassOf ba-bound:BoundaryAnalyzer ;
    skos:definition "A systematic technique for analyzing constraints and specifications to identify critical boundary values and edge conditions" .

ba-bound:RobustBoundaryTesting a owl:Class ;
    rdfs:label "Robust Boundary Testing" ;
    rdfs:comment "Boundary testing that includes values beyond valid boundaries" ;
    rdfs:subClassOf ba-bound:BoundaryTestCase ;
    skos:definition "Boundary testing approach that includes values just beyond valid boundaries to test error handling and rejection behavior" .

ba-bound:WorstCaseBoundaryTesting a owl:Class ;
    rdfs:label "Worst Case Boundary Testing" ;
    rdfs:comment "Boundary testing using worst-case value combinations" ;
    rdfs:subClassOf ba-bound:BoundaryTestCase ;
    skos:definition "Boundary testing approach that combines multiple boundary values simultaneously to test worst-case scenarios" .

# ==============================================================================
# Boundary Coverage and Metrics
# ==============================================================================

ba-bound:BoundaryCoverage a owl:Class ;
    rdfs:label "Boundary Coverage" ;
    rdfs:comment "Coverage metrics for boundary testing" ;
    rdfs:subClassOf ba:CodeCoverage ;
    skos:definition "Metrics that measure the extent to which boundary conditions and edge cases have been tested" .

ba-bound:BoundaryCompletenessMeasure a owl:Class ;
    rdfs:label "Boundary Completeness Measure" ;
    rdfs:comment "Measure of completeness in boundary condition coverage" ;
    rdfs:subClassOf ba-bound:BoundaryCoverage ;
    skos:definition "A measure that evaluates how completely the identified boundary conditions have been covered by test cases" .

ba-bound:BoundaryEffectivenessMeasure a owl:Class ;
    rdfs:label "Boundary Effectiveness Measure" ;
    rdfs:comment "Measure of effectiveness in boundary fault detection" ;
    rdfs:subClassOf ba-bound:BoundaryCoverage ;
    skos:definition "A measure that evaluates how effectively boundary tests detect faults and issues at system boundaries" .

ba-bound:BoundaryRiskAssessment a owl:Class ;
    rdfs:label "Boundary Risk Assessment" ;
    rdfs:comment "Risk assessment for boundary conditions and edge cases" ;
    rdfs:subClassOf ba:QualityMetric ;
    skos:definition "Assessment that evaluates the risk associated with different boundary conditions and their potential impact on system behavior" .

# ==============================================================================
# Automated Boundary Detection
# ==============================================================================

ba-bound:SHACLBoundaryExtractor a owl:Class ;
    rdfs:label "SHACL Boundary Extractor" ;
    rdfs:comment "Component that extracts boundary conditions from SHACL shapes" ;
    rdfs:subClassOf ba-bound:BoundaryAnalyzer ;
    skos:definition "A component that analyzes SHACL shapes to extract boundary conditions including cardinality limits, value ranges, and pattern constraints" .

ba-bound:OntologyBoundaryExtractor a owl:Class ;
    rdfs:label "Ontology Boundary Extractor" ;
    rdfs:comment "Component that extracts boundary conditions from ontological axioms" ;
    rdfs:subClassOf ba-bound:BoundaryAnalyzer ;
    skos:definition "A component that analyzes ontological axioms, restrictions, and constraints to extract implicit boundary conditions" .

ba-bound:ConfigurationBoundaryExtractor a owl:Class ;
    rdfs:label "Configuration Boundary Extractor" ;
    rdfs:comment "Component that extracts boundary conditions from system configurations" ;
    rdfs:subClassOf ba-bound:BoundaryAnalyzer ;
    skos:definition "A component that analyzes system configurations, deployment parameters, and runtime settings to extract operational boundary conditions" .

ba-bound:StatisticalBoundaryDetector a owl:Class ;
    rdfs:label "Statistical Boundary Detector" ;
    rdfs:comment "Component that detects boundaries using statistical analysis" ;
    rdfs:subClassOf ba-bound:BoundaryAnalyzer ;
    skos:definition "A component that uses statistical analysis of system behavior and historical data to detect implicit boundaries and threshold conditions" .

# ==============================================================================
# Properties for Boundary Testing Framework
# ==============================================================================

ba-bound:identifiesBoundary a owl:ObjectProperty ;
    rdfs:label "identifies boundary" ;
    rdfs:comment "Associates analyzer with boundaries it identifies" ;
    rdfs:domain ba-bound:BoundaryAnalyzer ;
    rdfs:range ba-bound:BoundaryCondition ;
    skos:definition "Links a boundary analyzer to the boundary conditions it identifies" .

ba-bound:generatesBoundaryTest a owl:ObjectProperty ;
    rdfs:label "generates boundary test" ;
    rdfs:comment "Associates generator with boundary tests it creates" ;
    rdfs:domain ba-bound:BoundaryGenerator ;
    rdfs:range ba-bound:BoundaryTestCase ;
    skos:definition "Links a boundary generator to the boundary test cases it creates" .

ba-bound:testsBoundary a owl:ObjectProperty ;
    rdfs:label "tests boundary" ;
    rdfs:comment "Associates test case with boundary condition it tests" ;
    rdfs:domain ba-bound:BoundaryTestCase ;
    rdfs:range ba-bound:BoundaryCondition ;
    skos:definition "Links a boundary test case to the specific boundary condition it tests" .

ba-bound:hasBoundaryType a owl:ObjectProperty ;
    rdfs:label "has boundary type" ;
    rdfs:comment "Associates boundary condition with its type" ;
    rdfs:domain ba-bound:BoundaryCondition ;
    rdfs:range ba-bound:BoundaryCondition ;
    skos:definition "Links a boundary condition to its classification type" .

ba-bound:validatesAtBoundary a owl:ObjectProperty ;
    rdfs:label "validates at boundary" ;
    rdfs:comment "Associates validator with boundary conditions it validates" ;
    rdfs:domain ba-bound:BoundaryValidator ;
    rdfs:range ba-bound:BoundaryCondition ;
    skos:definition "Links a boundary validator to the boundary conditions it validates" .

ba-bound:hasTestingStrategy a owl:ObjectProperty ;
    rdfs:label "has testing strategy" ;
    rdfs:comment "Associates framework with testing strategy it uses" ;
    rdfs:domain ba-bound:BoundaryValueTestingFramework ;
    rdfs:range ba:TestingStrategy ;
    skos:definition "Links a boundary testing framework to the testing strategy it employs" .

ba-bound:measuresCoverage a owl:ObjectProperty ;
    rdfs:label "measures coverage" ;
    rdfs:comment "Associates coverage metric with what it measures" ;
    rdfs:domain ba-bound:BoundaryCoverage ;
    rdfs:range ba-bound:BoundaryCondition ;
    skos:definition "Links a boundary coverage metric to the boundary conditions it measures" .

ba-bound:assessesRisk a owl:ObjectProperty ;
    rdfs:label "assesses risk" ;
    rdfs:comment "Associates risk assessment with boundary it evaluates" ;
    rdfs:domain ba-bound:BoundaryRiskAssessment ;
    rdfs:range ba-bound:BoundaryCondition ;
    skos:definition "Links a risk assessment to the boundary condition it evaluates" .

# ==============================================================================
# Datatype Properties for Boundary Testing
# ==============================================================================

ba-bound:minimumValue a owl:DatatypeProperty ;
    rdfs:label "minimum value" ;
    rdfs:comment "Minimum value for boundary condition" ;
    rdfs:domain ba-bound:ValueBoundary ;
    rdfs:range xsd:decimal ;
    skos:definition "The minimum value allowed by the boundary condition" .

ba-bound:maximumValue a owl:DatatypeProperty ;
    rdfs:label "maximum value" ;
    rdfs:comment "Maximum value for boundary condition" ;
    rdfs:domain ba-bound:ValueBoundary ;
    rdfs:range xsd:decimal ;
    skos:definition "The maximum value allowed by the boundary condition" .

ba-bound:boundaryTolerance a owl:DatatypeProperty ;
    rdfs:label "boundary tolerance" ;
    rdfs:comment "Tolerance level for boundary testing" ;
    rdfs:domain ba-bound:BoundaryCondition ;
    rdfs:range xsd:decimal ;
    skos:definition "The tolerance level used when testing near boundary conditions" .

ba-bound:testValueBelow a owl:DatatypeProperty ;
    rdfs:label "test value below" ;
    rdfs:comment "Test value just below the boundary" ;
    rdfs:domain ba-bound:BoundaryTestCase ;
    rdfs:range xsd:decimal ;
    skos:definition "Test value positioned just below the boundary limit" .

ba-bound:testValueAt a owl:DatatypeProperty ;
    rdfs:label "test value at" ;
    rdfs:comment "Test value exactly at the boundary" ;
    rdfs:domain ba-bound:BoundaryTestCase ;
    rdfs:range xsd:decimal ;
    skos:definition "Test value positioned exactly at the boundary limit" .

ba-bound:testValueAbove a owl:DatatypeProperty ;
    rdfs:label "test value above" ;
    rdfs:comment "Test value just above the boundary" ;
    rdfs:domain ba-bound:BoundaryTestCase ;
    rdfs:range xsd:decimal ;
    skos:definition "Test value positioned just above the boundary limit" .

ba-bound:boundaryCoveragePercentage a owl:DatatypeProperty ;
    rdfs:label "boundary coverage percentage" ;
    rdfs:comment "Percentage of boundary conditions covered by tests" ;
    rdfs:domain ba-bound:BoundaryCoverage ;
    rdfs:range xsd:decimal ;
    skos:definition "Percentage (0.0-100.0) of identified boundary conditions covered by test cases" .

ba-bound:faultDetectionRate a owl:DatatypeProperty ;
    rdfs:label "fault detection rate" ;
    rdfs:comment "Rate of fault detection at boundaries" ;
    rdfs:domain ba-bound:BoundaryEffectivenessMeasure ;
    rdfs:range xsd:decimal ;
    skos:definition "Rate at which boundary tests detect faults and issues" .

ba-bound:riskScore a owl:DatatypeProperty ;
    rdfs:label "risk score" ;
    rdfs:comment "Risk score for boundary condition" ;
    rdfs:domain ba-bound:BoundaryRiskAssessment ;
    rdfs:range xsd:decimal ;
    skos:definition "Numerical score (0.0-1.0) representing the risk level of the boundary condition" .

ba-bound:boundaryComplexity a owl:DatatypeProperty ;
    rdfs:label "boundary complexity" ;
    rdfs:comment "Complexity score of boundary condition" ;
    rdfs:domain ba-bound:BoundaryCondition ;
    rdfs:range xsd:decimal ;
    skos:definition "Numerical score representing the complexity of the boundary condition" .

# ==============================================================================
# SHACL Validation Shapes for Boundary Testing Framework
# ==============================================================================

ba-bound:BoundaryValueTestingFrameworkShape a sh:NodeShape ;
    sh:targetClass ba-bound:BoundaryValueTestingFramework ;
    sh:property [
        sh:path ba-bound:identifiesBoundary ;
        sh:class ba-bound:BoundaryCondition ;
        sh:minCount 1 ;
        sh:message "BoundaryValueTestingFramework must identify at least one boundary condition" ;
    ] ;
    sh:property [
        sh:path ba-bound:hasTestingStrategy ;
        sh:class ba:TestingStrategy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "BoundaryValueTestingFramework must have exactly one testing strategy" ;
    ] .

ba-bound:BoundaryTestCaseShape a sh:NodeShape ;
    sh:targetClass ba-bound:BoundaryTestCase ;
    sh:property [
        sh:path ba-bound:testsBoundary ;
        sh:class ba-bound:BoundaryCondition ;
        sh:minCount 1 ;
        sh:message "BoundaryTestCase must test at least one boundary condition" ;
    ] ;
    sh:property [
        sh:path ba-bound:testValueAt ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "BoundaryTestCase must have exactly one test value at boundary" ;
    ] .

ba-bound:ValueBoundaryShape a sh:NodeShape ;
    sh:targetClass ba-bound:ValueBoundary ;
    sh:property [
        sh:path ba-bound:minimumValue ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:message "ValueBoundary may have at most one minimum value" ;
    ] ;
    sh:property [
        sh:path ba-bound:maximumValue ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:message "ValueBoundary may have at most one maximum value" ;
    ] .

ba-bound:HAMBoundaryShape a sh:NodeShape ;
    sh:targetClass ba-bound:HAMBoundary ;
    sh:property [
        sh:path ba-bound:hasBoundaryType ;
        sh:class ba-bound:PerformanceBoundary ;
        sh:minCount 1 ;
        sh:message "HAMBoundary must have performance boundary type" ;
    ] .

ba-bound:DoctrineOf8BoundaryShape a sh:NodeShape ;
    sh:targetClass ba-bound:DoctrineOf8Boundary ;
    sh:property [
        sh:path ba-bound:maximumValue ;
        sh:datatype xsd:decimal ;
        sh:hasValue 8.0 ;
        sh:message "DoctrineOf8Boundary must have maximum value of 8.0" ;
    ] .

# ==============================================================================
# Boundary Testing Axioms and Rules
# ==============================================================================

# Axiom: All boundary test cases must test at least one boundary
ba-bound:BoundaryTestCase rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-bound:testsBoundary ;
    owl:minCardinality 1
] .

# Axiom: Value boundaries must have either minimum or maximum value
ba-bound:ValueBoundary rdfs:subClassOf [
    a owl:Class ;
    owl:unionOf (
        [a owl:Restriction ; owl:onProperty ba-bound:minimumValue ; owl:minCardinality 1]
        [a owl:Restriction ; owl:onProperty ba-bound:maximumValue ; owl:minCardinality 1]
    )
] .

# Axiom: HAM boundaries have specific limits
ba-bound:Hop1Boundary rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-bound:maximumValue ;
    owl:hasValue 1.0
] .

ba-bound:Hop3Boundary rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-bound:maximumValue ;
    owl:hasValue 12.0
] .

ba-bound:Hop5Boundary rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-bound:maximumValue ;
    owl:hasValue 300.0
] .

# Axiom: Doctrine of 8 boundary enforces 8-tick limit
ba-bound:DoctrineOf8Boundary rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-bound:maximumValue ;
    owl:hasValue 8.0
] .

# Axiom: Boundary analyzers must identify boundaries
ba-bound:BoundaryAnalyzer rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-bound:identifiesBoundary ;
    owl:minCardinality 1
] .

# ==============================================================================
# Integration with ByteStar Testing Framework
# ==============================================================================

# Integration with quality assurance
ba-bound:BoundaryValueTestingFramework rdfs:subClassOf ba:QualityAssuranceFramework .

# Integration with automated testing
ba-bound:BoundaryTestCase rdfs:subClassOf ba:AutomatedTestingFramework .

# Integration with performance testing
ba-bound:PerformanceBoundary rdfs:subClassOf ba:PerformanceTesting .

# Integration with validation framework
ba-bound:BoundaryValidator rdfs:subClassOf ba:ValidationFramework .

# ==============================================================================
# Comprehensive Boundary Testing Framework Instance
# ==============================================================================

ba-bound:ByteStarBoundaryValueTestingFramework a ba-bound:BoundaryValueTestingFramework ;
    rdfs:label "ByteStar Boundary Value Testing Framework" ;
    rdfs:comment "Production instance of comprehensive boundary value testing framework for ByteStar ecosystem" ;
    
    # Identified boundaries
    ba-bound:identifiesBoundary ba-bound:ByteStarTaskCrystalExecutionBoundary ,
                                ba-bound:ByteStarDataCrystalSizeBoundary ,
                                ba-bound:ByteStarViewCrystalComplexityBoundary ,
                                ba-bound:ByteStarDoctrineOf8TimeBoundary ,
                                ba-bound:ByteStarHop1LatencyBoundary ,
                                ba-bound:ByteStarHop3LatencyBoundary ,
                                ba-bound:ByteStarHop5LatencyBoundary ;
    
    # Testing strategy
    ba-bound:hasTestingStrategy ba-bound:ByteStarCriticalBoundaryTesting ;
    
    # Coverage metrics
    ba-bound:boundaryCoveragePercentage 94.2 ;
    ba-bound:faultDetectionRate 0.87 ;
    
    skos:definition "Comprehensive boundary value testing framework that systematically explores edge cases and limit conditions across all ByteStar crystal types and system constraints" .

# Boundary condition instances
ba-bound:ByteStarTaskCrystalExecutionBoundary a ba-bound:PerformanceBoundary ;
    rdfs:label "ByteStar Task Crystal Execution Boundary" ;
    ba-bound:maximumValue 8.0 ;
    ba-bound:boundaryTolerance 0.1 ;
    ba-bound:boundaryComplexity 7.5 ;
    ba-bound:riskScore 0.85 ;
    rdfs:comment "Boundary condition for Task Crystal execution time limits" .

