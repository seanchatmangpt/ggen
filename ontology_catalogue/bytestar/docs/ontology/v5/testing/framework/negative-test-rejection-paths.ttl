@prefix ba: <https://bytestar.org/ontology/> .
@prefix ba-neg: <https://bytestar.org/ontology/testing/negative/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# ==============================================================================
# Negative Test Cases and Rejection Path Framework - Comprehensive Testing
# ==============================================================================

ba-neg:negative-test-rejection-paths a owl:Ontology ;
    dc:title "ByteStar Negative Test Cases and Rejection Path Framework" ;
    dc:description "Comprehensive framework for creating negative test cases that validate rejection paths, error handling, and failure scenarios across all crystal types to ensure robust error detection and recovery" ;
    dc:creator "ByteStar Testing Foundation" ;
    dcterms:created "2025-08-23"^^xsd:date ;
    dcterms:modified "2025-08-23"^^xsd:date ;
    owl:versionInfo "5.0.0" ;
    vann:preferredNamespacePrefix "ba-neg" ;
    vann:preferredNamespaceUri "https://bytestar.org/ontology/testing/negative/" ;
    rdfs:comment "This framework creates comprehensive negative test cases that validate rejection paths, error conditions, and failure handling to ensure system robustness and proper error recovery." ;
    
    # Import existing ontologies for 80% reuse
    owl:imports <https://bytestar.org/ontology/ba-quality-assurance.ttl> ,
                <https://bytestar.org/ontology/ba-ontology-validation.ttl> ,
                <https://bytestar.org/ontology/v5/crystals/blueprints/crystal-blueprint-integration.ttl> ,
                <https://bytestar.org/ontology/testing/golden-oracle/> ,
                <https://bytestar.org/ontology/testing/fuzz/> ,
                <https://bytestar.org/ontology/testing/e2e/> .

# ==============================================================================
# Negative Testing Framework Core Classes
# ==============================================================================

ba-neg:NegativeTestFramework a owl:Class ;
    rdfs:label "Negative Test Framework" ;
    rdfs:comment "Core framework orchestrating negative test case creation and rejection path validation" ;
    rdfs:subClassOf ba:QualityAssuranceFramework ;
    skos:definition "A comprehensive framework that creates, manages, and executes negative test cases to validate error handling, rejection paths, and failure recovery mechanisms" .

ba-neg:NegativeTestCase a owl:Class ;
    rdfs:label "Negative Test Case" ;
    rdfs:comment "Test case designed to trigger error conditions and validate rejection paths" ;
    rdfs:subClassOf ba:TestCase ;
    skos:definition "A test case specifically designed to provide invalid inputs or create error conditions to validate system rejection and error handling behavior" .

ba-neg:RejectionPath a owl:Class ;
    rdfs:label "Rejection Path" ;
    rdfs:comment "Specific path through system that handles rejection of invalid inputs" ;
    rdfs:subClassOf ba:ValidationConstraint ;
    skos:definition "A defined path through the system that handles the rejection of invalid inputs, including error detection, validation, and appropriate response generation" .

ba-neg:ErrorCondition a owl:Class ;
    rdfs:label "Error Condition" ;
    rdfs:comment "Specific error condition that should trigger rejection" ;
    rdfs:subClassOf ba:ValidationIssue ;
    skos:definition "A specific error condition or invalid state that should trigger system rejection and appropriate error handling" .

ba-neg:RejectionValidator a owl:Class ;
    rdfs:label "Rejection Validator" ;
    rdfs:comment "Component that validates proper rejection behavior" ;
    rdfs:subClassOf ba:AutomatedTestingFramework ;
    skos:definition "A component that executes negative test cases and validates that the system properly rejects invalid inputs and handles error conditions" .

ba-neg:ErrorScenarioGenerator a owl:Class ;
    rdfs:label "Error Scenario Generator" ;
    rdfs:comment "Component that generates error scenarios and invalid inputs" ;
    rdfs:subClassOf ba:AutomatedTestingFramework ;
    skos:definition "A component that systematically generates error scenarios and invalid input combinations to test system rejection behavior" .

# ==============================================================================
# Crystal-Specific Negative Testing
# ==============================================================================

ba-neg:TaskCrystalNegativeTest a owl:Class ;
    rdfs:label "Task Crystal Negative Test" ;
    rdfs:comment "Negative test cases specific to Task Crystal validation" ;
    rdfs:subClassOf ba-neg:NegativeTestCase ;
    skos:definition "Negative test cases that validate Task Crystal rejection of invalid task definitions, execution parameters, and state transitions" .

ba-neg:DataCrystalNegativeTest a owl:Class ;
    rdfs:label "Data Crystal Negative Test" ;
    rdfs:comment "Negative test cases specific to Data Crystal validation" ;
    rdfs:subClassOf ba-neg:NegativeTestCase ;
    skos:definition "Negative test cases that validate Data Crystal rejection of invalid data structures, access patterns, and consistency violations" .

ba-neg:ViewCrystalNegativeTest a owl:Class ;
    rdfs:label "View Crystal Negative Test" ;
    rdfs:comment "Negative test cases specific to View Crystal validation" ;
    rdfs:subClassOf ba-neg:NegativeTestCase ;
    skos:definition "Negative test cases that validate View Crystal rejection of invalid rendering requests, transformation errors, and presentation constraint violations" .

ba-neg:PublicMirrorCrystalNegativeTest a owl:Class ;
    rdfs:label "Public Mirror Crystal Negative Test" ;
    rdfs:comment "Negative test cases specific to Public Mirror Crystal validation" ;
    rdfs:subClassOf ba-neg:NegativeTestCase ;
    skos:definition "Negative test cases that validate Public Mirror Crystal rejection of invalid synchronization requests, consistency violations, and access control breaches" .

ba-neg:PolycrystalLatticeNegativeTest a owl:Class ;
    rdfs:label "Polycrystal Lattice Negative Test" ;
    rdfs:comment "Negative test cases specific to Polycrystal Lattice validation" ;
    rdfs:subClassOf ba-neg:NegativeTestCase ;
    skos:definition "Negative test cases that validate Polycrystal Lattice rejection of invalid structural configurations, connectivity violations, and coordination failures" .

# ==============================================================================
# Error Categories and Classification
# ==============================================================================

ba-neg:ValidationError a owl:Class ;
    rdfs:label "Validation Error" ;
    rdfs:comment "Error condition related to input validation failures" ;
    rdfs:subClassOf ba-neg:ErrorCondition ;
    skos:definition "An error condition that occurs when input data fails validation against defined constraints and business rules" .

ba-neg:ConstraintViolation a owl:Class ;
    rdfs:label "Constraint Violation" ;
    rdfs:comment "Error condition related to ontological constraint violations" ;
    rdfs:subClassOf ba-neg:ErrorCondition ;
    skos:definition "An error condition that occurs when operations violate ontological constraints, cardinality restrictions, or logical axioms" .

ba-neg:SecurityViolation a owl:Class ;
    rdfs:label "Security Violation" ;
    rdfs:comment "Error condition related to security policy violations" ;
    rdfs:subClassOf ba-neg:ErrorCondition ;
    skos:definition "An error condition that occurs when operations violate security policies, access controls, or authentication requirements" .

ba-neg:PerformanceViolation a owl:Class ;
    rdfs:label "Performance Violation" ;
    rdfs:comment "Error condition related to performance constraint violations" ;
    rdfs:subClassOf ba-neg:ErrorCondition ;
    skos:definition "An error condition that occurs when operations violate performance constraints, timing requirements, or resource limits" .

ba-neg:IntegrityViolation a owl:Class ;
    rdfs:label "Integrity Violation" ;
    rdfs:comment "Error condition related to data integrity violations" ;
    rdfs:subClassOf ba-neg:ErrorCondition ;
    skos:definition "An error condition that occurs when operations violate data integrity constraints, consistency requirements, or referential integrity" .

ba-neg:ResourceExhaustion a owl:Class ;
    rdfs:label "Resource Exhaustion" ;
    rdfs:comment "Error condition related to resource exhaustion" ;
    rdfs:subClassOf ba-neg:ErrorCondition ;
    skos:definition "An error condition that occurs when system resources are exhausted or exceed defined limits" .

# ==============================================================================
# HAM Compliance and Doctrine of 8 Negative Testing
# ==============================================================================

ba-neg:HAMViolationTest a owl:Class ;
    rdfs:label "HAM Violation Test" ;
    rdfs:comment "Negative test for Hardware Abstraction Model violations" ;
    rdfs:subClassOf ba-neg:PerformanceViolation ;
    skos:definition "Negative test that validates rejection of operations that violate Hardware Abstraction Model constraints" .

ba-neg:DoctrineOf8ViolationTest a owl:Class ;
    rdfs:label "Doctrine of 8 Violation Test" ;
    rdfs:comment "Negative test for 8-tick execution constraint violations" ;
    rdfs:subClassOf ba-neg:PerformanceViolation ;
    skos:definition "Negative test that validates rejection of operations that violate the Doctrine of 8 maximum execution time constraint" .

ba-neg:Hop1ViolationTest a owl:Class ;
    rdfs:label "Hop 1 Violation Test" ;
    rdfs:comment "Negative test for L1 cache (Hop 1) constraint violations" ;
    rdfs:subClassOf ba-neg:HAMViolationTest ;
    skos:definition "Negative test that validates rejection of operations that violate L1 cache constraints (>1 tick latency or >32KB size)" .

ba-neg:Hop3ViolationTest a owl:Class ;
    rdfs:label "Hop 3 Violation Test" ;
    rdfs:comment "Negative test for L3 cache (Hop 3) constraint violations" ;
    rdfs:subClassOf ba-neg:HAMViolationTest ;
    skos:definition "Negative test that validates rejection of operations that violate L3 cache constraints (>12 tick latency or >8MB size)" .

ba-neg:Hop5ViolationTest a owl:Class ;
    rdfs:label "Hop 5 Violation Test" ;
    rdfs:comment "Negative test for main memory (Hop 5) constraint violations" ;
    rdfs:subClassOf ba-neg:HAMViolationTest ;
    skos:definition "Negative test that validates rejection of operations that violate main memory constraints (>300 tick latency or >16GB size)" .

# ==============================================================================
# Rejection Response Types
# ==============================================================================

ba-neg:RejectionResponse a owl:Class ;
    rdfs:label "Rejection Response" ;
    rdfs:comment "Response generated when input is rejected" ;
    rdfs:subClassOf ba:TestResult ;
    skos:definition "A structured response generated by the system when invalid input is properly rejected" .

ba-neg:ValidationErrorResponse a owl:Class ;
    rdfs:label "Validation Error Response" ;
    rdfs:comment "Response for validation error rejection" ;
    rdfs:subClassOf ba-neg:RejectionResponse ;
    skos:definition "A response that provides detailed information about validation failures and constraint violations" .

ba-neg:SecurityDeniedResponse a owl:Class ;
    rdfs:label "Security Denied Response" ;
    rdfs:comment "Response for security violation rejection" ;
    rdfs:subClassOf ba-neg:RejectionResponse ;
    skos:definition "A response that indicates access denial due to security policy violations without revealing sensitive information" .

ba-neg:ResourceLimitResponse a owl:Class ;
    rdfs:label "Resource Limit Response" ;
    rdfs:comment "Response for resource limit violation rejection" ;
    rdfs:subClassOf ba-neg:RejectionResponse ;
    skos:definition "A response that indicates rejection due to resource limits or capacity constraints" .

ba-neg:PerformanceConstraintResponse a owl:Class ;
    rdfs:label "Performance Constraint Response" ;
    rdfs:comment "Response for performance constraint violation rejection" ;
    rdfs:subClassOf ba-neg:RejectionResponse ;
    skos:definition "A response that indicates rejection due to performance constraint violations or timing requirements" .

ba-neg:IntegrityErrorResponse a owl:Class ;
    rdfs:label "Integrity Error Response" ;
    rdfs:comment "Response for data integrity violation rejection" ;
    rdfs:subClassOf ba-neg:RejectionResponse ;
    skos:definition "A response that indicates rejection due to data integrity violations or consistency failures" .

# ==============================================================================
# Edge Case and Boundary Testing
# ==============================================================================

ba-neg:BoundaryViolationTest a owl:Class ;
    rdfs:label "Boundary Violation Test" ;
    rdfs:comment "Negative test for boundary condition violations" ;
    rdfs:subClassOf ba-neg:NegativeTestCase ;
    skos:definition "Negative test that validates rejection of inputs that violate boundary conditions and limit thresholds" .

ba-neg:EdgeCaseError a owl:Class ;
    rdfs:label "Edge Case Error" ;
    rdfs:comment "Error condition at system boundaries or limits" ;
    rdfs:subClassOf ba-neg:ErrorCondition ;
    skos:definition "An error condition that occurs at the boundaries of valid input ranges or system operational limits" .

ba-neg:OverflowTest a owl:Class ;
    rdfs:label "Overflow Test" ;
    rdfs:comment "Negative test for overflow conditions" ;
    rdfs:subClassOf ba-neg:BoundaryViolationTest ;
    skos:definition "Negative test that validates rejection of inputs that cause overflow conditions or exceed maximum values" .

ba-neg:UnderflowTest a owl:Class ;
    rdfs:label "Underflow Test" ;
    rdfs:comment "Negative test for underflow conditions" ;
    rdfs:subClassOf ba-neg:BoundaryViolationTest ;
    skos:definition "Negative test that validates rejection of inputs that cause underflow conditions or fall below minimum values" .

ba-neg:NullPointerTest a owl:Class ;
    rdfs:label "Null Pointer Test" ;
    rdfs:comment "Negative test for null pointer and missing reference handling" ;
    rdfs:subClassOf ba-neg:EdgeCaseError ;
    skos:definition "Negative test that validates proper handling of null references and missing required parameters" .

ba-neg:InvalidTypeTest a owl:Class ;
    rdfs:label "Invalid Type Test" ;
    rdfs:comment "Negative test for type mismatch and invalid type handling" ;
    rdfs:subClassOf ba-neg:ValidationError ;
    skos:definition "Negative test that validates rejection of inputs with invalid types or type mismatches" .

# ==============================================================================
# Concurrency and Race Condition Testing
# ==============================================================================

ba-neg:ConcurrencyViolationTest a owl:Class ;
    rdfs:label "Concurrency Violation Test" ;
    rdfs:comment "Negative test for concurrency and synchronization violations" ;
    rdfs:subClassOf ba-neg:NegativeTestCase ;
    skos:definition "Negative test that validates rejection of operations that violate concurrency constraints and synchronization requirements" .

ba-neg:RaceConditionTest a owl:Class ;
    rdfs:label "Race Condition Test" ;
    rdfs:comment "Negative test for race condition detection and handling" ;
    rdfs:subClassOf ba-neg:ConcurrencyViolationTest ;
    skos:definition "Negative test that validates detection and proper handling of race conditions in concurrent operations" .

ba-neg:DeadlockTest a owl:Class ;
    rdfs:label "Deadlock Test" ;
    rdfs:comment "Negative test for deadlock detection and prevention" ;
    rdfs:subClassOf ba-neg:ConcurrencyViolationTest ;
    skos:definition "Negative test that validates detection and prevention of deadlock conditions in resource allocation" .

ba-neg:LivelockTest a owl:Class ;
    rdfs:label "Livelock Test" ;
    rdfs:comment "Negative test for livelock detection and resolution" ;
    rdfs:subClassOf ba-neg:ConcurrencyViolationTest ;
    skos:definition "Negative test that validates detection and resolution of livelock conditions where processes remain active but make no progress" .

# ==============================================================================
# Malformed Input and Injection Testing
# ==============================================================================

ba-neg:MalformedInputTest a owl:Class ;
    rdfs:label "Malformed Input Test" ;
    rdfs:comment "Negative test for malformed input handling" ;
    rdfs:subClassOf ba-neg:ValidationError ;
    skos:definition "Negative test that validates rejection of malformed, corrupted, or structurally invalid inputs" .

ba-neg:InjectionTest a owl:Class ;
    rdfs:label "Injection Test" ;
    rdfs:comment "Negative test for injection attack prevention" ;
    rdfs:subClassOf ba-neg:SecurityViolation ;
    skos:definition "Negative test that validates prevention of injection attacks including code injection, SQL injection, and command injection" .

ba-neg:BufferOverflowTest a owl:Class ;
    rdfs:label "Buffer Overflow Test" ;
    rdfs:comment "Negative test for buffer overflow prevention" ;
    rdfs:subClassOf ba-neg:SecurityViolation ;
    skos:definition "Negative test that validates prevention of buffer overflow attacks and proper memory boundary enforcement" .

ba-neg:PathTraversalTest a owl:Class ;
    rdfs:label "Path Traversal Test" ;
    rdfs:comment "Negative test for path traversal attack prevention" ;
    rdfs:subClassOf ba-neg:SecurityViolation ;
    skos:definition "Negative test that validates prevention of path traversal attacks and unauthorized file access" .

# ==============================================================================
# Properties for Negative Testing Framework
# ==============================================================================

ba-neg:triggersRejection a owl:ObjectProperty ;
    rdfs:label "triggers rejection" ;
    rdfs:comment "Associates test case with rejection path it triggers" ;
    rdfs:domain ba-neg:NegativeTestCase ;
    rdfs:range ba-neg:RejectionPath ;
    skos:definition "Links a negative test case to the rejection path it is designed to trigger" .

ba-neg:validatesErrorCondition a owl:ObjectProperty ;
    rdfs:label "validates error condition" ;
    rdfs:comment "Associates test case with error condition it validates" ;
    rdfs:domain ba-neg:NegativeTestCase ;
    rdfs:range ba-neg:ErrorCondition ;
    skos:definition "Links a negative test case to the specific error condition it validates" .

ba-neg:generatesResponse a owl:ObjectProperty ;
    rdfs:label "generates response" ;
    rdfs:comment "Associates rejection path with response it generates" ;
    rdfs:domain ba-neg:RejectionPath ;
    rdfs:range ba-neg:RejectionResponse ;
    skos:definition "Links a rejection path to the response it generates when triggered" .

ba-neg:hasErrorType a owl:ObjectProperty ;
    rdfs:label "has error type" ;
    rdfs:comment "Associates error condition with its type" ;
    rdfs:domain ba-neg:ErrorCondition ;
    rdfs:range ba-neg:ErrorCondition ;
    skos:definition "Links an error condition to its classification type" .

ba-neg:handlesRejection a owl:ObjectProperty ;
    rdfs:label "handles rejection" ;
    rdfs:comment "Associates validator with rejection paths it handles" ;
    rdfs:domain ba-neg:RejectionValidator ;
    rdfs:range ba-neg:RejectionPath ;
    skos:definition "Links a rejection validator to the rejection paths it validates" .

ba-neg:producesErrorScenario a owl:ObjectProperty ;
    rdfs:label "produces error scenario" ;
    rdfs:comment "Associates generator with error scenarios it produces" ;
    rdfs:domain ba-neg:ErrorScenarioGenerator ;
    rdfs:range ba-neg:NegativeTestCase ;
    skos:definition "Links an error scenario generator to the negative test cases it produces" .

ba-neg:violatesConstraint a owl:ObjectProperty ;
    rdfs:label "violates constraint" ;
    rdfs:comment "Associates error condition with constraint it violates" ;
    rdfs:domain ba-neg:ErrorCondition ;
    rdfs:range ba:ValidationConstraint ;
    skos:definition "Links an error condition to the specific constraint it violates" .

ba-neg:expectsRejection a owl:ObjectProperty ;
    rdfs:label "expects rejection" ;
    rdfs:comment "Associates test case with expected rejection behavior" ;
    rdfs:domain ba-neg:NegativeTestCase ;
    rdfs:range ba-neg:RejectionResponse ;
    skos:definition "Links a negative test case to the rejection response it expects" .

# ==============================================================================
# Datatype Properties for Negative Testing
# ==============================================================================

ba-neg:rejectionCode a owl:DatatypeProperty ;
    rdfs:label "rejection code" ;
    rdfs:comment "Numeric code identifying rejection reason" ;
    rdfs:domain ba-neg:RejectionResponse ;
    rdfs:range xsd:integer ;
    skos:definition "Numeric error code that identifies the specific reason for rejection" .

ba-neg:errorMessage a owl:DatatypeProperty ;
    rdfs:label "error message" ;
    rdfs:comment "Human-readable error message for rejection" ;
    rdfs:domain ba-neg:RejectionResponse ;
    rdfs:range xsd:string ;
    skos:definition "Human-readable error message explaining the rejection reason" .

ba-neg:violationSeverity a owl:DatatypeProperty ;
    rdfs:label "violation severity" ;
    rdfs:comment "Severity level of constraint violation" ;
    rdfs:domain ba-neg:ConstraintViolation ;
    rdfs:range xsd:string ;
    skos:definition "Severity level (Critical, High, Medium, Low) of the constraint violation" .

ba-neg:invalidInputValue a owl:DatatypeProperty ;
    rdfs:label "invalid input value" ;
    rdfs:comment "The invalid input value that triggers rejection" ;
    rdfs:domain ba-neg:NegativeTestCase ;
    rdfs:range xsd:string ;
    skos:definition "JSON representation of the invalid input value used in the negative test case" .

ba-neg:expectedErrorCode a owl:DatatypeProperty ;
    rdfs:label "expected error code" ;
    rdfs:comment "Expected error code for test case" ;
    rdfs:domain ba-neg:NegativeTestCase ;
    rdfs:range xsd:integer ;
    skos:definition "Expected numeric error code that should be returned for the negative test case" .

ba-neg:rejectionTimestamp a owl:DatatypeProperty ;
    rdfs:label "rejection timestamp" ;
    rdfs:comment "Timestamp when rejection occurred" ;
    rdfs:domain ba-neg:RejectionResponse ;
    rdfs:range xsd:dateTime ;
    skos:definition "ISO 8601 timestamp indicating when the rejection occurred" .

ba-neg:violationCount a owl:DatatypeProperty ;
    rdfs:label "violation count" ;
    rdfs:comment "Number of violations detected" ;
    rdfs:domain ba-neg:ErrorCondition ;
    rdfs:range xsd:nonNegativeInteger ;
    skos:definition "Total number of violations detected for the error condition" .

ba-neg:rejectionRate a owl:DatatypeProperty ;
    rdfs:label "rejection rate" ;
    rdfs:comment "Rate of rejection for test scenarios" ;
    rdfs:domain ba-neg:RejectionValidator ;
    rdfs:range xsd:decimal ;
    skos:definition "Percentage rate of successful rejections for negative test scenarios" .

ba-neg:recoveryTime a owl:DatatypeProperty ;
    rdfs:label "recovery time" ;
    rdfs:comment "Time required for error recovery" ;
    rdfs:domain ba-neg:ErrorCondition ;
    rdfs:range xsd:duration ;
    skos:definition "Duration required for the system to recover from the error condition" .

ba-neg:falsePositiveRate a owl:DatatypeProperty ;
    rdfs:label "false positive rate" ;
    rdfs:comment "Rate of false positive rejections" ;
    rdfs:domain ba-neg:RejectionValidator ;
    rdfs:range xsd:decimal ;
    skos:definition "Percentage rate of valid inputs incorrectly rejected by the system" .

# ==============================================================================
# SHACL Validation Shapes for Negative Testing Framework
# ==============================================================================

ba-neg:NegativeTestFrameworkShape a sh:NodeShape ;
    sh:targetClass ba-neg:NegativeTestFramework ;
    sh:property [
        sh:path ba-neg:handlesRejection ;
        sh:class ba-neg:RejectionPath ;
        sh:minCount 1 ;
        sh:message "NegativeTestFramework must handle at least one rejection path" ;
    ] .

ba-neg:NegativeTestCaseShape a sh:NodeShape ;
    sh:targetClass ba-neg:NegativeTestCase ;
    sh:property [
        sh:path ba-neg:invalidInputValue ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "NegativeTestCase must have exactly one invalid input value" ;
    ] ;
    sh:property [
        sh:path ba-neg:expectedErrorCode ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "NegativeTestCase must have exactly one expected error code" ;
    ] ;
    sh:property [
        sh:path ba-neg:triggersRejection ;
        sh:class ba-neg:RejectionPath ;
        sh:minCount 1 ;
        sh:message "NegativeTestCase must trigger at least one rejection path" ;
    ] .

ba-neg:RejectionResponseShape a sh:NodeShape ;
    sh:targetClass ba-neg:RejectionResponse ;
    sh:property [
        sh:path ba-neg:rejectionCode ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "RejectionResponse must have exactly one rejection code" ;
    ] ;
    sh:property [
        sh:path ba-neg:errorMessage ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "RejectionResponse must have exactly one error message" ;
    ] ;
    sh:property [
        sh:path ba-neg:rejectionTimestamp ;
        sh:datatype xsd:dateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "RejectionResponse must have exactly one rejection timestamp" ;
    ] .

ba-neg:HAMViolationTestShape a sh:NodeShape ;
    sh:targetClass ba-neg:HAMViolationTest ;
    sh:property [
        sh:path ba-neg:violatesConstraint ;
        sh:class ba:ValidationConstraint ;
        sh:minCount 1 ;
        sh:message "HAMViolationTest must violate at least one constraint" ;
    ] .

ba-neg:DoctrineOf8ViolationTestShape a sh:NodeShape ;
    sh:targetClass ba-neg:DoctrineOf8ViolationTest ;
    sh:property [
        sh:path ba-neg:expectedErrorCode ;
        sh:datatype xsd:integer ;
        sh:hasValue 8008 ;
        sh:message "DoctrineOf8ViolationTest must expect error code 8008" ;
    ] .

# ==============================================================================
# Negative Testing Axioms and Rules
# ==============================================================================

# Axiom: All negative test cases must trigger rejection
ba-neg:NegativeTestCase rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-neg:triggersRejection ;
    owl:minCardinality 1
] .

# Axiom: All rejection paths must generate responses
ba-neg:RejectionPath rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-neg:generatesResponse ;
    owl:minCardinality 1
] .

# Axiom: HAM violation tests must have specific error codes
ba-neg:Hop1ViolationTest rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-neg:expectedErrorCode ;
    owl:hasValue 1001
] .

ba-neg:Hop3ViolationTest rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-neg:expectedErrorCode ;
    owl:hasValue 3001
] .

ba-neg:Hop5ViolationTest rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-neg:expectedErrorCode ;
    owl:hasValue 5001
] .

# Axiom: Doctrine of 8 violations have specific error handling
ba-neg:DoctrineOf8ViolationTest rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-neg:expectedErrorCode ;
    owl:hasValue 8008
] .

# Axiom: Security violations must not reveal sensitive information
ba-neg:SecurityViolation rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ba-neg:errorMessage ;
    owl:hasValue "Access Denied"
] .

# ==============================================================================
# Integration with ByteStar Testing Framework
# ==============================================================================

# Integration with quality assurance
ba-neg:NegativeTestFramework rdfs:subClassOf ba:QualityAssuranceFramework .

# Integration with automated testing
ba-neg:RejectionValidator rdfs:subClassOf ba:AutomatedTestingFramework .

# Integration with security testing
ba-neg:SecurityViolation rdfs:subClassOf ba:SecurityTesting .

# Integration with performance testing
ba-neg:PerformanceViolation rdfs:subClassOf ba:PerformanceTesting .

# ==============================================================================
# Comprehensive Negative Test Framework Instance
# ==============================================================================

ba-neg:ByteStarNegativeTestFramework a ba-neg:NegativeTestFramework ;
    rdfs:label "ByteStar Negative Test Framework" ;
    rdfs:comment "Production instance of comprehensive negative test framework for ByteStar ecosystem" ;
    
    # Rejection path coverage
    ba-neg:handlesRejection ba-neg:ByteStarValidationRejectionPath ,
                            ba-neg:ByteStarSecurityRejectionPath ,
                            ba-neg:ByteStarPerformanceRejectionPath ,
                            ba-neg:ByteStarIntegrityRejectionPath ;
    
    # Quality metrics
