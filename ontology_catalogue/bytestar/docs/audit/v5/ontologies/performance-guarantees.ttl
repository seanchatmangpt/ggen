@prefix : <https://bytestar.org/ontology/v5/performance#> .
@prefix perf: <https://bytestar.org/ontology/v5/performance#> .
@prefix sla: <https://bytestar.org/ontology/v5/sla#> .
@prefix bytestar: <https://bytestar.org/ontology/bytestar-core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://bytestar.org/ontology/v5/performance>
  a owl:Ontology ;
  owl:versionInfo "5.0.0" ;
  rdfs:label "ByteStar v5 Performance Guarantees Ontology" ;
  rdfs:comment "Formal specification of performance requirements and SLA guarantees" .

#################################################################
# Performance Metric Classes
#################################################################

:PerformanceMetric a owl:Class ;
  rdfs:label "Performance Metric" ;
  rdfs:comment "Abstract performance measurement" .

:Throughput a owl:Class ;
  rdfs:subClassOf :PerformanceMetric ;
  rdfs:label "Throughput" ;
  rdfs:comment "Operations per second" .

:Latency a owl:Class ;
  rdfs:subClassOf :PerformanceMetric ;
  rdfs:label "Latency" ;
  rdfs:comment "Response time measurement" .

:CPUUtilization a owl:Class ;
  rdfs:subClassOf :PerformanceMetric ;
  rdfs:label "CPU Utilization" ;
  rdfs:comment "CPU usage percentage" .

:MemoryUtilization a owl:Class ;
  rdfs:subClassOf :PerformanceMetric ;
  rdfs:label "Memory Utilization" ;
  rdfs:comment "Memory usage metrics" .

:CachePerformance a owl:Class ;
  rdfs:subClassOf :PerformanceMetric ;
  rdfs:label "Cache Performance" ;
  rdfs:comment "Cache hit rates and efficiency" .

#################################################################
# Latency Breakdown Classes
#################################################################

:P50Latency a owl:Class ;
  rdfs:subClassOf :Latency ;
  rdfs:label "P50 Latency" ;
  rdfs:comment "50th percentile latency (median)" .

:P90Latency a owl:Class ;
  rdfs:subClassOf :Latency ;
  rdfs:label "P90 Latency" ;
  rdfs:comment "90th percentile latency" .

:P99Latency a owl:Class ;
  rdfs:subClassOf :Latency ;
  rdfs:label "P99 Latency" ;
  rdfs:comment "99th percentile latency" .

:P999Latency a owl:Class ;
  rdfs:subClassOf :Latency ;
  rdfs:label "P99.9 Latency" ;
  rdfs:comment "99.9th percentile latency" .

:MaxLatency a owl:Class ;
  rdfs:subClassOf :Latency ;
  rdfs:label "Maximum Latency" ;
  rdfs:comment "Maximum observed latency" .

#################################################################
# Doctrine of 8 Classes
#################################################################

:DoctrineOf8 a owl:Class ;
  rdfs:label "Doctrine of 8" ;
  rdfs:comment "8-tick execution guarantee" .

:TickCount a owl:Class ;
  rdfs:label "Tick Count" ;
  rdfs:comment "CPU tick measurement" .

:HotPath a owl:Class ;
  rdfs:label "Hot Path" ;
  rdfs:comment "Performance-critical execution path" .

:ColdPath a owl:Class ;
  rdfs:label "Cold Path" ;
  rdfs:comment "Non-critical execution path" .

#################################################################
# SLA Classes
#################################################################

sla:ServiceLevelAgreement a owl:Class ;
  rdfs:label "Service Level Agreement" ;
  rdfs:comment "Contractual performance guarantee" .

sla:Availability a owl:Class ;
  rdfs:label "Availability" ;
  rdfs:comment "System uptime guarantee" .

sla:ResponseTime a owl:Class ;
  rdfs:label "Response Time" ;
  rdfs:comment "Response time guarantee" .

sla:ThroughputGuarantee a owl:Class ;
  rdfs:label "Throughput Guarantee" ;
  rdfs:comment "Minimum throughput guarantee" .

#################################################################
# Hardware Performance Classes
#################################################################

:HardwareProfile a owl:Class ;
  rdfs:label "Hardware Profile" ;
  rdfs:comment "Hardware configuration profile" .

:CPUProfile a owl:Class ;
  rdfs:subClassOf :HardwareProfile ;
  rdfs:label "CPU Profile" ;
  rdfs:comment "CPU specifications and capabilities" .

:MemoryProfile a owl:Class ;
  rdfs:subClassOf :HardwareProfile ;
  rdfs:label "Memory Profile" ;
  rdfs:comment "Memory specifications" .

:GPUProfile a owl:Class ;
  rdfs:subClassOf :HardwareProfile ;
  rdfs:label "GPU Profile" ;
  rdfs:comment "GPU specifications for acceleration" .

#################################################################
# Properties
#################################################################

# Metric Value Properties
:value a owl:DatatypeProperty ;
  rdfs:domain :PerformanceMetric ;
  rdfs:range xsd:float ;
  rdfs:comment "Metric value" .

:unit a owl:DatatypeProperty ;
  rdfs:domain :PerformanceMetric ;
  rdfs:range xsd:string ;
  rdfs:comment "Measurement unit" .

:timestamp a owl:DatatypeProperty ;
  rdfs:domain :PerformanceMetric ;
  rdfs:range xsd:dateTime ;
  rdfs:comment "Measurement timestamp" .

# Throughput Properties
:operationsPerSecond a owl:DatatypeProperty ;
  rdfs:domain :Throughput ;
  rdfs:range xsd:integer ;
  rdfs:comment "Operations per second count" .

:transactionsPerSecond a owl:DatatypeProperty ;
  rdfs:domain :Throughput ;
  rdfs:range xsd:integer ;
  rdfs:comment "Transactions per second" .

:bytesPerSecond a owl:DatatypeProperty ;
  rdfs:domain :Throughput ;
  rdfs:range xsd:integer ;
  rdfs:comment "Data throughput in bytes/sec" .

# Latency Properties
:microseconds a owl:DatatypeProperty ;
  rdfs:domain :Latency ;
  rdfs:range xsd:integer ;
  rdfs:comment "Latency in microseconds" .

:nanoseconds a owl:DatatypeProperty ;
  rdfs:domain :Latency ;
  rdfs:range xsd:integer ;
  rdfs:comment "Latency in nanoseconds" .

# Doctrine of 8 Properties
:tickCount a owl:DatatypeProperty ;
  rdfs:domain :TickCount ;
  rdfs:range xsd:integer ;
  rdfs:comment "Number of CPU ticks" .

:isCompliant a owl:DatatypeProperty ;
  rdfs:domain :DoctrineOf8 ;
  rdfs:range xsd:boolean ;
  rdfs:comment "Whether kernel is Doctrine of 8 compliant" .

# Cache Properties
:l1HitRate a owl:DatatypeProperty ;
  rdfs:domain :CachePerformance ;
  rdfs:range xsd:float ;
  rdfs:comment "L1 cache hit rate (0.0 to 1.0)" .

:l2HitRate a owl:DatatypeProperty ;
  rdfs:domain :CachePerformance ;
  rdfs:range xsd:float ;
  rdfs:comment "L2 cache hit rate (0.0 to 1.0)" .

:l3HitRate a owl:DatatypeProperty ;
  rdfs:domain :CachePerformance ;
  rdfs:range xsd:float ;
  rdfs:comment "L3 cache hit rate (0.0 to 1.0)" .

:cacheMissRate a owl:DatatypeProperty ;
  rdfs:domain :CachePerformance ;
  rdfs:range xsd:float ;
  rdfs:comment "Overall cache miss rate" .

# SLA Properties
:uptimePercentage a owl:DatatypeProperty ;
  rdfs:domain sla:Availability ;
  rdfs:range xsd:float ;
  rdfs:comment "Required uptime percentage" .

:maxDowntimeMinutes a owl:DatatypeProperty ;
  rdfs:domain sla:Availability ;
  rdfs:range xsd:integer ;
  rdfs:comment "Maximum allowed downtime per year in minutes" .

# Hardware Properties
:cpuCores a owl:DatatypeProperty ;
  rdfs:domain :CPUProfile ;
  rdfs:range xsd:integer ;
  rdfs:comment "Number of CPU cores" .

:cpuFrequencyGHz a owl:DatatypeProperty ;
  rdfs:domain :CPUProfile ;
  rdfs:range xsd:float ;
  rdfs:comment "CPU frequency in GHz" .

:memoryGB a owl:DatatypeProperty ;
  rdfs:domain :MemoryProfile ;
  rdfs:range xsd:integer ;
  rdfs:comment "Memory size in GB" .

:memoryBandwidthGBps a owl:DatatypeProperty ;
  rdfs:domain :MemoryProfile ;
  rdfs:range xsd:float ;
  rdfs:comment "Memory bandwidth in GB/s" .

:gpuCores a owl:DatatypeProperty ;
  rdfs:domain :GPUProfile ;
  rdfs:range xsd:integer ;
  rdfs:comment "Number of GPU cores" .

:gpuMemoryGB a owl:DatatypeProperty ;
  rdfs:domain :GPUProfile ;
  rdfs:range xsd:integer ;
  rdfs:comment "GPU memory in GB" .

#################################################################
# Performance Targets (v5 Goals)
#################################################################

# Throughput Targets
:TargetThroughput a :Throughput ;
  :operationsPerSecond "250000"^^xsd:integer ;
  :unit "ops/sec" ;
  rdfs:comment "v5 target: 250,000+ operations per second" .

# Latency Targets
:TargetP50 a :P50Latency ;
  :microseconds "10"^^xsd:integer ;
  rdfs:comment "v5 target: P50 < 10μs" .

:TargetP90 a :P90Latency ;
  :microseconds "15"^^xsd:integer ;
  rdfs:comment "v5 target: P90 < 15μs" .

:TargetP99 a :P99Latency ;
  :microseconds "25"^^xsd:integer ;
  rdfs:comment "v5 target: P99 < 25μs" .

:TargetP999 a :P999Latency ;
  :microseconds "100"^^xsd:integer ;
  rdfs:comment "v5 target: P99.9 < 100μs" .

# Doctrine of 8 Compliance
:DoctrineCompliance a :DoctrineOf8 ;
  :isCompliant true ;
  :tickCount "8"^^xsd:integer ;
  rdfs:comment "All hot path kernels ≤8 ticks" .

# Cache Performance Targets
:TargetCachePerformance a :CachePerformance ;
  :l1HitRate "0.99"^^xsd:float ;
  :l2HitRate "0.95"^^xsd:float ;
  :l3HitRate "0.90"^^xsd:float ;
  :cacheMissRate "0.01"^^xsd:float ;
  rdfs:comment "v5 cache performance targets" .

# SLA Targets
:ProductionSLA a sla:ServiceLevelAgreement ;
  rdfs:label "Production SLA" ;
  rdfs:comment "v5 production service level agreement" .

:FiveNinesAvailability a sla:Availability ;
  :uptimePercentage "99.999"^^xsd:float ;
  :maxDowntimeMinutes "5"^^xsd:integer ;
  rdfs:comment "Five nines availability (5.26 minutes/year)" .

:ResponseTimeSLA a sla:ResponseTime ;
  :microseconds "50"^^xsd:integer ;
  rdfs:comment "P99 response time SLA" .

:ThroughputSLA a sla:ThroughputGuarantee ;
  :operationsPerSecond "200000"^^xsd:integer ;
  rdfs:comment "Minimum guaranteed throughput" .

#################################################################
# Hardware Requirements
#################################################################

:MinimumHardware a :HardwareProfile ;
  rdfs:label "Minimum Hardware Requirements" ;
  rdfs:comment "Minimum hardware for v5 performance" .

:MinCPU a :CPUProfile ;
  :cpuCores "8"^^xsd:integer ;
  :cpuFrequencyGHz "3.0"^^xsd:float ;
  rdfs:comment "Minimum 8 cores @ 3.0GHz" .

:MinMemory a :MemoryProfile ;
  :memoryGB "32"^^xsd:integer ;
  :memoryBandwidthGBps "50.0"^^xsd:float ;
  rdfs:comment "Minimum 32GB DDR4" .

:RecommendedHardware a :HardwareProfile ;
  rdfs:label "Recommended Hardware" ;
  rdfs:comment "Recommended hardware for optimal v5 performance" .

:RecCPU a :CPUProfile ;
  :cpuCores "32"^^xsd:integer ;
  :cpuFrequencyGHz "4.0"^^xsd:float ;
  rdfs:comment "32 cores @ 4.0GHz (AMD EPYC or Intel Xeon)" .

:RecMemory a :MemoryProfile ;
  :memoryGB "128"^^xsd:integer ;
  :memoryBandwidthGBps "200.0"^^xsd:float ;
  rdfs:comment "128GB DDR5" .

:RecGPU a :GPUProfile ;
  :gpuCores "10240"^^xsd:integer ;
  :gpuMemoryGB "24"^^xsd:integer ;
  rdfs:comment "NVIDIA A100 or better" .

#################################################################
# Constraints
#################################################################

# Doctrine of 8 enforcement
:DoctrineOf8 rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty :tickCount ;
  owl:allValuesFrom [ 
    a rdfs:Datatype ;
    owl:onDatatype xsd:integer ;
    owl:withRestrictions (
      [ xsd:minInclusive "1"^^xsd:integer ]
      [ xsd:maxInclusive "8"^^xsd:integer ]
    )
  ]
] .

# Cache hit rates must be between 0 and 1
:CachePerformance rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty :l1HitRate ;
  owl:allValuesFrom [ 
    a rdfs:Datatype ;
    owl:onDatatype xsd:float ;
    owl:withRestrictions (
      [ xsd:minInclusive "0.0"^^xsd:float ]
      [ xsd:maxInclusive "1.0"^^xsd:float ]
    )
  ]
] .

# Availability must be between 0 and 100
sla:Availability rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty :uptimePercentage ;
  owl:allValuesFrom [ 
    a rdfs:Datatype ;
    owl:onDatatype xsd:float ;
    owl:withRestrictions (
      [ xsd:minInclusive "0.0"^^xsd:float ]
      [ xsd:maxInclusive "100.0"^^xsd:float ]
    )
  ]
] .

#################################################################
# Performance Benchmark Suites
#################################################################

:BenchmarkSuite a owl:Class ;
  rdfs:label "Benchmark Suite" ;
  rdfs:comment "Performance testing suite" .

:CryptoBenchmark a :BenchmarkSuite ;
  rdfs:label "Cryptography Benchmark" ;
  rdfs:comment "PQC operation benchmarks" .

:ThroughputBenchmark a :BenchmarkSuite ;
  rdfs:label "Throughput Benchmark" ;
  rdfs:comment "Maximum throughput testing" .

:LatencyBenchmark a :BenchmarkSuite ;
  rdfs:label "Latency Benchmark" ;
  rdfs:comment "Latency distribution testing" .

#################################################################
# SPARQL Query Examples
#################################################################

# Check if performance meets v5 targets
# SELECT ?metric ?value ?target WHERE {
#   ?metric a :P99Latency ;
#           :microseconds ?value .
#   :TargetP99 :microseconds ?target .
#   FILTER(?value <= ?target)
# }

# Get SLA compliance status
# SELECT ?sla ?uptime WHERE {
#   ?sla a sla:Availability ;
#        :uptimePercentage ?uptime .
#   FILTER(?uptime >= 99.999)
# }

# Find Doctrine of 8 violations
# SELECT ?kernel ?ticks WHERE {
#   ?kernel :tickCount ?ticks .
#   FILTER(?ticks > 8)
# }