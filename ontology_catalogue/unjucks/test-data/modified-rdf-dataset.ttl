# Test completeness marker
ex:ModifiedTestDataset rdf:type kgen:TestDataset ;
    rdfs:label "Modified Complex RDF Test Dataset for Semantic Diff Testing" ;
    kgen:version "1.1.0" ;  # CHANGED: version bump
    kgen:tripleCount 250 ;  # CHANGED: increased from ~200
    kgen:complexityLevel "high" ;
    kgen:features "multilingual, blank-nodes, complex-datatypes, relationships, time-series, modifications" ;
    kgen:generatedAt "2024-01-15T14:00:00Z"^^xsd:dateTime ;  # CHANGED: later timestamp
    kgen:purpose "Testing semantic graph diffing with structural changes" ;
    kgen:modificationType "additions, deletions, modifications" .