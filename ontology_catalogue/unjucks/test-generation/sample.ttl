@prefix ex: <http://example.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

ex:Service1 rdf:type ex:APIService ;
    rdfs:label "User Management Service" ;
    ex:version "1.0.0" ;
    ex:endpoint "/api/users" ;
    ex:method "GET" , "POST" .

ex:Service2 rdf:type ex:APIService ;
    rdfs:label "Product Catalog Service" ;
    ex:version "2.1.0" ;
    ex:endpoint "/api/products" ;
    ex:method "GET" .
