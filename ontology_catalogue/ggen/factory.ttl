<https://ggen.dev/factory/skill/Software> a a2a:Skill ;
    rdfs:label "SoftwareSurface" ;
    rdfs:comment "Materializes code, modules, APIs, CLIs." .

<https://ggen.dev/factory/skill/Text> a a2a:Skill ;
    rdfs:label "TextSurface" ;
    rdfs:comment "Materializes docs, reports, runbooks, policies." .

<https://ggen.dev/factory/skill/AgentSystems> a a2a:Skill ;
    rdfs:label "AgentSystemsSurface" ;
    rdfs:comment "Materializes prompts, roles, constitutions." .

<https://ggen.dev/factory/skill/Process> a a2a:Skill ;
    rdfs:label "ProcessSurface" ;
    rdfs:comment "Materializes workflows, guards, escalation paths." .

<https://ggen.dev/factory/skill/Governance> a a2a:Skill ;
    rdfs:label "GovernanceSurface" ;
    rdfs:comment "Materializes roles, rights, duties, prohibitions." .

<https://ggen.dev/factory/skill/CryptoConsequence> a a2a:Skill ;
    rdfs:label "CryptoConsequenceSurface" ;
    rdfs:comment "Materializes seal rules, packet schemas." .

<https://ggen.dev/factory/skill/Compliance> a a2a:Skill ;
    rdfs:label "ComplianceSurface" ;
    rdfs:comment "Materializes controls, evidence maps, audit exports." .

<https://ggen.dev/factory/skill/Marketplace> a a2a:Skill ;
    rdfs:label "MarketplaceSurface" ;
    rdfs:comment "Materializes listings, claim units, pricing." .

<https://ggen.dev/factory/skill/Reproducibility> a a2a:Skill ;
    rdfs:label "ReproducibilitySurface" ;
    rdfs:comment "Materializes datasets, fixtures, receipt chains." .

<https://ggen.dev/factory/skill/Tooling> a a2a:Skill ;
    rdfs:label "ToolingSurface" ;
