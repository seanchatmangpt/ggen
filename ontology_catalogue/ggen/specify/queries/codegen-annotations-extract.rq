# codegen-annotations-extract.rq — SPARQL-star CONSTRUCT query for annotated axiom extraction
# A=mu(O): FieldMapping projections = mu(annotated ontology triple terms)
#
# Extracts code-generation annotations from RDF 1.2 triple terms and projects
# them as flat triples for Tera template consumption.
#
# Usage:
#   sparql --query codegen-annotations-extract.rq \
#          --data codegen-annotations.ttl \
#          --data codegen-annotations-example.ttl
#
# CONSTRUCT output is flat (no triple terms) because oxigraph materializes
# triple terms as strings like "<<s p o>>" which cannot be destructured by
# Tera templates consuming Vec<BTreeMap<String, String>>.

PREFIX cg: <https://ggen.dev/ontology/codegen#>
PREFIX ex: <https://ggen.dev/examples/codegen#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
  ?fieldMapping a cg:FieldMapping ;
    cg:className ?className ;
    cg:fieldName ?fieldName ;
    cg:fieldRange ?range ;
    cg:rustType ?rustType ;
    cg:goType ?goType ;
    cg:elixirType ?elixirType ;
    cg:tsType ?tsType ;
    cg:jsonKey ?jsonKey ;
    cg:required ?required ;
    cg:validator ?validator ;
    cg:deprecated ?deprecated ;
    cg:sinceVersion ?sinceVersion ;
    cg:docComment ?docComment ;
    cg:serdeAttr ?serdeAttr ;
    cg:defaultValue ?defaultValue ;
    cg:precision ?precision ;
    cg:minimum ?minimum ;
    cg:maximum ?maximum .
}
WHERE {
  # Match RDF 1.2 triple terms: <<class property range>> annotated with cg:rustType
  << ?cls ?prop ?range>> cg:rustType ?rustType .

  # At least one type mapping is required (rustType above); others are optional
  OPTIONAL { << ?cls ?prop ?range>> cg:goType ?goType . }
  OPTIONAL { << ?cls ?prop ?range>> cg:elixirType ?elixirType . }
  OPTIONAL { << ?cls ?prop ?range>> cg:tsType ?tsType . }
  OPTIONAL { << ?cls ?prop ?range>> cg:jsonKey ?jsonKey . }
  OPTIONAL { << ?cls ?prop ?range>> cg:required ?required . }
  OPTIONAL { << ?cls ?prop ?range>> cg:validator ?validator . }
  OPTIONAL { << ?cls ?prop ?range>> cg:deprecated ?deprecated . }
  OPTIONAL { << ?cls ?prop ?range>> cg:sinceVersion ?sinceVersion . }
  OPTIONAL { << ?cls ?prop ?range>> cg:docComment ?docComment . }
  OPTIONAL { << ?cls ?prop ?range>> cg:serdeAttr ?serdeAttr . }
  OPTIONAL { << ?cls ?prop ?range>> cg:defaultValue ?defaultValue . }
  OPTIONAL { << ?cls ?prop ?range>> cg:precision ?precision . }
  OPTIONAL { << ?cls ?prop ?range>> cg:minimum ?minimum . }
  OPTIONAL { << ?cls ?prop ?range>> cg:maximum ?maximum . }

  # Extract local names from IRIs for template-friendly variable names
  BIND(STRAFTER(STR(?cls), "#") AS ?className)
  BIND(STRAFTER(STR(?prop), "#") AS ?fieldName)

  # Generate a stable URI for the field mapping node
  BIND(IRI(CONCAT("https://ggen.dev/codegen/field/", ?className, "/", ?fieldName)) AS ?fieldMapping)
}
ORDER BY ?className ?fieldName
