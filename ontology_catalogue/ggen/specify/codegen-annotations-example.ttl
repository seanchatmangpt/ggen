# codegen-annotations-example.ttl — Instance data with annotated domain model
# A=mu(O) — 3 classes, 18 annotated properties demonstrating RDF 1.2 triple terms
#
# Pipeline: this file + codegen-annotations.ttl → codegen-annotations-extract.rq → rust-struct-from-ontology.tera

@prefix ex: <https://ggen.dev/examples/codegen#> .
@prefix cg: <https://ggen.dev/ontology/codegen#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
# 1. CLASSES
# ============================================================================

ex:Person
  a rdfs:Class ;
  rdfs:label "Person"@en ;
  rdfs:comment "A person in the system."@en .

ex:Invoice
  a rdfs:Class ;
  rdfs:label "Invoice"@en ;
  rdfs:comment "A billing invoice."@en .

ex:PaymentMethod
  a rdfs:Class ;
  rdfs:label "Payment Method"@en ;
  rdfs:comment "A payment method on file for a person."@en .

# ============================================================================
# 2. PERSON — 6 annotated properties
# ============================================================================

# hasName: required String with validator
<< ex:Person ex:hasName xsd:string>>
  cg:rustType "String" ;
  cg:goType "string" ;
  cg:elixirType "String.t" ;
  cg:tsType "string" ;
  cg:jsonKey "full_name" ;
  cg:required true ;
  cg:validator "validate_non_empty" ;
  cg:docComment "The person's full name" .

# hasEmail: required String with email validator
<< ex:Person ex:hasEmail xsd:string>>
  cg:rustType "String" ;
  cg:goType "string" ;
  cg:elixirType "String.t" ;
  cg:tsType "string" ;
  cg:jsonKey "email" ;
  cg:required true ;
  cg:validator "validate_email" ;
  cg:docComment "Email address, must be valid format" .

# hasAge: optional u32 with bounds
<< ex:Person ex:hasAge xsd:integer>>
  cg:rustType "u32" ;
  cg:goType "int" ;
  cg:elixirType "non_neg_integer" ;
  cg:tsType "number" ;
  cg:jsonKey "age" ;
  cg:required false ;
  cg:minimum 0 ;
  cg:maximum 150 ;
  cg:docComment "Person's age in years" .

# hasPhone: deprecated String field
<< ex:Person ex:hasPhone xsd:string>>
  cg:rustType "String" ;
  cg:goType "string" ;
  cg:elixirType "String.t" ;
  cg:tsType "string" ;
  cg:jsonKey "phone" ;
  cg:required false ;
  cg:deprecated true ;
  cg:sinceVersion "1.0" ;
  cg:docComment "Phone number (deprecated: use hasContact instead)" .

# hasCreatedAt: required DateTime
<< ex:Person ex:hasCreatedAt xsd:dateTime>>
  cg:rustType "DateTime<Utc>" ;
  cg:goType "time.Time" ;
  cg:elixirType "DateTime.t" ;
  cg:tsType "string" ;
  cg:jsonKey "created_at" ;
  cg:required true ;
  cg:defaultValue "Utc::now()" ;
  cg:docComment "Timestamp when the person record was created" .

# hasIsActive: required boolean with default
<< ex:Person ex:hasIsActive xsd:boolean>>
  cg:rustType "bool" ;
  cg:goType "bool" ;
  cg:elixirType "boolean" ;
  cg:tsType "boolean" ;
  cg:jsonKey "is_active" ;
  cg:required true ;
  cg:defaultValue "true" ;
  cg:docComment "Whether the person account is active" .

# ============================================================================
# 3. INVOICE — 6 annotated properties
# ============================================================================

# hasId: required UUID with serde rename
<< ex:Invoice ex:hasId xsd:string>>
  cg:rustType "uuid::Uuid" ;
  cg:goType "string" ;
  cg:elixirType "String.t" ;
  cg:tsType "string" ;
  cg:jsonKey "id" ;
  cg:required true ;
  cg:serdeAttr "#[serde(rename = \"id\")]" ;
  cg:docComment "Unique invoice identifier (UUID v4)" .

# hasTotal: required f64 with precision and bounds
<< ex:Invoice ex:hasTotal xsd:decimal>>
  cg:rustType "f64" ;
  cg:goType "float64" ;
  cg:elixirType "float" ;
  cg:tsType "number" ;
  cg:jsonKey "total" ;
  cg:required true ;
  cg:precision 2 ;
  cg:minimum 0.0 ;
  cg:validator "validate_non_negative" ;
  cg:docComment "Invoice total amount in USD (2 decimal places)" .

# hasCreatedAt: required DateTime
<< ex:Invoice ex:hasCreatedAt xsd:dateTime>>
  cg:rustType "DateTime<Utc>" ;
  cg:goType "time.Time" ;
  cg:elixirType "DateTime.t" ;
  cg:tsType "string" ;
  cg:jsonKey "created_at" ;
  cg:required true ;
  cg:defaultValue "Utc::now()" ;
  cg:docComment "Timestamp when the invoice was created" .

# hasStatus: required enum-like String
<< ex:Invoice ex:hasStatus xsd:string>>
  cg:rustType "InvoiceStatus" ;
  cg:goType "string" ;
  cg:elixirType "atom" ;
  cg:tsType "string" ;
  cg:jsonKey "status" ;
  cg:required true ;
  cg:defaultValue "InvoiceStatus::Draft" ;
  cg:docComment "Current invoice status: Draft, Sent, Paid, Overdue, Cancelled" .

# hasDueDate: optional DateTime
<< ex:Invoice ex:hasDueDate xsd:dateTime>>
  cg:rustType "DateTime<Utc>" ;
  cg:goType "time.Time" ;
  cg:elixirType "DateTime.t" ;
  cg:tsType "string" ;
  cg:jsonKey "due_date" ;
  cg:required false ;
  cg:docComment "Date when the invoice payment is due" .

# hasDescription: optional String with default
<< ex:Invoice ex:hasDescription xsd:string>>
  cg:rustType "String" ;
  cg:goType "string" ;
  cg:elixirType "String.t" ;
  cg:tsType "string" ;
  cg:jsonKey "description" ;
  cg:required false ;
  cg:defaultValue "String::new()" ;
  cg:docComment "Free-text description of the invoice" .

# ============================================================================
# 4. PAYMENT METHOD — 6 annotated properties
# ============================================================================

# hasType: required String (credit_card, debit_card, bank_transfer, etc.)
<< ex:PaymentMethod ex:hasType xsd:string>>
  cg:rustType "String" ;
  cg:goType "string" ;
  cg:elixirType "String.t" ;
  cg:tsType "string" ;
  cg:jsonKey "type" ;
  cg:required true ;
  cg:validator "validate_payment_type" ;
  cg:docComment "Payment method type: credit_card, debit_card, bank_transfer, paypal" .

# hasLast4: required String with validator
<< ex:PaymentMethod ex:hasLast4 xsd:string>>
  cg:rustType "String" ;
  cg:goType "string" ;
  cg:elixirType "String.t" ;
  cg:tsType "string" ;
  cg:jsonKey "last4" ;
  cg:required true ;
  cg:validator "validate_last4" ;
  cg:docComment "Last 4 digits of card or account number" .

# hasExpiryMonth: required u32 with bounds
<< ex:PaymentMethod ex:hasExpiryMonth xsd:integer>>
  cg:rustType "u32" ;
  cg:goType "int" ;
  cg:elixirType "pos_integer" ;
  cg:tsType "number" ;
  cg:jsonKey "expiry_month" ;
  cg:required true ;
  cg:minimum 1 ;
  cg:maximum 12 ;
  cg:docComment "Card expiry month (1-12)" .

# hasExpiryYear: required u32 with minimum
<< ex:PaymentMethod ex:hasExpiryYear xsd:integer>>
  cg:rustType "u32" ;
  cg:goType "int" ;
  cg:elixirType "pos_integer" ;
  cg:tsType "number" ;
  cg:jsonKey "expiry_year" ;
  cg:required true ;
  cg:minimum 2024 ;
  cg:docComment "Card expiry year (4 digits)" .

# hasIsDefault: required boolean with default
<< ex:PaymentMethod ex:hasIsDefault xsd:boolean>>
  cg:rustType "bool" ;
  cg:goType "bool" ;
  cg:elixirType "boolean" ;
  cg:tsType "boolean" ;
  cg:jsonKey "is_default" ;
  cg:required true ;
  cg:defaultValue "false" ;
  cg:docComment "Whether this is the default payment method" .

# hasNickname: optional String
<< ex:PaymentMethod ex:hasNickname xsd:string>>
  cg:rustType "String" ;
  cg:goType "string" ;
  cg:elixirType "String.t" ;
  cg:tsType "string" ;
  cg:jsonKey "nickname" ;
  cg:required false ;
  cg:docComment "User-defined nickname for this payment method (e.g., \"Work Visa\")" .
