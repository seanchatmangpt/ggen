# SYNC-ACTUATOR-1 seed facts — PUBLIC-ONTOLOGY-FOUNDATION-1.
#
# The foundation MUST be public vocabulary. There is no private `gall:`
# namespace here: every load-bearing class and predicate is drawn from a
# published, dereferenceable vocabulary. Custom names survive ONLY as local
# <#identifiers> under @base — they are subjects, never classes or predicates.
#
# Public footing:
#   PROV-O   — provenance of the actuation (Activity / Entity / SoftwareAgent /
#              wasGeneratedBy / used / wasDerivedFrom / wasAssociatedWith)
#   DCTERMS  — description metadata (title / identifier / hasVersion /
#              conformsTo / references / coverage)
#   SKOS     — controlled-vocabulary concepts for the diagnostic (E0011) and
#              the route template (template.values-inline), via skos:notation
#
# The actuation axiom, modelled in public terms:
#   <#sync-run>      a prov:Activity       — the single actuation (ggen sync)
#   <#ggen-sync>     a prov:SoftwareAgent  — the actuator binary (v26.5.28)
#   <#fixture>       a prov:Entity         — the SPARQL law surface consumed
#   <#foundation-test> a prov:Entity       — the emitted Gall test artifact,
#                       prov:wasGeneratedBy <#sync-run>,
#                       prov:wasDerivedFrom <#fixture>
#   <#diagnostic-e0011> / <#route-values-inline> a skos:Concept

@base <https://ggen.io/playground/sync-foundation/command-foundation> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .

# ── The actuator agent (ggen sync) ──────────────────────────────────────────
<#ggen-sync> a prov:SoftwareAgent ;
    dcterms:title "ggen sync" ;
    dcterms:identifier "ggen-sync" ;
    dcterms:hasVersion "26.5.28" ;
    dcterms:description "The only actuation: runs μ₁–μ₅, gates, emits artifacts + receipt." .

# The author-time sensing surface — an Entity, never an actuator.
<#ggen-lsp> a prov:Entity ;
    dcterms:title "ggen lsp" ;
    dcterms:identifier "ggen-lsp" ;
    dcterms:description "Author-time route surface; senses + routes, never actuates." .

# ── The fixture consumed by the actuation ───────────────────────────────────
<#fixture> a prov:Entity ;
    dcterms:title "broken-construct.rq" ;
    dcterms:identifier "playground/proof/broken-construct.rq" ;
    dcterms:description "A SPARQL law surface (.rq) — the input the run uses." .

# ── Controlled-vocabulary concepts (diagnostic + route) ─────────────────────
<#diagnostic-e0011> a skos:Concept ;
    skos:prefLabel "values-inline diagnostic" ;
    skos:notation "E0011" ;
    dcterms:description "The diagnostic identity precipitated into the artifact." .

<#route-values-inline> a skos:Concept ;
    skos:prefLabel "template values-inline route" ;
    skos:notation "template.values-inline" ;
    dcterms:description "The route engine identity carried across all transports." .

# ── The single actuation (ggen sync run) ────────────────────────────────────
<#sync-run> a prov:Activity ;
    dcterms:title "ggen sync run" ;
    dcterms:description "The single actuation that manufactures the foundation test + receipt." ;
    prov:wasAssociatedWith <#ggen-sync> ;
    prov:used <#fixture> .

# ── The emitted Gall foundation-test artifact (one pier) ────────────────────
# This is a prov:Entity generated by the run and derived from the fixture.
# Its dcterms:title carries the test name; coverage carries the three
# transports; conformsTo/references bind the route + diagnostic concepts.
<#foundation-test> a prov:Entity ;
    dcterms:title "lsp_mcp_a2a_foundation_uses_one_route_engine" ;
    dcterms:identifier "lsp_mcp_a2a_foundation_uses_one_route_engine" ;
    dcterms:coverage "LSP, MCP, A2A" ;
    dcterms:conformsTo <#route-values-inline> ;
    dcterms:references <#diagnostic-e0011> ;
    dcterms:source <#fixture> ;
    dcterms:description "One route engine across three transports; ggen sync is the only actuation." ;
    prov:wasGeneratedBy <#sync-run> ;
    prov:wasDerivedFrom <#fixture> .
