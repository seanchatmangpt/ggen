@prefix interview: <http://optimus.dev/interview/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ========================================
# ONTOLOGY DEFINITIONS
# ========================================

## Core Classes
interview:Domain a rdfs:Class ;
    rdfs:label "Interview Domain" ;
    rdfs:comment "A category or domain of interview questions" .

interview:Question a rdfs:Class ;
    rdfs:label "Interview Question" ;
    rdfs:comment "An interview question with associated metadata and answers" .

interview:Answer a rdfs:Class ;
    rdfs:label "Suggested Answer" ;
    rdfs:comment "A suggested answer or answer pattern for a question" .

interview:Accommodation a rdfs:Class ;
    rdfs:label "Neurodivergent Accommodation" ;
    rdfs:comment "Accommodations for neurodivergent candidates" .

## Properties
interview:domain a rdf:Property ;
    rdfs:domain interview:Question ;
    rdfs:range interview:Domain .

interview:difficulty a rdf:Property ;
    rdfs:domain interview:Question ;
    rdfs:range xsd:string ;
    rdfs:comment "Difficulty level: easy, medium, hard, expert" .

interview:suggestedAnswer a rdf:Property ;
    rdfs:domain interview:Question ;
    rdfs:range interview:Answer .

interview:followUp a rdf:Property ;
    rdfs:domain interview:Question ;
    rdfs:range interview:Question ;
    rdfs:comment "Related follow-up questions" .

interview:tags a rdf:Property ;
    rdfs:domain interview:Question ;
    rdfs:range xsd:string .

interview:framework a rdf:Property ;
    rdfs:domain interview:Question ;
    rdfs:range xsd:string ;
    rdfs:comment "Framework for answering (e.g., STAR, CAR)" .

interview:timeEstimate a rdf:Property ;
    rdfs:domain interview:Question ;
    rdfs:range xsd:string ;
    rdfs:comment "Estimated time to answer" .

interview:accommodation a rdf:Property ;
    rdfs:domain interview:Question ;
    rdfs:range interview:Accommodation .

interview:keyPoints a rdf:Property ;
    rdfs:domain interview:Answer ;
    rdfs:range xsd:string .

interview:example a rdf:Property ;
    rdfs:domain interview:Answer ;
    rdfs:range xsd:string .

interview:pitfalls a rdf:Property ;
    rdfs:domain interview:Answer ;
    rdfs:range xsd:string .

# ========================================
# DOMAINS
# ========================================

interview:technical a interview:Domain ;
    rdfs:label "Technical" ;
    rdfs:comment "Technical coding and implementation questions" .

interview:behavioral a interview:Domain ;
    rdfs:label "Behavioral" ;
    rdfs:comment "Behavioral and soft skills questions" .

interview:systemDesign a interview:Domain ;
    rdfs:label "System Design" ;
    rdfs:comment "System architecture and design questions" .

interview:algorithms a interview:Domain ;
    rdfs:label "Algorithms" ;
    rdfs:comment "Algorithmic problem-solving questions" .

# ========================================
# ACCOMMODATIONS
# ========================================

interview:accommodation001 a interview:Accommodation ;
    schema:name "Extended Think Time" ;
    schema:description "Provide 30-60 seconds of think time before answering" .

interview:accommodation002 a interview:Accommodation ;
    schema:name "Written Option" ;
    schema:description "Allow written response or diagram before verbal explanation" .

interview:accommodation003 a interview:Accommodation ;
    schema:name "Step-by-Step Breakdown" ;
    schema:description "Break complex questions into smaller, sequential steps" .

interview:accommodation004 a interview:Accommodation ;
    schema:name "Clarifying Prompts" ;
    schema:description "Offer clarifying questions or hints if candidate seems stuck" .

interview:accommodation005 a interview:Accommodation ;
    schema:name "Time Management Hints" ;
    schema:description "Provide time check-ins and pacing suggestions" .

# ========================================
# REACT/FRONTEND TECHNICAL QUESTIONS (10)
# ========================================

interview:q001 a interview:Question ;
    schema:name "Explain React hooks and when to use them vs class components" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "react, hooks, frontend, state-management" ;
    interview:timeEstimate "5-7 minutes" ;
    interview:accommodation interview:accommodation001, interview:accommodation004 ;
    interview:followUp interview:q002 ;
    interview:suggestedAnswer interview:a001 .

interview:a001 a interview:Answer ;
    interview:keyPoints "Hooks enable state and lifecycle in function components; useState for state, useEffect for side effects, useContext for context; benefits include simpler code, better code reuse, no this binding" ;
    interview:example "const [count, setCount] = useState(0); useEffect(() => { document.title = count; }, [count]);" ;
    interview:pitfalls "Don't call hooks conditionally, don't call in loops, must call at top level" .

interview:q002 a interview:Question ;
    schema:name "What are the rules of hooks and why do they exist?" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "react, hooks, best-practices" ;
    interview:timeEstimate "4-5 minutes" ;
    interview:accommodation interview:accommodation003 ;
    interview:suggestedAnswer interview:a002 .

interview:a002 a interview:Answer ;
    interview:keyPoints "Only call hooks at top level, only call from React functions, ensures consistent hook order across renders, enables React to preserve state" ;
    interview:example "ESLint plugin eslint-plugin-react-hooks enforces these rules" ;
    interview:pitfalls "Breaking rules causes state mismatches and bugs" .

interview:q003 a interview:Question ;
    schema:name "Explain useMemo and useCallback. When should you use them?" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "react, hooks, performance, optimization" ;
    interview:timeEstimate "6-8 minutes" ;
    interview:accommodation interview:accommodation001, interview:accommodation003 ;
    interview:followUp interview:q004 ;
    interview:suggestedAnswer interview:a003 .

interview:a003 a interview:Answer ;
    interview:keyPoints "useMemo memoizes computed values, useCallback memoizes functions; use when expensive computations or preventing unnecessary child re-renders; don't overuse - premature optimization" ;
    interview:example "const memoizedValue = useMemo(() => expensiveCalc(a, b), [a, b]); const memoizedCallback = useCallback(() => doSomething(a), [a]);" ;
    interview:pitfalls "Overuse adds complexity, incorrect dependencies cause stale closures" .

interview:q004 a interview:Question ;
    schema:name "How does React's virtual DOM work and why is it beneficial?" ;
    interview:domain interview:technical ;
    interview:difficulty "hard" ;
    interview:tags "react, virtual-dom, performance, rendering" ;
    interview:timeEstimate "7-10 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003 ;
    interview:suggestedAnswer interview:a004 .

interview:a004 a interview:Answer ;
    interview:keyPoints "Virtual DOM is in-memory representation; React compares (diff) old and new virtual DOM; reconciliation identifies minimal real DOM changes; batches updates for performance" ;
    interview:example "When state changes, React creates new virtual DOM tree, diffs with previous, applies only changes to real DOM" ;
    interview:pitfalls "Not a silver bullet - still need to optimize renders with keys, memo, etc." .

interview:q005 a interview:Question ;
    schema:name "Explain controlled vs uncontrolled components in React" ;
    interview:domain interview:technical ;
    interview:difficulty "easy" ;
    interview:tags "react, forms, state-management" ;
    interview:timeEstimate "4-5 minutes" ;
    interview:accommodation interview:accommodation003 ;
    interview:suggestedAnswer interview:a005 .

interview:a005 a interview:Answer ;
    interview:keyPoints "Controlled: React state is source of truth, onChange updates state; Uncontrolled: DOM is source of truth, use refs to access values; Controlled preferred for validation and dynamic UIs" ;
    interview:example "Controlled: <input value={name} onChange={e => setName(e.target.value)} />; Uncontrolled: <input ref={inputRef} />" ;
    interview:pitfalls "Mixing controlled/uncontrolled causes warnings and bugs" .

interview:q006 a interview:Question ;
    schema:name "What is React Context and when should you use it instead of props drilling?" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "react, context, state-management, architecture" ;
    interview:timeEstimate "6-7 minutes" ;
    interview:accommodation interview:accommodation001, interview:accommodation004 ;
    interview:followUp interview:q007 ;
    interview:suggestedAnswer interview:a006 .

interview:a006 a interview:Answer ;
    interview:keyPoints "Context provides global state without passing props through every level; use for themes, auth, language; createContext, Provider, useContext; avoid overuse - causes re-renders" ;
    interview:example "const ThemeContext = createContext('light'); const theme = useContext(ThemeContext);" ;
    interview:pitfalls "All consumers re-render when context changes; not a full state management solution" .

interview:q007 a interview:Question ;
    schema:name "Compare React Context, Redux, and Zustand for state management" ;
    interview:domain interview:technical ;
    interview:difficulty "hard" ;
    interview:tags "react, state-management, redux, zustand, architecture" ;
    interview:timeEstimate "8-10 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation005 ;
    interview:suggestedAnswer interview:a007 .

interview:a007 a interview:Answer ;
    interview:keyPoints "Context: built-in, simple, re-renders all consumers; Redux: predictable, middleware, DevTools, boilerplate; Zustand: minimal, hooks-based, selective subscriptions; choose based on app complexity" ;
    interview:example "Context for simple global state, Redux for complex apps with time-travel debugging, Zustand for lightweight global state" ;
    interview:pitfalls "Context performance issues at scale, Redux boilerplate overhead, Zustand less ecosystem support" .

interview:q008 a interview:Question ;
    schema:name "How would you optimize a React app with performance issues?" ;
    interview:domain interview:technical ;
    interview:difficulty "hard" ;
    interview:tags "react, performance, optimization, profiling" ;
    interview:timeEstimate "8-12 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation005 ;
    interview:suggestedAnswer interview:a008 .

interview:a008 a interview:Answer ;
    interview:keyPoints "Profile with React DevTools Profiler; use React.memo for expensive components; optimize re-renders with useMemo/useCallback; code splitting with lazy/Suspense; virtualize long lists; optimize images; reduce bundle size" ;
    interview:example "const MemoizedComponent = React.memo(ExpensiveComponent); const LazyComponent = lazy(() => import('./Heavy'));" ;
    interview:pitfalls "Premature optimization; not measuring before optimizing; over-memoization" .

interview:q009 a interview:Question ;
    schema:name "Explain React's useEffect hook and its cleanup function" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "react, hooks, lifecycle, side-effects" ;
    interview:timeEstimate "6-7 minutes" ;
    interview:accommodation interview:accommodation001, interview:accommodation003 ;
    interview:followUp interview:q010 ;
    interview:suggestedAnswer interview:a009 .

interview:a009 a interview:Answer ;
    interview:keyPoints "useEffect runs side effects after render; dependency array controls when it runs; cleanup function prevents memory leaks; runs before next effect and unmount" ;
    interview:example "useEffect(() => { const subscription = api.subscribe(); return () => subscription.unsubscribe(); }, [id]);" ;
    interview:pitfalls "Missing dependencies, infinite loops, not cleaning up subscriptions/timers" .

interview:q010 a interview:Question ;
    schema:name "What is the difference between useEffect and useLayoutEffect?" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "react, hooks, lifecycle, rendering" ;
    interview:timeEstimate "5-6 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation004 ;
    interview:suggestedAnswer interview:a010 .

interview:a010 a interview:Answer ;
    interview:keyPoints "useEffect runs after paint (asynchronous); useLayoutEffect runs before paint (synchronous); use useLayoutEffect for DOM measurements or preventing visual flicker; prefer useEffect for most cases" ;
    interview:example "useLayoutEffect(() => { const height = ref.current.offsetHeight; setHeight(height); });" ;
    interview:pitfalls "useLayoutEffect blocks visual updates - can cause performance issues if slow" .

# ========================================
# NODE/BACKEND TECHNICAL QUESTIONS (10)
# ========================================

interview:q011 a interview:Question ;
    schema:name "Explain how Node.js event loop works" ;
    interview:domain interview:technical ;
    interview:difficulty "hard" ;
    interview:tags "nodejs, event-loop, async, architecture" ;
    interview:timeEstimate "8-10 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003 ;
    interview:followUp interview:q012 ;
    interview:suggestedAnswer interview:a011 .

interview:a011 a interview:Answer ;
    interview:keyPoints "Single-threaded, non-blocking I/O; phases: timers, pending callbacks, idle, poll, check, close; processes callbacks from event queue; libuv handles async operations; microtasks (promises) have priority" ;
    interview:example "setTimeout in timers phase, setImmediate in check phase, Promise.then as microtask" ;
    interview:pitfalls "Blocking event loop with CPU-intensive tasks causes poor performance" .

interview:q012 a interview:Question ;
    schema:name "How would you handle CPU-intensive tasks in Node.js?" ;
    interview:domain interview:technical ;
    interview:difficulty "hard" ;
    interview:tags "nodejs, performance, worker-threads, optimization" ;
    interview:timeEstimate "7-9 minutes" ;
    interview:accommodation interview:accommodation001, interview:accommodation003 ;
    interview:suggestedAnswer interview:a012 .

interview:a012 a interview:Answer ;
    interview:keyPoints "Use Worker Threads for parallel processing; offload to child processes; use job queues (Bull, BullMQ); cluster mode for multiple processes; consider microservices for heavy computation" ;
    interview:example "const { Worker } = require('worker_threads'); const worker = new Worker('./heavy-task.js');" ;
    interview:pitfalls "Workers have overhead; shared memory complexity; debugging harder" .

interview:q013 a interview:Question ;
    schema:name "Design a REST API authentication system with JWT" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "nodejs, authentication, jwt, security, api" ;
    interview:timeEstimate "10-12 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation005 ;
    interview:followUp interview:q014 ;
    interview:suggestedAnswer interview:a013 .

interview:a013 a interview:Answer ;
    interview:keyPoints "JWT contains user claims, signed with secret; login endpoint returns access + refresh tokens; middleware verifies tokens; access token short-lived, refresh token for renewal; store refresh token securely (httpOnly cookie or secure storage)" ;
    interview:example "POST /login returns tokens; GET /protected uses Authorization: Bearer <token>; POST /refresh renews tokens" ;
    interview:pitfalls "Storing JWT in localStorage (XSS risk); not validating token expiry; weak secrets; no token rotation" .

interview:q014 a interview:Question ;
    schema:name "How do you prevent common API security vulnerabilities?" ;
    interview:domain interview:technical ;
    interview:difficulty "hard" ;
    interview:tags "nodejs, security, api, best-practices" ;
    interview:timeEstimate "8-10 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation005 ;
    interview:suggestedAnswer interview:a014 .

interview:a014 a interview:Answer ;
    interview:keyPoints "Rate limiting (express-rate-limit); input validation (Joi, Zod); SQL injection prevention (parameterized queries, ORM); XSS prevention (sanitize input); CSRF tokens; helmet.js for security headers; HTTPS only; dependency scanning" ;
    interview:example "app.use(helmet()); app.use(rateLimit({ windowMs: 15*60*1000, max: 100 }));" ;
    interview:pitfalls "Trusting user input; exposing sensitive errors; not updating dependencies; weak CORS config" .

interview:q015 a interview:Question ;
    schema:name "Explain database connection pooling and why it matters" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "nodejs, database, performance, postgresql, optimization" ;
    interview:timeEstimate "6-7 minutes" ;
    interview:accommodation interview:accommodation001, interview:accommodation003 ;
    interview:suggestedAnswer interview:a015 .

interview:a015 a interview:Answer ;
    interview:keyPoints "Pool maintains reusable connections; avoids overhead of creating new connections; configurable min/max size; handles connection lifecycle; prevents exhausting database connections; improves performance and scalability" ;
    interview:example "const pool = new Pool({ max: 20, idleTimeoutMillis: 30000 }); pool.query('SELECT * FROM users');" ;
    interview:pitfalls "Pool too small causes queuing; too large exhausts database resources; not handling connection errors; connection leaks" .

interview:q016 a interview:Question ;
    schema:name "How would you implement caching in a Node.js API?" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "nodejs, caching, redis, performance, api" ;
    interview:timeEstimate "8-10 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003 ;
    interview:followUp interview:q017 ;
    interview:suggestedAnswer interview:a016 .

interview:a016 a interview:Answer ;
    interview:keyPoints "Redis for distributed caching; in-memory cache for single instance; cache-aside pattern; TTL for expiration; cache invalidation on updates; HTTP caching headers (ETag, Cache-Control); CDN for static assets" ;
    interview:example "const cached = await redis.get(key); if (!cached) { const data = await db.query(); await redis.set(key, data, 'EX', 3600); }" ;
    interview:pitfalls "Stale data; cache stampede; memory limits; not handling cache failures; over-caching" .

interview:q017 a interview:Question ;
    schema:name "What strategies would you use to handle cache invalidation?" ;
    interview:domain interview:technical ;
    interview:difficulty "hard" ;
    interview:tags "caching, architecture, distributed-systems, redis" ;
    interview:timeEstimate "7-9 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation005 ;
    interview:suggestedAnswer interview:a017 .

interview:a017 a interview:Answer ;
    interview:keyPoints "TTL-based expiration; event-driven invalidation; write-through cache; cache tagging; pub/sub for distributed invalidation; versioning; LRU eviction; manual purge endpoints" ;
    interview:example "On user update: await redis.del('user:123'); await pubsub.publish('cache-invalidate', {key: 'user:123'});" ;
    interview:pitfalls "Race conditions; cascading invalidations; over-invalidation; inconsistent state" .

interview:q018 a interview:Question ;
    schema:name "Design error handling middleware for Express.js" ;
    interview:domain interview:technical ;
    interview:difficulty "medium" ;
    interview:tags "nodejs, express, error-handling, api, best-practices" ;
    interview:timeEstimate "7-8 minutes" ;
    interview:accommodation interview:accommodation001, interview:accommodation003 ;
    interview:suggestedAnswer interview:a018 .

interview:a018 a interview:Answer ;
    interview:keyPoints "Centralized error handler with 4 parameters; custom error classes; async error wrapper; log errors; return appropriate status codes; don't expose internal errors to clients; handle unhandled rejections" ;
    interview:example "app.use((err, req, res, next) => { logger.error(err); res.status(err.statusCode || 500).json({ error: err.message }); });" ;
    interview:pitfalls "Exposing stack traces; not logging errors; inconsistent error formats; not handling async errors" .

interview:q019 a interview:Question ;
    schema:name "Explain stream processing in Node.js and when to use it" ;
    interview:domain interview:technical ;
    interview:difficulty "hard" ;
    interview:tags "nodejs, streams, performance, memory" ;
    interview:timeEstimate "8-10 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003 ;
    interview:suggestedAnswer interview:a019 .

interview:a019 a interview:Answer ;
    interview:keyPoints "Process data chunk by chunk; Readable, Writable, Transform, Duplex streams; backpressure handling; use for large files, real-time data, CSV processing; pipe() chains streams; reduces memory footprint" ;
    interview:example "fs.createReadStream('large.csv').pipe(csvParser()).pipe(transform()).pipe(fs.createWriteStream('out.json'));" ;
    interview:pitfalls "Not handling errors on each stream; ignoring backpressure; memory leaks from unclosed streams" .

interview:q020 a interview:Question ;
    schema:name "How would you design a microservices communication pattern?" ;
    interview:domain interview:technical ;
    interview:difficulty "hard" ;
    interview:tags "nodejs, microservices, architecture, distributed-systems" ;
    interview:timeEstimate "10-12 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation005 ;
    interview:suggestedAnswer interview:a020 .

interview:a020 a interview:Answer ;
    interview:keyPoints "Synchronous: REST, gRPC; Asynchronous: message queues (RabbitMQ, Kafka), events; API gateway for routing; service discovery; circuit breakers; idempotency; saga pattern for distributed transactions; observability with tracing" ;
    interview:example "API Gateway -> Auth Service (gRPC) -> User Service (REST); Events via Kafka for async updates" ;
    interview:pitfalls "Network failures; cascading failures; data consistency; debugging complexity; latency overhead" .

# ========================================
# ALGORITHMS TECHNICAL QUESTIONS (10)
# ========================================

interview:q021 a interview:Question ;
    schema:name "Implement a function to find the longest substring without repeating characters" ;
    interview:domain interview:algorithms ;
    interview:difficulty "medium" ;
    interview:tags "algorithms, strings, sliding-window, hash-map" ;
    interview:timeEstimate "15-20 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation005 ;
    interview:suggestedAnswer interview:a021 .

interview:a021 a interview:Answer ;
    interview:keyPoints "Sliding window approach; hash map to track character positions; expand window until duplicate found; contract from left; track max length; O(n) time, O(min(m,n)) space where m is charset size" ;
    interview:example "function lengthOfLongestSubstring(s) { const seen = new Map(); let max = 0, left = 0; for (let right = 0; right < s.length; right++) { if (seen.has(s[right])) left = Math.max(left, seen.get(s[right]) + 1); seen.set(s[right], right); max = Math.max(max, right - left + 1); } return max; }" ;
    interview:pitfalls "Not handling edge cases (empty string); incorrect window contraction; off-by-one errors" .

interview:q022 a interview:Question ;
    schema:name "Reverse a linked list iteratively and recursively" ;
    interview:domain interview:algorithms ;
    interview:difficulty "medium" ;
    interview:tags "algorithms, linked-list, recursion, iteration" ;
    interview:timeEstimate "12-15 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation004 ;
    interview:followUp interview:q023 ;
    interview:suggestedAnswer interview:a022 .

interview:a022 a interview:Answer ;
    interview:keyPoints "Iterative: three pointers (prev, curr, next); reverse links while traversing; O(n) time, O(1) space; Recursive: reverse rest, fix links; O(n) time, O(n) space for call stack" ;
    interview:example "Iterative: let prev = null, curr = head; while (curr) { const next = curr.next; curr.next = prev; prev = curr; curr = next; } return prev; Recursive: if (!head || !head.next) return head; const newHead = reverse(head.next); head.next.next = head; head.next = null; return newHead;" ;
    interview:pitfalls "Losing reference to rest of list; not handling null/single node; stack overflow in recursive" .

interview:q023 a interview:Question ;
    schema:name "Detect if a linked list has a cycle and find the cycle start" ;
    interview:domain interview:algorithms ;
    interview:difficulty "medium" ;
    interview:tags "algorithms, linked-list, two-pointers, floyd-cycle" ;
    interview:timeEstimate "15-18 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003 ;
    interview:suggestedAnswer interview:a023 .

interview:a023 a interview:Answer ;
    interview:keyPoints "Floyd's cycle detection (tortoise and hare); slow moves 1, fast moves 2; if they meet, cycle exists; reset one pointer to head, move both 1 step until they meet - that's cycle start; O(n) time, O(1) space" ;
    interview:example "let slow = head, fast = head; while (fast && fast.next) { slow = slow.next; fast = fast.next.next; if (slow === fast) { slow = head; while (slow !== fast) { slow = slow.next; fast = fast.next; } return slow; } } return null;" ;
    interview:pitfalls "Not checking for null; incorrect logic for finding start; infinite loop" .

interview:q024 a interview:Question ;
    schema:name "Implement binary search and explain its time complexity" ;
    interview:domain interview:algorithms ;
    interview:difficulty "easy" ;
    interview:tags "algorithms, binary-search, arrays, complexity" ;
    interview:timeEstimate "10-12 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation004 ;
    interview:suggestedAnswer interview:a024 .

interview:a024 a interview:Answer ;
    interview:keyPoints "Requires sorted array; divide and conquer; compare middle element; eliminate half each iteration; O(log n) time, O(1) space iterative, O(log n) space recursive; base case: low > high" ;
    interview:example "function binarySearch(arr, target) { let low = 0, high = arr.length - 1; while (low <= high) { const mid = Math.floor((low + high) / 2); if (arr[mid] === target) return mid; if (arr[mid] < target) low = mid + 1; else high = mid - 1; } return -1; }" ;
    interview:pitfalls "Integer overflow in (low+high)/2; off-by-one errors; not handling duplicates if required" .

interview:q025 a interview:Question ;
    schema:name "Find the kth largest element in an unsorted array" ;
    interview:domain interview:algorithms ;
    interview:difficulty "medium" ;
    interview:tags "algorithms, arrays, quickselect, heap, sorting" ;
    interview:timeEstimate "15-20 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation005 ;
    interview:followUp interview:q026 ;
    interview:suggestedAnswer interview:a025 .

interview:a025 a interview:Answer ;
    interview:keyPoints "Three approaches: 1) Sort and return arr[n-k] - O(n log n); 2) Min-heap of size k - O(n log k); 3) Quickselect - O(n) average, O(n²) worst; quickselect is optimal on average" ;
    interview:example "function findKthLargest(nums, k) { const minHeap = new MinPriorityQueue(); for (const num of nums) { minHeap.enqueue(num); if (minHeap.size() > k) minHeap.dequeue(); } return minHeap.front(); }" ;
    interview:pitfalls "Confusing kth largest with kth smallest; not handling edge cases; inefficient sorting when quickselect is better" .

interview:q026 a interview:Question ;
    schema:name "Implement a LRU (Least Recently Used) cache" ;
    interview:domain interview:algorithms ;
    interview:difficulty "hard" ;
    interview:tags "algorithms, data-structures, hash-map, doubly-linked-list, design" ;
    interview:timeEstimate "20-25 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation005 ;
    interview:suggestedAnswer interview:a026 .

interview:a026 a interview:Answer ;
    interview:keyPoints "Hash map + doubly linked list; map for O(1) lookup; list for O(1) add/remove; most recent at head, least at tail; get() moves to head; put() adds to head, evicts tail if full; both O(1) time" ;
    interview:example "class LRUCache { constructor(capacity) { this.capacity = capacity; this.map = new Map(); this.head = {}; this.tail = {}; this.head.next = this.tail; this.tail.prev = this.head; } get(key) { if (!this.map.has(key)) return -1; const node = this.map.get(key); this.remove(node); this.addToHead(node); return node.value; } }" ;
    interview:pitfalls "Not maintaining both head and tail; incorrect pointer updates; not handling capacity properly" .

interview:q027 a interview:Question ;
    schema:name "Find all permutations of a string" ;
    interview:domain interview:algorithms ;
    interview:difficulty "medium" ;
    interview:tags "algorithms, backtracking, recursion, strings" ;
    interview:timeEstimate "15-18 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation005 ;
    interview:suggestedAnswer interview:a027 .

interview:a027 a interview:Answer ;
    interview:keyPoints "Backtracking approach; swap each character with every other; recurse on remaining; backtrack by swapping back; O(n! * n) time complexity; handle duplicates with set if needed" ;
    interview:example "function permute(str, l = 0, result = []) { if (l === str.length - 1) { result.push(str); return; } for (let i = l; i < str.length; i++) { str = swap(str, l, i); permute(str, l + 1, result); str = swap(str, l, i); // backtrack } return result; }" ;
    interview:pitfalls "Not backtracking properly; string immutability issues; not handling duplicates; exponential time complexity" .

interview:q028 a interview:Question ;
    schema:name "Implement merge sort and explain its stability" ;
    interview:domain interview:algorithms ;
    interview:difficulty "medium" ;
    interview:tags "algorithms, sorting, divide-conquer, recursion" ;
    interview:timeEstimate "15-20 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003 ;
    interview:suggestedAnswer interview:a028 .

interview:a028 a interview:Answer ;
    interview:keyPoints "Divide and conquer; split array in half recursively; merge sorted halves; stable (maintains relative order of equal elements); O(n log n) time always; O(n) space for auxiliary array; predictable performance" ;
    interview:example "function mergeSort(arr) { if (arr.length <= 1) return arr; const mid = Math.floor(arr.length / 2); const left = mergeSort(arr.slice(0, mid)); const right = mergeSort(arr.slice(mid)); return merge(left, right); } function merge(left, right) { const result = []; let i = 0, j = 0; while (i < left.length && j < right.length) { if (left[i] <= right[j]) result.push(left[i++]); else result.push(right[j++]); } return result.concat(left.slice(i)).concat(right.slice(j)); }" ;
    interview:pitfalls "Not using <= for stability; inefficient space usage; not handling empty arrays" .

interview:q029 a interview:Question ;
    schema:name "Find the diameter of a binary tree" ;
    interview:domain interview:algorithms ;
    interview:difficulty "medium" ;
    interview:tags "algorithms, binary-tree, dfs, recursion" ;
    interview:timeEstimate "15-18 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003 ;
    interview:followUp interview:q030 ;
    interview:suggestedAnswer interview:a029 .

interview:a029 a interview:Answer ;
    interview:keyPoints "Diameter is longest path between any two nodes; may or may not pass through root; use DFS to calculate height; at each node, diameter = left height + right height; track global max; O(n) time, O(h) space for recursion" ;
    interview:example "function diameterOfBinaryTree(root) { let maxDiameter = 0; function height(node) { if (!node) return 0; const left = height(node.left); const right = height(node.right); maxDiameter = Math.max(maxDiameter, left + right); return 1 + Math.max(left, right); } height(root); return maxDiameter; }" ;
    interview:pitfalls "Confusing diameter with height; not tracking global maximum; counting nodes instead of edges" .

interview:q030 a interview:Question ;
    schema:name "Validate if a binary tree is a valid binary search tree" ;
    interview:domain interview:algorithms ;
    interview:difficulty "medium" ;
    interview:tags "algorithms, binary-tree, bst, recursion, validation" ;
    interview:timeEstimate "12-15 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation004 ;
    interview:suggestedAnswer interview:a030 .

interview:a030 a interview:Answer ;
    interview:keyPoints "Pass valid range (min, max) down recursively; left subtree must be < node < right subtree; not just node.left < node < node.right (common mistake); O(n) time, O(h) space; alternative: in-order traversal should be sorted" ;
    interview:example "function isValidBST(root, min = -Infinity, max = Infinity) { if (!root) return true; if (root.val <= min || root.val >= max) return false; return isValidBST(root.left, min, root.val) && isValidBST(root.right, root.val, max); }" ;
    interview:pitfalls "Only checking immediate children; not handling duplicate values; integer overflow with min/max" .

