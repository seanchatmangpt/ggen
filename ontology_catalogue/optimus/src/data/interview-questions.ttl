    interview:domain interview:behavioral ;
    interview:difficulty "medium" ;
    interview:tags "problem-solving, debugging, persistence, technical" ;
    interview:framework "STAR" ;
    interview:timeEstimate "4-6 minutes" ;
    interview:accommodation interview:accommodation001, interview:accommodation002 ;
    interview:suggestedAnswer interview:a031 .

interview:a031 a interview:Answer ;
    interview:keyPoints "Situation: Describe the bug and impact; Task: Your responsibility to fix it; Action: Debugging steps, tools used, collaboration; Result: Resolution, what you learned, prevention measures" ;
    interview:example "S: Production memory leak affecting 10k users; T: Owned backend service; A: Profiled with heap snapshots, isolated to event listener leak, collaborated with team; R: Fixed in 3 days, added monitoring, documented pattern" ;
    interview:pitfalls "Being too technical without showing problem-solving process; not showing learning; blaming others" .

