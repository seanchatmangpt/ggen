interview:q057 a interview:Question ;
    schema:name "Design a distributed rate limiting system" ;
    interview:domain interview:systemDesign ;
    interview:difficulty "hard" ;
    interview:tags "system-design, rate-limiting, distributed-systems, redis, algorithms" ;
    interview:timeEstimate "30-40 minutes" ;
