interview:q064 a interview:Question ;
    schema:name "Design a collaborative document editing system like Google Docs" ;
    interview:domain interview:systemDesign ;
    interview:difficulty "expert" ;
    interview:tags "system-design, real-time, crdt, collaboration, operational-transform" ;
    interview:timeEstimate "45-55 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation005 ;
    interview:suggestedAnswer interview:a064 .

interview:a064 a interview:Answer ;
    interview:keyPoints "Requirements: real-time collaboration, conflict resolution, presence, version history; Algorithms: Operational Transform (OT) or CRDT for conflict-free merges; Components: WebSocket servers, document service, operation log, storage (S3 for snapshots), presence service; Sync: broadcast operations to all clients, transform concurrent ops, apply locally; Scale: partition by document, snapshot + operation log, eventual consistency; Consider: cursors, comments, offline editing" ;
    interview:example "User types -> generate operation -> send via WebSocket -> server transforms against concurrent ops -> broadcast to other clients -> apply locally; OT: transform operations based on prior ops; CRDT: commutative operations; Snapshots: periodic full doc save + operation log; Presence: WebSocket heartbeat, shared cursor positions" ;
    interview:pitfalls "Not discussing OT/CRDT; ignoring conflict resolution; no offline support; missing presence; not considering version history; single server architecture" .

interview:q065 a interview:Question ;
    schema:name "Design a content delivery network (CDN)" ;
    interview:domain interview:systemDesign ;
    interview:difficulty "expert" ;
    interview:tags "system-design, cdn, caching, networking, global-scale" ;
    interview:timeEstimate "40-50 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003 ;
    interview:suggestedAnswer interview:a065 .

interview:a065 a interview:Answer ;
    interview:keyPoints "Requirements: cache and serve static content globally, low latency, high availability; Components: edge servers (globally distributed), origin servers, DNS for routing (GeoDNS), cache invalidation system; Routing: anycast or GeoDNS routes to nearest edge; Caching: LRU eviction, cache-control headers, purge API; Features: SSL termination, DDoS protection, compression; Scale: pop distribution, tiered caching (edge -> regional -> origin); Consider: cache warming, failover, cost optimization" ;
    interview:example "Request -> GeoDNS resolves to nearest edge -> edge checks cache -> hit: return, miss: fetch from origin -> cache -> return; Invalidation: purge API -> propagate to all edges; SSL: terminate at edge; DDoS: rate limiting, IP blocking at edge; Tiered: edge -> regional cache -> origin" ;
    interview:pitfalls "Not discussing global distribution; ignoring cache invalidation; no SSL; missing DDoS protection; not considering costs; single tier caching only" .

