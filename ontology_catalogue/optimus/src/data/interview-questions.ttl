# ========================================
# SYSTEM DESIGN QUESTIONS (15)
# ========================================

interview:q051 a interview:Question ;
    schema:name "Design a URL shortening service like bit.ly" ;
    interview:domain interview:systemDesign ;
    interview:difficulty "medium" ;
    interview:tags "system-design, distributed-systems, databases, caching, scalability" ;
    interview:timeEstimate "35-45 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003, interview:accommodation005 ;
    interview:suggestedAnswer interview:a051 .

interview:a051 a interview:Answer ;
    interview:keyPoints "Requirements: shorten URL, redirect, analytics; Components: API gateway, short code generator (base62), KV store (Redis/DynamoDB), analytics DB; Scale: distributed ID generation (snowflake), CDN for redirects, read-heavy caching; Consider: collision handling, expiration, custom URLs" ;
    interview:example "POST /shorten {url} -> base62(hash(url+counter)) -> store mapping -> return short URL; GET /{code} -> cache lookup -> DB lookup -> 301 redirect; Analytics: async event stream to analytics DB" ;
    interview:pitfalls "Not discussing scale numbers; ignoring analytics; no caching strategy; not handling collisions; single point of failure" .

