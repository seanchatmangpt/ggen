    interview:suggestedAnswer interview:a057 .

interview:a057 a interview:Answer ;
    interview:keyPoints "Algorithms: token bucket, leaky bucket, fixed window, sliding window; Distributed: Redis with Lua scripts for atomicity, or local rate limiter with sync; Storage: Redis for counters, TTL for expiration; Scale: sharding by user ID, local caches with eventual consistency; Consider: different limits per tier, burst handling, graceful degradation" ;
    interview:example "Token bucket in Redis: EVAL script checks tokens, decrements if available; Sliding window: sorted set with timestamps, count in window; Per-user: key = user:{id}:minute; Multi-tier: different counters for different resources" ;
    interview:pitfalls "Not handling distributed race conditions; single Redis instance; no burst allowance; missing different limit types; not considering costs" .

interview:q058 a interview:Question ;
    schema:name "Design a distributed cache system" ;
    interview:domain interview:systemDesign ;
    interview:difficulty "hard" ;
    interview:tags "system-design, caching, distributed-systems, consistency, redis" ;
    interview:timeEstimate "35-45 minutes" ;
    interview:accommodation interview:accommodation002, interview:accommodation003 ;
    interview:followUp interview:q059 ;
    interview:suggestedAnswer interview:a058 .

interview:a058 a interview:Answer ;
    interview:keyPoints "Components: cache cluster (Redis Cluster), consistent hashing for sharding, replication for HA, client-side routing; Eviction: LRU, LFU, TTL; Consistency: write-through, write-back, cache-aside; Scale: horizontal sharding, read replicas; Challenges: cache warming, thundering herd, cache penetration; Consider: multi-level caching (L1 in-memory, L2 Redis), CDN" ;
    interview:example "Read: client -> hash key -> find shard -> read from cache or DB; Write: update DB -> invalidate cache; Consistent hashing: virtual nodes for even distribution; Replication: master-slave for reads; Cache warming: background job populates hot data" ;
    interview:pitfalls "Single point of failure; no eviction strategy; ignoring cache stampede; not considering memory limits; missing monitoring" .

interview:q059 a interview:Question ;
    schema:name "How would you handle cache invalidation in a distributed system?" ;
    interview:domain interview:systemDesign ;
    interview:difficulty "hard" ;
    interview:tags "system-design, caching, distributed-systems, consistency, patterns" ;
    interview:timeEstimate "25-35 minutes" ;
    interview:accommodation interview:accommodation003, interview:accommodation005 ;
    interview:suggestedAnswer interview:a059 .

interview:a059 a interview:Answer ;
    interview:keyPoints "Strategies: TTL-based, event-driven (CDC, pub/sub), versioning, write-through invalidation; Patterns: cache-aside with invalidate on write, write-through, write-behind; Distributed: pub/sub (Redis Pub/Sub, Kafka) for invalidation events, versioned keys; Challenges: race conditions, partial failures, thundering herd; Consider: lazy invalidation, stale reads acceptance, refresh-ahead" ;
    interview:example "Write: update DB -> publish invalidation event -> all cache nodes invalidate; Version-based: cache key includes version, increment on update; TTL: expire after time, refresh on read; CDC: database change log triggers cache updates" ;
    interview:pitfalls "No strategy for race conditions; assuming immediate consistency; cache stampede on invalidation; not handling partial failures; overly aggressive invalidation" .

interview:q060 a interview:Question ;
