  skos:hasTopConcept chatman:FileEditTool ;
  skos:hasTopConcept chatman:MultiFileEditTool ;
  skos:hasTopConcept chatman:DirListTool ;
  skos:hasTopConcept chatman:FileGlobTool ;
  skos:hasTopConcept chatman:FileGrepTool ;
  .

chatman:MemoryToolCategory
  a skos:ConceptScheme ;
  rdfs:label "Memory & Knowledge Tools"@en ;
  skos:hasTopConcept chatman:MemorySaveTool ;
  skos:hasTopConcept chatman:MemoryRecallTool ;
  skos:hasTopConcept chatman:SessionSearchTool ;
  .

chatman:NetworkToolCategory
  a skos:ConceptScheme ;
  rdfs:label "Network & Integration Tools"@en ;
  skos:hasTopConcept chatman:WebFetchTool ;
  skos:hasTopConcept chatman:DownloadTool ;
  skos:hasTopConcept chatman:A2ACallTool ;
  skos:hasTopConcept chatman:BusinessOSAPITool ;
  .

chatman:ExecutionToolCategory
  a skos:ConceptScheme ;
  rdfs:label "Command & Code Execution Tools"@en ;
  skos:hasTopConcept chatman:ShellExecuteTool ;
  skos:hasTopConcept chatman:GitTool ;
  skos:hasTopConcept chatman:ComputerUseTool ;
  .

chatman:CoordinationToolCategory
  a skos:ConceptScheme ;
