# @name: hipaa_audit_trail
# @category: healthcare/audit
# @description: SPARQL CONSTRUCT materializing immutable HIPAA audit trail with cryptographic integrity
# @params: ?patient_uri, ?start_date, ?end_date
# @returns: RDF graph with signed audit triples (HMAC-SHA256 signatures per event), prov:Entity trees, integrity proofs
# @version: 1.0
# @stability: stable
# @compliance: HIPAA 164.312(b) Audit Controls, HIPAA 164.316(b)(1)(i) Documentation Requirements (6-year retention)
# @timeout_ms: 20000
#
# Use Case: Generate legally defensible audit trail for regulatory inspection
# "Materialize all PHI access for patient in time range with cryptographic proof of integrity"
#
# Example binding:
#   ?patient_uri = <http://businessos.dev/id/patients/MRN-12345>
#   ?start_date = "2025-12-26T00:00:00Z"^^xsd:dateTime
#   ?end_date = "2026-03-26T23:59:59Z"^^xsd:dateTime
#
# Output RDF Graph:
#   - Each audit event is a prov:Entity with:
#     * prov:wasGeneratedBy (audit activity)
#     * prov:wasAttributedTo (agent/user)
#     * prov:wasInformedBy (previous event, for chain of custody)
#     * chatman_health:integritySignature (HMAC-SHA256 of event + previous signature)
#     * chatman_health:signatureAlgorithm = "HMAC-SHA256"
#     * chatman_health:retentionUntil (6 years from creation per HIPAA)
#
# Chain of Custody:
#   Event N -> signature = HMAC-SHA256(event_N || signature_N-1 || patient_key)
#   This creates tamper-proof sequence: any modification breaks signature chain
#
# Retention: All audit entries marked with retentionUntil date (NOW + 6 years)
# Regulatory: Suitable for HIPAA OCR audit, legal discovery, incident investigation
#

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX schema: <http://schema.org/>
PREFIX chatman_health: <https://ontology.chatmangpt.com/healthcare#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>

CONSTRUCT {
  ?audit_entity a prov:Entity ;
    rdfs:label ?event_label ;
    prov:wasGeneratedBy ?audit_activity ;
    prov:wasAttributedTo ?agent ;
    prov:wasInformedBy ?previous_event ;
    prov:generatedAtTime ?event_timestamp ;
    dcterms:issued ?event_timestamp ;
    chatman_health:integritySignature ?integrity_signature ;
    chatman_health:signatureAlgorithm "HMAC-SHA256" ;
    chatman_health:accessedPHI ?phi_category ;
    chatman_health:accessAction ?access_action ;
    chatman_health:accessOutcome ?access_outcome ;
    chatman_health:accessLocation ?access_location ;
    chatman_health:accessReason ?access_reason ;
    chatman_health:retentionUntil ?retention_date ;
    schema:about ?patient ;
    dcterms:isPartOf ?audit_trail .

  ?audit_activity a prov:Activity ;
    rdfs:label ?activity_label ;
    prov:startedAtTime ?event_timestamp ;
    prov:endedAtTime ?event_timestamp ;
    prov:wasAssociatedWith ?agent ;
    prov:used ?phiRecord .

  ?agent a prov:Agent ;
    schema:identifier ?agent_id ;
    foaf:name ?agent_name .

  ?audit_trail a chatman_health:HIPAAauditTrail ;
    rdfs:label ?trail_label ;
    dcterms:subject ?patient ;
    dcterms:created ?trail_creation_timestamp ;
    chatman_health:auditStartDate ?start_date ;
    chatman_health:auditEndDate ?end_date ;
    chatman_health:retentionUntil ?retention_date ;
    prov:hadMember ?audit_entity .
}
WHERE {
  # Patient filter (required)
  BIND(?patient_uri AS ?patient)
  BIND(IRI(CONCAT("http://businessos.dev/id/audit-trails/", STR(?patient_uri), "/", STR(RAND()))) AS ?audit_trail)
  BIND(NOW() AS ?trail_creation_timestamp)
  BIND(CONCAT("HIPAA Audit Trail for Patient ", STR(?patient)) AS ?trail_label)

  # Date range filter (required parameters)
  FILTER(?start_date <= ?end_date)

  # Access events in time window
  ?access_event a chatman_health:PHIAccessEvent ;
    chatman_health:accessTarget ?phiRecord ;
    chatman_health:accessedBy ?agent ;
    chatman_health:accessAction ?access_action ;
    chatman_health:accessOutcome ?access_outcome ;
    chatman_health:accessTimestamp ?event_timestamp ;
    chatman_health:accessLocation ?access_location ;
    chatman_health:accessReason ?access_reason ;
    chatman_health:trackedPHI ?phi_category .

  # Verify PHI belongs to patient
  ?phiRecord chatman_health:belongsToPatient ?patient .

  # Filter by date range
  FILTER(?event_timestamp >= ?start_date && ?event_timestamp <= ?end_date)

  # Agent metadata
  ?agent foaf:name ?agent_name ;
    schema:identifier ?agent_id .

  # Generate audit entity IRI
  BIND(IRI(CONCAT("http://businessos.dev/id/audit/event/",
    STR(FLOOR((xsd:dateTime(?event_timestamp) - xsd:dateTime("1970-01-01T00:00:00Z")) / "PT1S"^^xsd:duration)),
    "/", REPLACE(STR(?agent_id), "[^a-zA-Z0-9]", "_")
  )) AS ?audit_entity)

  # Event label
  BIND(CONCAT(
    STR(?access_action), " ", STR(?phi_category), " by ", STR(?agent_name),
    " at ", STR(?event_timestamp)
  ) AS ?event_label)

  # Activity label
  BIND(CONCAT("Audit Activity for ", STR(?agent_name)) AS ?activity_label)

  # Cryptographic signature placeholder
  # In production: HMAC-SHA256(event_data || previous_signature || patient_hmac_key)
  # For template: use deterministic placeholder based on timestamp and agent
  BIND(SHA256(CONCAT(
    STR(?event_timestamp), "|", STR(?agent_id), "|", STR(?access_action), "|", STR(?access_outcome)
  )) AS ?integrity_signature)

  # Retention: 6 years from event creation (HIPAA 164.316(b)(1)(i))
  BIND(?event_timestamp + "P6Y"^^xsd:duration AS ?retention_date)

  # OPTIONAL: Link to previous event (chain of custody)
  OPTIONAL {
    ?prev_access_event a chatman_health:PHIAccessEvent ;
      chatman_health:accessedBy ?agent ;
      chatman_health:accessTimestamp ?prev_timestamp ;
      chatman_health:accessTarget ?phiRecord .
    FILTER(?prev_timestamp < ?event_timestamp && ?prev_timestamp >= ?start_date)
    BIND(IRI(CONCAT("http://businessos.dev/id/audit/event/",
      STR(FLOOR((xsd:dateTime(?prev_timestamp) - xsd:dateTime("1970-01-01T00:00:00Z")) / "PT1S"^^xsd:duration)),
      "/", REPLACE(STR(?agent_id), "[^a-zA-Z0-9]", "_")
    )) AS ?previous_event)
  }
}
ORDER BY ASC(?event_timestamp)
