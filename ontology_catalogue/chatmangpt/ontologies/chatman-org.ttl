@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix chatman: <https://ontology.chatmangpt.com/core#> .

###############################################################################
# CHATMANGPT ORGANIZATIONAL ONTOLOGY
#
# Organizational structure using W3C ORG and FOAF vocabularies
#
# IRI: https://ontology.chatmangpt.com/org
# Module: chatman-org.ttl
#
# This ontology models the ChatmanGPT organization structure, including:
# - Company hierarchy (ChatmanGPT with divisions for each project)
# - Organizational units and teams
# - People with roles, positions, and reporting relationships
# - Sites and locations
# - Memberships and role assignments
###############################################################################

<https://ontology.chatmangpt.com/org>
  a owl:Ontology ;
  dcterms:title "ChatmanGPT Organizational Ontology"@en ;
  dcterms:description "W3C ORG and FOAF-based organizational structure for ChatmanGPT. Models the company hierarchy, teams, people, roles, and reporting relationships. Enables SPARQL queries for organizational reporting: 'Who reports to whom?', 'What teams exist in Engineering?', 'List all agents by project'."@en ;
  dcterms:issued "2026-03-25"^^xsd:date ;
  dcterms:created "2026-03-25T00:00:00Z"^^xsd:dateTime ;
  dcterms:creator "Sean Chatman"@en ;
  dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
  dcterms:isPartOf <https://ontology.chatmangpt.com/> ;
  owl:versionIRI <https://ontology.chatmangpt.com/org/1.0> ;
  owl:versionInfo "1.0"^^xsd:string ;

  # Import the core ontology (includes W3C ORG)
  owl:imports <https://ontology.chatmangpt.com/core> ;

  rdfs:comment "This ontology extends chatman-core.ttl with organizational structure details. It uses W3C ORG (org:Organization, org:OrganizationalUnit, org:Post, org:Role, org:Membership, org:reportsTo) combined with FOAF (foaf:Person, foaf:name, foaf:mbox) to provide a complete organizational graph. The structure can be queried with SPARQL to answer organizational questions and generate reports."@en ;
  .

###############################################################################
# ORGANIZATIONAL STRUCTURE
###############################################################################

chatman:ChatmanGPTOrganization
  a org:Organization ;
  dcterms:identifier "chatman-gpt-org"@en ;
  foaf:name "ChatmanGPT"@en ;
  rdfs:label "ChatmanGPT Organization"@en ;
  foaf:homepage <https://chatmangpt.com> ;
  foaf:mbox <mailto:info@chatmangpt.com> ;
  dcterms:description "Fortune 500-grade AI systems company with AGI-level cross-project connections. Building integrated ecosystem across BusinessOS, Canopy, OSA, and pm4py-rust."@en ;
  org:based_near chatman:PasadenaLocation ;
  org:hasUnit chatman:EngineeringUnit ;
  org:hasUnit chatman:ProductUnit ;
  org:hasUnit chatman:OperationsUnit ;
  .

###############################################################################
# LOCATIONS / SITES
###############################################################################

chatman:PasadenaLocation
  a org:Site ;
  foaf:name "Pasadena, CA Headquarters"@en ;
  rdfs:label "Pasadena Headquarters"@en ;
  vcard:hasStreetAddress "115 E Del Mar Blvd, Unit 405, Pasadena, CA 91105"@en ;
  vcard:hasLocality "Pasadena"@en ;
  vcard:hasRegion "California"@en ;
  vcard:hasPostalCode "91105"@en ;
  vcard:hasCountryName "United States"@en ;
  dcterms:description "Primary headquarters and development location for ChatmanGPT."@en ;
  .

