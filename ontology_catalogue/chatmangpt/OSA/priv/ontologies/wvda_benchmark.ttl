# OSA WvdA Soundness Verification Benchmark Ontology
# Wil van der Aalst soundness properties: deadlock freedom, liveness, boundedness

@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix bench:  <http://chatmangpt.com/ontology/benchmark#> .
@prefix osa:    <http://chatmangpt.com/osa/wvda#> .

# ═══════════════════════════════════════════════════════════════════════════════
# WVDA SOUNDNESS BENCHMARK DEFINITIONS (ELIXIR/BENCHEE)
# ═══════════════════════════════════════════════════════════════════════════════

# Deadlock Detection: 10 States
osa:deadlock_detection_10_states
    a bench:Benchmark ;
    bench:operation_name "deadlock_detection_10_states" ;
    bench:description "Tarjan SCC cycle detection on 10-state graph (Elixir implementation)" ;
    bench:complexity_class "O(V+E)" ;
    bench:operation_category "compute" ;
    bench:dataset_size "small" ;
    bench:dataset_cardinality 10 ;
    bench:slo_ms 2.0 ;
    bench:warmup_iterations 10 ;
    bench:measurement_iterations 100 ;
    bench:memory_profile "linear" ;
    bench:requires_state true ;
    bench:state_setup "Generate StateGraph with 10 states" ;
    bench:telemetry_opentelemetry true ;
    bench:span_name "osa.wvda.deadlock_detection" ;
    bench:attributes '{"algorithm": "tarjan_scc", "states": 10}' .

