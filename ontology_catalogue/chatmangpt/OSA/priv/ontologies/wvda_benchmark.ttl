# Liveness Verification: Timeout Check
osa:liveness_verification_timeout
    a bench:Benchmark ;
    bench:operation_name "liveness_verification_timeout" ;
    bench:description "Liveness verification with timeout_ms and termination path detection" ;
    bench:complexity_class "O(n)" ;
    bench:operation_category "compute" ;
    bench:dataset_size "medium" ;
    bench:dataset_cardinality 100 ;
    bench:slo_ms 20.0 ;
    bench:warmup_iterations 5 ;
    bench:measurement_iterations 50 ;
    bench:memory_profile "linear" ;
    bench:requires_state true ;
    bench:state_setup "Generate StateGraph with timeout_ms annotations" ;
    bench:telemetry_opentelemetry true ;
    bench:span_name "osa.wvda.liveness_verification" ;
    bench:attributes '{"check": "timeout_termination", "states": 100}' .

# Boundedness Check: Queue Limits
osa:boundedness_check_queue_limits
    a bench:Benchmark ;
    bench:operation_name "boundedness_check_queue_limits" ;
    bench:description "Boundedness verification: queue/resource limit detection" ;
    bench:complexity_class "O(n)" ;
    bench:operation_category "compute" ;
    bench:dataset_size "medium" ;
    bench:dataset_cardinality 100 ;
    bench:slo_ms 15.0 ;
    bench:warmup_iterations 5 ;
    bench:measurement_iterations 50 ;
    bench:memory_profile "linear" ;
    bench:requires_state true ;
    bench:state_setup "Generate StateGraph with queue size limits" ;
    bench:telemetry_opentelemetry true ;
    bench:span_name "osa.wvda.boundedness_check" ;
    bench:attributes '{"check": "queue_limits", "states": 100}' .

# Full Soundness Score: All Three Properties
osa:soundness_score_full
    a bench:Benchmark ;
    bench:operation_name "soundness_score_full" ;
    bench:description "Complete soundness score (deadlock + liveness + boundedness) on execution trace" ;
    bench:complexity_class "O(V+E)" ;
    bench:operation_category "compute" ;
    bench:dataset_size "medium" ;
    bench:dataset_cardinality 100 ;
    bench:slo_ms 50.0 ;
    bench:warmup_iterations 3 ;
    bench:measurement_iterations 20 ;
    bench:memory_profile "linear" ;
    bench:requires_state true ;
    bench:state_setup "Generate execution trace with 100 state transitions" ;
    bench:telemetry_opentelemetry true ;
    bench:span_name "osa.wvda.soundness_score" ;
    bench:attributes '{"checks": ["deadlock", "liveness", "boundedness"], "transitions": 100}' .
