# ============================================================================
# COMPLIANCE AUDIT TRAIL CONSTRUCTION
# ============================================================================
# SPARQL CONSTRUCT query materializing audit trail for compliance reporting.
#
# Purpose: Build complete PROV-O + custom audit namespace audit chain showing:
#   - Who performed an action
#   - What action (control check, remediation, approval)
#   - When it occurred
#   - Result of the action
#   - Any related entities (user, resource, rule)
#
# Input parameters:
#   - framework: SOC2, GDPR, HIPAA, SOX
#   - startDate: ISO8601 date (e.g., "2026-01-01")
#   - endDate: ISO8601 date (e.g., "2026-03-26")
#
# Output: RDF graph with PROV-O + audit namespace triples
#   - prov:Activity nodes (control checks, remediations)
#   - prov:Agent nodes (users, services performing actions)
#   - prov:Entity nodes (resources being checked or remediated)
#   - audit:Result nodes (pass/fail/partial outcomes)
#   - Relationships: wasAssociatedWith, used, wasGeneratedBy, wasDerivedFrom
#
# Timeout: 10 seconds max
# ============================================================================

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX bos: <https://chatmangpt.com/ontology/businessos/>
PREFIX audit: <https://chatmangpt.com/ontology/audit/>
PREFIX comp: <https://chatmangpt.com/ontology/compliance/>

CONSTRUCT {
  # Activity node (control check, remediation, approval)
  ?activity a prov:Activity ;
    a audit:ComplianceActivity ;
    audit:activityType ?activityType ;
    audit:framework ?framework ;
    prov:startedAtTime ?startTime ;
    prov:endedAtTime ?endTime ;
    dcterms:creator ?agent ;
    dcterms:subject ?ruleId ;
    prov:wasAssociatedWith ?agent ;
    audit:affectedResource ?resource ;
    audit:result ?resultNode ;
    prov:used ?inputEntity ;
    audit:durationSeconds ?duration ;
    audit:status ?status ;
    rdfs:comment ?comment .

  # Agent (person or service performing the activity)
  ?agent a prov:Agent ;
    a ?agentType ;
    foaf:name ?agentName ;
    foaf:mbox ?agentEmail ;
    audit:agentId ?agentId .

  # Result entity (outcome of the activity)
  ?resultNode a audit:Result ;
    audit:resultStatus ?resultStatus ;
    audit:resultMessage ?resultMessage ;
    audit:checkedDate ?resultTimestamp ;
    audit:evidenceCount ?evidenceCount ;
    audit:confidence ?confidence .

  # Input entity (configuration, policy, requirement being checked)
  ?inputEntity a audit:ComplianceRule ;
    audit:ruleId ?ruleId ;
    audit:ruleName ?ruleName ;
    audit:severity ?severity ;
    audit:framework ?framework ;
    audit:controlArea ?controlArea .

  # Resource entity (what was checked/remediated)
  ?resource a audit:Resource ;
    audit:resourceType ?resourceType ;
    audit:resourceId ?resourceId ;
    audit:resourceName ?resourceName ;
    prov:wasDerivedFrom ?derivedFrom .

  # Relationship: result was generated by activity
  ?resultNode prov:wasGeneratedBy ?activity .

  # Relationship: activity derived from compliance rule
  ?activity prov:wasDerivedFrom ?inputEntity .

  # Provenance of the audit record itself
  ?activity audit:wasRecordedBy ?recordingService ;
    prov:wasInformedBy ?previousActivity ;
    dcterms:issued ?recordedAt .

  ?recordingService a prov:Agent ;
    foaf:name "ComplianceAuditService" ;
    audit:serviceVersion "1.0.0" .
}
WHERE {
  # Input parameters
  BIND("SOC2" AS ?framework)
  BIND("2026-01-01"^^xsd:date AS ?startDate)
  BIND("2026-03-26"^^xsd:date AS ?endDate)

  # Find all audit entries for the framework in the date range
  ?activity a bos:AuditEntry ;
    bos:auditType ?activityType ;
    bos:checkFramework ?framework ;
    prov:startedAtTime ?startTime ;
    prov:endedAtTime ?endTime ;
    dcterms:creator ?agentId ;
    bos:ruleId ?ruleId ;
    bos:ruleName ?ruleName ;
    bos:affectedEntity ?resourceId ;
    bos:checkResult ?resultStatus ;
    bos:resultMessage ?resultMessage ;
    bos:severity ?severity ;
    bos:controlArea ?controlArea .

  # Filter by date range
  FILTER (?startTime >= ?startDate && ?startTime <= ?endDate)

  # Find agent details (person or service)
  ?agentId a ?agentType ;
    foaf:name ?agentName ;
    foaf:mbox ?agentEmail .

  # Find resource being checked
  ?resource a audit:Resource ;
    audit:resourceId ?resourceId ;
    audit:resourceName ?resourceName ;
    audit:resourceType ?resourceType .

  # Calculate derived fields
  BIND(IF(BOUND(?endTime), xsd:integer((?endTime - ?startTime) / 1000), 0) AS ?duration)
  BIND("completed" AS ?status)
  BIND(CONCAT(STR(?activity), "#result") AS ?resultNode)
  BIND(CONCAT(STR(?activity), "#input") AS ?inputEntity)
  BIND("ComplianceAuditService" AS ?recordingService)
  BIND(NOW() AS ?recordedAt)
  BIND(xsd:dateTime(NOW()) AS ?resultTimestamp)
  BIND(1 AS ?evidenceCount)
  BIND(0.95 AS ?confidence)
  BIND(CONCAT("Checked by ", ?agentName) AS ?comment)
  BIND(?startTime AS ?derivedFrom)

  # Order for deterministic results
}
ORDER BY DESC(?startTime)
