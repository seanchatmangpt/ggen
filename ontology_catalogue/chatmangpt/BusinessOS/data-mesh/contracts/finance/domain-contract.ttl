  ex:apiKey "masked" .

ex:ExternalContractors a odrl:Party ;
  foaf:name "External Contractors" .

ex:VendorRole a odrl:Party ;
  foaf:name "Vendor Role" .

ex:AccountingRole a odrl:Party ;
  foaf:name "Accounting Role" ;
  ex:ldapGroup "CN=accounting,OU=Groups,DC=businessos,DC=example,DC=com" .

ex:SalesRole a odrl:Party ;
  foaf:name "Sales Role" ;
  ex:ldapGroup "CN=sales-team,OU=Groups,DC=businessos,DC=example,DC=com" .

ex:TreasuryRole a odrl:Party ;
  foaf:name "Treasury Role" ;
  ex:ldapGroup "CN=treasury,OU=Groups,DC=businessos,DC=example,DC=com" .

ex:AuditRole a odrl:Party ;
  foaf:name "Internal Audit Role" ;
  ex:ldapGroup "CN=internal-audit,OU=Groups,DC=businessos,DC=example,DC=com" .
