PREFIX bos: <http://businessos.dev/id/>
PREFIX bpmn: <http://www.omg.org/spec/BPMN/20100524/MODEL#>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX org: <http://www.w3.org/ns/org#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <http://schema.org/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
  ?team_members_uri a <http://www.w3.org/ns/org#Member> ;
    <http://www.w3.org/ns/org#identifier> ?id ;
    <http://xmlns.com/foaf/0.1/name> ?name ;
    <http://xmlns.com/foaf/0.1/mbox> ?email ;
    <http://www.w3.org/ns/org#role> ?role ;
    <http://www.w3.org/ns/org#reportsTo> ?manager_id_uri ;
    <http://schema.org/priceSpecification> ?hourly_rate ;
    <http://www.w3.org/ns/org#status> ?status ;
    <http://www.w3.org/ns/prov#wasGeneratedBy> ?activity_uri .
}

WHERE {
  # Variables bound from data source
  BIND(IRI(CONCAT("http://businessos.dev/id/members/{id}", STR(?id))) AS ?team_members_uri)
  BIND(IF(BOUND(?manager_id) && ?manager_id != "",
    IRI(CONCAT("http://businessos.dev/id/team_members/", STR(?manager_id))),
    UNDEF) AS ?manager_id_uri)
  BIND(IRI(CONCAT("http://businessos.dev/activity/team_members/", STR(?id))) AS ?activity_uri)
}
