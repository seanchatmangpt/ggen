# Discover MCP tool surfaces from the ontology
# Extracts tool definitions that have been admitted to the manufacturing pipeline
# Returns tool metadata including admission status, tier classification, and safety properties
#
# Public ontology terms:
#   Tool -> skos:Concept in capabilities scheme
#   toolName -> skos:prefLabel
#   admissionStatus -> skos:related status concept
#   tier -> skos:related tier concept
#   description -> skos:definition
#   mutating -> skos:related mutability concept
#   requiresReceipt -> prov:generated

PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dct:  <http://purl.org/dc/terms/>

SELECT
    ?toolName
    ?description
    ?admissionStatus
    ?tier
    ?mutating
    ?requiresReceipt
WHERE {
    # Find all tools that have been admitted (skos:Concept in capabilities scheme)
    ?tool a skos:Concept ;
          skos:prefLabel ?toolName ;
          skos:inScheme <https://chatmangpt.com/ontologies/skos/capabilities> .

    # Admission status via related status concept
    ?tool skos:related ?statusConcept .
    ?statusConcept skos:prefLabel ?admissionStatus .

    # Tier classification via related tier concept
    OPTIONAL {
        ?tool skos:related ?tierConcept .
        ?tierConcept skos:prefLabel ?tier .
    }

    # Description
    OPTIONAL { ?tool skos:definition ?description }

    # Filter to only admitted tools
    FILTER(?admissionStatus = "admitted")

    # Optional safety properties
    OPTIONAL {
        ?tool skos:related ?mutatingConcept .
        ?mutatingConcept skos:prefLabel ?mutating .
        FILTER(?mutating IN ("mutating", "read-only"))
    }
    OPTIONAL { ?tool prov:generated ?requiresReceipt }
}
ORDER BY ?tier ?toolName
