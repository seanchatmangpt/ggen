# List all build profiles with their properties
# Returns profile IRI, label, optimization level, debug symbols, and target architecture

PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX ostar: <https://chatmangpt.com/ontologies/o-star/>

SELECT ?profile ?profile_label ?opt_level ?debug_symbols ?arch_label
WHERE {
  ?profile rdf:type ostar:BuildProfile ;
           rdfs:label ?profile_label ;
           ostar:optimizationLevel ?opt_level ;
           ostar:debugSymbols ?debug_symbols ;
           ostar:targetArchitecture ?arch .

  ?arch rdfs:label ?arch_label .
}
ORDER BY ?profile_label
