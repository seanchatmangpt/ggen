# =============================================================================
# ChatmanGPT Reference Ontology
# RDF model for YAWL 43 patterns, API endpoints, and port map
# Generated from existing reference documentation via ggen Tera + RDF pipeline
# =============================================================================

@prefix ref: <https://chatmangpt.com/reference/> .
@prefix doc: <https://ggen.dev/ontology/documentation#> .
@prefix yawl: <http://unrdf.org/yawl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# Extension Classes
# =============================================================================

ref:YAWLPattern a rdfs:Class ;
    rdfs:subClassOf doc:Reference ;
    rdfs:label "YAWL Workflow Pattern" ;
    rdfs:comment "One of the 43 YAWL workflow patterns from van der Aalst" .

ref:APIEndpoint a rdfs:Class ;
    rdfs:subClassOf doc:Reference ;
    rdfs:label "API Endpoint" ;
    rdfs:comment "An HTTP API endpoint across ChatmanGPT services" .

ref:PortMapping a rdfs:Class ;
    rdfs:subClassOf doc:Reference ;
    rdfs:label "Port Mapping" ;
    rdfs:comment "A service-to-port mapping in the ChatmanGPT stack" .

# =============================================================================
# Extension Properties
# =============================================================================

ref:patternId a rdf:Property ;
    rdfs:domain ref:YAWLPattern ;
    rdfs:range xsd:string ;
    rdfs:label "patternId" ;
    rdfs:comment "Canonical pattern identifier (e.g. '1.1')" .

ref:category a rdf:Property ;
    rdfs:range xsd:string ;
    rdfs:label "category" ;
    rdfs:comment "Pattern or endpoint category" .

ref:implementationStatus a rdf:Property ;
    rdfs:range xsd:string ;
    rdfs:label "implementationStatus" ;
    rdfs:comment "implemented, partial, planned" .

ref:yawlNetStructure a rdf:Property ;
    rdfs:domain ref:YAWLPattern ;
    rdfs:range xsd:string ;
    rdfs:label "yawlNetStructure" ;
    rdfs:comment "YAWL net structure description" .

ref:agentMapping a rdf:Property ;
    rdfs:domain ref:YAWLPattern ;
    rdfs:range xsd:string ;
    rdfs:label "agentMapping" ;
    rdfs:comment "How pattern maps to agent coordination" .

ref:usedIn a rdf:Property ;
    rdfs:domain ref:YAWLPattern ;
    rdfs:range xsd:string ;
    rdfs:label "usedIn" ;
    rdfs:comment "Projects where pattern is used" .

ref:relatedPattern a rdf:Property ;
    rdfs:domain ref:YAWLPattern ;
    rdfs:range ref:YAWLPattern ;
    rdfs:label "relatedPattern" ;
    rdfs:comment "Related YAWL pattern" .

ref:httpMethod a rdf:Property ;
    rdfs:domain ref:APIEndpoint ;
    rdfs:range xsd:string ;
    rdfs:label "httpMethod" ;
    rdfs:comment "HTTP method: GET, POST, PUT, DELETE" .

ref:basePath a rdf:Property ;
    rdfs:domain ref:APIEndpoint ;
    rdfs:range xsd:string ;
    rdfs:label "basePath" ;
    rdfs:comment "Base URL path for the service" .

ref:path a rdf:Property ;
    rdfs:domain ref:APIEndpoint ;
    rdfs:range xsd:string ;
    rdfs:label "path" ;
    rdfs:comment "Endpoint path" .

ref:auth a rdf:Property ;
    rdfs:domain ref:APIEndpoint ;
    rdfs:range xsd:string ;
    rdfs:label "auth" ;
    rdfs:comment "Authentication requirement" .

ref:service a rdf:Property ;
    rdfs:range xsd:string ;
    rdfs:label "service" ;
    rdfs:comment "Service name" .

ref:port a rdf:Property ;
    rdfs:domain ref:PortMapping ;
    rdfs:range xsd:integer ;
    rdfs:label "port" ;
    rdfs:comment "Port number" .

ref:protocol a rdf:Property ;
    rdfs:domain ref:PortMapping ;
    rdfs:range xsd:string ;
    rdfs:label "protocol" ;
    rdfs:comment "Protocol: HTTP, WebSocket, gRPC, PostgreSQL, Redis" .

ref:healthEndpoint a rdf:Property ;
    rdfs:domain ref:PortMapping ;
    rdfs:range xsd:string ;
    rdfs:label "healthEndpoint" ;
    rdfs:comment "Health check URL" .

ref:portRange a rdf:Property ;
    rdfs:domain ref:PortMapping ;
    rdfs:range xsd:string ;
    rdfs:label "portRange" ;
    rdfs:comment "Port allocation range description" .

ref:codeExample a rdf:Property ;
    rdfs:domain ref:APIEndpoint ;
    rdfs:range xsd:string ;
    rdfs:label "codeExample" ;
    rdfs:comment "curl example for the endpoint" .

# =============================================================================
# YAWL 43 PATTERNS
# =============================================================================

# --- Category 1: Control Flow (20 patterns) ---

ref:pattern-1-1 a ref:YAWLPattern ;
    doc:title "Sequence" ;
    doc:description "Tasks execute in order. One completes, next starts." ;
    ref:patternId "1.1" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: tasks: [task1, task2, task3]; flow: sequence" ;
    ref:agentMapping "Single agent with sequential steps, or handoffs between agents." ;
    ref:usedIn "All feature workflows, deployment pipelines" ;
    ref:relatedPattern ref:pattern-2-5 .

ref:pattern-1-2 a ref:YAWLPattern ;
    doc:title "Parallel Split" ;
    doc:description "One task completes, multiple tasks start concurrently." ;
    ref:patternId "1.2" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: split: { type: and, tasks: [task_a, task_b, task_c] }" ;
    ref:agentMapping "Dispatcher activates multiple agents in parallel." ;
    ref:usedIn "Code review (backend + frontend + security review in parallel)" ;
    ref:relatedPattern ref:pattern-1-3 .

ref:pattern-1-3 a ref:YAWLPattern ;
    doc:title "Synchronization" ;
    doc:description "Multiple concurrent tasks must all complete before next task starts." ;
    ref:patternId "1.3" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: and, tasks: [task_a, task_b, task_c], wait_for: all }" ;
    ref:agentMapping "Coordinator waits for all agent confirmations." ;
    ref:usedIn "QA approval (requires dev + QA + security approval)" ;
    ref:relatedPattern ref:pattern-1-2 .

ref:pattern-1-4 a ref:YAWLPattern ;
    doc:title "Exclusive Choice (XOR Split)" ;
    doc:description "One task completes, exactly one of multiple branches executes based on condition." ;
    ref:patternId "1.4" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: split: { type: xor, branches: [{condition: priority == 'high', task: urgent_handler}, ...] }" ;
    ref:agentMapping "Router activates one agent based on signal classification." ;
    ref:usedIn "Signal routing (different agents for different signal types)" ;
    ref:relatedPattern ref:pattern-1-5 .

ref:pattern-1-5 a ref:YAWLPattern ;
    doc:title "Simple Merge" ;
    doc:description "Multiple branches converge without synchronization. First to arrive continues." ;
    ref:patternId "1.5" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: xor, tasks: [task_a, task_b], wait_for: first }" ;
    ref:agentMapping "First agent to complete hands off to next phase." ;
    ref:usedIn "Competitive task execution (first response wins)" ;
    ref:relatedPattern ref:pattern-1-4 .

ref:pattern-1-6 a ref:YAWLPattern ;
    doc:title "Multi-Choice (OR Split)" ;
    doc:description "One task completes, multiple (possibly all) branches execute based on conditions." ;
    ref:patternId "1.6" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: split: { type: or, branches: [{condition: has_security_implications, task: security_review}, ...] }" ;
    ref:agentMapping "Dispatcher activates agents based on multiple conditions." ;
    ref:usedIn "Code review (only required reviewers activate)" ;
    ref:relatedPattern ref:pattern-2-2 .

ref:pattern-1-7 a ref:YAWLPattern ;
    doc:title "Synchronizing Merge (OR Join)" ;
    doc:description "Multiple branches converge. Wait for all active branches to complete." ;
    ref:patternId "1.7" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: or, wait_for: active }" ;
    ref:agentMapping "Coordinator waits for all activated agents." ;
    ref:usedIn "Dynamic review panels (all reviewers must approve)" ;
    ref:relatedPattern ref:pattern-1-6 .

ref:pattern-1-8 a ref:YAWLPattern ;
    doc:title "Multi-Merge (N-out-of-M Join)" ;
    doc:description "Multiple branches converge. Continue when M of N branches complete." ;
    ref:patternId "1.8" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: n_of_m, threshold: 2, of: 3 }" ;
    ref:agentMapping "Continue when quorum reached." ;
    ref:usedIn "Approval workflows (2 of 3 approvals required)" ;
    ref:relatedPattern ref:pattern-1-7 .

ref:pattern-1-9 a ref:YAWLPattern ;
    doc:title "Discriminator" ;
    doc:description "Wait for first N of M branches to complete, then ignore remaining." ;
    ref:patternId "1.9" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: discriminator, wait_for: first, count: 1, ignore_rest: true }" ;
    ref:agentMapping "First responder wins, others cancelled." ;
    ref:usedIn "Competitive bidding, parallel research" ;
    ref:relatedPattern ref:pattern-1-8 .

ref:pattern-1-10 a ref:YAWLPattern ;
    doc:title "Arbitrary Cycles" ;
    doc:description "Tasks can loop back to earlier tasks (with soundness guarantees)." ;
    ref:patternId "1.10" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: loop: { while: not_approved, do: review_and_fix, max_iterations: 3 }" ;
    ref:agentMapping "Retry loop with escalation." ;
    ref:usedIn "QA rejection cycles (max 3 retries)" ;
    ref:relatedPattern ref:pattern-1-1 .

ref:pattern-1-11 a ref:YAWLPattern ;
    doc:title "Implicit Termination" ;
    doc:description "Workflow terminates when no tasks are active or enabled." ;
    ref:patternId "1.11" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: termination: implicit, when: no_active_tasks" ;
    ref:agentMapping "Operation completes when all work done." ;
    ref:usedIn "Background processing, batch jobs" ;
    ref:relatedPattern ref:pattern-1-10 .

ref:pattern-1-12 a ref:YAWLPattern ;
    doc:title "Multiple Instances (Without Synchronization)" ;
    doc:description "Create multiple instances of a task. No synchronization needed." ;
    ref:patternId "1.12" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: task: { type: multiple_instances, create: for_each_item, sync: none }" ;
    ref:agentMapping "Spawn agents for each item, no coordination." ;
    ref:usedIn "Bulk processing (generate docs for 10 projects)" ;
    ref:relatedPattern ref:pattern-4-1 .

ref:pattern-1-13 a ref:YAWLPattern ;
    doc:title "Multiple Instances (With Prior Synchronization)" ;
    doc:description "Create multiple instances after synchronizing a prior join." ;
    ref:patternId "1.13" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: and }, then: { type: multiple_instances, create: for_each_item }" ;
    ref:agentMapping "Synchronize first, then spawn parallel agents." ;
    ref:usedIn "Post-approval parallel processing" ;
    ref:relatedPattern ref:pattern-1-12 .

ref:pattern-1-14 a ref:YAWLPattern ;
    doc:title "Multiple Instances (With Post-Synchronization)" ;
    doc:description "Synchronize after multiple instances complete." ;
    ref:patternId "1.14" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: { type: multiple_instances, sync: all }" ;
    ref:agentMapping "Spawn agents, wait for all to complete." ;
    ref:usedIn "Parallel test execution (wait for all tests)" ;
    ref:relatedPattern ref:pattern-4-4 .

ref:pattern-1-15 a ref:YAWLPattern ;
    doc:title "Multiple Instances (With Prior and Post-Synchronization)" ;
    doc:description "Synchronize before and after multiple instances." ;
    ref:patternId "1.15" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: and }, then: { type: multiple_instances }, sync: all" ;
    ref:agentMapping "Synchronize, spawn, synchronize again." ;
    ref:usedIn "Structured parallel review cycles" ;
    ref:relatedPattern ref:pattern-1-13 .

ref:pattern-1-16 a ref:YAWLPattern ;
    doc:title "Deferred Choice" ;
    doc:description "Multiple tasks are enabled. Choice is made at runtime based on which task completes first or external event." ;
    ref:patternId "1.16" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: choice: { type: deferred, options: [{task: manual_review, trigger: human_intervention}, {task: auto_approve, trigger: timeout}] }" ;
    ref:agentMapping "System chooses path based on events." ;
    ref:usedIn "Approval workflows (auto-approve if no objection in 24h)" ;
    ref:relatedPattern ref:pattern-5-1 .

ref:pattern-1-17 a ref:YAWLPattern ;
    doc:title "Interleaved Parallel Routing" ;
    doc:description "Multiple instances of a task execute in parallel with interleaving." ;
    ref:patternId "1.17" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: parallel: { type: interleaved, instances: [instance_a, instance_b, instance_c] }" ;
    ref:agentMapping "Agents work in parallel, can take turns." ;
    ref:usedIn "Round-robin task distribution" ;
    ref:relatedPattern ref:pattern-3-1 .

ref:pattern-1-18 a ref:YAWLPattern ;
    doc:title "Milestone" ;
    doc:description "Task can only execute if milestone reached. Once milestone passed, task can no longer execute." ;
    ref:patternId "1.18" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: milestone: { after: phase_1_complete, enables: [task_a, task_b], disables_after: phase_2_starts }" ;
    ref:agentMapping "Tasks only available in certain phases." ;
    ref:usedIn "Feature windows (bugs only accepted in freeze period)" ;
    ref:relatedPattern ref:pattern-1-16 .

ref:pattern-1-19 a ref:YAWLPattern ;
    doc:title "Cancel Activity" ;
    doc:description "Running task can be cancelled by external event." ;
    ref:patternId "1.19" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: task: { cancellable: true, on_cancel: cleanup }" ;
    ref:agentMapping "Agent can be interrupted and cleaned up." ;
    ref:usedIn "Emergency stops, cancelled deployments" ;
    ref:relatedPattern ref:pattern-5-3 .

ref:pattern-1-20 a ref:YAWLPattern ;
    doc:title "Close Multiple Instances" ;
    doc:description "Complete or cancel all remaining instances of a multiple-instance task." ;
    ref:patternId "1.20" ;
    ref:category "Control Flow" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: instances: { close_remaining_when: condition_met }" ;
    ref:agentMapping "Signal all agents to complete or cancel." ;
    ref:usedIn "Early completion of parallel reviews" ;
    ref:relatedPattern ref:pattern-5-2 .

# --- Category 2: Advanced Branching and Synchronization (7 patterns) ---

ref:pattern-2-1 a ref:YAWLPattern ;
    doc:title "Structured Discriminator" ;
    doc:description "Discriminator within a structured block (soundness-preserving)." ;
    ref:patternId "2.1" ;
    ref:category "Advanced Branching" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: discriminator, within: structured_block, count: 1 }" ;
    ref:agentMapping "First agent completes within a bounded scope, others cancelled." ;
    ref:usedIn "Structured competitive task execution" ;
    ref:relatedPattern ref:pattern-1-9 .

ref:pattern-2-2 a ref:YAWLPattern ;
    doc:title "Cancelling Discriminator" ;
    doc:description "Discriminator that cancels remaining branches on first completion." ;
    ref:patternId "2.2" ;
    ref:category "Advanced Branching" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: discriminator, cancel_rest: true }" ;
    ref:agentMapping "First responder wins, remaining agents terminated." ;
    ref:usedIn "Priority-based routing with cancellation" ;
    ref:relatedPattern ref:pattern-2-1 .

ref:pattern-2-3 a ref:YAWLPattern ;
    doc:title "Cancelling Partial Join" ;
    doc:description "N-of-M join that cancels remaining branches when threshold reached." ;
    ref:patternId "2.3" ;
    ref:category "Advanced Branching" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: n_of_m, threshold: 2, of: 3, cancel_rest: true }" ;
    ref:agentMapping "Quorum reached, remaining agents cancelled." ;
    ref:usedIn "Distributed voting with early termination" ;
    ref:relatedPattern ref:pattern-1-8 .

ref:pattern-2-4 a ref:YAWLPattern ;
    doc:title "Generalized AND-Join (OR-Join)" ;
    doc:description "Join that synchronizes on the set of active branches at runtime." ;
    ref:patternId "2.4" ;
    ref:category "Advanced Branching" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: or_join, wait_for: active_branches }" ;
    ref:agentMapping "Coordinator tracks which branches were activated and waits." ;
    ref:usedIn "Dynamic multi-path synchronization" ;
    ref:relatedPattern ref:pattern-1-7 .

ref:pattern-2-5 a ref:YAWLPattern ;
    doc:title "Recurring Sequence" ;
    doc:description "Sequence of tasks that repeats on a schedule or trigger." ;
    ref:patternId "2.5" ;
    ref:category "Advanced Branching" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: sequence: { tasks: [task1, task2, task3], repeat: { every: '24h', until: cancelled } }" ;
    ref:agentMapping "Agent loop with scheduled repetition." ;
    ref:usedIn "Nightly builds, periodic health checks" ;
    ref:relatedPattern ref:pattern-1-10 .

ref:pattern-2-6 a ref:YAWLPattern ;
    doc:title "Recurring Parallel" ;
    doc:description "Parallel split that repeats on a schedule." ;
    ref:patternId "2.6" ;
    ref:category "Advanced Branching" ;
    ref:implementationStatus "partial" ;
    ref:yawlNetStructure "workflow: split: { type: and, tasks: [task_a, task_b], repeat: { every: '1h' } }" ;
    ref:agentMapping "Periodic parallel agent dispatch." ;
    ref:usedIn "Hourly multi-system health probes" ;
    ref:relatedPattern ref:pattern-2-5 .

ref:pattern-2-7 a ref:YAWLPattern ;
    doc:title "Recurring Discriminator" ;
    doc:description "Discriminator pattern that repeats on a schedule." ;
    ref:patternId "2.7" ;
    ref:category "Advanced Branching" ;
    ref:implementationStatus "partial" ;
    ref:yawlNetStructure "workflow: join: { type: discriminator, repeat: { every: '30m' } }" ;
    ref:agentMapping "Periodic first-responder-wins dispatch." ;
    ref:usedIn "Load balancing with periodic reassignment" ;
    ref:relatedPattern ref:pattern-2-1 .

# --- Category 3: Structural Patterns (5 patterns) ---

ref:pattern-3-1 a ref:YAWLPattern ;
    doc:title "Arbitrary Interleaving" ;
    doc:description "Tasks from different branches can interleave arbitrarily." ;
    ref:patternId "3.1" ;
    ref:category "Structural" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: branches: [{branch_a: [task_a1, task_a2]}, {branch_b: [task_b1, task_b2]}]; interleaving: arbitrary" ;
    ref:agentMapping "Agents work independently, no order constraint." ;
    ref:usedIn "Research + implementation in parallel" ;
    ref:relatedPattern ref:pattern-1-17 .

ref:pattern-3-2 a ref:YAWLPattern ;
    doc:title "Structured Partial Join" ;
    doc:description "Partial join within a structured block (soundness-preserving)." ;
    ref:patternId "3.2" ;
    ref:category "Structural" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: n_of_m, within: structured_block, threshold: 2, of: 3 }" ;
    ref:agentMapping "Quorum within a bounded scope." ;
    ref:usedIn "Partial approvals within a phase" ;
    ref:relatedPattern ref:pattern-2-3 .

ref:pattern-3-3 a ref:YAWLPattern ;
    doc:title "Structured OR-Join" ;
    doc:description "OR-Join within a structured block." ;
    ref:patternId "3.3" ;
    ref:category "Structural" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: join: { type: or_join, within: structured_block }" ;
    ref:agentMapping "Dynamic synchronization within bounded scope." ;
    ref:usedIn "Phase-gated multi-path workflows" ;
    ref:relatedPattern ref:pattern-2-4 .

ref:pattern-3-4 a ref:YAWLPattern ;
    doc:title "Structured Loop Region" ;
    doc:description "Loop within a structured block with guaranteed termination." ;
    ref:patternId "3.4" ;
    ref:category "Structural" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: loop: { while: condition, do: [task_a, task_b], max_iterations: 10, within: structured_block }" ;
    ref:agentMapping "Bounded retry within a workflow phase." ;
    ref:usedIn "Iterative refinement loops" ;
    ref:relatedPattern ref:pattern-1-10 .

ref:pattern-3-5 a ref:YAWLPattern ;
    doc:title "Thread Split" ;
    doc:description "Single thread splits into multiple independent threads." ;
    ref:patternId "3.5" ;
    ref:category "Structural" ;
    ref:implementationStatus "partial" ;
    ref:yawlNetStructure "workflow: split: { type: thread, threads: [thread_a, thread_b, thread_c] }" ;
    ref:agentMapping "Spawn independent agent threads." ;
    ref:usedIn "Long-running independent processes" ;
    ref:relatedPattern ref:pattern-1-2 .

# --- Category 4: Multiple Instance Patterns (6 patterns) ---

ref:pattern-4-1 a ref:YAWLPattern ;
    doc:title "Multiple Instances (With Design Time Knowledge)" ;
    doc:description "Number of instances known at design time." ;
    ref:patternId "4.1" ;
    ref:category "Multiple Instance" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: instances: { count: 3, tasks: [task_a, task_b, task_c] }" ;
    ref:agentMapping "Fixed number of agents for known tasks." ;
    ref:usedIn "Three-stage review (dev, QA, security)" ;
    ref:relatedPattern ref:pattern-4-2 .

ref:pattern-4-2 a ref:YAWLPattern ;
    doc:title "Multiple Instances (With Runtime Knowledge)" ;
    doc:description "Number of instances known at runtime." ;
    ref:patternId "4.2" ;
    ref:category "Multiple Instance" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: instances: { count: from_data, source: num_reviewers }" ;
    ref:agentMapping "Dynamic number of agents based on data." ;
    ref:usedIn "Review panel size based on PR complexity" ;
    ref:relatedPattern ref:pattern-4-3 .

ref:pattern-4-3 a ref:YAWLPattern ;
    doc:title "Multiple Instances (Without Runtime Knowledge)" ;
    doc:description "Create instances until condition met." ;
    ref:patternId "4.3" ;
    ref:category "Multiple Instance" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: instances: { create: until, condition: all_items_processed }" ;
    ref:agentMapping "Spawn agents as needed until work done." ;
    ref:usedIn "Queue processing, crawling" ;
    ref:relatedPattern ref:pattern-4-2 .

ref:pattern-4-4 a ref:YAWLPattern ;
    doc:title "Synchronizing Multiple Instances" ;
    doc:description "Wait for all instances to complete." ;
    ref:patternId "4.4" ;
    ref:category "Multiple Instance" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: instances: { sync: all }" ;
    ref:agentMapping "Coordinator waits for all agents." ;
    ref:usedIn "Parallel test execution (wait for all tests)" ;
    ref:relatedPattern ref:pattern-4-5 .

ref:pattern-4-5 a ref:YAWLPattern ;
    doc:title "Partial Synchronization of Multiple Instances" ;
    doc:description "Continue when quorum of instances complete." ;
    ref:patternId "4.5" ;
    ref:category "Multiple Instance" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: instances: { sync: quorum, threshold: 0.6 }" ;
    ref:agentMapping "Continue when majority done." ;
    ref:usedIn "Distributed consensus, voting" ;
    ref:relatedPattern ref:pattern-4-4 .

ref:pattern-4-6 a ref:YAWLPattern ;
    doc:title "Multiple Instances With Priori Design Time Knowledge" ;
    doc:description "Instances created at design time with static configuration." ;
    ref:patternId "4.6" ;
    ref:category "Multiple Instance" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: instances: { type: static, configs: [{id: inst_a, config: config_a}, {id: inst_b, config: config_b}] }" ;
    ref:agentMapping "Pre-configured agents for known roles." ;
    ref:usedIn "Fixed team structure (architect, builder, reviewer)" ;
    ref:relatedPattern ref:pattern-4-1 .

# --- Category 5: State-Based Patterns (5 patterns) ---

ref:pattern-5-1 a ref:YAWLPattern ;
    doc:title "Deferred Choice with State" ;
    doc:description "Choice deferred until state condition met." ;
    ref:patternId "5.1" ;
    ref:category "State-Based" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: choice: { type: state_based, conditions: [{state: approval_granted, task: proceed}, {state: approval_denied, task: terminate}] }" ;
    ref:agentMapping "Router checks state before activating agent." ;
    ref:usedIn "Approval workflows (wait for board decision)" ;
    ref:relatedPattern ref:pattern-1-16 .

ref:pattern-5-2 a ref:YAWLPattern ;
    doc:title "Cancelling Multiple Instances" ;
    doc:description "Cancel all instances when condition met." ;
    ref:patternId "5.2" ;
    ref:category "State-Based" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: instances: { cancel_all_when: emergency_stop }" ;
    ref:agentMapping "Emergency stop terminates all agents." ;
    ref:usedIn "Incident response, rollbacks" ;
    ref:relatedPattern ref:pattern-5-3 .

ref:pattern-5-3 a ref:YAWLPattern ;
    doc:title "Cancel Region" ;
    doc:description "Cancel all tasks in a region." ;
    ref:patternId "5.3" ;
    ref:category "State-Based" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: region: { id: deployment_region, tasks: [task_a, task_b, task_c], cancel_when: deployment_failed }" ;
    ref:agentMapping "Region failure cancels all related agents." ;
    ref:usedIn "Deployment pipelines (failed stage stops all)" ;
    ref:relatedPattern ref:pattern-5-4 .

ref:pattern-5-4 a ref:YAWLPattern ;
    doc:title "Cancel Case" ;
    doc:description "Cancel entire workflow case." ;
    ref:patternId "5.4" ;
    ref:category "State-Based" ;
    ref:implementationStatus "implemented" ;
    ref:yawlNetStructure "workflow: cancel_case_when: critical_failure" ;
    ref:agentMapping "Critical failure terminates entire operation." ;
    ref:usedIn "Transaction rollback, failed operations" ;
    ref:relatedPattern ref:pattern-5-3 .

ref:pattern-5-5 a ref:YAWLPattern ;
    doc:title "Recursion" ;
    doc:description "Workflow can invoke itself." ;
    ref:patternId "5.5" ;
    ref:category "State-Based" ;
    ref:implementationStatus "partial" ;
    ref:yawlNetStructure "workflow: recursive: { call: self, until: base_condition }" ;
    ref:agentMapping "Agent invokes workflow recursively." ;
    ref:usedIn "Hierarchical processing, tree traversal" ;
    ref:relatedPattern ref:pattern-1-10 .

