    doc:hasSignature "POST /conformance { event_log, model }" ;
    doc:hasReturnValue "200 OK: { fitness, precision, generalization }" ;
    ref:codeExample "curl -s -X POST http://localhost:8090/conformance -H 'Content-Type: application/json' -d '{\"event_log\": [...], \"model\": \"...\"}'" .

ref:pm4py-analyze a ref:APIEndpoint ;
    doc:title "POST /analyze" ;
    doc:description "Analyze process metrics from event log" ;
    ref:service "pm4py-rust" ;
    ref:httpMethod "POST" ;
    ref:basePath "http://localhost:8090" ;
    ref:path "/analyze" ;
    ref:auth "None" ;
    ref:category "Process Mining" ;
    doc:hasSignature "POST /analyze { event_log, metrics? }" ;
    doc:hasReturnValue "200 OK: { metrics: { cycle_time, bottleneck, throughput } }" ;
    ref:codeExample "curl -s -X POST http://localhost:8090/analyze -H 'Content-Type: application/json' -d '{\"event_log\": [...]}\'" .
