    doc:order 1 .

# =============================================================================
# Code Examples
# =============================================================================

# --- Armstrong Supervision Tree (Elixir/OTP) ---

thesis:ArmstrongSupervisionExample a doc:Example ;
    doc:title "Armstrong Supervision Tree: OSA Root Supervisor" ;
    doc:codeLanguage "elixir" ;
    doc:codeExample """defmodule OSA.Supervisor do
  use Supervisor

  def start_link(init_arg) do
    Supervisor.start_link(__MODULE__, init_arg, name: __MODULE__)
  end

  @impl true
  def init(_arg) do
    children = [
      {OSA.WebServer, []},           # permanent: restart on any crash
      {OSA.AgentPool, max_agents: 10}, # permanent: bounded instance count
      {OSA.HealthCheck, interval_ms: 5000} # permanent: liveness heartbeat
    ]

    # one_for_one: child crash does NOT restart siblings
    # max_restarts: 5 in 60 seconds prevents restart storms
    Supervisor.init(children, strategy: :one_for_one,
                     max_restarts: 5, max_seconds: 60)
  end
end""" .

# --- WvdA Soundness: Timeout + Fallback ---

thesis:WvdATimeoutExample a doc:Example ;
    doc:title "WvdA Deadlock-Freedom: Explicit Timeout with Fallback" ;
    doc:codeLanguage "elixir" ;
    doc:codeExample """# Every GenServer.call has explicit timeout_ms
# This guarantees deadlock-freedom: no process waits forever
case GenServer.call(pid, {:request, data}, 5000) do
  {:ok, result} -> {:ok, result}
  :timeout -> escalate_to_supervisor(pid)
end""" .

# --- A2A Instrumentation with OTEL ---

thesis:A2AOTELExample a doc:Example ;
    doc:title "A2A Task Instrumentation with OpenTelemetry" ;
    doc:codeLanguage "elixir" ;
    doc:codeExample """# OTEL span captures execution proof for three-layer verification
def handle_task(task) do
  OpenTelemetry.Tracer.with_span "a2a.task.create",
    attributes: [
      agent_id: task.agent_id,
      resource_id: task.resource_id,
      status: "ok"
    ] do
    # ... task processing ...
    {:ok, result}
  end
end""" .

# --- WvdA Boundedness: Bounded Queue ---

thesis:WvdABoundednessExample a doc:Example ;
    doc:title "WvdA Boundedness: Queue with Eviction Policy" ;
    doc:codeLanguage "elixir" ;
    doc:codeExample """# Bounded queue prevents unbounded memory growth
def queue_loop(items, max_size: 1000) do
  receive do
    {:add, item} ->
      new_items =
        if length(items) >= 1000 do
          tl(items)  # Drop oldest when at capacity
        else
          items
        end
      queue_loop([item | new_items], max_size: 1000)

    :drain -> process_items(items)
  end
end""" .

