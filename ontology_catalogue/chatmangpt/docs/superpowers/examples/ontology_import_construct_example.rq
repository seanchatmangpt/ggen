# Example SPARQL CONSTRUCT Query for Ontology Import
# This query transforms external ontologies into ChatmanGPT namespace
# Generated by: bos ontology import
# Status: Production template

PREFIX chatman: <http://chatmangpt.org/ontology/>
PREFIX external: <http://example.org/schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
  # Core: mapped resource type and equivalence
  ?chatman_resource
    rdf:type ?chatman_class ;
    owl:equivalentClass ?external_class ;
    rdfs:label ?label ;
    rdfs:comment ?description .

  # Provenance: tracking transformation origin
  ?chatman_resource
    prov:wasGeneratedBy ?activity_uri ;
    prov:wasDerivedFrom ?source_uri ;
    prov:generatedAtTime ?timestamp ;
    prov:wasAttributedTo <http://chatmangpt.org/agent/ontology-importer> .

  # Properties: mapped with namespace transformation
  ?chatman_resource
    ?mapped_property ?value .

  # Relationships: preserved between transformed entities
  ?chatman_resource
    ?relationship ?related_resource .

  # Imports: preserved from source ontology
  chatman:ImportedOntology
    owl:imports ?imported_ontology ;
    prov:wasDerivedFrom ?source_ontology .
}
WHERE {
  # SOURCE PATTERN: Load external ontology
  {
    ?external_resource
      rdf:type ?external_class ;
      ?external_property ?value ;
      ?external_relation ?external_related .

    # Optional: extract labels and descriptions
    OPTIONAL { ?external_resource rdfs:label ?label . }
    OPTIONAL { ?external_resource rdfs:comment ?description . }
  }
  UNION
  {
    # Load imported ontologies
    ?source_ontology owl:imports ?imported_ontology .
  }

  # ============================================================================
  # CLASS MAPPING: External class → ChatmanGPT domain class
  # ============================================================================
  BIND(CASE
    # Organization classes
    WHEN ?external_class = external:Organization
      THEN chatman:Organization
    WHEN ?external_class = external:Company
      THEN chatman:Organization
    WHEN ?external_class = external:Enterprise
      THEN chatman:Organization

    # Agent/Person classes
    WHEN ?external_class = external:Employee
      THEN chatman:Agent
    WHEN ?external_class = external:Person
      THEN chatman:Agent
    WHEN ?external_class = external:User
      THEN chatman:Agent
    WHEN ?external_class = external:Contact
      THEN chatman:Agent

    # Process/Activity classes
    WHEN ?external_class = external:Process
      THEN chatman:Workflow
    WHEN ?external_class = external:Activity
      THEN chatman:Task
    WHEN ?external_class = external:Step
      THEN chatman:Task

    # Team/Group classes
    WHEN ?external_class = external:Department
      THEN chatman:Team
    WHEN ?external_class = external:Team
      THEN chatman:Team
    WHEN ?external_class = external:Group
      THEN chatman:Team

    # Fallback: namespace-based URI transformation
    ELSE IRI(CONCAT(
      "http://chatmangpt.org/ontology/",
      ENCODE_FOR_URI(STR(?external_class))
    ))
  END AS ?chatman_class)

  # ============================================================================
  # PROPERTY MAPPING: External property → ChatmanGPT domain property
  # ============================================================================
  BIND(CASE
    # Composition/containment
    WHEN ?external_property = external:hasEmployee
      THEN chatman:contains
    WHEN ?external_property = external:hasMember
      THEN chatman:contains
    WHEN ?external_property = external:hasChild
      THEN chatman:contains
    WHEN ?external_property = external:hasTask
      THEN chatman:contains

    # Relationship/membership
    WHEN ?external_property = external:worksFor
      THEN chatman:memberOf
    WHEN ?external_property = external:employedBy
      THEN chatman:memberOf
    WHEN ?external_property = external:memberOf
      THEN chatman:memberOf
    WHEN ?external_property = external:partOf
      THEN chatman:memberOf

    # Supervision/management
    WHEN ?external_property = external:manages
      THEN chatman:supervises
    WHEN ?external_property = external:supervisedBy
      THEN chatman:supervises
    WHEN ?external_property = external:reports
      THEN chatman:reports
    WHEN ?external_property = external:managed_by
      THEN chatman:supervises

    # Process flow
    WHEN ?external_property = external:hasActivity
      THEN chatman:contains
    WHEN ?external_property = external:nextActivity
      THEN chatman:transitions
    WHEN ?external_property = external:flows
      THEN chatman:transitions

    # Properties to preserve as-is
    WHEN ?external_property = rdf:type
      THEN rdf:type
    WHEN ?external_property = rdfs:label
      THEN rdfs:label
    WHEN ?external_property = rdfs:comment
      THEN rdfs:comment

    # Fallback: namespace-based URI transformation
    ELSE IRI(CONCAT(
      "http://chatmangpt.org/property/",
      ENCODE_FOR_URI(STR(?external_property))
    ))
  END AS ?mapped_property)

  # ============================================================================
  # RESOURCE URI MAPPING: Transform external IRI to ChatmanGPT namespace
  # ============================================================================
  # Strategy: Preserve local name, use chatmangpt base URI
  # Input:  external:Org123
  # Output: chatman:Org123
  BIND(IRI(CONCAT(
    "http://chatmangpt.org/id/",
    ENCODE_FOR_URI(STR(?external_resource))
  )) AS ?chatman_resource)

  # Map related resources with same pattern
  BIND(IRI(CONCAT(
    "http://chatmangpt.org/id/",
    ENCODE_FOR_URI(STR(?external_related))
  )) AS ?related_resource)

  # ============================================================================
  # PROVENANCE URIs: Track source and transformation activity
  # ============================================================================
  BIND(IRI(CONCAT(
    "http://chatmangpt.org/activity/import/",
    ENCODE_FOR_URI(STR(?external_resource))
  )) AS ?activity_uri)

  BIND(IRI(CONCAT(
    "http://chatmangpt.org/source/external/",
    ENCODE_FOR_URI(STR(?external_resource))
  )) AS ?source_uri)

  # Timestamp of transformation
  BIND(NOW() AS ?timestamp)

  # ============================================================================
  # FILTERS: Apply business rules and constraints
  # ============================================================================
  # Only map resources with recognized types
  FILTER(BOUND(?chatman_class))

  # Exclude blank nodes (use named resources only)
  FILTER(ISIRI(?external_resource))

  # Exclude certain properties (e.g., internal metadata)
  FILTER(!STRSTARTS(STR(?external_property), "http://example.org/internal/"))

  # Optional: only map resources modified recently
  # FILTER(?modified > "2026-01-01"^^xsd:dateTime)

  # Optional: only map resources in specific namespace
  # FILTER(STRSTARTS(STR(?external_resource), "http://example.org/"))
}

# ============================================================================
# EXECUTION NOTES
# ============================================================================
# 1. This query assumes external ontology is pre-loaded in SPARQL store
# 2. Run via: oxigraph query --data external.ttl construct.rq
# 3. Output will be RDF triples in N-Triples or Turtle format
#
# 4. Class mapping is case-insensitive (CASE statement handles variations)
# 5. Property mapping preserves inverse relationships via separate patterns
# 6. Provenance triples (prov:*) enable audit trail of transformation
# 7. Timestamp uses NOW() for UTC conversion; adjust if needed
# 8. Resource URIs use ENCODE_FOR_URI() to handle special characters
#
# CUSTOMIZATION:
# - Add more WHEN clauses in CASE statements for additional mappings
# - Modify FILTER clauses to apply domain-specific constraints
# - Adjust BIND() URIs to match your namespace conventions
# - Add OPTIONAL patterns for properties that may be missing
# ============================================================================
