@prefix cm: <https://chatmangpt.com/docs/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
# CHATMANGPT DOCUMENTATION ONTOLOGY
#
# Source of truth for all chatmangpt documentation.
# Edit this file, then run: cd docs/ggen && ggen sync
# ============================================================================

# CLASSES
cm:Document a rdfs:Class ;
  rdfs:label "Document" ;
  rdfs:comment "Base documentation entity" .

cm:Tutorial a rdfs:Class ;
  rdfs:subClassOf cm:Document ;
  rdfs:label "Tutorial" ;
  rdfs:comment "Step-by-step learning (hands-on)" .

cm:HowTo a rdfs:Class ;
  rdfs:subClassOf cm:Document ;
  rdfs:label "How-To Guide" ;
  rdfs:comment "Problem-oriented guide" .

cm:Reference a rdfs:Class ;
  rdfs:subClassOf cm:Document ;
  rdfs:label "Reference" ;
  rdfs:comment "Complete lookup documentation" .

cm:Explanation a rdfs:Class ;
  rdfs:subClassOf cm:Document ;
  rdfs:label "Explanation" ;
  rdfs:comment "Conceptual background and context" .

cm:Spec a rdfs:Class ;
  rdfs:subClassOf cm:Document ;
  rdfs:label "Specification" ;
  rdfs:comment "Design or implementation specification" .

cm:Report a rdfs:Class ;
  rdfs:subClassOf cm:Document ;
  rdfs:label "Report" ;
  rdfs:comment "Generated report or audit output" .

cm:Gap a rdfs:Class ;
  rdfs:label "Documentation Gap" ;
  rdfs:comment "Missing or incomplete documentation" .

cm:Marketing a rdfs:Class ;
  rdfs:subClassOf cm:Document ;
  rdfs:label "Marketing" ;
  rdfs:comment "Go-to-market collateral" .

# PROPERTIES
cm:title a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:string .

cm:description a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:string .

cm:category a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:string .

cm:project a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:string ;
  rdfs:comment "Which project this doc belongs to: BusinessOS, Canopy, OSA, pm4py-rust, knhk, root" .

cm:outputFile a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:string .

cm:estimatedMinutes a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:integer .

cm:difficulty a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:string .

cm:priority a rdf:Property ;
  rdfs:domain cm:Gap ;
  rdfs:range xsd:string .

cm:status a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:string ;
  rdfs:comment "complete, in-progress, draft, stale" .

cm:dateCreated a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:date .

cm:dateUpdated a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:date .

cm:codeRefs a rdf:Property ;
  rdfs:domain cm:Document ;
  rdfs:range xsd:string .

