# Discover Verified Agents from the Public Identity Graph
#
# Returns all verified agents that have at least one admitted capability.
# Each row includes the agent URI, label, count of admitted capabilities,
# and trust score. Results are ordered by trust score descending so that
# the most trusted agents appear first.
#
# Public ontology terms:
#   Agent -> prov:Agent
#   hasCapability -> skos:related
#   admissionStatus -> skos:prefLabel filter on "admitted"
#   trustScore -> dct:hasFormat or numeric annotation

PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>
PREFIX dct:  <http://purl.org/dc/terms/>

SELECT ?agent ?label (COUNT(DISTINCT ?capability) AS ?admittedCapabilityCount) ?trustScore
WHERE {
  # Agent must be a prov:Agent
  ?agent a prov:Agent .

  # Agent must have at least one capability (skos:Concept)
  ?agent skos:related ?capability .
  ?capability a skos:Concept ;
              skos:inScheme <https://chatmangpt.com/ontologies/skos/capabilities> .

  # Only count admitted capabilities (prefLabel = "admitted" on status concept)
  ?capability skos:related ?statusConcept .
  ?statusConcept skos:prefLabel "admitted" .

  # Agent label
  OPTIONAL { ?agent rdfs:label ?label }

  # Trust score on the agent
  OPTIONAL { ?agent dct:hasFormat ?trustScore }
}
GROUP BY ?agent ?label ?trustScore
HAVING (COUNT(DISTINCT ?capability) >= 1)
ORDER BY DESC(xsd:decimal(?trustScore))
