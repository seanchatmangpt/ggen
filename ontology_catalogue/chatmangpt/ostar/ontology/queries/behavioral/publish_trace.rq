# publish_trace.rq -- Insert a behavioral trace with provenance link
#
# Parameterize by replacing BIND values before execution:
#   ?traceId, ?agentUri, ?capabilityUri, ?startedAt, ?completedAt, ?durationMs, ?success
#
# Creates:
#   1. A prov:Activity instance representing the behavioral trace
#   2. A prov:Entity linking the trace to the producing agent
#
# Public ontology terms:
#   BehavioralTrace -> prov:Activity
#   DeviationRecord -> prov:Activity with skos:Concept type
#   producedBy -> prov:wasAssociatedWith
#   invokedCapability -> prov:used
#   startedAt -> prov:startedAtTime
#   completedAt -> prov:endedAtTime
#   durationMs -> prov:generated (with literal)
#   success -> prov:generated (with literal)

PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>
PREFIX dct:  <http://purl.org/dc/terms/>

INSERT DATA {
  # --- Behavioral trace as prov:Activity ---
  <https://chatmangpt.com/traces/trace-?traceId> a prov:Activity ;
      dct:identifier        ?traceId ;
      prov:wasAssociatedWith ?agentUri ;
      prov:used             ?capabilityUri ;
      prov:startedAtTime    ?startedAt ;
      prov:endedAtTime      ?completedAt ;
      dct:extent            ?durationMs ;
      dct:hasVersion        ?success .

  # --- PROV entity for the trace artifact ---
  <https://chatmangpt.com/traces/trace-?traceId> a prov:Entity ;
      prov:wasGeneratedBy <https://chatmangpt.com/traces/activity-?traceId> ;
      prov:wasAttributedTo ?agentUri .

  # --- Activity linking agent to trace ---
  <https://chatmangpt.com/traces/activity-?traceId> a prov:Activity ;
      prov:wasAssociatedWith ?agentUri ;
      prov:generated        <https://chatmangpt.com/traces/trace-?traceId> ;
      prov:startedAtTime    ?startedAt ;
      prov:endedAtTime      ?completedAt .
}
