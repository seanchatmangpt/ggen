# Extract MCP tool argument schemas from the ontology
# Traverses tool-to-argument relationships to return complete parameter schemas
# Used for validation, signature generation, and API documentation
#
# Public ontology terms:
#   Tool -> skos:Concept in capabilities scheme
#   Argument -> skos:Concept related to tool
#   argName -> skos:prefLabel
#   argType -> dct:type
#   description -> skos:definition
#   required -> dct:requires

PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dct:  <http://purl.org/dc/terms/>

SELECT
    ?toolName
    ?argName
    ?argType
    ?argDescription
    ?required
WHERE {
    # Find admitted tools (skos:Concept in capabilities scheme)
    ?tool a skos:Concept ;
          skos:prefLabel ?toolName ;
          skos:inScheme <https://chatmangpt.com/ontologies/skos/capabilities> .

    # Filter to admitted tools
    ?tool skos:related ?statusConcept .
    ?statusConcept skos:prefLabel "admitted" .

    # Traverse to arguments via skos:related
    ?tool skos:related ?arg .

    # Extract argument properties
    ?arg a skos:Concept .
    ?arg skos:prefLabel ?argName .
    ?arg dct:type ?argType .

    # Optional description
    OPTIONAL { ?arg skos:definition ?argDescription }

    # Optional required flag
    OPTIONAL { ?arg dct:requires ?required }
}
ORDER BY ?toolName ?argName
