# SELECT: Check which lawful invariants are NOT preserved across a migration
#
# Takes a migration URI as a parameter and returns every invariant that
# failed validation (invariantPreserved = false).
#
# Parameter: ?migration -- a prov:Activity URI (compound migration)
#
# Public ontology terms:
#   OntologyCompound -> prov:Bundle
#   CompoundMigration -> prov:Activity
#   LawfulInvariant -> prov:Entity with dct:title
#   MigrationValidation -> prov:Entity with dct:description

PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>
PREFIX dct:  <http://purl.org/dc/terms/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT ?invariantName
       ?invariantType
       ?invariantPreserved
       ?validationReport
WHERE {
  # Bind the migration parameter -- replace with a concrete URI
  VALUES ?migration { <https://chatmangpt.com/compounds/migration-placeholder> }

  # Migration must exist (prov:Activity representing compound migration)
  ?migration rdf:type prov:Activity .

  # Walk to the source compound (prov:Bundle) and its invariants
  ?migration prov:used ?sourceCompound .
  ?sourceCompound rdf:type prov:Bundle .
  ?sourceCompound prov:hadMember ?lawfulInvariant .

  # Invariant properties
  ?lawfulInvariant dct:title ?invariantName .
  ?lawfulInvariant dct:type ?invariantType .

  # Validation result linked to this migration and invariant
  ?validation rdf:type prov:Entity ;
             dct:description ?validationReport .
  ?validation prov:wasGeneratedBy ?migration .
  ?validation prov:wasDerivedFrom ?lawfulInvariant .
  ?validation prov:generated ?invariantPreserved .

  # Filter: only show invariants that failed preservation
  FILTER (?invariantPreserved = false)
}
ORDER BY ?invariantType ?invariantName
