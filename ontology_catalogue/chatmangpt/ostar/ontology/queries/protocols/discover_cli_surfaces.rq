
PREFIX proto: <https://chatmangpt.com/ontologies/o-star/protocol:>
PREFIX ostar: <https://chatmangpt.com/ontologies/o-star/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?commandName ?description ?category ?aliases ?argName ?argType ?argRequired ?argDescription
WHERE {
  ?cmd a proto:CliCommand ;
       proto:cliCommandName ?commandName .

  OPTIONAL { ?cmd proto:cliDescription ?description }
  OPTIONAL { ?cmd proto:cliCategory ?category }
  OPTIONAL { ?cmd proto:cliAliases ?aliases }

  OPTIONAL {
    ?cmd proto:hasArgument ?arg .
    ?arg proto:argName ?argName .
    OPTIONAL { ?arg proto:argType ?argType }
    OPTIONAL { ?arg proto:argRequired ?argRequired }
    OPTIONAL { ?arg proto:argDescription ?argDescription }
  }
}
ORDER BY ?commandName
