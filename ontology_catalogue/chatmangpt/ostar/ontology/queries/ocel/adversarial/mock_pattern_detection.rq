PREFIX ocel: <http://www.ocel-standard.org/ocel/2.0/>
PREFIX ostar: <http://ostar.manufactory/schema/>

# Detect mock/stub patterns in OCEL events
# Mock operations have suspicious names or durations

ASK {
  # Check if any event has mock/stub/fake keywords in activity name
  ?event ocel:activity ?activity .
  FILTER (REGEX(?activity, "mock|stub|fake|dummy|test|synthetic", "i"))
}
