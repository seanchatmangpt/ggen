@prefix ggen: <https://ggen.io/onto/ggen/> .
@prefix onto: <https://open-ontologies.io/onto/> .
@prefix : <urn:integration:ggen-onto-law/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .

# ============================================================================
# The Manufacturing Contract
# ============================================================================
# This is the canonical agreement between ggen and open-ontologies:
# ggen ALWAYS loads the ontology, executes SPARQL, renders templates,
# validates artifacts, and emits receipts. No shortcuts.
# ============================================================================

:ManufacturingContract
  a ggen:Contract ;
  rdfs:label "ggen-ontologies Manufacturing Contract" ;
  rdfs:comment "Canonical contract binding ggen pipeline to open-ontologies authority" ;
  ggen:loads [
    a ggen:OntologySource ;
    rdfs:label "CLI Ontology Source" ;
    ggen:graphUri onto:cli-open-ontologies ;
    ggen:format "turtle" ;
    ggen:isRequired true ;
  ] ;
  ggen:executes [
    a ggen:SPARQLQuery ;
    rdfs:label "WASM4PM Stub Interface Extraction" ;
    ggen:queryFile ".specify/queries/extract-wasm4pm-stub-interfaces.rq" ;
    ggen:againstGraph onto:cli-open-ontologies ;
    ggen:produces [
      a ggen:IntermediateFacts ;
      rdfs:label "Extracted Command Interfaces" ;
    ] ;
  ] ;
  ggen:renders [
    a ggen:TemplateStep ;
    rdfs:label "WASM4PM Stub Rendering" ;
    ggen:template ".specify/templates/wasm4pm-stub.rs.tera" ;
    ggen:inputFacts ggen:IntermediateFacts ;
    ggen:outputFile "src/wasm4pm_stub.rs" ;
    ggen:templateLanguage "tera" ;
  ] ;
  ggen:emits [
    a ggen:Artifact ;
    rdfs:label "Generated WASM4PM Stub" ;
    ggen:path "src/wasm4pm_stub.rs" ;
    ggen:mimeType "text/x-rust" ;
    ggen:registersAs onto:wasm4pm-stub-artifact ;
  ] ;
  ggen:produces [
    a ggen:Receipt ;
    rdfs:label "Manufacturing Receipt" ;
    ggen:format "json" ;
    ggen:signature "ed25519" ;
    ggen:registersIn onto:receipt-store ;
    ggen:recordsLineage true ;
  ] .

# ============================================================================
# Validation Contract
# ============================================================================
# All artifacts generated by ggen MUST pass SHACL validation before release.
# Failure halts the pipeline and blocks artifact emission.
# ============================================================================

:ValidationContract
  a onto:ValidationRule ;
  rdfs:label "Artifact Conformance Validation" ;
  rdfs:comment "SHACL shapes enforce artifact correctness before receipt emission" ;
  onto:validates :ManufacturingContract ;
  onto:checks [
    a onto:Constraint ;
    rdfs:label "Artifact Shape Constraint" ;
    onto:type "shacl" ;
    onto:shape onto:ArtifactShape ;
    onto:targetClass onto:Artifact ;
  ] ;
  onto:onFailure [
    a onto:Action ;
    rdfs:label "Block Release on Violation" ;
    onto:actionType onto:BlockRelease ;
    onto:emitViolationReport true ;
    onto:exitCode 1 ;
  ] ;
  onto:onSuccess [
    a onto:Action ;
    rdfs:label "Record Successful Validation" ;
    onto:storeReceipt true ;
    onto:updateLineage true ;
    onto:exitCode 0 ;
  ] .

# ============================================================================
# Cell8 Conformance Gates
# ============================================================================
# Gates A1-A7 are enforced during manufacturing.
# Gates A8-A13 are enforced during witness/attestation phase.
# ============================================================================

:ManufacturingGates
  a onto:GateSequence ;
  rdfs:label "Manufacturing Conformance Gates (A1-A7)" ;
  onto:requiresGate [
    a onto:Gate ;
    rdfs:label "Gate A1: Seed" ;
    onto:gateId "A1" ;
    onto:validates onto:ArtifactState ;
    onto:expectedState onto:seeded ;
  ] ;
  onto:requiresGate [
    a onto:Gate ;
    rdfs:label "Gate A2: Breed" ;
    onto:gateId "A2" ;
    onto:validates onto:RdfFormation ;
  ] ;
  onto:requiresGate [
    a onto:Gate ;
    rdfs:label "Gate A3: Validate" ;
    onto:gateId "A3" ;
    onto:validates onto:ShaclConformance ;
  ] ;
  onto:requiresGate [
    a onto:Gate ;
    rdfs:label "Gate A4: Reason" ;
    onto:gateId "A4" ;
    onto:validates onto:OwlConsistency ;
  ] ;
  onto:requiresGate [
    a onto:Gate ;
    rdfs:label "Gate A5: Prove" ;
    onto:gateId "A5" ;
    onto:validates onto:ReceiptChain ;
  ] ;
  onto:requiresGate [
    a onto:Gate ;
    rdfs:label "Gate A6: Seal" ;
    onto:gateId "A6" ;
    onto:validates onto:CryptographicSignature ;
  ] ;
  onto:requiresGate [
    a onto:Gate ;
    rdfs:label "Gate A7: Emit" ;
    onto:gateId "A7" ;
    onto:validates onto:ArtifactEmission ;
  ] .

# ============================================================================
# Feedback Loop
# ============================================================================
# When the source ontology changes, ggen MUST re-run the entire pipeline
# in audit mode. This ensures artifacts stay in sync with authority.
# ============================================================================

:FeedbackLoop
  a ggen:Trigger ;
  rdfs:label "Ontology-Driven Code Generation Trigger" ;
  rdfs:comment "Automatic pipeline re-run on ontology change" ;
  ggen:watches onto:cli-ontologies-ttl ;
  ggen:watchProperty dct:modified ;
  ggen:onChangeRun ggen:sync ;
  ggen:withMode "audit" ;
  ggen:recordLineage true ;
  ggen:emitReceipt true ;
  ggen:blockOnValidationFailure true .

# ============================================================================
# Authority Hierarchy
# ============================================================================
# The ontology is the single source of truth. Everything else derives from it.
# Templates have zero autonomy — they are law enforcement, not law makers.
# ============================================================================

:AuthorityHierarchy
  a onto:Hierarchy ;
  rdfs:label "ggen-ontologies Authority Hierarchy" ;
  onto:level [
    rdfs:label "Ontology (SOURCE OF TRUTH)" ;
    rdfs:comment "RDF triple facts in ontology/*.ttl files" ;
    onto:levelNumber 1 ;
    onto:authority onto:Absolute ;
    onto:mutable true ;
    onto:requiresValidation true ;
  ] ;
  onto:level [
    rdfs:label "SPARQL Queries (.specify/queries/)" ;
    rdfs:comment "Extract facts from ontology into intermediate RDF" ;
    onto:levelNumber 2 ;
    onto:authority onto:Delegated ;
    onto:mutable true ;
  ] ;
  onto:level [
    rdfs:label "Tera Templates (.specify/templates/)" ;
    rdfs:comment "Render code from SPARQL facts — zero discretion" ;
    onto:levelNumber 3 ;
    onto:authority onto:Enforced ;
    onto:mutable true ;
  ] ;
  onto:level [
    rdfs:label "Generated Artifacts (src/cmds/generated.rs, etc.)" ;
    rdfs:comment "Immutable artifacts — never edited directly" ;
    onto:levelNumber 4 ;
    onto:authority onto:Forbidden ;
    onto:mutable false ;
  ] ;
  onto:level [
    rdfs:label "Receipt (.ggen/receipts/*.json)" ;
    rdfs:comment "Proof object — signature, hashes, lineage" ;
    onto:levelNumber 5 ;
    onto:authority onto:Forbidden ;
    onto:mutable false ;
    onto:signedBy ggen:Ed25519Key ;
  ] .

# ============================================================================
# No Shortcuts Contract
# ============================================================================
# This is the enforcement rule: every step MUST run. No caching, no skipping,
# no "it's just test data". The pipeline is atomic.
# ============================================================================

:NoShortcutsContract
  a onto:Contract ;
  rdfs:label "No Shortcuts: Pipeline Atomicity" ;
  rdfs:comment "ggen MUST run all stages or none. Partial runs are forbidden." ;
  onto:forbidsPattern [
    rdfs:label "Forbidden: Skip SPARQL execution" ;
    onto:pattern "run :ManufacturingContract with ggen:executes = SKIP" ;
    onto:consequence "Artifact lacks authority and cannot be emitted" ;
  ] ;
  onto:forbidsPattern [
    rdfs:label "Forbidden: Skip template rendering" ;
    onto:pattern "run :ManufacturingContract with ggen:renders = SKIP" ;
    onto:consequence "Code generation is incomplete; exit non-zero" ;
  ] ;
  onto:forbidsPattern [
    rdfs:label "Forbidden: Skip SHACL validation" ;
    onto:pattern "run :ManufacturingContract with :ValidationContract = SKIP" ;
    onto:consequence "Artifact violates Cell8 gates; block release" ;
  ] ;
  onto:forbidsPattern [
    rdfs:label "Forbidden: Skip receipt emission" ;
    onto:pattern "run :ManufacturingContract with ggen:produces = SKIP" ;
    onto:consequence "No proof object; artifact is untrusted" ;
  ] ;
  onto:forbidsPattern [
    rdfs:label "Forbidden: Direct template invocation" ;
    onto:pattern "invoke tera directly without ggen orchestration" ;
    onto:consequence "Bypasses ontology load, SPARQL, validation, receipt; forbidden" ;
  ] .

# ============================================================================
# Receipt Invariants
# ============================================================================
# These invariants MUST hold for every receipt emitted by ggen.
# ============================================================================

:ReceiptInvariants
  a onto:InvariantSet ;
  rdfs:label "ggen Receipt Invariants" ;
  onto:invariant [
    rdfs:label "Invariant: Non-empty operation_id" ;
    onto:constraint "receipt.operation_id != empty AND receipt.operation_id matches UUID-v4" ;
    onto:checkTool ggen:receipt-verify ;
  ] ;
  onto:invariant [
    rdfs:label "Invariant: RFC-3339 timestamp" ;
    onto:constraint "receipt.timestamp is valid RFC-3339 datetime" ;
    onto:checkTool ggen:receipt-verify ;
  ] ;
  onto:invariant [
    rdfs:label "Invariant: input_hashes includes all ontology sources" ;
    onto:constraint "receipt.input_hashes keys = { files loaded by :ManufacturingContract }" ;
    onto:checkTool ggen:receipt-verify ;
  ] ;
  onto:invariant [
    rdfs:label "Invariant: output_hashes includes all artifacts" ;
    onto:constraint "receipt.output_hashes keys = { files emitted by :ManufacturingContract }" ;
    onto:checkTool ggen:receipt-verify ;
  ] ;
  onto:invariant [
    rdfs:label "Invariant: Non-empty Ed25519 signature" ;
    onto:constraint "receipt.signature != empty AND signature verifies against public key" ;
    onto:checkTool ggen:receipt-verify ;
  ] ;
  onto:invariant [
    rdfs:label "Invariant: Lineage recorded" ;
    onto:constraint "receipt.lineage event sequence = [ load, query, render, validate, emit, sign ]" ;
    onto:checkTool ggen:receipt-verify ;
  ] .

# ============================================================================
# Definitions
# ============================================================================

onto:cli-ontologies-ttl
  a owl:NamedIndividual ;
  rdfs:label "CLI Ontology File" ;
  rdfs:comment "Primary ontology file: ontology/cli-open-ontologies.ttl" .

dct:modified
  a owl:NamedIndividual ;
  rdfs:label "Modified (Dublin Core)" .

ggen:Ed25519Key
  a owl:Class ;
  rdfs:label "Ed25519 Signing Key" .

ggen:sync
  a ggen:Operation ;
  rdfs:label "Full Pipeline Sync" ;
  rdfs:comment "Load → Query → Render → Validate → Emit → Sign" .

onto:BlockRelease
  a onto:ActionType ;
  rdfs:label "Block Release" ;
  rdfs:comment "Halt pipeline; do not emit artifact or receipt" .

onto:seeded
  a onto:State ;
  rdfs:label "Seeded State" ;
  rdfs:comment "Artifact exists in initial, unprocessed state" .

onto:Artifact
  a owl:Class ;
  rdfs:label "Generated Artifact" ;
  rdfs:comment "Immutable code or data file produced by ggen" .

onto:ArtifactShape
  a owl:NamedIndividual ;
  rdfs:label "SHACL Artifact Validation Shape" .

onto:receipt-store
  a owl:NamedIndividual ;
  rdfs:label "Receipt Storage" ;
  rdfs:comment "Directory where signed receipts are stored" .

onto:Absolute
  a onto:AuthorityLevel ;
  rdfs:label "Absolute Authority" .

onto:Delegated
  a onto:AuthorityLevel ;
  rdfs:label "Delegated Authority" .

onto:Enforced
  a onto:AuthorityLevel ;
  rdfs:label "Enforced Authority (No Discretion)" .

onto:Forbidden
  a onto:AuthorityLevel ;
  rdfs:label "Forbidden to Modify" .
