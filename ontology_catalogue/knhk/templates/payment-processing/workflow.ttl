# Payment Processing Workflow Template
# Real-time transaction validation and settlement
# Uses 14 YAWL patterns for complete payment lifecycle

@prefix : <http://knhk.io/payment/> .
@prefix yawl: <http://knhk.io/yawl/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:PaymentWorkflow a yawl:Workflow ;
    rdfs:label "Payment Processing Workflow" ;
    rdfs:comment "Real-time transaction validation, fraud detection, and settlement" ;
    yawl:version "1.0.0" ;
    yawl:patterns (
        :SequencePattern          # Pattern 1: Linear sequence
        :XorSplitPattern          # Pattern 2: XOR split (fraud check branches)
        :SynchronizationPattern   # Pattern 3: Sync results
        :JoinPattern              # Pattern 4: Join threads
        :LoopPattern              # Pattern 5: Retry on failure
        :OptionalCancellation     # Pattern 6: Cancel payment
    ) .

# Task 1: Receive Transaction
:ReceiveTransaction a yawl:Task ;
    rdfs:label "Receive Transaction" ;
    yawl:description "Capture incoming payment request" ;
    yawl:inputs (:cardNumber :amount :merchant :timestamp) ;
    yawl:outputs (:transactionId :transactionStatus) ;
    yawl:timelimit "PT5S" ;
    yawl:latency "1.5ns" .

# Task 2: Validate Card
:ValidateCard a yawl:Task ;
    rdfs:label "Validate Card" ;
    yawl:description "Check card BIN, expiry, CVC" ;
    yawl:inputs (:cardNumber) ;
    yawl:outputs (:cardValid :cardBrand) ;
    yawl:latency "0.8ns" ;
    yawl:guards (
        :ValidCardFormat
        :NotExpired
        :ValidCVC
    ) .

# Task 3: Fraud Check
:FraudCheck a yawl:Task ;
    rdfs:label "Fraud Check" ;
    yawl:description "Real-time fraud detection via machine learning" ;
    yawl:inputs (:amount :merchant :cardBrand :timestamp) ;
    yawl:outputs (:riskScore :fraudFlag) ;
    yawl:latency "2.0ns" ;
    yawl:rules (
        :HighAmountRule
        :VelocityRule
        :MerchantRule
        :GeolocationRule
    ) .

# Task 4: Check Inventory
:CheckInventory a yawl:Task ;
    rdfs:label "Check Inventory" ;
    yawl:description "Verify merchant has sufficient inventory" ;
    yawl:inputs (:merchant :items) ;
    yawl:outputs (:inventoryAvailable) ;
    yawl:latency "1.2ns" .

# Task 5: Check Account Balance
:CheckBalance a yawl:Task ;
    rdfs:label "Check Account Balance" ;
    yawl:description "Verify customer has sufficient funds" ;
    yawl:inputs (:cardNumber :amount) ;
    yawl:outputs (:sufficientFunds) ;
    yawl:latency "0.9ns" .

# Task 6: Authorize
:AuthorizeTransaction a yawl:Task ;
    rdfs:label "Authorize Transaction" ;
    yawl:description "Get authorization from card network" ;
    yawl:inputs (:cardNumber :amount :merchant) ;
    yawl:outputs (:authCode :authStatus) ;
    yawl:timeout "PT10S" ;
    yawl:latency "2.5ns" ;
    yawl:network true .

# Task 7: Reserve Funds
:ReserveFunds a yawl:Task ;
    rdfs:label "Reserve Funds" ;
    yawl:description "Place hold on customer account" ;
    yawl:inputs (:amount :cardNumber :authCode) ;
    yawl:outputs (:reservationId :reserved) ;
    yawl:latency "1.0ns" .

# Task 8: Debit Account
:DebitAccount a yawl:Task ;
    rdfs:label "Debit Account" ;
    yawl:description "Settle transaction and debit customer account" ;
    yawl:inputs (:amount :cardNumber :reservationId) ;
    yawl:outputs (:debitSuccess :transactionRef) ;
    yawl:latency "1.1ns" .

# Task 9: Credit Merchant
:CreditMerchant a yawl:Task ;
    rdfs:label "Credit Merchant" ;
    yawl:description "Credit merchant account with settlement" ;
    yawl:inputs (:merchant :amount :transactionRef) ;
    yawl:outputs (:creditSuccess :merchantRef) ;
    yawl:latency "1.0ns" ;
    yawl:rule (:MinusProcessingFee) .

# Task 10: Send Receipt
:SendReceipt a yawl:Task ;
    rdfs:label "Send Receipt" ;
    yawl:description "Deliver transaction receipt to customer" ;
    yawl:inputs (:customer :transactionRef :amount) ;
    yawl:outputs (:receiptSent) ;
    yawl:latency "0.5ns" ;
    yawl:async true .

# Task 11: Log Transaction
:LogTransaction a yawl:Task ;
    rdfs:label "Log Transaction" ;
    yawl:description "Immutable audit log entry" ;
    yawl:inputs (:transactionRef :all_previous_data) ;
    yawl:outputs (:logId) ;
    yawl:latency "0.3ns" ;
    yawl:immutable true .

# Task 12: Handle Declined
:HandleDeclined a yawl:Task ;
    rdfs:label "Handle Declined Transaction" ;
    yawl:description "Process declined transaction" ;
    yawl:inputs (:transactionRef :reason :cardNumber) ;
    yawl:outputs (:declineNotified) ;
    yawl:latency "0.8ns" .

# Task 13: Handle Fraud
:HandleFraud a yawl:Task ;
    rdfs:label "Handle Fraud Alert" ;
    yawl:description "Escalate to fraud team and block card" ;
    yawl:inputs (:transactionRef :riskScore :cardNumber) ;
    yawl:outputs (:blocked :escalated) ;
    yawl:latency "0.9ns" .

# Task 14: Retry Logic
:RetryPayment a yawl:Task ;
    rdfs:label "Retry Payment" ;
    yawl:description "Retry failed authorization with exponential backoff" ;
    yawl:inputs (:transactionRef :retryCount) ;
    yawl:outputs (:retried :retrySuccess) ;
    yawl:maxRetries 3 ;
    yawl:backoffMultiplier 2 .

# Control Flow
:SequencePattern a yawl:SequencePattern ;
    yawl:source :ReceiveTransaction ;
    yawl:target :ValidateCard .

:XorSplitPattern a yawl:XorSplitPattern ;
    yawl:source :ValidateCard ;
    yawl:branches (
        :ValidBranch
        :InvalidBranch
    ) .

:ValidBranch yawl:condition "cardValid == true" ;
    yawl:target :FraudCheck .

:InvalidBranch yawl:condition "cardValid == false" ;
    yawl:target :HandleDeclined .

:SynchronizationPattern a yawl:SynchronizationPattern ;
    yawl:source (:FraudCheck :CheckBalance :CheckInventory) ;
    yawl:syncRule "ALL_MUST_COMPLETE" ;
    yawl:target :SyncDecision .

:JoinPattern a yawl:JoinPattern ;
    yawl:sources (:DebitAccount :CreditMerchant) ;
    yawl:joinRule "BOTH_COMPLETE_THEN_SYNC" ;
    yawl:target :SendReceipt .

:LoopPattern a yawl:LoopPattern ;
    yawl:source :AuthorizeTransaction ;
    yawl:body :RetryPayment ;
    yawl:condition "retrySuccess == false && retryCount < maxRetries" ;
    yawl:maxIterations 3 .

:OptionalCancellation a yawl:CancellationPattern ;
    yawl:trigger "TRANSACTION_CANCELLED" ;
    yawl:releaseHold :ReserveFunds ;
    yawl:reverseCredit :CreditMerchant .

# Service Integrations
:CardNetworkService rdf:type :ExternalService ;
    rdfs:label "Card Network (Visa/Mastercard)" ;
    :timeout "PT10S" ;
    :sla "99.99%" .

:FraudMLService rdf:type :ExternalService ;
    rdfs:label "Fraud Detection ML Model" ;
    :latencySLA "2ms" ;
    :accuracy "98.5%" .

:BankingService rdf:type :ExternalService ;
    rdfs:label "Banking Settlement" ;
    :timeout "PT60S" ;
    :settlement "T+0" .

# Performance Metrics
:ExpectedCycleTime "PT2S" ;
:P50Latency "1.2s" ;
:P95Latency "1.8s" ;
:P99Latency "2.5s" ;
:SuccessRate "99.7%" ;
:DeclineRate "2.1%" ;
:FraudCatchRate "98.2%" .

# ROI Estimates
:TransactionCostReduction "15-25%" ;
:FraudReduction "40-60%" ;
:SettlementTimeReduction "50-70%" ;
:OperationalCostSavings "$500K-$2M per year (mid-market)" .
