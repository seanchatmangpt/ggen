# Loan Origination Workflow Template
# 43-step mortgage origination process
# Uses all 43 Van der Aalst YAWL workflow patterns

@prefix : <http://knhk.io/loans/> .
@prefix yawl: <http://knhk.io/yawl/> .

:LoanOriginationWorkflow a yawl:Workflow ;
    rdfs:label "Loan Origination Workflow" ;
    rdfs:comment "Complete 43-step mortgage origination with underwriting, appraisal, funding" ;
    yawl:version "1.0.0" ;
    yawl:patterns 43 .

# Core Workflow Stages

:ApplicationStage a yawl:WorkflowStage ;
    rdfs:label "Application & Pre-Qualification" ;
    yawl:tasks (
        :ReceiveApplication
        :PreQualification
        :DocumentCollection
        :CreditPull
        :IncomeVerification
    ) .

:UnderwritingStage a yawl:WorkflowStage ;
    rdfs:label "Underwriting & Verification" ;
    yawl:tasks (
        :DTICalculation
        :AssetVerification
        :EmploymentVerification
        :CreditAnalysis
        :PolicyCompliance
        :ConditionalApproval
        :ClearConditions
        :FinalApproval
    ) .

:AppraisalStage a yawl:WorkflowStage ;
    rdfs:label "Property Appraisal" ;
    yawl:tasks (
        :OrderAppraisal
        :ReceiveAppraisal
        :AppraisalReview
        :HandleLowAppraisal
    ) .

:ClosingPreparationStage a yawl:WorkflowStage ;
    rdfs:label "Closing Preparation" ;
    yawl:tasks (
        :PrepareClosingDisclosure
        :FinalWalkthrough
        :InsuranceVerification
        :TitleSearch
        :TitleInsurance
        :FinalTitleReview
    ) .

:FundingAndClosingStage a yawl:WorkflowStage ;
    rdfs:label "Funding & Closing" ;
    yawl:tasks (
        :FinalApprovalAfterWalkthrough
        :FundTransfer
        :ClosingMeeting
        :DocumentSigning
        :DocumentRecording
        :FundsDisbursal
        :LoanActivation
        :CustomerNotification
    ) .

# Key Metrics
:ExpectedCycleTime "PT45D" ;
:P50Latency "32 days" ;
:P95Latency "42 days" ;
:P99Latency "55 days" ;
:ApprovalRate "87.5%" ;
:ConditionRate "65%" ;
:DeclineRate "5%" ;
:WithdrawalRate "7.5%" .

# SLA & Compliance
:Regulations (
    :TILA              # Truth in Lending Act
    :ECOA              # Equal Credit Opportunity Act
    :FCRA              # Fair Credit Reporting Act
    :FNMA              # Fannie Mae guidelines
    :FHA               # FHA loan requirements
    :VA                # VA loan requirements
) .

# ROI Estimates
:CycleTimeReduction "20-35% improvement" ;
:CostPerLoan "Reduce from $3,500 to $1,500-$2,000" ;
:OperationalEfficiency "40-50% process automation" ;
:ComplianceImprovement "Automated policy validation" ;
:CustomerSatisfactionGain "CSAT improvement: 15-25%" .

# Integration Points
:IncomeVerificationService rdf:type :ExternalService ;
    rdfs:label "Income Verification (Equifax, USIS)" ;
    :timeout "PT60S" ;
    :reliability "99.5%" .

:AppraisalService rdf:type :ExternalService ;
    rdfs:label "Appraisal Management Company" ;
    :timeout "PT7D" ;
    :average_turnaround "3-5 days" .

:TitleService rdf:type :ExternalService ;
    rdfs:label "Title Search & Insurance Provider" ;
    :timeout "PT10D" ;
    :coverage "All 50 states" .

:FundsTransferService rdf:type :ExternalService ;
    rdfs:label "ACH/Wire Transfer Processing" ;
    :sla "Same-day processing" ;
    :limits "$25M per transaction" .

# Critical Checkpoints
:ApprovalCheckpoint a yawl:DecisionPoint ;
    yawl:rule "Credit > 620 AND DTI < 50% AND LTV < 80%" .

:AppraisalValueCheckpoint a yawl:DecisionPoint ;
    yawl:rule "Appraisal value >= Purchase price OR < Purchase price with buyer approval" .

:FinalApprovalCheckpoint a yawl:DecisionPoint ;
    yawl:rule "All conditions cleared AND appraisal value confirmed AND title clear" .

:ClosingCheckpoint a yawl:DecisionPoint ;
    yawl:rule "Closing disclosure signed AND cashier check received AND title transferred" .
