@prefix insa: <https://w3id.org/insa/ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix field: <https://w3id.org/insa/field/> .

field:ACCESS_BADGE
    a insa:SemanticField ;
    insa:hasFieldId "FIELD-ACCESS-BADGE" ;
    skos:prefLabel "Access Admission Field" ;
    insa:hasPosition [
        insa:hasIndex 0 ;
        insa:hasMask "0b00000001"^^xsd:string ;
        insa:hasMeaning "BADGE_PRESENT" ;
        skos:definition "A badge was presented to the reader."
    ] , [
        insa:hasIndex 1 ;
        insa:hasMask "0b00000010"^^xsd:string ;
        insa:hasMeaning "BADGE_RECOGNIZED" ;
        skos:definition "The presented badge was recognized."
    ] , [
        insa:hasIndex 2 ;
        insa:hasMask "0b00000100"^^xsd:string ;
        insa:hasMeaning "HOLDER_ACTIVE" ;
        skos:definition "The badge holder is active."
    ] , [
        insa:hasIndex 3 ;
        insa:hasMask "0b00001000"^^xsd:string ;
        insa:hasMeaning "DOOR_ALLOWED" ;
        skos:definition "The door is allowed for this holder."
    ] , [
        insa:hasIndex 4 ;
        insa:hasMask "0b00010000"^^xsd:string ;
        insa:hasMeaning "TIME_ALLOWED" ;
        skos:definition "The time is allowed for this access attempt."
    ] , [
        insa:hasIndex 5 ;
        insa:hasMask "0b00100000"^^xsd:string ;
        insa:hasMeaning "GRANTED" ;
        skos:definition "The access attempt has been granted by rule."
    ] , [
        insa:hasIndex 6 ;
        insa:hasMask "0b01000000"^^xsd:string ;
        insa:hasMeaning "RECORDED" ;
        skos:definition "The access attempt has been recorded."
    ] , [
        insa:hasIndex 7 ;
        insa:hasMask "0b10000000"^^xsd:string ;
        insa:hasMeaning "REVIEW_REQUIRED" ;
        skos:definition "The access attempt requires review."
    ] .
