        "attention_span_duration" ;
        "task_switching_frequency" ;
        "stress_indicators" ;
        "fatigue_markers" ;
        "focus_quality_measures"
    ] ;
    cognitive:hasReportingFrequency "real_time" ;
    cognitive:hasAlertThresholds [
        "decision_speed_below_profile" ;
        "attention_span_degradation" ;
        "excessive_task_switching" ;
        "stress_threshold_exceeded" ;
        "focus_quality_deterioration"
    ] .

