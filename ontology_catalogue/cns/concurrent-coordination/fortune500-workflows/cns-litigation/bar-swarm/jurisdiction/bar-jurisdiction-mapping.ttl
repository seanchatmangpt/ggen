@prefix jurisdiction: <http://cns-litigation.org/jurisdiction#> .
@prefix bar: <http://cns-litigation.org/bar#> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix legal: <http://cns-litigation.org/legal#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

# Bar Jurisdiction Mapping Ontology
# Comprehensive mapping of bar disciplinary jurisdictions

jurisdiction:BarJurisdictionOntology a owl:Ontology ;
    rdfs:label "Bar Jurisdiction Mapping System" ;
    rdfs:comment "Comprehensive mapping of bar disciplinary jurisdictions and authorities" ;
    owl:versionInfo "2.0" ;
    owl:created "2025-07-29T22:42:00Z" .

# Top-Level Jurisdiction Classes
jurisdiction:Jurisdiction a owl:Class ;
    rdfs:label "Legal Jurisdiction" ;
    rdfs:comment "Geographic or administrative area with legal authority" .

jurisdiction:StateJurisdiction a owl:Class ;
    rdfs:subClassOf jurisdiction:Jurisdiction ;
    rdfs:label "State Jurisdiction" ;
    rdfs:comment "State-level bar disciplinary jurisdiction" .

jurisdiction:FederalJurisdiction a owl:Class ;
    rdfs:subClassOf jurisdiction:Jurisdiction ;
    rdfs:label "Federal Jurisdiction" ;
    rdfs:comment "Federal bar disciplinary jurisdiction" .

jurisdiction:LocalJurisdiction a owl:Class ;
    rdfs:subClassOf jurisdiction:Jurisdiction ;
    rdfs:label "Local Jurisdiction" ;
    rdfs:comment "Local or municipal bar disciplinary jurisdiction" .

jurisdiction:SpecialtyJurisdiction a owl:Class ;
    rdfs:subClassOf jurisdiction:Jurisdiction ;
    rdfs:label "Specialty Bar Jurisdiction" ;
    rdfs:comment "Specialized practice area bar jurisdiction" .

# State Bar Jurisdictions
jurisdiction:California a jurisdiction:StateJurisdiction ;
    rdfs:label "State Bar of California" ;
    jurisdiction:stateCode "CA" ;
    jurisdiction:barWebsite "https://www.calbar.ca.gov" ;
    jurisdiction:disciplinaryBoard "State Bar Court" ;
    jurisdiction:rulesReference "California Rules of Professional Conduct" ;
    jurisdiction:filingFee "500.00"^^xsd:decimal ;
    jurisdiction:currency "USD" ;
    jurisdiction:timeLimit "4 years" ;
    jurisdiction:contactInfo [
        foaf:phone "+1-415-538-2000" ;
        foaf:mbox "mailto:complaints@calbar.ca.gov" ;
        jurisdiction:address "180 Howard Street, San Francisco, CA 94105"
    ] ;
    geo:lat "37.7749"^^xsd:float ;
    geo:long "-122.4194"^^xsd:float .

