# Salary Expectations and Preferences
profile:SalaryExpectation rdf:type job:CompensationPreference ;
    job:target_base_salary 200000 ;
    job:minimum_base_salary 180000 ;
    job:currency "USD" ;
    job:equity_important true ;
    job:benefits_important true ;
    job:remote_preference "Hybrid" ;
    job:location_preference "Los Angeles Metro" .

# Job Search Criteria for Automation
profile:JobSearchCriteria rdf:type job:SearchCriteria ;
    job:keywords ("Staff Engineer" "Principal Engineer" "React" "Frontend" "Generative AI" "TypeScript") ;
    job:negative_keywords ("Junior" "Entry Level" "Intern") ;
    job:company_size_min 500 ;
    job:funding_stage_min "Series B" ;
    job:exclude_agencies true ;
    job:require_tech_stack ("React" "TypeScript" "JavaScript") ;
    job:preferred_tech_stack ("Node.js" "GraphQL" "Docker" "AI/ML") .

# Automation Preferences
profile:AutomationSettings rdf:type job:AutomationPreference ;
    job:auto_apply false ;
    job:auto_generate_cover_letter true ;
    job:auto_customize_resume true ;
    job:send_daily_digest true ;
    job:linkedin_outreach_enabled true ;
    job:recruiter_response_templates true ;
    job:interview_scheduling_automation true ;
    job:performance_tracking_enabled true .

# BitJob Extension Configuration
profile:ExtensionConfig rdf:type job:ExtensionSettings ;
    job:8space_performance_enabled true ;
    job:real_time_matching true ;
    job:wasm_acceleration true ;
    job:ai_powered_insights true ;
    job:linkedin_integration true ;
    job:indeed_integration true ;
    job:glassdoor_integration true ;
    job:stackoverflow_integration true .