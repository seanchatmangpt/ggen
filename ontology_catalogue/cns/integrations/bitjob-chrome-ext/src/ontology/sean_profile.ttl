@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://www.w3.org/xmlns/foaf/0.1/> .
@prefix job: <http://bitjob.io/ontology#> .
@prefix profile: <http://bitjob.io/profile#> .
@prefix skill: <http://bitjob.io/skills#> .

# BitJob Chrome Extension - Sean Chatman Professional Profile Ontology
# 80/20 Innovation: Complete professional identity in declarative TTL format

<http://bitjob.io/profile/sean-chatman> 
    rdf:type owl:Ontology ;
    rdfs:comment "Sean Chatman's professional profile for intelligent job matching" ;
    owl:versionInfo "2025.1.0" .

# Professional Identity
profile:SeanChatman rdf:type foaf:Person ;
    foaf:name "Sean Chatman" ;
    foaf:email "xpointsh@gmail.com" ;
    foaf:homepage <http://www.linkedin.com/in/seanchatman> ;
    profile:location "Pasadena, California, United States" ;
    profile:availability "Available for Front-End Staff Engineer: React, Typescript, Generative AI" ;
    profile:experience_years 25 ;
    rdfs:comment "Generative AI Front-End Staff Engineer with 25+ years in web development, full-stack architecture, and intelligent systems design" .

# Core Skills with Expertise Levels
