@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ahi: <http://ahi.bitflow.ai/unified#> .
@prefix eight: <http://8space.org/constraints#> .

# BitFlow AHI Unified Knowledge Graph
# Generated by Ontology Weaver v2026.1.1

<http://ahi.bitflow.ai/unified> rdf:type owl:Ontology ;
    rdfs:comment "Unified AHI knowledge graph with integrated domain ontologies" ;
    owl:versionInfo "2026.1.1" ;
    owl:imports <http://bitflow.ai/ahi/core> ;
    owl:imports <http://bitflow.ai/legal/domain> ;
    owl:imports <http://bitflow.ai/market/model> ;
    owl:imports <http://bitflow.ai/coordination/model> ;
    owl:imports <http://bitflow.ai/execution/trace> ;
    eight:compiledAt "$(date -u +%Y-%m-%dT%H:%M:%SZ)" ;
    eight:8spaceCompliant true .

# Integration mappings and cross-domain relationships will be generated here

# === BITFLOW_CORE ONTOLOGY ===


# 8-Space Constraint Classes
eight:EightSpaceConstraint rdf:type owl:Class ;
    rdfs:comment "Base class for all 8-Space constraints" .

eight:TickConstraint rdf:type owl:Class ;
    rdfs:subClassOf eight:EightSpaceConstraint ;
    rdfs:comment "Constraint limiting operations to 8 ticks maximum" .

eight:HopConstraint rdf:type owl:Class ;
    rdfs:subClassOf eight:EightSpaceConstraint ;
    rdfs:comment "Constraint limiting network hops to 8 maximum" .

eight:MemoryConstraint rdf:type owl:Class ;
    rdfs:subClassOf eight:EightSpaceConstraint ;
    rdfs:comment "Constraint limiting memory usage to 8 units" .

# Core AHI Classes with 8-Space Enforcement
ahi:LegalAction rdf:type owl:Class ;
    rdfs:comment "Legal action constrained to 8-Space" ;
    eight:maxTicks 8 ;
    eight:maxHops 8 ;
    eight:maxMemoryUnits 8 ;
    eight:enforcementMode "strict" .

ahi:MarketAction rdf:type owl:Class ;
    rdfs:comment "Market trading action with 8-Space constraints" ;
    eight:maxTicks 8 ;
    eight:maxLatencyMicroseconds 8 ;
    eight:maxNetworkHops 8 ;
    eight:enforcementMode "strict" .

ahi:CoordinationAction rdf:type owl:Class ;
    rdfs:comment "Human-machine coordination action" ;
    eight:maxTicks 8 ;
    eight:maxParallelAgents 8 ;
    eight:maxDecisionLatency 8 ;
    eight:enforcementMode "adaptive" .

# AHI Agent Architecture
ahi:AHIAgent rdf:type owl:Class ;
    rdfs:comment "Autonomous Human Intelligence agent with 8-Space constraints" ;
    eight:maxConcurrentTasks 8 ;
    eight:maxMemoryFootprint 8 ;
    eight:maxNetworkConnections 8 .

ahi:LegalAgent rdf:type owl:Class ;
    rdfs:subClassOf ahi:AHIAgent ;
    rdfs:comment "Specialized agent for legal document processing and filing" ;
    ahi:hasCapability ahi:DocumentGeneration ;
    ahi:hasCapability ahi:FilingAutomation ;
    ahi:hasCapability ahi:JurisdictionMapping .

ahi:MarketAgent rdf:type owl:Class ;
    rdfs:subClassOf ahi:AHIAgent ;
    rdfs:comment "Specialized agent for market analysis and trading" ;
    ahi:hasCapability ahi:MarketAnalysis ;
    ahi:hasCapability ahi:RiskAssessment ;
    ahi:hasCapability ahi:PortfolioOptimization .

ahi:CoordinatorAgent rdf:type owl:Class ;
    rdfs:subClassOf ahi:AHIAgent ;
    rdfs:comment "Agent coordinating human-machine interactions" ;
    ahi:hasCapability ahi:TaskDistribution ;
    ahi:hasCapability ahi:DecisionAggregation ;
    ahi:hasCapability ahi:ConflictResolution .

# Capability Framework
ahi:Capability rdf:type owl:Class ;
    rdfs:comment "Base capability class for AHI agents" ;
    eight:maxExecutionTime 8 ;
    eight:maxResourceConsumption 8 .

ahi:DocumentGeneration rdf:type ahi:Capability ;
    rdfs:comment "Generate legal documents from templates" ;
    ahi:inputFormat "TTL+Templates" ;
    ahi:outputFormat "PDF+Metadata" ;
    eight:maxProcessingTicks 8 .

ahi:FilingAutomation rdf:type ahi:Capability ;
    rdfs:comment "Automate court and regulatory filings" ;
    ahi:supportedJurisdictions ("Nevada" "California" "Federal") ;
    eight:maxFilingLatency 8 .

ahi:JurisdictionMapping rdf:type ahi:Capability ;
    rdfs:comment "Map legal requirements across jurisdictions" ;
    ahi:supportedDomains ("Employment" "IP" "Corporate") ;
    eight:maxMappingComplexity 8 .

ahi:MarketAnalysis rdf:type ahi:Capability ;
    rdfs:comment "Analyze market conditions and trends" ;
    ahi:supportedMarkets ("Equity" "Forex" "Crypto" "Commodities") ;
    eight:maxAnalysisDepth 8 .

ahi:RiskAssessment rdf:type ahi:Capability ;
    rdfs:comment "Assess and quantify investment risks" ;
    ahi:riskMetrics ("VaR" "CVaR" "Sharpe" "Sortino") ;
    eight:maxRiskHorizon 8 .

# Performance and Telemetry Integration
ahi:PerformanceMetric rdf:type owl:Class ;
    rdfs:comment "Performance measurement with OpenTelemetry integration" ;
    otel:traceable true ;
    eight:maxMeasurementLatency 8 .

ahi:ExecutionTrace rdf:type owl:Class ;
    rdfs:comment "Execution trace for audit and compliance" ;
    otel:spanName "ahi_execution" ;
    eight:maxTraceDepth 8 ;
    eight:compressionEnabled true .

# 8-Space Enforcement Properties
eight:maxTicks rdf:type owl:DatatypeProperty ;
    rdfs:domain ahi:AHIAgent ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Maximum ticks allowed for execution" .

eight:maxHops rdf:type owl:DatatypeProperty ;
    rdfs:domain ahi:AHIAgent ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Maximum network hops allowed" .

eight:maxMemoryUnits rdf:type owl:DatatypeProperty ;
    rdfs:domain ahi:AHIAgent ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Maximum memory units consumable" .

eight:enforcementMode rdf:type owl:DatatypeProperty ;
    rdfs:domain ahi:AHIAgent ;
    rdfs:range xsd:string ;
    rdfs:comment "Enforcement mode: strict, adaptive, or monitoring" .

# AHI Specific Properties
ahi:hasCapability rdf:type owl:ObjectProperty ;
    rdfs:domain ahi:AHIAgent ;
    rdfs:range ahi:Capability ;
    rdfs:comment "Agent has specific capability" .

ahi:processingPriority rdf:type owl:DatatypeProperty ;
    rdfs:domain ahi:AHIAgent ;
    rdfs:range xsd:integer ;
    rdfs:comment "Processing priority (1-8, 8 being highest)" .

ahi:currentLoad rdf:type owl:DatatypeProperty ;
    rdfs:domain ahi:AHIAgent ;
    rdfs:range xsd:float ;
    rdfs:comment "Current system load percentage" .

# Compliance and Audit Framework
ahi:ComplianceCheck rdf:type owl:Class ;
    rdfs:comment "Compliance verification with 8-Space constraints" ;
    eight:maxValidationTime 8 ;
    otel:metricsEnabled true .

ahi:AuditTrail rdf:type owl:Class ;
    rdfs:comment "Comprehensive audit trail for all AHI operations" ;
    eight:maxTrailSize 8 ;
    eight:compressionRatio 0.8 ;
    otel:logLevel "INFO" .

# SHACL Constraints for Validation
[] rdf:type sh:NodeShape ;
    sh:targetClass ahi:AHIAgent ;
    sh:property [
        sh:path ahi:processingPriority ;
        sh:minInclusive 1 ;
        sh:maxInclusive 8 ;
        sh:message "Processing priority must be between 1 and 8"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass ahi:LegalAction ;
    sh:property [
        sh:path eight:maxTicks ;
        sh:hasValue 8 ;
        sh:message "Legal actions must respect 8-tick constraint"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass ahi:MarketAction ;
    sh:property [
        sh:path eight:maxHops ;
        sh:maxInclusive 8 ;
        sh:message "Market actions cannot exceed 8 network hops"
    ] .
# === COORDINATION ONTOLOGY ===

    owl:imports <http://yawlsystem.org/ontology> ;
    owl:imports <http://8space.org/constraints> .

# Human Capability Framework
coord:HumanCapability rdf:type owl:Class ;
    rdfs:comment "Human cognitive and operational capabilities" ;
    eight:maxCognitiveLoad 8 ;
    eight:maxSimultaneousTasks 8 ;
    eight:maxDecisionTime 8 .

coord:CognitiveCapability rdf:type owl:Class ;
    rdfs:subClassOf coord:HumanCapability ;
    rdfs:comment "Human cognitive abilities for complex reasoning" ;
    coord:capabilityTypes ("Creative Thinking" "Pattern Recognition" "Ethical Reasoning" "Strategic Planning") ;
    eight:maxComplexity 8 .

coord:OperationalCapability rdf:type owl:Class ;
    rdfs:subClassOf coord:HumanCapability ;
    rdfs:comment "Human operational and execution abilities" ;
    coord:capabilityTypes ("Document Review" "Client Communication" "Negotiation" "Quality Control") ;
    eight:maxWorkloadHours 8 .

coord:DomainExpertise rdf:type owl:Class ;
    rdfs:subClassOf coord:HumanCapability ;
    rdfs:comment "Specialized domain knowledge" ;
    coord:domains ("Legal" "Financial" "Technical" "Regulatory") ;
    coord:experienceYears 8 ;
    eight:maxExpertiseBreadth 8 .

# Machine Capability Framework
coord:MachineCapability rdf:type owl:Class ;
    rdfs:comment "Machine computational and processing capabilities" ;
    eight:maxProcessingPower 8 ;  # cores
    eight:maxMemoryGB 8 ;
    eight:maxThroughput 8 .

coord:ComputationalCapability rdf:type owl:Class ;
    rdfs:subClassOf coord:MachineCapability ;
    rdfs:comment "Machine computational processing abilities" ;
    coord:capabilityTypes ("Data Processing" "Mathematical Calculation" "Pattern Matching" "Optimization") ;
    eight:maxCalculationsPerSecond 8 .

coord:AutomationCapability rdf:type owl:Class ;
    rdfs:subClassOf coord:MachineCapability ;
    rdfs:comment "Machine automation and execution abilities" ;
    coord:capabilityTypes ("Document Generation" "Data Entry" "System Integration" "Process Execution") ;
    eight:maxAutomationDepth 8 .

coord:AnalyticalCapability rdf:type owl:Class ;
    rdfs:subClassOf coord:MachineCapability ;
    rdfs:comment "Machine analytical and intelligence abilities" ;
    coord:capabilityTypes ("Statistical Analysis" "Predictive Modeling" "Risk Assessment" "Trend Analysis") ;
    eight:maxModelComplexity 8 .

# Task Classification and Distribution
coord:Task rdf:type owl:Class ;
    rdfs:comment "Task requiring coordination between human and machine" ;
    eight:maxTaskComplexity 8 ;
    eight:maxExecutionTime 8 ;
    eight:maxSubTasks 8 .

coord:RoutineTask rdf:type owl:Class ;
    rdfs:subClassOf coord:Task ;
    rdfs:comment "Routine task suitable for full machine automation" ;
    coord:automationLevel 1.0 ;
    coord:humanOversight false ;
    eight:maxAutomationLatency 8 .

coord:ComplexTask rdf:type owl:Class ;
    rdfs:subClassOf coord:Task ;
    rdfs:comment "Complex task requiring human-machine collaboration" ;
    coord:automationLevel 0.5 ;
    coord:humanOversight true ;
    eight:maxCollaborationDepth 8 .

coord:CreativeTask rdf:type owl:Class ;
    rdfs:subClassOf coord:Task ;
    rdfs:comment "Creative task requiring human leadership with machine support" ;
    coord:automationLevel 0.2 ;
    coord:humanOversight true ;
    coord:creativityRequired true ;
    eight:maxCreativityIterations 8 .

coord:CriticalTask rdf:type owl:Class ;
    rdfs:subClassOf coord:Task ;
    rdfs:comment "Critical task requiring human final approval" ;
    coord:automationLevel 0.8 ;
    coord:humanOversight true ;
    coord:approvalRequired true ;
    eight:maxApprovalTime 8 .

# Coordination Patterns (YAWL Integration)
coord:CoordinationPattern rdf:type owl:Class ;
    rdfs:subClassOf yawl:WorkflowPattern ;
    rdfs:comment "Human-machine coordination pattern" ;
    eight:maxPatternComplexity 8 ;
    eight:maxCoordinationSteps 8 .

coord:SequentialCoordination rdf:type coord:CoordinationPattern ;
    rdfs:comment "Sequential hand-off between human and machine" ;
    yawl:hasPattern yawl:Sequence ;
    coord:handoffType "sequential" ;
    eight:maxSequenceLength 8 .

coord:ParallelCoordination rdf:type coord:CoordinationPattern ;
    rdfs:comment "Parallel execution with synchronization points" ;
    yawl:hasPattern yawl:ParallelSplit ;
    yawl:hasPattern yawl:Synchronization ;
    coord:syncPoints ("Milestone" "Quality Gate" "Decision Point") ;
    eight:maxParallelBranches 8 .

coord:ConditionalCoordination rdf:type coord:CoordinationPattern ;
    rdfs:comment "Conditional routing based on task complexity or results" ;
    yawl:hasPattern yawl:ExclusiveChoice ;
    yawl:hasPattern yawl:SimpleMerge ;
    coord:decisionCriteria ("Complexity" "Risk Level" "Quality Score" "Time Pressure") ;
    eight:maxConditions 8 .

coord:IterativeCoordination rdf:type coord:CoordinationPattern ;
    rdfs:comment "Iterative refinement between human and machine" ;
    yawl:hasPattern yawl:ArbitraryLoop ;
    coord:maxIterations 8 ;
    coord:convergenceCriteria ("Quality Threshold" "Time Limit" "Resource Constraint") ;
    eight:maxLoopDepth 8 .

# Decision Making Framework
coord:DecisionMaker rdf:type owl:Class ;
    rdfs:comment "Entity responsible for making decisions in coordination" ;
    eight:maxDecisionTime 8 ;
    eight:maxDecisionFactors 8 .

coord:HumanDecisionMaker rdf:type coord:DecisionMaker ;
    rdfs:comment "Human decision maker with contextual judgment" ;
    coord:decisionTypes ("Strategic" "Ethical" "Creative" "Interpersonal") ;
    coord:intuitionWeight 0.4 ;
    coord:experienceWeight 0.6 .

coord:MachineDecisionMaker rdf:type coord:DecisionMaker ;
    rdfs:comment "Machine decision maker with analytical processing" ;
    coord:decisionTypes ("Computational" "Optimization" "Pattern-Based" "Risk-Based") ;
    coord:analyticsWeight 0.8 ;
    coord:dataWeight 0.2 .

coord:HybridDecisionMaker rdf:type coord:DecisionMaker ;
    rdfs:comment "Hybrid human-machine decision making" ;
    coord:humanComponent 0.6 ;
    coord:machineComponent 0.4 ;
    coord:consensusRequired true ;
    eight:maxConsensusTime 8 .

# Priority and Routing Logic
coord:PriorityLevel rdf:type owl:Class ;
    rdfs:comment "Task priority level for routing decisions" ;
    eight:maxPriorityScore 8 .

coord:CriticalPriority rdf:type coord:PriorityLevel ;
    rdfs:comment "Critical priority requiring immediate human attention" ;
    coord:priorityScore 8 ;
    coord:escalationTime 0 ;
    coord:humanRequired true .

coord:HighPriority rdf:type coord:PriorityLevel ;
    rdfs:comment "High priority with expedited processing" ;
    coord:priorityScore 6 ;
    coord:escalationTime 8 ;
    coord:automationAllowed true .

coord:MediumPriority rdf:type coord:PriorityLevel ;
    rdfs:comment "Medium priority with standard processing" ;
    coord:priorityScore 4 ;
    coord:escalationTime 8 ;
    coord:automationPreferred true .

coord:LowPriority rdf:type coord:PriorityLevel ;
    rdfs:comment "Low priority suitable for batch processing" ;
    coord:priorityScore 2 ;
    coord:escalationTime 8 ;
    coord:fullAutomation true .

# Quality Control and Feedback
coord:QualityMetric rdf:type owl:Class ;
    rdfs:comment "Quality measurement for coordination effectiveness" ;
    eight:maxMeasurementTime 8 ;
    otel:traceable true .

coord:AccuracyMetric rdf:type coord:QualityMetric ;
    rdfs:comment "Task execution accuracy measurement" ;
    coord:accuracyThreshold 0.95 ;
    coord:measurementMethod "comparison" ;
    eight:maxSampleSize 8 .

coord:EfficiencyMetric rdf:type coord:QualityMetric ;
    rdfs:comment "Coordination efficiency measurement" ;
    coord:efficiencyThreshold 0.8 ;
    coord:measurementMethod "time_analysis" ;
    eight:maxTimeWindow 8 .  # hours

coord:SatisfactionMetric rdf:type coord:QualityMetric ;
    rdfs:comment "User satisfaction with coordination" ;
    coord:satisfactionThreshold 4.0 ;  # out of 5
    coord:measurementMethod "survey" ;
    eight:maxSurveyQuestions 8 .

# Conflict Resolution Framework
coord:ConflictResolution rdf:type owl:Class ;
    rdfs:comment "Framework for resolving human-machine conflicts" ;
    eight:maxResolutionTime 8 ;
    eight:maxResolutionSteps 8 .

coord:EscalationResolution rdf:type coord:ConflictResolution ;
    rdfs:comment "Escalation to human oversight for conflict resolution" ;
    coord:escalationTriggers ("Quality Failure" "Timeout" "Resource Conflict" "Policy Violation") ;
    coord:escalationLevel ("Supervisor" "Manager" "Executive") ;
    eight:maxEscalationHops 8 .

coord:AutomaticResolution rdf:type coord:ConflictResolution ;
    rdfs:comment "Automatic conflict resolution through predefined rules" ;
    coord:resolutionRules ("Priority Based" "Resource Based" "Historical" "Policy Based") ;
    coord:confidenceThreshold 0.8 ;
    eight:maxRuleComplexity 8 .

# Properties for Coordination Domain
coord:capabilityTypes rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Types of capabilities available" .

coord:automationLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain coord:Task ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Level of automation (0.0 to 1.0)" .

coord:humanOversight rdf:type owl:DatatypeProperty ;
    rdfs:domain coord:Task ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether human oversight is required" .

coord:priorityScore rdf:type owl:DatatypeProperty ;
    rdfs:domain coord:PriorityLevel ;
    rdfs:range xsd:integer ;
    rdfs:comment "Priority score (1-8)" .

coord:escalationTime rdf:type owl:DatatypeProperty ;
    rdfs:domain coord:PriorityLevel ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Time before escalation in milliseconds" .

coord:maxIterations rdf:type owl:DatatypeProperty ;
    rdfs:domain coord:IterativeCoordination ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Maximum iterations allowed" .

# SHACL Validation for Coordination Domain
[] rdf:type sh:NodeShape ;
    sh:targetClass coord:Task ;
    sh:property [
        sh:path eight:maxTaskComplexity ;
        sh:maxInclusive 8 ;
        sh:message "Task complexity limited to 8 under 8-Space constraints"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass coord:CoordinationPattern ;
    sh:property [
        sh:path eight:maxCoordinationSteps ;
        sh:maxInclusive 8 ;
        sh:message "Coordination patterns cannot exceed 8 steps"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass coord:DecisionMaker ;
    sh:property [
        sh:path eight:maxDecisionTime ;
        sh:maxInclusive 8000 ;
        sh:message "Decision time cannot exceed 8000 milliseconds"
    ] .
# === EXECUTION_TRACE ONTOLOGY ===

    owl:imports <http://bitflow.ai/ahi/core> ;
    owl:imports <http://opentelemetry.io/ontology> ;
    owl:imports <http://8space.org/constraints> .

# Core Trace Framework
trace:ExecutionTrace rdf:type owl:Class ;
    rdfs:comment "Comprehensive execution trace with 8-Space constraints" ;
    otel:spanName "ahi_execution_trace" ;
    eight:maxTraceDepth 8 ;
    eight:maxTraceSize 8 ;  # MB
    eight:maxTraceDuration 8 .

trace:TraceSpan rdf:type owl:Class ;
    rdfs:comment "Individual trace span representing a unit of work" ;
    otel:spanId xsd:string ;
    otel:traceId xsd:string ;
    otel:parentSpanId xsd:string ;
    eight:maxSpanDuration 8 ;
    eight:maxSpanAttributes 8 .

trace:TraceEvent rdf:type owl:Class ;
    rdfs:comment "Discrete event within a trace span" ;
    otel:eventName xsd:string ;
    otel:eventTimestamp xsd:dateTime ;
    eight:maxEventSize 8 ;  # KB
    eight:maxEventAttributes 8 .

# Legal Compliance Tracing
trace:LegalTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Legal action execution trace for compliance and audit" ;
    legal:requiresRetention true ;
    legal:retentionPeriod 8 ;
    legal:auditTrail true ;
    eight:maxLegalSteps 8 .

trace:DocumentGenerationTrace rdf:type trace:LegalTrace ;
    rdfs:comment "Trace for legal document generation process" ;
    trace:processSteps ("Template Selection" "Variable Substitution" "Validation" "Formatting" "Signing" "Storage") ;
    trace:requiredMetadata ("Template Version" "User ID" "Timestamp" "Jurisdiction" "Document Type") ;
    eight:maxDocumentSize 8 .  # MB

trace:FilingTrace rdf:type trace:LegalTrace ;
    rdfs:comment "Trace for legal filing process" ;
    trace:filingSteps ("Document Preparation" "Validation" "E-Filing Submission" "Confirmation" "Service" "Archive") ;
    trace:complianceChecks ("Jurisdiction Rules" "Format Requirements" "Fee Calculation" "Deadline Verification") ;
    eight:maxFilingAttempts 8 .

trace:ServiceTrace rdf:type trace:LegalTrace ;
    rdfs:comment "Trace for service of process" ;
    trace:serviceSteps ("Address Verification" "Method Selection" "Execution" "Proof Generation" "Filing") ;
    trace:serviceValidation ("Recipient Identity" "Service Method" "Date/Time" "Server Credentials") ;
    eight:maxServiceAttempts 8 .

# Market Trading Tracing
trace:MarketTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Market trading execution trace for performance and compliance" ;
    market:regulatoryCompliance true ;
    market:best_execution_analysis true ;
    eight:maxTradingLatency 8 ;
    eight:maxOrderModifications 8 .

trace:OrderTrace rdf:type trace:MarketTrace ;
    rdfs:comment "Trace for order execution lifecycle" ;
    trace:orderSteps ("Order Creation" "Risk Check" "Routing" "Execution" "Settlement" "Confirmation") ;
    trace:performanceMetrics ("Latency" "Slippage" "Fill Rate" "Market Impact") ;
    eight:maxOrderLatency 8 .

trace:StrategyTrace rdf:type trace:MarketTrace ;
    rdfs:comment "Trace for trading strategy execution" ;
    trace:strategySteps ("Signal Generation" "Position Sizing" "Risk Assessment" "Order Generation" "Execution" "P&L Update") ;
    trace:strategyMetrics ("Sharpe Ratio" "Max Drawdown" "Win Rate" "Profit Factor") ;
    eight:maxSignalLatency 8 .

trace:RiskTrace rdf:type trace:MarketTrace ;
    rdfs:comment "Trace for risk management operations" ;
    trace:riskSteps ("Exposure Calculation" "Limit Check" "VaR Calculation" "Stress Test" "Alert Generation") ;
    trace:riskMetrics ("Portfolio VaR" "Concentration Risk" "Liquidity Risk" "Operational Risk") ;
    eight:maxRiskCalculationTime 8 .

# Performance Monitoring and Analytics
trace:PerformanceTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Performance monitoring trace with 8-Space metrics" ;
    otel:metricsEnabled true ;
    eight:maxMetricsCount 8 ;
    eight:maxSamplingRate 8 .

trace:LatencyTrace rdf:type trace:PerformanceTrace ;
    rdfs:comment "Latency measurement and analysis" ;
    trace:latencyTypes ("Network" "Processing" "I/O" "Serialization") ;
    trace:latencyPercentiles ("P50" "P95" "P99" "P99.9") ;
    eight:maxLatencyMicroseconds 8 .

trace:ThroughputTrace rdf:type trace:PerformanceTrace ;
    rdfs:comment "Throughput measurement and analysis" ;
    trace:throughputMetrics ("Requests/sec" "Messages/sec" "Bytes/sec" "Operations/sec") ;
    trace:throughputWindows ("1s" "5s" "30s" "5m") ;
    eight:maxThroughput 8 .

trace:ResourceTrace rdf:type trace:PerformanceTrace ;
    rdfs:comment "Resource utilization measurement" ;
    trace:resourceTypes ("CPU" "Memory" "Disk" "Network") ;
    trace:utilizationThresholds ("CPU: 0.8" "Memory: 0.8" "Disk: 0.8" "Network: 0.8") ;
    eight:maxResourceUtilization 0.8 .

# Error Tracking and Recovery
trace:ErrorTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Error tracking and recovery trace" ;
    eight:maxErrorRecoveryTime 8 ;
    eight:maxRecoveryAttempts 8 .

trace:SystemError rdf:type trace:ErrorTrace ;
    rdfs:comment "System-level error trace" ;
    trace:errorTypes ("Network Error" "Database Error" "Service Unavailable" "Timeout") ;
    trace:errorSeverity ("Critical" "High" "Medium" "Low") ;
    eight:maxErrorEscalationTime 8 .

trace:BusinessError rdf:type trace:ErrorTrace ;
    rdfs:comment "Business logic error trace" ;
    trace:businessErrorTypes ("Validation Failure" "Rule Violation" "Data Inconsistency" "Authorization Failure") ;
    trace:businessImpact ("Revenue" "Compliance" "Customer Experience" "Operational") ;
    eight:maxBusinessImpactScore 8 .

trace:RecoveryTrace rdf:type trace:ErrorTrace ;
    rdfs:comment "Error recovery and remediation trace" ;
    trace:recoveryStrategies ("Retry" "Fallback" "Circuit Breaker" "Manual Intervention") ;
    trace:recoveryMetrics ("Recovery Time" "Success Rate" "Impact Mitigation" "Cost") ;
    eight:maxRecoverySteps 8 .

# Learning and Feedback Integration
trace:LearningTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Learning and feedback trace for continuous improvement" ;
    eight:maxLearningDepth 8 ;
    eight:maxFeedbackLatency 8 .

trace:PatternLearning rdf:type trace:LearningTrace ;
    rdfs:comment "Pattern learning from execution traces" ;
    trace:patternTypes ("Success Patterns" "Failure Patterns" "Performance Patterns" "User Patterns") ;
    trace:learningAlgorithms ("Statistical" "Neural Network" "Decision Tree" "Clustering") ;
    eight:maxPatternComplexity 8 .

trace:FeedbackLoop rdf:type trace:LearningTrace ;
    rdfs:comment "Feedback loop for system improvement" ;
    trace:feedbackSources ("User Feedback" "Performance Metrics" "Error Analysis" "Business Outcomes") ;
    trace:improvementActions ("Parameter Tuning" "Algorithm Update" "Process Change" "Training Data") ;
    eight:maxFeedbackCycles 8 .

# Audit and Compliance Framework
trace:AuditTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Audit trail for compliance and governance" ;
    legal:auditCompliant true ;
    legal:tamperProof true ;
    eight:maxAuditRetention 8 ;  # years
    eight:maxAuditEntries 8 .

trace:ComplianceCheck rdf:type trace:AuditTrace ;
    rdfs:comment "Compliance verification trace" ;
    trace:complianceFrameworks ("SOX" "GDPR" "FINRA" "SEC") ;
    trace:checkResults ("Pass" "Fail" "Warning" "Not Applicable") ;
    eight:maxComplianceCheckTime 8 .

trace:GovernanceTrace rdf:type trace:AuditTrace ;
    rdfs:comment "Governance and policy enforcement trace" ;
    trace:governancePolicies ("Data Privacy" "Risk Management" "Operational" "Financial") ;
    trace:policyViolations ("Minor" "Major" "Critical" "Systemic") ;
    eight:maxPolicyComplexity 8 .

# Properties for Execution Trace Domain
trace:processSteps rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Ordered list of process execution steps" .

trace:requiredMetadata rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Required metadata fields for tracing" .

trace:performanceMetrics rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Performance metrics collected in trace" .

trace:errorTypes rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Types of errors that can occur" .

trace:recoveryStrategies rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Available recovery strategies" .

trace:learningAlgorithms rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Machine learning algorithms used" .

otel:spanId rdf:type owl:DatatypeProperty ;
    rdfs:domain trace:TraceSpan ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique span identifier" .

otel:traceId rdf:type owl:DatatypeProperty ;
    rdfs:domain trace:TraceSpan ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique trace identifier" .

otel:parentSpanId rdf:type owl:DatatypeProperty ;
    rdfs:domain trace:TraceSpan ;
    rdfs:range xsd:string ;
    rdfs:comment "Parent span identifier" .

# SHACL Validation for Execution Trace Domain
[] rdf:type sh:NodeShape ;
    sh:targetClass trace:ExecutionTrace ;
    sh:property [
        sh:path eight:maxTraceDepth ;
        sh:maxInclusive 8 ;
        sh:message "Execution traces limited to depth 8 under 8-Space constraints"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass trace:TraceSpan ;
    sh:property [
        sh:path eight:maxSpanDuration ;
        sh:maxInclusive 8000 ;
        sh:message "Trace spans cannot exceed 8000 milliseconds duration"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass trace:MarketTrace ;
    sh:property [
        sh:path eight:maxTradingLatency ;
        sh:maxInclusive 800 ;
        sh:message "Market traces must maintain sub-800 microsecond latency"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass trace:LegalTrace ;
    sh:property [
        sh:path eight:maxLegalSteps ;
        sh:maxInclusive 8 ;
        sh:message "Legal traces cannot exceed 8 execution steps"
    ] .
# === LEGAL_DOMAIN ONTOLOGY ===


# Jurisdiction Framework
legal:Jurisdiction rdf:type owl:Class ;
    rdfs:comment "Legal jurisdiction with specific filing requirements" ;
    eight:maxProcessingComplexity 8 ;
    eight:maxFilingSteps 8 .

legal:Nevada rdf:type legal:Jurisdiction ;
    rdfs:comment "Nevada state jurisdiction" ;
    legal:filingSystem "Nevada Supreme Court E-Filing" ;
    legal:businessDays ("Monday" "Tuesday" "Wednesday" "Thursday" "Friday") ;
    legal:holidays ("New Year" "Memorial Day" "Independence Day" "Labor Day" "Thanksgiving" "Christmas") ;
    eight:maxFilingLatency 8 .  # 8 time units

legal:California rdf:type legal:Jurisdiction ;
    rdfs:comment "California state jurisdiction" ;
    legal:filingSystem "Cal-eFiling" ;
    legal:requiresServeNotice true ;
    legal:serviceMethods ("Personal" "Certified Mail" "Electronic") ;
    eight:maxServiceTime 8 .  # 8 business days

legal:Federal rdf:type legal:Jurisdiction ;
    rdfs:comment "Federal jurisdiction (multiple districts)" ;
    legal:filingSystem "CM/ECF" ;
    legal:requiresPADUO true ;
    legal:supportedDistricts ("D.Nev" "C.D.Cal" "N.D.Cal" "S.D.Cal") ;
    eight:maxDistrictHops 8 .

# Legal Document Types with 8-Space Constraints
legal:LegalDocument rdf:type owl:Class ;
    rdfs:comment "Base class for legal documents" ;
    eight:maxPageCount 8 ;
    eight:maxAttachments 8 ;
    eight:maxProcessingTime 8 .

legal:MotionToDismiss rdf:type owl:Class ;
    rdfs:subClassOf legal:LegalDocument ;
    rdfs:comment "Motion to dismiss with procedural requirements" ;
    legal:requiredSections ("Caption" "Introduction" "Statement of Facts" "Argument" "Conclusion") ;
    legal:citeFormat "Bluebook" ;
    eight:maxArgumentPoints 8 .

legal:ComplaintFiling rdf:type owl:Class ;
    rdfs:subClassOf legal:LegalDocument ;
    rdfs:comment "Civil complaint filing" ;
    legal:requiredElements ("Jurisdiction" "Parties" "Causes of Action" "Prayer for Relief") ;
    legal:serviceRequired true ;
    eight:maxCausesOfAction 8 .

legal:AnswerFiling rdf:type owl:Class ;
    rdfs:subClassOf legal:LegalDocument ;
    rdfs:comment "Answer to complaint" ;
    legal:responseDeadline 30 ;  # days
    legal:allowedResponses ("Admit" "Deny" "Lack Knowledge") ;
    eight:maxDefenses 8 .

legal:DiscoveryRequest rdf:type owl:Class ;
    rdfs:subClassOf legal:LegalDocument ;
    rdfs:comment "Discovery requests and responses" ;
    legal:discoveryTypes ("Interrogatories" "Requests for Production" "Requests for Admission") ;
    legal:responseDeadline 30 ;
    eight:maxRequests 8 .

# Employment Law Specialization
legal:EmploymentCase rdf:type owl:Class ;
    rdfs:comment "Employment law case with specialized requirements" ;
    legal:caseTypes ("Wrongful Termination" "Discrimination" "Wage Claims" "Misclassification") ;
    legal:requiredNotices ("EEOC" "DFEH" "Labor Commissioner") ;
    eight:maxClaimants 8 .

legal:MisclassificationClaim rdf:type owl:Class ;
    rdfs:subClassOf legal:EmploymentCase ;
    rdfs:comment "Independent contractor misclassification claim" ;
    legal:applicableTests ("ABC Test" "Economic Realities" "Control Test") ;
    legal:evidenceTypes ("Contracts" "Communications" "Work Product" "Financial Records") ;
    eight:maxEvidenceItems 8 .

# Legal Workflow Patterns (YAWL Integration)
legal:LegalWorkflow rdf:type owl:Class ;
    rdfs:subClassOf yawl:Workflow ;
    rdfs:comment "Legal workflow with YAWL pattern integration" ;
    eight:maxWorkflowSteps 8 ;
    eight:maxParallelTasks 8 .

legal:FilingWorkflow rdf:type owl:Class ;
    rdfs:subClassOf legal:LegalWorkflow ;
    rdfs:comment "Document filing workflow with jurisdiction-specific steps" ;
    yawl:hasPattern yawl:Sequence ;
    yawl:hasPattern yawl:ParallelSplit ;
    yawl:hasPattern yawl:Synchronization ;
    legal:workflowSteps ("Document Generation" "Review" "E-Filing" "Service" "Confirmation") .

legal:ServiceWorkflow rdf:type owl:Class ;
    rdfs:subClassOf legal:LegalWorkflow ;
    rdfs:comment "Service of process workflow" ;
    legal:serviceSteps ("Identify Parties" "Select Method" "Execute Service" "File Proof") ;
    eight:maxServiceAttempts 8 .

# Legal Templates and Automation
legal:DocumentTemplate rdf:type owl:Class ;
    rdfs:comment "Legal document template with variable substitution" ;
    legal:templateFormat "TTL+Jinja2" ;
    legal:variableTypes ("Party Names" "Dates" "Amounts" "Legal Standards") ;
    eight:maxVariables 8 .

legal:NevadaMotionTemplate rdf:type legal:DocumentTemplate ;
    rdfs:comment "Motion template for Nevada state court" ;
    legal:applicableRules "NRCP" ;
    legal:templatePath "/templates/nevada/motion.j2" ;
    legal:requiredVariables ("case_number" "judge" "parties" "motion_type") .

legal:CaliforniaComplaintTemplate rdf:type legal:DocumentTemplate ;
    rdfs:comment "Complaint template for California state court" ;
    legal:applicableRules "CCP" ;
    legal:templatePath "/templates/california/complaint.j2" ;
    legal:requiredVariables ("court" "case_type" "damages" "causes_of_action") .

# Service of Process Rules
legal:ServiceRule rdf:type owl:Class ;
    rdfs:comment "Service of process rules by jurisdiction" ;
    eight:maxServiceWindow 8 .  # 8 business days

legal:PersonalService rdf:type legal:ServiceRule ;
    rdfs:comment "Personal service requirements" ;
    legal:validRecipients ("Named Party" "Authorized Agent" "Person in Charge") ;
    legal:proofRequired "Declaration of Service" ;
    eight:maxAttempts 8 .

legal:CertifiedMailService rdf:type legal:ServiceRule ;
    rdfs:comment "Certified mail service" ;
    legal:returnReceiptRequired true ;
    legal:deliveryConfirmation "USPS Tracking" ;
    eight:maxMailingDays 8 .

# Compliance and Audit Framework
legal:ComplianceCheck rdf:type owl:Class ;
    rdfs:comment "Legal compliance verification" ;
    legal:checkTypes ("Jurisdiction" "Service" "Deadlines" "Format") ;
    eight:maxCheckTime 8 .

legal:AuditTrail rdf:type owl:Class ;
    rdfs:comment "Legal audit trail for all filings and actions" ;
    legal:requiredFields ("Timestamp" "Actor" "Action" "Document" "Result") ;
    legal:retentionPeriod 2555 ;  # 7 years in days
    eight:maxTrailDepth 8 .

# Properties for Legal Domain
legal:filingSystem rdf:type owl:DatatypeProperty ;
    rdfs:domain legal:Jurisdiction ;
    rdfs:range xsd:string ;
    rdfs:comment "Electronic filing system used by jurisdiction" .

legal:requiredElements rdf:type owl:DatatypeProperty ;
    rdfs:domain legal:LegalDocument ;
    rdfs:range rdf:List ;
    rdfs:comment "Required elements for document validity" .

legal:responseDeadline rdf:type owl:DatatypeProperty ;
    rdfs:domain legal:LegalDocument ;
    rdfs:range xsd:nonNegativeInteger ;
    rdfs:comment "Response deadline in days" .

legal:caseTypes rdf:type owl:DatatypeProperty ;
    rdfs:domain legal:EmploymentCase ;
    rdfs:range rdf:List ;
    rdfs:comment "Supported employment case types" .

legal:serviceRequired rdf:type owl:DatatypeProperty ;
    rdfs:domain legal:LegalDocument ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Whether document requires service of process" .

legal:templatePath rdf:type owl:DatatypeProperty ;
    rdfs:domain legal:DocumentTemplate ;
    rdfs:range xsd:string ;
    rdfs:comment "File path to document template" .

legal:workflowSteps rdf:type owl:DatatypeProperty ;
    rdfs:domain legal:LegalWorkflow ;
    rdfs:range rdf:List ;
    rdfs:comment "Ordered list of workflow steps" .

# SHACL Validation for Legal Domain
[] rdf:type sh:NodeShape ;
    sh:targetClass legal:LegalDocument ;
    sh:property [
        sh:path eight:maxPageCount ;
        sh:maxInclusive 8 ;
        sh:message "Legal documents limited to 8 pages under 8-Space constraints"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass legal:FilingWorkflow ;
    sh:property [
        sh:path eight:maxWorkflowSteps ;
        sh:hasValue 8 ;
        sh:message "Filing workflows must not exceed 8 steps"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass legal:MisclassificationClaim ;
    sh:property [
        sh:path eight:maxEvidenceItems ;
        sh:maxInclusive 8 ;
        sh:message "Evidence items limited to 8 under 8-Space constraints"
    ] .
# === MARKET_MODEL ONTOLOGY ===


# Asset Classes and Market Structure
market:AssetClass rdf:type owl:Class ;
    rdfs:comment "Financial asset class with 8-Space trading constraints" ;
    eight:maxPositions 8 ;
    eight:maxLatencyMicroseconds 8 ;
    eight:maxOrderDepth 8 .

market:Equity rdf:type market:AssetClass ;
    rdfs:comment "Equity securities" ;
    market:tradingVenue ("NYSE" "NASDAQ" "ARCA" "BATS" "IEX" "EDGX" "EDGA" "CHX") ;
    market:tickSize "0.01" ;
    eight:maxOrderSize 8 .  # order units

market:FixedIncome rdf:type market:AssetClass ;
    rdfs:comment "Fixed income securities" ;
    market:tradingVenue ("Treasury Direct" "TRACE" "MarketAxess" "Tradeweb") ;
    market:yieldTypes ("Current" "YTM" "YTC" "YTW") ;
    eight:maxDuration 8.0 .  # years

market:Forex rdf:type market:AssetClass ;
    rdfs:comment "Foreign exchange" ;
    market:majorPairs ("EUR/USD" "GBP/USD" "USD/JPY" "USD/CHF" "AUD/USD" "USD/CAD" "NZD/USD") ;
    market:tradingSession ("Sydney" "Tokyo" "London" "New York") ;
    eight:maxLeverage 8.0 .

market:Cryptocurrency rdf:type market:AssetClass ;
    rdfs:comment "Cryptocurrency assets" ;
    market:exchanges ("Coinbase" "Binance" "Kraken" "Gemini" "Bitstamp") ;
    market:blockchainTypes ("Bitcoin" "Ethereum" "Solana" "Polygon") ;
    eight:maxVolatility 0.8 .  # 80% daily volatility limit

market:Commodities rdf:type market:AssetClass ;
    rdfs:comment "Commodity futures and spots" ;
    market:commodityTypes ("Energy" "Metals" "Agriculture" "Livestock") ;
    market:contractMonths ("H" "M" "U" "Z") ;  # Mar, Jun, Sep, Dec
    eight:maxContractSize 8 .

# Trading Strategies with 8-Space Constraints
market:TradingStrategy rdf:type owl:Class ;
    rdfs:comment "Algorithmic trading strategy" ;
    eight:maxExecutionTime 8 ;
    eight:maxSignalSources 8 ;
    eight:maxPositionSize 8 .

market:MomentumStrategy rdf:type market:TradingStrategy ;
    rdfs:comment "Momentum-based trading strategy" ;
    market:timeframes ("1m" "5m" "15m" "1h" "4h" "1d") ;
    market:indicators ("RSI" "MACD" "Stochastic" "Williams%R") ;
    eight:maxLookbackPeriods 8 .

market:MeanReversionStrategy rdf:type market:TradingStrategy ;
    rdfs:comment "Mean reversion trading strategy" ;
    market:bollinger_periods 20 ;
    market:standard_deviations 2.0 ;
    market:reversion_threshold 0.8 ;
    eight:maxHoldingPeriod 8 .  # hours

market:ArbitrageStrategy rdf:type market:TradingStrategy ;
    rdfs:comment "Statistical arbitrage strategy" ;
    market:correlation_threshold 0.8 ;
    market:spread_threshold 0.08 ;  # 8 basis points
    eight:maxPairCount 8 .

market:MarketMakingStrategy rdf:type market:TradingStrategy ;
    rdfs:comment "Market making with bid-ask spread capture" ;
    market:min_spread 0.0008 ;  # 8 basis points
    market:inventory_target 0.0 ;
    eight:maxQuoteUpdates 8 .

# Risk Management Framework
market:RiskMetric rdf:type owl:Class ;
    rdfs:comment "Risk measurement and management" ;
    eight:maxCalculationTime 8 ;
    eight:maxRiskFactors 8 .

market:VaR rdf:type market:RiskMetric ;
    rdfs:comment "Value at Risk calculation" ;
    market:confidence_level 0.95 ;
    market:time_horizon 1 ;  # day
    eight:maxPortfolioSize 8 .

market:CVaR rdf:type market:RiskMetric ;
    rdfs:comment "Conditional Value at Risk (Expected Shortfall)" ;
    market:confidence_level 0.95 ;
    market:tail_expectation "average" ;
    eight:maxTailSamples 8 .

market:SharpeRatio rdf:type market:RiskMetric ;
    rdfs:comment "Sharpe ratio for risk-adjusted returns" ;
    market:risk_free_rate 0.05 ;  # 5% annual
    market:calculation_period 252 ;  # trading days
    eight:maxObservations 8 .

market:MaxDrawdown rdf:type market:RiskMetric ;
    rdfs:comment "Maximum drawdown measurement" ;
    market:calculation_method "peak-to-trough" ;
    eight:maxDrawdownPeriod 8 .  # months

# Portfolio Optimization
market:PortfolioOptimizer rdf:type owl:Class ;
    rdfs:comment "Portfolio optimization engine with 8-Space constraints" ;
    eight:maxAssets 8 ;
    eight:maxIterations 8 ;
    eight:maxOptimizationTime 8 .

market:MarkowitzOptimizer rdf:type market:PortfolioOptimizer ;
    rdfs:comment "Modern Portfolio Theory optimizer" ;
    market:objective "minimize_variance" ;
    market:constraints ("sum_weights_eq_1" "long_only" "max_weight_0.8") ;
    eight:maxCovarianceSize 8 .

market:BlackLittermanOptimizer rdf:type market:PortfolioOptimizer ;
    rdfs:comment "Black-Litterman portfolio optimization" ;
    market:confidence_level 0.8 ;
    market:tau 0.025 ;
    market:views_uncertainty "proportional" ;
    eight:maxViewCount 8 .

# Market Microstructure and Order Management
market:OrderType rdf:type owl:Class ;
    rdfs:comment "Order types with execution constraints" ;
    eight:maxOrderLifetime 8 ;
    eight:maxModifications 8 .

market:MarketOrder rdf:type market:OrderType ;
    rdfs:comment "Market order for immediate execution" ;
    market:execution_priority "time" ;
    market:slippage_tolerance 0.008 ;  # 80 basis points
    eight:maxFillTime 8 .

market:LimitOrder rdf:type market:OrderType ;
    rdfs:comment "Limit order with price specification" ;
    market:time_in_force ("DAY" "GTC" "IOC" "FOK") ;
    market:price_improvement true ;
    eight:maxPriceLevels 8 .

market:StopOrder rdf:type market:OrderType ;
    rdfs:comment "Stop order for risk management" ;
    market:stop_types ("stop_loss" "take_profit" "trailing_stop") ;
    market:trigger_method "last_price" ;
    eight:maxSlippageTicks 8 .

# Performance Analytics
market:PerformanceMetric rdf:type owl:Class ;
    rdfs:comment "Performance measurement with OpenTelemetry integration" ;
    otel:traceable true ;
    eight:maxCalculationLatency 8 .

market:AlphaGeneration rdf:type market:PerformanceMetric ;
    rdfs:comment "Alpha generation measurement" ;
    market:benchmark "SPY" ;
    market:calculation_method "regression" ;
    eight:maxBenchmarkPeriod 8 .  # years

market:InformationRatio rdf:type market:PerformanceMetric ;
    rdfs:comment "Information ratio calculation" ;
    market:tracking_error_annualized true ;
    eight:maxTrackingPeriod 8 .  # years

# Ultra-High Frequency Trading Components
market:UHFTStrategy rdf:type owl:Class ;
    rdfs:subClassOf market:TradingStrategy ;
    rdfs:comment "Ultra-high frequency trading strategy" ;
    eight:maxLatencyNanoseconds 8 ;
    eight:maxOrdersPerSecond 8 ;
    eight:maxMarketDataFeeds 8 .

market:LatencyOptimization rdf:type owl:Class ;
    rdfs:comment "Latency optimization techniques" ;
    market:techniques ("Kernel Bypass" "FPGA" "Colocation" "Direct Market Access") ;
    eight:maxNetworkHops 8 ;
    eight:targetLatency 8 .

# Market Data and Signal Processing
market:MarketDataFeed rdf:type owl:Class ;
    rdfs:comment "Market data feed with 8-Space processing constraints" ;
    eight:maxUpdateFrequency 8 ;
    eight:maxBufferSize 8 ;
    eight:maxProcessingDelay 8 .

market:Level1Data rdf:type market:MarketDataFeed ;
    rdfs:comment "Level 1 market data (top of book)" ;
    market:data_fields ("bid" "ask" "bid_size" "ask_size" "last" "volume") ;
    eight:maxSymbols 8 .

market:Level2Data rdf:type market:MarketDataFeed ;
    rdfs:comment "Level 2 market data (full depth of book)" ;
    market:depth_levels 10 ;
    eight:maxDepthLevels 8 .

# Properties for Market Domain
market:tradingVenue rdf:type owl:DatatypeProperty ;
    rdfs:domain market:AssetClass ;
    rdfs:range rdf:List ;
    rdfs:comment "Available trading venues" .

market:tickSize rdf:type owl:DatatypeProperty ;
    rdfs:domain market:AssetClass ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Minimum price increment" .

market:timeframes rdf:type owl:DatatypeProperty ;
    rdfs:domain market:TradingStrategy ;
    rdfs:range rdf:List ;
    rdfs:comment "Supported timeframes for strategy" .

market:confidence_level rdf:type owl:DatatypeProperty ;
    rdfs:domain market:RiskMetric ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Statistical confidence level" .

market:objective rdf:type owl:DatatypeProperty ;
    rdfs:domain market:PortfolioOptimizer ;
    rdfs:range xsd:string ;
    rdfs:comment "Optimization objective function" .

market:execution_priority rdf:type owl:DatatypeProperty ;
    rdfs:domain market:OrderType ;
    rdfs:range xsd:string ;
    rdfs:comment "Order execution priority" .

# SHACL Validation for Market Domain
[] rdf:type sh:NodeShape ;
    sh:targetClass market:AssetClass ;
    sh:property [
        sh:path eight:maxPositions ;
        sh:hasValue 8 ;
        sh:message "Asset classes limited to 8 positions under 8-Space constraints"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass market:TradingStrategy ;
    sh:property [
        sh:path eight:maxExecutionTime ;
        sh:maxInclusive 8000 ;
        sh:message "Strategy execution time cannot exceed 8000 microseconds"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass market:PortfolioOptimizer ;
    sh:property [
        sh:path eight:maxAssets ;
        sh:maxInclusive 8 ;
        sh:message "Portfolio optimizers limited to 8 assets under 8-Space"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass market:UHFTStrategy ;
    sh:property [
        sh:path eight:maxLatencyNanoseconds ;
        sh:maxInclusive 800000 ;
        sh:message "UHFT strategies must maintain sub-800 microsecond latency"
    ] .