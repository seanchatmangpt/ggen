@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix trace: <http://bitflow.ai/execution/trace#> .
@prefix eight: <http://8space.org/constraints#> .
@prefix ahi: <http://ahi.bitflow.ai/core#> .
@prefix otel: <http://opentelemetry.io/ontology#> .
@prefix legal: <http://bitflow.ai/legal#> .
@prefix market: <http://bitflow.ai/market#> .

# Execution Trace Ontology - Audit Trail and Performance Metrics
# Based on existing OpenTelemetry patterns and audit frameworks
# Implements comprehensive tracing with 8-Space constraints and compliance requirements

<http://bitflow.ai/execution/trace> rdf:type owl:Ontology ;
    rdfs:comment "Execution trace ontology for audit, compliance, and performance monitoring" ;
    owl:versionInfo "2026.1.1" ;
    owl:imports <http://bitflow.ai/ahi/core> ;
    owl:imports <http://opentelemetry.io/ontology> ;
    owl:imports <http://8space.org/constraints> .

# Core Trace Framework
trace:ExecutionTrace rdf:type owl:Class ;
    rdfs:comment "Comprehensive execution trace with 8-Space constraints" ;
    otel:spanName "ahi_execution_trace" ;
    eight:maxTraceDepth 8 ;
    eight:maxTraceSize 8 ;  # MB
    eight:maxTraceDuration 8 .

trace:TraceSpan rdf:type owl:Class ;
    rdfs:comment "Individual trace span representing a unit of work" ;
    otel:spanId xsd:string ;
    otel:traceId xsd:string ;
    otel:parentSpanId xsd:string ;
    eight:maxSpanDuration 8 ;
    eight:maxSpanAttributes 8 .

trace:TraceEvent rdf:type owl:Class ;
    rdfs:comment "Discrete event within a trace span" ;
    otel:eventName xsd:string ;
    otel:eventTimestamp xsd:dateTime ;
    eight:maxEventSize 8 ;  # KB
    eight:maxEventAttributes 8 .

# Legal Compliance Tracing
trace:LegalTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Legal action execution trace for compliance and audit" ;
    legal:requiresRetention true ;
    legal:retentionPeriod 8 ;
    legal:auditTrail true ;
    eight:maxLegalSteps 8 .

trace:DocumentGenerationTrace rdf:type trace:LegalTrace ;
    rdfs:comment "Trace for legal document generation process" ;
    trace:processSteps ("Template Selection" "Variable Substitution" "Validation" "Formatting" "Signing" "Storage") ;
    trace:requiredMetadata ("Template Version" "User ID" "Timestamp" "Jurisdiction" "Document Type") ;
    eight:maxDocumentSize 8 .  # MB

trace:FilingTrace rdf:type trace:LegalTrace ;
    rdfs:comment "Trace for legal filing process" ;
    trace:filingSteps ("Document Preparation" "Validation" "E-Filing Submission" "Confirmation" "Service" "Archive") ;
    trace:complianceChecks ("Jurisdiction Rules" "Format Requirements" "Fee Calculation" "Deadline Verification") ;
    eight:maxFilingAttempts 8 .

trace:ServiceTrace rdf:type trace:LegalTrace ;
    rdfs:comment "Trace for service of process" ;
    trace:serviceSteps ("Address Verification" "Method Selection" "Execution" "Proof Generation" "Filing") ;
    trace:serviceValidation ("Recipient Identity" "Service Method" "Date/Time" "Server Credentials") ;
    eight:maxServiceAttempts 8 .

# Market Trading Tracing
trace:MarketTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Market trading execution trace for performance and compliance" ;
    market:regulatoryCompliance true ;
    market:best_execution_analysis true ;
    eight:maxTradingLatency 8 ;
    eight:maxOrderModifications 8 .

trace:OrderTrace rdf:type trace:MarketTrace ;
    rdfs:comment "Trace for order execution lifecycle" ;
    trace:orderSteps ("Order Creation" "Risk Check" "Routing" "Execution" "Settlement" "Confirmation") ;
    trace:performanceMetrics ("Latency" "Slippage" "Fill Rate" "Market Impact") ;
    eight:maxOrderLatency 8 .

trace:StrategyTrace rdf:type trace:MarketTrace ;
    rdfs:comment "Trace for trading strategy execution" ;
    trace:strategySteps ("Signal Generation" "Position Sizing" "Risk Assessment" "Order Generation" "Execution" "P&L Update") ;
    trace:strategyMetrics ("Sharpe Ratio" "Max Drawdown" "Win Rate" "Profit Factor") ;
    eight:maxSignalLatency 8 .

trace:RiskTrace rdf:type trace:MarketTrace ;
    rdfs:comment "Trace for risk management operations" ;
    trace:riskSteps ("Exposure Calculation" "Limit Check" "VaR Calculation" "Stress Test" "Alert Generation") ;
    trace:riskMetrics ("Portfolio VaR" "Concentration Risk" "Liquidity Risk" "Operational Risk") ;
    eight:maxRiskCalculationTime 8 .

# Performance Monitoring and Analytics
trace:PerformanceTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Performance monitoring trace with 8-Space metrics" ;
    otel:metricsEnabled true ;
    eight:maxMetricsCount 8 ;
    eight:maxSamplingRate 8 .

trace:LatencyTrace rdf:type trace:PerformanceTrace ;
    rdfs:comment "Latency measurement and analysis" ;
    trace:latencyTypes ("Network" "Processing" "I/O" "Serialization") ;
    trace:latencyPercentiles ("P50" "P95" "P99" "P99.9") ;
    eight:maxLatencyMicroseconds 8 .

trace:ThroughputTrace rdf:type trace:PerformanceTrace ;
    rdfs:comment "Throughput measurement and analysis" ;
    trace:throughputMetrics ("Requests/sec" "Messages/sec" "Bytes/sec" "Operations/sec") ;
    trace:throughputWindows ("1s" "5s" "30s" "5m") ;
    eight:maxThroughput 8 .

trace:ResourceTrace rdf:type trace:PerformanceTrace ;
    rdfs:comment "Resource utilization measurement" ;
    trace:resourceTypes ("CPU" "Memory" "Disk" "Network") ;
    trace:utilizationThresholds ("CPU: 0.8" "Memory: 0.8" "Disk: 0.8" "Network: 0.8") ;
    eight:maxResourceUtilization 0.8 .

# Error Tracking and Recovery
trace:ErrorTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Error tracking and recovery trace" ;
    eight:maxErrorRecoveryTime 8 ;
    eight:maxRecoveryAttempts 8 .

trace:SystemError rdf:type trace:ErrorTrace ;
    rdfs:comment "System-level error trace" ;
    trace:errorTypes ("Network Error" "Database Error" "Service Unavailable" "Timeout") ;
    trace:errorSeverity ("Critical" "High" "Medium" "Low") ;
    eight:maxErrorEscalationTime 8 .

trace:BusinessError rdf:type trace:ErrorTrace ;
    rdfs:comment "Business logic error trace" ;
    trace:businessErrorTypes ("Validation Failure" "Rule Violation" "Data Inconsistency" "Authorization Failure") ;
    trace:businessImpact ("Revenue" "Compliance" "Customer Experience" "Operational") ;
    eight:maxBusinessImpactScore 8 .

trace:RecoveryTrace rdf:type trace:ErrorTrace ;
    rdfs:comment "Error recovery and remediation trace" ;
    trace:recoveryStrategies ("Retry" "Fallback" "Circuit Breaker" "Manual Intervention") ;
    trace:recoveryMetrics ("Recovery Time" "Success Rate" "Impact Mitigation" "Cost") ;
    eight:maxRecoverySteps 8 .

# Learning and Feedback Integration
trace:LearningTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Learning and feedback trace for continuous improvement" ;
    eight:maxLearningDepth 8 ;
    eight:maxFeedbackLatency 8 .

trace:PatternLearning rdf:type trace:LearningTrace ;
    rdfs:comment "Pattern learning from execution traces" ;
    trace:patternTypes ("Success Patterns" "Failure Patterns" "Performance Patterns" "User Patterns") ;
    trace:learningAlgorithms ("Statistical" "Neural Network" "Decision Tree" "Clustering") ;
    eight:maxPatternComplexity 8 .

trace:FeedbackLoop rdf:type trace:LearningTrace ;
    rdfs:comment "Feedback loop for system improvement" ;
    trace:feedbackSources ("User Feedback" "Performance Metrics" "Error Analysis" "Business Outcomes") ;
    trace:improvementActions ("Parameter Tuning" "Algorithm Update" "Process Change" "Training Data") ;
    eight:maxFeedbackCycles 8 .

# Audit and Compliance Framework
trace:AuditTrace rdf:type owl:Class ;
    rdfs:subClassOf trace:ExecutionTrace ;
    rdfs:comment "Audit trail for compliance and governance" ;
    legal:auditCompliant true ;
    legal:tamperProof true ;
    eight:maxAuditRetention 8 ;  # years
    eight:maxAuditEntries 8 .

trace:ComplianceCheck rdf:type trace:AuditTrace ;
    rdfs:comment "Compliance verification trace" ;
    trace:complianceFrameworks ("SOX" "GDPR" "FINRA" "SEC") ;
    trace:checkResults ("Pass" "Fail" "Warning" "Not Applicable") ;
    eight:maxComplianceCheckTime 8 .

trace:GovernanceTrace rdf:type trace:AuditTrace ;
    rdfs:comment "Governance and policy enforcement trace" ;
    trace:governancePolicies ("Data Privacy" "Risk Management" "Operational" "Financial") ;
    trace:policyViolations ("Minor" "Major" "Critical" "Systemic") ;
    eight:maxPolicyComplexity 8 .

# Properties for Execution Trace Domain
trace:processSteps rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Ordered list of process execution steps" .

trace:requiredMetadata rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Required metadata fields for tracing" .

trace:performanceMetrics rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Performance metrics collected in trace" .

trace:errorTypes rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Types of errors that can occur" .

trace:recoveryStrategies rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Available recovery strategies" .

trace:learningAlgorithms rdf:type owl:DatatypeProperty ;
    rdfs:range rdf:List ;
    rdfs:comment "Machine learning algorithms used" .

otel:spanId rdf:type owl:DatatypeProperty ;
    rdfs:domain trace:TraceSpan ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique span identifier" .

otel:traceId rdf:type owl:DatatypeProperty ;
    rdfs:domain trace:TraceSpan ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique trace identifier" .

otel:parentSpanId rdf:type owl:DatatypeProperty ;
    rdfs:domain trace:TraceSpan ;
    rdfs:range xsd:string ;
    rdfs:comment "Parent span identifier" .

# SHACL Validation for Execution Trace Domain
[] rdf:type sh:NodeShape ;
    sh:targetClass trace:ExecutionTrace ;
    sh:property [
        sh:path eight:maxTraceDepth ;
        sh:maxInclusive 8 ;
        sh:message "Execution traces limited to depth 8 under 8-Space constraints"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass trace:TraceSpan ;
    sh:property [
        sh:path eight:maxSpanDuration ;
        sh:maxInclusive 8000 ;
        sh:message "Trace spans cannot exceed 8000 milliseconds duration"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass trace:MarketTrace ;
    sh:property [
        sh:path eight:maxTradingLatency ;
        sh:maxInclusive 800 ;
        sh:message "Market traces must maintain sub-800 microsecond latency"
    ] .

[] rdf:type sh:NodeShape ;
    sh:targetClass trace:LegalTrace ;
    sh:property [
        sh:path eight:maxLegalSteps ;
        sh:maxInclusive 8 ;
        sh:message "Legal traces cannot exceed 8 execution steps"
    ] .