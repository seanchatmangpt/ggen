@prefix ns1: <http://hyperintelligence.ai/patterns#> .
@prefix ns2: <http://cns.io/forex/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://cns.io/forex/reality> a owl:Ontology ;
    rdfs:label "CNS Forex Trading Reality Ontology" ;
    rdfs:comment "Real trading knowledge that actually works end-to-end" .

<http://cns.io/forex/reality#Bloomberg> a ns2:NewsSource ;
    rdfs:label "Bloomberg Terminal" ;
    ns2:averageLatency 50 ;
    ns2:credibilityScore 0.95 ;
    ns2:monthlyCost 2000.0 ;
    ns2:subscription "Active" .

<http://cns.io/forex/reality#CFTCPositionLimit> a ns2:ComplianceRule ;
    rdfs:label "CFTC Position Limits" ;
    ns2:appliesTo <http://cns.io/forex/reality#USD> ;
    ns2:maxPositionSize 500000000.0 ;
    ns2:penaltyForViolation 1000000.0 ;
    ns2:reportingThreshold 50000000.0 .

<http://cns.io/forex/reality#ConservativeRiskProfile> a ns2:RiskProfile ;
    rdfs:label "Conservative Risk Profile" ;
    ns2:maxDrawdown 0.10 ;
    ns2:maxLeverage 10 ;
    ns2:maxPositionSize 500000.0 ;
    ns2:minimumStopDistance 0.0020 ;
    ns2:stopLossRequired true .

<http://cns.io/forex/reality#ECBRateDecision> a ns2:MarketEvent ;
    rdfs:label "ECB Interest Rate Decision" ;
    ns2:affectedPairs <http://cns.io/forex/reality#EUR_GBP>,
        <http://cns.io/forex/reality#EUR_JPY>,
        <http://cns.io/forex/reality#EUR_USD> ;
    ns2:expectedVolatility 150 ;
    ns2:impactLevel "High" ;
    ns2:scheduledTime "2025-07-25T12:45:00+00:00"^^xsd:dateTime .

<http://cns.io/forex/reality#MiFIDTransparency> a ns2:ComplianceRule ;
    rdfs:label "MiFID II Transparency" ;
    ns2:appliesTo <http://cns.io/forex/reality#EUR>,
        <http://cns.io/forex/reality#GBP> ;
    ns2:reportingDeadline "PT15M"^^xsd:duration ;
    ns2:requiresPostTradeReporting true ;
    ns2:requiresPreTradeTransparency true .

<http://cns.io/forex/reality#PatternDayTraderRule> a ns2:ComplianceRule ;
    rdfs:label "Pattern Day Trader Rule" ;
    ns2:appliesIfBalanceBelow 25000.0 ;
    ns2:appliesTo <http://cns.io/forex/reality#USD> ;
    ns2:maxDayTradesPerWeek 3 ;
    ns2:minimumAccountBalance 25000.0 .

<http://cns.io/forex/reality#PositionValidationShape> a sh:NodeShape ;
    sh:property [ sh:message "Position size must be positive" ;
            sh:minExclusive 0.0 ;
            sh:path ns2:size ],
        [ sh:message "Position must have stop loss" ;
            sh:minCount 1 ;
            sh:path ns2:stopLoss ] ;
    sh:targetClass ns2:ActivePosition .

