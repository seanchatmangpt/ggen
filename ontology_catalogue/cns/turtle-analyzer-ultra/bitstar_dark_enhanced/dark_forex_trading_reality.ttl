<http://cns.io/forex/reality#TradingAuthorizationShape> a sh:NodeShape ;
    sh:property [ sh:hasValue "Active" ;
            sh:message "Trader account must be active" ;
            sh:path ns2:accountStatus ],
        [ sh:hasValue "Verified" ;
            sh:message "Trader must have verified compliance" ;
            sh:path ns2:complianceStatus ],
        [ sh:message "Trader must have at least $1000 available margin" ;
            sh:minInclusive 1000.0 ;
            sh:path ns2:availableMargin ] ;
    sh:targetClass ns2:ForexTrader .

