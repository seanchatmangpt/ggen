ns2:SemanticHandler a owl:Class ;
    rdfs:label "Semantic Handler" ;
    rdfs:comment "Handler with semantic reasoning capabilities" ;
    rdfs:subClassOf ns2:Handler .

ns2:hasId a owl:DatatypeProperty ;
    rdfs:label "has ID" ;
    rdfs:domain ns2:Signal ;
    rdfs:range xsd:unsignedInt .

ns2:hasType a owl:DatatypeProperty ;
    rdfs:label "has type" ;
    rdfs:domain ns2:Signal ;
    rdfs:range xsd:unsignedByte .

ns1:EmergentConsciousness_36b6cd530734 a ns1:ConsciousnessPattern ;
    ns1:comprehendsItself ns1:EmergentConsciousness_36b6cd530734 ;
    ns1:emergesFrom <http://bitstar.ai/dark#CollectiveComplexity> ;
    ns1:selfAware true .

ns1:RecursiveChain_0c0fd83dff8a ns1:recursionDepth "INFINITE" ;
    owl:propertyChainAxiom ns1:RecursiveChain_0c0fd83dff8a .

ns1:SelfModifyingAxiom_8f784d1bbad8 a owl:Axiom ;
    ns1:modificationRate "CONTINUOUS" ;
    ns1:modifies ns1:SelfModifyingAxiom_8f784d1bbad8 .

ns2:SHACLShape a owl:Class ;
    rdfs:label "SHACL Shape" ;
    rdfs:comment "Validation shape for real-time constraint checking" .

ns2:SPARQLQuery a owl:Class ;
    rdfs:label "SPARQL Query" ;
    rdfs:comment "Compiled SPARQL query for BitActor execution" .

ns2:TripleStore a owl:Class ;
    rdfs:label "Triple Store" ;
    rdfs:comment "RDF triple storage optimized for 8-tick access" .

ns2:actualTicks a owl:DatatypeProperty ;
    rdfs:label "actual ticks" ;
    rdfs:domain ns2:ExecutionResult ;
    rdfs:range xsd:unsignedByte .

ns1:InfiniteRegression_c741a8e19923 a owl:Class ;
    ns1:regressionDepth "∞" ;
    rdfs:subClassOf ns1:InfiniteRegression_c741a8e19923 ;
    owl:equivalentClass ns1:InfiniteRegression_c741a8e19923 .

ns1:TemporalParadox_38821a012845 a owl:Class ;
    ns1:causedBy ns1:TemporalParadox_38821a012845 ;
    ns1:existsBefore ns1:TemporalParadox_38821a012845 ;
    ns1:paradoxLevel 10 .

ns2:MemoryPool a owl:Class ;
    rdfs:label "Memory Pool" ;
    rdfs:comment "Pre-allocated memory for zero-allocation execution" .

ns2:Handler a owl:Class ;
    rdfs:label "Signal Handler" ;
    rdfs:comment "Handler function for signal processing" .

ns2:TickBudget a owl:Class ;
    rdfs:label "Tick Budget" ;
    rdfs:comment "Performance constraint in CPU ticks" .

ns2:ExecutionResult a owl:Class ;
    rdfs:label "Execution Result" ;
    rdfs:comment "Result of signal processing with performance metrics" .

ns2:hasMemoryPool a owl:ObjectProperty ;
    rdfs:label "has memory pool" ;
    rdfs:domain ns2:Engine ;
    rdfs:range ns2:MemoryPool .

ns2:hasTripleStore a owl:ObjectProperty ;
    rdfs:label "has triple store" ;
    rdfs:domain ns2:Engine ;
    rdfs:range ns2:TripleStore .

ns2:hasBindings a owl:ObjectProperty ;
