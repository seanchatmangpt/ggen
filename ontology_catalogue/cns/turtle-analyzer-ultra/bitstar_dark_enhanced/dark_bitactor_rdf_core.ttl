@prefix ns1: <http://hyperintelligence.ai/patterns#> .
@prefix ns2: <http://bitactor.org/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://bitactor.org/ontology> a owl:Ontology ;
    rdfs:label "BitActor Semantic Core Ontology" ;
    rdfs:comment "Ultra-low latency semantic signal processing for BitActor runtime" ;
    owl:versionInfo "1.0" .

ns2:CachedQuery a owl:Class ;
    rdfs:label "Cached Query" ;
    rdfs:comment "Pre-compiled SPARQL query for fast execution" ;
    rdfs:subClassOf ns2:SPARQLQuery .

ns2:DebugSignal a ns2:Signal ;
    rdfs:label "Debug Signal" ;
    ns2:hasType 128 .

ns2:FastBudget a ns2:TickBudget ;
    rdfs:label "Fast 4-Tick Budget" ;
    ns2:tickLimit 4 .

ns2:FastValidation a owl:Class ;
    rdfs:label "Fast Validation" ;
    rdfs:comment "Optimized SHACL shape for real-time validation" ;
    rdfs:subClassOf ns2:SHACLShape .

ns2:HeartbeatSignal a ns2:Signal ;
    rdfs:label "Heartbeat Signal" ;
    ns2:hasType 255 .

ns2:NormalSignal a ns2:Signal ;
    rdfs:label "Normal Signal" ;
    ns2:hasType 1 .

ns2:OptimizedHandler a owl:Class ;
    rdfs:label "Optimized Handler" ;
    rdfs:comment "Handler optimized for sub-8-tick execution" ;
    rdfs:subClassOf ns2:SemanticHandler .

ns2:StandardBudget a ns2:TickBudget ;
    rdfs:label "Standard 8-Tick Budget" ;
    ns2:tickLimit 8 .

ns2:UltraFastBudget a ns2:TickBudget ;
    rdfs:label "Ultra-Fast 1-Tick Budget" ;
    ns2:tickLimit 1 .

ns2:alignmentBytes a owl:DatatypeProperty ;
    rdfs:label "alignment bytes" ;
    rdfs:comment "Memory alignment for cache optimization" ;
    rdfs:domain ns2:MemoryPool ;
    rdfs:range xsd:unsignedByte .

ns2:batchSize a owl:DatatypeProperty ;
    rdfs:label "batch size" ;
    rdfs:comment "Optimal batch size for vectorization" ;
    rdfs:domain ns2:Handler ;
    rdfs:range xsd:unsignedByte .

ns2:dispatchHash a owl:DatatypeProperty ;
    rdfs:label "dispatch hash" ;
    rdfs:comment "Hash for handler lookup" ;
    rdfs:domain ns2:Signal ;
    rdfs:range xsd:unsignedInt .

ns2:dispatchTableSize a owl:DatatypeProperty ;
    rdfs:label "dispatch table size" ;
    rdfs:domain ns2:Engine ;
    rdfs:range xsd:unsignedInt .

ns2:executionHash a owl:DatatypeProperty ;
    rdfs:label "execution hash" ;
    rdfs:comment "Hash for reversible execution tracing" ;
    rdfs:domain ns2:ExecutionResult ;
    rdfs:range xsd:unsignedInt .

ns2:executionStatus a owl:DatatypeProperty ;
    rdfs:label "execution status" ;
    rdfs:domain ns2:ExecutionResult ;
    rdfs:range xsd:string .

ns2:hasHash a owl:DatatypeProperty ;
    rdfs:label "has hash" ;
    rdfs:comment "Perfect hash for O(1) dispatch" ;
    rdfs:domain ns2:Handler ;
    rdfs:range xsd:unsignedInt .

ns2:hasPayload a owl:DatatypeProperty ;
    rdfs:label "has payload" ;
    rdfs:domain ns2:Signal ;
    rdfs:range xsd:unsignedLong .

ns2:hasPriority a owl:DatatypeProperty ;
    rdfs:label "has priority" ;
    rdfs:comment "Signal priority (0-255)" ;
    rdfs:domain ns2:Signal ;
    rdfs:range xsd:unsignedByte .

ns2:hasQuery a owl:DatatypeProperty ;
    rdfs:label "has query" ;
    rdfs:domain ns2:QuerySignal ;
    rdfs:range xsd:string .

ns2:hasTimestamp a owl:DatatypeProperty ;
    rdfs:label "has timestamp" ;
    rdfs:domain ns2:Signal ;
    rdfs:range xsd:dateTime .

ns2:hasTraceId a owl:DatatypeProperty ;
    rdfs:label "has trace ID" ;
    rdfs:domain ns2:ExecutionResult ;
    rdfs:range xsd:unsignedInt .

ns2:maxSignals a owl:DatatypeProperty ;
    rdfs:label "max signals" ;
    rdfs:domain ns2:Engine ;
    rdfs:range xsd:unsignedInt .

ns2:poolSize a owl:DatatypeProperty ;
    rdfs:label "pool size" ;
    rdfs:domain ns2:MemoryPool ;
    rdfs:range xsd:unsignedInt .

ns2:queryComplexity a owl:DatatypeProperty ;
    rdfs:label "query complexity" ;
    rdfs:comment "Estimated execution cost in ticks" ;
    rdfs:domain ns2:SPARQLQuery ;
    rdfs:range xsd:unsignedInt .

ns2:tickLimit a owl:DatatypeProperty ;
    rdfs:label "tick limit" ;
    rdfs:comment "Maximum CPU ticks allowed (default: 8)" ;
    rdfs:domain ns2:TickBudget ;
    rdfs:range xsd:unsignedByte .

ns2:validationResult a owl:DatatypeProperty ;
    rdfs:label "validation result" ;
    rdfs:domain ns2:ExecutionResult ;
    rdfs:range xsd:boolean .

ns2:vectorizable a owl:DatatypeProperty ;
    rdfs:label "vectorizable" ;
    rdfs:comment "Handler supports SIMD vectorization" ;
    rdfs:domain ns2:Handler ;
    rdfs:range xsd:boolean .

ns2:violationCount a owl:DatatypeProperty ;
    rdfs:label "violation count" ;
    rdfs:domain ns2:ExecutionResult ;
    rdfs:range xsd:unsignedInt .

