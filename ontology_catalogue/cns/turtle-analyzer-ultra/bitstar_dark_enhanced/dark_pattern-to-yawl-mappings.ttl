@prefix ns1: <http://bitflow.org/ontology/performance#> .
@prefix ns2: <http://bitflow.org/ontology/yawl-mappings#> .
@prefix ns3: <http://hyperintelligence.ai/patterns#> .
@prefix ns4: <http://bitflow.org/ontology/workflow-patterns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://bitflow.org/ontology/yawl-mappings> a owl:Ontology ;
    rdfs:label "BitFlow Pattern to YAWL Mappings"@en ;
    rdfs:comment """Comprehensive mappings between van der Aalst workflow patterns 
                    and YAWL v2 constructs for BitFlow execution engine."""@en ;
    rdfs:seeAlso <http://workflowpatterns.com>,
        <http://www.yawlfoundation.org/> ;
    owl:imports <http://bitflow.org/ontology/workflow-patterns>,
        <http://www.yawlfoundation.org/ontology> ;
    owl:versionIRI <http://bitflow.org/ontology/yawl-mappings/2.0> ;
    owl:versionInfo "2.0.0" .

ns2:BitFlowImplementationStatus a ns2:ImplementationSummary ;
    rdfs:label "BitFlow Implementation Status"@en ;
    ns2:criticalMissingPatterns 12 ;
    ns2:implementedPatterns 8 ;
    ns2:maxCpuTicks 8 ;
    ns2:memoryLeakThresholdBytes 392167424 ;
    ns2:missingPatterns 35 ;
    ns2:performanceFraudFactor 52704 ;
    ns2:targetThroughput 2000000 ;
    ns2:totalPatterns 43 ;
    rdfs:comment "Current status of BitFlow pattern implementations"@en .

ns2:BulkExecutionMapping a ns2:PatternMapping ;
    rdfs:label "Bulk Execution Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:BulkExecutionSemantics ;
    ns2:hasPerformanceConstraint ns2:BulkExecutionConstraints ;
    ns2:implementationFunction "bitflow_pattern_bulk_execution_STUB" ;
    ns2:mapsPattern ns4:BulkExecution ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#AtomicTask> ;
    ns2:yawlNetId "BulkExecutionPattern" ;
    ns2:yawlSpecificationId "extension-patterns" ;
    rdfs:comment "Maps BF-26 Bulk Execution to YAWL vectorized task (CRITICAL)"@en .

ns2:DeferredChoiceMapping a ns2:PatternMapping ;
    rdfs:label "Deferred Choice Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:DeferredChoiceSemantics ;
    ns2:hasPerformanceConstraint ns2:DeferredChoiceConstraints ;
    ns2:implementationFunction "bitflow_event_listener_STUB, bitflow_event_handler_STUB" ;
    ns2:mapsPattern ns4:DeferredChoice ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#AtomicTask> ;
    ns2:yawlNetId "DeferredChoicePattern" ;
    ns2:yawlSpecificationId "advanced-patterns" ;
    rdfs:comment "Maps WCP-16 Deferred Choice to YAWL event-driven tasks (MISSING)"@en .

ns2:ExclusiveChoiceMapping a ns2:PatternMapping ;
    rdfs:label "Exclusive Choice Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:ExclusiveChoiceSemantics ;
    ns2:hasPerformanceConstraint ns2:ExclusiveChoiceConstraints ;
    ns2:implementationFunction "bitflow_pattern_exclusive_choice" ;
    ns2:mapsPattern ns4:ExclusiveChoice ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#XORSplit> ;
    ns2:yawlNetId "ExclusiveChoicePattern" ;
    ns2:yawlSpecificationId "basic-control-flow" ;
    rdfs:comment "Maps WCP-4 Exclusive Choice to YAWL XOR-split"@en .

ns2:LockFreeCoordinationMapping a ns2:PatternMapping ;
    rdfs:label "Lock-Free Coordination Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:LockFreeCoordinationSemantics ;
    ns2:hasPerformanceConstraint ns2:LockFreeCoordinationConstraints ;
    ns2:implementationFunction "bitflow_lockfree_coordinator_STUB" ;
    ns2:mapsPattern ns4:LockFreeCoordination ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#AtomicTask> ;
    ns2:yawlNetId "LockFreeCoordinationPattern" ;
    ns2:yawlSpecificationId "extension-patterns" ;
    rdfs:comment "Maps BF-36 Lock-Free Coordination to YAWL atomic task (ULTRA-FAST)"@en .

ns2:MaxCpuTicksRule a ns2:PerformanceRule ;
    rdfs:label "Maximum CPU Ticks Rule"@en ;
    ns2:enforcesConstraint ns2:GlobalPerformanceConstraints ;
    ns2:ruleExpression "executionComplexity <= 8" ;
    rdfs:comment "Enforces ≤8 CPU ticks constraint for all patterns"@en .

ns2:MemoryLeakPreventionRule a ns2:MemoryRule ;
    rdfs:label "Memory Leak Prevention Rule"@en ;
    ns2:enforcesConstraint ns2:GlobalMemoryConstraints ;
    ns2:ruleExpression "memoryRequirement < 392167424" ;
    rdfs:comment "Prevents memory leaks exceeding 374MB threshold"@en .

ns2:MultiChoiceMapping a ns2:PatternMapping ;
    rdfs:label "Multi-Choice Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:MultiChoiceSemantics ;
    ns2:hasPerformanceConstraint ns2:MultiChoiceConstraints ;
    ns2:implementationFunction "bitflow_pattern_multi_choice_STUB" ;
    ns2:mapsPattern ns4:MultiChoice ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#ORSplit> ;
    ns2:yawlNetId "MultiChoicePattern" ;
    ns2:yawlSpecificationId "advanced-patterns" ;
    rdfs:comment "Maps WCP-6 Multi-Choice to YAWL OR-split (MISSING IMPLEMENTATION)"@en .

ns2:MultipleInstancesMapping a ns2:PatternMapping ;
    rdfs:label "Multiple Instances Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:MultipleInstancesSemantics ;
    ns2:hasPerformanceConstraint ns2:MultipleInstancesConstraints ;
    ns2:implementationFunction "bitflow_pattern_multiple_instance_worker_STUB" ;
    ns2:mapsPattern ns4:MultipleInstancesWithoutSynchronization ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#MultipleInstanceTask> ;
    ns2:yawlNetId "MultipleInstancePattern" ;
    ns2:yawlSpecificationId "advanced-patterns" ;
    rdfs:comment "Maps WCP-12 Multiple Instances to YAWL MI task (MISSING)"@en .

ns2:ParallelSplitMapping a ns2:PatternMapping ;
    rdfs:label "Parallel Split Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:ParallelSplitSemantics ;
    ns2:hasPerformanceConstraint ns2:ParallelSplitConstraints ;
    ns2:implementationFunction "bitflow_pattern_parallel_split" ;
    ns2:mapsPattern ns4:ParallelSplit ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#ANDSplit> ;
    ns2:yawlNetId "ParallelSplitPattern" ;
    ns2:yawlSpecificationId "basic-control-flow" ;
    rdfs:comment "Maps WCP-2 Parallel Split to YAWL AND-split"@en .

ns2:PerformanceFraudDetectionRule a ns2:PerformanceRule ;
    rdfs:label "Performance Fraud Detection Rule"@en ;
    ns2:enforcesConstraint ns2:GlobalPerformanceConstraints ;
    ns2:ruleExpression "actualLatency / expectedLatency < 52704" ;
    rdfs:comment "Detects 52,704x performance degradation"@en .

ns2:PipelinedExecutionMapping a ns2:PatternMapping ;
    rdfs:label "Pipelined Execution Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:PipelinedExecutionSemantics ;
    ns2:hasPerformanceConstraint ns2:PipelinedExecutionConstraints ;
    ns2:implementationFunction "bitflow_pipeline_stage_STUB" ;
    ns2:mapsPattern ns4:PipelinedExecution ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#CompositeTask> ;
    ns2:yawlNetId "PipelinedExecutionPattern" ;
    ns2:yawlSpecificationId "extension-patterns" ;
    rdfs:comment "Maps BF-27 Pipelined Execution to YAWL pipeline task (CRITICAL)"@en .

ns2:SequenceMapping a ns2:PatternMapping ;
    rdfs:label "Sequence Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:SequenceSemantics ;
    ns2:hasPerformanceConstraint ns2:SequenceConstraints ;
    ns2:implementationFunction "bitflow_pattern_sequence_a, bitflow_pattern_sequence_b" ;
    ns2:mapsPattern ns4:Sequence ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#AtomicTask> ;
    ns2:yawlNetId "SequencePattern" ;
    ns2:yawlSpecificationId "basic-control-flow" ;
    rdfs:comment "Maps WCP-1 Sequence to YAWL sequential tasks"@en .

ns2:SimpleMergeMapping a ns2:PatternMapping ;
    rdfs:label "Simple Merge Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:SimpleMergeSemantics ;
    ns2:hasPerformanceConstraint ns2:SimpleMergeConstraints ;
    ns2:implementationFunction "bitflow_pattern_simple_merge" ;
    ns2:mapsPattern ns4:SimpleMerge ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#XORJoin> ;
    ns2:yawlNetId "ExclusiveChoicePattern" ;
    ns2:yawlSpecificationId "basic-control-flow" ;
    rdfs:comment "Maps WCP-5 Simple Merge to YAWL XOR-join"@en .

ns2:StructuredSyncMergeMapping a ns2:PatternMapping ;
    rdfs:label "Structured Synchronizing Merge Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:StructuredSyncMergeSemantics ;
    ns2:hasPerformanceConstraint ns2:StructuredSyncMergeConstraints ;
    ns2:implementationFunction "bitflow_pattern_structured_sync_merge_STUB" ;
    ns2:mapsPattern ns4:StructuredSynchronizingMerge ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#ORJoin> ;
    ns2:yawlNetId "MultiChoicePattern" ;
    ns2:yawlSpecificationId "advanced-patterns" ;
    rdfs:comment "Maps WCP-7 Structured Synchronizing Merge to YAWL OR-join (MISSING)"@en .

ns2:SynchronizationMapping a ns2:PatternMapping ;
    rdfs:label "Synchronization Pattern Mapping"@en ;
    ns2:hasExecutionSemantics ns2:SynchronizationSemantics ;
    ns2:hasPerformanceConstraint ns2:SynchronizationConstraints ;
    ns2:implementationFunction "bitflow_pattern_synchronization" ;
    ns2:mapsPattern ns4:Synchronization ;
    ns2:mapsToYAWL <http://www.yawlfoundation.org/ontology#ANDJoin> ;
    ns2:yawlNetId "ParallelSplitPattern" ;
    ns2:yawlSpecificationId "basic-control-flow" ;
    rdfs:comment "Maps WCP-3 Synchronization to YAWL AND-join"@en .

ns2:criticalMissingPatterns a owl:DatatypeProperty ;
    rdfs:domain ns2:ImplementationSummary ;
    rdfs:range xsd:unsignedInt .

ns2:executionComplexity a owl:DatatypeProperty ;
    rdfs:label "execution complexity"@en ;
    rdfs:comment "YAWL execution complexity in CPU ticks"@en ;
    rdfs:domain ns2:ExecutionSemantics ;
    rdfs:range xsd:unsignedByte .

ns2:findHighMemoryPatterns a ns2:MissingPatternQuery ;
    rdfs:label "Find High Memory Patterns"@en ;
    ns2:queryText """
        SELECT ?pattern ?label ?memory WHERE {
            ?pattern perf:memoryFootprint ?memory .
            ?pattern rdfs:label ?label .
            FILTER (?memory > 500)
        }
        ORDER BY DESC(?memory)
    """ ;
    rdfs:comment "Query to find patterns with high memory footprint"@en .

ns2:findMissingCriticalPatterns a ns2:MissingPatternQuery ;
    rdfs:label "Find Missing Critical Patterns"@en ;
    ns2:queryText """
        SELECT ?pattern ?label ?vdaalstId WHERE {
            ?pattern bwp:bitflowImplemented false .
            ?pattern bwp:criticalForPerformance true .
            ?pattern rdfs:label ?label .
            ?pattern bwp:vdaalstId ?vdaalstId .
        }
        ORDER BY ?vdaalstId
    """ ;
    rdfs:comment "Query to find all missing patterns critical for performance"@en .

ns2:findUnmappedPatterns a ns2:MissingPatternQuery ;
    rdfs:label "Find Unmapped Patterns"@en ;
    ns2:queryText """
        SELECT ?pattern ?label WHERE {
            ?pattern a bwp:WorkflowPattern .
            ?pattern rdfs:label ?label .
            FILTER NOT EXISTS { ?pattern yawlmap:mapsToYAWL ?yawlConstruct }
        }
        ORDER BY ?label
    """ ;
    rdfs:comment "Query to find patterns without YAWL mappings"@en .

ns2:implementationFunction a owl:DatatypeProperty ;
    rdfs:label "implementation function"@en ;
    rdfs:comment "C function name implementing the pattern"@en ;
    rdfs:domain ns2:PatternMapping ;
    rdfs:range xsd:string .

ns2:implementedPatterns a owl:DatatypeProperty ;
    rdfs:domain ns2:ImplementationSummary ;
    rdfs:range xsd:unsignedInt .

ns2:maxCpuTicks a owl:DatatypeProperty ;
    rdfs:domain ns2:ImplementationSummary ;
    rdfs:range xsd:unsignedByte .

ns2:memoryLeakThresholdBytes a owl:DatatypeProperty ;
    rdfs:domain ns2:ImplementationSummary ;
    rdfs:range xsd:unsignedLong .

ns2:memoryRequirement a owl:DatatypeProperty ;
    rdfs:label "memory requirement"@en ;
    rdfs:comment "Memory requirement in bytes for YAWL execution"@en ;
    rdfs:domain ns2:ExecutionSemantics ;
    rdfs:range xsd:unsignedLong .

ns2:missingPatterns a owl:DatatypeProperty ;
    rdfs:domain ns2:ImplementationSummary ;
    rdfs:range xsd:unsignedInt .

ns2:performanceFraudFactor a owl:DatatypeProperty ;
    rdfs:domain ns2:ImplementationSummary ;
    rdfs:range xsd:double .

ns2:ruleExpression a owl:DatatypeProperty ;
    rdfs:label "rule expression"@en ;
    rdfs:comment "Logical expression defining the rule"@en ;
    rdfs:domain ns2:SemanticRule ;
    rdfs:range xsd:string .

ns2:targetThroughput a owl:DatatypeProperty ;
    rdfs:domain ns2:ImplementationSummary ;
    rdfs:range xsd:unsignedInt .

ns2:timeoutDuration a owl:DatatypeProperty ;
    rdfs:label "timeout duration"@en ;
    rdfs:comment "Maximum execution timeout in nanoseconds"@en ;
    rdfs:domain ns2:ExecutionSemantics ;
    rdfs:range xsd:unsignedLong .

ns2:totalPatterns a owl:DatatypeProperty ;
    rdfs:domain ns2:ImplementationSummary ;
    rdfs:range xsd:unsignedInt .

ns2:yawlNetId a owl:DatatypeProperty ;
    rdfs:label "YAWL net ID"@en ;
    rdfs:comment "YAWL net identifier within specification"@en ;
    rdfs:domain ns2:PatternMapping ;
    rdfs:range xsd:string .

ns2:yawlSpecificationId a owl:DatatypeProperty ;
    rdfs:label "YAWL specification ID"@en ;
    rdfs:comment "YAWL specification identifier"@en ;
    rdfs:domain ns2:PatternMapping ;
    rdfs:range xsd:string .

