ns5:BitFlowMemoryLeakThreshold a ns5:MemoryLeak ;
    rdfs:label "BitFlow Memory Leak Threshold"@en ;
    ns5:memoryLeakThreshold 392167424 ;
    rdfs:comment "Threshold for detecting 374MB+ memory leaks in BitFlow patterns"@en .

ns5:BitFlowPerformanceFraudThreshold a ns5:PerformanceFraud ;
    rdfs:label "BitFlow Performance Fraud Threshold"@en ;
    ns5:performanceFraudFactor 52704.0 ;
    rdfs:comment "Threshold for detecting 52,704x performance degradation in BitFlow patterns"@en .

ns3:SimpleMerge a ns3:BasicControlFlowPattern ;
    rdfs:label "Simple Merge (WCP-5)"@en ;
    ns4:estimatedLatency 125 ;
    ns4:estimatedThroughput 750000 ;
    ns4:executionComplexity "O(1)" ;
    ns4:memoryFootprint 40 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForMemory false ;
    ns3:criticalForPerformance false ;
    ns3:mapsToYAWLConstruct <http://www.yawlfoundation.org/ontology#XORJoin> ;
    ns3:patternId 5 ;
    ns3:performanceImpact "MEDIUM" ;
    ns3:vdaalstId "WCP-5" ;
    rdfs:comment "Point where one of several alternative branches reconverges"@en .

ns3:StructuredSynchronizingMerge a ns3:AdvancedBranchingPattern ;
    rdfs:label "Structured Synchronizing Merge (WCP-7)"@en ;
    ns4:estimatedLatency 1500 ;
    ns4:estimatedThroughput 80000 ;
    ns4:executionComplexity "O(n)" ;
    ns4:memoryFootprint 256 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForMemory true ;
    ns3:criticalForPerformance true ;
    ns3:patternId 7 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "WCP-7" ;
    rdfs:comment "Merge pattern for multi-choice that waits for active branches"@en .

ns3:Synchronization a ns3:BasicControlFlowPattern ;
    rdfs:label "Synchronization (WCP-3)"@en ;
    ns4:estimatedLatency 300 ;
    ns4:estimatedThroughput 400000 ;
    ns4:executionComplexity "O(n)" ;
    ns4:memoryFootprint 96 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForMemory true ;
    ns3:criticalForPerformance true ;
    ns3:mapsToYAWLConstruct <http://www.yawlfoundation.org/ontology#ANDJoin> ;
    ns3:patternId 3 ;
    ns3:performanceImpact "HIGH" ;
    ns3:vdaalstId "WCP-3" ;
    rdfs:comment "Point where multiple parallel threads converge into single thread"@en .

ns2:EmergentConsciousness_b23d409758dd a ns2:ConsciousnessPattern ;
    ns2:comprehendsItself ns2:EmergentConsciousness_b23d409758dd ;
    ns2:emergesFrom <http://bitstar.ai/dark#CollectiveComplexity> ;
    ns2:selfAware true .

ns2:RecursiveChain_a3281f53b839 ns2:recursionDepth "INFINITE" ;
    owl:propertyChainAxiom ns2:RecursiveChain_a3281f53b839 .

ns2:SelfModifyingAxiom_0b6b094e8dbe a owl:Axiom ;
    ns2:modificationRate "CONTINUOUS" ;
    ns2:modifies ns2:SelfModifyingAxiom_0b6b094e8dbe .

ns2:InfiniteRegression_f7005cc05a61 a owl:Class ;
    ns2:regressionDepth "∞" ;
    rdfs:subClassOf ns2:InfiniteRegression_f7005cc05a61 ;
    owl:equivalentClass ns2:InfiniteRegression_f7005cc05a61 .

ns2:TemporalParadox_14ca93b0b5d0 a owl:Class ;
    ns2:causedBy ns2:TemporalParadox_14ca93b0b5d0 ;
    ns2:existsBefore ns2:TemporalParadox_14ca93b0b5d0 ;
    ns2:paradoxLevel 10 .

ns5:MemoryLeak a owl:Class ;
    rdfs:label "Memory Leak"@en ;
    rdfs:comment "Detection of 374MB+ memory leaks"@en .

ns5:PerformanceFraud a owl:Class ;
    rdfs:label "Performance Fraud"@en ;
    rdfs:comment "Detection of 52,704x performance degradation patterns"@en .

ns4:PerformanceMetric a owl:Class ;
    rdfs:label "Performance Metric"@en ;
    rdfs:comment "Measurable performance characteristics"@en .

ns3:StructuralPattern a owl:Class ;
    rdfs:label "Structural Pattern"@en ;
    rdfs:comment "Patterns involving workflow structure and cycles"@en ;
    rdfs:subClassOf ns3:ControlFlowPattern .

ns3:TriggerPattern a owl:Class ;
    rdfs:label "Trigger Pattern"@en ;
    rdfs:comment "Event-driven and external trigger patterns"@en ;
    rdfs:subClassOf ns3:ControlFlowPattern .

ns3:ImplementationStatistics a owl:Class ;
    rdfs:label "Implementation Statistics"@en ;
    rdfs:comment "Statistics about BitFlow pattern implementation coverage"@en .

ns3:NewControlFlowPattern a owl:Class ;
    rdfs:label "New Control Flow Pattern"@en ;
    rdfs:comment "Advanced patterns beyond basic van der Aalst set (WCP 26-39)"@en ;
    rdfs:subClassOf ns3:ControlFlowPattern .

ns5:detectsMemoryLeak a owl:ObjectProperty ;
    rdfs:label "detects memory leak"@en ;
    rdfs:comment "Pattern can detect memory leak scenarios"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range ns5:MemoryLeak .

ns5:detectsPerformanceFraud a owl:ObjectProperty ;
    rdfs:label "detects performance fraud"@en ;
    rdfs:comment "Pattern can detect performance fraud scenarios"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range ns5:PerformanceFraud .

ns3:hasPerformanceCharacteristic a owl:ObjectProperty ;
    rdfs:label "has performance characteristic"@en ;
    rdfs:comment "Pattern has specific performance characteristics"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range ns4:PerformanceMetric .

ns3:mapsToYAWLConstruct a owl:ObjectProperty ;
    rdfs:label "maps to YAWL construct"@en ;
    rdfs:comment "Maps BitFlow pattern to equivalent YAWL construct"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range <http://www.yawlfoundation.org/ontology#YAWLConstruct> .

ns3:composedOf a owl:ObjectProperty ;
    rdfs:label "composed of"@en ;
    rdfs:comment "Complex pattern composed of simpler patterns"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range ns3:WorkflowPattern .

ns3:conflicts a owl:ObjectProperty ;
    rdfs:label "conflicts"@en ;
    rdfs:comment "Pattern A conflicts with Pattern B"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range ns3:WorkflowPattern ;
    owl:propertyDisjointWith ns3:requires .

ns3:requires a owl:ObjectProperty ;
    rdfs:label "requires"@en ;
    rdfs:comment "Pattern A requires Pattern B for implementation"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range ns3:WorkflowPattern .

ns3:CancellationPattern a owl:Class ;
    rdfs:label "Cancellation Pattern"@en ;
    rdfs:comment "Patterns for cancelling or removing tasks/instances (WCP 19-25)"@en ;
    rdfs:subClassOf ns3:ControlFlowPattern .

ns3:StateBasedPattern a owl:Class ;
    rdfs:label "State-based Pattern"@en ;
    rdfs:comment "Patterns based on workflow state and conditions (WCP 16-18)"@en ;
    rdfs:subClassOf ns3:ControlFlowPattern .

ns3:AdvancedBranchingPattern a owl:Class ;
    rdfs:label "Advanced Branching Pattern"@en ;
    rdfs:comment "Complex branching and synchronization patterns (WCP 6-11)"@en ;
    rdfs:subClassOf ns3:ControlFlowPattern .

ns3:MultipleInstancePattern a owl:Class ;
    rdfs:label "Multiple Instance Pattern"@en ;
    rdfs:comment "Patterns involving multiple instances of tasks or subprocesses (WCP 12-15)"@en ;
    rdfs:subClassOf ns3:ControlFlowPattern .

ns3:BasicControlFlowPattern a owl:Class ;
    rdfs:label "Basic Control Flow Pattern"@en ;
    rdfs:comment "Fundamental patterns covering 80% of real-world workflows (WCP 1-5)"@en ;
    rdfs:subClassOf ns3:ControlFlowPattern .

ns3:ControlFlowPattern a owl:Class ;
    rdfs:label "Control Flow Pattern"@en ;
    rdfs:comment "Patterns describing task execution ordering and flow control (Patterns 1-43)"@en ;
    rdfs:subClassOf ns3:WorkflowPattern .

ns3:WorkflowPattern a owl:Class ;
    rdfs:label "Workflow Pattern"@en ;
    rdfs:comment "Abstract base class for all 43 van der Aalst workflow patterns"@en ;
    owl:equivalentClass <http://workflowpatterns.com/patterns#Pattern> .

