ns3:bitflowImplemented a owl:DatatypeProperty ;
    rdfs:label "BitFlow implemented"@en ;
    rdfs:comment "Whether pattern is implemented in current BitFlow version"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:boolean .

ns3:criticalForMemory a owl:DatatypeProperty ;
    rdfs:label "critical for memory"@en ;
    rdfs:comment "Whether pattern is critical for preventing 374MB memory leaks"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:boolean .

ns3:criticalForPerformance a owl:DatatypeProperty ;
    rdfs:label "critical for performance"@en ;
    rdfs:comment "Whether pattern is critical for addressing 52,704x performance issues"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:boolean .

ns3:criticalMissingPatterns a owl:DatatypeProperty ;
    rdfs:label "critical missing patterns"@en ;
    rdfs:domain ns3:ImplementationStatistics ;
    rdfs:range xsd:int .

ns3:highPerformanceImpactMissingPatterns a owl:DatatypeProperty ;
    rdfs:label "high performance impact missing patterns"@en ;
    rdfs:domain ns3:ImplementationStatistics ;
    rdfs:range xsd:int .

ns3:implementationPercentage a owl:DatatypeProperty ;
    rdfs:label "implementation percentage"@en ;
    rdfs:domain ns3:ImplementationStatistics ;
    rdfs:range xsd:double .

ns3:implementedPatterns a owl:DatatypeProperty ;
    rdfs:label "implemented patterns"@en ;
    rdfs:domain ns3:ImplementationStatistics ;
    rdfs:range xsd:int .

ns3:missingPatterns a owl:DatatypeProperty ;
    rdfs:label "missing patterns"@en ;
    rdfs:domain ns3:ImplementationStatistics ;
    rdfs:range xsd:int .

ns3:patternId a owl:DatatypeProperty ;
    rdfs:label "pattern ID"@en ;
    rdfs:comment "Numeric identifier for pattern (1-43)"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:int .

ns3:performanceImpact a owl:DatatypeProperty ;
    rdfs:label "performance impact"@en ;
    rdfs:comment "Level of performance impact (LOW, MEDIUM, HIGH, CRITICAL)"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range [ owl:oneOf ( "LOW" "MEDIUM" "HIGH" "CRITICAL" ) ] .

ns3:totalPatterns a owl:DatatypeProperty ;
    rdfs:label "total patterns"@en ;
    rdfs:domain ns3:ImplementationStatistics ;
    rdfs:range xsd:int .

ns3:vdaalstId a owl:DatatypeProperty ;
    rdfs:label "van der Aalst ID"@en ;
    rdfs:comment "Original van der Aalst pattern identifier (e.g., WCP-1)"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:string .

ns1:FindFraudDetectionPatternsQuery a ns1:QueryTemplate ;
    rdfs:label "Find Fraud Detection Patterns Query"@en ;
    ns1:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        PREFIX fraud: <http://bitflow.org/ontology/fraud-detection#>
        
        # Find patterns that can detect performance fraud or memory leaks
        SELECT ?pattern ?label ?fraudType ?threshold
        WHERE {
            {
                ?pattern fraud:detectsPerformanceFraud ?fraud .
                ?fraud fraud:performanceFraudFactor ?threshold .
                BIND("Performance Fraud" AS ?fraudType)
            } UNION {
                ?pattern fraud:detectsMemoryLeak ?leak .
                ?leak fraud:memoryLeakThreshold ?threshold .
                BIND("Memory Leak" AS ?fraudType)
            }
            ?pattern rdfs:label ?label .
        }
    """ .

ns1:FindImplementationPriorityQuery a ns1:QueryTemplate ;
    rdfs:label "Find Implementation Priority Query"@en ;
    ns1:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        PREFIX perf: <http://bitflow.org/ontology/performance#>
        
        # Prioritize missing patterns by performance impact and complexity
        SELECT ?pattern ?label ?performanceImpact ?complexity ?throughput 
               (IF(?performanceImpact = "CRITICAL", 1, 
                   IF(?performanceImpact = "HIGH", 2, 
                      IF(?performanceImpact = "MEDIUM", 3, 4))) AS ?priority)
        WHERE {
            ?pattern a bwp:WorkflowPattern ;
                     rdfs:label ?label ;
                     bwp:bitflowImplemented false ;
                     bwp:performanceImpact ?performanceImpact ;
                     perf:executionComplexity ?complexity ;
                     perf:estimatedThroughput ?throughput .
        }
        ORDER BY ?priority, ?throughput
    """ .

ns1:FindMissingPatternsQuery a ns1:QueryTemplate ;
    rdfs:label "Find Missing Patterns Query"@en ;
    ns1:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        
        # Find all patterns not implemented in BitFlow
        SELECT ?pattern ?label ?vdaalstId ?performanceImpact ?complexity
        WHERE {
            ?pattern a bwp:WorkflowPattern ;
                     rdfs:label ?label ;
                     bwp:vdaalstId ?vdaalstId ;
                     bwp:bitflowImplemented false ;
                     bwp:performanceImpact ?performanceImpact ;
                     perf:executionComplexity ?complexity .
        }
        ORDER BY ?vdaalstId
    """ .

ns1:FindPerformanceCriticalPatternsQuery a ns1:QueryTemplate ;
    rdfs:label "Find Performance Critical Patterns Query"@en ;
    ns1:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        PREFIX perf: <http://bitflow.org/ontology/performance#>
        
        # Find patterns critical for performance and memory
        SELECT ?pattern ?label ?throughput ?latency ?memory ?complexity
        WHERE {
            ?pattern a bwp:WorkflowPattern ;
                     rdfs:label ?label ;
                     bwp:criticalForPerformance true ;
                     perf:estimatedThroughput ?throughput ;
                     perf:estimatedLatency ?latency ;
                     perf:memoryFootprint ?memory ;
                     perf:executionComplexity ?complexity .
        }
        ORDER BY ?throughput
    """ .

ns1:FindYAWLMappingsQuery a ns1:QueryTemplate ;
    rdfs:label "Find YAWL Mappings Query"@en ;
    ns1:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        PREFIX yawl: <http://www.yawlfoundation.org/ontology#>
        
        # Find patterns with YAWL construct mappings
        SELECT ?pattern ?label ?yawlConstruct
        WHERE {
            ?pattern a bwp:WorkflowPattern ;
                     rdfs:label ?label ;
                     bwp:mapsToYAWLConstruct ?yawlConstruct .
        }
        ORDER BY ?label
    """ .

