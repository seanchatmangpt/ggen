@prefix ns1: <http://bitflow.org/sparql/patterns#> .
@prefix ns2: <http://hyperintelligence.ai/patterns#> .
@prefix ns3: <http://bitflow.org/ontology/workflow-patterns#> .
@prefix ns4: <http://bitflow.org/ontology/performance#> .
@prefix ns5: <http://bitflow.org/ontology/fraud-detection#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns5:memoryLeakThreshold a owl:DatatypeProperty ;
    rdfs:label "memory leak threshold"@en ;
    rdfs:comment "Memory usage threshold for leak detection (374MB = 392,167,424 bytes)"@en ;
    rdfs:domain ns5:MemoryLeak ;
    rdfs:range xsd:long .

ns5:performanceFraudFactor a owl:DatatypeProperty ;
    rdfs:label "performance fraud factor"@en ;
    rdfs:comment "Multiplier indicating performance degradation (52,704x threshold)"@en ;
    rdfs:domain ns5:PerformanceFraud ;
    rdfs:range xsd:double .

ns4:LatencyMetric a owl:Class ;
    rdfs:label "Latency Metric"@en ;
    rdfs:comment "Response time measurement in nanoseconds"@en ;
    rdfs:subClassOf ns4:PerformanceMetric .

ns4:MemoryMetric a owl:Class ;
    rdfs:label "Memory Metric"@en ;
    rdfs:comment "Memory usage measurement in bytes"@en ;
    rdfs:subClassOf ns4:PerformanceMetric .

ns4:ThroughputMetric a owl:Class ;
    rdfs:label "Throughput Metric"@en ;
    rdfs:comment "Operations per second measurement"@en ;
    rdfs:subClassOf ns4:PerformanceMetric .

ns4:estimatedLatency a owl:DatatypeProperty ;
    rdfs:label "estimated latency"@en ;
    rdfs:comment "Estimated execution latency in nanoseconds"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:int .

ns4:estimatedThroughput a owl:DatatypeProperty ;
    rdfs:label "estimated throughput"@en ;
    rdfs:comment "Estimated operations per second"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:int .

ns4:executionComplexity a owl:DatatypeProperty ;
    rdfs:label "execution complexity"@en ;
    rdfs:comment "Big-O notation for pattern execution complexity"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:string .

ns4:memoryFootprint a owl:DatatypeProperty ;
    rdfs:label "memory footprint"@en ;
    rdfs:comment "Memory usage in bytes for pattern execution"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:int .

<http://bitflow.org/ontology/workflow-patterns> a owl:Ontology ;
    rdfs:label "BitFlow Complete Workflow Patterns Ontology v3.0"@en ;
    rdfs:comment """Complete OWL ontology for all 43 van der Aalst workflow patterns 
                    with BitFlow implementation status, performance fraud detection 
                    (52,704x threshold), memory leak prevention (374MB), and YAWL 
                    compatibility mappings. Designed by OWL_Ontology_Architect agent 
                    for BitFlow OWL TTL YAWL integration."""@en ;
    rdfs:seeAlso <http://workflowpatterns.com>,
        <https://github.com/bitflow-engine/bitflow>,
        <https://www.yawlfoundation.org/> ;
    owl:imports <http://www.yawlfoundation.org/ontology> ;
    owl:versionIRI <http://bitflow.org/ontology/workflow-patterns/3.0> ;
    owl:versionInfo "3.0.0" .

ns3:AcyclicSynchronizingMerge a ns3:NewControlFlowPattern ;
    rdfs:label "Acyclic Synchronizing Merge (WCP-35)"@en ;
    ns4:estimatedLatency 900 ;
    ns4:estimatedThroughput 110000 ;
    ns4:executionComplexity "O(n)" ;
    ns4:memoryFootprint 192 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForMemory false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 35 ;
    ns3:performanceImpact "HIGH" ;
    ns3:vdaalstId "WCP-35" ;
    rdfs:comment "Synchronizing merge without cycles"@en .

ns3:ArbitraryCycles a ns3:StructuralPattern ;
    rdfs:label "Arbitrary Cycles (WCP-10)"@en ;
    ns4:estimatedLatency 2000 ;
    ns4:estimatedThroughput 50000 ;
    ns4:executionComplexity "O(k*n)" ;
    ns4:memoryFootprint 512 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForMemory true ;
    ns3:criticalForPerformance true ;
    ns3:patternId 10 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "WCP-10" ;
    rdfs:comment "Ability to represent cycles in workflow with single entry/exit point"@en .

ns3:BitFlowImplementationStats a ns3:ImplementationStatistics ;
    rdfs:label "BitFlow Implementation Statistics"@en ;
    ns3:criticalMissingPatterns 25 ;
    ns3:highPerformanceImpactMissingPatterns 15 ;
    ns3:implementationPercentage 18.6 ;
    ns3:implementedPatterns 8 ;
    ns3:missingPatterns 35 ;
    ns3:totalPatterns 43 ;
    rdfs:comment "Current implementation coverage: 8/43 patterns (18.6%)"@en .

ns3:BlockingDiscriminator a ns3:NewControlFlowPattern ;
