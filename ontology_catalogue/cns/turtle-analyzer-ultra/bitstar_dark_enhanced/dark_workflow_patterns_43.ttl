ns1:OptimizationHint a owl:Class ;
    rdfs:label "Optimization Hint" ;
    rdfs:comment "Performance optimization guidance" .

ns1:PatternMetrics a owl:Class ;
    rdfs:label "Pattern Metrics" ;
    rdfs:comment "Runtime metrics for pattern execution" .

ns1:BasicControl a ns1:PatternCategory ;
    rdfs:label "Basic Control Flow Patterns" ;
    rdfs:comment "Fundamental patterns for process control" .

ns1:Cancellation a ns1:PatternCategory ;
    rdfs:label "Cancellation and Force Completion" ;
    rdfs:comment "Patterns for process cancellation" .

ns1:StateBased a ns1:PatternCategory ;
    rdfs:label "State-based Patterns" ;
    rdfs:comment "Patterns based on process state" .

ns1:AdvancedBranching a ns1:PatternCategory ;
    rdfs:label "Advanced Branching and Synchronization" ;
    rdfs:comment "Complex split and join patterns" .

ns1:MultipleInstance a ns1:PatternCategory ;
    rdfs:label "Multiple Instance Patterns" ;
    rdfs:comment "Patterns for handling multiple instances" .

ns1:Triggering a ns1:PatternCategory ;
    rdfs:label "Trigger Patterns" ;
    rdfs:comment "Event-based triggering patterns" .

ns1:MultiMergePattern a owl:Class ;
    rdfs:label "Pattern 8: Multi-Merge" ;
    ns1:averageExecutionTicks 2 ;
    ns1:hasImplementationHint "Queue incoming tokens" ;
    ns1:patternCategory ns1:AdvancedBranching ;
    ns1:patternID 8 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Allows activity execution for each incoming branch" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:SimpleMergePattern a owl:Class ;
    rdfs:label "Pattern 5: Simple Merge (XOR-join)" ;
    ns1:averageExecutionTicks 1 ;
    ns1:hasImplementationHint "Direct flow merge, no waiting" ;
    ns1:patternCategory ns1:BasicControl ;
    ns1:patternID 5 ;
    ns1:supportsSIMD false ;
    ns4:hasJoinType ns4:XOR ;
    rdfs:comment "Merges alternative branches without synchronization" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:StructuredSyncMergePattern a owl:Class ;
    rdfs:label "Pattern 7: Structured Synchronizing Merge" ;
    ns1:averageExecutionTicks 4 ;
    ns1:dependsOn ns1:MultiChoicePattern ;
    ns1:hasImplementationHint "Track split context for proper sync" ;
    ns1:patternCategory ns1:AdvancedBranching ;
    ns1:patternID 7 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Merges paths that diverged from same OR-split" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:MultiChoicePattern a owl:Class ;
    rdfs:label "Pattern 6: Multi-Choice (OR-split)" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Bitmap for branch selection" ;
    ns1:patternCategory ns1:AdvancedBranching ;
    ns1:patternID 6 ;
    ns1:supportsSIMD true ;
    ns4:hasSplitType ns4:OR ;
    rdfs:comment "Selects one or more branches based on conditions" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:ExclusiveChoicePattern a owl:Class ;
    rdfs:label "Pattern 4: Exclusive Choice (XOR-split)" ;
    ns1:averageExecutionTicks 2 ;
    ns1:hasImplementationHint "Branch prediction optimization" ;
    ns1:incompatibleWith ns1:ParallelSplitPattern ;
    ns1:patternCategory ns1:BasicControl ;
    ns1:patternID 4 ;
    ns1:supportsSIMD false ;
    ns4:hasSplitType ns4:XOR ;
    rdfs:comment "Selects one branch from multiple alternatives" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:SynchronizationPattern a owl:Class ;
    rdfs:label "Pattern 3: Synchronization (AND-join)" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Atomic counter for branch tracking" ;
    ns1:patternCategory ns1:BasicControl ;
    ns1:patternID 3 ;
    ns1:supportsSIMD true ;
    ns4:hasJoinType ns4:AND ;
    rdfs:comment "Synchronizes multiple parallel branches" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:ParallelSplitPattern a owl:Class ;
    rdfs:label "Pattern 2: Parallel Split (AND-split)" ;
    ns1:averageExecutionTicks 2 ;
    ns1:canCombineWith ns1:SynchronizationPattern ;
    ns1:hasImplementationHint "Use SIMD for parallel branch initialization" ;
    ns1:patternCategory ns1:BasicControl ;
    ns1:patternID 2 ;
    ns1:supportsSIMD true ;
    ns4:hasSplitType ns4:AND ;
    rdfs:comment "Splits execution into multiple parallel branches" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:canCombineWith a owl:ObjectProperty ;
    rdfs:label "can combine with" ;
    rdfs:comment "Patterns that work well together" ;
    rdfs:domain ns1:WorkflowPattern ;
    rdfs:range ns1:WorkflowPattern .

ns1:dependsOn a owl:ObjectProperty ;
    rdfs:label "depends on" ;
    rdfs:comment "Pattern execution dependency" ;
    rdfs:domain ns1:WorkflowPattern ;
    rdfs:range ns1:WorkflowPattern .

ns1:incompatibleWith a owl:ObjectProperty ;
    rdfs:label "incompatible with" ;
    rdfs:comment "Patterns that cannot coexist" ;
    rdfs:domain ns1:WorkflowPattern ;
    rdfs:range ns1:WorkflowPattern .

ns1:patternCategory a owl:ObjectProperty ;
    rdfs:label "Pattern Category" ;
    rdfs:domain ns1:WorkflowPattern ;
    rdfs:range ns1:PatternCategory .

ns1:SequencePattern a owl:Class ;
    rdfs:label "Pattern 1: Sequence" ;
    ns1:averageExecutionTicks 1 ;
    ns1:hasImplementationHint "Direct flow transition, zero overhead" ;
    ns1:patternCategory ns1:BasicControl ;
    ns1:patternID 1 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Sequential execution of activities" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:WorkflowPattern a owl:Class ;
