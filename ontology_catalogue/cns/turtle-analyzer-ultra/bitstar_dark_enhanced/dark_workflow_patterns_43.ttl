@prefix ns1: <http://bitflow.ai/ontology/patterns#> .
@prefix ns2: <http://hyperintelligence.ai/patterns#> .
@prefix ns3: <http://bitflow.ai/sparql/patterns#> .
@prefix ns4: <http://bitflow.ai/ontology/yawl/v2#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:AcyclicSyncMergePattern a owl:Class ;
    rdfs:label "Pattern 37: Acyclic Synchronizing Merge" ;
    ns1:averageExecutionTicks 4 ;
    ns1:hasImplementationHint "Topological branch analysis" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 37 ;
    ns1:supportsSIMD false ;
    rdfs:comment "OR-join without cycles" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:ArbitraryCyclesPattern a owl:Class ;
    rdfs:label "Pattern 10: Arbitrary Cycles" ;
    ns1:averageExecutionTicks 2 ;
    ns1:hasImplementationHint "Loop counter with overflow protection" ;
    ns1:patternCategory ns1:AdvancedBranching ;
    ns1:patternID 10 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Supports loops in workflow graph" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:BlockingDiscriminatorPattern a owl:Class ;
    rdfs:label "Pattern 28: Blocking Discriminator" ;
    ns1:averageExecutionTicks 4 ;
    ns1:hasImplementationHint "Branch completion counter" ;
    ns1:patternCategory ns1:Cancellation ;
    ns1:patternID 28 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Blocks until all branches complete" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:BlockingPartialJoinPattern a owl:Class ;
    rdfs:label "Pattern 31: Blocking Partial Join" ;
    ns1:averageExecutionTicks 5 ;
    ns1:hasImplementationHint "Blocking queue for late arrivals" ;
    ns1:patternCategory ns1:Cancellation ;
    ns1:patternID 31 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Waits for N of M then blocks rest" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:BranchingPatterns a ns1:OptimizationHint ;
    rdfs:label "Branching Patterns" ;
    ns1:recommendedOptimization "Branch prediction hints, speculative execution" ;
    rdfs:comment "Patterns 4, 5, 6, 7, 16" .

ns1:CancelActivityPattern a owl:Class ;
    rdfs:label "Pattern 19: Cancel Activity" ;
    ns1:averageExecutionTicks 2 ;
    ns1:hasImplementationHint "Interrupt flag signaling" ;
    ns1:patternCategory ns1:MultipleInstance ;
    ns1:patternID 19 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Cancels a running activity" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:CancelCasePattern a owl:Class ;
    rdfs:label "Pattern 20: Cancel Case" ;
    ns1:averageExecutionTicks 4 ;
    ns1:hasImplementationHint "Broadcast cancellation signal" ;
    ns1:patternCategory ns1:MultipleInstance ;
    ns1:patternID 20 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Cancels entire process instance" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:CancelMIActivityPattern a owl:Class ;
    rdfs:label "Pattern 26: Cancel MI Activity" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Instance list traversal" ;
    ns1:patternCategory ns1:StateBased ;
    ns1:patternID 26 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Cancels all instances of MI activity" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:CancelRegionPattern a owl:Class ;
    rdfs:label "Pattern 25: Cancel Region" ;
    ns1:averageExecutionTicks 4 ;
    ns1:hasImplementationHint "Region bitmap for bulk cancel" ;
    ns1:patternCategory ns1:StateBased ;
    ns1:patternID 25 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Cancels set of activities in region" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:CancellingDiscriminatorPattern a owl:Class ;
    rdfs:label "Pattern 29: Cancelling Discriminator" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Atomic cancel broadcast" ;
    ns1:patternCategory ns1:Cancellation ;
    ns1:patternID 29 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Cancels remaining branches after first" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:CancellingPartialJoinMIPattern a owl:Class ;
    rdfs:label "Pattern 35: Cancelling Partial Join for MI" ;
    ns1:averageExecutionTicks 4 ;
    ns1:hasImplementationHint "MI cancel broadcast" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 35 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Cancels remaining MI after threshold" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:CancellingPartialJoinPattern a owl:Class ;
    rdfs:label "Pattern 32: Cancelling Partial Join" ;
    ns1:averageExecutionTicks 4 ;
    ns1:hasImplementationHint "Threshold with immediate cancel" ;
    ns1:patternCategory ns1:Cancellation ;
    ns1:patternID 32 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Joins N of M then cancels rest" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:CompleteMIActivityPattern a owl:Class ;
    rdfs:label "Pattern 27: Complete MI Activity" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Force completion flag" ;
    ns1:patternCategory ns1:StateBased ;
    ns1:patternID 27 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Forces completion of MI activity" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:ComplexityAnalysisQuery a ns3:QueryTemplate ;
    rdfs:label "Complexity Analysis Query" ;
    ns3:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        
        # Find high-complexity patterns
        SELECT ?pattern ?id ?ticks ?category
        WHERE {
            ?pattern a :WorkflowPattern ;
                     :patternID ?id ;
                     :averageExecutionTicks ?ticks ;
                     :patternCategory ?category .
            FILTER (?ticks >= 5)
        }
        ORDER BY DESC(?ticks)
    """ .

ns1:CriticalSectionPattern a owl:Class ;
    rdfs:label "Pattern 39: Critical Section" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Lock-free CAS operations" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 39 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Mutual exclusion for shared resources" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:DeferredChoicePattern a owl:Class ;
    rdfs:label "Pattern 16: Deferred Choice" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Event-driven branch selection" ;
    ns1:patternCategory ns1:MultipleInstance ;
    ns1:patternID 16 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Choice made by environment, not process" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:DynamicPartialJoinMIPattern a owl:Class ;
    rdfs:label "Pattern 36: Dynamic Partial Join for MI" ;
    ns1:averageExecutionTicks 5 ;
    ns1:hasImplementationHint "Dynamic threshold evaluation" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 36 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Runtime determined MI join threshold" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:ExplicitTerminationPattern a owl:Class ;
    rdfs:label "Pattern 43: Explicit Termination" ;
    ns1:averageExecutionTicks 1 ;
    ns1:hasImplementationHint "Termination signal broadcast" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 43 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Defined end point for process" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:GeneralSyncMergePattern a owl:Class ;
    rdfs:label "Pattern 38: General Synchronizing Merge" ;
    ns1:averageExecutionTicks 7 ;
    ns1:hasImplementationHint "Reachability analysis required" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 38 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Complex OR-join with cycle support" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:GeneralizedANDJoinPattern a owl:Class ;
    rdfs:label "Pattern 33: Generalized AND-Join" ;
    ns1:averageExecutionTicks 6 ;
    ns1:hasImplementationHint "Dynamic branch tracking" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 33 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Waits for all active incoming branches" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:ImplicitTerminationPattern a owl:Class ;
    rdfs:label "Pattern 11: Implicit Termination" ;
    ns1:averageExecutionTicks 4 ;
    ns1:hasImplementationHint "Global activity counter" ;
    ns1:patternCategory ns1:AdvancedBranching ;
    ns1:patternID 11 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Process ends when no activities can execute" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:InterleavedParallelPattern a owl:Class ;
    rdfs:label "Pattern 17: Interleaved Parallel Routing" ;
    ns1:averageExecutionTicks 6 ;
    ns1:hasImplementationHint "Mutex for resource access" ;
    ns1:patternCategory ns1:MultipleInstance ;
    ns1:patternID 17 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Parallel execution with shared resources" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:InterleavedRoutingPattern a owl:Class ;
    rdfs:label "Pattern 40: Interleaved Routing" ;
    ns1:averageExecutionTicks 5 ;
    ns1:hasImplementationHint "Segment queue management" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 40 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Sequential execution of parallel segments" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:LoopPatterns a ns1:OptimizationHint ;
    rdfs:label "Loop Patterns" ;
    ns1:recommendedOptimization "Loop unrolling, iterator optimization" ;
    rdfs:comment "Patterns 10, 21, 22" .

ns1:MIAprioriDesignPattern a owl:Class ;
    rdfs:label "Pattern 13: MI with Design-Time Knowledge" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Pre-allocated instance pool" ;
    ns1:patternCategory ns1:AdvancedBranching ;
    ns1:patternID 13 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Number of instances known at design time" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:MIAprioriRuntimePattern a owl:Class ;
    rdfs:label "Pattern 14: MI with Run-Time Knowledge" ;
    ns1:averageExecutionTicks 4 ;
    ns1:hasImplementationHint "Dynamic instance allocation" ;
    ns1:patternCategory ns1:MultipleInstance ;
    ns1:patternID 14 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Number of instances known at runtime" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:MINoAprioriPattern a owl:Class ;
    rdfs:label "Pattern 15: MI without Run-Time Knowledge" ;
    ns1:averageExecutionTicks 5 ;
    ns1:hasImplementationHint "Growing instance pool" ;
    ns1:patternCategory ns1:MultipleInstance ;
    ns1:patternID 15 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Dynamic instance creation during execution" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:MIWithoutSyncPattern a owl:Class ;
    rdfs:label "Pattern 12: MI without Synchronization" ;
    ns1:averageExecutionTicks 2 ;
    ns1:hasImplementationHint "Fire-and-forget spawning" ;
    ns1:patternCategory ns1:AdvancedBranching ;
    ns1:patternID 12 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Creates instances without waiting for completion" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:MilestonePattern a owl:Class ;
    rdfs:label "Pattern 18: Milestone" ;
    ns1:averageExecutionTicks 2 ;
    ns1:hasImplementationHint "State flag checking" ;
    ns1:patternCategory ns1:MultipleInstance ;
    ns1:patternID 18 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Activity enabled until milestone reached" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:ParallelizablePatterns a ns1:OptimizationHint ;
    rdfs:label "Parallelizable Patterns" ;
    ns1:recommendedOptimization "SIMD vectorization for parallel operations" ;
    ns1:useSIMD true ;
    rdfs:comment "Patterns 2, 3, 6, 12, 13, 14, 20, 25, 26, 27, 29, 30, 32, 34, 35, 42" .

ns1:PatternAnalysisQuery a ns3:QueryTemplate ;
    rdfs:label "Pattern Analysis Query" ;
    ns3:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        PREFIX wp: <http://bitflow.ai/ontology/workflow-patterns#>
        
        # Find all patterns in a category
        SELECT ?pattern ?id ?ticks ?simd
        WHERE {
            ?pattern a :WorkflowPattern ;
                     :patternCategory ?category ;
                     :patternID ?id ;
                     :averageExecutionTicks ?ticks ;
                     :supportsSIMD ?simd .
            FILTER (?category = :AdvancedBranching)
        }
        ORDER BY ?id
    """ .

ns1:PerformanceOptimizationQuery a ns3:QueryTemplate ;
    rdfs:label "Performance Optimization Query" ;
    ns3:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        
        # Find patterns suitable for SIMD optimization
        SELECT ?pattern ?id ?hint
        WHERE {
            ?pattern a :WorkflowPattern ;
                     :patternID ?id ;
                     :supportsSIMD true ;
                     :hasImplementationHint ?hint .
        }
        ORDER BY ?id
    """ .

ns1:PersistentTriggerPattern a owl:Class ;
    rdfs:label "Pattern 24: Persistent Trigger" ;
    ns1:averageExecutionTicks 2 ;
    ns1:hasImplementationHint "Trigger queue per activity" ;
    ns1:patternCategory ns1:StateBased ;
    ns1:patternID 24 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Trigger retained until consumed" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:RecursionPattern a owl:Class ;
    rdfs:label "Pattern 22: Recursion" ;
    ns1:averageExecutionTicks 5 ;
    ns1:hasImplementationHint "Stack depth limit enforcement" ;
    ns1:patternCategory ns1:StateBased ;
    ns1:patternID 22 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Activity can invoke itself recursively" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:StaticPartialJoinMIPattern a owl:Class ;
    rdfs:label "Pattern 34: Static Partial Join for MI" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Static counter initialization" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 34 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Joins fixed number of MI instances" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:StructuredDiscriminatorPattern a owl:Class ;
    rdfs:label "Pattern 9: Structured Discriminator" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Atomic first-arrival detection" ;
    ns1:patternCategory ns1:AdvancedBranching ;
    ns1:patternID 9 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Waits for first incoming branch then cancels others" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:StructuredLoopPattern a owl:Class ;
    rdfs:label "Pattern 21: Structured Loop" ;
    ns1:averageExecutionTicks 3 ;
    ns1:hasImplementationHint "Loop counter with condition check" ;
    ns1:patternCategory ns1:MultipleInstance ;
    ns1:patternID 21 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Pre-test or post-test loop construct" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:StructuredPartialJoinPattern a owl:Class ;
    rdfs:label "Pattern 30: Structured Partial Join" ;
    ns1:averageExecutionTicks 4 ;
    ns1:hasImplementationHint "Threshold counter with cancel" ;
    ns1:patternCategory ns1:Cancellation ;
    ns1:patternID 30 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Joins N of M branches then cancels rest" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:SynchronizationPatterns a ns1:OptimizationHint ;
    rdfs:label "Synchronization Patterns" ;
    ns1:recommendedOptimization "Lock-free algorithms, atomic operations" ;
    rdfs:comment "Patterns 3, 7, 11, 28, 33, 37, 38" .

ns1:ThreadMergePattern a owl:Class ;
    rdfs:label "Pattern 41: Thread Merge" ;
    ns1:averageExecutionTicks 2 ;
    ns1:hasImplementationHint "Thread ID tracking" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 41 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Merges thread of control" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:ThreadSplitPattern a owl:Class ;
    rdfs:label "Pattern 42: Thread Split" ;
    ns1:averageExecutionTicks 2 ;
    ns1:hasImplementationHint "Thread spawning optimization" ;
    ns1:patternCategory ns1:Triggering ;
    ns1:patternID 42 ;
    ns1:supportsSIMD true ;
    rdfs:comment "Splits thread of control" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:TransientTriggerPattern a owl:Class ;
    rdfs:label "Pattern 23: Transient Trigger" ;
    ns1:averageExecutionTicks 1 ;
    ns1:hasImplementationHint "Non-blocking trigger check" ;
    ns1:patternCategory ns1:StateBased ;
    ns1:patternID 23 ;
    ns1:supportsSIMD false ;
    rdfs:comment "Trigger lost if activity not ready" ;
    rdfs:subClassOf ns1:WorkflowPattern .

ns1:WorkflowPatternShape a sh:NodeShape ;
    sh:property [ sh:maxCount 1 ;
            sh:maxInclusive 43 ;
            sh:message "Pattern ID must be between 1 and 43" ;
            sh:minCount 1 ;
            sh:minInclusive 1 ;
            sh:path ns1:patternID ],
        [ sh:maxCount 1 ;
            sh:message "Every pattern must belong to exactly one category" ;
            sh:minCount 1 ;
            sh:path ns1:patternCategory ],
        [ sh:maxInclusive 8 ;
            sh:message "Execution must complete within 8 ticks" ;
            sh:minInclusive 1 ;
            sh:path ns1:averageExecutionTicks ],
        [ sh:datatype xsd:boolean ;
            sh:message "SIMD support must be explicitly specified" ;
            sh:path ns1:supportsSIMD ] ;
    sh:targetClass ns1:WorkflowPattern .

ns1:averageLatency a owl:DatatypeProperty ;
    rdfs:label "average latency" ;
    rdfs:comment "Average execution time in microseconds" ;
    rdfs:domain ns1:PatternMetrics ;
    rdfs:range xsd:decimal .

ns1:executionCount a owl:DatatypeProperty ;
    rdfs:label "execution count" ;
    rdfs:domain ns1:PatternMetrics ;
    rdfs:range xsd:integer .

ns1:hasImplementationHint a owl:DatatypeProperty ;
    rdfs:label "Implementation Hint" ;
    rdfs:comment "Performance and implementation guidance" ;
    rdfs:domain ns1:WorkflowPattern ;
    rdfs:range xsd:string .

ns1:lastExecutionHash a owl:DatatypeProperty ;
    rdfs:label "last execution hash" ;
    rdfs:comment "Blake3 hash of last execution" ;
    rdfs:domain ns1:PatternMetrics ;
    rdfs:range xsd:string .

ns1:successRate a owl:DatatypeProperty ;
    rdfs:label "success rate" ;
    rdfs:comment "Percentage of successful executions" ;
    rdfs:domain ns1:PatternMetrics ;
    rdfs:range xsd:decimal .

<http://bitflow.ai/ontology/workflow-patterns> a owl:Ontology ;
    rdfs:label "Workflow Patterns Ontology v1.0" ;
    rdfs:comment "Complete semantic definition of all 43 workflow patterns with performance hints and SHACL constraints" ;
    rdfs:seeAlso <http://www.workflowpatterns.com/>,
        <https://www.yawlfoundation.org/> ;
    owl:versionInfo "1.0" .

