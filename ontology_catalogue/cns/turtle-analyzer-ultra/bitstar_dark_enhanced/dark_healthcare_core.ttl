ns1:AcuteCondition a owl:Class ;
    rdfs:label "Acute Medical Condition"@en ;
    rdfs:subClassOf ns1:MedicalCondition .

ns1:AtrialFibrillation a ns1:Arrhythmia ;
    rdfs:label "Atrial Fibrillation" .

ns1:BaxterInfusionPump a ns1:InfusionPump ;
    ns1:deviceManufacturer "Baxter International" ;
    ns1:deviceModel "SIGMA Spectrum" ;
    ns1:deviceStatus "operational" .

ns1:BloodPressureMonitor a owl:Class ;
    rdfs:label "Blood Pressure Monitor"@en ;
    rdfs:subClassOf ns1:MonitoringDevice .

ns1:Cardiologist a ns1:Specialist ;
    rdfs:label "Cardiologist" .

ns1:CardiologyUnit a owl:Class ;
    rdfs:label "Cardiology Unit"@en ;
    rdfs:subClassOf ns1:MedicalUnit .

ns1:ChronicCOPD a ns1:COPD ;
    rdfs:label "Chronic COPD" .

ns1:Clinic a owl:Class ;
    rdfs:label "Medical Clinic"@en ;
    rdfs:subClassOf ns1:HealthcareFacility .

ns1:ClinicalEvent a owl:Class ;
    rdfs:label "Clinical Event"@en ;
    rdfs:comment "Significant occurrence in patient care or monitoring"@en .

ns1:CodeBlue a owl:Class ;
    rdfs:label "Code Blue Emergency"@en ;
    rdfs:subClassOf ns1:CriticalAlert .

ns1:Defibrillator a owl:Class ;
    rdfs:label "Automated External Defibrillator"@en ;
    rdfs:subClassOf ns1:MedicalDevice .

ns1:DeviceAlert a owl:Class ;
    rdfs:label "Medical Device Alert"@en ;
    rdfs:subClassOf ns1:MedicalAlert .

ns1:ECGMonitor a owl:Class ;
    rdfs:label "Electrocardiogram Monitor"@en ;
    rdfs:subClassOf ns1:MonitoringDevice .

ns1:EmergencyDepartment a owl:Class ;
    rdfs:label "Emergency Department"@en ;
    rdfs:subClassOf ns1:MedicalUnit .

ns1:EssentialHypertension a ns1:Hypertension ;
    rdfs:label "Essential Hypertension" .

ns1:GlucoseMonitor a owl:Class ;
    rdfs:label "Blood Glucose Monitor"@en ;
    rdfs:subClassOf ns1:MonitoringDevice .

ns1:HealthcareOntology a owl:Ontology ;
    rdfs:label "Real-time Healthcare Monitoring System"@en ;
    rdfs:comment "Semantic model for ultra-fast patient monitoring and clinical decision support"@en ;
    owl:versionInfo "1.0" .

ns1:Hospital a owl:Class ;
    rdfs:label "Hospital"@en ;
    rdfs:subClassOf ns1:HealthcareFacility .

ns1:ICU a owl:Class ;
    rdfs:label "Intensive Care Unit"@en ;
    rdfs:subClassOf ns1:MedicalUnit .

ns1:ICUNurse a ns1:Nurse ;
    rdfs:label "ICU Nurse" .

ns1:MasimoPulseOx a ns1:PulseOximeter ;
    ns1:deviceManufacturer "Masimo Corporation" ;
    ns1:deviceModel "Radical-7" ;
    ns1:measurementAccuracy 99.2 ;
    ns1:realTimeMonitoring true ;
    ns1:samplingRate 50.0 .

ns1:MedicalSurgicalUnit a owl:Class ;
    rdfs:label "Medical-Surgical Unit"@en ;
    rdfs:subClassOf ns1:MedicalUnit .

ns1:MedicationAlert a owl:Class ;
    rdfs:label "Medication Alert"@en ;
    rdfs:subClassOf ns1:MedicalAlert .

ns1:NICU a owl:Class ;
    rdfs:label "Neonatal Intensive Care Unit"@en ;
    rdfs:subClassOf ns1:MedicalUnit .

ns1:NormalBloodGlucose a ns1:BloodGlucose ;
    ns1:criticalRangeHigh 400.0 ;
    ns1:criticalRangeLow 50.0 ;
    ns1:measurementUnit "mg/dL" ;
    ns1:normalRangeHigh 140.0 ;
    ns1:normalRangeLow 70.0 .

ns1:NormalBloodPressure a ns1:BloodPressure ;
    ns1:criticalRangeHigh 180.0 ;
    ns1:criticalRangeLow 70.0 ;
    ns1:measurementUnit "mmHg" ;
    ns1:normalRangeHigh 140.0 ;
    ns1:normalRangeLow 90.0 .

ns1:NormalBodyTemperature a ns1:BodyTemperature ;
    ns1:criticalRangeHigh 40.0 ;
    ns1:criticalRangeLow 35.0 ;
    ns1:measurementUnit "°C" ;
    ns1:normalRangeHigh 37.2 ;
    ns1:normalRangeLow 36.1 .

ns1:NormalHeartRate a ns1:HeartRate ;
    ns1:criticalRangeHigh 150.0 ;
    ns1:criticalRangeLow 40.0 ;
    ns1:measurementUnit "bpm" ;
    ns1:normalRangeHigh 100.0 ;
    ns1:normalRangeLow 60.0 .

ns1:NormalOxygenSaturation a ns1:OxygenSaturation ;
    ns1:criticalRangeHigh 100.0 ;
    ns1:criticalRangeLow 88.0 ;
    ns1:measurementUnit "%" ;
    ns1:normalRangeHigh 100.0 ;
    ns1:normalRangeLow 95.0 .

ns1:NormalRespiratoryRate a ns1:RespiratoryRate ;
    ns1:criticalRangeHigh 30.0 ;
    ns1:criticalRangeLow 8.0 ;
    ns1:measurementUnit "breaths/min" ;
    ns1:normalRangeHigh 20.0 ;
    ns1:normalRangeLow 12.0 .

ns1:PatientDeteriorationAlert a owl:Class ;
    rdfs:label "Patient Deterioration Alert"@en ;
    rdfs:subClassOf ns1:CriticalAlert .

ns1:PhilipsIntelliVue a ns1:VitalSignsMonitor ;
    ns1:deviceManufacturer "Philips Healthcare" ;
    ns1:deviceModel "IntelliVue MX800" ;
    ns1:measurementAccuracy 98.5 ;
    ns1:realTimeMonitoring true ;
    ns1:samplingRate 125.0 ;
    ns1:simdOptimized true .

ns1:RespiratoryMonitor a owl:Class ;
    rdfs:label "Respiratory Monitor"@en ;
    rdfs:subClassOf ns1:MonitoringDevice .

ns1:RespiratoryTherapist a ns1:Technician ;
    rdfs:label "Respiratory Therapist" .

ns1:Surgery a owl:Class ;
    rdfs:label "Surgical Procedure"@en ;
    rdfs:subClassOf ns1:Treatment .

ns1:TemperatureMonitor a owl:Class ;
    rdfs:label "Body Temperature Monitor"@en ;
    rdfs:subClassOf ns1:MonitoringDevice .

ns1:Therapy a owl:Class ;
    rdfs:label "Medical Therapy"@en ;
    rdfs:subClassOf ns1:Treatment .

ns1:Type2Diabetes a ns1:Diabetes ;
    rdfs:label "Type 2 Diabetes Mellitus" .

ns1:Ventilator a owl:Class ;
    rdfs:label "Mechanical Ventilator"@en ;
    rdfs:subClassOf ns1:MedicalDevice .

ns1:VitalSignAlert a owl:Class ;
    rdfs:label "Vital Sign Alert"@en ;
    rdfs:subClassOf ns1:MedicalAlert .

ns1:WelchAllynVitalSigns a ns1:VitalSignsMonitor ;
    ns1:deviceManufacturer "Welch Allyn" ;
    ns1:deviceModel "Connex VSM 6000" ;
    ns1:measurementAccuracy 97.8 ;
    ns1:realTimeMonitoring true .

ns1:acknowledgedBy a owl:DatatypeProperty ;
    rdfs:label "Alert Acknowledged By"@en ;
    rdfs:domain ns1:MedicalAlert ;
    rdfs:range xsd:string .

ns1:acknowledgmentTime a owl:DatatypeProperty ;
    rdfs:label "Alert Acknowledgment Time"@en ;
    rdfs:domain ns1:MedicalAlert ;
