@prefix ns1: <http://bitflow.ai/ontology/patterns#> .
@prefix ns2: <http://hyperintelligence.ai/patterns#> .
@prefix ns3: <http://bitflow.ai/ontology/yawl/v2#> .
@prefix ns4: <http://bitflow.ai/sparql/patterns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://bitflow.ai/ontology/bitflow-comprehensive-patterns> a owl:Ontology ;
    rdfs:label "BitFlow Comprehensive Workflow Patterns Ontology v2.0" ;
    rdfs:comment "Complete TTL semantic model for all 43 workflow patterns with BitFlow performance extensions" ;
    rdfs:seeAlso <http://bitflow.ai/>,
        <http://www.workflowpatterns.com/>,
        <https://www.yawlfoundation.org/> ;
    owl:imports <http://bitflow.ai/ontology/yawl/v2> ;
    owl:versionInfo "2.0.0" .

ns1:AtomicRequired a ns1:OptimizationClass ;
    rdfs:label "Atomic Required" ;
    rdfs:comment "Patterns requiring atomic operations for correctness" ;
    rdfs:seeAlso ns1:CancelActivityPattern,
        ns1:CancelCasePattern,
        ns1:CancelRegionPattern,
        ns1:DeferredChoicePattern,
        ns1:ImplicitTerminationPattern,
        ns1:InterleavedParallelPattern,
        ns1:MINoRuntimePattern,
        ns1:MIRuntimePattern,
        ns1:PersistentTriggerPattern,
        ns1:RecursionPattern,
        ns1:StructuredDiscriminatorPattern,
        ns1:StructuredSyncMergePattern,
        ns1:SynchronizationPattern .

ns1:BitFlowPatternAnalysisQuery a ns4:QueryTemplate ;
    rdfs:label "BitFlow Pattern Analysis Query" ;
    ns4:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        PREFIX bitflow: <http://bitflow.ai/ontology/core#>
        
        # Find all patterns with their performance characteristics
        SELECT ?pattern ?id ?ticks ?simd ?atomic ?branchless ?handler
        WHERE {
            ?pattern a :BitFlowPattern ;
                     :patternID ?id ;
                     :maxExecutionTicks ?ticks ;
                     :requiredFeatures ?features ;
                     :isBranchless ?branchless ;
                     :usesAtomicOps ?atomic ;
                     :handlerFunction ?handler .
            BIND(CONTAINS(?features, "SIMD") AS ?simd)
        }
        ORDER BY ?id
    """ .

ns1:BitFlowPatternShape a sh:NodeShape ;
    sh:property [ sh:maxCount 1 ;
            sh:maxInclusive 42 ;
            sh:message "Pattern ID must be between 0 and 42 (zero-based)" ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:path ns1:patternID ],
        [ sh:maxCount 1 ;
            sh:maxInclusive 8 ;
            sh:message "Execution must complete within 8 ticks" ;
            sh:minCount 1 ;
            sh:minInclusive 1 ;
            sh:path ns1:maxExecutionTicks ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Every pattern must have a handler function" ;
            sh:minCount 1 ;
            sh:path ns1:handlerFunction ],
        [ sh:hasValue 128 ;
            sh:message "All patterns use 128-byte aligned scratch space" ;
            sh:path ns1:scratchSize ],
        [ sh:datatype xsd:boolean ;
            sh:message "Branchless optimization must be specified" ;
            sh:path ns1:isBranchless ],
        [ sh:datatype xsd:boolean ;
            sh:message "Atomic operation usage must be specified" ;
            sh:path ns1:usesAtomicOps ] ;
    sh:targetClass ns1:BitFlowPattern .

ns1:BranchlessOptimized a ns1:OptimizationClass ;
    rdfs:label "Branchless Optimized" ;
    rdfs:comment "Patterns using branchless programming techniques" ;
    rdfs:seeAlso ns1:ArbitraryCyclesPattern,
        ns1:CancelActivityPattern,
        ns1:CancelCasePattern,
        ns1:CancelRegionPattern,
        ns1:ExclusiveChoicePattern,
        ns1:MIDesignTimePattern,
        ns1:MIRuntimePattern,
        ns1:MIWithoutSyncPattern,
        ns1:MilestonePattern,
        ns1:MultiChoicePattern,
        ns1:MultiMergePattern,
        ns1:ParallelSplitPattern,
        ns1:PersistentTriggerPattern,
        ns1:SequencePattern,
        ns1:SimpleMergePattern,
        ns1:StructuredLoopPattern,
        ns1:SynchronizationPattern,
        ns1:TransientTriggerPattern .

ns1:ComplexityAnalysisQuery a ns4:QueryTemplate ;
    rdfs:label "Complexity Analysis Query" ;
    ns4:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        
        # Find high-complexity patterns requiring special attention
        SELECT ?pattern ?id ?ticks ?atomic ?hint
        WHERE {
            ?pattern a :BitFlowPattern ;
                     :patternID ?id ;
                     :maxExecutionTicks ?ticks ;
                     :usesAtomicOps ?atomic ;
                     :hasImplementationHint ?hint .
            FILTER(?ticks >= 5)
        }
        ORDER BY DESC(?ticks)
    """ .

ns1:PatternDependencyQuery a ns4:QueryTemplate ;
    rdfs:label "Pattern Dependency Query" ;
    ns4:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        PREFIX yawl: <http://bitflow.ai/ontology/yawl/v2#>
        
        # Find split/join pattern combinations
        SELECT ?pattern ?id ?splitType ?joinType ?ticks
        WHERE {
            ?pattern a :BitFlowPattern ;
                     :patternID ?id ;
                     :maxExecutionTicks ?ticks ;
                     yawl:hasSplitType ?splitType ;
                     yawl:hasJoinType ?joinType .
        }
        ORDER BY ?splitType, ?joinType, ?id
    """ .

ns1:SIMDOptimizable a ns1:OptimizationClass ;
    rdfs:label "SIMD Optimizable" ;
    rdfs:comment "Patterns that benefit from SIMD vectorization" ;
    rdfs:seeAlso ns1:CancelCasePattern,
        ns1:CancelRegionPattern,
        ns1:CancellingDiscriminatorPattern,
        ns1:CancellingPartialJoinMIPattern,
        ns1:CancellingPartialJoinPattern,
        ns1:ExplicitTerminationPattern,
        ns1:HierarchicalCancellationPattern,
        ns1:MIDesignTimePattern,
        ns1:MIRuntimePattern,
        ns1:MIWithoutSyncPattern,
        ns1:MultiChoicePattern,
        ns1:ParallelSplitPattern,
        ns1:StaticPartialJoinMIPattern,
        ns1:StructuredPartialJoinPattern,
        ns1:SynchronizationPattern,
        ns1:ThreadSplitPattern .

ns1:SIMDOptimizationQuery a ns4:QueryTemplate ;
    rdfs:label "SIMD Optimization Query" ;
    ns4:queryString """
        PREFIX : <http://bitflow.ai/ontology/patterns#>
        
        # Find patterns suitable for SIMD optimization
        SELECT ?pattern ?id ?hint ?ticks
        WHERE {
            ?pattern a :BitFlowPattern ;
                     :patternID ?id ;
                     :maxExecutionTicks ?ticks ;
                     :requiredFeatures ?features ;
                     :hasImplementationHint ?hint .
            FILTER(CONTAINS(?features, "SIMD"))
        }
        ORDER BY ?ticks DESC
    """ .

ns1:bitflowPatternRegistry a ns1:PatternRegistry ;
    rdfs:label "BitFlow Pattern Registry" ;
    ns1:containsPattern ns1:AcyclicSyncMergePattern,
        ns1:ArbitraryCyclesPattern,
        ns1:BlockingDiscriminatorPattern,
        ns1:BlockingPartialJoinPattern,
        ns1:CancelActivityPattern,
        ns1:CancelCasePattern,
        ns1:CancelRegionPattern,
        ns1:CancellingDiscriminatorPattern,
        ns1:CancellingPartialJoinMIPattern,
        ns1:CancellingPartialJoinPattern,
        ns1:CriticalSectionPattern,
        ns1:DeferredChoicePattern,
        ns1:DynamicPartialJoinMIPattern,
        ns1:ExclusiveChoicePattern,
        ns1:ExplicitTerminationPattern,
        ns1:GeneralSyncMergePattern,
        ns1:GeneralizedANDJoinPattern,
        ns1:HierarchicalCancellationPattern,
        ns1:ImplicitTerminationPattern,
        ns1:InterleavedParallelPattern,
        ns1:InterleavedRoutingPattern,
        ns1:MIDesignTimePattern,
        ns1:MINoRuntimePattern,
        ns1:MIRuntimePattern,
        ns1:MIWithoutSyncPattern,
        ns1:MilestonePattern,
        ns1:MultiChoicePattern,
        ns1:MultiMergePattern,
        ns1:NonLocalSyncPattern,
        ns1:ParallelSplitPattern,
        ns1:PersistentTriggerPattern,
        ns1:RecursionPattern,
        ns1:SequencePattern,
        ns1:SimpleMergePattern,
        ns1:StaticPartialJoinMIPattern,
        ns1:StructuredDiscriminatorPattern,
        ns1:StructuredLoopPattern,
        ns1:StructuredPartialJoinPattern,
        ns1:StructuredSyncMergePattern,
        ns1:SynchronizationPattern,
        ns1:ThreadMergePattern,
        ns1:ThreadSplitPattern,
        ns1:TransientTriggerPattern ;
    rdfs:comment "Main registry instance containing all patterns" .

ns1:requiredFeatures a owl:DatatypeProperty ;
    rdfs:label "Required Features" ;
    rdfs:comment "CPU features needed (SIMD, atomic, prefetch)" ;
    rdfs:domain ns1:BitFlowPattern ;
    rdfs:range xsd:string .

<http://bitflow.ai/ontology/telemetry#actualTicks> a owl:DatatypeProperty ;
    rdfs:label "Actual Ticks" ;
    rdfs:comment "Measured CPU ticks consumed" ;
    rdfs:domain <http://bitflow.ai/ontology/telemetry#ExecutionMetrics> ;
    rdfs:range xsd:integer .

<http://bitflow.ai/ontology/telemetry#hasBlake3Hash> a owl:DatatypeProperty ;
    rdfs:label "Blake3 Hash" ;
    rdfs:comment "Cryptographic hash of execution data" ;
    rdfs:domain <http://bitflow.ai/ontology/telemetry#ExecutionMetrics> ;
    rdfs:range xsd:string .

<http://bitflow.ai/ontology/telemetry#memoryUsage> a owl:DatatypeProperty ;
    rdfs:label "Memory Usage" ;
    rdfs:comment "Scratch memory consumed in bytes" ;
    rdfs:domain <http://bitflow.ai/ontology/telemetry#ExecutionMetrics> ;
    rdfs:range xsd:integer .

<http://bitflow.ai/ontology/telemetry#taskState> a owl:DatatypeProperty ;
    rdfs:label "Task State" ;
    rdfs:comment "Current execution state (EXECUTING, COMPLETED, etc.)" ;
    rdfs:domain <http://bitflow.ai/ontology/telemetry#ExecutionMetrics> ;
    rdfs:range xsd:string .

