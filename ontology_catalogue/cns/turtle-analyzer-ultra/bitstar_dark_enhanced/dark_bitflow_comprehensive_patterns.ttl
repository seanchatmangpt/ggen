ns2:NotExistsCascade_0_395d9e13c44f a sh:NodeShape ;
    ns2:nestingDepth 1 ;
    sh:sparql "SELECT ?this WHERE { ?this a hyper:Entity . NOT EXISTS { ?this hyper:level0 ?val0 . } }" .

ns2:NotExistsCascade_1_b63b37006c7b a sh:NodeShape ;
    ns2:nestingDepth 2 ;
    sh:sparql "SELECT ?this WHERE { ?this a hyper:Entity . NOT EXISTS { ?this hyper:level0 ?val0 . NOT EXISTS { ?this hyper:level1 ?val1 . }} }" .

ns2:NotExistsCascade_2_bdb1a453332d a sh:NodeShape ;
    ns2:nestingDepth 3 ;
    sh:sparql "SELECT ?this WHERE { ?this a hyper:Entity . NOT EXISTS { ?this hyper:level0 ?val0 . NOT EXISTS { ?this hyper:level1 ?val1 . NOT EXISTS { ?this hyper:level2 ?val2 . }}} }" .

ns2:NotExistsCascade_3_824f7b99df18 a sh:NodeShape ;
