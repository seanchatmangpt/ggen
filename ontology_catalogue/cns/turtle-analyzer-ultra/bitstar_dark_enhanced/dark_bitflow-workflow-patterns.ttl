@prefix ns1: <http://bitflow.org/ontology/performance#> .
@prefix ns2: <http://hyperintelligence.ai/patterns#> .
@prefix ns3: <http://bitflow.org/ontology/workflow-patterns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ns1:LatencyMetric a owl:Class ;
    rdfs:label "Latency Metric"@en ;
    rdfs:comment "Response time measurement"@en ;
    rdfs:subClassOf ns1:PerformanceMetric .

ns1:MemoryMetric a owl:Class ;
    rdfs:label "Memory Metric"@en ;
    rdfs:comment "Memory usage measurement"@en ;
    rdfs:subClassOf ns1:PerformanceMetric .

ns1:ThroughputMetric a owl:Class ;
    rdfs:label "Throughput Metric"@en ;
    rdfs:comment "Operations per second measurement"@en ;
    rdfs:subClassOf ns1:PerformanceMetric .

ns1:estimatedLatency a owl:DatatypeProperty ;
    rdfs:label "estimated latency"@en ;
    rdfs:comment "Estimated execution latency in nanoseconds"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:int .

ns1:estimatedThroughput a owl:DatatypeProperty ;
    rdfs:label "estimated throughput"@en ;
    rdfs:comment "Estimated operations per second"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:int .

ns1:executionComplexity a owl:DatatypeProperty ;
    rdfs:label "execution complexity"@en ;
    rdfs:comment "Big-O notation for pattern execution complexity"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:string .

ns1:memoryFootprint a owl:DatatypeProperty ;
    rdfs:label "memory footprint"@en ;
    rdfs:comment "Memory usage in bytes for pattern execution"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:int .

<http://bitflow.org/ontology/workflow-patterns> a owl:Ontology ;
    rdfs:label "BitFlow Workflow Patterns Ontology"@en ;
    rdfs:comment """Comprehensive OWL ontology for 43 van der Aalst workflow patterns 
                    implemented in BitFlow system. Addresses performance fraud issues 
                    and provides semantic framework for missing patterns."""@en ;
    rdfs:seeAlso <http://workflowpatterns.com>,
        <https://github.com/bitflow-engine/bitflow> ;
    owl:imports <http://www.yawlfoundation.org/ontology> ;
    owl:versionIRI <http://bitflow.org/ontology/workflow-patterns/2.0> ;
    owl:versionInfo "2.0.0" .

ns3:AdaptiveLoadBalancing a ns3:HighPerformancePattern ;
    rdfs:label "Adaptive Load Balancing (BF-43)"@en ;
    ns1:estimatedLatency 40 ;
    ns1:estimatedThroughput 2500000 ;
    ns1:executionComplexity "O(log n)" ;
    ns1:memoryFootprint 256 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 43 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "BF-43" ;
    rdfs:comment "Dynamic work distribution based on system load"@en .

ns3:ArbitraryTermination a ns3:StructuralPattern ;
    rdfs:label "Arbitrary Cycles (WCP-10)"@en ;
    ns1:estimatedLatency 2000 ;
    ns1:estimatedThroughput 50000 ;
    ns1:executionComplexity "O(k*n)" ;
    ns1:memoryFootprint 512 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 10 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "WCP-10" ;
    rdfs:comment "Ability to represent cycles in workflow with single entry/exit point"@en .

ns3:BackpressureControl a ns3:StreamProcessingPattern ;
    rdfs:label "Backpressure Control (BF-30)"@en ;
    ns1:estimatedLatency 110 ;
    ns1:estimatedThroughput 900000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 128 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 30 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "BF-30" ;
    rdfs:comment "Flow control to prevent memory exhaustion"@en .

ns3:BitFlowPerformanceFraud a ns3:PerformanceFraudThreshold ;
    rdfs:label "BitFlow Performance Fraud Detection"@en ;
    ns3:memoryLeakThreshold 392167424 ;
    ns3:performanceFraudFactor 52704.0 ;
    rdfs:comment "Specific thresholds for BitFlow performance fraud detection"@en .

ns3:BulkExecution a ns3:StreamProcessingPattern ;
    rdfs:label "Bulk Execution (BF-26)"@en ;
    ns1:estimatedLatency 50 ;
    ns1:estimatedThroughput 2000000 ;
    ns1:executionComplexity "O(n/k)" ;
    ns1:memoryFootprint 1024 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 26 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "BF-26" ;
    rdfs:comment "Execute multiple instances in vectorized batch - CRITICAL for 52,704x performance fraud fix"@en .

ns3:CacheConsciousLayout a ns3:HighPerformancePattern ;
    rdfs:label "Cache-Conscious Layout (BF-38)"@en ;
    ns1:estimatedLatency 25 ;
    ns1:estimatedThroughput 4000000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 96 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 38 ;
    ns3:performanceImpact "HIGH" ;
    ns3:vdaalstId "BF-38" ;
    rdfs:comment "Cache-friendly data structure layout"@en .

ns3:CancelCase a ns3:CancellationPattern ;
    rdfs:label "Cancel Case (WCP-20)"@en ;
    ns1:estimatedLatency 250 ;
    ns1:estimatedThroughput 400000 ;
    ns1:executionComplexity "O(n)" ;
    ns1:memoryFootprint 128 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForPerformance false ;
    ns3:patternId 20 ;
    ns3:performanceImpact "MEDIUM" ;
    ns3:vdaalstId "WCP-20" ;
    rdfs:comment "Ability to remove entire case from workflow"@en .

ns3:CancelTask a ns3:CancellationPattern ;
    rdfs:label "Cancel Task (WCP-19)"@en ;
    ns1:estimatedLatency 120 ;
    ns1:estimatedThroughput 850000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 32 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForPerformance false ;
    ns3:patternId 19 ;
    ns3:performanceImpact "LOW" ;
    ns3:vdaalstId "WCP-19" ;
    rdfs:comment "Ability to withdraw enabled task instance"@en .

ns3:DeferredChoice a ns3:StateBasedPattern ;
    rdfs:label "Deferred Choice (WCP-16)"@en ;
    ns1:estimatedLatency 550 ;
    ns1:estimatedThroughput 180000 ;
    ns1:executionComplexity "O(n)" ;
    ns1:memoryFootprint 160 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 16 ;
    ns3:performanceImpact "HIGH" ;
    ns3:vdaalstId "WCP-16" ;
    rdfs:comment "Choice between alternatives made by environment, not workflow"@en .

ns3:ExclusiveChoice a ns3:BasicControlFlowPattern ;
    rdfs:label "Exclusive Choice (WCP-4)"@en ;
    ns1:estimatedLatency 150 ;
    ns1:estimatedThroughput 800000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 48 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForPerformance false ;
    ns3:mapsToYAWLConstruct <http://www.yawlfoundation.org/ontology#XORSplit> ;
    ns3:patternId 4 ;
    ns3:performanceImpact "MEDIUM" ;
    ns3:requires ns3:SimpleMerge ;
    ns3:vdaalstId "WCP-4" ;
    rdfs:comment "Point where single thread chooses one of several alternatives"@en .

ns3:GeneralizedSynchronizingMerge a ns3:AdvancedBranchingPattern ;
    rdfs:label "Generalized Synchronizing Merge (WCP-23)"@en ;
    ns1:estimatedLatency 1500 ;
    ns1:estimatedThroughput 60000 ;
    ns1:executionComplexity "O(2^n)" ;
    ns1:memoryFootprint 512 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 23 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "WCP-23" ;
    rdfs:comment "Merge that synchronizes based on runtime conditions"@en .

ns3:ImplicitTermination a ns3:StructuralPattern ;
    rdfs:label "Implicit Termination (WCP-11)"@en ;
    ns1:estimatedLatency 110 ;
    ns1:estimatedThroughput 900000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 24 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForPerformance false ;
    ns3:patternId 11 ;
    ns3:performanceImpact "LOW" ;
    ns3:vdaalstId "WCP-11" ;
    rdfs:comment "Workflow terminates when no more tasks can be activated"@en .

ns3:InterleavedParallelRouting a ns3:StateBasedPattern ;
    rdfs:label "Interleaved Parallel Routing (WCP-17)"@en ;
    ns1:estimatedLatency 10000 ;
    ns1:estimatedThroughput 10000 ;
    ns1:executionComplexity "O(n!)" ;
    ns1:memoryFootprint 1024 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 17 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "WCP-17" ;
    rdfs:comment "Set of tasks executed in arbitrary order"@en .

ns3:LockFreeCoordination a ns3:HighPerformancePattern ;
    rdfs:label "Lock-Free Coordination (BF-36)"@en ;
    ns1:estimatedLatency 20 ;
    ns1:estimatedThroughput 5000000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 64 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 36 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "BF-36" ;
    rdfs:comment "Lock-free synchronization using atomic operations"@en .

ns3:Milestone a ns3:StateBasedPattern ;
    rdfs:label "Milestone (WCP-18)"@en ;
    ns1:estimatedLatency 350 ;
    ns1:estimatedThroughput 300000 ;
    ns1:executionComplexity "O(n)" ;
    ns1:memoryFootprint 144 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance false ;
    ns3:patternId 18 ;
    ns3:performanceImpact "MEDIUM" ;
    ns3:vdaalstId "WCP-18" ;
    rdfs:comment "Task enabled when milestone is achieved and remains valid"@en .

ns3:MultiChoice a ns3:AdvancedBranchingPattern ;
    rdfs:label "Multi-Choice (WCP-6)"@en ;
    ns1:estimatedLatency 1000 ;
    ns1:estimatedThroughput 100000 ;
    ns1:executionComplexity "O(2^n)" ;
    ns1:memoryFootprint 128 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 6 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:requires ns3:StructuredSynchronizingMerge ;
    ns3:vdaalstId "WCP-6" ;
    rdfs:comment "Point where one or more branches can be chosen based on decision"@en .

ns3:MultiMerge a ns3:AdvancedBranchingPattern ;
    rdfs:label "Multi-Merge (WCP-8)"@en ;
    ns1:estimatedLatency 180 ;
    ns1:estimatedThroughput 600000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 72 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForPerformance false ;
    ns3:patternId 8 ;
    ns3:performanceImpact "MEDIUM" ;
    ns3:vdaalstId "WCP-8" ;
    rdfs:comment "Merge point that converges multiple threads without synchronization"@en .

ns3:MultipleInstancesWithAPrioriDesignTimeKnowledge a ns3:MultipleInstancePattern ;
    rdfs:label "Multiple Instances with A Priori Design Time Knowledge (WCP-13)"@en ;
    ns1:estimatedLatency 500 ;
    ns1:estimatedThroughput 200000 ;
    ns1:executionComplexity "O(n)" ;
    ns1:memoryFootprint 256 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 13 ;
    ns3:performanceImpact "HIGH" ;
    ns3:vdaalstId "WCP-13" ;
    rdfs:comment "Multiple instances where number is known at design time"@en .

ns3:MultipleInstancesWithAPrioriRuntimeKnowledge a ns3:MultipleInstancePattern ;
    rdfs:label "Multiple Instances with A Priori Runtime Knowledge (WCP-14)"@en ;
    ns1:estimatedLatency 750 ;
    ns1:estimatedThroughput 120000 ;
    ns1:executionComplexity "O(n)" ;
    ns1:memoryFootprint 320 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 14 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "WCP-14" ;
    rdfs:comment "Multiple instances where number is determined at runtime before activation"@en .

ns3:MultipleInstancesWithoutAPrioriRuntimeKnowledge a ns3:MultipleInstancePattern ;
    rdfs:label "Multiple Instances without A Priori Runtime Knowledge (WCP-15)"@en ;
    ns1:estimatedLatency 2000 ;
    ns1:estimatedThroughput 50000 ;
    ns1:executionComplexity "O(n^2)" ;
    ns1:memoryFootprint 768 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 15 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "WCP-15" ;
    rdfs:comment "Multiple instances where number is not predetermined"@en .

ns3:MultipleInstancesWithoutSynchronization a ns3:MultipleInstancePattern ;
    rdfs:label "Multiple Instances without Synchronization (WCP-12)"@en ;
    ns1:estimatedLatency 600 ;
    ns1:estimatedThroughput 150000 ;
    ns1:executionComplexity "O(n)" ;
    ns1:memoryFootprint 384 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 12 ;
    ns3:performanceImpact "HIGH" ;
    ns3:vdaalstId "WCP-12" ;
    rdfs:comment "Multiple instances of task without synchronization"@en .

ns3:NUMAAwareScheduling a ns3:HighPerformancePattern ;
    rdfs:label "NUMA-Aware Scheduling (BF-37)"@en ;
    ns1:estimatedLatency 35 ;
    ns1:estimatedThroughput 3000000 ;
    ns1:executionComplexity "O(log n)" ;
    ns1:memoryFootprint 192 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 37 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "BF-37" ;
    rdfs:comment "NUMA topology-aware task scheduling"@en .

ns3:ParallelSplit a ns3:BasicControlFlowPattern ;
    rdfs:label "Parallel Split (WCP-2)"@en ;
    ns1:estimatedLatency 200 ;
    ns1:estimatedThroughput 500000 ;
    ns1:executionComplexity "O(n)" ;
    ns1:memoryFootprint 64 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForPerformance true ;
    ns3:mapsToYAWLConstruct <http://www.yawlfoundation.org/ontology#ANDSplit> ;
    ns3:patternId 2 ;
    ns3:performanceImpact "HIGH" ;
    ns3:requires ns3:Synchronization ;
    ns3:vdaalstId "WCP-2" ;
    rdfs:comment "Point where single thread splits into multiple parallel threads"@en .

ns3:PersistentTrigger a ns3:StateBasedPattern ;
    rdfs:label "Persistent Trigger (WCP-25)"@en ;
    ns1:estimatedLatency 300 ;
    ns1:estimatedThroughput 350000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 128 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance false ;
    ns3:patternId 25 ;
    ns3:performanceImpact "MEDIUM" ;
    ns3:vdaalstId "WCP-25" ;
    rdfs:comment "Task triggered by persistent external signal"@en .

ns3:PipelinedExecution a ns3:StreamProcessingPattern ;
    rdfs:label "Pipelined Execution (BF-27)"@en ;
    ns1:estimatedLatency 75 ;
    ns1:estimatedThroughput 1500000 ;
    ns1:executionComplexity "O(n+k)" ;
    ns1:memoryFootprint 512 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 27 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "BF-27" ;
    rdfs:comment "Pipeline stages with overlapping execution - CRITICAL for 374MB memory leak fix"@en .

ns3:Recursion a ns3:StructuralPattern ;
    rdfs:label "Recursion (WCP-22)"@en ;
    ns1:estimatedLatency 5000 ;
    ns1:estimatedThroughput 20000 ;
    ns1:executionComplexity "O(k^n)" ;
    ns1:memoryFootprint 2048 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 22 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "WCP-22" ;
    rdfs:comment "Ability for task to call itself recursively"@en .

ns3:Sequence a ns3:BasicControlFlowPattern ;
    rdfs:label "Sequence (WCP-1)"@en ;
    ns1:estimatedLatency 100 ;
    ns1:estimatedThroughput 1000000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 32 ;
    ns3:bitflowImplemented true ;
    ns3:criticalForPerformance false ;
    ns3:mapsToYAWLConstruct <http://www.yawlfoundation.org/ontology#SequenceTask> ;
    ns3:patternId 1 ;
    ns3:performanceImpact "LOW" ;
    ns3:vdaalstId "WCP-1" ;
    rdfs:comment "Task A followed by Task B in sequential order"@en .

ns3:StreamAggregation a ns3:StreamProcessingPattern ;
    rdfs:label "Stream Aggregation (BF-29)"@en ;
    ns1:estimatedLatency 85 ;
    ns1:estimatedThroughput 1200000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 256 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 29 ;
    ns3:performanceImpact "HIGH" ;
    ns3:vdaalstId "BF-29" ;
    rdfs:comment "Incremental aggregation with state management"@en .

ns3:StreamWindowing a ns3:StreamProcessingPattern ;
    rdfs:label "Stream Windowing (BF-28)"@en ;
    ns1:estimatedLatency 125 ;
    ns1:estimatedThroughput 800000 ;
    ns1:executionComplexity "O(w)" ;
    ns1:memoryFootprint 768 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 28 ;
    ns3:performanceImpact "HIGH" ;
    ns3:vdaalstId "BF-28" ;
    rdfs:comment "Time-based and count-based windowing for stream processing"@en .

ns3:StructuredDiscriminatorMerge a ns3:StructuralPattern ;
    rdfs:label "Structured Discriminator (WCP-9)"@en ;
    ns1:estimatedLatency 800 ;
    ns1:estimatedThroughput 200000 ;
    ns1:executionComplexity "O(n)" ;
    ns1:memoryFootprint 192 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 9 ;
    ns3:performanceImpact "HIGH" ;
    ns3:vdaalstId "WCP-9" ;
    rdfs:comment "Merge that waits for first branch to complete, then continues"@en .

ns3:StructuredLoop a ns3:StructuralPattern ;
    rdfs:label "Structured Loop (WCP-21)"@en ;
    ns1:estimatedLatency 1000 ;
    ns1:estimatedThroughput 100000 ;
    ns1:executionComplexity "O(k*n)" ;
    ns1:memoryFootprint 256 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance true ;
    ns3:patternId 21 ;
    ns3:performanceImpact "CRITICAL" ;
    ns3:vdaalstId "WCP-21" ;
    rdfs:comment "Ability to execute task/subprocess repeatedly"@en .

ns3:TransientTrigger a ns3:StateBasedPattern ;
    rdfs:label "Transient Trigger (WCP-24)"@en ;
    ns1:estimatedLatency 250 ;
    ns1:estimatedThroughput 400000 ;
    ns1:executionComplexity "O(1)" ;
    ns1:memoryFootprint 96 ;
    ns3:bitflowImplemented false ;
    ns3:criticalForPerformance false ;
    ns3:patternId 24 ;
    ns3:performanceImpact "MEDIUM" ;
    ns3:vdaalstId "WCP-24" ;
    rdfs:comment "Task triggered by transient external event"@en .

ns3:bitflowImplemented a owl:DatatypeProperty ;
    rdfs:label "BitFlow implemented"@en ;
    rdfs:comment "Whether pattern is implemented in current BitFlow version"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:boolean .

ns3:criticalForPerformance a owl:DatatypeProperty ;
    rdfs:label "critical for performance"@en ;
    rdfs:comment "Whether pattern is critical for addressing performance issues"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:boolean .

ns3:memoryLeakThreshold a owl:DatatypeProperty ;
    rdfs:label "memory leak threshold"@en ;
    rdfs:comment "Memory usage threshold for leak detection (374MB)"@en ;
    rdfs:domain ns3:PerformanceFraudThreshold ;
    rdfs:range xsd:long .

ns3:patternId a owl:DatatypeProperty ;
    rdfs:label "pattern ID"@en ;
    rdfs:comment "Numeric identifier for pattern"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:int .

ns3:performanceFraudFactor a owl:DatatypeProperty ;
    rdfs:label "performance fraud factor"@en ;
    rdfs:comment "Multiplier indicating performance degradation (52,704x)"@en ;
    rdfs:domain ns3:PerformanceFraudThreshold ;
    rdfs:range xsd:double .

ns3:performanceImpact a owl:DatatypeProperty ;
    rdfs:label "performance impact"@en ;
    rdfs:comment "Level of performance impact (LOW, MEDIUM, HIGH, CRITICAL)"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range [ owl:oneOf ( "LOW" "MEDIUM" "HIGH" "CRITICAL" ) ] .

ns3:vdaalstId a owl:DatatypeProperty ;
    rdfs:label "van der Aalst ID"@en ;
    rdfs:comment "Original van der Aalst pattern identifier (e.g., WCP-1)"@en ;
    rdfs:domain ns3:WorkflowPattern ;
    rdfs:range xsd:string .

