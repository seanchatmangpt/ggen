# =============================================================================
# DFLSS Critical to Quality Metrics
# =============================================================================

fp:MaxAdverseExcursion a fp:DFLSSCQ ;
    rdfs:label "Maximum Adverse Excursion" ;
    rdfs:comment "Maximum unrealized loss during trade lifecycle" ;
    fp:hasLimit "12"^^xsd:float ;
    fp:hasUnit "basis_points" ;
    fp:hasSigmaTarget "6"^^xsd:float .

fp:RealizedSlippage a fp:DFLSSCQ ;
    rdfs:label "Realized Slippage" ;
    rdfs:comment "Actual fill price vs expected price difference" ;
    fp:hasLimit "0.9"^^xsd:float ;
    fp:hasUnit "basis_points" ;
    fp:hasSigmaTarget "6"^^xsd:float .

fp:TimeInMarket a fp:DFLSSCQ ;
    rdfs:label "Time In Market" ;
    rdfs:comment "Total position hold time" ;
    fp:hasLimit "240"^^xsd:float ;
    fp:hasUnit "seconds" ;
    fp:hasSigmaTarget "6"^^xsd:float .

fp:ExitLatency a fp:DFLSSCQ ;
    rdfs:label "Exit Latency" ;
    rdfs:comment "Time from exit signal to position close" ;
    fp:hasLimit "1.8"^^xsd:float ;
    fp:hasUnit "hops" ;
    fp:hasSigmaTarget "6"^^xsd:float .

fp:TailRiskBps a fp:DFLSSCQ ;
    rdfs:label "Tail Risk Basis Points" ;
    rdfs:comment "95th percentile risk exposure" ;
    fp:hasLimit "7.5"^^xsd:float ;
    fp:hasUnit "basis_points" ;
    fp:hasSigmaTarget "6"^^xsd:float .

# =============================================================================
# 8-Space Constraints
# =============================================================================

fp:EightSpaceMax a fp:EightSpaceConstraint ;
    rdfs:label "8-Space Maximum Constraints" ;
    rdfs:comment "BitStar 8-bit computational limits" ;
    fp:maxTicks "8"^^xsd:integer ;
    fp:maxHops "8"^^xsd:integer ;
    fp:positionSizeBits "8"^^xsd:integer ;
    fp:maxMemoryMB "128"^^xsd:integer ;
    fp:maxCores "8"^^xsd:integer .

# =============================================================================
# Pass/Fail Predicates for Patterns
# =============================================================================

# Micro Impulse Predicates
fp:MicroImpulsePassPredicate a fp:PassFailPredicate ;
    rdfs:label "Micro Impulse Pass Predicate" ;
    rdfs:comment "Pass conditions for micro impulse patterns" ;
    fp:requiresCondition "order_book_imbalance_gt_2_1" ;
    fp:requiresCondition "volatility_percentile_lt_40" ;
    fp:requiresCondition "liquidity_depth_gt_1M" ;
    fp:requiresCondition "news_delta_benign" .

# Volatility Breakout Predicates
fp:VolatilityBreakoutPassPredicate a fp:PassFailPredicate ;
    rdfs:label "Volatility Breakout Pass Predicate" ;
    rdfs:comment "Pass conditions for volatility breakout patterns" ;
    fp:requiresCondition "volatility_percentile_gt_70" ;
    fp:requiresCondition "liquidity_spread_lt_1_5" ;
    fp:requiresCondition "news_sentiment_directional" ;
    fp:requiresCondition "cross_asset_confirmation" .

# Cross Asset Momentum Predicates
fp:CrossAssetMomentumPassPredicate a fp:PassFailPredicate ;
    rdfs:label "Cross Asset Momentum Pass Predicate" ;
    rdfs:comment "Pass conditions for cross asset momentum patterns" ;
    fp:requiresCondition "dxy_correlation_gt_0_7" ;
    fp:requiresCondition "es_correlation_gt_0_65" ;
    fp:requiresCondition "bonds_correlation_consistent" ;
    fp:requiresCondition "macro_headline_supportive" .

# Liquidity Gap Fade Predicates
fp:LiquidityGapFadePassPredicate a fp:PassFailPredicate ;
    rdfs:label "Liquidity Gap Fade Pass Predicate" ;
    rdfs:comment "Pass conditions for liquidity gap fade patterns" ;
    fp:requiresCondition "liquidity_gap_identified" ;
    fp:requiresCondition "order_flow_reversal_signal" ;
    fp:requiresCondition "volatility_mean_reversion" ;
    fp:requiresCondition "session_transition_timing" .

# News Momentum Predicates
fp:NewsMomentumPassPredicate a fp:PassFailPredicate ;
    rdfs:label "News Momentum Pass Predicate" ;
    rdfs:comment "Pass conditions for news momentum patterns" ;
    fp:requiresCondition "news_surprise_gt_threshold" ;
    fp:requiresCondition "market_reaction_directional" ;
    fp:requiresCondition "liquidity_adequate" ;
    fp:requiresCondition "cross_asset_follow_through" .

# =============================================================================
# Lens Properties
# =============================================================================

fp:hasImbalanceThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "Imbalance Threshold" .

fp:hasDepthThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:integer ;
    rdfs:label "Depth Threshold" .

fp:hasFlowThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "Flow Threshold" .

fp:hasSentimentThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "Sentiment Threshold" .

fp:hasPolicyThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "Policy Threshold" .

fp:hasDXYThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "DXY Threshold" .

fp:hasESThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "ES Threshold" .

fp:hasBondsThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "Bonds Threshold" .

fp:hasVolPercentileThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "Vol Percentile Threshold" .

fp:hasSpreadThreshold a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "Spread Threshold" .

fp:hasTimeWindow a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:integer ;
    rdfs:label "Time Window" .

fp:hasReliability a owl:DatatypeProperty ;
    rdfs:domain fp:Lens ;
    rdfs:range xsd:float ;
    rdfs:label "Reliability Score" .

# =============================================================================
# Pattern Properties
# =============================================================================

fp:requiresLenses a owl:ObjectProperty ;
    rdfs:domain fp:TradingPattern ;
    rdfs:range fp:Lens ;
    rdfs:label "Requires Lenses" .

fp:hasLeverage a owl:DatatypeProperty ;
    rdfs:domain fp:TradingPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "Leverage" .

fp:hasMaxTicks a owl:DatatypeProperty ;
    rdfs:domain fp:TradingPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "Maximum Ticks" .

fp:hasMaxHops a owl:DatatypeProperty ;
    rdfs:domain fp:TradingPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "Maximum Hops" .

fp:hasPositionSizeBits a owl:DatatypeProperty ;
    rdfs:domain fp:TradingPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "Position Size Bits" .

# =============================================================================
# CTQ Properties
# =============================================================================

fp:hasLimit a owl:DatatypeProperty ;
    rdfs:domain fp:DFLSSCQ ;
    rdfs:range xsd:float ;
    rdfs:label "Quality Limit" .

fp:hasUnit a owl:DatatypeProperty ;
    rdfs:domain fp:DFLSSCQ ;
    rdfs:range xsd:string ;
    rdfs:label "Unit" .

fp:hasSigmaTarget a owl:DatatypeProperty ;
    rdfs:domain fp:DFLSSCQ ;
    rdfs:range xsd:float ;
    rdfs:label "Sigma Target" .

# =============================================================================
# Predicate Properties
# =============================================================================

fp:requiresCondition a owl:DatatypeProperty ;
    rdfs:domain fp:PassFailPredicate ;
    rdfs:range xsd:string ;
    rdfs:label "Required Condition" .

# =============================================================================
# 8-Space Constraint Properties
# =============================================================================

fp:maxTicks a owl:DatatypeProperty ;
    rdfs:domain fp:EightSpaceConstraint ;
    rdfs:range xsd:integer ;
    rdfs:label "Maximum Ticks" .

fp:maxHops a owl:DatatypeProperty ;
    rdfs:domain fp:EightSpaceConstraint ;
    rdfs:range xsd:integer ;
    rdfs:label "Maximum Hops" .

fp:positionSizeBits a owl:DatatypeProperty ;
    rdfs:domain fp:EightSpaceConstraint ;
    rdfs:range xsd:integer ;
    rdfs:label "Position Size Bits" .

fp:maxMemoryMB a owl:DatatypeProperty ;
    rdfs:domain fp:EightSpaceConstraint ;
    rdfs:range xsd:integer ;
    rdfs:label "Maximum Memory MB" .

fp:maxCores a owl:DatatypeProperty ;
    rdfs:domain fp:EightSpaceConstraint ;
    rdfs:range xsd:integer ;
    rdfs:label "Maximum Cores" .

# =============================================================================
# SHACL Validation Constraints
# =============================================================================

fp:EightSpaceValidation a shacl:NodeShape ;
    shacl:targetClass fp:TradingPattern ;
    shacl:property [
        shacl:path fp:hasMaxTicks ;
        shacl:maxInclusive "8"^^xsd:integer ;
        shacl:message "Pattern must complete within 8 ticks"
    ] ;
    shacl:property [
        shacl:path fp:hasMaxHops ;
        shacl:maxInclusive "8"^^xsd:integer ;
        shacl:message "Pattern must execute within 8 hops"
    ] ;
    shacl:property [
        shacl:path fp:hasPositionSizeBits ;
        shacl:equals "8"^^xsd:integer ;
        shacl:message "Position size must be 8-bit encoded"
    ] .

fp:LeverageValidation a shacl:NodeShape ;
    shacl:targetClass fp:TradingPattern ;
    shacl:property [
        shacl:path fp:hasLeverage ;
        shacl:equals "50"^^xsd:integer ;
        shacl:message "All patterns must use 50x leverage"
    ] .

fp:CTQValidation a shacl:NodeShape ;
    shacl:targetClass fp:DFLSSCQ ;
    shacl:property [
        shacl:path fp:hasLimit ;
        shacl:minExclusive "0"^^xsd:float ;
        shacl:message "CTQ limits must be positive"
    ] ;
    shacl:property [
        shacl:path fp:hasSigmaTarget ;
        shacl:equals "6"^^xsd:float ;
        shacl:message "All CTQs must target Six-Sigma quality"
    ] .

fp:LensValidation a shacl:NodeShape ;
    shacl:targetClass fp:Lens ;
    shacl:property [
        shacl:path fp:hasReliability ;
        shacl:minInclusive "0"^^xsd:float ;
        shacl:maxInclusive "1"^^xsd:float ;
        shacl:message "Lens reliability must be between 0 and 1"
    ] ;
    shacl:property [
        shacl:path fp:hasTimeWindow ;
        shacl:minExclusive "0"^^xsd:integer ;
        shacl:message "Time window must be positive"
    ] .

# =============================================================================
# BitStar Integration Annotations
# =============================================================================

# Processing tick assignments for 8-tick compliance
fp:OrderBookMicroPressure fp:processingTicks "2"^^xsd:integer .
fp:MacroHeadlineDelta fp:processingTicks "1"^^xsd:integer .
fp:CrossAssetCoMotion fp:processingTicks "2"^^xsd:integer .
fp:VolatilityRegime fp:processingTicks "1"^^xsd:integer .
fp:LiquidityState fp:processingTicks "2"^^xsd:integer .

# Validation hashes for production deployment
fp:MicroImpulseLongUSDJPY fp:validationHash "a1b2c3d4e5f6g7h8" .
fp:VolatilityBreakoutUSDJPY fp:validationHash "b2c3d4e5f6g7h8i9" .
fp:CrossAssetMomentumEURUSD fp:validationHash "c3d4e5f6g7h8i9j0" .
fp:LiquidityGapFadeEURUSD fp:validationHash "d4e5f6g7h8i9j0k1" .
fp:NewsMomentumEURUSD fp:validationHash "e5f6g7h8i9j0k1l2" .

# =============================================================================
# Production Performance Targets
# =============================================================================

fp:ProductionTarget a owl:Class ;
    rdfs:label "Production Performance Target" ;
    rdfs:comment "Production-grade performance expectations" .

fp:NanosecondLatency a fp:ProductionTarget ;
    rdfs:label "Nanosecond Latency Target" ;
    fp:hasLatencyTarget "500"^^xsd:integer ;
    fp:hasUnit "nanoseconds" .

fp:SixSigmaQuality a fp:ProductionTarget ;
    rdfs:label "Six Sigma Quality Target" ;
    fp:hasDefectRate "3.4"^^xsd:float ;
    fp:hasUnit "per_million" .

fp:FiftyXLeverage a fp:ProductionTarget ;
    rdfs:label "50x Leverage Target" ;
    fp:hasLeverageMultiplier "50"^^xsd:integer ;
    fp:hasRiskLimit "2.0"^^xsd:float ;
    fp:hasUnit "percent" .