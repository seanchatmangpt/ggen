    fp:hasLeverage "50"^^xsd:integer ;
    fp:hasMaxTicks "8"^^xsd:integer ;
    fp:hasMaxHops "8"^^xsd:integer ;
    fp:hasPositionSizeBits "8"^^xsd:integer .

fp:OrderFlowImbalanceGBPUSD a fp:TradingPattern ;
    rdfs:label "GBP/USD Order Flow Imbalance" ;
