@prefix fp: <http://cns.io/forex/planner#> .
@prefix cns: <http://cns.io/ontology#> .
@prefix e8: <http://bitstar.ai/eight#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix shacl: <http://www.w3.org/ns/shacl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# =============================================================================
# Forex Planner TTL Ontology for 50x Trading
# Nanosecond-precision patterns with 8-Space constraints
# Built for BitStar production deployment
# =============================================================================

<http://cns.io/forex/planner> a owl:Ontology ;
    dcterms:title "CNS Forex Planner Ontology" ;
    dcterms:description "50x leveraged forex trading patterns with 8-Space semantic processing" ;
    dcterms:creator "CNS BitStar Trading System" ;
    dcterms:date "2025-08-10"^^xsd:date ;
    owl:versionInfo "2026.1.1-production" ;
    dcterms:license "Internal CNS Use Only" .

# =============================================================================
# Core Classes
# =============================================================================

fp:ForexPlanner a owl:Class ;
    rdfs:label "Forex Planner" ;
    rdfs:comment "50x trading pattern orchestrator with nanosecond precision" .

fp:TradingPattern a owl:Class ;
    rdfs:label "Trading Pattern" ;
    rdfs:comment "Named pattern with lenses, thresholds, and predicates" .

fp:Lens a owl:Class ;
    rdfs:label "Signal Lens" ;
    rdfs:comment "Independent signal source with defined thresholds" .

fp:DFLSSCQ a owl:Class ;
    rdfs:label "DFLSS Critical to Quality" ;
    rdfs:comment "Six-Sigma quality metric for trading performance" .

fp:EightSpaceConstraint a owl:Class ;
    rdfs:label "8-Space Constraint" ;
    rdfs:comment "BitStar 8-bit computational constraint" .

fp:PassFailPredicate a owl:Class ;
    rdfs:label "Pass/Fail Predicate" ;
    rdfs:comment "Binary decision gate for pattern activation" .

# =============================================================================
# 5 Independent Lenses
# =============================================================================

fp:OrderBookMicroPressure a fp:Lens ;
    rdfs:label "Order Book Micro Pressure" ;
    rdfs:comment "Imbalance, depth, and flow analysis lens" ;
    fp:hasImbalanceThreshold "2.1"^^xsd:float ;
    fp:hasDepthThreshold "1000000"^^xsd:integer ;
    fp:hasFlowThreshold "0.85"^^xsd:float ;
    fp:hasTimeWindow "100"^^xsd:integer ;
    fp:hasReliability "0.876"^^xsd:float .

fp:MacroHeadlineDelta a fp:Lens ;
    rdfs:label "Macro Headline Delta" ;
    rdfs:comment "News sentiment and policy impact lens" ;
    fp:hasSentimentThreshold "0.4"^^xsd:float ;
    fp:hasPolicyThreshold "0.6"^^xsd:float ;
    fp:hasTimeWindow "2000"^^xsd:integer ;
    fp:hasReliability "0.734"^^xsd:float .

fp:CrossAssetCoMotion a fp:Lens ;
    rdfs:label "Cross Asset Co-Motion" ;
    rdfs:comment "DXY, ES, bonds correlation lens" ;
    fp:hasDXYThreshold "0.72"^^xsd:float ;
    fp:hasESThreshold "0.68"^^xsd:float ;
    fp:hasBondsThreshold "0.58"^^xsd:float ;
    fp:hasTimeWindow "500"^^xsd:integer ;
    fp:hasReliability "0.812"^^xsd:float .

fp:VolatilityRegime a fp:Lens ;
    rdfs:label "Volatility Regime" ;
    rdfs:comment "Intraday vol percentile lens" ;
    fp:hasVolPercentileThreshold "35"^^xsd:float ;
    fp:hasSpreadThreshold "1.5"^^xsd:float ;
    fp:hasTimeWindow "300"^^xsd:integer ;
    fp:hasReliability "0.798"^^xsd:float .

fp:LiquidityState a fp:Lens ;
    rdfs:label "Liquidity State" ;
    rdfs:comment "Spreads and depth analysis lens" ;
    fp:hasSpreadThreshold "0.8"^^xsd:float ;
    fp:hasDepthThreshold "2000000"^^xsd:integer ;
    fp:hasTimeWindow "200"^^xsd:integer ;
    fp:hasReliability "0.889"^^xsd:float .

# =============================================================================
# 15 Named Trading Patterns
# =============================================================================

# USD/JPY Patterns
fp:MicroImpulseLongUSDJPY a fp:TradingPattern ;
    rdfs:label "USD/JPY Micro Impulse Long" ;
    rdfs:comment "Micro-second impulse long pattern for USD/JPY" ;
    fp:requiresLenses ( fp:OrderBookMicroPressure fp:CrossAssetCoMotion fp:VolatilityRegime ) ;
    fp:hasLeverage "50"^^xsd:integer ;
    fp:hasMaxTicks "8"^^xsd:integer ;
    fp:hasMaxHops "8"^^xsd:integer ;
    fp:hasPositionSizeBits "8"^^xsd:integer .

fp:MicroImpulseShortUSDJPY a fp:TradingPattern ;
    rdfs:label "USD/JPY Micro Impulse Short" ;
    rdfs:comment "Micro-second impulse short pattern for USD/JPY" ;
    fp:requiresLenses ( fp:OrderBookMicroPressure fp:CrossAssetCoMotion fp:VolatilityRegime ) ;
    fp:hasLeverage "50"^^xsd:integer ;
    fp:hasMaxTicks "8"^^xsd:integer ;
    fp:hasMaxHops "8"^^xsd:integer ;
    fp:hasPositionSizeBits "8"^^xsd:integer .

fp:VolatilityBreakoutUSDJPY a fp:TradingPattern ;
    rdfs:label "USD/JPY Volatility Breakout" ;
    rdfs:comment "High volatility breakout pattern for USD/JPY" ;
    fp:requiresLenses ( fp:VolatilityRegime fp:LiquidityState fp:MacroHeadlineDelta ) ;
    fp:hasLeverage "50"^^xsd:integer ;
    fp:hasMaxTicks "8"^^xsd:integer ;
    fp:hasMaxHops "8"^^xsd:integer ;
    fp:hasPositionSizeBits "8"^^xsd:integer .

