# =============================================================================
# COMMAND RELATIONSHIPS AND DEPENDENCIES
# =============================================================================

# Core Command Dependencies
cli:AnalyzeTurtleCommand cli:dependsOn cli:StatusCommand .
cli:GenerateCommand cli:dependsOn cli:AnalyzeTurtleCommand .
cli:OptimizeCommand cli:dependsOn cli:GenerateCommand .
cli:ValidateCommand cli:dependsOn cli:OptimizeCommand .
cli:DeployCommand cli:dependsOn cli:ValidateCommand .

# Consolidation Relationships (93 -> 8 core commands)
cli:AnalyzeTurtleCommand cli:consolidates [
    a cli:Command ;
    cli:commandName "turtle-parse" ;
    cli:commandGroup "legacy"
] , [
    a cli:Command ;
    cli:commandName "turtle-validate" ;
    cli:commandGroup "legacy"
] , [
    a cli:Command ;
    cli:commandName "rdf-analyze" ;
    cli:commandGroup "legacy"
] .

cli:GenerateCommand cli:consolidates [
    a cli:Command ;
    cli:commandName "bitactor-compile" ;
    cli:commandGroup "legacy"
] , [
    a cli:Command ;
    cli:commandName "code-generate" ;
    cli:commandGroup "legacy"
] , [
    a cli:Command ;
    cli:commandName "c-generate" ;
    cli:commandGroup "legacy"
] .

# DFLS Phase Relationships
cli:StatusCommand cli:implementsPhase dflss:Define .
cli:InitCommand cli:implementsPhase dflss:Define .
cli:AnalyzeTurtleCommand cli:implementsPhase dflss:Measure .
cli:FindLiesCommand cli:implementsPhase dflss:Measure .
cli:SearchCommand cli:implementsPhase dflss:Explore .
cli:GenerateCommand cli:implementsPhase dflss:Develop .
cli:OptimizeCommand cli:implementsPhase dflss:Develop .
cli:ValidateCommand cli:implementsPhase dflss:Implement .
cli:DeployCommand cli:implementsPhase dflss:Implement .

# OTEL Weaver Instrumentation Relationships
cli:StatusCommand cli:generatesSpan [
    a otel:Span ;
    otel:name "cli.system.status" ;
    otel:kind "internal"
] .

cli:AnalyzeTurtleCommand cli:generatesSpan [
    a otel:Span ;
    otel:name "cli.turtle.analyze" ;
    otel:kind "internal"
] ;
cli:generatesMetric [
    a otel:Metric ;
    otel:name "cli.turtle.analyze.file_size" ;
    otel:type "histogram"
] .

cli:FindLiesCommand cli:generatesSpan [
    a otel:Span ;
    otel:name "cli.validation.find_lies" ;
    otel:kind "internal"
] ;
cli:generatesMetric [
    a otel:Metric ;
    otel:name "cli.validation.lies.count" ;
    otel:type "counter"
] .

# =============================================================================
# WEAVER TEMPLATE DEFINITIONS
# =============================================================================

cli:StandardWeaverTemplate a cli:WeaverTemplate ;
    rdfs:label "Standard OTEL Weaver Template" ;
    cli:templateContent """
@app.command("{command_name}")
@weaver.instrument(
    span_name="{span_name}",
    metrics=["{metric_name}"]
)
def {command_name}_wrapper({parameters}):
    ''''{help_text}''''
    with weaver.start_span("{span_name}") as span:
        span.set_attribute("cli.command", "{command_name}")
        span.set_attribute("cli.group", "{command_group}")
        span.set_attribute("cli.priority", "{priority}")
        span.set_attribute("cli.architecture_level", "{architecture_level}")
        
        try:
            start_time = time.time()
            result = {module_name}.{function_name}({parameters})
            duration = time.time() - start_time
            
            span.set_attribute("cli.success", True)
            span.set_attribute("cli.duration", duration)
            
            # Record metric
            {metric_name}.record(duration, {{"command": "{command_name}"}})
            
            return result
        except Exception as e:
            span.set_attribute("cli.success", False)
            span.set_attribute("cli.error", str(e))
            span.set_status(Status(StatusCode.ERROR, str(e)))
            raise
""" .

cli:HeuristicWeaverTemplate a cli:WeaverTemplate ;
    rdfs:label "Heuristic Command OTEL Weaver Template" ;
    cli:templateContent """
@app.command("{command_name}")
@weaver.instrument(
    span_name="{span_name}",
    metrics=["{metric_name}", "cli.heuristics.optimization_score"]
)
def {command_name}_wrapper({parameters}):
    ''''{help_text}''''
    with weaver.start_span("{span_name}") as span:
        span.set_attribute("cli.command", "{command_name}")
        span.set_attribute("cli.group", "{command_group}")
        span.set_attribute("cli.heuristic_algorithm", "{heuristic_algorithm}")
        span.set_attribute("cli.optimization_target", "{optimization_target}")
        
        try:
            start_time = time.time()
            result = {module_name}.{function_name}({parameters})
            duration = time.time() - start_time
            
            span.set_attribute("cli.success", True)
            span.set_attribute("cli.duration", duration)
            
            # Heuristic-specific metrics
            if hasattr(result, 'optimization_score'):
                span.set_attribute("cli.optimization_score", result.optimization_score)
                optimization_score_metric.record(result.optimization_score)
            
            {metric_name}.record(duration, {{"command": "{command_name}"}})
            
            return result
        except Exception as e:
            span.set_attribute("cli.success", False)
            span.set_attribute("cli.error", str(e))
            span.set_status(Status(StatusCode.ERROR, str(e)))
            raise
""" .

# Template Assignments
cli:StatusCommand cli:weaverTemplate cli:StandardWeaverTemplate .
cli:AnalyzeTurtleCommand cli:weaverTemplate cli:HeuristicWeaverTemplate .
cli:FindLiesCommand cli:weaverTemplate cli:HeuristicWeaverTemplate .
cli:GenerateCommand cli:weaverTemplate cli:HeuristicWeaverTemplate .
cli:OptimizeCommand cli:weaverTemplate cli:HeuristicWeaverTemplate .
cli:ValidateCommand cli:weaverTemplate cli:HeuristicWeaverTemplate .
cli:DeployCommand cli:weaverTemplate cli:StandardWeaverTemplate .