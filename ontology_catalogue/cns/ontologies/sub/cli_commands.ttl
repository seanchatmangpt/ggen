    cli:parameterName "file" ;
    cli:parameterType "Path" ;
    cli:required true ;
    cli:typerHelp "Turtle file to analyze" ;
    cli:typerConstraint "existing_file" .

cli:TurtleDetailedOption a cli:Option, cli:TyperAnnotation ;
    cli:parameterName "detailed" ;
