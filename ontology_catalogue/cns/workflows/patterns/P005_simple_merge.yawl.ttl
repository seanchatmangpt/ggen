cns:P005 a yawl:YAWLSpecification ;
    rdfs:label "Simple Merge" ;
    yawl:specVersion "4.0" ;
    trinity:vanDerAalstIndex "5"^^xsd:integer ;
    trinity:maxTicks "8"^^xsd:integer ;
    trinity:deterministicState "true"^^xsd:boolean ;
    trinity:complianceValidated "true"^^xsd:boolean ;
    yawl:decomposesTo cns:P005_net .


cns:P005_net a yawl:Net ;
    rdfs:label "Simple Merge Net" ;
    yawl:inputCondition cns:P005_start ;
    yawl:outputCondition cns:P005_end .

cns:P005_START a cns:FlowNode, yawl:StartNode ;
    cns:hasNodeID "START" ;
    cns:hasNodeType cns:start ;
    trinity:progressTick "0"^^xsd:integer ;
    cns:hasProcessingTimeUs "0"^^xsd:integer ;
    cns:hasPosition "0,0"  ;
    dag:successors (cns:P005_CHOICE) .

cns:P005_CHOICE a cns:FlowNode, yawl:GatewayNode ;
    cns:hasNodeID "CHOICE" ;
    cns:hasNodeType cns:gateway ;
    trinity:progressTick "1"^^xsd:integer ;
    cns:hasProcessingTimeUs "500000"^^xsd:integer ;
    cns:hasPosition "1,0"  ;
    dag:predecessors (cns:P005_START) ;
    dag:successors (cns:P005_TASK1, cns:P005_TASK2) .

cns:P005_TASK1 a cns:FlowNode, yawl:TaskNode ;
    cns:hasNodeID "TASK1" ;
    cns:hasNodeType cns:task ;
    trinity:progressTick "2"^^xsd:integer ;
    cns:hasProcessingTimeUs "2000000"^^xsd:integer ;
    cns:hasPosition "2,-1"  ;
    dag:predecessors (cns:P005_CHOICE) ;
    dag:successors (cns:P005_MERGE) .

cns:P005_TASK2 a cns:FlowNode, yawl:TaskNode ;
    cns:hasNodeID "TASK2" ;
    cns:hasNodeType cns:task ;
    trinity:progressTick "2"^^xsd:integer ;
    cns:hasProcessingTimeUs "2000000"^^xsd:integer ;
    cns:hasPosition "2,1"  ;
    dag:predecessors (cns:P005_CHOICE) ;
    dag:successors (cns:P005_MERGE) .

cns:P005_MERGE a cns:FlowNode, yawl:GatewayNode ;
    cns:hasNodeID "MERGE" ;
    cns:hasNodeType cns:gateway ;
    trinity:progressTick "3"^^xsd:integer ;
    cns:hasProcessingTimeUs "500000"^^xsd:integer ;
    cns:hasPosition "3,0"  ;
    dag:predecessors (cns:P005_TASK1, cns:P005_TASK2) ;
    dag:successors (cns:P005_END) .

cns:P005_END a cns:FlowNode, yawl:EndNode ;
    cns:hasNodeID "END" ;
    cns:hasNodeType cns:end ;
    trinity:progressTick "3"^^xsd:integer ;
    cns:hasProcessingTimeUs "0"^^xsd:integer ;
    cns:hasPosition "4,0"  ;
    dag:predecessors (cns:P005_MERGE) .

# DAG Edge Definitions

cns:edge_001 a cns:FlowEdge, dag:DirectedEdge ;
    dag:hasSource cns:START ;
    dag:hasTarget cns:CHOICE ;
    cns:hasTransitionCondition cns:AutomaticTransition ;
    cns:hasWeight "1.0"^^xsd:decimal .

