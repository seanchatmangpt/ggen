cns:P001 a yawl:YAWLSpecification ;
    rdfs:label "Sequence" ;
    yawl:specVersion "4.0" ;
    trinity:vanDerAalstIndex "1"^^xsd:integer ;
    trinity:maxTicks "8"^^xsd:integer ;
    trinity:deterministicState "true"^^xsd:boolean ;
    trinity:complianceValidated "true"^^xsd:boolean ;
    yawl:decomposesTo cns:P001_net .


cns:P001_net a yawl:Net ;
    rdfs:label "Sequence Net" ;
    yawl:inputCondition cns:P001_start ;
    yawl:outputCondition cns:P001_end .

cns:P001_START a cns:FlowNode, yawl:StartNode ;
    cns:hasNodeID "START" ;
    cns:hasNodeType cns:start ;
    trinity:progressTick "0"^^xsd:integer ;
    cns:hasProcessingTimeUs "0"^^xsd:integer ;
    cns:hasPosition "0,0"  ;
    dag:successors (cns:P001_TASK1) .

cns:P001_TASK1 a cns:FlowNode, yawl:TaskNode ;
    cns:hasNodeID "TASK1" ;
    cns:hasNodeType cns:task ;
    trinity:progressTick "1"^^xsd:integer ;
    cns:hasProcessingTimeUs "1000000"^^xsd:integer ;
    cns:hasPosition "1,0"  ;
    dag:predecessors (cns:P001_START) ;
    dag:successors (cns:P001_END) .

cns:P001_END a cns:FlowNode, yawl:EndNode ;
    cns:hasNodeID "END" ;
    cns:hasNodeType cns:end ;
    trinity:progressTick "2"^^xsd:integer ;
    cns:hasProcessingTimeUs "0"^^xsd:integer ;
    cns:hasPosition "2,0"  ;
    dag:predecessors (cns:P001_TASK1) .

# DAG Edge Definitions

cns:edge_001 a cns:FlowEdge, dag:DirectedEdge ;
    dag:hasSource cns:START ;
    dag:hasTarget cns:TASK1 ;
    cns:hasTransitionCondition cns:AutomaticTransition ;
    cns:hasWeight "1.0"^^xsd:decimal .

cns:edge_002 a cns:FlowEdge, dag:DirectedEdge ;
    dag:hasSource cns:TASK1 ;
    dag:hasTarget cns:END ;
    cns:hasTransitionCondition cns:AutomaticTransition ;
    cns:hasWeight "1.0"^^xsd:decimal .

