cns:P003 a yawl:YAWLSpecification ;
    rdfs:label "Synchronization" ;
    yawl:specVersion "4.0" ;
    trinity:vanDerAalstIndex "3"^^xsd:integer ;
    trinity:maxTicks "8"^^xsd:integer ;
    trinity:deterministicState "true"^^xsd:boolean ;
    trinity:complianceValidated "true"^^xsd:boolean ;
    yawl:decomposesTo cns:P003_net .


cns:P003_net a yawl:Net ;
    rdfs:label "Synchronization Net" ;
    yawl:inputCondition cns:P003_start ;
    yawl:outputCondition cns:P003_end .

cns:P003_START a cns:FlowNode, yawl:StartNode ;
    cns:hasNodeID "START" ;
    cns:hasNodeType cns:start ;
    trinity:progressTick "0"^^xsd:integer ;
    cns:hasProcessingTimeUs "0"^^xsd:integer ;
    cns:hasPosition "0,0"  ;
    dag:successors (cns:P003_SPLIT) .

cns:P003_SPLIT a cns:FlowNode, yawl:GatewayNode ;
    cns:hasNodeID "SPLIT" ;
    cns:hasNodeType cns:gateway ;
    trinity:progressTick "1"^^xsd:integer ;
    cns:hasProcessingTimeUs "500000"^^xsd:integer ;
    cns:hasPosition "1,0"  ;
    dag:predecessors (cns:P003_START) ;
    dag:successors (cns:P003_TASK1, cns:P003_TASK2) .

cns:P003_TASK1 a cns:FlowNode, yawl:TaskNode ;
    cns:hasNodeID "TASK1" ;
    cns:hasNodeType cns:task ;
    trinity:progressTick "2"^^xsd:integer ;
    cns:hasProcessingTimeUs "2000000"^^xsd:integer ;
    cns:hasPosition "2,-1"  ;
    dag:predecessors (cns:P003_SPLIT) ;
    dag:successors (cns:P003_JOIN) .

cns:P003_TASK2 a cns:FlowNode, yawl:TaskNode ;
    cns:hasNodeID "TASK2" ;
    cns:hasNodeType cns:task ;
    trinity:progressTick "2"^^xsd:integer ;
    cns:hasProcessingTimeUs "2000000"^^xsd:integer ;
    cns:hasPosition "2,1"  ;
    dag:predecessors (cns:P003_SPLIT) ;
    dag:successors (cns:P003_JOIN) .

cns:P003_JOIN a cns:FlowNode, yawl:GatewayNode ;
    cns:hasNodeID "JOIN" ;
    cns:hasNodeType cns:gateway ;
    trinity:progressTick "3"^^xsd:integer ;
    cns:hasProcessingTimeUs "500000"^^xsd:integer ;
    cns:hasPosition "3,0"  ;
    dag:predecessors (cns:P003_TASK1, cns:P003_TASK2) ;
    dag:successors (cns:P003_END) .

cns:P003_END a cns:FlowNode, yawl:EndNode ;
    cns:hasNodeID "END" ;
    cns:hasNodeType cns:end ;
    trinity:progressTick "3"^^xsd:integer ;
    cns:hasProcessingTimeUs "0"^^xsd:integer ;
    cns:hasPosition "4,0"  ;
    dag:predecessors (cns:P003_JOIN) .

# DAG Edge Definitions

cns:edge_001 a cns:FlowEdge, dag:DirectedEdge ;
    dag:hasSource cns:START ;
    dag:hasTarget cns:SPLIT ;
    cns:hasTransitionCondition cns:AutomaticTransition ;
    cns:hasWeight "1.0"^^xsd:decimal .

