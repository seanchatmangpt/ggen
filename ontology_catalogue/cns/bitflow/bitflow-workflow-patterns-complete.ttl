    perf:executionComplexity "O(1)" ;
    perf:memoryFootprint 72 ;
    perf:estimatedThroughput 600000 ;
    perf:estimatedLatency 180 .

bwp:StructuredDiscriminator a bwp:AdvancedBranchingPattern ;
    rdfs:label "Structured Discriminator (WCP-9)"@en ;
    rdfs:comment "Merge that waits for first branch to complete, then continues"@en ;
    bwp:patternId 9 ;
    bwp:vdaalstId "WCP-9" ;
    bwp:bitflowImplemented false ;
    bwp:criticalForPerformance true ;
    bwp:criticalForMemory false ;
    bwp:performanceImpact "HIGH" ;
    perf:executionComplexity "O(n)" ;
    perf:memoryFootprint 192 ;
    perf:estimatedThroughput 200000 ;
    perf:estimatedLatency 800 .

bwp:ArbitraryCycles a bwp:StructuralPattern ;
    rdfs:label "Arbitrary Cycles (WCP-10)"@en ;
    rdfs:comment "Ability to represent cycles in workflow with single entry/exit point"@en ;
    bwp:patternId 10 ;
    bwp:vdaalstId "WCP-10" ;
    bwp:bitflowImplemented true ;
    bwp:criticalForPerformance true ;
    bwp:criticalForMemory true ;
    bwp:performanceImpact "CRITICAL" ;
    perf:executionComplexity "O(k*n)" ;
    perf:memoryFootprint 512 ;
    perf:estimatedThroughput 50000 ;
    perf:estimatedLatency 2000 .

bwp:ImplicitTermination a bwp:StructuralPattern ;
    rdfs:label "Implicit Termination (WCP-11)"@en ;
    rdfs:comment "Workflow terminates when no more tasks can be activated"@en ;
    bwp:patternId 11 ;
    bwp:vdaalstId "WCP-11" ;
    bwp:bitflowImplemented true ;
    bwp:criticalForPerformance false ;
    bwp:criticalForMemory false ;
    bwp:performanceImpact "LOW" ;
    perf:executionComplexity "O(1)" ;
    perf:memoryFootprint 24 ;
    perf:estimatedThroughput 900000 ;
    perf:estimatedLatency 110 .

