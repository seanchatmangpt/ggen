# BitFlow Complete Workflow Patterns Ontology v3.0 (Turtle/TTL Format)
# Comprehensive semantic model for all 43 van der Aalst workflow patterns
# Addresses BitFlow performance fraud (52,704x), memory leak prevention (374MB)
# YAWL-compatible format for workflow management systems
# Created by: OWL_Ontology_Architect Agent for BitFlow OWL TTL YAWL implementation
# Date: 2025-08-02
# Version: 3.0.0

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bwp: <http://bitflow.org/ontology/workflow-patterns#> .
@prefix perf: <http://bitflow.org/ontology/performance#> .
@prefix yawl: <http://www.yawlfoundation.org/ontology#> .
@prefix vdaalst: <http://workflowpatterns.com/patterns#> .
@prefix fraud: <http://bitflow.org/ontology/fraud-detection#> .
@prefix sparql: <http://bitflow.org/sparql/patterns#> .

# =====================================================================
# ONTOLOGY METADATA
# =====================================================================

<http://bitflow.org/ontology/workflow-patterns> 
    a owl:Ontology ;
    owl:versionIRI <http://bitflow.org/ontology/workflow-patterns/3.0> ;
    rdfs:label "BitFlow Complete Workflow Patterns Ontology v3.0"@en ;
    rdfs:comment """Complete OWL ontology for all 43 van der Aalst workflow patterns 
                    with BitFlow implementation status, performance fraud detection 
                    (52,704x threshold), memory leak prevention (374MB), and YAWL 
                    compatibility mappings. Designed by OWL_Ontology_Architect agent 
                    for BitFlow OWL TTL YAWL integration."""@en ;
    owl:versionInfo "3.0.0" ;
    rdfs:seeAlso <http://workflowpatterns.com> ;
    rdfs:seeAlso <https://github.com/bitflow-engine/bitflow> ;
    rdfs:seeAlso <https://www.yawlfoundation.org/> ;
    owl:imports <http://www.yawlfoundation.org/ontology> .

# =====================================================================
# ROOT CLASS HIERARCHY
# =====================================================================

## Abstract base classes
bwp:WorkflowPattern a owl:Class ;
    rdfs:label "Workflow Pattern"@en ;
    rdfs:comment "Abstract base class for all 43 van der Aalst workflow patterns"@en ;
    owl:equivalentClass vdaalst:Pattern .

bwp:ControlFlowPattern a owl:Class ;
    rdfs:label "Control Flow Pattern"@en ;
    rdfs:comment "Patterns describing task execution ordering and flow control (Patterns 1-43)"@en ;
    rdfs:subClassOf bwp:WorkflowPattern .

# =====================================================================
# PATTERN CATEGORIES (Complete 43-pattern taxonomy)
# =====================================================================

## Category 1: Basic Control Flow Patterns (1-5) - 80% coverage
bwp:BasicControlFlowPattern a owl:Class ;
    rdfs:label "Basic Control Flow Pattern"@en ;
    rdfs:comment "Fundamental patterns covering 80% of real-world workflows (WCP 1-5)"@en ;
    rdfs:subClassOf bwp:ControlFlowPattern .

## Category 2: Advanced Branching and Synchronization (6-11)
bwp:AdvancedBranchingPattern a owl:Class ;
    rdfs:label "Advanced Branching Pattern"@en ;
    rdfs:comment "Complex branching and synchronization patterns (WCP 6-11)"@en ;
    rdfs:subClassOf bwp:ControlFlowPattern .

## Category 3: Multiple Instance Patterns (12-15)
bwp:MultipleInstancePattern a owl:Class ;
    rdfs:label "Multiple Instance Pattern"@en ;
    rdfs:comment "Patterns involving multiple instances of tasks or subprocesses (WCP 12-15)"@en ;
    rdfs:subClassOf bwp:ControlFlowPattern .

## Category 4: State-based Patterns (16-18)
bwp:StateBasedPattern a owl:Class ;
    rdfs:label "State-based Pattern"@en ;
    rdfs:comment "Patterns based on workflow state and conditions (WCP 16-18)"@en ;
    rdfs:subClassOf bwp:ControlFlowPattern .

## Category 5: Cancellation Patterns (19-25)
bwp:CancellationPattern a owl:Class ;
    rdfs:label "Cancellation Pattern"@en ;
    rdfs:comment "Patterns for cancelling or removing tasks/instances (WCP 19-25)"@en ;
    rdfs:subClassOf bwp:ControlFlowPattern .

## Category 6: Trigger Patterns (23-24, 40-43)
bwp:TriggerPattern a owl:Class ;
    rdfs:label "Trigger Pattern"@en ;
    rdfs:comment "Event-driven and external trigger patterns"@en ;
    rdfs:subClassOf bwp:ControlFlowPattern .

## Category 7: Structural Patterns (10-11, 21-22)
bwp:StructuralPattern a owl:Class ;
    rdfs:label "Structural Pattern"@en ;
    rdfs:comment "Patterns involving workflow structure and cycles"@en ;
    rdfs:subClassOf bwp:ControlFlowPattern .

## Category 8: New Control Flow Patterns (26-39)
bwp:NewControlFlowPattern a owl:Class ;
    rdfs:label "New Control Flow Pattern"@en ;
    rdfs:comment "Advanced patterns beyond basic van der Aalst set (WCP 26-39)"@en ;
    rdfs:subClassOf bwp:ControlFlowPattern .

# =====================================================================
# PERFORMANCE FRAUD DETECTION ONTOLOGY
# =====================================================================

## Performance fraud and memory leak detection
fraud:PerformanceFraud a owl:Class ;
    rdfs:label "Performance Fraud"@en ;
    rdfs:comment "Detection of 52,704x performance degradation patterns"@en .

fraud:MemoryLeak a owl:Class ;
    rdfs:label "Memory Leak"@en ;
    rdfs:comment "Detection of 374MB+ memory leaks"@en .

## Performance metric classes
perf:PerformanceMetric a owl:Class ;
    rdfs:label "Performance Metric"@en ;
    rdfs:comment "Measurable performance characteristics"@en .

perf:ThroughputMetric a owl:Class ;
    rdfs:label "Throughput Metric"@en ;
    rdfs:comment "Operations per second measurement"@en ;
    rdfs:subClassOf perf:PerformanceMetric .

perf:LatencyMetric a owl:Class ;
    rdfs:label "Latency Metric"@en ;
    rdfs:comment "Response time measurement in nanoseconds"@en ;
    rdfs:subClassOf perf:PerformanceMetric .

perf:MemoryMetric a owl:Class ;
    rdfs:label "Memory Metric"@en ;
    rdfs:comment "Memory usage measurement in bytes"@en ;
    rdfs:subClassOf perf:PerformanceMetric .

# =====================================================================
# OBJECT PROPERTIES (Relationships)
# =====================================================================

## Pattern dependencies and relationships
bwp:requires a owl:ObjectProperty ;
    rdfs:label "requires"@en ;
    rdfs:comment "Pattern A requires Pattern B for implementation"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range bwp:WorkflowPattern .

bwp:conflicts a owl:ObjectProperty ;
    rdfs:label "conflicts"@en ;
    rdfs:comment "Pattern A conflicts with Pattern B"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range bwp:WorkflowPattern ;
    owl:propertyDisjointWith bwp:requires .

bwp:composedOf a owl:ObjectProperty ;
    rdfs:label "composed of"@en ;
    rdfs:comment "Complex pattern composed of simpler patterns"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range bwp:WorkflowPattern .

bwp:hasPerformanceCharacteristic a owl:ObjectProperty ;
    rdfs:label "has performance characteristic"@en ;
    rdfs:comment "Pattern has specific performance characteristics"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range perf:PerformanceMetric .

## YAWL integration mapping
bwp:mapsToYAWLConstruct a owl:ObjectProperty ;
    rdfs:label "maps to YAWL construct"@en ;
    rdfs:comment "Maps BitFlow pattern to equivalent YAWL construct"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range yawl:YAWLConstruct .

## Fraud detection relationships
fraud:detectsPerformanceFraud a owl:ObjectProperty ;
    rdfs:label "detects performance fraud"@en ;
    rdfs:comment "Pattern can detect performance fraud scenarios"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range fraud:PerformanceFraud .

fraud:detectsMemoryLeak a owl:ObjectProperty ;
    rdfs:label "detects memory leak"@en ;
    rdfs:comment "Pattern can detect memory leak scenarios"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range fraud:MemoryLeak .

# =====================================================================
# DATA PROPERTIES (Attributes)
# =====================================================================

## Core pattern attributes
bwp:patternId a owl:DatatypeProperty ;
    rdfs:label "pattern ID"@en ;
    rdfs:comment "Numeric identifier for pattern (1-43)"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range xsd:int .

bwp:vdaalstId a owl:DatatypeProperty ;
    rdfs:label "van der Aalst ID"@en ;
    rdfs:comment "Original van der Aalst pattern identifier (e.g., WCP-1)"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range xsd:string .

bwp:bitflowImplemented a owl:DatatypeProperty ;
    rdfs:label "BitFlow implemented"@en ;
    rdfs:comment "Whether pattern is implemented in current BitFlow version"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range xsd:boolean .

## Performance criticality attributes
bwp:criticalForPerformance a owl:DatatypeProperty ;
    rdfs:label "critical for performance"@en ;
    rdfs:comment "Whether pattern is critical for addressing 52,704x performance issues"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range xsd:boolean .

bwp:criticalForMemory a owl:DatatypeProperty ;
    rdfs:label "critical for memory"@en ;
    rdfs:comment "Whether pattern is critical for preventing 374MB memory leaks"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range xsd:boolean .

bwp:performanceImpact a owl:DatatypeProperty ;
    rdfs:label "performance impact"@en ;
    rdfs:comment "Level of performance impact (LOW, MEDIUM, HIGH, CRITICAL)"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range [ owl:oneOf ( "LOW" "MEDIUM" "HIGH" "CRITICAL" ) ] .

## Performance metrics
perf:executionComplexity a owl:DatatypeProperty ;
    rdfs:label "execution complexity"@en ;
    rdfs:comment "Big-O notation for pattern execution complexity"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range xsd:string .

perf:memoryFootprint a owl:DatatypeProperty ;
    rdfs:label "memory footprint"@en ;
    rdfs:comment "Memory usage in bytes for pattern execution"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range xsd:int .

perf:estimatedThroughput a owl:DatatypeProperty ;
    rdfs:label "estimated throughput"@en ;
    rdfs:comment "Estimated operations per second"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range xsd:int .

perf:estimatedLatency a owl:DatatypeProperty ;
    rdfs:label "estimated latency"@en ;
    rdfs:comment "Estimated execution latency in nanoseconds"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range xsd:int .

## Fraud detection thresholds
fraud:performanceFraudFactor a owl:DatatypeProperty ;
    rdfs:label "performance fraud factor"@en ;
    rdfs:comment "Multiplier indicating performance degradation (52,704x threshold)"@en ;
    rdfs:domain fraud:PerformanceFraud ;
    rdfs:range xsd:double .

fraud:memoryLeakThreshold a owl:DatatypeProperty ;
    rdfs:label "memory leak threshold"@en ;
    rdfs:comment "Memory usage threshold for leak detection (374MB = 392,167,424 bytes)"@en ;
    rdfs:domain fraud:MemoryLeak ;
    rdfs:range xsd:long .

# =====================================================================
# CATEGORY 1: BASIC CONTROL FLOW PATTERNS (WCP 1-5) - IMPLEMENTED
# =====================================================================

bwp:Sequence a bwp:BasicControlFlowPattern ;
    rdfs:label "Sequence (WCP-1)"@en ;
    rdfs:comment "Task A followed by Task B in sequential order"@en ;
    bwp:patternId 1 ;
    bwp:vdaalstId "WCP-1" ;
    bwp:bitflowImplemented true ;
    bwp:criticalForPerformance false ;
    bwp:criticalForMemory false ;
    bwp:performanceImpact "LOW" ;
    perf:executionComplexity "O(1)" ;
    perf:memoryFootprint 32 ;
    perf:estimatedThroughput 1000000 ;
    perf:estimatedLatency 100 ;
    bwp:mapsToYAWLConstruct yawl:SequenceTask .

bwp:ParallelSplit a bwp:BasicControlFlowPattern ;
    rdfs:label "Parallel Split (WCP-2)"@en ;
    rdfs:comment "Point where single thread splits into multiple parallel threads"@en ;
    bwp:patternId 2 ;
    bwp:vdaalstId "WCP-2" ;
    bwp:bitflowImplemented true ;
    bwp:criticalForPerformance true ;
    bwp:criticalForMemory true ;
    bwp:performanceImpact "HIGH" ;
    perf:executionComplexity "O(n)" ;
    perf:memoryFootprint 64 ;
    perf:estimatedThroughput 500000 ;
    perf:estimatedLatency 200 ;
    bwp:requires bwp:Synchronization ;
    bwp:mapsToYAWLConstruct yawl:ANDSplit .

bwp:Synchronization a bwp:BasicControlFlowPattern ;
    rdfs:label "Synchronization (WCP-3)"@en ;
    rdfs:comment "Point where multiple parallel threads converge into single thread"@en ;
    bwp:patternId 3 ;
    bwp:vdaalstId "WCP-3" ;
    bwp:bitflowImplemented true ;
    bwp:criticalForPerformance true ;
    bwp:criticalForMemory true ;
    bwp:performanceImpact "HIGH" ;
    perf:executionComplexity "O(n)" ;
    perf:memoryFootprint 96 ;
    perf:estimatedThroughput 400000 ;
    perf:estimatedLatency 300 ;
    bwp:mapsToYAWLConstruct yawl:ANDJoin .

bwp:ExclusiveChoice a bwp:BasicControlFlowPattern ;
    rdfs:label "Exclusive Choice (WCP-4)"@en ;
    rdfs:comment "Point where single thread chooses one of several alternatives"@en ;
    bwp:patternId 4 ;
    bwp:vdaalstId "WCP-4" ;
    bwp:bitflowImplemented true ;
    bwp:criticalForPerformance false ;
    bwp:criticalForMemory false ;
    bwp:performanceImpact "MEDIUM" ;
    perf:executionComplexity "O(1)" ;
    perf:memoryFootprint 48 ;
    perf:estimatedThroughput 800000 ;
    perf:estimatedLatency 150 ;
    bwp:requires bwp:SimpleMerge ;
    bwp:mapsToYAWLConstruct yawl:XORSplit .

bwp:SimpleMerge a bwp:BasicControlFlowPattern ;
    rdfs:label "Simple Merge (WCP-5)"@en ;
    rdfs:comment "Point where one of several alternative branches reconverges"@en ;
    bwp:patternId 5 ;
    bwp:vdaalstId "WCP-5" ;
    bwp:bitflowImplemented true ;
    bwp:criticalForPerformance false ;
    bwp:criticalForMemory false ;
    bwp:performanceImpact "MEDIUM" ;
    perf:executionComplexity "O(1)" ;
    perf:memoryFootprint 40 ;
    perf:estimatedThroughput 750000 ;
    perf:estimatedLatency 125 ;
    bwp:mapsToYAWLConstruct yawl:XORJoin .

# =====================================================================
# CATEGORY 2: ADVANCED BRANCHING PATTERNS (WCP 6-11) - MOSTLY MISSING
# =====================================================================

bwp:MultiChoice a bwp:AdvancedBranchingPattern ;
    rdfs:label "Multi-Choice (WCP-6)"@en ;
    rdfs:comment "Point where one or more branches can be chosen based on decision"@en ;
    bwp:patternId 6 ;
    bwp:vdaalstId "WCP-6" ;
    bwp:bitflowImplemented false ;
    bwp:criticalForPerformance true ;
    bwp:criticalForMemory true ;
    bwp:performanceImpact "CRITICAL" ;
    perf:executionComplexity "O(2^n)" ;
    perf:memoryFootprint 128 ;
    perf:estimatedThroughput 100000 ;
    perf:estimatedLatency 1000 ;
    bwp:requires bwp:StructuredSynchronizingMerge .

bwp:StructuredSynchronizingMerge a bwp:AdvancedBranchingPattern ;
    rdfs:label "Structured Synchronizing Merge (WCP-7)"@en ;
    rdfs:comment "Merge pattern for multi-choice that waits for active branches"@en ;
    bwp:patternId 7 ;
    bwp:vdaalstId "WCP-7" ;
    bwp:bitflowImplemented false ;
