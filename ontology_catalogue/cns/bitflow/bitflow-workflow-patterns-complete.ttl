# =====================================================================
# PERFORMANCE FRAUD DETECTION INSTANCES
# =====================================================================

fraud:BitFlowPerformanceFraudThreshold a fraud:PerformanceFraud ;
    rdfs:label "BitFlow Performance Fraud Threshold"@en ;
    rdfs:comment "Threshold for detecting 52,704x performance degradation in BitFlow patterns"@en ;
    fraud:performanceFraudFactor 52704.0 .

fraud:BitFlowMemoryLeakThreshold a fraud:MemoryLeak ;
    rdfs:label "BitFlow Memory Leak Threshold"@en ;
    rdfs:comment "Threshold for detecting 374MB+ memory leaks in BitFlow patterns"@en ;
    fraud:memoryLeakThreshold 392167424 .  # 374MB in bytes

# =====================================================================
# SPARQL QUERY TEMPLATES FOR PATTERN ANALYSIS
# =====================================================================

sparql:FindMissingPatternsQuery a sparql:QueryTemplate ;
    rdfs:label "Find Missing Patterns Query"@en ;
    sparql:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        
        # Find all patterns not implemented in BitFlow
        SELECT ?pattern ?label ?vdaalstId ?performanceImpact ?complexity
        WHERE {
            ?pattern a bwp:WorkflowPattern ;
                     rdfs:label ?label ;
                     bwp:vdaalstId ?vdaalstId ;
                     bwp:bitflowImplemented false ;
                     bwp:performanceImpact ?performanceImpact ;
                     perf:executionComplexity ?complexity .
        }
        ORDER BY ?vdaalstId
    """ .

sparql:FindPerformanceCriticalPatternsQuery a sparql:QueryTemplate ;
    rdfs:label "Find Performance Critical Patterns Query"@en ;
    sparql:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        PREFIX perf: <http://bitflow.org/ontology/performance#>
        
        # Find patterns critical for performance and memory
        SELECT ?pattern ?label ?throughput ?latency ?memory ?complexity
        WHERE {
            ?pattern a bwp:WorkflowPattern ;
                     rdfs:label ?label ;
                     bwp:criticalForPerformance true ;
                     perf:estimatedThroughput ?throughput ;
                     perf:estimatedLatency ?latency ;
                     perf:memoryFootprint ?memory ;
                     perf:executionComplexity ?complexity .
        }
        ORDER BY ?throughput
    """ .

sparql:FindFraudDetectionPatternsQuery a sparql:QueryTemplate ;
    rdfs:label "Find Fraud Detection Patterns Query"@en ;
    sparql:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        PREFIX fraud: <http://bitflow.org/ontology/fraud-detection#>
        
        # Find patterns that can detect performance fraud or memory leaks
        SELECT ?pattern ?label ?fraudType ?threshold
        WHERE {
            {
                ?pattern fraud:detectsPerformanceFraud ?fraud .
                ?fraud fraud:performanceFraudFactor ?threshold .
                BIND("Performance Fraud" AS ?fraudType)
            } UNION {
                ?pattern fraud:detectsMemoryLeak ?leak .
                ?leak fraud:memoryLeakThreshold ?threshold .
                BIND("Memory Leak" AS ?fraudType)
            }
            ?pattern rdfs:label ?label .
        }
    """ .

sparql:FindYAWLMappingsQuery a sparql:QueryTemplate ;
    rdfs:label "Find YAWL Mappings Query"@en ;
    sparql:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        PREFIX yawl: <http://www.yawlfoundation.org/ontology#>
        
        # Find patterns with YAWL construct mappings
        SELECT ?pattern ?label ?yawlConstruct
        WHERE {
            ?pattern a bwp:WorkflowPattern ;
                     rdfs:label ?label ;
                     bwp:mapsToYAWLConstruct ?yawlConstruct .
        }
        ORDER BY ?label
    """ .

sparql:FindImplementationPriorityQuery a sparql:QueryTemplate ;
    rdfs:label "Find Implementation Priority Query"@en ;
    sparql:queryString """
        PREFIX bwp: <http://bitflow.org/ontology/workflow-patterns#>
        PREFIX perf: <http://bitflow.org/ontology/performance#>
        
        # Prioritize missing patterns by performance impact and complexity
        SELECT ?pattern ?label ?performanceImpact ?complexity ?throughput 
               (IF(?performanceImpact = "CRITICAL", 1, 
                   IF(?performanceImpact = "HIGH", 2, 
                      IF(?performanceImpact = "MEDIUM", 3, 4))) AS ?priority)
        WHERE {
            ?pattern a bwp:WorkflowPattern ;
                     rdfs:label ?label ;
                     bwp:bitflowImplemented false ;
                     bwp:performanceImpact ?performanceImpact ;
                     perf:executionComplexity ?complexity ;
                     perf:estimatedThroughput ?throughput .
        }
        ORDER BY ?priority, ?throughput
    """ .

# =====================================================================
# IMPLEMENTATION STATISTICS AND COMPLETION METRICS
# =====================================================================

bwp:ImplementationStatistics a owl:Class ;
    rdfs:label "Implementation Statistics"@en ;
    rdfs:comment "Statistics about BitFlow pattern implementation coverage"@en .

bwp:BitFlowImplementationStats a bwp:ImplementationStatistics ;
    rdfs:label "BitFlow Implementation Statistics"@en ;
    rdfs:comment "Current implementation coverage: 8/43 patterns (18.6%)"@en ;
    bwp:totalPatterns 43 ;
    bwp:implementedPatterns 8 ;
    bwp:missingPatterns 35 ;
    bwp:implementationPercentage 18.6 ;
    bwp:criticalMissingPatterns 25 ;
    bwp:highPerformanceImpactMissingPatterns 15 .

bwp:totalPatterns a owl:DatatypeProperty ;
    rdfs:label "total patterns"@en ;
    rdfs:domain bwp:ImplementationStatistics ;
    rdfs:range xsd:int .

bwp:implementedPatterns a owl:DatatypeProperty ;
    rdfs:label "implemented patterns"@en ;
    rdfs:domain bwp:ImplementationStatistics ;
    rdfs:range xsd:int .

bwp:missingPatterns a owl:DatatypeProperty ;
    rdfs:label "missing patterns"@en ;
    rdfs:domain bwp:ImplementationStatistics ;
    rdfs:range xsd:int .

bwp:implementationPercentage a owl:DatatypeProperty ;
    rdfs:label "implementation percentage"@en ;
    rdfs:domain bwp:ImplementationStatistics ;
    rdfs:range xsd:double .

bwp:criticalMissingPatterns a owl:DatatypeProperty ;
    rdfs:label "critical missing patterns"@en ;
    rdfs:domain bwp:ImplementationStatistics ;
    rdfs:range xsd:int .

bwp:highPerformanceImpactMissingPatterns a owl:DatatypeProperty ;
    rdfs:label "high performance impact missing patterns"@en ;
    rdfs:domain bwp:ImplementationStatistics ;
    rdfs:range xsd:int .

