@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bf: <http://bitflow.com/ontology/> .
@prefix fin: <http://bitflow.com/ontology/financial/> .
@prefix yawl: <http://yawl.org/ontology/> .

# BitFlow Financial System - OWL TTL YAWL Pattern Catalog
# Comprehensive workflow pattern ontology for financial trading systems

# ================================
# Core Ontology Declaration
# ================================

<http://bitflow.com/ontology/financial/>
    a owl:Ontology ;
    rdfs:label "BitFlow Financial Workflow Patterns"@en ;
    rdfs:comment "Comprehensive OWL TTL YAWL pattern catalog for financial trading systems"@en ;
    owl:versionInfo "1.0.0" ;
    owl:imports <http://bitflow.com/ontology/> ,
                <http://yawl.org/ontology/> .

# ================================
# Pattern Classification Hierarchy
# ================================

fin:WorkflowPattern
    a owl:Class ;
    rdfs:subClassOf bf:Pattern ;
    rdfs:label "Financial Workflow Pattern"@en ;
    rdfs:comment "Base class for all financial workflow patterns"@en .

fin:TradingPattern
    a owl:Class ;
    rdfs:subClassOf fin:WorkflowPattern ;
    rdfs:label "Trading Pattern"@en ;
    rdfs:comment "Patterns related to trade execution and order management"@en .

fin:RiskPattern
    a owl:Class ;
    rdfs:subClassOf fin:WorkflowPattern ;
    rdfs:label "Risk Management Pattern"@en ;
    rdfs:comment "Patterns for risk assessment and control"@en .

fin:CompliancePattern
    a owl:Class ;
    rdfs:subClassOf fin:WorkflowPattern ;
    rdfs:label "Compliance Pattern"@en ;
    rdfs:comment "Patterns for regulatory compliance and reporting"@en .

fin:DataPattern
    a owl:Class ;
    rdfs:subClassOf fin:WorkflowPattern ;
    rdfs:label "Data Management Pattern"@en ;
    rdfs:comment "Patterns for data processing and analytics"@en .

fin:IntegrationPattern
    a owl:Class ;
    rdfs:subClassOf fin:WorkflowPattern ;
    rdfs:label "Integration Pattern"@en ;
    rdfs:comment "Patterns for system integration and communication"@en .

# ================================
# Pattern Properties
# ================================

fin:hasLatencyRequirement
    a owl:DatatypeProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "latency requirement (nanoseconds)"@en ;
    rdfs:comment "Maximum acceptable latency in nanoseconds"@en .

fin:hasThroughputRequirement
    a owl:DatatypeProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "throughput requirement (ops/sec)"@en ;
    rdfs:comment "Minimum required throughput in operations per second"@en .

fin:hasRiskLevel
    a owl:DatatypeProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range xsd:string ;
    rdfs:label "risk level"@en ;
    rdfs:comment "Risk classification: LOW, MEDIUM, HIGH, CRITICAL"@en .

fin:requiresCompliance
    a owl:ObjectProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range fin:RegulatoryFramework ;
    rdfs:label "requires compliance"@en ;
    rdfs:comment "Regulatory frameworks this pattern must comply with"@en .

fin:hasImplementationStatus
    a owl:DatatypeProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range xsd:string ;
    rdfs:label "implementation status"@en ;
    rdfs:comment "Current implementation status: IMPLEMENTED, PARTIAL, MISSING, PLANNED"@en .

# ================================
# YAWL Integration Properties
# ================================

fin:hasYAWLNet
    a owl:ObjectProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range yawl:Net ;
    rdfs:label "has YAWL net"@en ;
    rdfs:comment "Associated YAWL workflow net specification"@en .

fin:hasControlFlow
    a owl:ObjectProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range yawl:ControlFlow ;
    rdfs:label "has control flow"@en ;
    rdfs:comment "Control flow specification for the pattern"@en .

fin:hasDataFlow
    a owl:ObjectProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range yawl:DataFlow ;
    rdfs:label "has data flow"@en ;
    rdfs:comment "Data flow specification for the pattern"@en .

# ================================
# Regulatory Framework Classes
# ================================

fin:RegulatoryFramework
    a owl:Class ;
    rdfs:label "Regulatory Framework"@en ;
    rdfs:comment "Financial regulatory frameworks and standards"@en .

fin:MiFIDII
    a fin:RegulatoryFramework ;
    rdfs:label "MiFID II"@en ;
    rdfs:comment "Markets in Financial Instruments Directive II (EU)"@en .

fin:EMIR
    a fin:RegulatoryFramework ;
    rdfs:label "EMIR"@en ;
    rdfs:comment "European Market Infrastructure Regulation"@en .

fin:DoddFrank
    a fin:RegulatoryFramework ;
    rdfs:label "Dodd-Frank"@en ;
    rdfs:comment "Dodd-Frank Wall Street Reform Act (US)"@en .

fin:SOX
    a fin:RegulatoryFramework ;
    rdfs:label "SOX"@en ;
    rdfs:comment "Sarbanes-Oxley Act (US)"@en .

# ================================
# Currently Implemented Patterns
# ================================

fin:OrderManagementPattern
    a fin:TradingPattern ;
    rdfs:label "Order Management System Pattern"@en ;
    rdfs:comment "Ultra-low latency order processing with CRC32 integrity"@en ;
    fin:hasLatencyRequirement 50000 ;
    fin:hasThroughputRequirement 100000 ;
    fin:hasRiskLevel "HIGH" ;
    fin:hasImplementationStatus "IMPLEMENTED" ;
    fin:requiresCompliance fin:MiFIDII , fin:EMIR .

fin:MarketDataPattern
    a fin:DataPattern ;
    rdfs:label "Market Data Processing Pattern"@en ;
    rdfs:comment "10M ticks/second processing with sub-100ns latency"@en ;
    fin:hasLatencyRequirement 10000 ;
    fin:hasThroughputRequirement 10000000 ;
    fin:hasRiskLevel "MEDIUM" ;
    fin:hasImplementationStatus "IMPLEMENTED" .

fin:HFTOrderBookPattern
    a fin:TradingPattern ;
    rdfs:label "HFT Order Book Pattern"@en ;
    rdfs:comment "Lock-free order matching with price-time priority"@en ;
    fin:hasLatencyRequirement 100000 ;
    fin:hasThroughputRequirement 1000000 ;
    fin:hasRiskLevel "HIGH" ;
    fin:hasImplementationStatus "IMPLEMENTED" .

fin:RiskManagementPattern
    a fin:RiskPattern ;
    rdfs:label "Risk Management Pattern"@en ;
    rdfs:comment "Real-time position limits and circuit breakers"@en ;
    fin:hasLatencyRequirement 1000000 ;
    fin:hasThroughputRequirement 50000 ;
    fin:hasRiskLevel "CRITICAL" ;
    fin:hasImplementationStatus "IMPLEMENTED" ;
    fin:requiresCompliance fin:SOX , fin:DoddFrank .

fin:PositionTrackingPattern
    a fin:TradingPattern ;
    rdfs:label "Position Tracking Pattern"@en ;
    rdfs:comment "Atomic position updates with version control"@en ;
    fin:hasLatencyRequirement 500000 ;
    fin:hasThroughputRequirement 150000 ;
    fin:hasRiskLevel "HIGH" ;
    fin:hasImplementationStatus "IMPLEMENTED" .

fin:TradeExecutionPattern
    a fin:TradingPattern ;
    rdfs:label "Trade Execution Pattern"@en ;
    rdfs:comment "Multiple order types (Market, Limit, IOC, FOK)"@en ;
    fin:hasLatencyRequirement 30000 ;
    fin:hasThroughputRequirement 300000 ;
    fin:hasRiskLevel "HIGH" ;
    fin:hasImplementationStatus "IMPLEMENTED" ;
    fin:requiresCompliance fin:MiFIDII .

fin:MarketMakingPattern
    a fin:TradingPattern ;
    rdfs:label "Market Making Pattern"@en ;
    rdfs:comment "Automated bid/ask spread management"@en ;
    fin:hasLatencyRequirement 50000 ;
    fin:hasThroughputRequirement 200000 ;
    fin:hasRiskLevel "MEDIUM" ;
    fin:hasImplementationStatus "IMPLEMENTED" .

fin:KillSwitchPattern
    a fin:RiskPattern ;
    rdfs:label "Kill Switch Pattern"@en ;
    rdfs:comment "Global emergency halt with <100ns propagation"@en ;
    fin:hasLatencyRequirement 100 ;
    fin:hasThroughputRequirement 1 ;
    fin:hasRiskLevel "CRITICAL" ;
    fin:hasImplementationStatus "IMPLEMENTED" .

fin:CircuitBreakerPattern
    a fin:RiskPattern ;
    rdfs:label "Circuit Breaker Pattern"@en ;
    rdfs:comment "Multi-tier risk protection"@en ;
    fin:hasLatencyRequirement 1000 ;
    fin:hasThroughputRequirement 1000 ;
    fin:hasRiskLevel "CRITICAL" ;
    fin:hasImplementationStatus "IMPLEMENTED" .

fin:BackpressureControlPattern
    a fin:IntegrationPattern ;
    rdfs:label "Backpressure Control Pattern"@en ;
    rdfs:comment "Graceful degradation under load"@en ;
    fin:hasLatencyRequirement 5000 ;
    fin:hasThroughputRequirement 764000 ;
    fin:hasRiskLevel "MEDIUM" ;
    fin:hasImplementationStatus "IMPLEMENTED" .

