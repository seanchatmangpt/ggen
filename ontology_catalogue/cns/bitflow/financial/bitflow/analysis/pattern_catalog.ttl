# ================================
# Pattern Dependencies
# ================================

fin:dependsOn
    a owl:ObjectProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range fin:WorkflowPattern ;
    rdfs:label "depends on"@en ;
    rdfs:comment "This pattern depends on another pattern"@en .

# Define key dependencies
fin:AlgorithmicTradingWorkflowPattern fin:dependsOn fin:OrderManagementPattern .
fin:AlgorithmicTradingWorkflowPattern fin:dependsOn fin:RiskManagementPattern .
fin:AlgorithmicTradingWorkflowPattern fin:dependsOn fin:RealTimeMarketAnalyticsPattern .

fin:RegulatoryReportingPattern fin:dependsOn fin:AuditTrailPattern .
fin:RegulatoryReportingPattern fin:dependsOn fin:TradeLifecycleManagementPattern .

fin:OrderRoutingOptimizationPattern fin:dependsOn fin:VenueConnectivityPattern .
fin:OrderRoutingOptimizationPattern fin:dependsOn fin:FIXProtocolIntegrationPattern .

fin:MultiAssetTradeSettlementPattern fin:dependsOn fin:TradeLifecycleManagementPattern .
fin:MultiAssetTradeSettlementPattern fin:dependsOn fin:ReferenceDataManagementPattern .

# ================================
# Pattern Quality Metrics
# ================================

fin:hasComplexity
    a owl:DatatypeProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range xsd:string ;
    rdfs:label "complexity"@en ;
    rdfs:comment "Implementation complexity: LOW, MEDIUM, HIGH, VERY_HIGH"@en .

fin:hasBusinessValue
    a owl:DatatypeProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range xsd:string ;
    rdfs:label "business value"@en ;
    rdfs:comment "Business impact: LOW, MEDIUM, HIGH, CRITICAL"@en .

fin:hasImplementationEffort
    a owl:DatatypeProperty ;
    rdfs:domain fin:WorkflowPattern ;
    rdfs:range xsd:integer ;
    rdfs:label "implementation effort (weeks)"@en ;
    rdfs:comment "Estimated implementation effort in weeks"@en .

# Add complexity and effort estimates for critical missing patterns
fin:MultiAssetTradeSettlementPattern fin:hasComplexity "VERY_HIGH" .
fin:MultiAssetTradeSettlementPattern fin:hasBusinessValue "CRITICAL" .
fin:MultiAssetTradeSettlementPattern fin:hasImplementationEffort 16 .

fin:AlgorithmicTradingWorkflowPattern fin:hasComplexity "HIGH" .
fin:AlgorithmicTradingWorkflowPattern fin:hasBusinessValue "CRITICAL" .
fin:AlgorithmicTradingWorkflowPattern fin:hasImplementationEffort 12 .

fin:RegulatoryReportingPattern fin:hasComplexity "HIGH" .
fin:RegulatoryReportingPattern fin:hasBusinessValue "CRITICAL" .
fin:RegulatoryReportingPattern fin:hasImplementationEffort 8 .

fin:FIXProtocolIntegrationPattern fin:hasComplexity "MEDIUM" .
fin:FIXProtocolIntegrationPattern fin:hasBusinessValue "CRITICAL" .
fin:FIXProtocolIntegrationPattern fin:hasImplementationEffort 6 .

# ================================
# End of Ontology
# ================================