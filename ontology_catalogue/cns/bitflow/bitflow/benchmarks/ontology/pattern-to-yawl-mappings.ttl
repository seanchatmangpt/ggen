yawlmap:StructuredSyncMergeConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Structured Synchronizing Merge Performance Constraints"@en ;
    rdfs:comment "CRITICAL: Required for multi-choice pattern completion"@en ;
