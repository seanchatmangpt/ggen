    yawlmap:hasExecutionSemantics yawlmap:StructuredSyncMergeSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:StructuredSyncMergeConstraints .

yawlmap:StructuredSyncMergeSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Structured Synchronizing Merge Execution Semantics"@en ;
    rdfs:comment "Merge pattern for multi-choice that waits for active branches"@en ;
    yawlmap:executionComplexity 8 ;  # 8 CPU ticks maximum
    yawlmap:memoryRequirement 256 ;  # 256 bytes
