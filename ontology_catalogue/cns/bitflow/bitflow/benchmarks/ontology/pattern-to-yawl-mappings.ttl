    perf:estimatedLatency 1500 ;
    bwp:criticalForPerformance true .

bwp:StructuredSynchronizingMerge yawlmap:mapsToYAWL yawl:ORJoin .

## WCP-12: Multiple Instances without Synchronization (MISSING - CRITICAL)
yawlmap:MultipleInstancesMapping a yawlmap:PatternMapping ;
    rdfs:label "Multiple Instances Pattern Mapping"@en ;
    rdfs:comment "Maps WCP-12 Multiple Instances to YAWL MI task (MISSING)"@en ;
    yawlmap:mapsPattern bwp:MultipleInstancesWithoutSynchronization ;
