# Pattern-to-YAWL Mappings (Turtle/TTL Format)
# Maps van der Aalst workflow patterns to YAWL v2 constructs for BitFlow execution
# Addresses BitFlow performance fraud (52,704x) and missing patterns (35)
# 
# Author: YAWL_Specification_Analyst Agent
# Date: 2025-08-02
# Version: 2.0.0

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bwp: <http://bitflow.org/ontology/workflow-patterns#> .
@prefix yawl: <http://www.yawlfoundation.org/ontology#> .
@prefix yawlmap: <http://bitflow.org/ontology/yawl-mappings#> .
@prefix perf: <http://bitflow.org/ontology/performance#> .

# =====================================================================
# ONTOLOGY METADATA
# =====================================================================

<http://bitflow.org/ontology/yawl-mappings> 
    a owl:Ontology ;
    owl:versionIRI <http://bitflow.org/ontology/yawl-mappings/2.0> ;
    rdfs:label "BitFlow Pattern to YAWL Mappings"@en ;
    rdfs:comment """Comprehensive mappings between van der Aalst workflow patterns 
                    and YAWL v2 constructs for BitFlow execution engine."""@en ;
    owl:versionInfo "2.0.0" ;
    rdfs:seeAlso <http://www.yawlfoundation.org/> ;
    rdfs:seeAlso <http://workflowpatterns.com> ;
    owl:imports <http://bitflow.org/ontology/workflow-patterns> ;
    owl:imports <http://www.yawlfoundation.org/ontology> .

# =====================================================================
# YAWL MAPPING CLASSES AND PROPERTIES
# =====================================================================

## Mapping Classes
yawlmap:PatternMapping a owl:Class ;
    rdfs:label "Pattern Mapping"@en ;
    rdfs:comment "Maps a workflow pattern to YAWL constructs"@en .

yawlmap:YAWLConstruct a owl:Class ;
    rdfs:label "YAWL Construct"@en ;
    rdfs:comment "YAWL language construct (task, condition, split, join)"@en .

yawlmap:ExecutionSemantics a owl:Class ;
    rdfs:label "Execution Semantics"@en ;
    rdfs:comment "Defines execution semantics for pattern-to-YAWL mapping"@en .

yawlmap:PerformanceConstraint a owl:Class ;
    rdfs:label "Performance Constraint"@en ;
    rdfs:comment "Performance constraints for YAWL execution (≤8 CPU ticks)"@en .

## Mapping Properties
yawlmap:mapsToYAWL a owl:ObjectProperty ;
    rdfs:label "maps to YAWL"@en ;
    rdfs:comment "Maps BitFlow pattern to YAWL construct"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range yawlmap:YAWLConstruct .

yawlmap:hasExecutionSemantics a owl:ObjectProperty ;
    rdfs:label "has execution semantics"@en ;
    rdfs:comment "Defines execution semantics for mapping"@en ;
    rdfs:domain yawlmap:PatternMapping ;
    rdfs:range yawlmap:ExecutionSemantics .

yawlmap:hasPerformanceConstraint a owl:ObjectProperty ;
    rdfs:label "has performance constraint"@en ;
    rdfs:comment "Associates performance constraints with mapping"@en ;
    rdfs:domain yawlmap:PatternMapping ;
    rdfs:range yawlmap:PerformanceConstraint .

yawlmap:implementationFunction a owl:DatatypeProperty ;
    rdfs:label "implementation function"@en ;
    rdfs:comment "C function name implementing the pattern"@en ;
    rdfs:domain yawlmap:PatternMapping ;
    rdfs:range xsd:string .

yawlmap:yawlSpecificationId a owl:DatatypeProperty ;
    rdfs:label "YAWL specification ID"@en ;
    rdfs:comment "YAWL specification identifier"@en ;
    rdfs:domain yawlmap:PatternMapping ;
    rdfs:range xsd:string .

yawlmap:yawlNetId a owl:DatatypeProperty ;
    rdfs:label "YAWL net ID"@en ;
    rdfs:comment "YAWL net identifier within specification"@en ;
    rdfs:domain yawlmap:PatternMapping ;
    rdfs:range xsd:string .

yawlmap:executionComplexity a owl:DatatypeProperty ;
    rdfs:label "execution complexity"@en ;
    rdfs:comment "YAWL execution complexity in CPU ticks"@en ;
    rdfs:domain yawlmap:ExecutionSemantics ;
    rdfs:range xsd:unsignedByte .

yawlmap:memoryRequirement a owl:DatatypeProperty ;
    rdfs:label "memory requirement"@en ;
    rdfs:comment "Memory requirement in bytes for YAWL execution"@en ;
    rdfs:domain yawlmap:ExecutionSemantics ;
    rdfs:range xsd:unsignedLong .

yawlmap:timeoutDuration a owl:DatatypeProperty ;
    rdfs:label "timeout duration"@en ;
    rdfs:comment "Maximum execution timeout in nanoseconds"@en ;
    rdfs:domain yawlmap:ExecutionSemantics ;
    rdfs:range xsd:unsignedLong .

# =====================================================================
# YAWL CONSTRUCT DEFINITIONS
# =====================================================================

## YAWL Task Types
yawl:AtomicTask a yawlmap:YAWLConstruct ;
    rdfs:label "Atomic Task"@en ;
    rdfs:comment "YAWL atomic task with single activity"@en .

yawl:CompositeTask a yawlmap:YAWLConstruct ;
    rdfs:label "Composite Task"@en ;
    rdfs:comment "YAWL composite task with subnet"@en .

yawl:MultipleInstanceTask a yawlmap:YAWLConstruct ;
    rdfs:label "Multiple Instance Task"@en ;
    rdfs:comment "YAWL task with multiple instances"@en .

## YAWL Split/Join Types
yawl:XORSplit a yawlmap:YAWLConstruct ;
    rdfs:label "XOR Split"@en ;
    rdfs:comment "YAWL exclusive choice split"@en .

yawl:ANDSplit a yawlmap:YAWLConstruct ;
    rdfs:label "AND Split"@en ;
    rdfs:comment "YAWL parallel split"@en .

yawl:ORSplit a yawlmap:YAWLConstruct ;
    rdfs:label "OR Split"@en ;
    rdfs:comment "YAWL multi-choice split"@en .

yawl:XORJoin a yawlmap:YAWLConstruct ;
    rdfs:label "XOR Join"@en ;
    rdfs:comment "YAWL exclusive choice join"@en .

yawl:ANDJoin a yawlmap:YAWLConstruct ;
    rdfs:label "AND Join"@en ;
    rdfs:comment "YAWL synchronization join"@en .

yawl:ORJoin a yawlmap:YAWLConstruct ;
    rdfs:label "OR Join"@en ;
    rdfs:comment "YAWL multi-merge join"@en .

## YAWL Conditions
yawl:InputCondition a yawlmap:YAWLConstruct ;
    rdfs:label "Input Condition"@en ;
    rdfs:comment "YAWL workflow start condition"@en .

yawl:OutputCondition a yawlmap:YAWLConstruct ;
    rdfs:label "Output Condition"@en ;
    rdfs:comment "YAWL workflow end condition"@en .

yawl:Condition a yawlmap:YAWLConstruct ;
    rdfs:label "Condition"@en ;
    rdfs:comment "YAWL intermediate condition"@en .

# =====================================================================
# PATTERN MAPPINGS: BASIC CONTROL FLOW (WCP 1-5) - IMPLEMENTED
# =====================================================================

## WCP-1: Sequence Pattern Mapping
yawlmap:SequenceMapping a yawlmap:PatternMapping ;
    rdfs:label "Sequence Pattern Mapping"@en ;
    rdfs:comment "Maps WCP-1 Sequence to YAWL sequential tasks"@en ;
    yawlmap:mapsPattern bwp:Sequence ;
    yawlmap:mapsToYAWL yawl:AtomicTask ;
    yawlmap:yawlSpecificationId "basic-control-flow" ;
    yawlmap:yawlNetId "SequencePattern" ;
    yawlmap:implementationFunction "bitflow_pattern_sequence_a, bitflow_pattern_sequence_b" ;
    yawlmap:hasExecutionSemantics yawlmap:SequenceSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:SequenceConstraints .

yawlmap:SequenceSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Sequence Execution Semantics"@en ;
    rdfs:comment "Task A followed by Task B in strict sequential order"@en ;
    yawlmap:executionComplexity 2 ;  # 2 CPU ticks total
    yawlmap:memoryRequirement 32 ;   # 32 bytes
    yawlmap:timeoutDuration 100000 . # 100μs

yawlmap:SequenceConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Sequence Performance Constraints"@en ;
    perf:executionComplexity "O(1)" ;
    perf:memoryFootprint 32 ;
    perf:estimatedThroughput 1000000 ;
    perf:estimatedLatency 100 .

bwp:Sequence yawlmap:mapsToYAWL yawl:AtomicTask .

## WCP-2: Parallel Split Pattern Mapping
yawlmap:ParallelSplitMapping a yawlmap:PatternMapping ;
    rdfs:label "Parallel Split Pattern Mapping"@en ;
    rdfs:comment "Maps WCP-2 Parallel Split to YAWL AND-split"@en ;
    yawlmap:mapsPattern bwp:ParallelSplit ;
    yawlmap:mapsToYAWL yawl:ANDSplit ;
    yawlmap:yawlSpecificationId "basic-control-flow" ;
    yawlmap:yawlNetId "ParallelSplitPattern" ;
    yawlmap:implementationFunction "bitflow_pattern_parallel_split" ;
    yawlmap:hasExecutionSemantics yawlmap:ParallelSplitSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:ParallelSplitConstraints .

yawlmap:ParallelSplitSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Parallel Split Execution Semantics"@en ;
    rdfs:comment "Single thread splits into multiple parallel threads"@en ;
    yawlmap:executionComplexity 4 ;  # 4 CPU ticks for split + sync
    yawlmap:memoryRequirement 64 ;   # 64 bytes
    yawlmap:timeoutDuration 200000 . # 200μs

yawlmap:ParallelSplitConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Parallel Split Performance Constraints"@en ;
    perf:executionComplexity "O(n)" ;
    perf:memoryFootprint 64 ;
    perf:estimatedThroughput 500000 ;
    perf:estimatedLatency 200 .

bwp:ParallelSplit yawlmap:mapsToYAWL yawl:ANDSplit .

## WCP-3: Synchronization Pattern Mapping
yawlmap:SynchronizationMapping a yawlmap:PatternMapping ;
    rdfs:label "Synchronization Pattern Mapping"@en ;
    rdfs:comment "Maps WCP-3 Synchronization to YAWL AND-join"@en ;
    yawlmap:mapsPattern bwp:Synchronization ;
    yawlmap:mapsToYAWL yawl:ANDJoin ;
    yawlmap:yawlSpecificationId "basic-control-flow" ;
    yawlmap:yawlNetId "ParallelSplitPattern" ;
    yawlmap:implementationFunction "bitflow_pattern_synchronization" ;
    yawlmap:hasExecutionSemantics yawlmap:SynchronizationSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:SynchronizationConstraints .

yawlmap:SynchronizationSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Synchronization Execution Semantics"@en ;
    rdfs:comment "Multiple parallel threads converge into single thread"@en ;
    yawlmap:executionComplexity 4 ;  # 4 CPU ticks for synchronization
    yawlmap:memoryRequirement 96 ;   # 96 bytes
    yawlmap:timeoutDuration 300000 . # 300μs

yawlmap:SynchronizationConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Synchronization Performance Constraints"@en ;
    perf:executionComplexity "O(n)" ;
    perf:memoryFootprint 96 ;
    perf:estimatedThroughput 400000 ;
    perf:estimatedLatency 300 .

bwp:Synchronization yawlmap:mapsToYAWL yawl:ANDJoin .

## WCP-4: Exclusive Choice Pattern Mapping
yawlmap:ExclusiveChoiceMapping a yawlmap:PatternMapping ;
    rdfs:label "Exclusive Choice Pattern Mapping"@en ;
    rdfs:comment "Maps WCP-4 Exclusive Choice to YAWL XOR-split"@en ;
    yawlmap:mapsPattern bwp:ExclusiveChoice ;
    yawlmap:mapsToYAWL yawl:XORSplit ;
    yawlmap:yawlSpecificationId "basic-control-flow" ;
    yawlmap:yawlNetId "ExclusiveChoicePattern" ;
    yawlmap:implementationFunction "bitflow_pattern_exclusive_choice" ;
    yawlmap:hasExecutionSemantics yawlmap:ExclusiveChoiceSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:ExclusiveChoiceConstraints .

yawlmap:ExclusiveChoiceSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Exclusive Choice Execution Semantics"@en ;
    rdfs:comment "Single thread chooses one of several alternatives"@en ;
    yawlmap:executionComplexity 2 ;  # 2 CPU ticks for choice evaluation
    yawlmap:memoryRequirement 48 ;   # 48 bytes
    yawlmap:timeoutDuration 150000 . # 150μs

yawlmap:ExclusiveChoiceConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Exclusive Choice Performance Constraints"@en ;
    perf:executionComplexity "O(1)" ;
    perf:memoryFootprint 48 ;
    perf:estimatedThroughput 800000 ;
    perf:estimatedLatency 150 .

bwp:ExclusiveChoice yawlmap:mapsToYAWL yawl:XORSplit .

## WCP-5: Simple Merge Pattern Mapping
yawlmap:SimpleMergeMapping a yawlmap:PatternMapping ;
    rdfs:label "Simple Merge Pattern Mapping"@en ;
    rdfs:comment "Maps WCP-5 Simple Merge to YAWL XOR-join"@en ;
    yawlmap:mapsPattern bwp:SimpleMerge ;
    yawlmap:mapsToYAWL yawl:XORJoin ;
    yawlmap:yawlSpecificationId "basic-control-flow" ;
    yawlmap:yawlNetId "ExclusiveChoicePattern" ;
    yawlmap:implementationFunction "bitflow_pattern_simple_merge" ;
    yawlmap:hasExecutionSemantics yawlmap:SimpleMergeSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:SimpleMergeConstraints .

yawlmap:SimpleMergeSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Simple Merge Execution Semantics"@en ;
    rdfs:comment "One of several alternative branches reconverges"@en ;
    yawlmap:executionComplexity 1 ;  # 1 CPU tick for merge
    yawlmap:memoryRequirement 40 ;   # 40 bytes
    yawlmap:timeoutDuration 125000 . # 125μs

yawlmap:SimpleMergeConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Simple Merge Performance Constraints"@en ;
    perf:executionComplexity "O(1)" ;
    perf:memoryFootprint 40 ;
    perf:estimatedThroughput 750000 ;
    perf:estimatedLatency 125 .

bwp:SimpleMerge yawlmap:mapsToYAWL yawl:XORJoin .

