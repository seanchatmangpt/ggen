    yawlmap:implementationFunction "bitflow_pattern_multiple_instance_worker_STUB" ;
    yawlmap:hasExecutionSemantics yawlmap:MultipleInstancesSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:MultipleInstancesConstraints .

yawlmap:MultipleInstancesSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Multiple Instances Execution Semantics"@en ;
    rdfs:comment "Multiple instances of task without synchronization"@en ;
    yawlmap:executionComplexity 8 ;  # 8 CPU ticks per instance
    yawlmap:memoryRequirement 384 ;  # 384 bytes total
    yawlmap:timeoutDuration 600000 . # 600μs

yawlmap:MultipleInstancesConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Multiple Instances Performance Constraints"@en ;
    rdfs:comment "CRITICAL: High memory usage pattern"@en ;
    perf:executionComplexity "O(n)" ;
    perf:memoryFootprint 384 ;
    perf:estimatedThroughput 150000 ;
    perf:estimatedLatency 600 ;
    bwp:criticalForPerformance true .

bwp:MultipleInstancesWithoutSynchronization yawlmap:mapsToYAWL yawl:MultipleInstanceTask .

## WCP-16: Deferred Choice Pattern Mapping (MISSING - STATE-BASED)
yawlmap:DeferredChoiceMapping a yawlmap:PatternMapping ;
    rdfs:label "Deferred Choice Pattern Mapping"@en ;
    rdfs:comment "Maps WCP-16 Deferred Choice to YAWL event-driven tasks (MISSING)"@en ;
    yawlmap:mapsPattern bwp:DeferredChoice ;
    yawlmap:mapsToYAWL yawl:AtomicTask ;
    yawlmap:yawlSpecificationId "advanced-patterns" ;
    yawlmap:yawlNetId "DeferredChoicePattern" ;
    yawlmap:implementationFunction "bitflow_event_listener_STUB, bitflow_event_handler_STUB" ;
    yawlmap:hasExecutionSemantics yawlmap:DeferredChoiceSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:DeferredChoiceConstraints .

yawlmap:DeferredChoiceSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Deferred Choice Execution Semantics"@en ;
    rdfs:comment "Choice between alternatives made by environment, not workflow"@en ;
    yawlmap:executionComplexity 6 ;  # 6 CPU ticks for event handling
    yawlmap:memoryRequirement 160 ;  # 160 bytes
    yawlmap:timeoutDuration 550000 . # 550μs

yawlmap:DeferredChoiceConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Deferred Choice Performance Constraints"@en ;
    rdfs:comment "Event-driven pattern with external dependencies"@en ;
    perf:executionComplexity "O(n)" ;
    perf:memoryFootprint 160 ;
    perf:estimatedThroughput 180000 ;
    perf:estimatedLatency 550 .

bwp:DeferredChoice yawlmap:mapsToYAWL yawl:AtomicTask .

# =====================================================================
# PATTERN MAPPINGS: BITFLOW EXTENSION PATTERNS (26-43) - CRITICAL
# =====================================================================

## BF-26: Bulk Execution Pattern Mapping (CRITICAL FOR 52,704x FRAUD)
yawlmap:BulkExecutionMapping a yawlmap:PatternMapping ;
    rdfs:label "Bulk Execution Pattern Mapping"@en ;
    rdfs:comment "Maps BF-26 Bulk Execution to YAWL vectorized task (CRITICAL)"@en ;
    yawlmap:mapsPattern bwp:BulkExecution ;
    yawlmap:mapsToYAWL yawl:AtomicTask ;
    yawlmap:yawlSpecificationId "extension-patterns" ;
    yawlmap:yawlNetId "BulkExecutionPattern" ;
    yawlmap:implementationFunction "bitflow_pattern_bulk_execution_STUB" ;
    yawlmap:hasExecutionSemantics yawlmap:BulkExecutionSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:BulkExecutionConstraints .

yawlmap:BulkExecutionSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Bulk Execution Execution Semantics"@en ;
    rdfs:comment "Execute multiple instances in vectorized batch - ADDRESSES 52,704x FRAUD"@en ;
    yawlmap:executionComplexity 4 ;  # 4 CPU ticks for vectorized batch
    yawlmap:memoryRequirement 1024 ; # 1KB for batch processing
    yawlmap:timeoutDuration 50000 .  # 50μs ultra-fast

yawlmap:BulkExecutionConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Bulk Execution Performance Constraints"@en ;
    rdfs:comment "CRITICAL: Must achieve 2M ops/sec to address performance fraud"@en ;
    perf:executionComplexity "O(n/k)" ;
    perf:memoryFootprint 1024 ;
    perf:estimatedThroughput 2000000 ;
    perf:estimatedLatency 50 ;
    bwp:criticalForPerformance true ;
    bwp:performanceImpact "CRITICAL" .

bwp:BulkExecution yawlmap:mapsToYAWL yawl:AtomicTask .

## BF-27: Pipelined Execution Pattern Mapping (CRITICAL FOR 374MB LEAK)
yawlmap:PipelinedExecutionMapping a yawlmap:PatternMapping ;
    rdfs:label "Pipelined Execution Pattern Mapping"@en ;
    rdfs:comment "Maps BF-27 Pipelined Execution to YAWL pipeline task (CRITICAL)"@en ;
    yawlmap:mapsPattern bwp:PipelinedExecution ;
    yawlmap:mapsToYAWL yawl:CompositeTask ;
    yawlmap:yawlSpecificationId "extension-patterns" ;
    yawlmap:yawlNetId "PipelinedExecutionPattern" ;
    yawlmap:implementationFunction "bitflow_pipeline_stage_STUB" ;
    yawlmap:hasExecutionSemantics yawlmap:PipelinedExecutionSemantics ;
    yawlmap:hasPerformanceConstraint yawlmap:PipelinedExecutionConstraints .

yawlmap:PipelinedExecutionSemantics a yawlmap:ExecutionSemantics ;
    rdfs:label "Pipelined Execution Execution Semantics"@en ;
    rdfs:comment "Pipeline stages with overlapping execution - ADDRESSES 374MB MEMORY LEAK"@en ;
    yawlmap:executionComplexity 6 ;  # 6 CPU ticks for pipeline coordination
    yawlmap:memoryRequirement 512 ;  # 512 bytes controlled memory
    yawlmap:timeoutDuration 75000 .  # 75μs

yawlmap:PipelinedExecutionConstraints a yawlmap:PerformanceConstraint ;
    rdfs:label "Pipelined Execution Performance Constraints"@en ;
    rdfs:comment "CRITICAL: Must prevent memory leaks through controlled pipeline"@en ;
    perf:executionComplexity "O(n+k)" ;
    perf:memoryFootprint 512 ;
    perf:estimatedThroughput 1500000 ;
    perf:estimatedLatency 75 ;
    bwp:criticalForPerformance true ;
    bwp:performanceImpact "CRITICAL" .

bwp:PipelinedExecution yawlmap:mapsToYAWL yawl:CompositeTask .

## BF-36: Lock-Free Coordination Pattern Mapping (ULTRA-HIGH PERFORMANCE)
yawlmap:LockFreeCoordinationMapping a yawlmap:PatternMapping ;
    rdfs:label "Lock-Free Coordination Pattern Mapping"@en ;
