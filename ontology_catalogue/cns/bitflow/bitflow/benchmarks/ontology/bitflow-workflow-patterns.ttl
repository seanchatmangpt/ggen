bwp:AdaptiveLoadBalancing a bwp:HighPerformancePattern ;
    rdfs:label "Adaptive Load Balancing (BF-43)"@en ;
    rdfs:comment "Dynamic work distribution based on system load"@en ;
    bwp:patternId 43 ;
