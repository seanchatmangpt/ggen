# =====================================================================
# PERFORMANCE METRIC CLASSES
# =====================================================================

perf:PerformanceMetric a owl:Class ;
    rdfs:label "Performance Metric"@en ;
    rdfs:comment "Measurable performance characteristic"@en .

perf:ThroughputMetric a owl:Class ;
    rdfs:label "Throughput Metric"@en ;
    rdfs:comment "Operations per second measurement"@en ;
    rdfs:subClassOf perf:PerformanceMetric .

perf:LatencyMetric a owl:Class ;
    rdfs:label "Latency Metric"@en ;
    rdfs:comment "Response time measurement"@en ;
    rdfs:subClassOf perf:PerformanceMetric .

perf:MemoryMetric a owl:Class ;
    rdfs:label "Memory Metric"@en ;
    rdfs:comment "Memory usage measurement"@en ;
    rdfs:subClassOf perf:PerformanceMetric .

# =====================================================================
# PERFORMANCE FRAUD DETECTION RULES
# =====================================================================

# Define performance fraud detection thresholds
bwp:PerformanceFraudThreshold a owl:Class ;
    rdfs:label "Performance Fraud Threshold"@en ;
    rdfs:comment "Threshold for detecting 52,704x performance degradation"@en .

bwp:performanceFraudFactor a owl:DatatypeProperty ;
    rdfs:label "performance fraud factor"@en ;
    rdfs:comment "Multiplier indicating performance degradation (52,704x)"@en ;
    rdfs:domain bwp:PerformanceFraudThreshold ;
    rdfs:range xsd:double .

bwp:memoryLeakThreshold a owl:DatatypeProperty ;
    rdfs:label "memory leak threshold"@en ;
    rdfs:comment "Memory usage threshold for leak detection (374MB)"@en ;
    rdfs:domain bwp:PerformanceFraudThreshold ;
    rdfs:range xsd:long .

# Performance fraud detection instance
bwp:BitFlowPerformanceFraud a bwp:PerformanceFraudThreshold ;
    rdfs:label "BitFlow Performance Fraud Detection"@en ;
    rdfs:comment "Specific thresholds for BitFlow performance fraud detection"@en ;
    bwp:performanceFraudFactor 52704.0 ;
    bwp:memoryLeakThreshold 392167424 .  # 374MB in bytes

# =====================================================================
# YAWL INTEGRATION MAPPINGS
# =====================================================================

# Map BitFlow patterns to YAWL constructs
bwp:mapsToYAWLConstruct a owl:ObjectProperty ;
    rdfs:label "maps to YAWL construct"@en ;
    rdfs:comment "Maps BitFlow pattern to equivalent YAWL construct"@en ;
    rdfs:domain bwp:WorkflowPattern ;
    rdfs:range yawl:YAWLConstruct .

# Example YAWL mappings
bwp:Sequence bwp:mapsToYAWLConstruct yawl:SequenceTask .
bwp:ParallelSplit bwp:mapsToYAWLConstruct yawl:ANDSplit .
bwp:Synchronization bwp:mapsToYAWLConstruct yawl:ANDJoin .
bwp:ExclusiveChoice bwp:mapsToYAWLConstruct yawl:XORSplit .
bwp:SimpleMerge bwp:mapsToYAWLConstruct yawl:XORJoin .

# =====================================================================
# SPARQL QUERY EXAMPLES FOR MISSING PATTERNS
# =====================================================================

# The following are example SPARQL queries that can be used to query this ontology:

# Query 1: Find all missing patterns critical for performance
# SELECT ?pattern ?label WHERE {
#   ?pattern bwp:bitflowImplemented false .
#   ?pattern bwp:criticalForPerformance true .
#   ?pattern rdfs:label ?label .
# }

# Query 2: Find patterns with high memory footprint (>500 bytes)
# SELECT ?pattern ?label ?memory WHERE {
#   ?pattern perf:memoryFootprint ?memory .
#   ?pattern rdfs:label ?label .
#   FILTER (?memory > 500)
# }

# Query 3: Find patterns that require other patterns
# SELECT ?pattern ?required ?patternLabel ?requiredLabel WHERE {
#   ?pattern bwp:requires ?required .
#   ?pattern rdfs:label ?patternLabel .
#   ?required rdfs:label ?requiredLabel .
# }

# Query 4: Find BitFlow extension patterns (26-43)
# SELECT ?pattern ?label WHERE {
#   ?pattern bwp:patternId ?id .
#   ?pattern rdfs:label ?label .
#   FILTER (?id >= 26 && ?id <= 43)
# }

# Query 5: Performance fraud detection candidates
# SELECT ?pattern ?label ?throughput WHERE {
#   ?pattern perf:estimatedThroughput ?throughput .
#   ?pattern rdfs:label ?label .
#   FILTER (?throughput < 100000)
# }