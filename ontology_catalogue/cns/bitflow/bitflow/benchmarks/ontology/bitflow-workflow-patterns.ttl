# =====================================================================
# BITFLOW EXTENSION PATTERNS (26-43) - CRITICAL FOR PERFORMANCE
# =====================================================================

## Stream Processing Patterns (26-35)
bwp:BulkExecution a bwp:StreamProcessingPattern ;
    rdfs:label "Bulk Execution (BF-26)"@en ;
