    cns:hasContingency cns:FederalRejectionContingency ;
    cns:hasContingency cns:NevadaNotarizationContingency ;
    cns:hasContingency cns:SystemFailureContingency .

cns:CaliforniaDelayContingency cns:hasResponse "Parallel Nevada preparation acceleration" ;
    cns:hasTimelineAdjustment "2-day compression of Nevada timeline" ;
    cns:hasResourceReallocation "Additional notarization coordination" .

# Timeline Coordination
cns:TimelineCoordination a owl:Class ;
    rdfs:label "Inter-Filing Timeline Coordination" .

cns:timeline_coordination_2025 a cns:TimelineCoordination ;
    cns:hasCoordinationPoint cns:CaliforniaFederalTransition ;
    cns:hasCoordinationPoint cns:FederalNevadaTransition ;
    cns:hasCoordinationPoint cns:CompletionSynchronization .

cns:CaliforniaFederalTransition cns:hasGapDuration "2 business days" ;
    cns:hasRationale "Allows California processing and precedent establishment" ;
    cns:hasValidationRequirement "California filing receipt confirmation" .

cns:FederalNevadaTransition cns:hasGapDuration "5 business days" ;
    cns:hasRationale "Allows federal case assignment and Nevada preparation" ;
    cns:hasValidationRequirement "Federal case number assignment" .

# Document Readiness Matrix
