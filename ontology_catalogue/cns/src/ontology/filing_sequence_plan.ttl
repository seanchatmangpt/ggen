    cns:hasDocument cns:FederalCivilComplaint ;
    cns:hasDocument cns:NevadaBarComplaint ;
    cns:hasDocument cns:SupportingExhibits .

cns:CaliforniaBarComplaint cns:hasReadinessStatus cns:Complete ;
    cns:hasValidationStatus cns:FilingLogicOptimized ;
    cns:hasContradictionStatus cns:NoContradictionsDetected ;
    cns:hasNarrativeAlignment cns:Synchronized ;
