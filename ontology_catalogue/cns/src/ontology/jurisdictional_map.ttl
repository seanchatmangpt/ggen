@prefix cns: <http://cns-litigation.org/ontology#> .
@prefix legal: <http://legal-framework.org/ontology#> .
@prefix geo: <http://geo-jurisdiction.org/ontology#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Jurisdictional Mapping for CNS Legal Coordination
# Cognitive Intelligence Analysis - Regulatory Schema Overlay
# Generated by Filing Logic Optimizer & Jurisdictional Overlay Builder

# Primary Jurisdiction Classes
cns:Jurisdiction a owl:Class ;
    rdfs:label "Legal Jurisdiction" ;
    rdfs:comment "Geographic and regulatory authority domains" .

cns:StateJurisdiction rdfs:subClassOf cns:Jurisdiction .
cns:FederalJurisdiction rdfs:subClassOf cns:Jurisdiction .
cns:BarJurisdiction rdfs:subClassOf cns:Jurisdiction .

# California State Jurisdiction
cns:CaliforniaState a cns:StateJurisdiction ;
    cns:hasStateCode "CA" ;
    cns:hasCapital "Sacramento" ;
    cns:hasLegalFramework cns:CaliforniaCivilCode ;
    cns:hasBarAuthority cns:StateBarCalifornia ;
    cns:hasCourtSystem cns:CaliforniaSupriorCourt .

cns:CaliforniaSupriorCourt cns:hasJurisdiction cns:GeneralJurisdiction ;
    cns:hasFilingRequirements cns:CaliforniaFilingRules ;
    cns:hasServiceRequirements cns:CaliforniaServiceRules ;
    cns:hasStatuteLimitations cns:CaliforniaStatuteLimitations .

cns:StateBarCalifornia a cns:BarJurisdiction ;
    cns:hasComplaintProcess cns:OnlineFiling ;
    cns:requiresNotarization "false"^^xsd:boolean ;
    cns:hasStatuteLimitations "5 years" ;
    cns:hasJurisdictionalScope cns:CaliforniaLicensedAttorneys ;
    cns:hasFilingFee "0"^^xsd:decimal ;
    cns:hasProcessingTime "90-180 days" .

# Nevada State Jurisdiction
cns:NevadaState a cns:StateJurisdiction ;
    cns:hasStateCode "NV" ;
    cns:hasCapital "Carson City" ;
    cns:hasLegalFramework cns:NevadaRevisedStatutes ;
    cns:hasBarAuthority cns:StateBarNevada ;
    cns:hasCourtSystem cns:NevadaDistrictCourt .

cns:NevadaDistrictCourt cns:hasJurisdiction cns:GeneralJurisdiction ;
    cns:hasFilingRequirements cns:NevadaFilingRules ;
    cns:hasServiceRequirements cns:NevadaServiceRules ;
    cns:hasStatuteLimitations cns:NevadaStatuteLimitations .

cns:StateBarNevada a cns:BarJurisdiction ;
    cns:hasComplaintProcess cns:PhysicalFiling ;
    cns:requiresNotarization "true"^^xsd:boolean ;
    cns:hasStatuteLimitations "4 years" ;
    cns:hasJurisdictionalScope cns:NevadaLicensedAttorneys ;
    cns:hasFilingFee "25"^^xsd:decimal ;
    cns:hasProcessingTime "120-240 days" ;
    cns:requiresEconomicHarm "true"^^xsd:boolean .

# Federal Jurisdiction
cns:FederalDistrictCourt a cns:FederalJurisdiction ;
    cns:hasSystemType "Article III Court" ;
    cns:hasFilingSystem cns:CMECF ;
    cns:hasJurisdictionalBasis cns:FederalQuestion ;
    cns:hasJurisdictionalBasis cns:DiversityJurisdiction ;
    cns:hasRulesFramework cns:FederalRulesCivilProcedure .

cns:CMECF cns:requiresECFAccount "true"^^xsd:boolean ;
    cns:hasFilingFee "402"^^xsd:decimal ;
    cns:allowsElectronicService "true"^^xsd:boolean ;
    cns:hasBusinessHours "24/7 electronic" ;
    cns:requiresCaseNumber "true"^^xsd:boolean .

# Cross-Jurisdictional Analysis
cns:JurisdictionalOverlay a owl:Class ;
    rdfs:label "Cross-Jurisdictional Analysis Framework" ;
    rdfs:comment "Interaction analysis between multiple jurisdictions" .

cns:overlay_ca_nv_federal a cns:JurisdictionalOverlay ;
    cns:hasJurisdiction cns:CaliforniaState ;
    cns:hasJurisdiction cns:NevadaState ;
    cns:hasJurisdiction cns:FederalDistrictCourt ;
    cns:hasComplexityLevel cns:High ;
    cns:requiresCoordination "true"^^xsd:boolean .

# Regulatory Schema Interactions
cns:RegulatorySchema a owl:Class ;
    rdfs:label "Regulatory Framework Interaction Model" .

cns:state_federal_interaction a cns:RegulatorySchema ;
    cns:hasPreemptionAnalysis cns:NoFederalPreemption ;
    cns:hasComityRequirements cns:InterstateComity ;
    cns:hasConflictLaws cns:ConflictOfLawsAnalysis ;
    cns:hasUniformityRequirements cns:ModelRulesAlignment .

# Bar Complaint Coordination
cns:BarComplaintStrategy a owl:Class ;
    rdfs:label "Multi-Jurisdictional Bar Complaint Strategy" .

cns:bar_strategy_2025 a cns:BarComplaintStrategy ;
    cns:hasPrimaryJurisdiction cns:StateBarCalifornia ;
    cns:hasSecondaryJurisdiction cns:StateBarNevada ;
    cns:hasFilingSequence cns:SequentialFiling ;
    cns:hasTimingStrategy cns:CoordinatedTiming .

cns:SequentialFiling cns:hasOrder cns:CaliforniaFirst ;
    cns:hasReason "No notarization requirement" ;
    cns:hasTimeframe "5 business days" ;
    cns:hasFollowUp cns:NevadaSecond .

cns:NevadaSecond cns:hasDelay "10 business days" ;
    cns:hasReason "Notarization processing time" ;
    cns:hasPrerequisite cns:CaliforniaFiling ;
    cns:requiresDocumentation cns:EconomicHarmEvidence .

# Court Filing Coordination
cns:CourtFilingStrategy a owl:Class ;
    rdfs:label "Multi-Jurisdictional Court Filing Strategy" .

cns:court_strategy_2025 a cns:CourtFilingStrategy ;
    cns:hasPreferredJurisdiction cns:FederalDistrictCourt ;
    cns:hasJurisdictionalBasis cns:FederalQuestion ;
    cns:hasBackupJurisdiction cns:CaliforniaSupriorCourt ;
    cns:hasVenue cns:NorthernDistrictCalifornia .

# Procedural Requirements Matrix
cns:ProceduralMatrix a owl:Class ;
    rdfs:label "Cross-Jurisdictional Procedural Requirements" .

cns:procedural_matrix_2025 a cns:ProceduralMatrix ;
    cns:hasRequirement cns:CaliforniaRequirements ;
    cns:hasRequirement cns:NevadaRequirements ;
    cns:hasRequirement cns:FederalRequirements .

cns:CaliforniaRequirements cns:hasServiceMethod cns:PersonalService ;
    cns:hasServiceMethod cns:SubstitutedService ;
    cns:hasFilingDeadline "30 days after service" ;
    cns:requiresVerification "true"^^xsd:boolean ;
    cns:allowsElectronicFiling "true"^^xsd:boolean .

cns:NevadaRequirements cns:hasServiceMethod cns:PersonalService ;
    cns:hasServiceMethod cns:MailService ;
    cns:hasFilingDeadline "20 days after service" ;
    cns:requiresVerification "true"^^xsd:boolean ;
    cns:allowsElectronicFiling "limited"^^xsd:string .

cns:FederalRequirements cns:hasServiceMethod cns:Rule4Service ;
    cns:hasFilingDeadline "21 days after service" ;
    cns:requiresVerification "under penalty of perjury" ;
    cns:allowsElectronicFiling "true"^^xsd:boolean ;
    cns:requiresCMECF "true"^^xsd:boolean .

# Timeline Optimization
cns:JurisdictionalTiming a owl:Class ;
    rdfs:label "Optimized Timeline Across Jurisdictions" .

cns:timing_optimization_2025 a cns:JurisdictionalTiming ;
    cns:hasPhase cns:PreparationPhase ;
    cns:hasPhase cns:FilingPhase ;
    cns:hasPhase cns:ServicePhase ;
    cns:hasPhase cns:ResponsePhase .

cns:PreparationPhase cns:hasDuration "14 days" ;
    cns:includes cns:DocumentDrafting ;
    cns:includes cns:NotarizationProcessing ;
    cns:includes cns:EvidenceCompilation ;
    cns:includes cns:JurisdictionalCompliance .

# Compliance Monitoring
cns:ComplianceMonitoring a owl:Class ;
    rdfs:label "Multi-Jurisdictional Compliance Tracking" .

cns:compliance_2025 a cns:ComplianceMonitoring ;
    cns:monitors cns:CaliforniaCompliance ;
    cns:monitors cns:NevadaCompliance ;
    cns:monitors cns:FederalCompliance ;
    cns:hasAutomatedAlerts "true"^^xsd:boolean ;
    cns:hasRealtimeTracking "true"^^xsd:boolean .

# Risk Assessment by Jurisdiction
cns:JurisdictionalRisk a owl:Class ;
    rdfs:label "Jurisdiction-Specific Risk Analysis" .

cns:risk_by_jurisdiction a cns:JurisdictionalRisk ;
    cns:hasRisk cns:CaliforniaRisk ;
    cns:hasRisk cns:NevadaRisk ;
    cns:hasRisk cns:FederalRisk .

cns:CaliforniaRisk cns:hasLevel "Low-Moderate" ;
    cns:hasFactors "Favorable bar complaint process, no notarization" ;
    cns:hasMitigation "Online filing, established procedures" .

cns:NevadaRisk cns:hasLevel "Moderate" ;
    cns:hasFactors "Notarization requirement, economic harm standard" ;
    cns:hasMitigation "Preparation time allocation, documentation" .

cns:FederalRisk cns:hasLevel "Moderate-High" ;
    cns:hasFactors "Federal question analysis, CMECF requirements" ;
    cns:hasMitigation "Federal bar admission, procedural expertise" .

