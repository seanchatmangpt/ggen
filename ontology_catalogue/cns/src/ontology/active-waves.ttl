# TAI Cognitive Mesh - Active Waves Layer
# Macro-pattern detection across actors with wave propagation dynamics
# Supports bit* ecosystem and cognitive primitives

@prefix tai: <http://tai.cognitive-mesh.org/ontology#> .
@prefix bit: <http://bit-ecosystem.org/ontology#> .
@prefix wave: <http://tai.cognitive-mesh.org/wave#> .
@prefix actor: <http://tai.cognitive-mesh.org/actor#> .
@prefix pattern: <http://tai.cognitive-mesh.org/pattern#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Wave Propagation Ontology
wave:Wave a owl:Class ;
    rdfs:label "Cognitive Wave" ;
    rdfs:comment "A propagating pattern of cognitive activity across the mesh" .

wave:WaveType a owl:Class ;
    rdfs:label "Wave Type" ;
    rdfs:comment "Classification of wave patterns" .

wave:MacroPattern a owl:Class ;
    rdfs:subClassOf wave:Wave ;
    rdfs:label "Macro Pattern" ;
    rdfs:comment "Large-scale emergent pattern spanning multiple actors" .

wave:WaveFront a owl:Class ;
    rdfs:label "Wave Front" ;
    rdfs:comment "Leading edge of wave propagation" .

wave:WaveInterference a owl:Class ;
    rdfs:label "Wave Interference" ;
    rdfs:comment "Interaction between multiple waves" .

# Wave Properties
wave:amplitude a owl:DatatypeProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range xsd:double ;
    rdfs:label "Wave Amplitude" .

wave:frequency a owl:DatatypeProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range xsd:double ;
    rdfs:label "Wave Frequency" .

wave:wavelength a owl:DatatypeProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range xsd:double ;
    rdfs:label "Wave Length" .

wave:velocity a owl:DatatypeProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range xsd:double ;
    rdfs:label "Propagation Velocity" .

wave:phase a owl:DatatypeProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range xsd:double ;
    rdfs:label "Wave Phase" .

# Wave Relationships
wave:propagatesThrough a owl:ObjectProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range actor:CognitiveActor ;
    rdfs:label "Propagates Through" .

wave:originatesFrom a owl:ObjectProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range actor:CognitiveActor ;
    rdfs:label "Originates From" .

wave:interferesWith a owl:ObjectProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range wave:Wave ;
    rdfs:label "Interferes With" .

wave:constructivelyWith a owl:ObjectProperty ;
    rdfs:subPropertyOf wave:interferesWith ;
    rdfs:label "Constructive Interference" .

wave:destructivelyWith a owl:ObjectProperty ;
    rdfs:subPropertyOf wave:interferesWith ;
    rdfs:label "Destructive Interference" .

# Active Wave Instances
wave:Alpha001 a wave:MacroPattern ;
    rdfs:label "Alpha Cognitive Wave 001" ;
    wave:amplitude 0.85 ;
    wave:frequency 2.3 ;
    wave:wavelength 15.7 ;
    wave:velocity 3.2 ;
    wave:phase 1.57 ;
    wave:originatesFrom actor:BitCore_Prime ;
    wave:propagatesThrough actor:BitFlow_Network, actor:BitActor_Swarm ;
    time:hasBeginning "2025-07-30T10:00:00Z"^^xsd:dateTime .

wave:Beta002 a wave:MacroPattern ;
    rdfs:label "Beta Cognitive Wave 002" ;
    wave:amplitude 0.72 ;
    wave:frequency 1.8 ;
    wave:wavelength 12.3 ;
    wave:velocity 2.9 ;
    wave:phase 0.78 ;
    wave:originatesFrom actor:BitThink_Mesh ;
    wave:propagatesThrough actor:BitFlow_Network, actor:BitAgent_Collective ;
    time:hasBeginning "2025-07-30T10:15:00Z"^^xsd:dateTime .

wave:Gamma003 a wave:MacroPattern ;
    rdfs:label "Gamma Cognitive Wave 003" ;
    wave:amplitude 0.91 ;
    wave:frequency 3.1 ;
    wave:wavelength 18.2 ;
    wave:velocity 3.8 ;
    wave:phase 2.35 ;
    wave:originatesFrom actor:BitMind_Core ;
    wave:propagatesThrough actor:BitActor_Swarm, actor:BitThink_Mesh ;
    time:hasBeginning "2025-07-30T10:30:00Z"^^xsd:dateTime .

# Wave Interference Patterns
wave:AlphaBetaInterference a wave:WaveInterference ;
    rdfs:label "Alpha-Beta Constructive Interference" ;
    wave:constructivelyWith wave:Alpha001, wave:Beta002 ;
    wave:amplitude 1.57 ;  # Combined amplitude
    pattern:emergentBehavior "Synchronized cognitive processing" ;
    time:hasBeginning "2025-07-30T10:15:00Z"^^xsd:dateTime .

wave:BetaGammaInterference a wave:WaveInterference ;
    rdfs:label "Beta-Gamma Destructive Interference" ;
    wave:destructivelyWith wave:Beta002, wave:Gamma003 ;
    wave:amplitude 0.19 ;  # Reduced amplitude
    pattern:emergentBehavior "Cognitive dampening in overlap region" ;
    time:hasBeginning "2025-07-30T10:30:00Z"^^xsd:dateTime .

# Emergent Behavior Tracking
pattern:EmergentBehavior a owl:Class ;
    rdfs:label "Emergent Behavior" ;
    rdfs:comment "Behaviors that emerge from wave interactions" .

pattern:CognitiveSynchrony a pattern:EmergentBehavior ;
    rdfs:label "Cognitive Synchrony" ;
    rdfs:comment "Synchronized cognitive states across actors" ;
    pattern:triggeredBy wave:AlphaBetaInterference ;
    pattern:affects actor:BitFlow_Network ;
    pattern:strength 0.85 .

pattern:CollectiveInsight a pattern:EmergentBehavior ;
    rdfs:label "Collective Insight" ;
    rdfs:comment "Distributed insight formation" ;
    pattern:triggeredBy wave:Gamma003 ;
    pattern:affects actor:BitThink_Mesh ;
    pattern:strength 0.91 .

pattern:CognitiveDampening a pattern:EmergentBehavior ;
    rdfs:label "Cognitive Dampening" ;
    rdfs:comment "Reduced cognitive activity in interference zones" ;
    pattern:triggeredBy wave:BetaGammaInterference ;
    pattern:affects actor:BitActor_Swarm ;
    pattern:strength 0.19 .

# Cross-Substrate Wave Propagation
wave:CrossSubstrateWave a owl:Class ;
    rdfs:subClassOf wave:Wave ;
    rdfs:label "Cross-Substrate Wave" ;
    rdfs:comment "Wave that propagates across different cognitive substrates" .

wave:Delta004 a wave:CrossSubstrateWave ;
    rdfs:label "Delta Cross-Substrate Wave 004" ;
    wave:amplitude 0.65 ;
    wave:frequency 2.7 ;
    wave:wavelength 14.1 ;
    wave:velocity 3.5 ;
    wave:phase 1.23 ;
    wave:originatesFrom actor:BitCore_Prime ;
    wave:propagatesThrough actor:Human_Substrate, actor:AI_Substrate, actor:Hybrid_Substrate ;
    pattern:crossSubstrateEffect "Information integration across cognitive domains" ;
    time:hasBeginning "2025-07-30T10:45:00Z"^^xsd:dateTime .

# Wave Decay and Attenuation
wave:decayRate a owl:DatatypeProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range xsd:double ;
    rdfs:label "Decay Rate" .

wave:attenuationFactor a owl:DatatypeProperty ;
    rdfs:domain wave:Wave ;
    rdfs:range xsd:double ;
    rdfs:label "Attenuation Factor" .

# Wave Pattern Detection Rules
pattern:WaveDetectionRule a owl:Class ;
    rdfs:label "Wave Detection Rule" ;
    rdfs:comment "Rules for detecting macro-patterns in wave activity" .

pattern:AmplitudeThreshold a pattern:WaveDetectionRule ;
    rdfs:label "Amplitude Threshold Detection" ;
    pattern:threshold 0.7 ;
    pattern:description "Detect waves with amplitude > 0.7" .

pattern:FrequencyResonance a pattern:WaveDetectionRule ;
    rdfs:label "Frequency Resonance Detection" ;
    pattern:resonanceRange "2.0-3.5"^^xsd:string ;
    pattern:description "Detect resonant frequency patterns" .

pattern:PhaseCoherence a pattern:WaveDetectionRule ;
    rdfs:label "Phase Coherence Detection" ;
    pattern:coherenceThreshold 0.8 ;
    pattern:description "Detect phase-coherent wave groups" .

# Real-time Wave Monitoring
wave:WaveMonitor a owl:Class ;
    rdfs:label "Wave Monitor" ;
    rdfs:comment "Real-time monitoring of wave activity" .

wave:Monitor_Alpha a wave:WaveMonitor ;
    rdfs:label "Alpha Wave Monitor" ;
    wave:monitors wave:Alpha001 ;
    wave:samplingRate 100.0 ;  # Hz
    wave:lastUpdate "2025-07-30T10:45:30Z"^^xsd:dateTime ;
    wave:status "ACTIVE" .

wave:Monitor_Beta a wave:WaveMonitor ;
    rdfs:label "Beta Wave Monitor" ;
    wave:monitors wave:Beta002 ;
    wave:samplingRate 100.0 ;  # Hz
    wave:lastUpdate "2025-07-30T10:45:30Z"^^xsd:dateTime ;
    wave:status "ACTIVE" .

wave:Monitor_Gamma a wave:WaveMonitor ;
    rdfs:label "Gamma Wave Monitor" ;
    wave:monitors wave:Gamma003 ;
    wave:samplingRate 100.0 ;  # Hz
    wave:lastUpdate "2025-07-30T10:45:30Z"^^xsd:dateTime ;
    wave:status "ACTIVE" .

# Wave History and Analytics
wave:WaveHistory a owl:Class ;
    rdfs:label "Wave History" ;
    rdfs:comment "Historical wave pattern data" .

wave:WaveAnalytics a owl:Class ;
    rdfs:label "Wave Analytics" ;
    rdfs:comment "Analytics derived from wave patterns" .

wave:HistoricalPattern a wave:WaveHistory ;
    rdfs:label "Historical Wave Pattern Alpha-001" ;
    wave:waveId "Alpha001" ;
    wave:duration 1800 ;  # 30 minutes in seconds
    wave:peakAmplitude 0.95 ;
    wave:averageAmplitude 0.85 ;
    wave:totalPropagation 47 ;  # Number of actors affected
    time:hasBeginning "2025-07-30T10:00:00Z"^^xsd:dateTime ;
    time:hasEnd "2025-07-30T10:30:00Z"^^xsd:dateTime .