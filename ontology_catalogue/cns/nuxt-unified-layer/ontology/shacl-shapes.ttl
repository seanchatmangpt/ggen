# SHACL Validation Shapes for Nuxt Unified Layer
# Fortune 5 Quality Governance and Compliance Rules
# UltraThink 80/20 HiveMind Implementation

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix nuxt: <https://nuxt.com/ontology#> .
@prefix bit: <https://nuxt.com/bit-systems#> .
@prefix perf: <https://nuxt.com/performance#> .
@prefix sec: <https://nuxt.com/security#> .

# =============================================================================
# CORE APPLICATION SHAPES
# =============================================================================

nuxt:ApplicationShape a sh:NodeShape ;
    sh:targetClass nuxt:Application ;
    sh:severity sh:Violation ;
    sh:message "Nuxt Application validation failed" ;
    
    # Performance contract is mandatory
    sh:property [
        sh:path nuxt:hasPerformanceContract ;
        sh:minCount 1 ;
        sh:class perf:PerformanceContract ;
        sh:message "Every Nuxt application MUST have at least one performance contract" ;
        sh:severity sh:Violation
    ] ;
    
    # Security policy is mandatory
    sh:property [
        sh:path nuxt:hasSecurityPolicy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sec:NuxtSecurityPolicy ;
        sh:message "Every Nuxt application MUST have exactly one security policy" ;
        sh:severity sh:Violation
    ] ;
    
    # Application name is required
    sh:property [
        sh:path nuxt:applicationName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:maxLength 255 ;
        sh:pattern "^[a-zA-Z0-9-_]+$" ;
        sh:message "Application name must be alphanumeric with hyphens/underscores (1-255 chars)" 
    ] .

# =============================================================================
# BIT* SYSTEM SHAPES
# =============================================================================

bit:BitSystemShape a sh:NodeShape ;
    sh:targetClass bit:BitSystem ;
    sh:severity sh:Violation ;
    
    # 8-tick contract is mandatory for all bit* systems
    sh:property [
        sh:path perf:hasContract ;
        sh:qualifiedValueShape [
            sh:class perf:EightTickContract
        ] ;
        sh:qualifiedMinCount 1 ;
        sh:message "All bit* systems MUST implement the 8-tick performance contract" ;
        sh:severity sh:Violation
    ] ;
    
    # System must declare capabilities
    sh:property [
        sh:path bit:capability ;
        sh:minCount 1 ;
        sh:class bit:Capability ;
        sh:message "Bit* systems must declare at least one capability"
    ] ;
    
    # Throughput must be specified
    sh:property [
        sh:path perf:throughput ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1000000 ;
        sh:message "Throughput must be at least 1M ops/sec"
    ] .

# BitFlow specific constraints
bit:BitFlowShape a sh:NodeShape ;
    sh:targetClass bit:BitFlow ;
    sh:property [
        sh:path perf:throughput ;
        sh:minInclusive 650000000 ;
        sh:message "BitFlow must achieve at least 650M ops/sec throughput"
    ] ;
    sh:property [
        sh:path bit:capability ;
        sh:hasValue bit:WorkflowExecution ;
        sh:message "BitFlow must have WorkflowExecution capability"
    ] .

# BitActor specific constraints  
bit:BitActorShape a sh:NodeShape ;
    sh:targetClass bit:BitActor ;
    sh:property [
        sh:path perf:maxActors ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1000 ;
        sh:maxInclusive 100000 ;
        sh:message "BitActor must support 1,000-100,000 concurrent actors"
    ] .

# BitStar multi-tenancy constraints
bit:BitStarShape a sh:NodeShape ;
    sh:targetClass bit:BitStar ;
    sh:property [
        sh:path sec:isolationLevel ;
        sh:in ( sec:Strict sec:Moderate sec:Relaxed ) ;
        sh:message "BitStar isolation level must be Strict, Moderate, or Relaxed"
    ] ;
    sh:property [
        sh:path bit:capability ;
        sh:hasValue bit:MultiTenancy ;
        sh:message "BitStar must have MultiTenancy capability"
    ] .

# =============================================================================
# PERFORMANCE CONTRACT SHAPES
# =============================================================================

perf:EightTickContractShape a sh:NodeShape ;
    sh:targetClass perf:EightTickContract ;
    sh:property [
        sh:path perf:maxCycles ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxInclusive 8 ;
        sh:message "8-tick contract violations: operations must complete within 8 CPU cycles" ;
        sh:severity sh:Violation
    ] ;
    sh:property [
        sh:path perf:enforcementLevel ;
        sh:hasValue perf:Critical ;
        sh:message "8-tick contract must have Critical enforcement level"
    ] .

perf:EightSpaceContractShape a sh:NodeShape ;
    sh:targetClass perf:EightSpaceContract ;
    sh:property [
        sh:path perf:quantumBytes ;
        sh:hasValue 8 ;
        sh:message "Memory must be 8-byte aligned"
    ] ;
    sh:property [
        sh:path perf:maxFragmentation ;
        sh:datatype xsd:decimal ;
        sh:maxInclusive 0.0 ;
        sh:message "Zero fragmentation guarantee violated"
    ] .

perf:SixSigmaContractShape a sh:NodeShape ;
    sh:targetClass perf:SixSigmaContract ;
    sh:property [
        sh:path perf:targetSigma ;
        sh:minInclusive 6 ;
        sh:message "Must maintain Six Sigma quality level"
    ] ;
    sh:property [
        sh:path perf:minCpk ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 20.0 ;
        sh:message "Cpk must be greater than 20 for Fortune 5 quality"
    ] ;
    sh:property [
        sh:path perf:defectsPPM ;
        sh:datatype xsd:decimal ;
        sh:maxInclusive 3.4 ;
        sh:message "Defects per million must not exceed 3.4"
    ] .

# =============================================================================
# COMPOSABLE CONTRACT SHAPES
# =============================================================================

perf:ComposableContractShape a sh:NodeShape ;
    sh:targetClass perf:ComposablePerformanceContract ;
    
    sh:property [
        sh:path perf:maxInitTime ;
        sh:datatype xsd:integer ;
        sh:maxInclusive 50 ;
        sh:message "Composable initialization must complete within 50ms"
    ] ;
    
    sh:property [
        sh:path perf:maxReactivityLatency ;
        sh:datatype xsd:integer ;
        sh:maxInclusive 16 ;
        sh:message "Reactivity latency must be <16ms for 60fps"
    ] ;
    
    sh:property [
        sh:path perf:maxMemoryUsage ;
        sh:datatype xsd:integer ;
        sh:maxInclusive 10 ;
        sh:message "Composable memory usage must not exceed 10MB"
    ] .

# =============================================================================
# SSR PERFORMANCE SHAPES
# =============================================================================

perf:SSRContractShape a sh:NodeShape ;
    sh:targetClass perf:SSRPerformanceContract ;
    
    sh:property [
        sh:path perf:maxRenderTime ;
        sh:datatype xsd:integer ;
        sh:maxInclusive 100 ;
        sh:message "SSR render time must not exceed 100ms"
    ] ;
    
    sh:property [
        sh:path perf:maxPayloadSize ;
        sh:datatype xsd:integer ;
        sh:maxInclusive 50 ;
        sh:message "SSR payload size must not exceed 50KB"
    ] .

perf:HydrationContractShape a sh:NodeShape ;
    sh:targetClass perf:HydrationContract ;
    
    sh:property [
        sh:path perf:maxHydrationTime ;
        sh:datatype xsd:integer ;
        sh:maxInclusive 200 ;
        sh:message "Hydration must complete within 200ms"
    ] ;
    
    sh:property [
        sh:path perf:maxCLS ;
        sh:datatype xsd:decimal ;
        sh:maxInclusive 0.1 ;
        sh:message "Cumulative Layout Shift must be < 0.1"
    ] ;
    
    sh:property [
        sh:path perf:maxFID ;
        sh:datatype xsd:integer ;
        sh:maxInclusive 100 ;
        sh:message "First Input Delay must be < 100ms"
    ] .

# =============================================================================
# SHADOW PIPELINE SHAPES
# =============================================================================

nuxt:ShadowPipelineShape a sh:NodeShape ;
    sh:targetClass nuxt:ShadowPipeline ;
    
    sh:property [
        sh:path nuxt:hasRolloutPercentage ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "Rollout percentage must be between 0 and 100"
    ] ;
    
    sh:property [
        sh:path nuxt:hasPerformanceComparison ;
        sh:minCount 1 ;
        sh:class perf:PerformanceComparison ;
        sh:message "Shadow pipeline must track performance comparison"
    ] ;
    
    sh:property [
        sh:path nuxt:rollbackThreshold ;
        sh:datatype xsd:decimal ;
        sh:minInclusive -50.0 ;
        sh:maxInclusive 0.0 ;
        sh:message "Rollback threshold must be negative percentage (-50% to 0%)"
    ] .

# =============================================================================
# SECURITY POLICY SHAPES
# =============================================================================

sec:Fortune5SecurityShape a sh:NodeShape ;
    sh:targetClass sec:Fortune5SecurityLevel ;
    
    sh:property [
        sh:path sec:requiresMFA ;
        sh:hasValue true ;
        sh:message "Fortune 5 security requires MFA authentication"
    ] ;
    
    sh:property [
        sh:path sec:requiresEncryption ;
        sh:in ( sec:AES256 sec:AES512 ) ;
        sh:message "Must use AES-256 or AES-512 encryption"
    ] ;
    
    sh:property [
        sh:path sec:requiresAuditLog ;
        sh:hasValue true ;
        sh:message "Audit logging is mandatory for Fortune 5 compliance"
    ] ;
    
    sh:property [
        sh:path sec:complianceLevel ;
        sh:in ( sec:SOC2Type2 sec:ISO27001 sec:PCI_DSS ) ;
        sh:message "Must have SOC2 Type II, ISO 27001, or PCI DSS compliance"
    ] .

sec:FederalSecurityShape a sh:NodeShape ;
    sh:targetClass sec:FederalSecurityLevel ;
    
    sh:property [
        sh:path sec:requiresFedRAMP ;
        sh:hasValue true ;
        sh:message "Federal systems require FedRAMP certification"
    ] ;
    
    sh:property [
        sh:path sec:requiresFIPS140_2 ;
        sh:hasValue true ;
        sh:message "Federal systems require FIPS 140-2 compliance"
    ] ;
    
    sh:property [
        sh:path sec:classificationLevel ;
        sh:in ( sec:Unclassified sec:Confidential sec:Secret sec:TopSecret ) ;
        sh:message "Must specify classification level"
    ] .

# =============================================================================
# WORKFLOW VALIDATION SHAPES
# =============================================================================

nuxt:WorkflowShape a sh:NodeShape ;
    sh:targetClass nuxt:Workflow ;
    
    sh:property [
        sh:path nuxt:hasStage ;
        sh:minCount 1 ;
        sh:class nuxt:WorkflowStage ;
        sh:message "Workflow must have at least one stage"
    ] ;
    
    sh:property [
        sh:path nuxt:maxExecutionTime ;
        sh:datatype xsd:duration ;
        sh:maxInclusive "PT30S"^^xsd:duration ;
        sh:message "Workflow execution must complete within 30 seconds"
    ] .

# =============================================================================
# CAPABILITY VALIDATION SHAPES
# =============================================================================

bit:CapabilityShape a sh:NodeShape ;
    sh:targetClass bit:Capability ;
    
    sh:property [
        sh:path bit:capabilityName ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:maxLength 100 ;
        sh:message "Capability name required (1-100 characters)"
    ] ;
    
    sh:property [
        sh:path bit:capabilityVersion ;
        sh:datatype xsd:string ;
        sh:pattern "^\\d+\\.\\d+\\.\\d+$" ;
        sh:message "Capability version must follow semantic versioning (x.y.z)"
    ] .

# =============================================================================
# CROSS-CUTTING CONCERNS
# =============================================================================

# Ensure all performance metrics are positive
perf:PerformanceMetricShape a sh:NodeShape ;
    sh:targetClass perf:PerformanceMetric ;
    
    sh:property [
        sh:path perf:value ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:message "Performance metric values must be non-negative"
    ] .

# Validate metric types
perf:MetricTypeShape a sh:NodeShape ;
    sh:targetClass perf:MetricType ;
    
    sh:property [
        sh:path perf:metricUnit ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Metric type must specify units"
    ] .

# =============================================================================
# COMPOSABLE VALIDATION
# =============================================================================

nuxt:ComposableShape a sh:NodeShape ;
    sh:targetClass nuxt:Composable ;
    
    sh:property [
        sh:path nuxt:composableName ;
        sh:datatype xsd:string ;
        sh:pattern "^use[A-Z][a-zA-Z0-9]*$" ;
        sh:message "Composable name must follow Vue convention (useXxx)"
    ] ;
    
    sh:property [
        sh:path perf:hasContract ;
        sh:minCount 1 ;
        sh:class perf:ComposablePerformanceContract ;
        sh:message "All composables must have performance contracts"
    ] ;
    
    sh:sparql [
        sh:message "Composables must not create circular dependencies" ;
        sh:prefixes [ sh:declare [ sh:prefix "nuxt" ; sh:namespace "https://nuxt.com/ontology#" ] ] ;
        sh:select """
            SELECT $this
            WHERE {
                $this nuxt:dependsOn+ $this .
            }
        """
    ] .

# End of SHACL Validation Shapes