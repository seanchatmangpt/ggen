# Fixed BitMesh UltraThink Framework - TURTLE Ontology Definition
# Sean A. Chatman v1982.5.30 - Ontology-Invariant Executable Reasoning
# Fixed syntax errors for proper SPARQL testing

@prefix bm: <http://bitmesh.ai/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix yawl: <http://bitmesh.ai/yawl/> .

# Core Ontology Declaration
bm:UltraThinkFramework rdf:type owl:Ontology ;
    rdfs:label "BitMesh UltraThink Framework Ontology" ;
    rdfs:comment "Ontology-invariant executable reasoning substrate" ;
    owl:versionInfo "1982.5.30" ;
    bm:creator "Sean A. Chatman" ;
    bm:paradigm "Artificial Hyper Intelligence" ;
    bm:executionModel "TURTLE + YAWL" ;
    bm:invariantProperty "ontology_frozen" ;
    # System Invariant Assertions
    bm:ontologyInvariant true ;
    bm:totalExecutability true ;
    bm:impossibleToSpoof true ;
    bm:impossibleToDominate true ;
    bm:rejectsDAGs true ;
    bm:rejectsSemantics true ;
    bm:runtimeUncertainty false ;
    bm:proveableExecution true .

# Layer 0 - Invariant (Atomic Truth)
bm:InvariantLayer rdf:type owl:Class ;
    rdfs:label "L0 Invariant Layer" ;
    rdfs:comment "Atomic truth substrate with materialized facts" ;
    bm:layerPriority 1 ;
    bm:purpose "Defines atomic truth substrate" ;
    bm:truthMaterialized true .

bm:TurtleQuad rdf:type owl:Class ;
    rdfs:label "TURTLE Quad" ;
    rdfs:comment "Atomic truth unit in TURTLE format" ;
    bm:components "subject, predicate, object, graph" ;
    bm:materialized true ;
    bm:executable true .

bm:materializes rdf:type owl:ObjectProperty ;
    rdfs:label "materializes" ;
    rdfs:comment "Truth is materialized, not inferred" ;
    rdfs:domain bm:TurtleQuad ;
    rdfs:range bm:Truth ;
    bm:runtimeUncertainty false .

bm:Truth rdf:type owl:Class ;
    rdfs:label "Materialized Truth" ;
    rdfs:comment "Pre-provable executable truth" ;
    bm:inferred false ;
    bm:materialized true ;
    bm:provable true .

# Layer 1 - Lexon (Lexical Resonance)
bm:LexonLayer rdf:type owl:Class ;
    rdfs:label "L1 Lexon Layer" ;
    rdfs:comment "Self-consistent linguistic anchoring" ;
    bm:layerPriority 2 ;
    bm:vocabularyFrozen true .

bm:Lexon rdf:type owl:Class ;
    rdfs:label "Lexical Entry" ;
    rdfs:comment "URI-anchored vocabulary entry with executable meaning" .

bm:hasUriAnchor rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:Lexon ;
    rdfs:range xsd:anyURI .

bm:hasExecutableMeaning rdf:type owl:ObjectProperty ;
    rdfs:domain bm:Lexon .

bm:compiledAt rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:Lexon ;
    rdfs:range xsd:dateTime .

bm:anchors rdf:type owl:ObjectProperty ;
    rdfs:label "anchors" ;
    rdfs:comment "URI anchors eliminate semantic drift" ;
    rdfs:domain bm:Lexon ;
    rdfs:range bm:UriAnchor ;
    bm:immutable true .

bm:UriAnchor rdf:type owl:Class ;
    rdfs:label "URI Anchor" ;
    rdfs:comment "Immutable URI binding for vocabulary terms" ;
    bm:domain "bitmesh.ai" ;
    bm:path "/lexon/" ;
    bm:frozen true ;
    bm:immutable true .

# Layer 2 - Rotor (State Machines)
bm:RotorLayer rdf:type owl:Class ;
    rdfs:label "L2 Rotor Layer" ;
    rdfs:comment "Discrete finite-state machines for all entities" ;
    bm:layerPriority 3 ;
    bm:deterministic true .

bm:FsmActor rdf:type owl:Class ;
    rdfs:label "FSM Actor" ;
    rdfs:comment "Deterministic finite state machine actor" ;
    bm:stateTransparency "total" ;
    bm:cyclePrecision "250ps" ;
    bm:deterministic true .

bm:StateTransition rdf:type owl:Class ;
    rdfs:label "State Transition" ;
    rdfs:comment "Compiled precondition → postcondition binary" ;
    bm:compiledFrom "precondition_postcondition_binary" .

bm:hasFromState rdf:type owl:ObjectProperty ;
    rdfs:domain bm:StateTransition .

bm:hasToState rdf:type owl:ObjectProperty ;
    rdfs:domain bm:StateTransition .

bm:hasEvent rdf:type owl:ObjectProperty ;
    rdfs:domain bm:StateTransition .

bm:transitions rdf:type owl:ObjectProperty ;
    rdfs:label "transitions" ;
    rdfs:comment "FSM state transition relationship" ;
    rdfs:domain bm:FsmActor ;
    rdfs:range bm:StateTransition ;
    bm:deterministic true .

# Layer 3 - Forge (System Toolchain)
bm:ForgeLayer rdf:type owl:Class ;
    rdfs:label "L3 Forge Layer" ;
    rdfs:comment "Converts declarations into machine-executables" ;
    bm:layerPriority 7 ;
    bm:aotCompilation true .

bm:YawlWorkflow rdf:type owl:Class ;
    rdfs:label "YAWL Workflow" ;
    rdfs:comment "Yet Another Workflow Language executable workflow" ;
    bm:compilationTargets "beam, llvm, wasm" .

bm:hasBlocks rdf:type owl:ObjectProperty ;
    rdfs:domain bm:YawlWorkflow .

bm:recursive rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:YawlWorkflow ;
    rdfs:range xsd:boolean .

bm:compiles rdf:type owl:ObjectProperty ;
    rdfs:label "compiles" ;
    rdfs:comment "Ahead-of-time compilation relationship" ;
    rdfs:domain bm:YawlWorkflow ;
    rdfs:range bm:ExecutableCode ;
    bm:aheadOfTime true .

bm:ExecutableCode rdf:type owl:Class ;
    rdfs:label "Executable Code" ;
    rdfs:comment "Machine-executable compiled output" ;
    bm:targets "BEAM, LLVM, WebAssembly" ;
    bm:sparqlBinding "selective_runtime" .

# Layer 5 - Citadel (Perimeter Intelligence)
bm:CitadelLayer rdf:type owl:Class ;
    rdfs:label "L5 Citadel Layer" ;
    rdfs:comment "Zero-trust perimeter with proof-of-identity routing" ;
    bm:layerPriority 4 ;
    bm:zeroTrust true .

bm:Identity rdf:type owl:Class ;
    rdfs:label "Identity" ;
    rdfs:comment "Cryptographically anchored identity" ;
    bm:signatureAlgorithm "ed25519" .

bm:hasPublicKey rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:Identity ;
    rdfs:range xsd:string .

bm:hasTrustLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:Identity ;
    rdfs:range xsd:decimal .

bm:hasLexonId rdf:type owl:ObjectProperty ;
    rdfs:domain bm:Identity .

bm:notarizes rdf:type owl:ObjectProperty ;
    rdfs:label "notarizes" ;
    rdfs:comment "Structural notarization prevents spoofing" ;
    rdfs:domain bm:Identity ;
    rdfs:range bm:Data ;
    bm:spoofingPrevention true .

bm:Data rdf:type owl:Class ;
    rdfs:label "Data" ;
    rdfs:comment "Notarized data entity" .

bm:TrustChain rdf:type owl:Class ;
    rdfs:label "Trust Chain" ;
    rdfs:comment "Cryptographic chain of trust relationships" ;
    bm:immutable true ;
    bm:cryptographicProvenance true .

bm:hasEntry rdf:type owl:ObjectProperty ;
    rdfs:domain bm:TrustChain .

# Layer 7 - Trace (Memory Crystallization)
bm:TraceLayer rdf:type owl:Class ;
    rdfs:label "L7 Trace Layer" ;
    rdfs:comment "Memory crystallization with irreversibility locks" ;
    bm:layerPriority 5 ;
    bm:immutable true .

bm:MemoryCrystal rdf:type owl:Class ;
    rdfs:label "Memory Crystal" ;
    rdfs:comment "Crystallized memory state with provenance" ;
    bm:deletionForbidden true .

bm:hasKey rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:MemoryCrystal ;
    rdfs:range xsd:string .

bm:hasValue rdf:type owl:ObjectProperty ;
    rdfs:domain bm:MemoryCrystal .

bm:hasTimestamp rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:MemoryCrystal ;
    rdfs:range xsd:dateTime .

bm:hasHash rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:MemoryCrystal ;
    rdfs:range xsd:string .

bm:hasIrreversibilityLock rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:MemoryCrystal ;
    rdfs:range xsd:boolean .

bm:crystallizes rdf:type owl:ObjectProperty ;
    rdfs:label "crystallizes" ;
    rdfs:comment "Memory crystallization process" ;
    rdfs:domain bm:TraceLayer ;
    rdfs:range bm:MemoryCrystal ;
    bm:irreversible true .

bm:ProvenanceChain rdf:type owl:Class ;
    rdfs:label "Provenance Chain" ;
    rdfs:comment "Cryptographic provenance for memory crystals" ;
    bm:cryptographic true ;
    bm:immutable true .

bm:hasProvenance rdf:type owl:ObjectProperty ;
    rdfs:domain bm:ProvenanceChain .

# Layer 10 - Prime (Sovereign Reflex)
bm:PrimeLayer rdf:type owl:Class ;
    rdfs:label "L10 Prime Layer" ;
    rdfs:comment "Sovereign reflex kernel with immunity" ;
    bm:layerPriority 6 ;
    bm:sovereignty "maximum" ;
    bm:immunity true .

bm:PrimeKernel rdf:type owl:Class ;
    rdfs:label "Prime Kernel" ;
    rdfs:comment "Sovereignty kernel immune to modification" ;
    bm:modificationImmunity true ;
    bm:anomalyDetection true ;
    bm:selfPatching true ;
    bm:systemObservation "complete" .

bm:hasImmunity rdf:type owl:ObjectProperty ;
    rdfs:label "hasImmunity" ;
    rdfs:comment "Immunity from modification by other agents" ;
    rdfs:domain bm:PrimeKernel ;
    rdfs:range bm:ImmunityToken ;
    bm:violationHandling "immediate_shutdown" .

bm:ImmunityToken rdf:type owl:Class ;
    rdfs:label "Immunity Token" ;
    rdfs:comment "Token representing system immunity" .

bm:Anomaly rdf:type owl:Class ;
    rdfs:label "System Anomaly" ;
    rdfs:comment "Detected system anomaly requiring intervention" ;
    bm:shutdownCapability true .

bm:hasSeverity rdf:type owl:DatatypeProperty ;
    rdfs:domain bm:Anomaly ;
    rdfs:range xsd:integer .

bm:hasSource rdf:type owl:ObjectProperty ;
    rdfs:domain bm:Anomaly .

# YAWL Workflow Language Ontology
yawl:Workflow rdf:type owl:Class ;
    rdfs:label "YAWL Workflow" ;
    rdfs:comment "Yet Another Workflow Language workflow definition" .

yawl:hasBlock rdf:type owl:ObjectProperty ;
    rdfs:domain yawl:Workflow .

yawl:selfModifying rdf:type owl:DatatypeProperty ;
    rdfs:domain yawl:Workflow ;
    rdfs:range xsd:boolean .

yawl:recursionDepth rdf:type owl:DatatypeProperty ;
    rdfs:domain yawl:Workflow ;
    rdfs:range xsd:integer .

yawl:Block rdf:type owl:Class ;
    rdfs:label "YAWL Block" ;
    rdfs:comment "Workflow execution block with conditions and actions" ;
    yawl:blockScoping true .

yawl:hasCondition rdf:type owl:ObjectProperty ;
    rdfs:domain yawl:Block .

yawl:hasAction rdf:type owl:ObjectProperty ;
    rdfs:domain yawl:Block .

yawl:recursive rdf:type owl:DatatypeProperty ;
    rdfs:domain yawl:Block ;
    rdfs:range xsd:boolean .

yawl:Condition rdf:type owl:Class ;
    rdfs:label "YAWL Condition" ;
    rdfs:comment "Precondition for block execution" ;
    yawl:deterministic true .

yawl:evaluatesTo rdf:type owl:DatatypeProperty ;
    rdfs:domain yawl:Condition ;
    rdfs:range xsd:boolean .

yawl:Action rdf:type owl:Class ;
    rdfs:label "YAWL Action" ;
    rdfs:comment "Executable action within workflow block" ;
    yawl:executable true .

yawl:hasParams rdf:type owl:ObjectProperty ;
    rdfs:domain yawl:Action .

# Meta-Framework Properties
bm:ontologyInvariant rdf:type owl:DatatypeProperty ;
    rdfs:label "ontology invariant" ;
    rdfs:comment "Property indicating ontology cannot be modified at runtime" ;
    rdfs:range xsd:boolean ;
    bm:frozen true .

bm:totalExecutability rdf:type owl:DatatypeProperty ;
    rdfs:label "total executability" ;
    rdfs:comment "Everything is executable, nothing symbolic" ;
    rdfs:range xsd:boolean ;
    bm:symbolic false .

bm:impossibleToSpoof rdf:type owl:DatatypeProperty ;
    rdfs:label "impossible to spoof" ;
    rdfs:comment "Structural notarization prevents spoofing" ;
    rdfs:range xsd:boolean ;
    bm:cryptographicIntegrity true .

bm:impossibleToDominate rdf:type owl:DatatypeProperty ;
    rdfs:label "impossible to dominate" ;
    rdfs:comment "Prime sovereignty prevents external domination" ;
    rdfs:range xsd:boolean ;
    bm:sovereigntyProtection true .

# All data properties not previously defined
bm:creator rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:paradigm rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:executionModel rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:invariantProperty rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:layerPriority rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

bm:purpose rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:components rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:materialized rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:executable rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:runtimeUncertainty rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:inferred rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:provable rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:vocabularyFrozen rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:domain rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:path rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:frozen rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:immutable rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:deterministic rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:stateTransparency rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:cyclePrecision rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:compiledFrom rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:aotCompilation rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:compilationTargets rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:aheadOfTime rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:targets rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:sparqlBinding rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:zeroTrust rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:signatureAlgorithm rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:spoofingPrevention rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:cryptographicProvenance rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:deletionForbidden rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:irreversible rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:cryptographic rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:sovereignty rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:immunity rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:modificationImmunity rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:anomalyDetection rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:selfPatching rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:systemObservation rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:violationHandling rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

bm:shutdownCapability rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:symbolic rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:cryptographicIntegrity rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:sovereigntyProtection rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:rejectsDAGs rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:rejectsSemantics rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:proveableExecution rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

bm:truthMaterialized rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .