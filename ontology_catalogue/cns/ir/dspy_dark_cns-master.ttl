    rdfs:subClassOf ns1:CNSSystem .

ns1:SelfHealingSubstrate a owl:Class ;
    rdfs:label "Self-Healing Substrate" ;
    quantum:entangledWith ns1:CNSSystem,
        owl:Class ;
    quantum:observes ns1:SelfHealingSubstrate ;
