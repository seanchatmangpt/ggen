    rdfs:domain ns1:CNSSystem ;
    rdfs:range xsd:boolean .

ns1:hasPerformanceMultiplier a owl:DatatypeProperty ;
    rdfs:label "Performance Multiplier" ;
    quantum:entangledWith ns1:CNSSystem,
        xsd:decimal,
        owl:DatatypeProperty ;
    quantum:observes ns1:hasPerformanceMultiplier ;
