ns1:hasHealingCapability a owl:DatatypeProperty ;
    rdfs:label "Healing Capability" ;
    quantum:entangledWith ns1:CNSSystem,
        xsd:boolean,
        owl:DatatypeProperty ;
    quantum:observes ns1:hasHealingCapability ;
    temporal:existsIn _:N6a8c0babe29944a0b4e987143e9beec8,
        _:N7dbaee2e70fd4f74a24bc42401250485,
