        _:Nf93414f8898c4cf481080b23edee76ce .

xsd:decimal quantum:entangledWith ns1:hasPerformanceMultiplier ;
    quantum:observes xsd:decimal .

ns1:AOTCompiler a owl:Class ;
    rdfs:label "AOT Compiler" ;
    quantum:entangledWith ns1:CNSSystem,
        owl:Class ;
    quantum:observes ns1:AOTCompiler ;
    temporal:existsIn _:N57448054cd2f4534b41d8cdf37edb263,
