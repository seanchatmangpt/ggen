ns1:CNSv8 a ns1:CNSSystem ;
    rdfs:label "CNS v8.0 Instance" ;
    ns1:hasContinuityGuarantee true ;
    ns1:hasHealingCapability true ;
    ns1:hasPerformanceMultiplier 26.0 ;
    quantum:entangledWith ns1:CNSSystem ;
    quantum:observes ns1:CNSv8 ;
    temporal:existsIn _:N29991f8c807b45099ce03f430386a320,
        _:N5ef91da14aab4c76ab7352a777c3ec93,
