ns1:hasContinuityGuarantee a owl:DatatypeProperty ;
    rdfs:label "Continuity Guarantee" ;
    quantum:entangledWith ns1:CNSSystem,
        xsd:boolean,
        owl:DatatypeProperty ;
    quantum:observes ns1:hasContinuityGuarantee ;
    temporal:existsIn _:N0768174b66c24efdb9215b0cf058ebfe,
        _:N169732403dfa4fa2bd162cfb8758e4a4,
