    wisdom:truthMonotonicity "Never mutate truth records - breaks foundation of reliability" ;
    wisdom:signalPurity "Never add conditional logic to signal processing - destroys truth flow" ;
    wisdom:supervisionTree "Never flatten supervision - eliminates resilience patterns" ;
    wisdom:contradictionDetection "Never ignore contradictions - prevents wisdom refinement" .

