@prefix core: <https://cns.dev/core#> .
@prefix m: <https://cns.dev/metrics#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

m:Counter a rdfs:Class ; rdfs:subClassOf core:Primitive .
m:Gauge a rdfs:Class ; rdfs:subClassOf core:Primitive .
m:Histogram a rdfs:Class ; rdfs:subClassOf core:Primitive .
