@prefix log: <http://bitstar.ai/core/log#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

log:Event a rdfs:Class ;
  rdfs:label "Log Event" ;
  rdfs:comment "Structured, deterministic log event" .

log:level a rdf:Property ;
  rdfs:domain log:Event ;
  rdfs:range xsd:string ;
  rdfs:label "level" .

log:timestamp a rdf:Property ;
  rdfs:domain log:Event ;
  rdfs:range xsd:dateTime ;
  rdfs:label "timestamp" .

log:message a rdf:Property ;
  rdfs:domain log:Event ;
  rdfs:range xsd:string ;
  rdfs:label "message" .

log:trace_id a rdf:Property ;
  rdfs:domain log:Event ;
  rdfs:range xsd:string ;
  rdfs:label "trace id" .




