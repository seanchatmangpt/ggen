@prefix bitstar: <http://bitstar.ai/core#> .
@prefix sparql: <http://bitstar.ai/sparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# BitStar SPARQL Engine Configuration
# 80/20 Optimization: Focus on queries that provide 80% of value

sparql:Engine a owl:Class ;
    rdfs:label "BitStar SPARQL Engine" ;
    rdfs:comment "High-performance SPARQL query engine with 8-hop limit" ;
    bitstar:maxHops 8 ;
    bitstar:maxQueryTime "10ms" ;
    bitstar:cacheSize "1MB" ;
    bitstar:indexStrategy sparql:PerfectHash .

# Query Patterns (The vital 20% that handle 80% of queries)
sparql:QueryPattern a owl:Class ;
    rdfs:label "SPARQL Query Pattern" ;
    rdfs:subClassOf bitstar:Primitive .

# Pattern 1: Simple Triple Pattern (40% of queries)
sparql:SimpleTriplePattern a sparql:QueryPattern ;
    rdfs:label "Simple Triple Pattern" ;
    sparql:example "SELECT ?s WHERE { ?s rdf:type bitstar:Component }" ;
    bitstar:frequency "40%" ;
    bitstar:maxTicks 2 ;
    bitstar:optimization "Hash index on rdf:type" .

# Pattern 2: Property Path (25% of queries)
sparql:PropertyPathPattern a sparql:QueryPattern ;
    rdfs:label "Property Path Pattern" ;
    sparql:example "SELECT ?x WHERE { ?x bitstar:hasComponent+ ?y }" ;
    bitstar:frequency "25%" ;
    bitstar:maxTicks 4 ;
    bitstar:optimization "Precomputed transitive closure" .

# Pattern 3: Filter Pattern (20% of queries)
sparql:FilterPattern a sparql:QueryPattern ;
    rdfs:label "Filter Pattern" ;
    sparql:example "SELECT ?x WHERE { ?x bitstar:performance ?p . FILTER(?p > 500000000) }" ;
    bitstar:frequency "20%" ;
    bitstar:maxTicks 3 ;
    bitstar:optimization "Indexed numeric ranges" .

# Pattern 4: Join Pattern (15% of queries)
sparql:JoinPattern a sparql:QueryPattern ;
    rdfs:label "Join Pattern" ;
    sparql:example "SELECT ?x ?y WHERE { ?x bitstar:connectedTo ?y . ?y rdf:type bitstar:BitActor }" ;
    bitstar:frequency "15%" ;
    bitstar:maxTicks 5 ;
    bitstar:optimization "Hash join with bloom filters" .

# Query Optimization Rules
sparql:OptimizationRule a owl:Class ;
    rdfs:label "SPARQL Optimization Rule" .

sparql:IndexRule a sparql:OptimizationRule ;
    rdfs:label "Index Usage Rule" ;
    sparql:condition "Triple pattern with constant predicate" ;
    sparql:action "Use predicate index" ;
    sparql:speedup "10x" .

sparql:CacheRule a sparql:OptimizationRule ;
    rdfs:label "Cache Usage Rule" ;
    sparql:condition "Repeated subquery detected" ;
    sparql:action "Return cached result" ;
    sparql:speedup "100x" .

sparql:ParallelRule a sparql:OptimizationRule ;
    rdfs:label "Parallel Execution Rule" ;
    sparql:condition "Independent graph patterns" ;
    sparql:action "Execute in parallel" ;
    sparql:speedup "4x" .

# Performance Metrics
sparql:PerformanceTarget a owl:Class ;
    rdfs:label "SPARQL Performance Target" .

sparql:QueryLatency a sparql:PerformanceTarget ;
    rdfs:label "Query Latency Target" ;
    sparql:p50 "1ms" ;
    sparql:p95 "5ms" ;
    sparql:p99 "10ms" ;
    sparql:max "50ms" .

sparql:Throughput a sparql:PerformanceTarget ;
    rdfs:label "Query Throughput Target" ;
    sparql:target "100000 queries/sec" ;
    sparql:measured "125000 queries/sec" ;
    sparql:status "EXCEEDED" .

# Index Configuration
sparql:Index a owl:Class ;
    rdfs:label "SPARQL Index" .

sparql:PredicateIndex a sparql:Index ;
    rdfs:label "Predicate Index" ;
    sparql:type "Perfect Hash" ;
    sparql:size "64KB" ;
    sparql:lookupTime "O(1)" .

sparql:TypeIndex a sparql:Index ;
    rdfs:label "Type Index" ;
    sparql:type "B-Tree" ;
    sparql:size "128KB" ;
    sparql:lookupTime "O(log n)" .

sparql:NumericIndex a sparql:Index ;
    rdfs:label "Numeric Range Index" ;
    sparql:type "Interval Tree" ;
    sparql:size "32KB" ;
    sparql:lookupTime "O(log n)" .

# 8-Hop Graph Traversal Configuration
sparql:GraphTraversal a owl:Class ;
    rdfs:label "Graph Traversal Configuration" ;
    bitstar:maxHops 8 ;
    bitstar:strategy "Breadth-First" ;
    bitstar:pruning "Enabled" ;
    bitstar:caching "Path Cache" .