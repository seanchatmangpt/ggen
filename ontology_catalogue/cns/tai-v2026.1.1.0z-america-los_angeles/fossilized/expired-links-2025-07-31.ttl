# Fossilized Connection 001 - Experimental Integration
fossil:deprecated_integration_001 a tai:FossilizedConnection ;
    rdfs:label "Deprecated BitTest Integration" ;
    fossil:originalRelevanceStrength 0.42 ;
    fossil:finalRelevanceStrength 0.18 ;
    fossil:connectionType "experimental-integration" ;
    fossil:reasonForExpiry "experiment-concluded-unsuccessful" ;
    fossil:activeFrom "2025-07-25T09:00:00Z"^^xsd:dateTime ;
    fossil:expiredAt "2025-07-31T14:30:00Z"^^xsd:dateTime ;
    fossil:totalLifespan 538200 ;  # 6.23 days in seconds
    fossil:peakRelevance 0.67 ;
    fossil:decayPattern "gradual-decline" ;
    fossil:fossilizationReason "natural-decay-below-threshold" .

# Fossilized Connection 002 - Temporary Coordination
fossil:temp_coordination_002 a tai:FossilizedConnection ;
    rdfs:label "Temporary Cross-Domain Bridge" ;
    fossil:originalRelevanceStrength 0.78 ;
    fossil:finalRelevanceStrength 0.12 ;
    fossil:connectionType "temporary-bridge" ;
    fossil:reasonForExpiry "purpose-completed" ;
    fossil:activeFrom "2025-07-30T16:45:00Z"^^xsd:dateTime ;
