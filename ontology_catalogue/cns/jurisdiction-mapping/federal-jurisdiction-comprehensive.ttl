# === FEDERAL COURT SYSTEM HIERARCHY ===

jurisdiction:FederalCourtSystem a jurisdiction:FederalJurisdiction ;
    rdfs:label "United States Federal Court System" ;
    federal:systemType "Article III Courts" ;
    federal:supremeAuthority jurisdiction:USSupremeCourt ;
    federal:circuitCourts jurisdiction:FederalCircuitCourts ;
    federal:districtCourts jurisdiction:FederalDistrictCourts ;
    federal:specialtyCourts jurisdiction:FederalSpecialtyCourts .

# === U.S. SUPREME COURT ===

jurisdiction:USSupremeCourt a jurisdiction:FederalJurisdiction ;
    rdfs:label "Supreme Court of the United States" ;
    federal:courtLevel "Highest" ;
    federal:jurisdiction "Constitutional and Federal Law" ;
    court:address "1 First Street NE, Washington, DC 20543" ;
    foaf:phone "+1-202-479-3000" ;
    court:website <https://www.supremecourt.gov> ;
    geo:lat "38.8906"^^xsd:float ;
    geo:long "-77.0044"^^xsd:float ;
    
    # Bar Admission
    federal:barAdmission [
        filing:applicationFee "200.00"^^xsd:decimal ;
        filing:requirements "Good standing in state bar for 3+ years" ;
        filing:sponsorship "2 Supreme Court bar members required" ;
        filing:ceremony "Optional admission ceremony" ;
        filing:certificate "Suitable for framing certificate provided"
    ] ;
    
    # Filing Procedures
    federal:filingProcedures [
        filing:petitionForCertiorari "Primary method of case review" ;
        filing:certiorariDeadline "90 days from lower court judgment" ;
        filing:originalJurisdiction "Limited to disputes between states" ;
        filing:mandatoryAppeals "Very limited, mostly abolished" ;
        filing:filingFee "300.00"^^xsd:decimal ;
        filing:pauperFiling "In forma pauperis available"
    ] .

# === FEDERAL CIRCUIT COURTS ===

jurisdiction:FederalCircuitCourts a jurisdiction:FederalJurisdiction ;
