        legal:discoveryDeadlines "Fed. R. Civ. P. 26-37 - various discovery deadlines" ;
        legal:motionPractice "Fed. R. Civ. P. 6 - additional time for electronic service" ;
        legal:appealDeadlines "Fed. R. App. P. 4 - 30/60 day appeal deadlines"
    ] ;
    
    # Cross-Jurisdictional Timing
    procedure:crossJurisdictionalTiming [
        procedure:stateToFederal "Removal within 30 days under 28 U.S.C. § 1446" ;
        procedure:federalToState "Remand motions within 30 days of removal" ;
        procedure:parallelProceedings "First-filed rule, Colorado River abstention" ;
        procedure:classActions "CAFA notice requirements to state officials" ;
        procedure:exhaustionRequirements "Administrative exhaustion before federal court"
    ] ;
    
    # Electronic Filing Timing
    procedure:electronicFilingTiming [
        filing:deadline "11:59 PM local time of court" ;
        filing:weekendExtension "Next business day if deadline falls on weekend/holiday" ;
        filing:technicalFailure "Reasonable efforts to file, notice to court next day" ;
        filing:serviceDeemed "Complete upon transmission for CM/ECF users" ;
