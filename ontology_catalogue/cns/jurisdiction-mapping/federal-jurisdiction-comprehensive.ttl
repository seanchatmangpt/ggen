# === CM/ECF ELECTRONIC FILING SYSTEM ===

jurisdiction:CMECFSystem a federal:ElectronicFilingSystem ;
    rdfs:label "Case Management/Electronic Case Files (CM/ECF)" ;
    federal:systemType "Nationwide Federal Court Filing System" ;
    federal:administeredBy "Administrative Office of the U.S. Courts" ;
    federal:website <https://www.pacer.gov> ;
    
    # System Requirements
    federal:systemRequirements [
        filing:browserRequirements "Chrome, Firefox, Safari, Edge (current versions)" ;
        filing:pdfRequirements "PDF/A format preferred, OCR text-searchable" ;
        filing:fileSizeLimit "25 MB per document, 500 MB per filing" ;
        filing:redactionRequired "Personal identifiers must be redacted per Fed. R. Civ. P. 5.2" ;
        filing:digitalSignature "Electronic signature required (typically /s/ format)"
    ] ;
    
    # Registration Process
    federal:registrationProcess [
        filing:eligibility "Attorneys admitted to federal bar" ;
        filing:training "Mandatory online training required" ;
        filing:loginCredentials "Username/password plus secondary authentication" ;
        filing:certificateInstallation "Digital certificate for some districts" ;
        filing:supportContact "Local court CM/ECF help desk"
    ] ;
    
    # Filing Procedures
    federal:filingProcedures [
        filing:businessHours "24/7 electronic filing availability" ;
        filing:deadlineRule "Documents due by 11:59 PM local time" ;
        filing:confirmationReceipt "Electronic Notice of Electronic Filing (NEF)" ;
        filing:serviceOfProcess "Automatic electronic service to registered users" ;
        filing:docketingTime "Real-time docket updates" ;
        filing:technicalFailure "Technical failure provisions in local rules"
    ] ;
    
    # Fee Structure
    federal:feeSchedule [
        filing:civilComplaint "402.00"^^xsd:decimal ;
        filing:answerOrAppearance "0.00"^^xsd:decimal ;
        filing:crossClaim "402.00"^^xsd:decimal ;
        filing:thirdPartyComplaint "402.00"^^xsd:decimal ;
        filing:motion "0.00"^^xsd:decimal ;
        filing:appeal "505.00"^^xsd:decimal ;
        filing:pacer "0.10 per page viewed"^^xsd:decimal ;
        filing:quarterlyCapPacer "30.00"^^xsd:decimal
    ] .

# === FEDERAL JURISDICTIONAL REQUIREMENTS ===

jurisdiction:FederalJurisdictionalBasis a legal:JurisdictionalFramework ;
    rdfs:label "Federal Court Jurisdictional Requirements" ;
    
    # Subject Matter Jurisdiction
    legal:subjectMatterJurisdiction [
        legal:federalQuestion [
            legal:authority "28 U.S.C. § 1331" ;
            legal:definition "Claim arising under Constitution, laws, or treaties of United States" ;
            legal:wellPleasedRule "Federal question must appear on face of complaint" ;
            legal:amountInControversy "No minimum amount required" ;
            legal:examples (
                "Civil rights violations under 42 U.S.C. § 1983"
                "Federal employment discrimination claims"
                "Intellectual property disputes"
                "Antitrust violations"
                "Securities law violations"
            )
        ] ;
        
        legal:diversityJurisdiction [
            legal:authority "28 U.S.C. § 1332" ;
            legal:citizenshipRequirement "Complete diversity between parties" ;
            legal:amountInControversy "Exceeds $75,000 exclusive of interest and costs" ;
            legal:aggregationRules "Multiple claims by single plaintiff may be aggregated" ;
            legal:removableFromState "Within 30 days of service or discovery of removability" ;
            legal:examples (
                "Multi-state business disputes"
                "Personal injury cases with diverse parties"
                "Contract disputes exceeding threshold"
                "Class actions meeting CAFA requirements"
            )
        ]
    ] ;
    
    # Personal Jurisdiction
    legal:personalJurisdiction [
        legal:generalJurisdiction "At home standard - very limited" ;
        legal:specificJurisdiction "Minimum contacts related to the claim" ;
        legal:consentJurisdiction "Express or implied consent to jurisdiction" ;
        legal:serviceRequirements "Federal Rule of Civil Procedure 4" ;
        legal:longArmStatutes "Applicable state long-arm statute limits"
    ] ;
    
    # Venue Requirements  
    legal:venueRequirements [
        legal:authority "28 U.S.C. § 1391" ;
        legal:generalRule "Where any defendant resides, where claim arose, or fallback provision" ;
        legal:corporateResidence "Any judicial district where subject to personal jurisdiction" ;
        legal:transferMotions "28 U.S.C. § 1404(a) convenience transfer, § 1406 improper venue" ;
        legal:forumNonConveniens "Dismissal in favor of foreign forum"
    ] .

# === FEDERAL EMPLOYMENT LAW JURISDICTION ===

jurisdiction:FederalEmploymentLaw a legal:EmploymentLawFramework ;
    rdfs:label "Federal Employment Law Jurisdictional Requirements" ;
    
    # EEOC Procedures
    legal:eeocProcedures [
        legal:agency "Equal Employment Opportunity Commission" ;
        legal:website <https://www.eeoc.gov> ;
        legal:complaintDeadline "180 days (300 days in deferral states like CA and NV)" ;
        legal:investigationProcess "Charge, investigation, determination, conciliation" ;
        legal:rightToSue "90 days after EEOC determination or 180 days after filing" ;
        legal:courtDeadline "90 days from receipt of right-to-sue letter"
    ] ;
    
    # Federal Employment Statutes
    legal:federalStatutes [
        legal:titleVII [
            legal:statute "Title VII of Civil Rights Act of 1964" ;
            legal:coverage "Employers with 15+ employees" ;
            legal:prohibitions "Race, color, religion, sex, national origin discrimination" ;
            legal:remedies "Back pay, front pay, compensatory and punitive damages" ;
            legal:caps "Punitive damages capped based on employer size"
        ] ;
        
        legal:ada [
            legal:statute "Americans with Disabilities Act" ;
            legal:coverage "Employers with 15+ employees" ;
            legal:requirements "Reasonable accommodation, essential functions analysis" ;
            legal:remedies "Similar to Title VII" ;
            legal:interaction "State disability laws may provide additional protections"
        ] ;
        
        legal:adea [
            legal:statute "Age Discrimination in Employment Act" ;
            legal:coverage "Employers with 20+ employees, age 40+" ;
            legal:procedures "Similar to Title VII but jury trial right" ;
            legal:remedies "Liquidated damages for willful violations"
        ]
    ] .

# === FEDERAL CIVIL RIGHTS JURISDICTION ===

jurisdiction:FederalCivilRights a legal:CivilRightsFramework ;
    rdfs:label "Federal Civil Rights Jurisdictional Framework" ;
    
    # Section 1983 Claims
    legal:section1983 [
        legal:statute "42 U.S.C. § 1983" ;
        legal:requirements "State actor, constitutional or federal statutory violation" ;
        legal:immunities "Qualified immunity for individual defendants" ;
        legal:statueOfLimitations "State personal injury statute (2-3 years typically)" ;
        legal:attorneys'fees "42 U.S.C. § 1988 fee-shifting provision" ;
        legal:monellLiability "Municipal liability requires policy or custom"
    ] ;
    
    # Constitutional Claims
    legal:bivensActions [
        legal:basis "Direct constitutional claims against federal officials" ;
        legal:limitations "Significantly restricted by recent Supreme Court decisions" ;
        legal:alternatives "Administrative remedies, statutory claims preferred" ;
        legal:immunities "Qualified immunity applicable"
    ] ;
    
    # Civil Rights Statutes
    legal:civilRightsStatutes [
        legal:section1981 "Contracts - race discrimination" ;
        legal:section1982 "Property rights - race discrimination" ;
        legal:fairHousingAct "Housing discrimination" ;
        legal:section504Rehab "Federal program disability discrimination" ;
        legal:titleIX "Education sex discrimination"
    ] .

# === MULTIDISTRICT LITIGATION (MDL) ===

jurisdiction:MDLFramework a federal:MultidistrictLitigation ;
    rdfs:label "Multidistrict Litigation Coordination" ;
    federal:panel "Judicial Panel on Multidistrict Litigation (JPML)" ;
    federal:headquarters "Washington, DC" ;
    
    # MDL Process
    federal:mdlProcess [
        filing:threshold "Common questions of fact in multiple districts" ;
        filing:motion "Motion to transfer and consolidate" ;
        filing:briefingSchedule "Response within 60 days" ;
        filing:hearing "Optional oral argument before JPML" ;
        filing:transferOrder "Creates new MDL in designated district" ;
        filing:bellwetherTrials "Test cases to gauge settlement values"
    ] ;
    
    # California/Nevada MDL Considerations
    federal:regionalConsiderations [
        federal:commonMDLs "Product liability, securities fraud, employment class actions" ;
        federal:transfereeDistricts "Often N.D. Cal for tech cases, C.D. Cal for entertainment" ;
        federal:coordinatedState "California state court coordination procedures" ;
        federal:classActionFairness "CAFA removal to federal court"
    ] .

