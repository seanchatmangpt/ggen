    federal:courtLevel "Intermediate Appellate" ;
    federal:circuitCount "13"^^xsd:integer ;
    federal:geographicCircuits "11"^^xsd:integer ;
    federal:specialtyCircuits "2"^^xsd:integer .

# Ninth Circuit (California/Nevada Coverage)
jurisdiction:NinthCircuit a jurisdiction:FederalJurisdiction ;
    rdfs:label "U.S. Court of Appeals for the Ninth Circuit" ;
    federal:circuit "9" ;
    court:headquarters [
        court:address "95 Seventh Street, San Francisco, CA 94103" ;
        foaf:phone "+1-415-556-9800" ;
        court:website <https://www.ca9.uscourts.gov> ;
        geo:lat "37.7749"^^xsd:float ;
        geo:long "-122.4194"^^xsd:float
    ] ;
    
    # Geographic Coverage
    federal:statesCovered (
        "Alaska" "Arizona" "California" "Hawaii" "Idaho" 
        "Montana" "Nevada" "Oregon" "Washington"
    ) ;
    federal:territorysCovered ("Guam" "Northern Mariana Islands") ;
    
    # Appeal Procedures
    federal:appealProcedures [
        filing:appealDeadline "30 days from final judgment (60 days if US is party)" ;
        filing:filingFee "505.00"^^xsd:decimal ;
        filing:docketingFee "500.00"^^xsd:decimal ;
        filing:briefingSchedule "Appellant 40 days, Appellee 30 days, Reply 14 days" ;
        filing:oralArgument "Discretionary, typically 15 minutes per side"
    ] .

