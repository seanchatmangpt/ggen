# === EMPLOYMENT CLASSIFICATION FILING REQUIREMENTS ===

jurisdiction:CaliforniaEmploymentLaw a legal:EmploymentClassificationFramework ;
    rdfs:label "California Employment Classification Requirements" ;
    
    # AB5/Dynamex Test
    legal:independentContractorTest [
        legal:testName "ABC Test (AB5/Dynamex)" ;
        legal:effectiveDate "2020-01-01"^^xsd:date ;
        legal:criteria [
            legal:prong "A" ;
            legal:requirement "Worker is free from control and direction in performance"
        ] ;
        legal:criteria [
            legal:prong "B" ;
            legal:requirement "Worker performs work outside usual course of business"
        ] ;
        legal:criteria [
            legal:prong "C" ;
            legal:requirement "Worker is customarily engaged in independent trade/occupation"
        ] ;
        legal:burden "All three prongs must be satisfied for independent contractor status"
    ] ;
    
    # Filing Authorities
    legal:filingAuthority [
        legal:agency "California Department of Industrial Relations (DIR)" ;
        legal:website <https://www.dir.ca.gov> ;
        legal:complaintForm "https://www.dir.ca.gov/dlse/HowToFileWageClaim.htm" ;
        legal:address "455 Golden Gate Avenue, San Francisco, CA 94102"
    ] ;
    
    legal:filingAuthority [
        legal:agency "California Employment Development Department (EDD)" ;
        legal:website <https://www.edd.ca.gov> ;
        legal:auditDivision "https://www.edd.ca.gov/payroll_taxes/Employment_Tax_Audits.htm" ;
        legal:address "800 Capitol Mall, Sacramento, CA 95814"
    ] ;
    
    legal:filingAuthority [
        legal:agency "California Workers' Compensation Appeals Board" ;
        legal:website <https://www.wcab.ca.gov> ;
        legal:address "455 Golden Gate Avenue, San Francisco, CA 94102"
    ] .

# === CIVIL RIGHTS FILING OPTIONS ===

jurisdiction:CaliforniaCivilRights a legal:CivilRightsFramework ;
    rdfs:label "California Civil Rights Filing Requirements" ;
    
    # State Civil Rights Agencies
    legal:filingVenue [
        legal:agency "California Civil Rights Department (CRD)" ;
        legal:formerName "Department of Fair Employment and Housing (DFEH)" ;
        legal:website <https://www.crd.ca.gov> ;
        legal:complaintDeadline "1 year from last incident" ;
        legal:address "2218 Kausen Drive, Suite 100, Elk Grove, CA 95758" ;
        legal:regionalOffices (
            "Los Angeles: 611 W. 6th Street, Los Angeles, CA 90017"
            "San Francisco: 1515 Clay Street, Oakland, CA 94612"
            "San Diego: 1350 Front Street, San Diego, CA 92101"
        )
    ] ;
    
    # Federal Civil Rights Filing
    legal:federalFiling [
        legal:agency "U.S. Equal Employment Opportunity Commission (EEOC)" ;
        legal:complaintDeadline "300 days from incident (deferral state)" ;
        legal:website <https://www.eeoc.gov> ;
        legal:rightToSue "90 days after EEOC determination or 180 days after filing"
    ] ;
    
    # Court Filing Options
    legal:courtVenue [
        legal:stateCourt "California Superior Court" ;
        legal:timeLimit "2-3 years depending on cause of action" ;
        legal:filingFee "435.00"^^xsd:decimal
    ] ;
    
    legal:courtVenue [
        legal:federalCourt "U.S. District Court" ;
        legal:timeLimit "Federal civil rights statutes vary (2-6 years)" ;
        legal:filingFee "402.00"^^xsd:decimal ;
        legal:jurisdiction "Federal question or diversity"
    ] .

# === TIMELINE REGULATION FRAMEWORK ===

jurisdiction:CaliforniaTimelineRegulation a procedure:TimelineRegulationSystem ;
    rdfs:label "California Multi-Jurisdictional Timeline Coordination" ;
    
    # Statute of Limitations Coordination
    procedure:statuteLimitations [
        legal:civilProcedure "California Code of Civil Procedure Section 335 et seq." ;
        legal:personalInjury "2 years" ;
        legal:contractWritten "4 years" ;
        legal:contractOral "2 years" ;
        legal:fraud "3 years from discovery" ;
        legal:professionalMalpractice "1 year from discovery, 4 years from occurrence"
    ] ;
    
    # Service Timeline Requirements
    procedure:serviceRequirements [
        legal:personalService "Immediate effect upon service" ;
        legal:substitutedService "10 days after mailing" ;
        legal:publicationService "Court-ordered timeline" ;
        legal:electronicService "Consent required, effective on transmission"
    ] ;
    
    # Response Deadlines
    procedure:responseDeadlines [
        legal:generalDemurrer "30 days" ;
        legal:motionToStrike "30 days" ;
        legal:answerToComplaint "30 days" ;
        legal:discoveryResponses "30 days" ;
        legal:motionPractice "Various, typically 16 court days notice"
    ] .

# === CONTRADICTION VALIDATION SYSTEM ===

jurisdiction:ContradictionValidation a procedure:ContradictionDetectionFramework ;
    rdfs:label "California Opposing Counsel Contradiction Detection" ;
    
    # Detection Categories
    procedure:contradictionType [
        procedure:category "Factual Contradictions" ;
        procedure:definition "Inconsistent statements of material fact" ;
        procedure:evidenceStandard "Clear and convincing evidence of inconsistency" ;
        procedure:legalEffect "Impeachment, sanctions under CCP 128.7"
    ] ;
    
    procedure:contradictionType [
        procedure:category "Legal Position Contradictions" ;
        procedure:definition "Inconsistent legal arguments in same or related cases" ;
        procedure:evidenceStandard "Judicial estoppel analysis" ;
        procedure:legalEffect "Preclusion of inconsistent position"
    ] ;
    
    procedure:contradictionType [
        procedure:category "Timeline Contradictions" ;
        procedure:definition "Inconsistent chronology of events" ;
        procedure:evidenceStandard "Documentary evidence of conflicting dates" ;
        procedure:legalEffect "Credibility impeachment"
    ] ;
    
    # Validation Procedures
    procedure:validationMethod [
        procedure:step "Document Collection" ;
        procedure:sources "Pleadings, discovery responses, depositions, exhibits" ;
        procedure:timeline "Ongoing throughout litigation"
    ] ;
    
    procedure:validationMethod [
        procedure:step "Cross-Reference Analysis" ;
        procedure:method "Digital text analysis and human review" ;
        procedure:output "Contradiction matrix with citations"
    ] ;
    
    procedure:validationMethod [
        procedure:step "Legal Brief Preparation" ;
        procedure:format "Motion for sanctions or impeachment evidence" ;
        procedure:standard "California Code of Civil Procedure Section 128.7"
    ] .

