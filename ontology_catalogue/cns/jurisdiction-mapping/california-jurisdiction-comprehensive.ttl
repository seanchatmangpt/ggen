# === CALIFORNIA STATE BAR AUTHORITY ===

jurisdiction:StateBarCalifornia a jurisdiction:BarJurisdiction ;
    rdfs:label "State Bar of California" ;
    jurisdiction:barId "CA-SB-001" ;
    foaf:homepage <https://www.calbar.ca.gov> ;
    jurisdiction:disciplinaryWebsite <https://www.calbar.ca.gov/About/Complaints-Discipline> ;
    jurisdiction:onlineComplaintPortal <https://apps.calbar.ca.gov/complaint/> ;
    
    # Primary Contact Information
    jurisdiction:headquarters [
        jurisdiction:address "180 Howard Street, San Francisco, CA 94105" ;
        foaf:phone "+1-415-538-2000" ;
        foaf:mbox <mailto:complaints@calbar.ca.gov> ;
        geo:lat "37.7749"^^xsd:float ;
        geo:long "-122.4194"^^xsd:float ;
        jurisdiction:businessHours "Monday-Friday 8:30 AM - 5:00 PM PST"
    ] ;
    
    # Los Angeles Office
    jurisdiction:regionalOffice [
        jurisdiction:officeName "Los Angeles Office" ;
        jurisdiction:address "845 S. Figueroa Street, Los Angeles, CA 90017" ;
        foaf:phone "+1-213-765-1000" ;
        geo:lat "34.0522"^^xsd:float ;
        geo:long "-118.2437"^^xsd:float
    ] ;
    
    # San Diego Office  
    jurisdiction:regionalOffice [
        jurisdiction:officeName "San Diego Office" ;
        jurisdiction:address "4010 Morena Blvd., Suite 300, San Diego, CA 92117" ;
        foaf:phone "+1-619-525-1300" ;
        geo:lat "32.7157"^^xsd:float ;
        geo:long "-117.1611"^^xsd:float
    ] ;
    
    # Filing Requirements
    jurisdiction:filingRequirements [
        filing:format "PDF, Word, or Physical Paper" ;
        filing:copiesRequired "1"^^xsd:integer ;
        filing:verificationRequired "true"^^xsd:boolean ;
        filing:notarizationRequired "false"^^xsd:boolean ;
        filing:electronicFilingAvailable "true"^^xsd:boolean ;
        filing:filingFee "0.00"^^xsd:decimal ;
        filing:currency "USD" ;
        filing:processingTime "5-10 business days initial review" ;
        filing:confirmationMethod "Email confirmation with tracking number"
    ] ;
    
    # Jurisdictional Scope
    jurisdiction:hasJurisdictionOver [
        jurisdiction:scope "All California licensed attorneys" ;
        jurisdiction:memberCount "280000"^^xsd:integer ;
        jurisdiction:activeMembers "200000"^^xsd:integer ;
        jurisdiction:inactiveMembers "80000"^^xsd:integer
    ] ;
    
    # Disciplinary Procedure
    jurisdiction:disciplinaryProcess [
        procedure:step1 [
            procedure:stageName "Initial Review" ;
            procedure:duration "30-60 days" ;
            procedure:description "Administrative review of complaint for jurisdiction and merit" ;
            procedure:outcome "Dismissal, Investigation, or Referral"
        ] ;
        procedure:step2 [
            procedure:stageName "Investigation" ;
            procedure:duration "6-18 months" ;
            procedure:description "Fact-finding, interviews, document review" ;
            procedure:investigator "State Bar Investigator"
        ] ;
        procedure:step3 [
            procedure:stageName "Notice to Show Cause" ;
            procedure:duration "30 days response time" ;
            procedure:description "Formal charges if probable cause found" ;
            procedure:hearingVenue "State Bar Court"
        ] ;
        procedure:step4 [
            procedure:stageName "Hearing" ;
            procedure:duration "3-12 months to completion" ;
            procedure:description "Formal disciplinary hearing" ;
            procedure:judge "State Bar Court Judge"
        ]
    ] ;
    
    # Time Limitations
    jurisdiction:timeLimit "4 years from discovery of misconduct" ;
    jurisdiction:continuingViolationException "true"^^xsd:boolean ;
    jurisdiction:criminalConvictionException "No time limit for felony convictions" ;
    
    # Required Complaint Elements
    jurisdiction:requiredElements [
        filing:element "Respondent attorney name and bar number" ;
        filing:element "Respondent law firm and address" ;
        filing:element "Complainant name and contact information" ;
        filing:element "Date(s) of alleged misconduct" ;
        filing:element "Detailed description of conduct" ;
        filing:element "Specific professional conduct rules violated" ;
        filing:element "Attorney-client relationship details" ;
        filing:element "Supporting documentation" ;
        filing:element "Complainant signature and verification"
    ] ;
    
    # Professional Conduct Rules
    jurisdiction:rulesReference [
        legal:rulebook "California Rules of Professional Conduct" ;
        legal:effectiveDate "2018-11-01"^^xsd:date ;
        legal:primaryRules (
            "Rule 1.1 - Competence"
            "Rule 1.2 - Scope of Representation and Allocation of Authority"
            "Rule 1.3 - Diligence"
            "Rule 1.4 - Communication with Clients"
            "Rule 1.5 - Fees for Legal Services"
            "Rule 1.6 - Confidentiality of Information"
            "Rule 1.7 - Conflict of Interest: Current Clients"
            "Rule 1.8 - Conflict of Interest: Specific Rules"
            "Rule 1.9 - Duties to Former Clients"
            "Rule 3.1 - Meritorious Claims and Contentions"
            "Rule 3.3 - Candor Toward the Tribunal"
            "Rule 3.4 - Fairness to Opposing Party and Counsel"
            "Rule 4.1 - Truthfulness in Statements to Others"
            "Rule 8.4 - Professional Responsibility"
        )
    ] .

