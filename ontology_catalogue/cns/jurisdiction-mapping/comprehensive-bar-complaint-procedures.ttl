# === CALIFORNIA STATE BAR COMPLAINT PROCEDURES ===

bar:CaliforniaBarComplaintProcedure a procedure:ComplaintProcedure ;
    rdfs:label "California State Bar Complaint Procedure" ;
    jurisdiction:appliesTo jurisdiction:StateBarCalifornia ;
    
    # Pre-Filing Requirements
    procedure:preFilingRequirements [
        procedure:step "Attorney Identification Verification" ;
        procedure:description "Verify respondent attorney's California bar number and active status" ;
        procedure:resource "https://apps.calbar.ca.gov/attorney/Licensee/Detail" ;
        procedure:verification "Screenshot of attorney lookup with timestamp" ;
        procedure:timeRequired "5 minutes"
    ] ;
    
    procedure:preFilingRequirements [
        procedure:step "Jurisdiction Verification" ;
        procedure:description "Confirm California State Bar has jurisdiction over the attorney" ;
        procedure:requirements "California license, conduct in California, or California client relationship" ;
        procedure:exceptions "Federal court practice may trigger California jurisdiction" ;
        procedure:documentation "Evidence of jurisdictional connection required"
    ] ;
    
    procedure:preFilingRequirements [
        procedure:step "Time Limitation Check" ;
        procedure:description "Verify complaint filed within 4-year limitation period" ;
        procedure:calculation "4 years from discovery of misconduct, continuing violation exception" ;
        procedure:documentation "Timeline calculation worksheet with evidence dates" ;
        procedure:caveats "Criminal convictions may extend limitations period"
    ] ;
    
    # Filing Process
    procedure:filingProcess [
        procedure:phase "Complaint Form Preparation" ;
        procedure:form "California State Bar Complaint Form (online or PDF)" ;
        procedure:url "https://apps.calbar.ca.gov/complaint/" ;
        procedure:completion "Must be completed fully - incomplete forms rejected" ;
        procedure:accuracy "All information must be accurate and verifiable" ;
        procedure:attachments "Supporting documents may be attached electronically"
    ] ;
    
    procedure:filingProcess [
        procedure:phase "Electronic Submission" ;
        procedure:method "Online portal preferred, email acceptable, mail permitted" ;
        procedure:confirmation "Electronic submission provides immediate confirmation number" ;
        procedure:receipt "Email confirmation sent within 24 hours" ;
        procedure:tracking "Complaint tracking number provided for status inquiries" ;
        procedure:backup "Print confirmation page for records"
    ] ;
    
    # Required Information Elements
    complaint:requiredElements [
        complaint:element "Complainant Information" ;
        complaint:details [
            filing:field "Full legal name" ;
            filing:field "Complete mailing address" ;
            filing:field "Primary phone number" ;
            filing:field "Email address" ;
            filing:field "Relationship to respondent attorney"
        ] ;
        complaint:notes "Anonymous complaints not accepted"
    ] ;
    
    complaint:requiredElements [
        complaint:element "Respondent Attorney Information" ;
        complaint:details [
            filing:field "Attorney's full legal name" ;
            filing:field "California State Bar number" ;
            filing:field "Law firm name and address" ;
            filing:field "Attorney's business phone and email if known" ;
            filing:field "Areas of practice involved in complaint"
        ] ;
        complaint:verification "Bar number must be verified before submission"
    ] ;
    
    complaint:requiredElements [
        complaint:element "Misconduct Description" ;
        complaint:requirements [
            filing:requirement "Detailed chronological narrative" ;
            filing:requirement "Specific dates, times, and locations" ;
            filing:requirement "Names of witnesses present" ;
            filing:requirement "Description of harm suffered" ;
            filing:requirement "Specific professional conduct rules violated" ;
            filing:requirement "Attempts to resolve matter with attorney"
        ] ;
        complaint:minLength "Minimum 200 words detailed description" ;
        complaint:maxLength "No maximum but conciseness preferred"
    ] ;
    
    complaint:requiredElements [
        complaint:element "Supporting Documentation" ;
        complaint:acceptableFormats ("PDF" "DOCX" "JPG" "PNG" "TXT") ;
        complaint:maxFileSize "25 MB per attachment" ;
        complaint:examples [
            evidence:type "Engagement letter or retainer agreement" ;
            evidence:type "Email correspondence with attorney" ;
            evidence:type "Court documents showing attorney misconduct" ;
            evidence:type "Billing statements or fee disputes" ;
            evidence:type "Written communications" ;
            evidence:type "Witness statements" ;
            evidence:type "Expert opinions on professional standards"
        ] ;
        complaint:organization "Documents should be organized chronologically" ;
        complaint:authentication "Attestation that documents are true and correct copies"
    ] ;
    
    # Post-Filing Process
    procedure:postFilingProcess [
        procedure:stage "Initial Review (30-60 days)" ;
        procedure:reviewers "State Bar intake attorneys" ;
        procedure:criteria [
            procedure:criterion "Jurisdictional authority" ;
            procedure:criterion "Time limitations compliance" ;
            procedure:criterion "Professional conduct rule violation alleged" ;
            procedure:criterion "Sufficient detail for investigation" ;
            procedure:criterion "Complete information provided"
        ] ;
        procedure:outcomes ("Dismissal for lack of jurisdiction" "Administrative resolution" "Investigation assignment" "Request for additional information") ;
        procedure:notification "Written notice of initial review outcome"
    ] ;
    
    procedure:postFilingProcess [
        procedure:stage "Investigation (6-18 months)" ;
        procedure:investigator "Assigned State Bar investigator" ;
        procedure:activities [
            procedure:activity "Interview complainant" ;
            procedure:activity "Interview respondent attorney" ;
            procedure:activity "Interview witnesses" ;
            procedure:activity "Request documents from attorney" ;
            procedure:activity "Review court records" ;
            procedure:activity "Consult expert witnesses if needed"
        ] ;
        procedure:communication "Periodic status updates provided to complainant" ;
        procedure:cooperation "Complainant cooperation required for investigation continuation"
    ] ;
    
    procedure:postFilingProcess [
        procedure:stage "Preliminary Review (60-90 days)" ;
        procedure:reviewers "State Bar prosecution team" ;
        procedure:standard "Probable cause that professional conduct violation occurred" ;
        procedure:outcomes ("Dismissal" "Private reproval" "Notice to Show Cause (formal charges)" "Administrative resolution") ;
        procedure:rights "Respondent attorney has right to respond to proposed discipline"
    ] ;
    
    procedure:postFilingProcess [
        procedure:stage "State Bar Court Hearing (if charges filed)" ;
        procedure:venue "State Bar Court of California" ;
        procedure:judge "State Bar Court judge (not regular court judge)" ;
        procedure:procedure "Formal hearing with evidence presentation" ;
        procedure:representation "Both parties may be represented by counsel" ;
        procedure:standard "Clear and convincing evidence standard" ;
        procedure:outcomes ("Dismissal" "Private reproval" "Public reproval" "Suspension" "Disbarment") ;
        procedure:appeal "California Supreme Court review available"
    ] .

# === NEVADA STATE BAR COMPLAINT PROCEDURES ===

bar:NevadaBarComplaintProcedure a procedure:ComplaintProcedure ;
    rdfs:label "Nevada State Bar Complaint Procedure" ;
    jurisdiction:appliesTo jurisdiction:StateBarNevada ;
    
    # Pre-Filing Requirements (Nevada-Specific)
    procedure:preFilingRequirements [
        procedure:step "Economic Harm Documentation" ;
        procedure:requirement "Demonstrate actual economic harm from attorney misconduct" ;
        procedure:standard "Financial loss, damages, or opportunity costs must be documented" ;
        procedure:documentation [
            evidence:type "Legal fees paid to correct attorney errors" ;
            evidence:type "Lost settlement opportunities with valuation" ;
            evidence:type "Business damages from missed deadlines" ;
            evidence:type "Additional attorney fees for replacement counsel" ;
            evidence:type "Expert witness costs for malpractice evaluation" ;
            evidence:type "Court sanctions or penalties resulting from misconduct"
        ] ;
        procedure:calculation "Detailed calculation of economic harm required" ;
        procedure:proof "Must establish causal connection between misconduct and harm"
    ] ;
    
    procedure:preFilingRequirements [
        procedure:step "Notarization Preparation" ;
        procedure:requirement "All Nevada bar complaints must be notarized" ;
        procedure:process "Complete complaint form but do not sign until before notary" ;
        procedure:identification "Valid government-issued photo ID required" ;
        procedure:acceptableID ("Nevada driver license" "Nevada state ID" "U.S. passport" "Military ID" "Other state driver license") ;
        procedure:presence "Physical presence before notary required - no remote notarization" ;
        procedure:locations [
            procedure:venue "Nevada State Bar offices (free notarization)" ;
            procedure:venue "Banks, UPS stores, mobile notaries (fee-based)" ;
            procedure:venue "Law offices with notary services"
        ]
    ] ;
    
    procedure:preFilingRequirements [
        procedure:step "Attempted Resolution Documentation" ;
        procedure:requirement "Must document attempts to resolve matter directly with attorney" ;
        procedure:evidence [
            evidence:type "Written communication requesting resolution" ;
            evidence:type "Email exchanges attempting resolution" ;
            evidence:type "Records of phone calls or meetings" ;
            evidence:type "Certified mail receipts for resolution attempts"
        ] ;
        procedure:exceptions "Emergency situations where direct contact inappropriate" ;
        procedure:timeline "Resolution attempts should precede complaint filing"
    ] ;
    
    # Filing Process (Nevada-Specific)
    procedure:filingProcess [
        procedure:phase "Form Completion" ;
        procedure:form "Nevada State Bar Grievance Form (fillable PDF)" ;
        procedure:url "https://www.nvbar.org/wp-content/uploads/Grievance-Form-Fillable.pdf" ;
        procedure:completion "Must be typed or clearly handwritten" ;
        procedure:signature "Do not sign until in presence of notary" ;
        procedure:attachments "Supporting documents should be organized and labeled"
    ] ;
    
    procedure:filingProcess [
        procedure:phase "Notarization Process" ;
        procedure:step1 "Bring unsigned completed form to notary" ;
        procedure:step2 "Present valid photo identification" ;
        procedure:step3 "Sign form in notary's presence" ;
        procedure:step4 "Notary completes acknowledgment certificate" ;
        procedure:step5 "Obtain notarized original for filing" ;
        procedure:cost "Free at Nevada State Bar offices, $5-15 elsewhere"
    ] ;
    
    procedure:filingProcess [
        procedure:phase "Submission Methods" ;
        procedure:electronic "PDF scan of notarized form acceptable" ;
        procedure:mail "Certified mail to Nevada State Bar" ;
        procedure:physical "Hand delivery to bar offices" ;
        procedure:address "9456 Double R Boulevard, Reno, NV 89521" ;
        procedure:confirmation "Written acknowledgment provided" ;
        procedure:timeline "Processing begins after notarized complaint received"
    ] ;
    
    # Required Elements (Nevada-Specific)
    complaint:nevadaRequiredElements [
        complaint:element "Economic Harm Statement" ;
        complaint:details [
            filing:field "Specific monetary amount of harm claimed" ;
            filing:field "Detailed calculation of damages" ;
            filing:field "Causal relationship explanation" ;
            filing:field "Supporting documentation attached" ;
            filing:field "Impact on complainant's situation"
        ] ;
        complaint:standard "Must be specific and verifiable" ;
        complaint:burden "Complainant must prove harm more likely than not"
    ] ;
    
    complaint:nevadaRequiredElements [
        complaint:element "Resolution Attempt Details" ;
        complaint:details [
            filing:field "Date and method of resolution attempt" ;
            filing:field "Attorney's response or lack thereof" ;
            filing:field "Specific resolution requested" ;
            filing:field "Outcome of resolution attempt" ;
            filing:field "Reasons resolution was unsuccessful"
        ] ;
        complaint:documentation "Copies of all correspondence required" ;
        complaint:timeline "Should occur before complaint filing"
    ] ;
    
    # Post-Filing Process (Nevada-Specific)
    procedure:nevadaPostFilingProcess [
        procedure:stage "Screening Review (30 days)" ;
        procedure:reviewers "Nevada State Bar screening committee" ;
        procedure:focus "Economic harm verification, procedural compliance" ;
        procedure:outcomes ("Dismissal for insufficient harm" "Administrative closure" "Investigation assignment") ;
        procedure:notification "Written notice with reasoning provided" ;
        procedure:appeal "No appeal of screening dismissal"
    ] ;
    
    procedure:nevadaPostFilingProcess [
        procedure:stage "Investigation (4-8 months)" ;
        procedure:investigator "Nevada State Bar counsel" ;
        procedure:economicHarmVerification "Independent verification of claimed damages" ;
        procedure:respondentNotification "30 days for attorney to respond" ;
        procedure:discoveryLimited "Limited document requests and interviews" ;
        procedure:cooperation "Complainant must cooperate or case dismissed"
    ] ;
    
    procedure:nevadaPostFilingProcess [
        procedure:stage "Screening Panel Decision (60 days)" ;
        procedure:panel "3-member panel (2 attorneys, 1 public member)" ;
        procedure:standard "Clear and convincing evidence with economic harm" ;
        procedure:outcomes ("Dismissal" "Admonishment" "Formal disciplinary charges") ;
        procedure:economicThreshold "Economic harm factor in all decisions" ;
        procedure:appeal "Nevada Supreme Court review of formal discipline only"
    ] .

# === FEDERAL BAR COMPLAINT PROCEDURES ===

bar:FederalBarComplaintProcedure a procedure:ComplaintProcedure ;
    rdfs:label "Federal Bar Complaint and Disciplinary Procedures" ;
    jurisdiction:appliesTo jurisdiction:FederalDistrictCourts ;
    
    # Federal District Court Procedures
    procedure:federalDistrictProcedures [
        procedure:court "U.S. District Court for the Northern District of California" ;
        procedure:localRules "Local Rule 83-1 through 83-6 (Attorney Discipline)" ;
        procedure:authority "Federal court inherent disciplinary authority" ;
        procedure:jurisdiction "Attorneys admitted to practice before the court" ;
        procedure:triggers [
            procedure:trigger "Misconduct in federal court proceedings" ;
            procedure:trigger "State bar discipline of federal bar member" ;
            procedure:trigger "Criminal conviction involving moral turpitude" ;
            procedure:trigger "Conduct reflecting adversely on fitness to practice"
        ]
    ] ;
    
    procedure:federalDistrictProcedures [
        procedure:filing "Motion or complaint filed with court clerk" ;
        procedure:format "Motion format following federal court local rules" ;
        procedure:service "Service on respondent attorney required" ;
        procedure:supporting "Affidavits and supporting documents required" ;
        procedure:standard "Show cause why attorney should not be disciplined" ;
        procedure:hearing "Court may order hearing or respond to written submissions"
    ] ;
    
    # Supreme Court Bar Procedures
    procedure:supremeCourtBarProcedures [
        procedure:court "Supreme Court of the United States" ;
        procedure:rules "Supreme Court Rule 8 (Disbarment and Disciplinary Action)" ;
        procedure:authority "Supreme Court Rules, inherent authority" ;
        procedure:jurisdiction "Members of Supreme Court Bar" ;
        procedure:automaticDiscipline "Automatic discipline for state bar disbarment" ;
        procedure:notification "Attorney must self-report state discipline within 30 days"
    ] ;
    
    # Patent Bar (USPTO) Procedures  
    procedure:patentBarProcedures [
        procedure:agency "United States Patent and Trademark Office" ;
        procedure:regulations "37 CFR Part 11 - Practice Before the USPTO" ;
        procedure:jurisdiction "Patent attorneys and agents registered with USPTO" ;
        procedure:office "Office of Enrollment and Discipline (OED)" ;
        procedure:contact "OEDmail@uspto.gov, (571) 272-4097" ;
        procedure:procedures [
            procedure:complaint "Formal complaint to OED" ;
            procedure:investigation "OED investigation and fact-finding" ;
            procedure:hearing "Administrative hearing before administrative law judge" ;
            procedure:appeal "USPTO Director review, then federal court appeal" ;
            procedure:discipline "Reprimand, suspension, exclusion from practice"
        ]
    ] ;
    
    # Federal Employment Cases
    procedure:federalEmploymentDiscipline [
        procedure:context "Federal employment discrimination cases" ;
        procedure:rules "Federal Rules Professional Conduct, local rules" ;
        procedure:sanctions "Federal Rule 11, inherent court authority" ;
        procedure:issues [
            procedure:issue "Frivolous EEOC charges or federal lawsuits" ;
            procedure:issue "Discovery abuse in employment litigation" ;
            procedure:issue "Bad faith settlement negotiations" ;
            procedure:issue "Violation of confidentiality agreements" ;
            procedure:issue "Conflict of interest in class actions"
        ] ;
        procedure:remedies "Monetary sanctions, referral to state bar, case dismissal"
    ] .

# === COORDINATED FILING STRATEGY ===

bar:CoordinatedFilingStrategy a procedure:MultiJurisdictionalStrategy ;
    rdfs:label "Coordinated Multi-Jurisdictional Bar Complaint Strategy" ;
    
    # Strategic Sequencing
    procedure:strategicSequencing [
        procedure:phase1 "California State Bar Filing" ;
        procedure:rationale "No notarization, faster processing, online filing" ;
        procedure:timeline "File first, within 5 business days" ;
        procedure:advantages ("Electronic confirmation" "Faster processing" "No economic harm requirement") ;
        procedure:evidence "Complete evidence package with California complaint"
    ] ;
    
    procedure:strategicSequencing [
        procedure:phase2 "Federal District Court Filing (if applicable)" ;
        procedure:rationale "Federal question jurisdiction or diversity" ;
        procedure:timeline "7-10 days after California filing" ;
        procedure:coordination "Reference California complaint in federal filing" ;
        procedure:advantages ("Federal precedent" "CM/ECF electronic filing" "Broader remedies")
    ] ;
    
    procedure:strategicSequencing [
        procedure:phase3 "Nevada State Bar Filing" ;
        procedure:rationale "Complete after other filings to show pattern" ;
        procedure:timeline "10-15 days after federal filing" ;
        procedure:preparation "Economic harm documentation complete" ;
        procedure:notarization "Schedule notary appointment in advance" ;
        procedure:advantages "Pattern of misconduct across jurisdictions established"
    ] ;
    
    # Evidence Coordination
    procedure:evidenceCoordination [
        procedure:standardization "Consistent evidence package across all jurisdictions" ;
        procedure:customization "Jurisdiction-specific adaptations" ;
        procedure:authentication "Proper authentication for each jurisdiction's requirements" ;
        procedure:organization "Chronological organization with cross-references" ;
        procedure:integrity "Hash verification and chain of custody maintenance"
    ] ;
    
    # Timeline Coordination
    procedure:timelineCoordination [
        procedure:deadlineManagement "Track all jurisdiction-specific deadlines" ;
        procedure:responseCoordination "Coordinate responses across jurisdictions" ;
        procedure:updateProtocol "Share developments across all proceedings" ;
        procedure:consistencyMaintenance "Ensure consistent positions across jurisdictions" ;
        procedure:contradictionAvoidance "Avoid creating contradictions between filings"
    ] .

# === PROCEDURAL SAFEGUARDS ===

bar:ProceduralSafeguards a procedure:SafeguardFramework ;
    rdfs:label "Bar Complaint Procedural Safeguards" ;
    
    # Ethical Compliance
    procedure:ethicalCompliance [
        procedure:goodFaith "All complaints must be filed in good faith" ;
        procedure:evidence "Reasonable basis in fact for all allegations" ;
        procedure:privilege "Attorney-client privilege must be respected" ;
        procedure:confidentiality "Maintain confidentiality where required" ;
        procedure:retaliation "No retaliatory motive for complaint filing"
    ] ;
    
    # Evidence Protection
    procedure:evidenceProtection [
        procedure:authenticity "All evidence must be authentic and unaltered" ;
        procedure:completeness "Provide complete context, not selective excerpts" ;
        procedure:accuracy "All factual statements must be accurate" ;
        procedure:verification "Independent verification where possible" ;
        procedure:preservation "Maintain original evidence in secure manner"
    ] ;
    
    # Process Integrity
    procedure:processIntegrity [
        procedure:compliance "Full compliance with all jurisdictional requirements" ;
        procedure:transparency "Disclosure of all related proceedings" ;
        procedure:cooperation "Full cooperation with all investigations" ;
        procedure:honesty "Complete honesty in all communications" ;
        procedure:updates "Promptly report material developments"
    ] ;
    
    # Quality Control
    procedure:qualityControl [
        procedure:review "Multi-level review before filing" ;
        procedure:verification "Independent verification of all claims" ;
        procedure:consistency "Consistency checks across all filings" ;
        procedure:completeness "Completeness verification for all requirements" ;
        procedure:accuracy "Accuracy verification of all factual assertions"
    ] .

