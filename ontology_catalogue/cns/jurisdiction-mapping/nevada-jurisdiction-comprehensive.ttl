# === NOTARIZATION REQUIREMENTS ===

jurisdiction:NevadaNotarizationFramework a procedure:NotarizationRequirements ;
    rdfs:label "Nevada Bar Complaint Notarization Standards" ;
    
    # Notary Requirements
    procedure:notaryRequirements [
        legal:statuteAuthority "Nevada Revised Statutes Chapter 240" ;
        legal:identification "Current government-issued photo ID required" ;
        legal:acceptableID (
            "Nevada driver's license"
            "Nevada state ID card"
            "U.S. passport"
            "Military ID with photo"
            "Other state driver's license with photo"
        ) ;
        legal:signerPresence "Physical presence required, remote notarization not accepted for bar complaints" ;
        legal:acknowledgmentForm "Standard Nevada acknowledgment certificate"
    ] ;
    
    # Notary Locations
    procedure:notaryServices [
        procedure:serviceType "Nevada State Bar Office" ;
        procedure:address "9456 Double R Boulevard, Reno, NV 89521" ;
        procedure:availability "By appointment Monday-Friday 9:00 AM - 4:00 PM" ;
        procedure:cost "Free for bar complaint notarization" ;
        procedure:contact "+1-775-382-2200"
    ] ;
    
    procedure:notaryServices [
        procedure:serviceType "Las Vegas Bar Office" ;
        procedure:address "600 E. Charleston Blvd., Las Vegas, NV 89104" ;
        procedure:availability "By appointment" ;
        procedure:cost "Free for bar complaint notarization"
    ] ;
    
    procedure:notaryServices [
        procedure:serviceType "Public Notary Services" ;
        procedure:locations "Banks, UPS stores, law offices, mobile notaries" ;
        procedure:cost "Typically $5-$15 per notarization" ;
        procedure:verification "Ensure notary is licensed in Nevada"
    ] ;
    
    # Notarization Process
    procedure:notarizationProcess [
        procedure:step1 "Complete bar complaint form but do not sign" ;
        procedure:step2 "Bring unsigned form and valid ID to notary" ;
        procedure:step3 "Sign form in presence of notary" ;
        procedure:step4 "Notary completes acknowledgment certificate" ;
        procedure:step5 "Submit notarized complaint to Nevada State Bar" ;
        procedure:requirements "Form must be signed in notary's physical presence"
    ] .

