# === NEVADA STATE BAR AUTHORITY ===

jurisdiction:StateBarNevada a jurisdiction:BarJurisdiction ;
    rdfs:label "State Bar of Nevada" ;
    jurisdiction:barId "NV-SB-001" ;
    foaf:homepage <https://www.nvbar.org> ;
    jurisdiction:complaintsWebsite <https://www.nvbar.org/for-the-public/attorney-discipline/> ;
    jurisdiction:complaintForm <https://www.nvbar.org/wp-content/uploads/Grievance-Form-Fillable.pdf> ;
    
    # Primary Contact Information
    jurisdiction:headquarters [
        jurisdiction:address "9456 Double R Boulevard, Reno, NV 89521" ;
        foaf:phone "+1-775-382-2200" ;
        foaf:mbox <mailto:barcomplaints@nvbar.org> ;
        geo:lat "39.5296"^^xsd:float ;
        geo:long "-119.8138"^^xsd:float ;
        jurisdiction:businessHours "Monday-Friday 8:00 AM - 5:00 PM PST"
    ] ;
    
    # Las Vegas Office
    jurisdiction:regionalOffice [
        jurisdiction:officeName "Las Vegas Office" ;
        jurisdiction:address "600 E. Charleston Blvd., Las Vegas, NV 89104" ;
        foaf:phone "+1-702-382-2200" ;
        geo:lat "36.1699"^^xsd:float ;
        geo:long "-115.1398"^^xsd:float ;
        jurisdiction:services "Complaint intake, attorney information"
    ] ;
    
    # Filing Requirements - Nevada Specific
    jurisdiction:filingRequirements [
        filing:format "PDF preferred, physical paper accepted" ;
        filing:copiesRequired "1"^^xsd:integer ;
        filing:verificationRequired "true"^^xsd:boolean ;
        filing:notarizationRequired "true"^^xsd:boolean ;
        filing:notarizationDetails "All complaints must be notarized with proper identification" ;
        filing:electronicFilingAvailable "true"^^xsd:boolean ;
        filing:electronicFilingNote "Electronic submission available but notarized hard copy still required" ;
        filing:filingFee "0.00"^^xsd:decimal ;
        filing:currency "USD" ;
        filing:processingTime "10-15 business days initial review" ;
        filing:confirmationMethod "Written acknowledgment by mail"
    ] ;
    
    # Economic Harm Requirement
    jurisdiction:economicHarmRequirement [
        legal:standardRequired "true"^^xsd:boolean ;
        legal:threshold "None specified, but harm must be demonstrated" ;
        legal:definition "Financial loss, damages, or opportunity costs resulting from attorney misconduct" ;
        legal:documentation "Detailed description with supporting evidence required" ;
        legal:examples (
            "Legal fees for corrective representation"
            "Lost settlement opportunity"
            "Business damages from missed deadlines"
            "Costs of expert witnesses for malpractice claim"
            "Economic losses from conflict of interest"
        ) ;
        legal:burden "Complainant must establish causal connection between misconduct and harm"
    ] ;
    
    # Jurisdictional Scope
    jurisdiction:hasJurisdictionOver [
        jurisdiction:scope "All Nevada licensed attorneys" ;
        jurisdiction:memberCount "12500"^^xsd:integer ;
        jurisdiction:activeMembers "9800"^^xsd:integer ;
        jurisdiction:inactiveMembers "2700"^^xsd:integer ;
        jurisdiction:outOfStateAttorneys "Admitted pro hac vice under Nevada rules"
    ] ;
    
    # Disciplinary Process - Nevada Specific
    jurisdiction:disciplinaryProcess [
        procedure:step1 [
            procedure:stageName "Complaint Screening" ;
            procedure:duration "30 days" ;
            procedure:description "Initial review for jurisdiction, completeness, and merit" ;
            procedure:requirements "Completed form, notarization, economic harm documentation" ;
            procedure:outcome "Dismissal, Investigation, or Administrative Resolution"
        ] ;
        procedure:step2 [
            procedure:stageName "Investigation" ;
            procedure:duration "4-8 months" ;
            procedure:description "Fact-finding by State Bar Counsel" ;
            procedure:investigator "Nevada State Bar Counsel" ;
            procedure:respondentNotification "30 days to respond to allegations"
        ] ;
        procedure:step3 [
            procedure:stageName "Screening Panel Review" ;
            procedure:duration "60 days" ;
            procedure:description "Three-member panel reviews investigation results" ;
            procedure:composition "2 attorneys, 1 public member" ;
            procedure:options "Dismissal, Admonishment, Formal Charges"
        ] ;
        procedure:step4 [
            procedure:stageName "Formal Hearing" ;
            procedure:duration "6-12 months" ;
            procedure:description "If formal charges filed, hearing before disciplinary panel" ;
            procedure:hearingOfficer "Disciplinary Board Hearing Panel" ;
            procedure:appealRight "Nevada Supreme Court within 30 days"
        ]
    ] ;
    
    # Time Limitations
    jurisdiction:timeLimit "4 years from occurrence of misconduct" ;
    jurisdiction:discoveryRule "false"^^xsd:boolean ;
    jurisdiction:continuingViolationException "May extend limitation period for ongoing misconduct" ;
    jurisdiction:criminalConvictionException "No time limit for criminal convictions involving moral turpitude" ;
    
    # Required Complaint Elements - Nevada Specific
    jurisdiction:requiredElements [
        filing:element "Respondent attorney full name and Nevada Bar number" ;
        filing:element "Respondent law firm name and complete address" ;
        filing:element "Complainant full name, address, and telephone number" ;
        filing:element "Detailed factual allegations in chronological order" ;
        filing:element "Specific Nevada Rules of Professional Conduct allegedly violated" ;
        filing:element "Description of economic harm suffered" ;
        filing:element "Evidence of attempts to resolve matter with attorney" ;
        filing:element "Supporting documentation and exhibits" ;
        filing:element "Notarized signature with date" ;
        filing:element "Statement under penalty of perjury"
    ] ;
    
    # Professional Conduct Rules
    jurisdiction:rulesReference [
        legal:rulebook "Nevada Rules of Professional Conduct" ;
        legal:effectiveDate "2006-05-01"^^xsd:date ;
        legal:basedOn "ABA Model Rules of Professional Conduct" ;
        legal:primaryRules (
            "RPC 1.1 - Competence"
            "RPC 1.2 - Scope of Representation and Allocation of Authority"
            "RPC 1.3 - Diligence"
            "RPC 1.4 - Communication"
            "RPC 1.5 - Fees"
            "RPC 1.6 - Confidentiality of Information"
            "RPC 1.7 - Conflict of Interest: Current Clients"
            "RPC 1.8 - Conflict of Interest: Specific Rules"
            "RPC 1.9 - Duties to Former Clients"
            "RPC 3.1 - Meritorious Claims and Contentions"
            "RPC 3.3 - Candor Toward the Tribunal"
            "RPC 3.4 - Fairness to Opposing Party and Counsel"
            "RPC 4.1 - Truthfulness in Statements to Others"
            "RPC 8.4 - Professional Responsibility"
        )
    ] .

