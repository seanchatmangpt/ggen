# === TIMELINE REGULATION SYSTEM ===

jurisdiction:NevadaTimelineRegulation a procedure:TimelineRegulationSystem ;
    rdfs:label "Nevada Multi-Jurisdictional Timeline Coordination" ;
    
    # Statute of Limitations
    procedure:statuteLimitations [
        legal:civilProcedure "Nevada Revised Statutes Chapter 11" ;
        legal:personalInjury "2 years" ;
        legal:contractWritten "6 years" ;
        legal:contractOral "4 years" ;
        legal:fraud "3 years from discovery" ;
        legal:professionalMalpractice "2 years from discovery, 4 years from act" ;
        legal:employmentClaims "Various - wage claims 2 years, discrimination 2-4 years"
    ] ;
    
    # Service of Process Timeline
    procedure:serviceRequirements [
        legal:personalService "Immediate effect upon service" ;
        legal:substitutedService "As provided in NRCP 4(f)" ;
        legal:serviceByMail "Complete upon return receipt" ;
        legal:publicationService "Court-ordered timeline after diligent search" ;
        legal:electronicService "With consent, effective on transmission"
    ] ;
    
    # Response Deadlines
    procedure:responseDeadlines [
        legal:answerToComplaint "21 days after service" ;
        legal:motionToDismiss "21 days after service" ;
        legal:discoveryResponses "30 days unless otherwise ordered" ;
        legal:motionPractice "Minimum 14 days notice unless emergency" ;
        legal:appealDeadline "30 days from final judgment"
    ] .

# === CONTRADICTION VALIDATION FRAMEWORK ===

jurisdiction:NevadaContradictionValidation a procedure:ContradictionDetectionFramework ;
    rdfs:label "Nevada Opposing Counsel Contradiction Detection System" ;
    
    # Nevada-Specific Detection Categories
    procedure:contradictionType [
        procedure:category "Economic Harm Contradictions" ;
        procedure:definition "Inconsistent claims about financial impact or damages" ;
        procedure:nevadaSpecific "Critical for Nevada bar complaints requiring economic harm" ;
        procedure:evidenceStandard "Documentation of conflicting damage claims" ;
        procedure:legalEffect "Undermines credibility of economic harm requirement"
    ] ;
    
    procedure:contradictionType [
        procedure:category "Notarization Contradictions" ;
        procedure:definition "Inconsistent statements in notarized vs. non-notarized documents" ;
        procedure:nevadaSpecific "Notarized bar complaints vs. other sworn statements" ;
        procedure:evidenceStandard "Comparison of sworn statements under penalty of perjury" ;
        procedure:legalEffect "Potential perjury implications, credibility destruction"
    ] ;
    
    procedure:contradictionType [
        procedure:category "Professional Conduct Rule Contradictions" ;
        procedure:definition "Attorney claims inconsistent positions about ethical obligations" ;
        procedure:scope "Nevada RPC interpretations vs. actual conduct" ;
        procedure:evidenceStandard "Documented positions in pleadings, correspondence, or testimony" ;
        procedure:legalEffect "Disciplinary impeachment, professional credibility damage"
    ] ;
    
    # Mining Law Specialty Contradictions
    procedure:contradictionType [
        procedure:category "Mining Law Contradictions" ;
        procedure:definition "Inconsistent positions in Nevada's specialized mining jurisdiction" ;
        procedure:nevadaSpecific "Federal vs. state mining law interpretations" ;
        procedure:expertise "Nevada federal court has specialized mining law jurisdiction" ;
        procedure:evidenceStandard "Technical expertise and precedent analysis required"
    ] ;
    
    # Validation Methodology
    procedure:validationMethod [
        procedure:step "Nevada-Specific Document Collection" ;
        procedure:sources "Nevada court filings, bar complaints, administrative proceedings" ;
        procedure:specialFocus "Economic harm documentation, notarized statements" ;
        procedure:timeline "Ongoing with quarterly comprehensive review"
    ] ;
    
    procedure:validationMethod [
        procedure:step "Cross-Jurisdictional Analysis" ;
        procedure:method "Compare Nevada positions with California and federal filings" ;
        procedure:automated "Digital analysis flagging inconsistent language patterns" ;
        procedure:output "Multi-jurisdictional contradiction matrix"
    ] ;
    
    procedure:validationMethod [
        procedure:step "Economic Harm Validation" ;
        procedure:nevadaSpecific "Verify consistency of economic harm claims across proceedings" ;
        procedure:method "Financial document analysis, expert witness comparison" ;
        procedure:threshold "Material inconsistencies in claimed damages"
    ] .

