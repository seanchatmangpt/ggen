# === NEVADA EMPLOYMENT LAW ===

jurisdiction:NevadaEmploymentLaw a legal:EmploymentClassificationFramework ;
    rdfs:label "Nevada Employment Classification Requirements" ;
    
    # Independent Contractor Test
    legal:independentContractorTest [
        legal:testName "Nevada Right-to-Control Test" ;
        legal:authority "Nevada Revised Statutes Chapter 608" ;
        legal:criteria [
            legal:factor "Right to control means and manner of work" ;
            legal:weight "Primary factor"
        ] ;
        legal:criteria [
            legal:factor "Skill required for particular occupation" ;
            legal:weight "Secondary factor"
        ] ;
        legal:criteria [
            legal:factor "Length of time services performed" ;
            legal:weight "Secondary factor"
        ] ;
        legal:criteria [
            legal:factor "Method of payment (hourly vs. project)" ;
            legal:weight "Secondary factor"
        ] ;
        legal:criteria [
            legal:factor "Whether work is part of regular business" ;
            legal:weight "Secondary factor"
        ] ;
        legal:burden "Totality of circumstances test, no single factor determinative"
    ] ;
    
    # Filing Authorities
    legal:filingAuthority [
        legal:agency "Nevada Labor Commissioner" ;
        legal:website <https://labor.nv.gov> ;
        legal:complaintForm "https://labor.nv.gov/Complaints/File_a_Complaint/" ;
        legal:address "1818 College Parkway, Suite 102, Carson City, NV 89706" ;
        legal:regionalOffice "2800 E. St. Louis Ave., Las Vegas, NV 89104"
    ] ;
    
    legal:filingAuthority [
        legal:agency "Nevada Employment Security Division" ;
        legal:website <https://detr.nv.gov> ;
        legal:unemploymentInsurance "Worker classification for UI purposes" ;
        legal:address "500 E. Third Street, Carson City, NV 89713"
    ] ;
    
    legal:filingAuthority [
        legal:agency "Nevada Division of Industrial Relations" ;
        legal:website <https://dir.nv.gov> ;
        legal:workersCompensation "Worker classification for WC coverage" ;
        legal:address "400 West King Street, Carson City, NV 89703"
    ] .

