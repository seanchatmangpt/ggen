# type-registry.ttl -- RDF 1.2 Cross-Ontology Unified Type Registry Vocabulary
# A=mu(O) -- Unified type registry = mu(all ontology type mappings via triple terms)
#
# Uses RDF 1.2 triple terms (<<s p o>>) to aggregate type mappings across ALL
# ontologies into a single authoritative source. Each triple term represents an
# entity-property-range axiom, and annotations attach cross-language type bindings,
# provenance, confidence scores, and lifecycle metadata.
#
# Pipeline: type-registry.ttl + type-registry-example.ttl
#        -> type-registry-extract.rq (SPARQL-star CONSTRUCT)
#        -> type-registry.tera (Tera template)
#        -> type-registry.md (generated artifact)
#
# Blue Ocean: Raises ggen from "generates code from one ontology" to
# "generates code from the entire ontology ecosystem."

@prefix tr: <https://ggen.dev/ontology/typeregistry#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
# 1. ONTOLOGY METADATA
# ============================================================================

<https://ggen.dev/ontology/typeregistry>
  a owl:Ontology ;
  owl:imports
    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>,
    <http://www.w3.org/2000/01/rdf-schema#>,
    <http://www.w3.org/2002/07/owl#>,
    <http://www.w3.org/2001/XMLSchema#> ;
  rdfs:label "Cross-Ontology Type Registry Vocabulary"@en ;
  rdfs:comment "RDF 1.2 vocabulary for a unified type registry that aggregates type mappings across multiple ontologies. Uses triple terms (<<s p o>>) so each axiom can carry annotations from multiple sources simultaneously, enabling cross-ontology code generation from a single authoritative registry."@en .

# ============================================================================
# 2. ANNOTATION PROPERTIES -- Provenance (used ON triple terms)
# ============================================================================
# These annotate triple terms to record which ontology contributed each mapping.

tr:sourceOntology
  a owl:AnnotationProperty ;
  rdfs:label "source ontology"@en ;
  rdfs:comment "IRI of the ontology this type mapping originates from (e.g., https://schema.org, https://spec.edmcouncil.org/fibo/)."@en ;
  rdfs:range owl:Thing .

tr:sourceOntologyName
  a owl:AnnotationProperty ;
  rdfs:label "source ontology name"@en ;
  rdfs:comment "Human-readable name of the source ontology (e.g., 'schema.org', 'FIBO', 'PROV-O', 'FOAF', 'SKOS')."@en ;
  rdfs:range xsd:string .

tr:confidence
  a owl:AnnotationProperty ;
  rdfs:label "confidence"@en ;
  rdfs:comment "Confidence in this type mapping from 0.0 to 1.0. Higher values indicate stronger evidence, more authoritative source, or broader adoption."@en ;
  rdfs:range xsd:decimal .

tr:isCanonical
  a owl:AnnotationProperty ;
  rdfs:label "is canonical"@en ;
  rdfs:comment "Whether this is the authoritative (canonical) mapping for this domain concept. When multiple ontologies map the same concept, the canonical one is preferred for code generation."@en ;
  rdfs:range xsd:boolean .

tr:sinceVersion
  a owl:AnnotationProperty ;
  rdfs:label "since version"@en ;
  rdfs:comment "Version of the source ontology when this mapping was first added (e.g., '1.0', '15.0')."@en ;
  rdfs:range xsd:string .

tr:deprecatedBy
  a owl:AnnotationProperty ;
  rdfs:label "deprecated by"@en ;
  rdfs:comment "IRI of another triple term that supersedes this mapping. Used to chain deprecation and migration paths."@en ;
  rdfs:range owl:Thing .

tr:conversionNote
  a owl:AnnotationProperty ;
  rdfs:label "conversion note"@en ;
  rdfs:comment "Notes about converting between types, lossy transformations, or compatibility concerns when using this mapping."@en ;
  rdfs:range xsd:string .

# ============================================================================
# 3. ANNOTATION PROPERTIES -- Language-Specific Type Bindings
# ============================================================================

tr:rustType
  a owl:AnnotationProperty ;
  rdfs:label "Rust type"@en ;
  rdfs:comment "Rust type mapping for a property range (e.g., String, u8, f64, Vec<u8>, uuid::Uuid, DateTime<Utc>)."@en ;
  rdfs:range xsd:string .

tr:goType
  a owl:AnnotationProperty ;
  rdfs:label "Go type"@en ;
  rdfs:comment "Go type mapping for a property range (e.g., string, uint8, float64, []byte, time.Time)."@en ;
  rdfs:range xsd:string .

tr:elixirType
  a owl:AnnotationProperty ;
  rdfs:label "Elixir type"@en ;
  rdfs:comment "Elixir type mapping for a property range (e.g., String.t, non_neg_integer, float, DateTime.t, [byte])."@en ;
  rdfs:range xsd:string .

tr:tsType
  a owl:AnnotationProperty ;
  rdfs:label "TypeScript type"@en ;
  rdfs:comment "TypeScript type mapping for a property range (e.g., string, number, number[], boolean, Date)."@en ;
  rdfs:range xsd:string .

tr:pythonType
  a owl:AnnotationProperty ;
  rdfs:label "Python type"@en ;
  rdfs:comment "Python type mapping for a property range (e.g., str, int, float, bool, datetime, List[int])."@en ;
  rdfs:range xsd:string .

# ============================================================================
# 4. ANNOTATION PROPERTIES -- Schema & Validation
# ============================================================================

tr:jsonSchema
  a owl:AnnotationProperty ;
  rdfs:label "JSON Schema type"@en ;
  rdfs:comment "JSON Schema primitive type: string, number, integer, boolean, object, array, or null."@en ;
  rdfs:range xsd:string .

tr:defaultValue
  a owl:AnnotationProperty ;
  rdfs:label "default value"@en ;
  rdfs:comment "Default value expression for the field in the target language (e.g., '0', 'String::new()', 'false')."@en ;
  rdfs:range xsd:string .

tr:validationRule
  a owl:AnnotationProperty ;
  rdfs:label "validation rule"@en ;
  rdfs:comment "Validation expression or constraint description (e.g., '0..=150', 'regex(^[^@]+@[^@]+$)', 'ISO 8601')."@en ;
  rdfs:range xsd:string .

# ============================================================================
# 5. CLASSES -- Type Registry Domain Model
# ============================================================================

tr:TypeMapping
  a owl:Class ;
  rdfs:label "Type Mapping"@en ;
  rdfs:comment "A single type mapping extracted from a triple term annotation. Contains the domain entity, property, range, source ontology, and all language bindings."@en .

tr:UnifiedType
  a owl:Class ;
  rdfs:label "Unified Type"@en ;
  rdfs:comment "An aggregation of multiple TypeMappings for the same entity+property from different ontologies. The unified type selects the canonical mapping as primary and lists alternatives."@en .

tr:LanguageBinding
  a owl:Class ;
  rdfs:label "Language Binding"@en ;
  rdfs:comment "A single language-to-type binding (e.g., Rust=u8, Go=uint8, TypeScript=number). Part of a TypeMapping."@en .

tr:OntologySource
  a owl:Class ;
  rdfs:label "Ontology Source"@en ;
  rdfs:comment "A registered ontology that contributes type mappings to the registry. Tracks name, IRI, version, and mapping count."@en .

tr:TypeRegistry
  a owl:Class ;
  rdfs:label "Type Registry"@en ;
  rdfs:comment "The root container for the unified type registry. Tracks all sources, total mappings, canonical count, and coverage statistics."@en .

tr:CompatibilityRule
  a owl:Class ;
  rdfs:label "Compatibility Rule"@en ;
  rdfs:comment "A rule governing how type mappings from different ontologies interact when generating code. Used to resolve conflicts and enforce consistency."@en .

# ============================================================================
# 6. DATATYPE PROPERTIES -- TypeMapping fields (flat output from CONSTRUCT)
# ============================================================================

tr:domainEntity
  a owl:DatatypeProperty ;
  rdfs:label "domain entity"@en ;
  rdfs:comment "Local name of the domain entity (e.g., 'Person', 'MonetaryAmount')."@en ;
  rdfs:domain tr:TypeMapping ;
  rdfs:range xsd:string .

tr:domainProperty
  a owl:DatatypeProperty ;
  rdfs:label "domain property"@en ;
  rdfs:comment "Local name of the domain property (e.g., 'hasName', 'hasValue')."@en ;
  rdfs:domain tr:TypeMapping ;
  rdfs:range xsd:string .

tr:domainRange
  a owl:DatatypeProperty ;
  rdfs:label "domain range"@en ;
  rdfs:comment "Local name of the XSD range type (e.g., 'string', 'integer', 'decimal')."@en ;
  rdfs:domain tr:TypeMapping ;
  rdfs:range xsd:string .

tr:sourceName
  a owl:DatatypeProperty ;
  rdfs:label "source name"@en ;
  rdfs:comment "Human-readable name of the source ontology for this mapping."@en ;
  rdfs:domain tr:TypeMapping ;
  rdfs:range xsd:string .

# ============================================================================
# 7. OBJECT PROPERTIES -- Registry structure
# ============================================================================

tr:hasMapping
  a owl:ObjectProperty ;
  rdfs:label "has mapping"@en ;
  rdfs:comment "Links a TypeRegistry or UnifiedType to a specific TypeMapping."@en ;
  rdfs:range tr:TypeMapping .

tr:hasSource
  a owl:ObjectProperty ;
  rdfs:label "has source"@en ;
  rdfs:comment "Links a TypeRegistry to a registered OntologySource."@en ;
  rdfs:domain tr:TypeRegistry ;
  rdfs:range tr:OntologySource .

tr:hasCompatibilityRule
  a owl:ObjectProperty ;
  rdfs:label "has compatibility rule"@en ;
  rdfs:comment "Links a TypeRegistry to a CompatibilityRule."@en ;
  rdfs:domain tr:TypeRegistry ;
  rdfs:range tr:CompatibilityRule .

tr:totalMappings
  a owl:DatatypeProperty ;
  rdfs:label "total mappings"@en ;
  rdfs:comment "Total number of type mappings in the registry."@en ;
  rdfs:domain tr:TypeRegistry ;
  rdfs:range xsd:integer .

tr:canonicalCount
  a owl:DatatypeProperty ;
  rdfs:label "canonical count"@en ;
  rdfs:comment "Number of mappings marked as canonical."@en ;
  rdfs:domain tr:TypeRegistry ;
  rdfs:range xsd:integer .

tr:deprecatedCount
  a owl:DatatypeProperty ;
  rdfs:label "deprecated count"@en ;
  rdfs:comment "Number of mappings marked as deprecated."@en ;
  rdfs:domain tr:TypeRegistry ;
  rdfs:range xsd:integer .

# ============================================================================
# 8. EXAMPLE TRIPLE TERM PATTERN
# ============================================================================
# This demonstrates the core pattern: a triple term <<s p o>> is annotated
# with provenance, language bindings, and metadata.

@prefix ex: <https://ggen.dev/examples/typeregistry#> .

<< ex:Person ex:hasAge xsd:integer >> tr:sourceOntology <https://schema.org> ;
                                        tr:sourceOntologyName "schema.org" ;
                                        tr:rustType "u8" ;
                                        tr:goType "uint8" ;
                                        tr:elixirType "non_neg_integer" ;
                                        tr:tsType "number" ;
                                        tr:pythonType "int" ;
                                        tr:confidence "0.95"^^xsd:decimal ;
                                        tr:isCanonical true ;
                                        tr:jsonSchema "number" ;
                                        tr:validationRule "0..=150" .
