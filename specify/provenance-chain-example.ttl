ex:PetriNet
    a owl:Class ;
    rdfs:label "Petri Net"@en ;
    rdfs:comment "A mathematical modeling language for concurrent systems."@en .

ex:PetriNet rdfs:subClassOf ex:WorkflowModel .

ex:SoundnessChecker
    a owl:Class ;
    rdfs:label "Soundness Checker"@en ;
    rdfs:comment "Verifies deadlock freedom, liveness, and boundedness of a Petri net."@en .

ex:SoundnessChecker dod:requiresArtifact ex:VerificationReport .

