# review-rules-extract.rq
# Extract code review rules with RDF 1.2 triple-term context-awareness annotations.
#
# Uses SPARQL-star to extract << ?rule rev:ruleId ?ruleId >> triple-term
# annotations (appliesToContext, conflictsWithRule, triggersMergeGate, etc.)
# and CONSTRUCT flat triples for Tera template consumption.
#
# Usage: Replace ?targetLanguage with the desired language name.
#   Example: BIND("Rust" AS ?targetLanguage)
#
# Output: rule ID, description, category, severity, check pattern, suggestion,
#         contextName, conflictingRuleId, isMergeGate, priority, isAutoFixable, autoFixCommand

PREFIX rev: <https://ggen.dev/ontology/review/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

CONSTRUCT {
    ?rule a rev:ReviewRule ;
        rev:ruleId ?ruleId ;
        rev:ruleDescription ?description ;
        rev:checkPattern ?pattern ;
        rev:checkType ?checkType ;
        rev:suggestion ?suggestion ;
        rev:hasCategory ?category ;
        rev:hasSeverity ?severity ;
        rev:appliesToLanguage ?lang ;
        rev:contextName ?contextName ;
        rev:conflictingRuleId ?conflictingRuleId ;
        rev:isMergeGate ?isMergeGate ;
        rev:priority ?priority ;
        rev:isAutoFixable ?isAutoFixable ;
        rev:autoFixCommand ?autoFixCommand ;
        rev:categoryName ?catName ;
        rev:severityLabel ?sevLabel ;
        rev:severityLevel ?sevLevel ;
        rev:languageName ?langName ;
        rev:ruleLocalName ?ruleLocalName .
}
WHERE {
    # Bind target language (change this value to filter by language)
    BIND("all" AS ?targetLanguage)

    # Core rule triples
    ?rule a rev:ReviewRule ;
        rev:ruleId ?ruleId ;
        rev:ruleDescription ?description ;
        rev:checkPattern ?pattern ;
        rev:checkType ?checkType ;
        rev:suggestion ?suggestion ;
        rev:hasCategory ?category ;
        rev:hasSeverity ?severity ;
        rev:appliesToLanguage ?lang .

    # Filter: rule applies to target language or to "all"
    ?lang rev:languageName ?langName .
    FILTER(?langName = ?targetLanguage)

    # Local-name extraction via STRAFTER (e.g., "rule-no-unsafe-without-doc" from full URI)
    BIND(STRAFTER(STR(?rule), "#") AS ?afterHash)
    BIND(IF(STRLEN(?afterHash) > 0, ?afterHash, STRAFTER(STR(?rule), "/")) AS ?ruleLocalName)

    # Category name
    OPTIONAL { ?category rev:categoryName ?catName }

    # Severity label and level
    OPTIONAL { ?severity rdfs:label ?sevLabel }
    OPTIONAL { ?severity rev:severityLevel ?sevLevel }

    # ---- SPARQL-star triple-term annotations ----

    # Context-aware: which code context this rule fires in
    OPTIONAL {
        << ?rule rev:ruleId ?ruleId >> rev:appliesToContext ?contextName .
    }

    # Rule conflicts: which other rule contradicts this one
    OPTIONAL {
        << ?rule rev:ruleId ?ruleId >> rev:conflictsWithRule ?conflictingRuleId .
    }

    # Merge gate: whether violation blocks merge
    OPTIONAL {
        << ?rule rev:ruleId ?ruleId >> rev:triggersMergeGate ?mergeGateRaw .
        BIND(COALESCE(?mergeGateRaw, false) AS ?isMergeGate)
    }

    # Priority: numeric ranking when multiple rules match
    OPTIONAL {
        << ?rule rev:ruleId ?ruleId >> rev:rulePriority ?priority .
    }

    # Auto-fixable: whether a CLI command can fix this
    OPTIONAL {
        << ?rule rev:ruleId ?ruleId >> rev:autoFixable ?autoFixRaw .
        BIND(COALESCE(?autoFixRaw, false) AS ?isAutoFixable)
    }

    # Fix command: CLI command for auto-fix
    OPTIONAL {
        << ?rule rev:ruleId ?ruleId >> rev:fixCommand ?autoFixCommand .
    }

    # Superseded: provenance — which ontology version deprecated this rule
    OPTIONAL {
        << ?rule rev:ruleId ?ruleId >> rev:supersededByVersion ?supersededBy .
        FILTER(!BOUND(?supersededBy))
    }
}
ORDER BY DESC(COALESCE(?priority, ?sevLevel, 0))
LIMIT 50

