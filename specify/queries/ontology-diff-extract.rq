# ontology-diff-extract.rq — SPARQL-star CONSTRUCT query for ontology diff extraction
# A=mu(O): Migration report = mu(ontology-diff.ttl + ontology-diff-example.ttl)
#
# Uses RDF 1.2 triple terms (<<s p o>>) in WHERE patterns to find axioms annotated
# with diff metadata. Outputs flat triples in CONSTRUCT for consumption by Tera
# templates (Vec<BTreeMap<String, String>>).
#
# Extracts:
#   1. Individual changes with full metadata (entity, property, range, type, reason, impact)
#   2. Summary counts by changeType
#   3. Summary counts by breaking/non-breaking
#   4. Summary counts by auto-migratable/manual
#
# Usage:
#   sparql --query ontology-diff-extract.rq \
#          --data ontology-diff.ttl \
#          --data ontology-diff-example.ttl

PREFIX diff: <https://ggen.dev/ontology/diff#>
PREFIX ex: <https://ggen.dev/examples/diff#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
  # Each annotated triple term becomes a flat ExtractedChange instance
  ?change a diff:ExtractedChange ;
    diff:entity ?entityName ;
    diff:property ?propName ;
    diff:range ?rangeName ;
    diff:changeType ?changeType ;
    diff:changeReason ?reason ;
    diff:removedInVersion ?removedVersion ;
    diff:addedInVersion ?addedVersion ;
    diff:modifiedInVersion ?modifiedVersion ;
    diff:replacement ?replacement ;
    diff:oldRange ?oldRange ;
    diff:newRange ?newRange ;
    diff:oldCardinality ?oldCard ;
    diff:newCardinality ?newCard ;
    diff:impactLevel ?impact ;
    diff:affectedTemplates ?templates ;
    diff:affectedQueries ?queries ;
    diff:breakingChange ?breaking ;
    diff:autoMigration ?autoMigrate ;
    diff:migrationStep ?step ;
    diff:migrationCode ?code ;
    diff:verificationQuery ?verify .

  # Summary report root
  ?report a diff:DiffReport ;
    diff:fromVersion ?fromVer ;
    diff:toVersion ?toVer ;
    diff:totalChanges ?totalCount ;
    diff:breakingCount ?breakCount ;
    diff:nonBreakingCount ?nonBreakCount ;
    diff:autoMigratableCount ?autoCount ;
    diff:manualCount ?manualCount ;
    diff:hasChange ?change .
}
WHERE {

  # ========================================================================
  # CORE EXTRACTION: Match annotated triple terms
  # ========================================================================
  << ?entity ?prop ?range >> diff:changeType ?changeType .

  # Extract optional annotations — BIND with defaults for missing values
  OPTIONAL { << ?entity ?prop ?range >> diff:changeReason ?reason . }
  OPTIONAL { << ?entity ?prop ?range >> diff:removedInVersion ?removedVersion . }
  OPTIONAL { << ?entity ?prop ?range >> diff:addedInVersion ?addedVersion . }
  OPTIONAL { << ?entity ?prop ?range >> diff:modifiedInVersion ?modifiedVersion . }
  OPTIONAL { << ?entity ?prop ?range >> diff:replacementTriple ?replacement . }
  OPTIONAL { << ?entity ?prop ?range >> diff:oldRange ?oldRange . }
  OPTIONAL { << ?entity ?prop ?range >> diff:newRange ?newRange . }
  OPTIONAL { << ?entity ?prop ?range >> diff:oldCardinality ?oldCard . }
  OPTIONAL { << ?entity ?prop ?range >> diff:newCardinality ?newCard . }
  OPTIONAL { << ?entity ?prop ?range >> diff:impactLevel ?impact . }
  OPTIONAL { << ?entity ?prop ?range >> diff:affectedTemplates ?templates . }
  OPTIONAL { << ?entity ?prop ?range >> diff:affectedQueries ?queries . }
  OPTIONAL { << ?entity ?prop ?range >> diff:breakingChange ?breaking . }
  OPTIONAL { << ?entity ?prop ?range >> diff:autoMigration ?autoMigrate . }
  OPTIONAL { << ?entity ?prop ?range >> diff:migrationStep ?step . }
  OPTIONAL { << ?entity ?prop ?range >> diff:migrationCode ?code . }
  OPTIONAL { << ?entity ?prop ?range >> diff:verificationQuery ?verify . }

  # Format entity/property/range names: strip full IRI to local name
  BIND(STRAFTER(STR(?entity), "#") AS ?entityName)
  BIND(STRAFTER(STR(?prop), "#") AS ?propName)
  BIND(STRAFTER(STR(?range), "#") AS ?rangeName)

  # Defaults for optional fields
  BIND(COALESCE(?reason, "") AS ?reason)
  BIND(COALESCE(?removedVersion, "") AS ?removedVersion)
  BIND(COALESCE(?addedVersion, "") AS ?addedVersion)
  BIND(COALESCE(?modifiedVersion, "") AS ?modifiedVersion)
  BIND(COALESCE(?replacement, "") AS ?replacement)
  BIND(COALESCE(?oldRange, "") AS ?oldRange)
  BIND(COALESCE(?newRange, "") AS ?newRange)
  BIND(COALESCE(?oldCard, "") AS ?oldCard)
  BIND(COALESCE(?newCard, "") AS ?newCard)
  BIND(COALESCE(?impact, "medium") AS ?impact)
  BIND(COALESCE(?templates, "") AS ?templates)
  BIND(COALESCE(?queries, "") AS ?queries)
  BIND(COALESCE(?breaking, false) AS ?breaking)
  BIND(COALESCE(?autoMigrate, false) AS ?autoMigrate)
  BIND(COALESCE(?step, "") AS ?step)
  BIND(COALESCE(?code, "") AS ?code)
  BIND(COALESCE(?verify, "") AS ?verify)

  # Generate stable change IRI from entity + property
  BIND(IRI(CONCAT("https://ggen.dev/examples/diff#Change-", ?entityName, "-", ?propName)) AS ?change)

  # ========================================================================
  # SUMMARY COUNTS — Computed across all changes
  # ========================================================================

  # Total change count
  {
    SELECT (COUNT(DISTINCT ?entity) AS ?totalCount)
    WHERE {
      << ?entity ?prop ?range >> diff:changeType ?changeType .
    }
  }

  # Breaking change count
  {
    SELECT (COUNT(DISTINCT ?entity) AS ?breakCount)
    WHERE {
      << ?entity ?prop ?range >> diff:changeType ?changeType .
      << ?entity ?prop ?range >> diff:breakingChange true .
    }
  }

  # Non-breaking change count
  {
    SELECT (COUNT(DISTINCT ?entity) AS ?nonBreakCount)
    WHERE {
      << ?entity ?prop ?range >> diff:changeType ?changeType .
      OPTIONAL { << ?entity ?prop ?range >> diff:breakingChange ?brk . }
      FILTER(COALESCE(?brk, false) = false)
    }
  }

  # Auto-migratable count
  {
    SELECT (COUNT(DISTINCT ?entity) AS ?autoCount)
    WHERE {
      << ?entity ?prop ?range >> diff:changeType ?changeType .
      << ?entity ?prop ?range >> diff:autoMigration true .
    }
  }

  # Manual intervention count
  {
    SELECT (COUNT(DISTINCT ?entity) AS ?manualCount)
    WHERE {
      << ?entity ?prop ?range >> diff:changeType ?changeType .
      OPTIONAL { << ?entity ?prop ?range >> diff:autoMigration ?auto . }
      FILTER(COALESCE(?auto, false) = false)
    }
  }

  # Report root node
  BIND(IRI("https://ggen.dev/examples/diff#DiffReport-generated") AS ?report)

  # Version info — extract from any version annotation
  {
    SELECT ?fromVer ?toVer
    WHERE {
      << ?e ?p ?r >> diff:addedInVersion ?toVer .
      << ?e2 ?p2 ?r2 >> diff:removedInVersion ?fromVer .
    }
    LIMIT 1
  }

  # Fallback if no version annotations found
  BIND(COALESCE(?fromVer, "1.0.0") AS ?fromVer)
  BIND(COALESCE(?toVer, "2.0.0") AS ?toVer)
}
ORDER BY DESC(?impact) ?entityName ?propName
