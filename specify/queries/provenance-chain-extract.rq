# provenance-chain-extract.rq — SPARQL-star CONSTRUCT query for provenance receipt extraction
# Extracts provenance annotations from RDF 1.2 triple terms and produces flat triples
# for Tera template rendering via ggen pipeline.
# A=mu(O): receipt-report.md = mu(provenance ontology triple terms)
#
# Usage:
#   sparql --query provenance-chain-extract.rq --data provenance-chain.ttl --data provenance-chain-example.ttl
#
# Note: SPARQL-star WHERE matches triple terms (<<s p o>>).
#       CONSTRUCT outputs flat triples (not nested triple terms)
#       because the consumer (Vec<BTreeMap<String, String>>) cannot handle nested structures.

PREFIX prv: <https://ggen.dev/ontology/provenance#>
PREFIX ex: <https://ggen.dev/examples/provenance#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
  # Receipt instance — flat triples for Tera consumption
  ?receipt a prv:ArtifactReceipt ;
    prv:sourceEntity ?sourceEntity ;
    prv:sourcePredicate ?sourcePredicate ;
    prv:sourceObject ?sourceObject ;
    prv:sourceTriple ?sourceTriple ;
    prv:commit ?commit ;
    prv:generator ?generator ;
    prv:template ?template ;
    prv:query ?query ;
    prv:ontology ?ontology ;
    prv:timestamp ?timestamp ;
    prv:artifactPath ?artifactPath ;
    prv:artifactType ?artifactType ;
    prv:artifactSize ?artifactSize ;
    prv:verification ?verification ;
    prv:hash ?hash ;
    prv:parentHash ?parentHash .

  # Chain instance — links receipts together
  ?chain a prv:ReceiptChain ;
    prv:chainHead ?chainHead ;
    prv:chainLength ?chainLength .
}
WHERE {
  # SPARQL-star pattern: match triple terms annotated with provenance properties
  << ?entity ?pred ?obj >>
    prv:generatedInCommit ?commit ;
    prv:generatedBy ?generator ;
    prv:templateUsed ?template ;
    prv:extractionQuery ?query ;
    prv:sourceOntology ?ontology ;
    prv:generatedAt ?timestamp ;
    prv:artifactPath ?artifactPath ;
    prv:artifactType ?artifactType ;
    prv:artifactSize ?artifactSize ;
    prv:receiptHash ?hash ;
    prv:verificationStatus ?verification .

  # OPTIONAL: parent receipt link (first receipt in chain has no parent)
  OPTIONAL {
    << ?entity ?pred ?obj >> prv:parentReceipt ?parentHash .
  }

  # Generate a deterministic receipt URI from the hash
  BIND(IRI(CONCAT("https://ggen.dev/examples/provenance#receipt-", SUBSTR(?hash, 1, 8))) AS ?receipt)

  # Extract string representations for flat triple output
  BIND(STR(?entity) AS ?sourceEntity)
  BIND(STR(?pred) AS ?sourcePredicate)
  BIND(STR(?obj) AS ?sourceObject)

  # Build human-readable triple string: "<< s p o >>"
  BIND(CONCAT("<< ", STR(?entity), " ", STR(?pred), " ", STR(?obj), " >>") AS ?sourceTriple)

  # Bind chain metadata (single chain per query execution)
  # In practice, the chain URI would be parameterized
  BIND(IRI("https://ggen.dev/examples/provenance#chain-extracted") AS ?chain)

  # Compute chain head and length from subqueries
  {
    SELECT ?chain (MAX(?timestamp) AS ?latestTimestamp) (COUNT(DISTINCT ?hash) AS ?chainLength)
    WHERE {
      << ?e ?p ?o >> prv:receiptHash ?hash ; prv:generatedAt ?timestamp .
    }
    GROUP BY ?chain
  }

  # Get the hash of the latest receipt as chain head
  {
    SELECT ?chain ?chainHead
    WHERE {
      << ?e2 ?p2 ?o2 >> prv:receiptHash ?chainHead ; prv:generatedAt ?latestTs .
      {
        SELECT (MAX(?ts) AS ?latestTs)
        WHERE {
          << ?e3 ?p3 ?o3 >> prv:generatedAt ?ts .
        }
      }
      FILTER(?latestTs = ?latestTs)
    }
    LIMIT 1
  }
}
ORDER BY ?timestamp
