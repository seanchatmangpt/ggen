# openapi-typegen-extract.rq -- SPARQL-star CONSTRUCT query for OpenAPI 3.0 generation
# A=mu(O): OpenAPI spec = mu(type-registry triple-term annotations + api endpoint annotations)
#
# Extracts two categories of data from RDF 1.2 triple-term annotated registries:
#
#   1. SCHEMA MAPPINGS -- Entity-property-range triples projected into OpenAPI
#      components/schemas. Each canonical triple term becomes a schema object with
#      properties typed via jsonSchema or inferred from language bindings.
#
#   2. ENDPOINT MAPPINGS -- API endpoint annotations projected into OpenAPI paths.
#      Each endpoint triple term becomes a path entry with method, operationId,
#      request/response schema references, and tags.
#
# Reuses the same <<?entity ?prop ?range>> triple-term pattern from type-registry.ttl.
# CONSTRUCT output is flat triples (no triple terms) for Tera template consumption.
#
# Usage:
#   sparql --query openapi-typegen-extract.rq \
#          --data type-registry.ttl \
#          --data type-registry-example.ttl \
#          --data openapi-endpoints.ttl

PREFIX tr: <https://ggen.dev/ontology/typeregistry#>
PREFIX api: <https://ggen.dev/ontology/openapi#>
PREFIX ex: <https://ggen.dev/examples/typeregistry#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
  # ==========================================================================
  # 1. SCHEMA DEFINITIONS -- One per entity, from canonical triple terms
  # ==========================================================================
  ?schemaNode a api:Schema ;
    api:schemaName ?entityName ;
    api:schemaDescription ?schemaDesc ;
    api:sourceOntologyName ?srcName ;
    api:isCanonical ?canonical ;
    api:confidence ?confidence .

  # ==========================================================================
  # 2. PROPERTY DEFINITIONS -- One per property within a schema
  # ==========================================================================
  ?propNode a api:SchemaProperty ;
    api:belongsToSchema ?entityName ;
    api:propertyName ?propName ;
    api:propertyType ?openApiType ;
    api:propertyFormat ?openApiFormat ;
    api:propertyDescription ?propDesc ;
    api:propertyRequired ?isRequired ;
    api:jsonSchema ?jsonSchema ;
    api:rustType ?rustType ;
    api:goType ?goType ;
    api:tsType ?tsType ;
    api:validationRule ?validation ;
    api:sourceOntologyName ?srcName ;
    api:confidence ?confidence ;
    api:isCanonical ?canonical .

  # ==========================================================================
  # 3. ENDPOINT DEFINITIONS -- From api: annotated triple terms
  # ==========================================================================
  ?endpointNode a api:Endpoint ;
    api:method ?method ;
    api:path ?path ;
    api:operationId ?operationId ;
    api:summary ?summary ;
    api:requestBodySchema ?requestBodySchema ;
    api:responseSchema ?responseSchema ;
    api:tags ?tags .

  # ==========================================================================
  # 4. REGISTRY SUMMARY -- Aggregate stats for OpenAPI info section
  # ==========================================================================
  ?openapiSummary a api:OpenAPISpec ;
    api:totalSchemas ?schemaCount ;
    api:totalEndpoints ?endpointCount ;
    api:totalProperties ?propertyCount .
}
WHERE {
  # ==========================================================================
  # 1. SCHEMA + PROPERTY EXTRACTION (from type-registry triple terms)
  # ==========================================================================
  # Match RDF 1.2 triple terms annotated with tr:rustType (required anchor).
  # We reuse the exact same pattern as type-registry-extract.rq.
  << ?entity ?prop ?range >> tr:rustType ?rustType ;
                                tr:sourceOntologyName ?srcName .

  # Optional language bindings
  OPTIONAL { << ?entity ?prop ?range >> tr:goType ?goType . }
  OPTIONAL { << ?entity ?prop ?range >> tr:elixirType ?elixirType . }
  OPTIONAL { << ?entity ?prop ?range >> tr:tsType ?tsType . }
  OPTIONAL { << ?entity ?prop ?range >> tr:pythonType ?pythonType . }

  # Optional metadata
  OPTIONAL { << ?entity ?prop ?range >> tr:confidence ?rawConfidence . }
  OPTIONAL { << ?entity ?prop ?range >> tr:isCanonical ?canonical . }
  OPTIONAL { << ?entity ?prop ?range >> tr:jsonSchema ?jsonSchema . }
  OPTIONAL { << ?entity ?prop ?range >> tr:validationRule ?validation . }
  OPTIONAL { << ?entity ?prop ?range >> tr:sinceVersion ?sinceVersion . }
  OPTIONAL { << ?entity ?prop ?range >> tr:conversionNote ?conversionNote . }
  OPTIONAL { << ?entity ?prop ?range >> tr:deprecatedBy ?depTriple . }
  OPTIONAL { << ?entity ?prop ?range >> tr:required ?rawRequired . }

  # Extract local names from IRIs for template-friendly variable names
  BIND(STRAFTER(STR(?entity), "#") AS ?entityName)
  BIND(STRAFTER(STR(?prop), "#") AS ?propName)
  BIND(STRAFTER(STR(?range), "#") AS ?rangeName)

  # Default confidence to "0.80" if not annotated
  BIND(COALESCE(?rawConfidence, "0.80"^^xsd:decimal) AS ?confidence)

  # Default canonical to false if not annotated
  BIND(COALESCE(?canonical, false) AS ?canonical)

  # ==========================================================================
  # 2. OPENAPI TYPE INFERENCE -- jsonSchema or inferred from range/language types
  # ==========================================================================
  # Primary: use jsonSchema if available
  # Fallback: infer from XSD range type
  # Secondary fallback: infer from tsType or goType

  BIND(IF(BOUND(?jsonSchema) && ?jsonSchema != "",
         ?jsonSchema,
         IF(?rangeName = "string" || ?rangeName = "anyURI",
            "string",
            IF(?rangeName = "integer",
               "integer",
               IF(?rangeName = "decimal" || ?rangeName = "float" || ?rangeName = "double",
                  "number",
                  IF(?rangeName = "boolean",
                     "boolean",
                     IF(?rangeName = "dateTime" || ?rangeName = "date",
                        "string",
                        COALESCE(?tsType, ?goType, ?rustType, "string"))))))) AS ?openApiType)

  # Format inference for OpenAPI
  BIND(IF(?openApiType = "string" && ?rangeName = "dateTime",
         "date-time",
         IF(?openApiType = "string" && ?rangeName = "date",
            "date",
            IF(?openApiType = "integer" && (?propName = "hasAge" || ?propName = "hasId" || STRSTARTS(?propName, "hasCount")),
               "int32",
               IF(?openApiType = "number",
                  "double",
                  "")))) AS ?openApiFormat)

  # Required inference: explicit annotation or naming convention
  # Properties starting with "has" and having a non-optional type are required,
  # unless the range is an entity (object reference) or starts with "hasOptional"
  BIND(IF(BOUND(?rawRequired),
         IF(?rawRequired = true, "true", "false"),
         IF(STRSTARTS(?propName, "hasOptional") || ?rangeName = "Concept",
            "false",
            "true")) AS ?isRequired)

  # Schema description: provenance annotation
  BIND(CONCAT("Auto-generated from ", ?srcName, " ontology") AS ?schemaDesc)

  # Property description: includes range for documentation
  BIND(CONCAT("Property ", ?propName, " (range: ", ?rangeName, ")") AS ?propDesc)

  # Generate stable URIs for schema and property nodes
  BIND(IRI(CONCAT(
    "https://ggen.dev/openapi/schema/", ?entityName
  )) AS ?schemaNode)

  BIND(IRI(CONCAT(
    "https://ggen.dev/openapi/schema/", ?entityName, "/property/", ?propName
  )) AS ?propNode)

  # ==========================================================================
  # 3. ENDPOINT EXTRACTION -- From api: annotated triple terms
  # ==========================================================================
  # Endpoints are annotated via a different triple-term pattern:
  #   << ex:ApiEndpoint ?path ?method >> api:operationId ... ; api:summary ... ;
  OPTIONAL {
    << ?endpointEntity ?endpointProp ?endpointRange >> api:method ?method ;
                                                          api:path ?path ;
                                                          api:operationId ?operationId .

    OPTIONAL { << ?endpointEntity ?endpointProp ?endpointRange >> api:summary ?rawSummary . }
    OPTIONAL { << ?endpointEntity ?endpointProp ?endpointRange >> api:requestBodySchema ?requestBodySchema . }
    OPTIONAL { << ?endpointEntity ?endpointProp ?endpointRange >> api:responseSchema ?responseSchema . }
    OPTIONAL { << ?endpointEntity ?endpointProp ?endpointRange >> api:tags ?tags . }

    BIND(COALESCE(?rawSummary, CONCAT(?method, " ", ?path)) AS ?summary)

    BIND(IRI(CONCAT(
      "https://ggen.dev/openapi/endpoint/",
      COALESCE(?operationId, "unknown")
    )) AS ?endpointNode)
  }

  # ==========================================================================
  # 4. REGISTRY SUMMARY -- Subquery for aggregate stats
  # ==========================================================================
  {
    SELECT ?openapiSummary ?schemaCount ?endpointCount ?propertyCount
    WHERE {
      # Count distinct schemas (entities with canonical mappings)
      {
        SELECT (COUNT(DISTINCT ?e1) AS ?schemaCount) WHERE {
          << ?e1 ?p1 ?r1 >> tr:rustType ?rt1 .
        }
      }

      # Count distinct endpoints
      {
        SELECT (COUNT(DISTINCT ?ep) AS ?endpointCount) WHERE {
          << ?epEnt ?epProp ?epRange >> api:method ?epMethod ; api:path ?epPath .
          BIND(IRI(CONCAT("https://ggen.dev/openapi/endpoint/dummy")) AS ?ep)
        }
      }

      # Count distinct properties
      {
        SELECT (COUNT(DISTINCT ?pr) AS ?propertyCount) WHERE {
          << ?ePr ?pPr ?rPr >> tr:rustType ?rtPr .
          BIND(IRI(CONCAT("https://ggen.dev/openapi/property/dummy")) AS ?pr)
        }
      }

      BIND(IRI("https://ggen.dev/openapi/summary") AS ?openapiSummary)
    }
  }
}
ORDER BY ?entityName ?propName ?srcName
