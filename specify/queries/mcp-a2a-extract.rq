# mcp-a2a-extract.rq — SPARQL-star CONSTRUCT query for MCP + A2A protocol extraction
# A=mu(O): Protocol projections = mu(annotated MCP/A2A ontology triple terms)
#
# Extracts MCP tools (with parameter annotations), A2A agents (with skill annotations),
# and bridge mappings from RDF 1.2 triple terms and projects them as flat triples
# for Tera template consumption.
#
# Usage:
#   sparql --query mcp-a2a-extract.rq \
#          --data mcp-a2a-protocol.ttl \
#          --data mcp-a2a-protocol-example.ttl
#
# CONSTRUCT output is flat (no triple terms) because oxigraph materializes
# triple terms as strings like "<<s p o>>" which cannot be destructured by
# Tera templates consuming Vec<BTreeMap<String, String>>.

PREFIX mcp: <https://ggen.dev/ontology/mcp#>
PREFIX a2a: <https://ggen.dev/ontology/a2a#>
PREFIX bridge: <https://ggen.dev/ontology/bridge#>
PREFIX ex: <https://ggen.dev/examples/mcp-a2a#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

# ============================================================================
# PART 1: MCP TOOL + PARAMETER EXTRACTION
# ============================================================================

# 1a. Extract MCP tools with server context
CONSTRUCT {
  ?extractedTool a mcp:ExtractedTool ;
    mcp:serverName ?serverName ;
    mcp:toolName ?toolName ;
    mcp:toolDescription ?toolDescription .
}
WHERE {
  ?server a mcp:McpsServer ;
    mcp:hasTool ?tool .

  ?tool a mcp:Tool ;
    mcp:toolName ?toolName ;
    mcp:toolDescription ?toolDescription .

  ?server mcp:serverName ?serverName .

  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/extracted/tool/", ENCODE_FOR_URI(?toolName))) AS ?extractedTool)
}
ORDER BY ?serverName ?toolName

# 1b. Extract MCP tool parameters with all triple-term annotations
CONSTRUCT {
  ?extractedParam a mcp:ExtractedToolParameter ;
    mcp:toolName ?toolName ;
    mcp:paramName ?paramName ;
    mcp:paramType ?paramType ;
    mcp:paramDescription ?paramDescription ;
    mcp:rustType ?rustType ;
    mcp:tsType ?tsType ;
    mcp:goType ?goType ;
    mcp:elixirType ?elixirType ;
    mcp:javaType ?javaType ;
    mcp:jsonSchema ?jsonSchema ;
    mcp:required ?required ;
    mcp:defaultValue ?defaultValue ;
    mcp:enumValues ?enumValues ;
    mcp:validation ?validation .
}
WHERE {
  # Match RDF 1.2 triple terms: <<tool hasParameter param>> annotated with mcp:rustType
  << ?tool mcp:hasParameter ?param >> mcp:rustType ?rustType .

  ?tool mcp:toolName ?toolName .

  # At least one type mapping is required (rustType above); others are optional
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:tsType ?tsType . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:goType ?goType . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:elixirType ?elixirType . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:javaType ?javaType . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:jsonSchema ?jsonSchema . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:required ?required . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:defaultValue ?defaultValue . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:enumValues ?enumValues . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:validation ?validation . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:paramName ?paramName . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:paramDescription ?paramDescription . }
  OPTIONAL { << ?tool mcp:hasParameter ?param >> mcp:paramType ?paramType . }

  # Extract local name from param IRI if paramName not annotated
  BIND(COALESCE(?paramName, STRAFTER(STR(?param), "#")) AS ?paramNameResolved)

  # Generate stable URI for the extracted parameter node
  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/extracted/param/", ENCODE_FOR_URI(?toolName), "/", ENCODE_FOR_URI(?paramNameResolved))) AS ?extractedParam)
}
ORDER BY ?toolName ?paramNameResolved

# ============================================================================
# PART 2: A2A AGENT + SKILL EXTRACTION
# ============================================================================

# 2a. Extract A2A agents with card context
CONSTRUCT {
  ?extractedAgent a a2a:ExtractedAgent ;
    a2a:agentName ?agentName ;
    a2a:agentVersion ?agentVersion ;
    a2a:agentDescription ?agentDescription ;
    a2a:agentUrl ?agentUrl ;
    a2a:agentProvider ?agentProvider .
}
WHERE {
  ?agent a a2a:Agent ;
    a2a:agentName ?agentName ;
    a2a:agentDescription ?agentDescription .

  OPTIONAL { ?agent a2a:agentVersion ?agentVersion . }
  OPTIONAL { ?agent a2a:agentUrl ?agentUrl . }
  OPTIONAL {
    ?agent a2a:hasAgentCard ?card .
    ?card a2a:agentProvider ?agentProvider .
  }

  # Defaults for optional fields
  BIND(COALESCE(?agentVersion, "0.0.0") AS ?agentVersionResolved)
  BIND(COALESCE(?agentUrl, "") AS ?agentUrlResolved)
  BIND(COALESCE(?agentProvider, "unknown") AS ?agentProviderResolved)

  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/extracted/agent/", ENCODE_FOR_URI(?agentName))) AS ?extractedAgent)
}
ORDER BY ?agentName

# 2b. Extract A2A skills with all triple-term annotations
CONSTRUCT {
  ?extractedSkill a a2a:ExtractedSkill ;
    a2a:agentName ?agentName ;
    a2a:skillName ?skillName ;
    a2a:skillDescription ?skillDescription ;
    a2a:skillTags ?skillTags ;
    a2a:rustReturnType ?rustReturnType ;
    a2a:tsReturnType ?tsReturnType ;
    a2a:goReturnType ?goReturnType ;
    a2a:elixirReturnType ?elixirReturnType ;
    a2a:javaReturnType ?javaReturnType ;
    a2a:streaming ?streaming ;
    a2a:timeout_ms ?timeout_ms ;
    a2a:retryPolicy ?retryPolicy .
}
WHERE {
  # Match RDF 1.2 triple terms: <<agent hasSkill skill>> annotated with a2a:rustReturnType
  << ?agent a2a:hasSkill ?skill >> a2a:rustReturnType ?rustReturnType .

  ?agent a2a:agentName ?agentName .

  # At least one return type is required (rustReturnType above); others are optional
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:tsReturnType ?tsReturnType . }
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:goReturnType ?goReturnType . }
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:elixirReturnType ?elixirReturnType . }
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:javaReturnType ?javaReturnType . }
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:streaming ?streaming . }
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:timeout_ms ?timeout_ms . }
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:retryPolicy ?retryPolicy . }
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:skillName ?skillName . }
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:skillDescription ?skillDescription . }
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:skillTags ?skillTags . }

  # Extract local name from skill IRI if skillName not annotated
  BIND(COALESCE(?skillName, STRAFTER(STR(?skill), "#")) AS ?skillNameResolved)

  # Defaults
  BIND(COALESCE(?streaming, false) AS ?streamingResolved)
  BIND(COALESCE(?timeout_ms, 30000) AS ?timeoutMsResolved)

  # Generate stable URI for the extracted skill node
  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/extracted/skill/", ENCODE_FOR_URI(?agentName), "/", ENCODE_FOR_URI(?skillNameResolved))) AS ?extractedSkill)
}
ORDER BY ?agentName ?skillNameResolved

# ============================================================================
# PART 3: A2A SKILL INPUT PARAMETER EXTRACTION
# ============================================================================

# 3a. Extract A2A skill input parameters with triple-term annotations
CONSTRUCT {
  ?extractedParam a a2a:ExtractedSkillInputParam ;
    a2a:agentName ?agentName ;
    a2a:skillName ?skillName ;
    a2a:inputParamName ?inputParamName ;
    a2a:inputParamDescription ?inputParamDescription ;
    a2a:inputParamType ?inputParamType ;
    a2a:inputParamRequired ?inputParamRequired ;
    a2a:inputParamDefaultValue ?inputParamDefaultValue ;
    a2a:rustType ?rustType ;
    a2a:tsType ?tsType ;
    a2a:goType ?goType ;
    a2a:elixirType ?elixirType ;
    a2a:javaType ?javaType .
}
WHERE {
  # Match RDF 1.2 triple terms: <<agent hasSkill skill>> annotated with a2a:hasInputParam
  << ?agent a2a:hasSkill ?skill >> a2a:hasInputParam ?param .

  ?agent a2a:agentName ?agentName .

  # Get skill name from triple-term annotation
  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:skillName ?skillName . }
  BIND(COALESCE(?skillName, STRAFTER(STR(?skill), "#")) AS ?skillNameResolved)

  # Get param properties
  OPTIONAL { ?param a2a:inputParamName ?inputParamName . }
  OPTIONAL { ?param a2a:inputParamDescription ?inputParamDescription . }
  OPTIONAL { ?param a2a:inputParamType ?inputParamType . }
  OPTIONAL { ?param a2a:inputParamRequired ?inputParamRequired . }
  OPTIONAL { ?param a2a:inputParamDefaultValue ?inputParamDefaultValue . }

  # Get triple-term type mappings for input params
  # Match <<param inputParamName "name">> annotated with a2a:rustType etc.
  OPTIONAL {
    << ?param a2a:inputParamName ?anyName >> a2a:rustType ?rustType .
  }
  OPTIONAL {
    << ?param a2a:inputParamName ?anyName >> a2a:tsType ?tsType .
  }
  OPTIONAL {
    << ?param a2a:inputParamName ?anyName >> a2a:goType ?goType .
  }
  OPTIONAL {
    << ?param a2a:inputParamName ?anyName >> a2a:elixirType ?elixirType .
  }
  OPTIONAL {
    << ?param a2a:inputParamName ?anyName >> a2a:javaType ?javaType .
  }

  # Defaults
  BIND(COALESCE(?inputParamName, STRAFTER(STR(?param), "#")) AS ?inputParamNameResolved)
  BIND(COALESCE(?inputParamRequired, false) AS ?inputParamRequiredResolved)

  # Generate stable URI for the extracted param node
  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/extracted/skill-param/", ENCODE_FOR_URI(?agentName), "/", ENCODE_FOR_URI(?skillNameResolved), "/", ENCODE_FOR_URI(?inputParamNameResolved))) AS ?extractedParam)
}
ORDER BY ?agentName ?skillNameResolved ?inputParamNameResolved

# ============================================================================
# PART 4: BRIDGE EXTRACTION
# ============================================================================

# 4a. Extract ToolAgentBridge mappings
CONSTRUCT {
  ?extractedBridge a bridge:ExtractedBridge ;
    bridge:bridgeType ?bridgeType ;
    bridge:toolSide ?toolSide ;
    bridge:skillSide ?skillSide ;
    bridge:conversionNote ?conversionNote .
}
WHERE {
  # Match RDF 1.2 triple terms: <<bridge bridgesTool tool>> annotated with bridge:bridgesSkill
  << ?bridge bridge:bridgesTool ?tool >> bridge:bridgesSkill ?skill .

  ?bridge a ?bridgeClass ;
    bridge:bridgeType ?bridgeType .

  OPTIONAL { << ?bridge bridge:bridgesTool ?tool >> bridge:conversionNote ?conversionNote . }
  OPTIONAL { << ?bridge bridge:bridgesTool ?tool >> bridge:toolSide ?toolSide . }
  OPTIONAL { << ?bridge bridge:bridgesTool ?tool >> bridge:skillSide ?skillSide . }

  BIND(COALESCE(?conversionNote, "") AS ?conversionNoteResolved)
  BIND(COALESCE(?toolSide, STRAFTER(STR(?tool), "#")) AS ?toolSideResolved)
  BIND(COALESCE(?skillSide, STRAFTER(STR(?skill), "#")) AS ?skillSideResolved)

  # Generate stable URI
  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/extracted/bridge/", ENCODE_FOR_URI(?toolSideResolved), "-", ENCODE_FOR_URI(?skillSideResolved))) AS ?extractedBridge)
}
ORDER BY ?toolSideResolved ?skillSideResolved

# 4b. Extract SkillToolBridge mappings (reverse direction)
CONSTRUCT {
  ?extractedReverseBridge a bridge:ExtractedBridge ;
    bridge:bridgeType ?bridgeType ;
    bridge:toolSide ?toolSide ;
    bridge:skillSide ?skillSide ;
    bridge:conversionNote ?conversionNote .
}
WHERE {
  # Match RDF 1.2 triple terms: <<bridge bridgesSkill skill>> annotated with bridge:bridgesTool
  << ?bridge bridge:bridgesSkill ?skill >> bridge:bridgesTool ?tool .

  ?bridge a ?bridgeClass ;
    bridge:bridgeType ?bridgeType .

  OPTIONAL { << ?bridge bridge:bridgesSkill ?skill >> bridge:conversionNote ?conversionNote . }
  OPTIONAL { << ?bridge bridge:bridgesSkill ?skill >> bridge:toolSide ?toolSide . }
  OPTIONAL { << ?bridge bridge:bridgesSkill ?skill >> bridge:skillSide ?skillSide . }

  BIND(COALESCE(?conversionNote, "") AS ?conversionNoteResolved)
  BIND(COALESCE(?toolSide, STRAFTER(STR(?tool), "#")) AS ?toolSideResolved)
  BIND(COALESCE(?skillSide, STRAFTER(STR(?skill), "#")) AS ?skillSideResolved)

  # Generate stable URI (reversed to avoid collision with 3a)
  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/extracted/bridge/reverse/", ENCODE_FOR_URI(?skillSideResolved), "-", ENCODE_FOR_URI(?toolSideResolved))) AS ?extractedReverseBridge)
}
ORDER BY ?skillSideResolved ?toolSideResolved

# ============================================================================
# PART 5: SUMMARY SUBQUERIES
# ============================================================================

# 5a. Total MCP tools per server
CONSTRUCT {
  ?toolCountSummary a mcp:ExtractedTool ;
    mcp:serverName ?serverName ;
    mcp:toolName ?toolCountLabel ;
    mcp:toolDescription ?toolCountDesc .
}
WHERE {
  {
    SELECT ?serverName (COUNT(?tool) AS ?toolCount)
    WHERE {
      ?server a mcp:McpsServer ;
        mcp:serverName ?serverName ;
        mcp:hasTool ?tool .
    }
    GROUP BY ?serverName
  }

  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/summary/tools/", ENCODE_FOR_URI(?serverName))) AS ?toolCountSummary)
  BIND(CONCAT("total_tools:", STR(?toolCount)) AS ?toolCountLabel)
  BIND(CONCAT("Total MCP tools for server ", ?serverName, ": ", STR(?toolCount)) AS ?toolCountDesc)
}

# 5b. Total parameters per MCP tool
CONSTRUCT {
  ?paramCountSummary a mcp:ExtractedToolParameter ;
    mcp:toolName ?toolName ;
    mcp:paramName ?paramCountLabel ;
    mcp:paramDescription ?paramCountDesc .
}
WHERE {
  {
    SELECT ?toolName (COUNT(?param) AS ?paramCount)
    WHERE {
      << ?tool mcp:hasParameter ?param >> mcp:rustType ?any .
      ?tool mcp:toolName ?toolName .
    }
    GROUP BY ?toolName
  }

  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/summary/params/", ENCODE_FOR_URI(?toolName))) AS ?paramCountSummary)
  BIND(CONCAT("total_params:", STR(?paramCount)) AS ?paramCountLabel)
  BIND(CONCAT("Total parameters for tool ", ?toolName, ": ", STR(?paramCount)) AS ?paramCountDesc)
}

# 5c. Total A2A skills per agent
CONSTRUCT {
  ?skillCountSummary a a2a:ExtractedSkill ;
    a2a:agentName ?agentName ;
    a2a:skillName ?skillCountLabel ;
    a2a:skillDescription ?skillCountDesc .
}
WHERE {
  {
    SELECT ?agentName (COUNT(?skill) AS ?skillCount)
    WHERE {
      << ?agent a2a:hasSkill ?skill >> a2a:rustReturnType ?any .
      ?agent a2a:agentName ?agentName .
    }
    GROUP BY ?agentName
  }

  BIND(IRI(CONCAT("https://ggen.dev/mcp-a2a/summary/skills/", ENCODE_FOR_URI(?agentName))) AS ?skillCountSummary)
  BIND(CONCAT("total_skills:", STR(?skillCount)) AS ?skillCountLabel)
  BIND(CONCAT("Total skills for agent ", ?agentName, ": ", STR(?skillCount)) AS ?skillCountDesc)
}

# 5d. Grand totals
CONSTRUCT {
  ?grandTotal a bridge:ExtractedBridge ;
    bridge:bridgeType "summary" ;
    bridge:toolSide ?totalToolsLabel ;
    bridge:skillSide ?totalSkillsLabel ;
    bridge:conversionNote ?grandTotalDesc .
}
WHERE {
  {
    SELECT
      (COUNT(DISTINCT ?t1) AS ?totalTools)
      (COUNT(DISTINCT ?s1) AS ?totalSkills)
      (COUNT(DISTINCT ?b1) AS ?totalBridges)
    WHERE {
      OPTIONAL { ?anyServer mcp:hasTool ?t1 . ?t1 a mcp:Tool . }
      OPTIONAL { << ?anyAgent a2a:hasSkill ?s1 >> a2a:rustReturnType ?any . }
      OPTIONAL { << ?b1 bridge:bridgesTool ?anyT >> bridge:bridgesSkill ?anyS . }
    }
  }

  BIND(IRI("https://ggen.dev/mcp-a2a/summary/grand-total") AS ?grandTotal)
  BIND(CONCAT("total_mcp_tools:", STR(?totalTools)) AS ?totalToolsLabel)
  BIND(CONCAT("total_a2a_skills:", STR(?totalSkills)) AS ?totalSkillsLabel)
  BIND(CONCAT("Grand totals: ", STR(?totalTools), " MCP tools, ", STR(?totalSkills), " A2A skills, ", STR(?totalBridges), " bridges") AS ?grandTotalDesc)
}
