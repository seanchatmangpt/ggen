# ontology-explorer-extract.rq — SPARQL-star CONSTRUCT query for Ontology Explorer Dashboard
# A=mu(O): Dashboard profiles = mu(annotated ontology triple terms)
#
# Extracts ontology explorer annotations from RDF 1.2 triple terms and projects
# them as flat triples for Tera template consumption.
#
# Also detects elements WITHOUT annotations (missing coverage) by comparing
# annotated elements against all ontology elements.
#
# Usage:
#   sparql --query ontology-explorer-extract.rq \
#          --data ontology-explorer.ttl \
#          --data ontology-explorer-example.ttl \
#          --data dod-ontology.ttl
#
# CONSTRUCT output is flat (no triple terms) because oxigraph materializes
# triple terms as strings like "<<s p o>>" which cannot be destructured by
# Tera templates consuming Vec<BTreeMap<String, String>>.

PREFIX exp: <https://ggen.dev/ontology/explorer#>
PREFIX dod: <http://ggen.chatmangpt.com/dod#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

CONSTRUCT {
  # ---------------------------------------------------------------
  # PROFILE: Annotated elements (those WITH explorer annotations)
  # ---------------------------------------------------------------
  ?profile a ?profileClass ;
    exp:elementName ?elementName ;
    exp:elementIri ?elementIri ;
    exp:elementType ?elementType ;
    exp:widgetType ?widgetType ;
    exp:section ?section ;
    exp:order ?order ;
    exp:tooltip ?tooltip ;
    exp:icon ?icon ;
    exp:importance ?importance ;
    exp:status ?status ;
    exp:crossRefTarget ?extOntology ;
    exp:crossRefCount ?refCount .

  # ---------------------------------------------------------------
  # PROFILE: Missing elements (those WITHOUT explorer annotations)
  # ---------------------------------------------------------------
  ?missingProfile a ?missingProfileClass ;
    exp:elementName ?missingName ;
    exp:elementIri ?missingIri ;
    exp:elementType ?missingType ;
    exp:widgetType "none" ;
    exp:section ?missingSection ;
    exp:order 999 ;
    exp:tooltip "" ;
    exp:icon "?" ;
    exp:importance "unknown" ;
    exp:status "missing" .

  # ---------------------------------------------------------------
  # SUMMARY: Ontology-level statistics
  # ---------------------------------------------------------------
  ?ontologyProfile a exp:OntologyProfile ;
    exp:ontologyUri ?ontologyUri ;
    exp:ontologyLabel ?ontologyLabel ;
    exp:totalClasses ?totalClasses ;
    exp:totalProperties ?totalProperties ;
    exp:totalAnnotations ?totalAnnotationProps ;
    exp:overallCoverage ?overallCoverage .

  # ---------------------------------------------------------------
  # COVERAGE: Per-category breakdown
  # ---------------------------------------------------------------
  ?classCoverage a exp:CoverageReport ;
    exp:elementName "Classes" ;
    exp:elementType "class" ;
    exp:totalElements ?totalClasses ;
    exp:annotatedElements ?annotatedClasses ;
    exp:overallCoverage ?classCoveragePct .

  ?objPropCoverage a exp:CoverageReport ;
    exp:elementName "Object Properties" ;
    exp:elementType "objectProperty" ;
    exp:totalElements ?totalObjProps ;
    exp:annotatedElements ?annotatedObjProps ;
    exp:overallCoverage ?objPropCoveragePct .

  ?dtPropCoverage a exp:CoverageReport ;
    exp:elementName "Datatype Properties" ;
    exp:elementType "datatypeProperty" ;
    exp:totalElements ?totalDtProps ;
    exp:annotatedElements ?annotatedDtProps ;
    exp:overallCoverage ?dtPropCoveragePct .

  # ---------------------------------------------------------------
  # CROSS-REFERENCES: External ontology references
  # ---------------------------------------------------------------
  ?xref a exp:CrossReference ;
    exp:elementName ?extOntName ;
    exp:crossRefTarget ?extOntIri ;
    exp:crossRefCount ?xrefCount .
}
WHERE {
  # ---------------------------------------------------------------
  # PART 1: Annotated elements (have exp:widgetType annotation)
  # ---------------------------------------------------------------
  {
    # --- Classes with annotations ---
    << ?cls rdf:type owl:Class >> exp:widgetType ?widgetType .
    << ?cls rdf:type owl:Class >> exp:displaySection ?section .
    OPTIONAL { << ?cls rdf:type owl:Class >> exp:displayOrder ?order . }
    OPTIONAL { << ?cls rdf:type owl:Class >> exp:tooltip ?tooltip . }
    OPTIONAL { << ?cls rdf:type owl:Class >> exp:icon ?icon . }
    OPTIONAL { << ?cls rdf:type owl:Class >> exp:importance ?importance . }
    OPTIONAL { << ?cls rdf:type owl:Class >> exp:annotationStatus ?status . }
    OPTIONAL { << ?cls rdf:type owl:Class >> exp:externalOntology ?extOntology . }
    OPTIONAL { << ?cls rdf:type owl:Class >> exp:referenceCount ?refCount . }

    BIND(STRAFTER(STR(?cls), "#") AS ?elementName)
    BIND(STR(?cls) AS ?elementIri)
    BIND("class" AS ?elementType)
    BIND(exp:ClassProfile AS ?profileClass)
    BIND(IRI(CONCAT("https://ggen.dev/explorer/profile/class/", ?elementName)) AS ?profile)
  }
  UNION
  {
    # --- Object properties with annotations ---
    << ?prop rdf:type owl:ObjectProperty >> exp:widgetType ?widgetType .
    << ?prop rdf:type owl:ObjectProperty >> exp:displaySection ?section .
    OPTIONAL { << ?prop rdf:type owl:ObjectProperty >> exp:displayOrder ?order . }
    OPTIONAL { << ?prop rdf:type owl:ObjectProperty >> exp:tooltip ?tooltip . }
    OPTIONAL { << ?prop rdf:type owl:ObjectProperty >> exp:icon ?icon . }
    OPTIONAL { << ?prop rdf:type owl:ObjectProperty >> exp:importance ?importance . }
    OPTIONAL { << ?prop rdf:type owl:ObjectProperty >> exp:annotationStatus ?status . }
    OPTIONAL { << ?prop rdf:type owl:ObjectProperty >> exp:externalOntology ?extOntology . }
    OPTIONAL { << ?prop rdf:type owl:ObjectProperty >> exp:referenceCount ?refCount . }

    BIND(STRAFTER(STR(?prop), "#") AS ?elementName)
    BIND(STR(?prop) AS ?elementIri)
    BIND("objectProperty" AS ?elementType)
    BIND(exp:PropertyProfile AS ?profileClass)
    BIND(IRI(CONCAT("https://ggen.dev/explorer/profile/prop/", ?elementName)) AS ?profile)
  }
  UNION
  {
    # --- Datatype properties with annotations ---
    << ?prop rdf:type owl:DatatypeProperty >> exp:widgetType ?widgetType .
    << ?prop rdf:type owl:DatatypeProperty >> exp:displaySection ?section .
    OPTIONAL { << ?prop rdf:type owl:DatatypeProperty >> exp:displayOrder ?order . }
    OPTIONAL { << ?prop rdf:type owl:DatatypeProperty >> exp:tooltip ?tooltip . }
    OPTIONAL { << ?prop rdf:type owl:DatatypeProperty >> exp:icon ?icon . }
    OPTIONAL { << ?prop rdf:type owl:DatatypeProperty >> exp:importance ?importance . }
    OPTIONAL { << ?prop rdf:type owl:DatatypeProperty >> exp:annotationStatus ?status . }
    OPTIONAL { << ?prop rdf:type owl:DatatypeProperty >> exp:externalOntology ?extOntology . }
    OPTIONAL { << ?prop rdf:type owl:DatatypeProperty >> exp:referenceCount ?refCount . }

    BIND(STRAFTER(STR(?prop), "#") AS ?elementName)
    BIND(STR(?prop) AS ?elementIri)
    BIND("datatypeProperty" AS ?elementType)
    BIND(exp:PropertyProfile AS ?profileClass)
    BIND(IRI(CONCAT("https://ggen.dev/explorer/profile/prop/", ?elementName)) AS ?profile)
  }

  # ---------------------------------------------------------------
  # PART 2: Missing elements (no exp:widgetType annotation)
  # ---------------------------------------------------------------
  UNION
  {
    # --- Classes without annotations ---
    ?missingCls a owl:Class .
    FILTER NOT EXISTS { << ?missingCls rdf:type owl:Class >> exp:widgetType ?_wt . }
    FILTER(!ISBLANK(?missingCls))

    BIND(STRAFTER(STR(?missingCls), "#") AS ?missingName)
    BIND(STR(?missingCls) AS ?missingIri)
    BIND("class" AS ?missingType)
    BIND("classes" AS ?missingSection)
    BIND(exp:ClassProfile AS ?missingProfileClass)
    BIND(IRI(CONCAT("https://ggen.dev/explorer/profile/missing/class/", ?missingName)) AS ?missingProfile)
  }
  UNION
  {
    # --- Object properties without annotations ---
    ?missingProp a owl:ObjectProperty .
    FILTER NOT EXISTS { << ?missingProp rdf:type owl:ObjectProperty >> exp:widgetType ?_wt . }
    FILTER(!ISBLANK(?missingProp))

    BIND(STRAFTER(STR(?missingProp), "#") AS ?missingName)
    BIND(STR(?missingProp) AS ?missingIri)
    BIND("objectProperty" AS ?missingType)
    BIND("properties" AS ?missingSection)
    BIND(exp:PropertyProfile AS ?missingProfileClass)
    BIND(IRI(CONCAT("https://ggen.dev/explorer/profile/missing/prop/", ?missingName)) AS ?missingProfile)
  }
  UNION
  {
    # --- Datatype properties without annotations ---
    ?missingDt a owl:DatatypeProperty .
    FILTER NOT EXISTS { << ?missingDt rdf:type owl:DatatypeProperty >> exp:widgetType ?_wt . }
    FILTER(!ISBLANK(?missingDt))

    BIND(STRAFTER(STR(?missingDt), "#") AS ?missingName)
    BIND(STR(?missingDt) AS ?missingIri)
    BIND("datatypeProperty" AS ?missingType)
    BIND("properties" AS ?missingSection)
    BIND(exp:PropertyProfile AS ?missingProfileClass)
    BIND(IRI(CONCAT("https://ggen.dev/explorer/profile/missing/prop/", ?missingName)) AS ?missingProfile)
  }

  # ---------------------------------------------------------------
  # PART 3: Summary statistics (bind constants for template)
  # ---------------------------------------------------------------
  UNION
  {
    # Total classes
    {
      SELECT (COUNT(DISTINCT ?c) AS ?totalClasses)
      WHERE { ?c a owl:Class . FILTER(!ISBLANK(?c)) }
    }
    # Annotated classes
    {
      SELECT (COUNT(DISTINCT ?ac) AS ?annotatedClasses)
      WHERE { << ?ac rdf:type owl:Class >> exp:widgetType ?_w . }
    }
    # Total object properties
    {
      SELECT (COUNT(DISTINCT ?op) AS ?totalObjProps)
      WHERE { ?op a owl:ObjectProperty . FILTER(!ISBLANK(?op)) }
    }
    # Annotated object properties
    {
      SELECT (COUNT(DISTINCT ?aop) AS ?annotatedObjProps)
      WHERE { << ?aop rdf:type owl:ObjectProperty >> exp:widgetType ?_w . }
    }
    # Total datatype properties
    {
      SELECT (COUNT(DISTINCT ?dp) AS ?totalDtProps)
      WHERE { ?dp a owl:DatatypeProperty . FILTER(!ISBLANK(?dp)) }
    }
    # Annotated datatype properties
    {
      SELECT (COUNT(DISTINCT ?adp) AS ?annotatedDtProps)
      WHERE { << ?adp rdf:type owl:DatatypeProperty >> exp:widgetType ?_w . }
    }
    # Total annotation properties
    {
      SELECT (COUNT(DISTINCT ?ap) AS ?totalAnnotationProps)
      WHERE { ?ap a owl:AnnotationProperty . FILTER(!ISBLANK(?ap)) }
    }

    BIND(IRI("https://ggen.dev/explorer/summary") AS ?ontologyProfile)
    BIND("http://ggen.chatmangpt.com/dod" AS ?ontologyUri)
    BIND("DoD Ontology" AS ?ontologyLabel)

    # Compute per-category coverage percentages
    BIND(IF(?totalClasses > 0, (xsd:integer(?annotatedClasses * 100)) / ?totalClasses, 0) AS ?classCoveragePct)
    BIND(IF(?totalObjProps > 0, (xsd:integer(?annotatedObjProps * 100)) / ?totalObjProps, 0) AS ?objPropCoveragePct)
    BIND(IF(?totalDtProps > 0, (xsd:integer(?annotatedDtProps * 100)) / ?totalDtProps, 0) AS ?dtPropCoveragePct)

    # Overall coverage: annotated / (classes + obj props + dt props)
    BIND(?totalClasses + ?totalObjProps + ?totalDtProps AS ?totalAll)
    BIND(?annotatedClasses + ?annotatedObjProps + ?annotatedDtProps AS ?annotatedAll)
    BIND(IF(?totalAll > 0, (xsd:integer(?annotatedAll * 100)) / ?totalAll, 0) AS ?overallCoverage)

    BIND(IRI("https://ggen.dev/explorer/coverage/classes") AS ?classCoverage)
    BIND(IRI("https://ggen.dev/explorer/coverage/obj-props") AS ?objPropCoverage)
    BIND(IRI("https://ggen.dev/explorer/coverage/dt-props") AS ?dtPropCoverage)
  }

  # ---------------------------------------------------------------
  # PART 4: Cross-references to external ontologies
  # ---------------------------------------------------------------
  UNION
  {
    << ?src rdf:type ?_type >> exp:externalOntology ?extOntIri .
    OPTIONAL { << ?src rdf:type ?_type >> exp:referenceCount ?rc . }

    BIND(COALESCE(?rc, 1) AS ?xrefCount)
    BIND(STRAFTER(STR(?extOntIri), "//") AS ?extOntName)
    BIND(IRI(CONCAT("https://ggen.dev/explorer/xref/", ENCODE_FOR_URI(?extOntIri))) AS ?xref)
  }
}
ORDER BY ?elementType ?order ?elementName
