# conflict-detection.ttl — RDF 1.2 Multi-Ontology Conflict Detection Vocabulary
# A=mu(O) — Conflict reports are projections of ontology annotations through SPARQL CONSTRUCT + Tera
#
# Uses RDF 1.2 triple terms (<<s p o>>) to annotate axioms with provenance from multiple sources.
# When the same axiom receives conflicting annotations from different ontologies,
# triple terms enable detecting and resolving those conflicts.
#
# Pipeline: conflict-detection.ttl + conflict-detection-example.ttl
#        -> conflict-detect-extract.rq (SPARQL-star CONSTRUCT)
#        -> conflict-report.tera (Tera template)
#        -> conflict-report.md (generated artifact)

@prefix cfl: <https://ggen.dev/ontology/conflict#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <https://ggen.dev/examples/conflict#> .

<https://ggen.dev/ontology/conflict>
  a owl:Ontology ;
  owl:imports rdf: rdfs: owl: xsd: ;
  rdfs:label "Multi-Ontology Conflict Detection Vocabulary"@en ;
  rdfs:comment "Vocabulary for detecting and resolving conflicts when multiple ontologies annotate the same axiom with different directives. Uses RDF 1.2 triple terms to attach provenance annotations to axiom triples."@en .

# ============================================================================
# 1. ANNOTATION PROPERTIES — Provenance metadata on triple terms
# ============================================================================

cfl:source
  a owl:AnnotationProperty ;
  rdfs:label "source"@en ;
  rdfs:comment "Which ontology this annotation comes from (e.g., FIBO, SchemaOrg, ChatmanGPT)."@en ;
  rdfs:range owl:Thing .

cfl:rustType
  a owl:AnnotationProperty ;
  rdfs:label "Rust type"@en ;
  rdfs:comment "The Rust type mapping for this axiom from this source ontology."@en ;
  rdfs:range xsd:string .

cfl:goType
  a owl:AnnotationProperty ;
  rdfs:label "Go type"@en ;
  rdfs:comment "The Go type mapping for this axiom from this source ontology."@en ;
  rdfs:range xsd:string .

cfl:confidence
  a owl:AnnotationProperty ;
  rdfs:label "confidence"@en ;
  rdfs:comment "Confidence in this type mapping from 0.0 to 1.0. Higher values indicate stronger evidence or more authoritative source."@en ;
  rdfs:range xsd:decimal .

cfl:deprecated
  a owl:AnnotationProperty ;
  rdfs:label "deprecated"@en ;
  rdfs:comment "Whether this source considers the axiom deprecated. Used to detect deprecated_conflict type."@en ;
  rdfs:range xsd:boolean .

cfl:sinceVersion
  a owl:AnnotationProperty ;
  rdfs:label "since version"@en ;
  rdfs:comment "Version of the source ontology when this mapping was first added."@en ;
  rdfs:range xsd:string .

# ============================================================================
# 2. OBJECT PROPERTIES — Conflict report structure
# ============================================================================

cfl:hasConflict
  a owl:ObjectProperty ;
  rdfs:label "has conflict"@en ;
  rdfs:comment "Links a ConflictReport to a specific detected conflict."@en ;
  rdfs:domain cfl:ConflictReport ;
  rdfs:range cfl:TypeConflict .

cfl:conflictType
  a owl:DatatypeProperty ;
  rdfs:label "conflict type"@en ;
  rdfs:comment "The category of conflict: type_mismatch, cardinality, deprecated_conflict, missing_mapping, naming_conflict."@en ;
  rdfs:domain cfl:TypeConflict ;
  rdfs:range xsd:string .

cfl:entity
  a owl:DatatypeProperty ;
  rdfs:label "entity"@en ;
  rdfs:comment "The subject IRI of the conflicting axiom (the entity being described)."@en ;
  rdfs:domain cfl:TypeConflict ;
  rdfs:range xsd:string .

cfl:property
  a owl:DatatypeProperty ;
  rdfs:label "property"@en ;
  rdfs:comment "The predicate IRI of the conflicting axiom (the property with conflicting mappings)."@en ;
  rdfs:domain cfl:TypeConflict ;
  rdfs:range xsd:string .

cfl:source1
  a owl:DatatypeProperty ;
  rdfs:label "source 1"@en ;
  rdfs:comment "The first (alphabetically lower) source ontology involved in the conflict."@en ;
  rdfs:domain cfl:TypeConflict ;
  rdfs:range xsd:string .

cfl:source2
  a owl:DatatypeProperty ;
  rdfs:label "source 2"@en ;
  rdfs:comment "The second (alphabetically higher) source ontology involved in the conflict."@en ;
  rdfs:domain cfl:TypeConflict ;
  rdfs:range xsd:string .

cfl:source1Type
  a owl:DatatypeProperty ;
  rdfs:label "source 1 type"@en ;
  rdfs:comment "The type mapping from source1 (Rust type, Go type, or other)."@en ;
  rdfs:domain cfl:TypeConflict ;
  rdfs:range xsd:string .

cfl:source2Type
  a owl:DatatypeProperty ;
  rdfs:label "source 2 type"@en ;
  rdfs:comment "The type mapping from source2 (Rust type, Go type, or other)."@en ;
  rdfs:domain cfl:TypeConflict ;
  rdfs:range xsd:string .

cfl:resolutionStrategy
  a owl:DatatypeProperty ;
  rdfs:label "resolution strategy"@en ;
  rdfs:comment "Recommended resolution: first_wins, most_specific, manual, error, merge."@en ;
  rdfs:domain cfl:ConflictResolution ;
  rdfs:range xsd:string .

cfl:resolutionNote
  a owl:DatatypeProperty ;
  rdfs:label "resolution note"@en ;
  rdfs:comment "Human-readable explanation of why this resolution strategy was chosen."@en ;
  rdfs:domain cfl:ConflictResolution ;
  rdfs:range xsd:string .

cfl:severity
  a owl:DatatypeProperty ;
  rdfs:label "severity"@en ;
  rdfs:comment "Severity level of the conflict: critical, high, medium, low."@en ;
  rdfs:domain cfl:TypeConflict ;
  rdfs:range xsd:string .

cfl:autoResolvable
  a owl:DatatypeProperty ;
  rdfs:label "auto resolvable"@en ;
  rdfs:comment "Whether ggen can resolve this conflict automatically without human intervention."@en ;
  rdfs:domain cfl:TypeConflict ;
  rdfs:range xsd:boolean .

# ============================================================================
# 3. CLASSES — Conflict domain model
# ============================================================================

cfl:TypeConflict
  a owl:Class ;
  rdfs:label "Type Conflict"@en ;
  rdfs:comment "A single detected conflict between two source ontologies on the same axiom. Contains the conflicting values, sources, severity, and resolution metadata."@en .

cfl:ConflictReport
  a owl:Class ;
  rdfs:label "Conflict Report"@en ;
  rdfs:comment "A collection of detected conflicts with summary statistics. Serves as the root node for conflict report generation."@en .

cfl:ConflictResolution
  a owl:Class ;
  rdfs:label "Conflict Resolution"@en ;
  rdfs:comment "A recommended resolution for a detected conflict. Includes the strategy, rationale, and whether it can be applied automatically."@en .

# ============================================================================
# 4. EXAMPLE ANNOTATIONS — Demonstrating the triple-term pattern
# ============================================================================
#
# These examples show how multiple ontologies annotate the same axiom
# using RDF 1.2 triple terms. Each <<s p o>> triple is the subject of
# provenance annotations from different sources.
#
# Pattern:
#   << entity property range >> cfl:source   :SourceOntology ;
#                               cfl:rustType "some_type" ;
#                               cfl:confidence "0.9"^^xsd:decimal .
#
# When two sources disagree on rustType for the same <<entity property range>>,
# the CONSTRUCT query detects the conflict and generates a TypeConflict instance.

ex:FIBO
  a owl:NamedIndividual ;
  rdfs:label "FIBO"@en ;
  rdfs:comment "Financial Industry Business Ontology — authoritative source for financial domain types."@en .

ex:SchemaOrg
  a owl:NamedIndividual ;
  rdfs:label "Schema.org"@en ;
  rdfs:comment "Schema.org vocabulary — general-purpose structured data vocabulary."@en .

ex:ChatmanGPT
  a owl:NamedIndividual ;
  rdfs:label "ChatmanGPT"@en ;
  rdfs:comment "ChatmanGPT internal ontology — project-specific extensions and overrides."@en .

# Example: Type mismatch on Amount.hasValue
# FIBO says f32 (precision loss), Schema.org says BigDecimal (exact), ChatmanGPT says f64 (compromise)
<< ex:Amount ex:hasValue xsd:float >> cfl:source ex:FIBO ;
                                     cfl:rustType "f32" ;
                                     cfl:confidence "0.9"^^xsd:decimal ;
                                     cfl:sinceVersion "4.0" .

<< ex:Amount ex:hasValue xsd:decimal >> cfl:source ex:SchemaOrg ;
                                       cfl:rustType "BigDecimal" ;
                                       cfl:confidence "0.95"^^xsd:decimal ;
                                       cfl:sinceVersion "15.0" .

<< ex:Amount ex:hasValue xsd:double >> cfl:source ex:ChatmanGPT ;
                                       cfl:rustType "f64" ;
                                       cfl:confidence "0.85"^^xsd:decimal ;
                                       cfl:sinceVersion "1.0" .
