@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ggen: <https://ggen.dev/ontology/> .
@prefix conv: <https://ggen.dev/ontology/convention/> .
@prefix ex: <https://ggen.dev/ontology/example/> .

# ==============================================================================
# OWL Ontology: Project Conventions for Developer Onboarding
# ==============================================================================

<https://ggen.dev/ontology/convention>
    a owl:Ontology ;
    rdfs:label "Project Convention Ontology" ;
    rdfs:comment "Defines project conventions for automated developer onboarding guide generation." ;
    owl:versionInfo "1.0.0" .

# ==============================================================================
# Classes
# ==============================================================================

conv:Project a owl:Class ;
    rdfs:label "Project" ;
    rdfs:comment "A software project with conventions." .

conv:Convention a owl:Class ;
    rdfs:label "Convention" ;
    rdfs:comment "A project convention or rule." .

conv:Language a owl:Class ;
    rdfs:label "Language" ;
    rdfs:comment "A programming language used in the project." ;
    rdfs:subClassOf conv:Convention .

conv:Framework a owl:Class ;
    rdfs:label "Framework" ;
    rdfs:comment "A framework used in the project." ;
    rdfs:subClassOf conv:Convention .

conv:BuildTool a owl:Class ;
    rdfs:label "Build Tool" ;
    rdfs:comment "A tool for building the project." ;
    rdfs:subClassOf conv:Convention .

conv:TestFramework a owl:Class ;
    rdfs:label "Test Framework" ;
    rdfs:comment "A framework for running tests." ;
    rdfs:subClassOf conv:Convention .

conv:Linter a owl:Class ;
    rdfs:label "Linter" ;
    rdfs:comment "A static analysis tool." ;
    rdfs:subClassOf conv:Convention .

conv:Formatter a owl:Class ;
    rdfs:label "Formatter" ;
    rdfs:comment "A code formatting tool." ;
    rdfs:subClassOf conv:Convention .

conv:EditorConfig a owl:Class ;
    rdfs:label "Editor Configuration" ;
    rdfs:comment "Editor-specific configuration rules." ;
    rdfs:subClassOf conv:Convention .

conv:BuildCommand a owl:Class ;
    rdfs:label "Build Command" ;
    rdfs:comment "A shell command for building." ;
    rdfs:subClassOf conv:Convention .

conv:TestCommand a owl:Class ;
    rdfs:label "Test Command" ;
    rdfs:comment "A shell command for testing." ;
    rdfs:subClassOf conv:Convention .

conv:QuickStartStep a owl:Class ;
    rdfs:label "Quick Start Step" ;
    rdfs:comment "A step in the developer quick-start guide." .

conv:CommonIssue a owl:Class ;
    rdfs:label "Common Issue" ;
    rdfs:comment "A known issue and its resolution." .

# ==============================================================================
# Object Properties
# ==============================================================================

conv:hasLanguage a owl:ObjectProperty ;
    rdfs:label "has language" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:Language .

conv:hasFramework a owl:ObjectProperty ;
    rdfs:label "has framework" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:Framework .

conv:hasBuildTool a owl:ObjectProperty ;
    rdfs:label "has build tool" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:BuildTool .

conv:hasTestFramework a owl:ObjectProperty ;
    rdfs:label "has test framework" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:TestFramework .

conv:hasLinter a owl:ObjectProperty ;
    rdfs:label "has linter" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:Linter .

conv:hasFormatter a owl:ObjectProperty ;
    rdfs:label "has formatter" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:Formatter .

conv:hasEditorConfig a owl:ObjectProperty ;
    rdfs:label "has editor config" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:EditorConfig .

conv:hasBuildCommand a owl:ObjectProperty ;
    rdfs:label "has build command" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:BuildCommand .

conv:hasTestCommand a owl:ObjectProperty ;
    rdfs:label "has test command" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:TestCommand .

conv:hasQuickStartStep a owl:ObjectProperty ;
    rdfs:label "has quick start step" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:QuickStartStep .

conv:hasCommonIssue a owl:ObjectProperty ;
    rdfs:label "has common issue" ;
    rdfs:domain conv:Project ;
    rdfs:range conv:CommonIssue .

conv:appliesToLanguage a owl:ObjectProperty ;
    rdfs:label "applies to language" ;
    rdfs:domain conv:Convention ;
    rdfs:range conv:Language .

# ==============================================================================
# Datatype Properties
# ==============================================================================

conv:projectName a owl:DatatypeProperty ;
    rdfs:label "project name" ;
    rdfs:domain conv:Project ;
    rdfs:range xsd:string .

conv:projectDescription a owl:DatatypeProperty ;
    rdfs:label "project description" ;
    rdfs:domain conv:Project ;
    rdfs:range xsd:string .

conv:repositoryUrl a owl:DatatypeProperty ;
    rdfs:label "repository URL" ;
    rdfs:domain conv:Project ;
    rdfs:range xsd:string .

conv:languageName a owl:DatatypeProperty ;
    rdfs:label "language name" ;
    rdfs:domain conv:Language ;
    rdfs:range xsd:string .

conv:languageVersion a owl:DatatypeProperty ;
    rdfs:label "language version" ;
    rdfs:domain conv:Language ;
    rdfs:range xsd:string .

conv:frameworkName a owl:DatatypeProperty ;
    rdfs:label "framework name" ;
    rdfs:domain conv:Framework ;
    rdfs:range xsd:string .

conv:frameworkVersion a owl:DatatypeProperty ;
    rdfs:label "framework version" ;
    rdfs:domain conv:Framework ;
    rdfs:range xsd:string .

conv:buildToolName a owl:DatatypeProperty ;
    rdfs:label "build tool name" ;
    rdfs:domain conv:BuildTool ;
    rdfs:range xsd:string .

conv:testFrameworkName a owl:DatatypeProperty ;
    rdfs:label "test framework name" ;
    rdfs:domain conv:TestFramework ;
    rdfs:range xsd:string .

conv:linterName a owl:DatatypeProperty ;
    rdfs:label "linter name" ;
    rdfs:domain conv:Linter ;
    rdfs:range xsd:string .

conv:linterCommand a owl:DatatypeProperty ;
    rdfs:label "linter command" ;
    rdfs:domain conv:Linter ;
    rdfs:range xsd:string .

conv:formatterName a owl:DatatypeProperty ;
    rdfs:label "formatter name" ;
    rdfs:domain conv:Formatter ;
    rdfs:range xsd:string .

conv:formatterCommand a owl:DatatypeProperty ;
    rdfs:label "formatter command" ;
    rdfs:domain conv:Formatter ;
    rdfs:range xsd:string .

conv:indentSize a owl:DatatypeProperty ;
    rdfs:label "indent size" ;
    rdfs:domain conv:EditorConfig ;
    rdfs:range xsd:integer .

conv:indentStyle a owl:DatatypeProperty ;
    rdfs:label "indent style" ;
    rdfs:range xsd:string .

conv:maxLineWidth a owl:DatatypeProperty ;
    rdfs:label "max line width" ;
    rdfs:domain conv:EditorConfig ;
    rdfs:range xsd:integer .

conv:charset a owl:DatatypeProperty ;
    rdfs:label "charset" ;
    rdfs:domain conv:EditorConfig ;
    rdfs:range xsd:string .

conv:endOfLine a owl:DatatypeProperty ;
    rdfs:label "end of line" ;
    rdfs:domain conv:EditorConfig ;
    rdfs:range xsd:string .

conv:fileExtension a owl:DatatypeProperty ;
    rdfs:label "file extension" ;
    rdfs:range xsd:string .

conv:commandText a owl:DatatypeProperty ;
    rdfs:label "command text" ;
    rdfs:range xsd:string .

conv:commandDescription a owl:DatatypeProperty ;
    rdfs:label "command description" ;
    rdfs:range xsd:string .

conv:stepOrder a owl:DatatypeProperty ;
    rdfs:label "step order" ;
    rdfs:domain conv:QuickStartStep ;
    rdfs:range xsd:integer .

conv:stepDescription a owl:DatatypeProperty ;
    rdfs:label "step description" ;
    rdfs:domain conv:QuickStartStep ;
    rdfs:range xsd:string .

conv:stepCommand a owl:DatatypeProperty ;
    rdfs:label "step command" ;
    rdfs:domain conv:QuickStartStep ;
    rdfs:range xsd:string .

conv:issueTitle a owl:DatatypeProperty ;
    rdfs:label "issue title" ;
    rdfs:domain conv:CommonIssue ;
    rdfs:range xsd:string .

conv:issueSymptom a owl:DatatypeProperty ;
    rdfs:label "issue symptom" ;
    rdfs:domain conv:CommonIssue ;
    rdfs:range xsd:string .

conv:issueResolution a owl:DatatypeProperty ;
    rdfs:label "issue resolution" ;
    rdfs:domain conv:CommonIssue ;
    rdfs:range xsd:string .

# ==============================================================================
# Instance: ChatmanGPT Workspace (multi-language: Rust + Go + Elixir + TypeScript)
# ==============================================================================

ex:chatmangpt a conv:Project ;
    conv:projectName "ChatmanGPT" ;
    conv:projectDescription "Fortune 500-grade AI systems with AGI-level cross-project connections." ;
    conv:repositoryUrl "https://github.com/seanchatmangpt/chatmangpt" ;
    conv:hasLanguage ex:lang-rust ;
    conv:hasLanguage ex:lang-go ;
    conv:hasLanguage ex:lang-elixir ;
    conv:hasLanguage ex:lang-typescript ;
    conv:hasBuildTool ex:build-cargo ;
    conv:hasBuildTool ex:build-go ;
    conv:hasBuildTool ex:build-mix ;
    conv:hasBuildTool ex:build-npm ;
    conv:hasTestFramework ex:test-cargo ;
    conv:hasTestFramework ex:test-go ;
    conv:hasTestFramework ex:test-exunit ;
    conv:hasTestFramework ex:test-vitest ;
    conv:hasLinter ex:lint-clippy ;
    conv:hasLinter ex:lint-govet ;
    conv:hasLinter ex:lint-credo ;
    conv:hasFormatter ex:fmt-rustfmt ;
    conv:hasFormatter ex:fmt-gofmt ;
    conv:hasFormatter ex:fmt-mixfmt ;
    conv:hasEditorConfig ex:editorconfig-rust ;
    conv:hasEditorConfig ex:editorconfig-go ;
    conv:hasEditorConfig ex:editorconfig-elixir ;
    conv:hasEditorConfig ex:editorconfig-default ;
    conv:hasBuildCommand ex:cmd-cargo-build ;
    conv:hasBuildCommand ex:cmd-go-build ;
    conv:hasBuildCommand ex:cmd-mix-compile ;
    conv:hasTestCommand ex:cmd-cargo-test ;
    conv:hasTestCommand ex:cmd-go-test ;
    conv:hasTestCommand ex:cmd-mix-test ;
    conv:hasQuickStartStep ex:qs-1 ;
    conv:hasQuickStartStep ex:qs-2 ;
    conv:hasQuickStartStep ex:qs-3 ;
    conv:hasQuickStartStep ex:qs-4 ;
    conv:hasCommonIssue ex:issue-rust-compile ;
    conv:hasCommonIssue ex:issue-elixir-otp ;
    conv:hasCommonIssue ex:issue-go-mod .

# Languages

ex:lang-rust a conv:Language ;
    conv:languageName "Rust" ;
    conv:languageVersion "1.85" ;
    conv:fileExtension ".rs" .

ex:lang-go a conv:Language ;
    conv:languageName "Go" ;
    conv:languageVersion "1.24" ;
    conv:fileExtension ".go" .

ex:lang-elixir a conv:Language ;
    conv:languageName "Elixir" ;
    conv:languageVersion "1.17" ;
    conv:fileExtension ".ex" .

ex:lang-typescript a conv:Language ;
    conv:languageName "TypeScript" ;
    conv:languageVersion "5.7" ;
    conv:fileExtension ".ts" .

# Build Tools

ex:build-cargo a conv:BuildTool ;
    conv:buildToolName "Cargo" ;
    conv:appliesToLanguage ex:lang-rust .

ex:build-go a conv:BuildTool ;
    conv:buildToolName "Go" ;
    conv:appliesToLanguage ex:lang-go .

ex:build-mix a conv:BuildTool ;
    conv:buildToolName "Mix" ;
    conv:appliesToLanguage ex:lang-elixir .

ex:build-npm a conv:BuildTool ;
    conv:buildToolName "npm" ;
    conv:appliesToLanguage ex:lang-typescript .

# Test Frameworks

ex:test-cargo a conv:TestFramework ;
    conv:testFrameworkName "cargo test" ;
    conv:appliesToLanguage ex:lang-rust .

ex:test-go a conv:TestFramework ;
    conv:testFrameworkName "go test" ;
    conv:appliesToLanguage ex:lang-go .

ex:test-exunit a conv:TestFramework ;
    conv:testFrameworkName "ExUnit" ;
    conv:appliesToLanguage ex:lang-elixir .

ex:test-vitest a conv:TestFramework ;
    conv:testFrameworkName "Vitest" ;
    conv:appliesToLanguage ex:lang-typescript .

# Linters

ex:lint-clippy a conv:Linter ;
    conv:linterName "Clippy" ;
    conv:linterCommand "cargo clippy -- -D warnings" ;
    conv:appliesToLanguage ex:lang-rust .

ex:lint-govet a conv:Linter ;
    conv:linterName "go vet" ;
    conv:linterCommand "go vet ./..." ;
    conv:appliesToLanguage ex:lang-go .

ex:lint-credo a conv:Linter ;
    conv:linterName "Credo" ;
    conv:linterCommand "mix credo" ;
    conv:appliesToLanguage ex:lang-elixir .

# Formatters

ex:fmt-rustfmt a conv:Formatter ;
    conv:formatterName "rustfmt" ;
    conv:formatterCommand "cargo fmt" ;
    conv:appliesToLanguage ex:lang-rust .

ex:fmt-gofmt a conv:Formatter ;
    conv:formatterName "gofmt" ;
    conv:formatterCommand "gofmt -w ." ;
    conv:appliesToLanguage ex:lang-go .

ex:fmt-mixfmt a conv:Formatter ;
    conv:formatterName "mix format" ;
    conv:formatterCommand "mix format" ;
    conv:appliesToLanguage ex:lang-elixir .

# Editor Configs

ex:editorconfig-rust a conv:EditorConfig ;
    conv:indentSize 4 ;
    conv:indentStyle "space" ;
    conv:maxLineWidth 100 ;
    conv:charset "utf-8" ;
    conv:endOfLine "lf" ;
    conv:appliesToLanguage ex:lang-rust .

ex:editorconfig-go a conv:EditorConfig ;
    conv:indentSize 4 ;
    conv:indentStyle "tab" ;
    conv:maxLineWidth 120 ;
    conv:charset "utf-8" ;
    conv:endOfLine "lf" ;
    conv:appliesToLanguage ex:lang-go .

ex:editorconfig-elixir a conv:EditorConfig ;
    conv:indentSize 2 ;
    conv:indentStyle "space" ;
    conv:maxLineWidth 98 ;
    conv:charset "utf-8" ;
    conv:endOfLine "lf" ;
    conv:appliesToLanguage ex:lang-elixir .

ex:editorconfig-default a conv:EditorConfig ;
    conv:indentSize 2 ;
    conv:indentStyle "space" ;
    conv:maxLineWidth 120 ;
    conv:charset "utf-8" ;
    conv:endOfLine "lf" .

# Build Commands

ex:cmd-cargo-build a conv:BuildCommand ;
    conv:commandText "cargo build" ;
    conv:commandDescription "Build the Rust workspace" ;
    conv:appliesToLanguage ex:lang-rust .

ex:cmd-go-build a conv:BuildCommand ;
    conv:commandText "go build ./..." ;
    conv:commandDescription "Build all Go packages" ;
    conv:appliesToLanguage ex:lang-go .

ex:cmd-mix-compile a conv:BuildCommand ;
    conv:commandText "mix compile --warnings-as-errors" ;
    conv:commandDescription "Compile Elixir with warnings treated as errors" ;
    conv:appliesToLanguage ex:lang-elixir .

# Test Commands

ex:cmd-cargo-test a conv:TestCommand ;
    conv:commandText "cargo test" ;
    conv:commandDescription "Run all Rust tests" ;
    conv:appliesToLanguage ex:lang-rust .

ex:cmd-go-test a conv:TestCommand ;
    conv:commandText "go test ./..." ;
    conv:commandDescription "Run all Go tests" ;
    conv:appliesToLanguage ex:lang-go .

ex:cmd-mix-test a conv:TestCommand ;
    conv:commandText "mix test" ;
    conv:commandDescription "Run all Elixir tests" ;
    conv:appliesToLanguage ex:lang-elixir .

# Quick Start Steps

ex:qs-1 a conv:QuickStartStep ;
    conv:stepOrder 1 ;
    conv:stepDescription "Clone the repository" ;
    conv:stepCommand "git clone https://github.com/seanchatmangpt/chatmangpt.git && cd chatmangpt" .

ex:qs-2 a conv:QuickStartStep ;
    conv:stepOrder 2 ;
    conv:stepDescription "Install Rust toolchain (if working on pm4py-rust)" ;
    conv:stepCommand "rustup toolchain install stable && rustup default stable" .

ex:qs-3 a conv:QuickStartStep ;
    conv:stepOrder 3 ;
    conv:stepDescription "Install Elixir (if working on OSA or Canopy)" ;
    conv:stepCommand "brew install elixir" .

ex:qs-4 a conv:QuickStartStep ;
    conv:stepOrder 4 ;
    conv:stepDescription "Verify all projects build" ;
    conv:stepCommand "cd pm4py-rust && cargo build && cd ../OSA && mix compile --warnings-as-errors" .

# Common Issues

ex:issue-rust-compile a conv:CommonIssue ;
    conv:issueTitle "Rust compilation fails with missing feature" ;
    conv:issueSymptom "error[E0432]: unresolved import" ;
    conv:issueResolution "Run `cargo build` from the workspace root, not a subdirectory. Check Cargo.toml feature flags." .

ex:issue-elixir-otp a conv:CommonIssue ;
    conv:issueTitle "Elixir tests fail in --no-start mode" ;
    conv:issueSymptom "** (ArgumentError) could not fetch ETS table" ;
    conv:issueResolution "Run `mix test` without `--no-start` for tests that depend on OTP applications. Tag with `@moduletag :integration`." .

ex:issue-go-mod a conv:CommonIssue ;
    conv:issueTitle "Go module checksum mismatch" ;
    conv:issueSymptom "go: module ... found, but does not contain package" ;
    conv:issueResolution "Run `go mod tidy && go mod download`. Check go.mod replace directives." .
