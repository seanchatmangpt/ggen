# ============================================================================
# 10. ORGANIZATION -- hasMember (FOAF)
# ============================================================================

<< ex:Organization ex:hasMember ex:Person >> tr:sourceOntology <http://xmlns.com/foaf/0.1/> ;
                                              tr:sourceOntologyName "FOAF" ;
                                              tr:rustType "Vec<Person>" ;
                                              tr:goType "[]Person" ;
                                              tr:elixirType "[Person.t]" ;
                                              tr:tsType "Person[]" ;
                                              tr:pythonType "List[Person]" ;
                                              tr:confidence "0.90"^^xsd:decimal ;
                                              tr:isCanonical true ;
                                              tr:jsonSchema "array" ;
                                              tr:sinceVersion "1.1" .

# ============================================================================
# 11. ACTIVITY -- wasGeneratedBy (PROV-O)
# ============================================================================

<< ex:Activity ex:wasGeneratedBy ex:Entity >> tr:sourceOntology <https://www.w3.org/ns/prov#> ;
                                                tr:sourceOntologyName "PROV-O" ;
                                                tr:rustType "Entity" ;
                                                tr:goType "Entity" ;
                                                tr:elixirType "Entity.t" ;
