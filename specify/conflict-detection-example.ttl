# conflict-detection-example.ttl — Instance data for multi-ontology conflict detection
# Contains 5 conflicts of different types between FIBO, SchemaOrg, and ChatmanGPT ontologies.
#
# This file is loaded alongside conflict-detection.ttl as input data for
# the conflict-detect-extract.rq SPARQL-star CONSTRUCT query.

@prefix cfl: <https://ggen.dev/ontology/conflict#> .
@prefix ex: <https://ggen.dev/examples/conflict#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

# ============================================================================
# 1. SOURCE ONTOLOGY DEFINITIONS
# ============================================================================

ex:FIBO
  a owl:NamedIndividual ;
  rdfs:label "FIBO"@en ;
  rdfs:comment "Financial Industry Business Ontology — authoritative source for financial domain types."@en .

ex:SchemaOrg
  a owl:NamedIndividual ;
  rdfs:label "Schema.org"@en ;
  rdfs:comment "Schema.org vocabulary — general-purpose structured data vocabulary."@en .

ex:ChatmanGPT
  a owl:NamedIndividual ;
  rdfs:label "ChatmanGPT"@en ;
  rdfs:comment "ChatmanGPT internal ontology — project-specific extensions and overrides."@en .

# ============================================================================
# 2. CONFLICT 1: TYPE MISMATCH (critical)
# Amount.hasValue — f32 (FIBO) vs BigDecimal (SchemaOrg) vs f64 (ChatmanGPT)
# Three-way conflict. Precision loss risk if f32 chosen for financial amounts.
# ============================================================================

<< ex:Amount ex:hasValue xsd:float >> cfl:source ex:FIBO ;
                                     cfl:rustType "f32" ;
                                     cfl:goType "float32" ;
                                     cfl:confidence "0.9"^^xsd:decimal ;
                                     cfl:deprecated false ;
                                     cfl:sinceVersion "4.0" .

<< ex:Amount ex:hasValue xsd:decimal >> cfl:source ex:SchemaOrg ;
                                       cfl:rustType "BigDecimal" ;
                                       cfl:goType "decimal.Decimal" ;
                                       cfl:confidence "0.95"^^xsd:decimal ;
                                       cfl:deprecated false ;
                                       cfl:sinceVersion "15.0" .

<< ex:Amount ex:hasValue xsd:double >> cfl:source ex:ChatmanGPT ;
                                       cfl:rustType "f64" ;
                                       cfl:goType "float64" ;
                                       cfl:confidence "0.85"^^xsd:decimal ;
                                       cfl:deprecated false ;
                                       cfl:sinceVersion "1.0" .

# ============================================================================
# 3. CONFLICT 2: DEPRECATED CONFLICT (high)
# CurrencyCode.isA — FIBO says active, SchemaOrg says deprecated
# Risk: generating code for a deprecated entity may produce unmaintainable artifacts.
# ============================================================================

<< ex:CurrencyCode rdf:type ex:CodeElement >> cfl:source ex:FIBO ;
                                               cfl:rustType "String" ;
                                               cfl:goType "string" ;
                                               cfl:confidence "0.9"^^xsd:decimal ;
                                               cfl:deprecated false ;
                                               cfl:sinceVersion "4.0" .

<< ex:CurrencyCode rdf:type ex:CodeElement >> cfl:source ex:SchemaOrg ;
                                               cfl:rustType "String" ;
                                               cfl:goType "string" ;
                                               cfl:confidence "0.7"^^xsd:decimal ;
                                               cfl:deprecated true ;
                                               cfl:sinceVersion "7.0" .

# ============================================================================
# 4. CONFLICT 3: MISSING MAPPING (medium)
# LegalEntity.hasName — exists in FIBO and ChatmanGPT, absent in SchemaOrg
# Risk: code generated from SchemaOrg will lack this property.
# ============================================================================

<< ex:LegalEntity ex:hasName xsd:string >> cfl:source ex:FIBO ;
                                           cfl:rustType "String" ;
                                           cfl:goType "string" ;
                                           cfl:confidence "0.95"^^xsd:decimal ;
                                           cfl:deprecated false ;
                                           cfl:sinceVersion "4.0" .

<< ex:LegalEntity ex:hasName xsd:string >> cfl:source ex:ChatmanGPT ;
                                           cfl:rustType "String" ;
                                           cfl:goType "string" ;
                                           cfl:confidence "0.8"^^xsd:decimal ;
                                           cfl:deprecated false ;
                                           cfl:sinceVersion "1.0" .

# Note: No << ex:LegalEntity ex:hasName ... >> triple term with cfl:source ex:SchemaOrg
# This missing annotation is itself a conflict type detected by the query.

# ============================================================================
# 5. CONFLICT 4: NAMING CONFLICT (low)
# Transaction.hasTimestamp — same concept, different property names across ontologies
# FIBO uses ex:hasTradeTimestamp, ChatmanGPT uses ex:hasTimestamp
# ============================================================================

<< ex:Transaction ex:hasTradeTimestamp xsd:dateTime >> cfl:source ex:FIBO ;
                                                  cfl:rustType "chrono::DateTime<Utc>" ;
                                                  cfl:goType "time.Time" ;
                                                  cfl:confidence "0.95"^^xsd:decimal ;
                                                  cfl:deprecated false ;
                                                  cfl:sinceVersion "4.0" .

<< ex:Transaction ex:hasTimestamp xsd:dateTime >> cfl:source ex:ChatmanGPT ;
                                                cfl:rustType "chrono::DateTime<Utc>" ;
                                                cfl:goType "time.Time" ;
                                                cfl:confidence "0.8"^^xsd:decimal ;
                                                cfl:deprecated false ;
                                                cfl:sinceVersion "1.0" .

# ============================================================================
# 6. CONFLICT 5: CARDINALITY CONFLICT (medium)
# Account.hasOwner — FIBO says 1..1, ChatmanGPT says 0..*
# Different cardinality constraints on the same relationship.
# ============================================================================

<< ex:Account ex:hasOwner ex:LegalEntity >> cfl:source ex:FIBO ;
                                           cfl:rustType "LegalEntity" ;
                                           cfl:goType "*LegalEntity" ;
                                           cfl:confidence "0.95"^^xsd:decimal ;
                                           cfl:deprecated false ;
                                           cfl:sinceVersion "4.0" .

<< ex:Account ex:hasOwner ex:LegalEntity >> cfl:source ex:ChatmanGPT ;
                                           cfl:rustType "Option<LegalEntity>" ;
                                           cfl:goType "[]*LegalEntity" ;
                                           cfl:confidence "0.8"^^xsd:decimal ;
                                           cfl:deprecated false ;
                                           cfl:sinceVersion "1.0" .

# ============================================================================
# 7. CONFLICT REPORT — Aggregation of all detected conflicts
# ============================================================================

ex:ConflictReport-2026-03-29
  a cfl:ConflictReport ;
  rdfs:label "Multi-Ontology Conflict Report 2026-03-29"@en ;
  rdfs:comment "Conflict detection run across FIBO, Schema.org, and ChatmanGPT ontologies."@en ;
  cfl:hasConflict ex:Conflict-amount-type ;
  cfl:hasConflict ex:Conflict-currency-deprecated ;
  cfl:hasConflict ex:Conflict-legalentity-missing ;
  cfl:hasConflict ex:Conflict-timestamp-naming ;
  cfl:hasConflict ex:Conflict-account-cardinality .

# ============================================================================
# 8. CONFLICT INSTANCES WITH RESOLUTIONS
# ============================================================================

# Conflict 1 resolution: Use BigDecimal (most_specific, highest confidence)
ex:Conflict-amount-type
  a cfl:TypeConflict ;
  cfl:conflictType "type_mismatch" ;
  cfl:entity "https://ggen.dev/examples/conflict#Amount" ;
  cfl:property "https://ggen.dev/examples/conflict#hasValue" ;
  cfl:source1 "https://ggen.dev/examples/conflict#FIBO" ;
  cfl:source2 "https://ggen.dev/examples/conflict#SchemaOrg" ;
  cfl:source1Type "f32" ;
  cfl:source2Type "BigDecimal" ;
  cfl:severity "critical" ;
  cfl:autoResolvable true .

ex:Resolution-amount-type
  a cfl:ConflictResolution ;
  cfl:resolutionStrategy "most_specific" ;
  cfl:resolutionNote "Financial amounts require exact precision. BigDecimal (0.95 confidence) wins over f32 (0.90). f64 from ChatmanGPT is a compromise but loses precision vs BigDecimal." .

# Conflict 2 resolution: Manual review required
ex:Conflict-currency-deprecated
  a cfl:TypeConflict ;
  cfl:conflictType "deprecated_conflict" ;
  cfl:entity "https://ggen.dev/examples/conflict#CurrencyCode" ;
  cfl:property "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" ;
  cfl:source1 "https://ggen.dev/examples/conflict#FIBO" ;
  cfl:source2 "https://ggen.dev/examples/conflict#SchemaOrg" ;
  cfl:source1Type "String (active)" ;
  cfl:source2Type "String (deprecated)" ;
  cfl:severity "high" ;
  cfl:autoResolvable false .

ex:Resolution-currency-deprecated
  a cfl:ConflictResolution ;
  cfl:resolutionStrategy "manual" ;
  cfl:resolutionNote "Schema.org deprecated CurrencyCode but FIBO still uses it. Determine if Schema.org replacement (Currency) covers FIBO use cases before deprecating." .

# Conflict 3 resolution: First source wins (FIBO is authoritative)
ex:Conflict-legalentity-missing
  a cfl:TypeConflict ;
  cfl:conflictType "missing_mapping" ;
  cfl:entity "https://ggen.dev/examples/conflict#LegalEntity" ;
  cfl:property "https://ggen.dev/examples/conflict#hasName" ;
  cfl:source1 "https://ggen.dev/examples/conflict#FIBO" ;
  cfl:source2 "https://ggen.dev/examples/conflict#SchemaOrg" ;
  cfl:source1Type "String" ;
  cfl:source2Type "(missing)" ;
  cfl:severity "medium" ;
  cfl:autoResolvable true .

ex:Resolution-legalentity-missing
  a cfl:ConflictResolution ;
  cfl:resolutionStrategy "first_wins" ;
  cfl:resolutionNote "Schema.org has no mapping for LegalEntity.hasName. Use FIBO mapping (String). Schema.org consumers will lack this property." .

# Conflict 4 resolution: Merge with alias
ex:Conflict-timestamp-naming
  a cfl:TypeConflict ;
  cfl:conflictType "naming_conflict" ;
  cfl:entity "https://ggen.dev/examples/conflict#Transaction" ;
  cfl:property "https://ggen.dev/examples/conflict#hasTradeTimestamp" ;
  cfl:source1 "https://ggen.dev/examples/conflict#FIBO" ;
  cfl:source2 "https://ggen.dev/examples/conflict#ChatmanGPT" ;
  cfl:source1Type "chrono::DateTime<Utc> (hasTradeTimestamp)" ;
  cfl:source2Type "chrono::DateTime<Utc> (hasTimestamp)" ;
  cfl:severity "low" ;
  cfl:autoResolvable true .

ex:Resolution-timestamp-naming
  a cfl:ConflictResolution ;
  cfl:resolutionStrategy "merge" ;
  cfl:resolutionNote "Same type, different property names. Generate both with FIBO's hasTradeTimestamp as primary and ChatmanGPT's hasTimestamp as an alias/deprecation." .

# Conflict 5 resolution: Manual — cardinality affects API contract
ex:Conflict-account-cardinality
  a cfl:TypeConflict ;
  cfl:conflictType "cardinality" ;
  cfl:entity "https://ggen.dev/examples/conflict#Account" ;
  cfl:property "https://ggen.dev/examples/conflict#hasOwner" ;
  cfl:source1 "https://ggen.dev/examples/conflict#FIBO" ;
  cfl:source2 "https://ggen.dev/examples/conflict#ChatmanGPT" ;
  cfl:source1Type "LegalEntity (1..1)" ;
  cfl:source2Type "Option<LegalEntity> (0..*)" ;
  cfl:severity "medium" ;
  cfl:autoResolvable false .

ex:Resolution-account-cardinality
  a cfl:ConflictResolution ;
  cfl:resolutionStrategy "manual" ;
  cfl:resolutionNote "FIBO mandates exactly one owner (1..1). ChatmanGPT allows zero or more (0..*). This affects database schema, API validation, and business rules. Requires domain expert decision." .
