# mcp-a2a-protocol.ttl — Unified MCP + A2A Protocol Ontology with RDF 1.2 Triple Terms
# A=mu(O) — Protocol artifacts are projections of annotated ontology axioms through SPARQL CONSTRUCT + Tera
#
# This vocabulary uses RDF 1.2 triple terms (<<s p o>>) to annotate MCP tools and A2A agent skills
# with multi-language type mappings, validation rules, and bridge conversion metadata.
# The annotations live INSIDE the ontology, keeping protocol metadata co-located with domain semantics.
#
# Pipeline: ontology (.ttl) → SPARQL CONSTRUCT (.rq) → Tera template (.tera) → code artifact
#
# Domains:
#   mcp:    — Model Context Protocol (server, tool, resource, prompt, transport, parameter)
#   a2a:    — Agent-to-Agent Protocol (agent, skill, task handler, message, agent card)
#   bridge: — MCP <-> A2A bridge mappings (tool↔agent, skill↔tool)

@prefix mcp: <https://ggen.dev/ontology/mcp#> .
@prefix a2a: <https://ggen.dev/ontology/a2a#> .
@prefix bridge: <https://ggen.dev/ontology/bridge#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================================================
# 1. ONTOLOGY METADATA
# ============================================================================

<https://ggen.dev/ontology/mcp-a2a>
  a owl:Ontology ;
  owl:imports
    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>,
    <http://www.w3.org/2000/01/rdf-schema#>,
    <http://www.w3.org/2002/07/owl#>,
    <http://www.w3.org/2001/XMLSchema#> ;
  rdfs:label "MCP + A2A Protocol Ontology"@en ;
  rdfs:comment "Unified RDF 1.2 vocabulary for annotating MCP servers/tools and A2A agents/skills with multi-language type mappings, validation rules, and bridge conversion metadata using triple terms."@en .

# ============================================================================
# 2. MCP CLASSES
# ============================================================================

mcp:McpsServer
  a owl:Class ;
  rdfs:label "MCP Server"@en ;
  rdfs:comment "A Model Context Protocol server exposing tools, resources, and prompts."@en .

mcp:Tool
  a owl:Class ;
  rdfs:label "MCP Tool"@en ;
  rdfs:comment "A tool exposed by an MCP server with a name, description, and input schema."@en .

mcp:Resource
  a owl:Class ;
  rdfs:label "MCP Resource"@en ;
  rdfs:comment "A resource served by an MCP server with a URI template, name, description, and MIME type."@en .

mcp:Prompt
  a owl:Class ;
  rdfs:label "MCP Prompt"@en ;
  rdfs:comment "A prompt template exposed by an MCP server with a name, description, and arguments."@en .

mcp:Transport
  a owl:Class ;
  rdfs:label "MCP Transport"@en ;
  rdfs:comment "Transport mechanism for an MCP server (stdio, http, sse, websocket)."@en .

mcp:ToolParameter
  a owl:Class ;
  rdfs:label "MCP Tool Parameter"@en ;
  rdfs:comment "An input parameter for an MCP tool with name, type, description, required flag, default value, and enum values."@en .

mcp:ExtractedTool
  a owl:Class ;
  rdfs:label "Extracted MCP Tool"@en ;
  rdfs:comment "A tool extraction result from SPARQL CONSTRUCT containing flattened annotation data."@en .

mcp:ExtractedToolParameter
  a owl:Class ;
  rdfs:label "Extracted MCP Tool Parameter"@en ;
  rdfs:comment "A parameter extraction result from SPARQL CONSTRUCT containing flattened annotation data."@en .

# ============================================================================
# 3. A2A CLASSES
# ============================================================================

a2a:Agent
  a owl:Class ;
  rdfs:label "A2A Agent"@en ;
  rdfs:comment "An Agent-to-Agent protocol agent with a name, description, version, URL, and skills."@en .

a2a:Skill
  a owl:Class ;
  rdfs:label "A2A Skill"@en ;
  rdfs:comment "A capability of an A2A agent with a name, description, input/output schemas, and tags."@en .

a2a:TaskHandler
  a owl:Class ;
  rdfs:label "A2A Task Handler"@en ;
  rdfs:comment "Handles the A2A task lifecycle: submit, cancel, get status, and stream."@en .

a2a:Message
  a owl:Class ;
  rdfs:label "A2A Message"@en ;
  rdfs:comment "A typed A2A message: request, response, event, or stream chunk."@en .

a2a:AgentCard
  a owl:Class ;
  rdfs:label "A2A Agent Card"@en ;
  rdfs:comment "Agent metadata for discovery including name, description, URL, skills, and provider."@en .

a2a:ExtractedAgent
  a owl:Class ;
  rdfs:label "Extracted A2A Agent"@en ;
  rdfs:comment "An agent extraction result from SPARQL CONSTRUCT containing flattened annotation data."@en .

a2a:ExtractedSkill
  a owl:Class ;
  rdfs:label "Extracted A2A Skill"@en ;
  rdfs:comment "A skill extraction result from SPARQL CONSTRUCT containing flattened annotation data."@en .

a2a:SkillInputParam
  a owl:Class ;
  rdfs:label "A2A Skill Input Parameter"@en ;
  rdfs:comment "A parameter accepted by an A2A skill, with multi-language type mappings for code generation."@en .

a2a:ExtractedSkillInputParam
  a owl:Class ;
  rdfs:label "Extracted A2A Skill Input Parameter"@en ;
  rdfs:comment "A skill input parameter extraction result from SPARQL CONSTRUCT containing flattened annotation data."@en .

# ============================================================================
# 4. BRIDGE CLASSES
# ============================================================================

bridge:ToolAgentBridge
  a owl:Class ;
  rdfs:label "Tool-Agent Bridge"@en ;
  rdfs:comment "Maps an MCP tool to an A2A agent skill for cross-protocol invocation."@en .

bridge:SkillToolBridge
  a owl:Class ;
  rdfs:label "Skill-Tool Bridge"@en ;
  rdfs:comment "Maps an A2A skill to an MCP tool for cross-protocol invocation."@en .

bridge:ExtractedBridge
  a owl:Class ;
  rdfs:label "Extracted Bridge"@en ;
  rdfs:comment "A bridge extraction result from SPARQL CONSTRUCT containing flattened annotation data."@en .

# ============================================================================
# 5. MCP ANNOTATION PROPERTIES — Language-Specific Type Mappings
# ============================================================================
# These annotate triple terms << ?tool mcp:hasParameter ?param >> with
# multi-language type information for code generation.

mcp:rustType
  a owl:AnnotationProperty ;
  rdfs:label "Rust type"@en ;
  rdfs:comment "Rust type mapping for an MCP tool parameter (e.g., String, PathBuf, Vec<u8>)."@en ;
  rdfs:range xsd:string .

mcp:tsType
  a owl:AnnotationProperty ;
  rdfs:label "TypeScript type"@en ;
  rdfs:comment "TypeScript type mapping for an MCP tool parameter (e.g., string, number, boolean)."@en ;
  rdfs:range xsd:string .

mcp:goType
  a owl:AnnotationProperty ;
  rdfs:label "Go type"@en ;
  rdfs:comment "Go type mapping for an MCP tool parameter (e.g., string, int, []byte, bool)."@en ;
  rdfs:range xsd:string .

mcp:elixirType
  a owl:AnnotationProperty ;
  rdfs:label "Elixir type"@en ;
  rdfs:comment "Elixir type mapping for an MCP tool parameter (e.g., String.t, integer, boolean, Path.t)."@en ;
  rdfs:range xsd:string .

mcp:javaType
  a owl:AnnotationProperty ;
  rdfs:label "Java type"@en ;
  rdfs:comment "Java type mapping for an MCP tool parameter (e.g., String, int, Path, boolean)."@en ;
  rdfs:range xsd:string .

# ============================================================================
# 6. MCP ANNOTATION PROPERTIES — Schema & Validation
# ============================================================================

mcp:jsonSchema
  a owl:AnnotationProperty ;
  rdfs:label "JSON Schema"@en ;
  rdfs:comment "JSON Schema definition for an MCP tool parameter (as a JSON string)."@en ;
  rdfs:range xsd:string .

mcp:required
  a owl:AnnotationProperty ;
  rdfs:label "required"@en ;
  rdfs:comment "Whether the MCP tool parameter is required (true) or optional (false)."@en ;
  rdfs:range xsd:boolean .

mcp:defaultValue
  a owl:AnnotationProperty ;
  rdfs:label "default value"@en ;
  rdfs:comment "Default value for an MCP tool parameter when omitted."@en ;
  rdfs:range xsd:string .

mcp:enumValues
  a owl:AnnotationProperty ;
  rdfs:label "enum values"@en ;
  rdfs:comment "Comma-separated list of allowed enum values for an MCP tool parameter."@en ;
  rdfs:range xsd:string .

mcp:validation
  a owl:AnnotationProperty ;
  rdfs:label "validation"@en ;
  rdfs:comment "Validation rule name for an MCP tool parameter (e.g., validate_uri, validate_path_exists)."@en ;
  rdfs:range xsd:string .

# ============================================================================
# 7. A2A ANNOTATION PROPERTIES — Return Type Mappings
# ============================================================================
# These annotate triple terms << ?agent a2a:hasSkill ?skill >> with
# multi-language return type information for code generation.

a2a:rustReturnType
  a owl:AnnotationProperty ;
  rdfs:label "Rust return type"@en ;
  rdfs:comment "Rust return type for an A2A skill (e.g., Result<ReviewReport, Error>, serde_json::Value)."@en ;
  rdfs:range xsd:string .

a2a:tsReturnType
  a owl:AnnotationProperty ;
  rdfs:label "TypeScript return type"@en ;
  rdfs:comment "TypeScript return type for an A2A skill (e.g., Promise<ReviewResult>, AsyncIterable<StreamChunk>)."@en ;
  rdfs:range xsd:string .

a2a:goReturnType
  a owl:AnnotationProperty ;
  rdfs:label "Go return type"@en ;
  rdfs:comment "Go return type for an A2A skill (e.g., *ReviewReport, error)."@en ;
  rdfs:range xsd:string .

a2a:elixirReturnType
  a owl:AnnotationProperty ;
  rdfs:label "Elixir return type"@en ;
  rdfs:comment "Elixir return type for an A2A skill (e.g., {:ok, map()}, {:error, term()})."@en ;
  rdfs:range xsd:string .

a2a:javaReturnType
  a owl:AnnotationProperty ;
  rdfs:label "Java return type"@en ;
  rdfs:comment "Java return type for an A2A skill (e.g., CompletableFuture<ReviewResult>)."@en ;
  rdfs:range xsd:string .

# ============================================================================
# 8. A2A ANNOTATION PROPERTIES — Behavioral Metadata
# ============================================================================

a2a:streaming
  a owl:AnnotationProperty ;
  rdfs:label "streaming"@en ;
  rdfs:comment "Whether the A2A skill supports streaming responses (true/false)."@en ;
  rdfs:range xsd:boolean .

a2a:timeout_ms
  a owl:AnnotationProperty ;
  rdfs:label "timeout (ms)"@en ;
  rdfs:comment "Maximum execution timeout in milliseconds for an A2A skill."@en ;
  rdfs:range xsd:integer .

a2a:retryPolicy
  a owl:AnnotationProperty ;
  rdfs:label "retry policy"@en ;
  rdfs:comment "Retry policy for an A2A skill (e.g., none, exponential_backoff, fixed_3)."@en ;
  rdfs:range xsd:string .

# ============================================================================
# 9. BRIDGE ANNOTATION PROPERTIES
# ============================================================================
# These annotate triple terms << ?bridge bridge:bridgesTool ?tool >> with
# conversion metadata for cross-protocol mapping.

bridge:bridgesTool
  a owl:AnnotationProperty ;
  rdfs:label "bridges tool"@en ;
  rdfs:comment "The MCP tool name that this bridge maps from."@en ;
  rdfs:range xsd:string .

bridge:bridgesSkill
  a owl:AnnotationProperty ;
  rdfs:label "bridges skill"@en ;
  rdfs:comment "The A2A skill name that this bridge maps to."@en ;
  rdfs:range xsd:string .

bridge:conversionNote
  a owl:AnnotationProperty ;
  rdfs:label "conversion note"@en ;
  rdfs:comment "Human-readable note about the type conversion or data transformation applied by the bridge."@en ;
  rdfs:range xsd:string .

# ============================================================================
# 10. DATATYPE PROPERTIES — Flat Output (Tera-compatible)
# ============================================================================
# These are used in CONSTRUCT output for Tera template consumption.
# They avoid triple terms in the output graph, producing flat key-value triples.

mcp:serverName a owl:DatatypeProperty ; rdfs:range xsd:string .
mcp:serverVersion a owl:DatatypeProperty ; rdfs:range xsd:string .
mcp:serverDescription a owl:DatatypeProperty ; rdfs:range xsd:string .
mcp:serverTransport a owl:DatatypeProperty ; rdfs:range xsd:string .
mcp:toolName a owl:DatatypeProperty ; rdfs:range xsd:string .
mcp:toolDescription a owl:DatatypeProperty ; rdfs:range xsd:string .
mcp:paramName a owl:DatatypeProperty ; rdfs:range xsd:string .
mcp:paramDescription a owl:DatatypeProperty ; rdfs:range xsd:string .
mcp:paramType a owl:DatatypeProperty ; rdfs:range xsd:string .
mcp:hasTool a owl:ObjectProperty .
mcp:hasParameter a owl:ObjectProperty .
mcp:hasTransport a owl:ObjectProperty .
mcp:hasResource a owl:ObjectProperty .
mcp:hasPrompt a owl:ObjectProperty .

a2a:agentName a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:agentVersion a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:agentDescription a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:agentUrl a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:agentProvider a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:skillName a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:skillDescription a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:skillTags a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:hasSkill a owl:ObjectProperty .
a2a:hasTaskHandler a owl:ObjectProperty .
a2a:hasAgentCard a owl:ObjectProperty .
a2a:hasInputParam a owl:ObjectProperty .
a2a:inputParamName a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:inputParamDescription a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:inputParamType a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:inputParamRequired a owl:DatatypeProperty ; rdfs:range xsd:boolean .
a2a:inputParamDefaultValue a owl:DatatypeProperty ; rdfs:range xsd:string .
a2a:messageType a owl:DatatypeProperty ; rdfs:range xsd:string .

bridge:bridgeType a owl:DatatypeProperty ; rdfs:range xsd:string .
bridge:toolSide a owl:DatatypeProperty ; rdfs:range xsd:string .
bridge:skillSide a owl:DatatypeProperty ; rdfs:range xsd:string .

# ============================================================================
# 11. TRANSPORT INSTANCES
# ============================================================================

mcp:StdioTransport
  a mcp:Transport ;
  rdfs:label "stdio"@en ;
  rdfs:comment "Standard I/O transport for local MCP server communication."@en .

mcp:HttpTransport
  a mcp:Transport ;
  rdfs:label "http"@en ;
  rdfs:comment "HTTP transport for remote MCP server communication."@en .

mcp:SseTransport
  a mcp:Transport ;
  rdfs:label "sse"@en ;
  rdfs:comment "Server-Sent Events transport for streaming MCP server responses."@en .

mcp:WebSocketTransport
  a mcp:Transport ;
  rdfs:label "websocket"@en ;
  rdfs:comment "WebSocket transport for bidirectional MCP server communication."@en .

# ============================================================================
# 12. A2A MESSAGE TYPE INSTANCES
# ============================================================================

a2a:RequestMessage
  a a2a:Message ;
  rdfs:label "Request"@en ;
  rdfs:comment "An A2A request message initiating a task."@en .

a2a:ResponseMessage
  a a2a:Message ;
  rdfs:label "Response"@en ;
  rdfs:comment "An A2A response message completing a task."@en .

a2a:EventMessage
  a a2a:Message ;
  rdfs:label "Event"@en ;
  rdfs:comment "An A2A event message for status updates."@en .

a2a:StreamMessage
  a a2a:Message ;
  rdfs:label "Stream"@en ;
  rdfs:comment "An A2A stream message for partial data delivery."@en .
