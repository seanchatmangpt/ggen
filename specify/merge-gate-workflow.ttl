@prefix mg: <http://ggen.dev/merge-gate#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix wvda: <http://ggen.dev/wvda#> .
@prefix otel: <http://ggen.dev/otel#> .
@prefix weaver: <http://ggen.dev/weaver#> .
@prefix receipt: <http://ggen.dev/receipt#> .

# ─── Ontology Declaration ────────────────────────────────────────────────

<http://ggen.dev/merge-gate-workflow> a owl:Ontology ;
    rdfs:label "Merge Gate Workflow Ontology" ;
    rdfs:comment "Defines the YAWL workflow for enforcing merge gates: test execution, OTEL span verification, weaver schema conformance, cryptographic receipt signing, and merge decision."@en ;
    owl:versionInfo "1.0.0" .

# ─── Task Classes ────────────────────────────────────────────────────────

mg:RunTests a owl:Class ;
    rdfs:subClassOf mg:GateTask ;
    rdfs:label "Run Tests" ;
    rdfs:comment "Execute the full test suite (cargo test / mix test / go test) and verify all tests pass with zero failures."@en ;
    mg:timeoutMs "600000"^^xsd:long ;    # 10 minutes
    mg:gatePriority "1"^^xsd:integer ;
    wvda:hasTimeout "true"^^xsd:boolean ;
    wvda:timeoutFallback "block_and_notify" .

mg:CheckOTELSpans a owl:Class ;
    rdfs:subClassOf mg:GateTask ;
    rdfs:label "Check OTEL Spans" ;
    rdfs:comment "Query Jaeger for OTEL spans matching the claim. Verify service name, span name, status=ok, and required attributes exist."@en ;
    mg:timeoutMs "120000"^^xsd:long ;   # 2 minutes
    mg:gatePriority "2"^^xsd:integer ;
    mg:requiresJaeger "true"^^xsd:boolean ;
    wvda:hasTimeout "true"^^xsd:boolean ;
    wvda:timeoutFallback "block_and_notify" .

mg:WeaverRegistryCheck a owl:Class ;
    rdfs:subClassOf mg:GateTask ;
    rdfs:label "Weaver Registry Check" ;
    rdfs:comment "Run weaver registry check against semconv/model and semconv/policies. Must exit 0 with zero violations."@en ;
    mg:timeoutMs "120000"^^xsd:long ;   # 2 minutes
    mg:gatePriority "3"^^xsd:integer ;
    weaver:modelPath "./semconv/model" ;
    weaver:policyPath "./semconv/policies" ;
    wvda:hasTimeout "true"^^xsd:boolean ;
    wvda:timeoutFallback "block_and_notify" .

mg:SignReceipt a owl:Class ;
    rdfs:subClassOf mg:GateTask ;
    rdfs:label "Sign Cryptographic Receipt" ;
    rdfs:comment "Generate Ed25519 receipt linking the commit hash to the verified gate results. Stores in .ggen/receipts/."@en ;
    mg:timeoutMs "30000"^^xsd:long ;    # 30 seconds
    mg:gatePriority "4"^^xsd:integer ;
    receipt:signingAlgorithm "Ed25519" ;
    receipt:chainPath ".ggen/receipts/chain.json" .

mg:AllowMerge a owl:Class ;
    rdfs:subClassOf mg:TerminalTask ;
    rdfs:label "Allow Merge" ;
    rdfs:comment "All gates passed. Merge is permitted. Generate success report."@en ;
    mg:isSuccessTerminal "true"^^xsd:boolean .

mg:BlockMerge a owl:Class ;
    rdfs:subClassOf mg:TerminalTask ;
    rdfs:label "Block Merge" ;
    rdfs:comment "One or more gates failed. Merge is blocked. Generate failure report with details."@en ;
    mg:isFailureTerminal "true"^^xsd:boolean .

# ─── Flow Control Classes ────────────────────────────────────────────────

mg:GateTask a owl:Class ;
    rdfs:label "Gate Task" ;
    rdfs:comment "A task in the merge gate pipeline that must pass before proceeding."@en .

mg:TerminalTask a owl:Class ;
    rdfs:label "Terminal Task" ;
    rdfs:comment "A task that represents the final state of the workflow (success or failure)."@en .

mg:TimeoutHandler a owl:Class ;
    rdfs:label "Timeout Handler" ;
    rdfs:comment "Exception handler invoked when a gate task exceeds its time budget."@en ;
    mg:defaultAction "block_and_notify" ;
    mg:notificationChannel "github_commit_status" .

mg:FailureHandler a owl:Class ;
    rdfs:label "Failure Handler" ;
    rdfs:comment "Exception handler invoked when a gate task returns a non-zero exit code."@en ;
    mg:defaultAction "block_and_notify" ;
    mg:collectDiagnostics "true"^^xsd:boolean .

# ─── Workflow Definition ─────────────────────────────────────────────────

mg:MergeGateWorkflow a owl:NamedIndividual ;
    rdf:type mg:Workflow ;
    rdfs:label "Merge Gate Workflow" ;
    rdfs:comment "Five-gate sequential merge validation: tests, OTEL, weaver, receipt, decision."@en ;
    mg:hasTask mg:Task_RunTests ;
    mg:hasTask mg:Task_CheckOTELSpans ;
    mg:hasTask mg:Task_WeaverRegistryCheck ;
    mg:hasTask mg:Task_SignReceipt ;
    mg:hasTask mg:Task_AllowMerge ;
    mg:hasTask mg:Task_BlockMerge ;
    mg:hasExceptionHandler mg:TimeoutHandler ;
    mg:hasExceptionHandler mg:FailureHandler .

# ─── Task Instances ──────────────────────────────────────────────────────

mg:Task_RunTests rdf:type mg:RunTests ;
    rdfs:label "T1: Run Tests" ;
    mg:taskId "run-tests" ;
    mg:nextOnPass mg:Task_CheckOTELSpans ;
    mg:nextOnFail mg:Task_BlockMerge ;
    mg:nextOnTimeout mg:Task_BlockMerge .

mg:Task_CheckOTELSpans rdf:type mg:CheckOTELSpans ;
    rdfs:label "T2: Check OTEL Spans" ;
    mg:taskId "check-otel-spans" ;
    mg:nextOnPass mg:Task_WeaverRegistryCheck ;
    mg:nextOnFail mg:Task_BlockMerge ;
    mg:nextOnTimeout mg:Task_BlockMerge .

mg:Task_WeaverRegistryCheck rdf:type mg:WeaverRegistryCheck ;
    rdfs:label "T3: Weaver Registry Check" ;
    mg:taskId "weaver-registry-check" ;
    mg:nextOnPass mg:Task_SignReceipt ;
    mg:nextOnFail mg:Task_BlockMerge ;
    mg:nextOnTimeout mg:Task_BlockMerge .

mg:Task_SignReceipt rdf:type mg:SignReceipt ;
    rdfs:label "T4: Sign Receipt" ;
    mg:taskId "sign-receipt" ;
    mg:nextOnPass mg:Task_AllowMerge ;
    mg:nextOnFail mg:Task_BlockMerge .

mg:Task_AllowMerge rdf:type mg:AllowMerge ;
    rdfs:label "T5: Allow Merge" ;
    mg:taskId "allow-merge" ;
    mg:outputCondition "merge_allowed" .

mg:Task_BlockMerge rdf:type mg:BlockMerge ;
    rdfs:label "T5b: Block Merge" ;
    mg:taskId "block-merge" ;
    mg:outputCondition "merge_blocked" .

# ─── Timeout Definitions (WvdA Soundness) ────────────────────────────────

mg:Timeout_Tests a wvda:TimeoutConstraint ;
    rdfs:label "Test Execution Timeout" ;
    wvda:maxDurationMs "600000"^^xsd:long ;
    wvda:onExceed mg:Task_BlockMerge ;
    wvda:fallbackAction "escalate_to_supervisor" .

mg:Timeout_OTEL a wvda:TimeoutConstraint ;
    rdfs:label "OTEL Check Timeout" ;
    wvda:maxDurationMs "120000"^^xsd:long ;
    wvda:onExceed mg:Task_BlockMerge ;
    wvda:fallbackAction "escalate_to_supervisor" .

mg:Timeout_Weaver a wvda:TimeoutConstraint ;
    rdfs:label "Weaver Check Timeout" ;
    wvda:maxDurationMs "120000"^^xsd:long ;
    wvda:onExceed mg:Task_BlockMerge ;
    wvda:fallbackAction "escalate_to_supervisor" .

mg:Timeout_Receipt a wvda:TimeoutConstraint ;
    rdfs:label "Receipt Signing Timeout" ;
    wvda:maxDurationMs "30000"^^xsd:long ;
    wvda:onExceed mg:Task_AllowMerge ;
    wvda:fallbackAction "warn_and_proceed" ;
    rdfs:comment "Receipt signing is non-blocking: if it times out, allow merge but warn."@en .
