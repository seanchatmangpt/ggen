@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix prv: <https://ggen.dev/ontology/provenance#> .

# ==============================================================================
# OWL Ontology: RDF 1.2 Provenance + Receipt Chain
# ==============================================================================
# A=mu(O) — ArtifactReceipts are projections of ontology triples through
# SPARQL-star CONSTRUCT queries, rendered by Tera templates into receipt reports.
#
# RDF 1.2 triple terms (<<s p o>>) enable annotating which ontology triples
# generated which artifacts. This vocabulary defines the provenance vocabulary
# for the ggen pipeline receipt chain.
#
# Key constraint: CONSTRUCT output is materialized as flat triples
# (Vec<BTreeMap<String, String>>). Triple terms serialize as strings.
# Use triple terms in WHERE patterns, output flat triples in CONSTRUCT.
# ==============================================================================

<https://ggen.dev/ontology/provenance>
    a owl:Ontology ;
    rdfs:label "ggen Provenance Chain Ontology" ;
    rdfs:comment "Vocabulary for artifact provenance using RDF 1.2 triple terms. Tracks which ontology triples generated which code artifacts through the ggen pipeline (ontology -> SPARQL CONSTRUCT -> Tera template -> artifact)." ;
    owl:versionInfo "1.0.0" ;
    owl:imports prov: .

# ==============================================================================
# 1. CLASSES
# ==============================================================================

prv:ArtifactReceipt
    a owl:Class ;
    rdfs:label "Artifact Receipt"@en ;
    rdfs:comment "Immutable proof that an artifact was generated from specific ontology triples at a specific point in time. Contains a cryptographic hash for integrity verification."@en ;
    owl:equivalentClass prov:Entity .

prv:GenerationStep
    a owl:Class ;
    rdfs:label "Generation Step"@en ;
    rdfs:comment "One step in the ggen generation pipeline: ontology ingestion, SPARQL CONSTRUCT extraction, or Tera template rendering. Each step has inputs, outputs, and timing metadata."@en ;
    owl:equivalentClass prov:Activity .

prv:ReceiptChain
    a owl:Class ;
    rdfs:label "Receipt Chain"@en ;
    rdfs:comment "An ordered sequence of ArtifactReceipts forming a tamper-evident chain. Each receipt references the hash of the previous receipt, creating a linked list structure."@en ;
    rdfs:subClassOf prov:Collection .

# ==============================================================================
# 2. ANNOTATION PROPERTIES (metadata on triples via RDF 1.2 triple terms)
# ==============================================================================

prv:generatedInCommit
    a owl:AnnotationProperty ;
    rdfs:label "generated in commit"@en ;
    rdfs:comment "Git commit hash at which this artifact was generated."@en ;
    rdfs:range xsd:string .

prv:generatedBy
    a owl:AnnotationProperty ;
    rdfs:label "generated by"@en ;
    rdfs:comment "Identity of the generator that produced the artifact (e.g., 'ggen v2.0')."@en ;
    rdfs:range xsd:string .

prv:receiptHash
    a owl:AnnotationProperty ;
    rdfs:label "receipt hash"@en ;
    rdfs:comment "SHA-256 hash of the receipt for integrity verification."@en ;
    rdfs:range xsd:string .

prv:templateUsed
    a owl:AnnotationProperty ;
    rdfs:label "template used"@en ;
    rdfs:comment "Filename of the Tera template used to render the artifact."@en ;
    rdfs:range xsd:string .

prv:extractionQuery
    a owl:AnnotationProperty ;
    rdfs:label "extraction query"@en ;
    rdfs:comment "Filename of the SPARQL CONSTRUCT query used to extract data from the ontology."@en ;
    rdfs:range xsd:string .

prv:sourceOntology
    a owl:AnnotationProperty ;
    rdfs:label "source ontology"@en ;
    rdfs:comment "IRI of the source ontology from which data was extracted."@en ;
    rdfs:range xsd:string .

prv:generatedAt
    a owl:AnnotationProperty ;
    rdfs:label "generated at"@en ;
    rdfs:comment "Timestamp when the artifact was generated (ISO 8601)."@en ;
    rdfs:range xsd:dateTime .

prv:artifactPath
    a owl:AnnotationProperty ;
    rdfs:label "artifact path"@en ;
    rdfs:comment "File system path of the generated artifact."@en ;
    rdfs:range xsd:string .

prv:artifactType
    a owl:AnnotationProperty ;
    rdfs:label "artifact type"@en ;
    rdfs:comment "Type of the generated artifact: rust_struct, go_module, elixir_module, test_file, documentation, config, etc."@en ;
    rdfs:range xsd:string .

prv:artifactSize
    a owl:AnnotationProperty ;
    rdfs:label "artifact size"@en ;
    rdfs:comment "Size of the generated artifact in bytes."@en ;
    rdfs:range xsd:integer .

prv:verificationStatus
    a owl:AnnotationProperty ;
    rdfs:label "verification status"@en ;
    rdfs:comment "Whether the artifact was verified after generation: verified, unverified, or failed."@en ;
    rdfs:range xsd:string .

prv:parentReceipt
    a owl:AnnotationProperty ;
    rdfs:label "parent receipt"@en ;
    rdfs:comment "SHA-256 hash of the previous receipt in the chain. The first receipt in a chain has no parent."@en ;
    rdfs:range xsd:string .

# ==============================================================================
# 3. OBJECT PROPERTIES (relationships between class instances)
# ==============================================================================

prv:hasReceipt
    a owl:ObjectProperty ;
    rdfs:label "has receipt"@en ;
    rdfs:comment "Relates a ReceiptChain to one of its ArtifactReceipts."@en ;
    rdfs:domain prv:ReceiptChain ;
    rdfs:range prv:ArtifactReceipt .

prv:hasStep
    a owl:AnnotationProperty ;
    rdfs:label "has step"@en ;
    rdfs:comment "Relates a GenerationStep to its position in the pipeline."@en .

prv:usedEntity
    a owl:ObjectProperty ;
    rdfs:label "used entity"@en ;
    rdfs:comment "Links a GenerationStep to the prov:Entity it consumed (input ontology, template, query)."@en ;
    rdfs:domain prv:GenerationStep ;
    rdfs:range prov:Entity ;
    owl:equivalentProperty prov:used .

prv:generatedArtifact
    a owl:ObjectProperty ;
    rdfs:label "generated artifact"@en ;
    rdfs:comment "Links a GenerationStep to the ArtifactReceipt it produced."@en ;
    rdfs:domain prv:GenerationStep ;
    rdfs:range prv:ArtifactReceipt ;
    owl:equivalentProperty prov:generated .

# ==============================================================================
# 4. DATATYPE PROPERTIES (properties on class instances, not on triples)
# ==============================================================================

prv:sourceEntity
    a owl:DatatypeProperty ;
    rdfs:label "source entity"@en ;
    rdfs:comment "The subject of the source triple that generated this artifact (extracted from triple term)."@en ;
    rdfs:domain prv:ArtifactReceipt ;
    rdfs:range xsd:string .

prv:sourcePredicate
    a owl:DatatypeProperty ;
    rdfs:label "source predicate"@en ;
    rdfs:comment "The predicate of the source triple that generated this artifact (extracted from triple term)."@en ;
    rdfs:domain prv:ArtifactReceipt ;
    rdfs:range xsd:string .

prv:sourceObject
    a owl:DatatypeProperty ;
    rdfs:label "source object"@en ;
    rdfs:comment "The object of the source triple that generated this artifact (extracted from triple term)."@en ;
    rdfs:domain prv:ArtifactReceipt ;
    rdfs:range xsd:string .

prv:sourceTriple
    a owl:DatatypeProperty ;
    rdfs:label "source triple"@en ;
    rdfs:comment "Stringified representation of the source triple term: '<< s p o >>'."@en ;
    rdfs:domain prv:ArtifactReceipt ;
    rdfs:range xsd:string .

prv:chainHead
    a owl:DatatypeProperty ;
    rdfs:label "chain head"@en ;
    rdfs:comment "Hash of the most recent receipt in the chain."@en ;
    rdfs:domain prv:ReceiptChain ;
    rdfs:range xsd:string .

prv:chainLength
    a owl:DatatypeProperty ;
    rdfs:label "chain length"@en ;
    rdfs:comment "Number of receipts in the chain."@en ;
    rdfs:domain prv:ReceiptChain ;
    rdfs:range xsd:integer .

prv:stepOrder
    a owl:DatatypeProperty ;
    rdfs:label "step order"@en ;
    rdfs:comment "Position of this step in the generation pipeline (1-indexed)."@en ;
    rdfs:domain prv:GenerationStep ;
    rdfs:range xsd:integer .

prv:stepName
    a owl:DatatypeProperty ;
    rdfs:label "step name"@en ;
    rdfs:comment "Human-readable name of the generation step."@en ;
    rdfs:domain prv:GenerationStep ;
    rdfs:range xsd:string .

prv:stepDurationMs
    a owl:DatatypeProperty ;
    rdfs:label "step duration ms"@en ;
    rdfs:comment "Duration of the generation step in milliseconds."@en ;
    rdfs:domain prv:GenerationStep ;
    rdfs:range xsd:integer .

# ==============================================================================
# 5. EXAMPLE TRIPLE TERM ANNOTATIONS (pattern demonstration)
# ==============================================================================
# These show how RDF 1.2 triple terms annotate ontology triples with
# provenance metadata. The triple term <<s p o>> is the subject of the
# annotation properties.

# Example 1: A DoD check triple annotated with its generation provenance
# In a real graph, these would reference actual ontology triples.
# << dod:Project dod:hasFeature dod:Feature >>
#     prv:generatedInCommit "a1b2c3d4" ;
#     prv:generatedBy "ggen v2.0" ;
#     prv:templateUsed "dod-checklist.tera" ;
#     prv:extractionQuery "dod-extract.rq" ;
#     prv:receiptHash "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855" ;
#     prv:verificationStatus "verified" .

# Example 2: A code artifact generated from an ontology class definition
# << dod:ArtifactReceipt rdf:type owl:Class >>
#     prv:generatedInCommit "e5f6a7b8" ;
#     prv:generatedBy "ggen v2.0" ;
#     prv:templateUsed "rust-struct.tera" ;
#     prv:extractionQuery "provenance-chain-extract.rq" ;
#     prv:sourceOntology "https://ggen.dev/ontology/provenance" ;
#     prv:generatedAt "2026-03-29T14:30:00Z"^^xsd:dateTime ;
#     prv:artifactPath "src/provenance/receipt.rs" ;
#     prv:artifactType "rust_struct" ;
#     prv:artifactSize 2048 ;
#     prv:receiptHash "cf80cd8aed482d5d1527d7dc72fceff84e6326592848447d2dc0b0e87dfc9a90" ;
#     prv:verificationStatus "verified" .
