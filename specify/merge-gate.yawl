<?xml version="1.0" encoding="UTF-8"?>
<!-- merge-gate.yawl — YAWL 2.0 Merge Gate Workflow Specification -->
<!-- Generated by ggen specify/merge-gate-workflow.ttl -->
<!-- Version: 1.0.0 -->
<specification xmlns="http://www.yawlfoundation.org/yawlschema"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              version="2.0"
              uri="urn:ggen:merge-gate-workflow">

  <meta>
    <creator>ggen</creator>
    <description>Five-gate sequential merge validation workflow enforcing WvdA soundness, OTEL evidence, weaver schema conformance, and cryptographic receipt signing.</description>
    <version>1.0.0</version>
  </meta>

  <name>MergeGateWorkflow</name>
  <documentation>
    This workflow enforces the ChatmanGPT merge gate:
    1. Run all tests (zero failures allowed)
    2. Verify OTEL spans exist in Jaeger (evidence of execution)
    3. Run weaver registry check (schema conformance, exit 0)
    4. Sign cryptographic receipt (Ed25519 hash chain)
    5. Decision: allow merge (all pass) or block merge (any fail)

    All gate tasks have timeout constraints per WvdA soundness.
    Exception handlers route failures to BlockMerge with diagnostics.
  </documentation>

  <!-- ================================================================ -->
  <!-- Root Net Decomposition                                           -->
  <!-- ================================================================ -->
  <decomposition id="MergeGateWorkflow_net" type="WSNet" isRootNet="true">

    <!-- Input: Trigger merge gate evaluation -->
    <inputCondition id="IC_Start">
      <documentation>Workflow entry point. Triggered by CI pipeline or manual merge gate invocation.</documentation>
      <flowsInto>T1_RunTests</flowsInto>
    </inputCondition>

    <!-- ============================================================ -->
    <!-- Gate 1: Run Tests                                            -->
    <!-- ============================================================ -->
    <task id="T1_RunTests">
      <name>Run Tests</name>
      <documentation>
        Execute the full test suite for all projects in the workspace.
        Exit code 0 required. Zero failures allowed. Zero skipped for production code.
        Timeout: 10 minutes (600,000 ms).
      </documentation>
      <split type="XOR" xsi:type="ExclusiveSplitType"/>
      <join type="XOR" xsi:type="ExclusiveJoinType"/>
      <starting>
        <timer>
          <on>
            <some>
              <parameter>duration</parameter>
              <some>
                <parameter>duration</parameter>
                <expression>P600S</expression>
              </some>
            </some>
          </on>
          <exceptionHandler>EH_TestTimeout</exceptionHandler>
        </timer>
      </starting>
      <resourcing>
        <offer>
          <allocator initial="false" />
          <participantSet>
            <participant>ci-runner</participant>
          </participantSet>
        </offer>
      </resourcing>
      <flowsInto condition="tests_pass">T2_CheckOTELSpans</flowsInto>
      <flowsInto condition="tests_fail">T5b_BlockMerge</flowsInto>
    </task>

    <!-- ============================================================ -->
    <!-- Gate 2: Check OTEL Spans                                     -->
    <!-- ============================================================ -->
    <task id="T2_CheckOTELSpans">
      <name>Check OTEL Spans</name>
      <documentation>
        Query Jaeger (http://localhost:16686) for OTEL spans matching the claim.
        Verify: service name, span name, status=ok, required attributes present.
        Timeout: 2 minutes (120,000 ms).
      </documentation>
      <split type="XOR" xsi:type="ExclusiveSplitType"/>
      <join type="XOR" xsi:type="ExclusiveJoinType"/>
      <timer>
        <on>
          <some>
            <parameter>duration</parameter>
            <some>
              <parameter>duration</parameter>
              <expression>P120S</expression>
            </some>
          </some>
        </on>
        <exceptionHandler>EH_OTELTimeout</exceptionHandler>
      </timer>
      <resourcing>
        <offer>
          <allocator initial="false" />
          <participantSet>
            <participant>otel-verifier</participant>
          </participantSet>
        </offer>
      </resourcing>
      <flowsInto condition="spans_found">T3_WeaverRegistryCheck</flowsInto>
      <flowsInto condition="spans_missing">T5b_BlockMerge</flowsInto>
    </task>

    <!-- ============================================================ -->
    <!-- Gate 3: Weaver Registry Check                                -->
    <!-- ============================================================ -->
    <task id="T3_WeaverRegistryCheck">
      <name>Weaver Registry Check</name>
      <documentation>
        Run 'weaver registry check -r ./semconv/model -p ./semconv/policies --quiet'.
        Must exit 0 with zero violations. Validates semconv schema conformance.
        Timeout: 2 minutes (120,000 ms).
      </documentation>
      <split type="XOR" xsi:type="ExclusiveSplitType"/>
      <join type="XOR" xsi:type="ExclusiveJoinType"/>
      <timer>
        <on>
          <some>
            <parameter>duration</parameter>
            <some>
              <parameter>duration</parameter>
              <expression>P120S</expression>
            </some>
          </some>
        </on>
        <exceptionHandler>EH_WeaverTimeout</exceptionHandler>
      </timer>
      <resourcing>
        <offer>
          <allocator initial="false" />
          <participantSet>
            <participant>weaver-verifier</participant>
          </participantSet>
        </offer>
      </resourcing>
      <flowsInto condition="weaver_pass">T4_SignReceipt</flowsInto>
      <flowsInto condition="weaver_fail">T5b_BlockMerge</flowsInto>
    </task>

    <!-- ============================================================ -->
    <!-- Gate 4: Sign Cryptographic Receipt                           -->
    <!-- ============================================================ -->
    <task id="T4_SignReceipt">
      <name>Sign Receipt</name>
      <documentation>
        Generate Ed25519 cryptographic receipt linking commit hash to gate results.
        Append to receipt chain at .ggen/receipts/chain.json.
        Non-blocking timeout: 30 seconds. If timeout, warn but allow merge.
      </documentation>
      <split type="XOR" xsi:type="ExclusiveSplitType"/>
      <join type="XOR" xsi:type="ExclusiveJoinType"/>
      <timer>
        <on>
          <some>
            <parameter>duration</parameter>
            <some>
              <parameter>duration</parameter>
              <expression>P30S</expression>
            </some>
          </some>
        </on>
        <exceptionHandler>EH_ReceiptTimeout</exceptionHandler>
      </timer>
      <resourcing>
        <offer>
          <allocator initial="false" />
          <participantSet>
            <participant>receipt-signer</participant>
          </participantSet>
        </offer>
      </resourcing>
      <flowsInto condition="receipt_signed">T5_AllowMerge</flowsInto>
      <flowsInto condition="receipt_failed">T5_AllowMerge</flowsInto>
    </task>

    <!-- ============================================================ -->
    <!-- Terminal: Allow Merge (all gates passed)                     -->
    <!-- ============================================================ -->
    <task id="T5_AllowMerge">
      <name>Allow Merge</name>
      <documentation>
        All four gates passed. Merge is permitted.
        Generate success report with gate results and receipt chain link.
      </documentation>
      <split type="AND" xsi:type="AndSplitType"/>
      <join type="AND" xsi:type="AndJoinType"/>
      <completing />
      <flowsInto>OC_MergeAllowed</flowsInto>
    </task>

    <!-- ============================================================ -->
    <!-- Terminal: Block Merge (any gate failed)                      -->
    <!-- ============================================================ -->
    <task id="T5b_BlockMerge">
      <name>Block Merge</name>
      <documentation>
        One or more gates failed. Merge is blocked.
        Generate failure report with diagnostic details.
        Notify via GitHub commit status or CI annotation.
      </documentation>
      <split type="AND" xsi:type="AndSplitType"/>
      <join type="AND" xsi:type="AndJoinType"/>
      <completing />
      <flowsInto>OC_MergeBlocked</flowsInto>
    </task>

    <!-- ============================================================ -->
    <!-- Exception Handlers (WvdA Timeout + Failure)                  -->
    <!-- ============================================================ -->
    <task id="EH_TestTimeout">
      <name>Exception: Test Timeout</name>
      <documentation>Tests exceeded 10-minute timeout. Block merge and notify.</documentation>
      <split type="AND" xsi:type="AndSplitType"/>
      <join type="AND" xsi:type="AndJoinType"/>
      <completing />
      <flowsInto>OC_MergeBlocked</flowsInto>
    </task>

    <task id="EH_OTELTimeout">
      <name>Exception: OTEL Timeout</name>
      <documentation>OTEL span check exceeded 2-minute timeout. Block merge and notify.</documentation>
      <split type="AND" xsi:type="AndSplitType"/>
      <join type="AND" xsi:type="AndJoinType"/>
      <completing />
      <flowsInto>OC_MergeBlocked</flowsInto>
    </task>

    <task id="EH_WeaverTimeout">
      <name>Exception: Weaver Timeout</name>
      <documentation>Weaver check exceeded 2-minute timeout. Block merge and notify.</documentation>
      <split type="AND" xsi:type="AndSplitType"/>
      <join type="AND" xsi:type="AndJoinType"/>
      <completing />
      <flowsInto>OC_MergeBlocked</flowsInto>
    </task>

    <task id="EH_ReceiptTimeout">
      <name>Exception: Receipt Timeout</name>
      <documentation>Receipt signing exceeded 30-second timeout. Allow merge (receipt is non-blocking).</documentation>
      <split type="AND" xsi:type="AndSplitType"/>
      <join type="AND" xsi:type="AndJoinType"/>
      <completing />
      <flowsInto>OC_MergeAllowed</flowsInto>
    </task>

    <!-- ============================================================ -->
    <!-- Output Conditions                                            -->
    <!-- ============================================================ -->
    <outputCondition id="OC_MergeAllowed">
      <documentation>Merge is permitted. All gates passed or only receipt timed out (non-blocking).</documentation>
    </outputCondition>

    <outputCondition id="OC_MergeBlocked">
      <documentation>Merge is blocked. One or more critical gates failed or timed out.</documentation>
    </outputCondition>

  </decomposition>

</specification>
