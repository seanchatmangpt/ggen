@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mcpp: <http://mcpp.dev/ontology#> .
@prefix : <http://mcpp.dev/config#> .

# Main marketplace configuration
:marketplace a mcpp:MarketplaceConfig ;
    rdfs:label "mcpp Marketplace Configuration" ;
    rdfs:comment "Main configuration for mcpp template marketplace" ;

    # Registry settings
    mcpp:registryUrl "https://registry.mcpp.dev" ;
    mcpp:fallbackRegistries ( "https://backup1.mcpp.dev" "https://backup2.mcpp.dev" ) ;

    # Local cache settings
    mcpp:cacheDir "~/.mcpp/cache" ;
    mcpp:maxCacheSize "1073741824"^^xsd:integer ;  # 1GB
    mcpp:cacheExpiryDays "30"^^xsd:integer ;

    # Download limits
    mcpp:maxDownloadSize "104857600"^^xsd:integer ;  # 100MB
    mcpp:downloadTimeout "300"^^xsd:integer ;  # 5 minutes
    mcpp:maxConcurrentDownloads "5"^^xsd:integer ;

    # Validation settings
    mcpp:validationEnabled "true"^^xsd:boolean ;
    mcpp:strictValidation "true"^^xsd:boolean ;
    mcpp:validateDependencies "true"^^xsd:boolean ;
    mcpp:allowDeprecated "false"^^xsd:boolean ;
    mcpp:allowYanked "false"^^xsd:boolean ;

    # Update settings
    mcpp:autoUpdateEnabled "false"^^xsd:boolean ;
    mcpp:autoUpdateInterval "86400"^^xsd:integer ;  # 24 hours
    mcpp:updateCheckOnInstall "true"^^xsd:boolean ;

    # Security settings
    mcpp:requireSignatures "true"^^xsd:boolean ;
    mcpp:verifyChecksums "true"^^xsd:boolean ;
    mcpp:tlsVerifyPeer "true"^^xsd:boolean ;

    # Telemetry settings
    mcpp:telemetryEnabled "true"^^xsd:boolean ;
    mcpp:telemetryEndpoint "https://telemetry.mcpp.dev/v1/metrics" ;
    mcpp:reportErrors "true"^^xsd:boolean ;
    mcpp:anonymizeData "true"^^xsd:boolean ;

    # Performance settings
    mcpp:sparqlQueryTimeout "30"^^xsd:integer ;  # 30 seconds
    mcpp:maxMemoryUsage "536870912"^^xsd:integer ;  # 512MB
    mcpp:enableQueryCache "true"^^xsd:boolean ;
    mcpp:queryCacheSize "1000"^^xsd:integer ;

    # FMEA settings
    mcpp:fmeaEnabled "true"^^xsd:boolean ;
    mcpp:autoRecoveryEnabled "true"^^xsd:boolean ;
    mcpp:maxRecoveryAttempts "3"^^xsd:integer ;

    # Logging settings
    mcpp:logLevel "info" ;
    mcpp:logFormat "json" ;
    mcpp:logDir "~/.mcpp/logs" ;

    # References to other configs
    mcpp:hasRegistryConfig :primary-registry, :backup-registry ;
    mcpp:hasValidationRules <validation-rules.ttl> ;
    mcpp:hasStateMachines <state-machines.ttl> .

# Primary registry configuration
:primary-registry a mcpp:RegistryConfig ;
    mcpp:name "Official mcpp Registry" ;
    mcpp:url "https://registry.mcpp.dev" ;
    mcpp:priority "1"^^xsd:integer ;
    mcpp:enabled "true"^^xsd:boolean ;
    mcpp:authRequired "false"^^xsd:boolean ;
    mcpp:syncInterval "3600"^^xsd:integer ;  # 1 hour
    mcpp:publicKey """-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
-----END PUBLIC KEY-----""" .

# Backup registry configuration
:backup-registry a mcpp:RegistryConfig ;
    mcpp:name "Backup Registry" ;
    mcpp:url "https://backup1.mcpp.dev" ;
    mcpp:priority "2"^^xsd:integer ;
    mcpp:enabled "true"^^xsd:boolean ;
    mcpp:authRequired "false"^^xsd:boolean ;
    mcpp:syncInterval "7200"^^xsd:integer .  # 2 hours

# Package categories configuration
:categories a rdf:Bag ;
    rdfs:label "Package Categories" ;
    rdf:_1 :cat-web ;
    rdf:_2 :cat-mobile ;
    rdf:_3 :cat-backend ;
    rdf:_4 :cat-data ;
    rdf:_5 :cat-ml ;
    rdf:_6 :cat-devops .

:cat-web a mcpp:Category ;
    rdfs:label "Web Development" ;
    mcpp:description "Frontend and fullstack web templates" .

:cat-mobile a mcpp:Category ;
    rdfs:label "Mobile Development" ;
    mcpp:description "iOS, Android, and cross-platform mobile templates" .

:cat-backend a mcpp:Category ;
    rdfs:label "Backend Services" ;
    mcpp:description "API, microservices, and backend templates" .

:cat-data a mcpp:Category ;
    rdfs:label "Data & Analytics" ;
    mcpp:description "Data processing, ETL, and analytics templates" .

:cat-ml a mcpp:Category ;
    rdfs:label "Machine Learning" ;
    mcpp:description "ML, AI, and data science templates" .

:cat-devops a mcpp:Category ;
    rdfs:label "DevOps & Infrastructure" ;
    mcpp:description "CI/CD, deployment, and infrastructure templates" .

# Feature flags
:features a rdf:Bag ;
    rdf:_1 [
        mcpp:featureName "experimental-neural-search" ;
        mcpp:enabled "false"^^xsd:boolean ;
        mcpp:description "Neural network-based package search"
    ] ;
    rdf:_2 [
        mcpp:featureName "distributed-cache" ;
        mcpp:enabled "true"^^xsd:boolean ;
        mcpp:description "Distributed RDF cache across nodes"
    ] ;
    rdf:_3 [
        mcpp:featureName "realtime-updates" ;
        mcpp:enabled "true"^^xsd:boolean ;
        mcpp:description "Real-time package update notifications"
    ] .

# Rate limiting configuration
:rate-limits a mcpp:RateLimitConfig ;
    mcpp:searchQueriesPerMinute "60"^^xsd:integer ;
    mcpp:downloadsPerHour "100"^^xsd:integer ;
    mcpp:publishesPerDay "10"^^xsd:integer ;
    mcpp:burstAllowance "10"^^xsd:integer .
