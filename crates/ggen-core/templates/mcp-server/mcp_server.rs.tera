{# MCP server implementation template #}
{# Context variables: server_name, registry_type, io_handler_type #}
{# Extends the base header template #}

{% extends "mcp-server/_head.tera" %}

{% block imports %}
{{ super() }}
use crate::mcp::tool_registry::McpToolRegistry;
use std::sync::Arc;
use tokio::sync::RwLock;
{% endblock imports %}

{% block body %}
/// MCP Server: {{ server_name | default(value="GgenMcpServer") }}
///
/// This server implements the Model Context Protocol (MCP) for
/// tool invocation, resource access, and prompt management.
{% if server_docstring %}
///
/// {{ server_docstring }}
{% endif %}
#[derive(Debug, Clone)]
pub struct {{ server_name | default(value="GgenMcpServer") | pascal }} {
    /// Tool registry for managing available tools
    registry: Arc<RwLock<{{ registry_type | default(value="McpToolRegistry") }>>>,
    /// JSON-RPC I/O handler
    io_handler: Arc<{{ io_handler_type | default(value="IoHandler") }}>,
    /// Server configuration
    config: ServerConfig,
}

/// Server configuration
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ServerConfig {
    /// Server name
    pub name: String,
    /// Server version
    pub version: String,
    /// Maximum concurrent requests
    pub max_concurrent_requests: usize,
    /// Request timeout in seconds
    pub request_timeout_seconds: u64,
}

impl Default for ServerConfig {
    fn default() -> Self {
        Self {
            name: "ggen-mcp-server".to_string(),
            version: env!("CARGO_PKG_VERSION").to_string(),
            max_concurrent_requests: 100,
            request_timeout_seconds: 30,
        }
    }
}

impl {{ server_name | default(value="GgenMcpServer") | pascal }} {
    /// Create a new MCP server instance
    pub fn new() -> Result<Self, {{ error_type | default(value="McpError") }}> {
        Self::with_config(ServerConfig::default())
    }

    /// Create a new MCP server with custom configuration
    pub fn with_config(config: ServerConfig) -> Result<Self, {{ error_type | default(value="McpError") }}> {
        Ok(Self {
            registry: Arc::new(RwLock::new({{ registry_type | default(value="McpToolRegistry") }}::new()?)),
            io_handler: Arc::new({{ io_handler_type | default(value="IoHandler") }}::new()),
            config,
        })
    }

    /// Register a tool with the server
    pub async fn register_tool(&self, tool: {{ tool_type | default(value="Tool") }}) -> Result<(), {{ error_type | default(value="McpError") }}> {
        let mut registry = self.registry.write().await;
        registry.register(tool)?;
        Ok(())
    }

    /// Register a resource with the server
    pub async fn register_resource(&self, resource: {{ resource_type | default(value="Resource") }}) -> Result<(), {{ error_type | default(value="McpError") }}> {
        let mut registry = self.registry.write().await;
        registry.register_resource(resource)?;
        Ok(())
    }

    /// Get the server configuration
    pub fn config(&self) -> &ServerConfig {
        &self.config
    }

    /// Get the tool registry
    pub async fn registry(&self) -> {{ registry_type | default(value="McpToolRegistry") }} {
        self.registry.read().await.clone()
    }
}

{% if enable_default_impl %}
/// Default implementation for convenience
impl Default for {{ server_name | default(value="GgenMcpServer") | pascal }} {
    fn default() -> Self {
        Self::new().expect("Failed to create MCP server")
    }
}
{% endif %}
{% endblock body %}
