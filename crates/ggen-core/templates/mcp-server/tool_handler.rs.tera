{# Tool handler implementation template — rmcp 1.3.0 #}
{# Context variables (per-row): tool_name, tool_description, server_name #}
{# Context variables (all rows): sparql_results (array of all tool+param rows) #}
{#                                                                                       #}
{# ggen pipeline: renders ONCE PER ROW from extract-mcp-full.rq SELECT query.     #}
{# Each row = one tool. sparql_results = array of ALL rows for cross-tool refs.   #}
{#                                                                                       #}
{# CRITICAL FACTS (rmcp 1.3.0):                                                         #}
{#   1. #[tool_router] generates `tool_router()` fn only                                #}
{#   2. #[tool_handler] wires list_tools + call_tool dispatch — REQUIRED on impl ServerHandler #}
{#   3. Without #[tool_handler]: list_tools() → empty, call_tool() → -32601             #}
{#   4. Keep server alive: svc.waiting().await (NOT let _ = serve(...))                 #}

{% extends "mcp-server/_head.tera" %}

{% block imports %}
{{ super() }}
use rmcp::model::{CallToolRequestParams, Content};
use serde_json::Value;
{% endblock imports %}

{% block body %}
{# ── Current tool's param struct ──────────────────────────────────────────── #}
/// Input parameters for `{{ tool_name }}` tool
#[derive(Debug, serde::Deserialize, schemars::JsonSchema)]
pub struct {{ tool_name | pascal_case }}Params {
{%- for row in sparql_results %}
{%- if row.tool_name == tool_name %}
    /// {{ row.param_description | default(value=row.param_name) }}
    pub {{ row.param_name }}: {% if row.is_required == "true" %}{{ row.rust_type | default(value="String") }}{% else %}Option<{{ row.rust_type | default(value="String") }}>{% endif %},
{%- endif %}
{%- endfor %}
}

{# ── Server struct ───────────────────────────────────────────────────────── #}
/// MCP server exposing {{ sparql_results | length }} tool(s)
///
/// Generated by ggen. SDK: rmcp 1.3.0
///
/// # Wire diagram
/// ```
/// #[tool_router]   → generates Self::tool_router()
/// #[tool_handler]  → wires tool_router into ServerHandler::list_tools + call_tool
/// ```
///
/// Both macros are REQUIRED. Missing #[tool_handler] → tools list empty, calls return -32601.
#[derive(Debug, Clone)]
pub struct {{ server_name | default(value="GeneratedMcpServer") | pascal }} {
    tool_router: ToolRouter<Self>,
}

#[tool_router]
impl {{ server_name | default(value="GeneratedMcpServer") | pascal }} {
{% for row in sparql_results %}
    #[tool(description = "{{ row.tool_description | default(value=row.tool_name) }}")]
    async fn {{ row.tool_name | snake_case }}(
        &self,
        #[tool(aggr)] params: {{ row.tool_name | pascal_case }}Params,
    ) -> String {
        // TODO: implement {{ row.tool_name }}
        format!("{{ row.tool_name }}: {:?}", params)
    }

{% endfor %}
}

/// ServerHandler implementation — MUST carry #[tool_handler]
///
/// #[tool_handler] injects:
///   async fn list_tools()  → delegates to self.tool_router.list_tools()
///   async fn call_tool()   → delegates to self.tool_router.call(name, args)
///
/// Without this attribute the default trait impls return empty / -32601.
#[tool_handler]
impl ServerHandler for {{ server_name | default(value="GeneratedMcpServer") | pascal }} {
    fn get_info(&self) -> ServerInfo {
        ServerInfo {
            instructions: Some(
                "{{ server_description | default(value='Generated MCP server') }}".into(),
            ),
            capabilities: ServerCapabilities::builder()
                .enable_tools()
                .build(),
            server_info: Implementation {
                name: "{{ server_name | default(value='generated-mcp-server') }}".into(),
                version: env!("CARGO_PKG_VERSION").into(),
            },
            ..Default::default()
        }
    }
}

impl {{ server_name | default(value="GeneratedMcpServer") | pascal }} {
    pub fn new() -> Self {
        Self {
            tool_router: Self::tool_router(),
        }
    }
}

impl Default for {{ server_name | default(value="GeneratedMcpServer") | pascal }} {
    fn default() -> Self {
        Self::new()
    }
}
{% endblock body %}
