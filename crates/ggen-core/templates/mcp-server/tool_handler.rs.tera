{# Tool handler implementation template #}
{# Context variables: tools (array of Tool objects), error_type #}
{# Each tool has: name, description, input_schema, handler_type #}

{% extends "mcp-server/_head.tera" %}

{% block imports %}
{{ super() }}
use jsonrpc_core::{ErrorCode, Result as RpcResult};
use serde_json::json;
{% endblock imports %}

{% block body %}
{# Generate handler for each tool #}
{% for tool in tools -%}
{%- if tool.description %}
/// Tool handler: {{ tool.name }}
///
/// {{ tool.description }}
{%- else %}
/// Tool handler: {{ tool.name }}
{%- endif %}
{%- if tool.input_schema %}
///
/// # Input Schema
/// ```json
/// {{ tool.input_schema | indent(width=4) }}
/// ```
{%- endif %}
pub async fn {{ tool.name | snake }}_handler(
    params: Params,
    context: &{{ handler_context_type | default(value="HandlerContext") }},
) -> Result<Value, {{ error_type | default(value="McpError") }}> {
    // Parse input parameters
    let input: {{ tool.input_type | default(value="serde_json::Value") }} = params
        .parse()
        .map_err(|e| {{ error_type | default(value="McpError") }}::invalid_params(format!(
            "Invalid parameters for {{ tool.name }}: {}",
            e
        )))?;

    // Execute tool logic
    let result = context
        .executor()
        .execute_{{ tool.name | snake }}(input)
        .await
        .map_err(|e| {{ error_type | default(value="McpError") }}::execution_failed(format!(
            "Tool {{ tool.name }} failed: {}",
            e
        )))?;

    // Return result
    Ok(json!({
        "result": result,
        "status": "success"
    }))
}

{%- if tool.enable_streaming %}
/// Streaming tool handler: {{ tool.name }}
///
/// Provides streaming responses for long-running operations.
pub async fn {{ tool.name | snake }}_streaming_handler(
    params: Params,
    context: &{{ handler_context_type | default(value="HandlerContext") }},
) -> Result<{{ stream_result_type | default(value="tokio::sync::mpsc::Receiver<String>") }}, {{ error_type | default(value="McpError") }}> {
    let input: {{ tool.input_type | default(value="serde_json::Value") }} = params
        .parse()
        .map_err(|e| {{ error_type | default(value="McpError") }}::invalid_params(format!(
            "Invalid parameters for {{ tool.name }}: {}",
            e
        )))?;

    context
        .executor()
        .execute_{{ tool.name | snake }}_streaming(input)
        .await
        .map_err(|e| {{ error_type | default(value="McpError") }}::execution_failed(format!(
            "Tool {{ tool.name }} streaming failed: {}",
            e
        )))
}

{%- endif %}
{% endfor -%}

/// Tool handler registry
///
/// Maps tool names to their handler functions
pub struct ToolHandlerRegistry {
    handlers: std::collections::HashMap<String, ToolHandler>,
}

/// Tool handler function pointer
pub type ToolHandlerFn = fn(
    Params,
    &{{ handler_context_type | default(value="HandlerContext") }},
) -> futures::future::BoxFuture<'static, Result<Value, {{ error_type | default(value="McpError") }}>>;

/// Individual tool handler
pub struct ToolHandler {
    name: String,
    handler: ToolHandlerFn,
    description: String,
    input_schema: serde_json::Value,
}

impl ToolHandler {
    /// Create a new tool handler
    pub fn new(
        name: String,
        handler: ToolHandlerFn,
        description: String,
        input_schema: serde_json::Value,
    ) -> Self {
        Self {
            name,
            handler,
            description,
            input_schema,
        }
    }

    /// Get the tool name
    pub fn name(&self) -> &str {
        &self.name
    }

    /// Get the tool description
    pub fn description(&self) -> &str {
        &self.description
    }

    /// Get the input schema
    pub fn input_schema(&self) -> &serde_json::Value {
        &self.input_schema
    }

    /// Execute the handler
    pub async fn execute(
        &self,
        params: Params,
        context: &{{ handler_context_type | default(value="HandlerContext") }},
    ) -> Result<Value, {{ error_type | default(value="McpError") }}> {
        (self.handler)(params, context).await
    }
}

impl ToolHandlerRegistry {
    /// Create a new tool handler registry
    pub fn new() -> Self {
        Self {
            handlers: std::collections::HashMap::new(),
        }
    }

    /// Register a tool handler
    pub fn register(&mut self, handler: ToolHandler) {
        self.handlers.insert(handler.name().to_string(), handler);
    }

    /// Get a tool handler by name
    pub fn get(&self, name: &str) -> Option<&ToolHandler> {
        self.handlers.get(name)
    }

    /// List all registered tool handlers
    pub fn list(&self) -> Vec<&ToolHandler> {
        self.handlers.values().collect()
    }
}

impl Default for ToolHandlerRegistry {
    fn default() -> Self {
        Self::new()
    }
}

{# Register default handlers #}
impl {{ server_impl_type | default(value="McpServerImpl") }} {
    /// Register default tool handlers
    pub fn register_default_handlers(&self) -> Result<(), {{ error_type | default(value="McpError") }}> {
        let mut registry = ToolHandlerRegistry::new();

        {% for tool in tools -%}
        registry.register(ToolHandler::new(
            "{{ tool.name }}".to_string(),
            |params, context| Box::pin({{ tool.name | snake }}_handler(params, context)),
            "{{ tool.description | default(value=tool.name) }}".to_string(),
            serde_json::from_str::<serde_json::Value>(r#"{{ tool.input_schema | default(value="{}") }}"#)
                .unwrap_or_default(),
        ));

        {% endfor %}
        Ok(())
    }
}
{% endblock body %}
