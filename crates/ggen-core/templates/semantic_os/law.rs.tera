//! {{ name }} - Compiled Operational Law
//! {{ description }}

use ggen_semantic_bit::Law;
use serde::{Serialize, Deserialize};

#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
pub enum {{ condition_type }} {
    {% for transition in transitions %}
    {{ transition.condition_name }},
    {% endfor %}
    Invalid,
}

pub struct {{ name }}Law;

impl Law for {{ name }}Law {
    type Field = {{ field_type }};
    type Condition = {{ condition_type }};
    type Admitted = {{ condition_type }};
    type Receipt = String;
    type Exit = u8;
    type Error = ggen_semantic_bit::Error;

    fn validate(field: {{ field_type }}) -> Result<{{ field_type }}, Self::Error> {
        Ok(field)
    }

    fn select(field: {{ field_type }}) -> Self::Condition {
        match field {
            {% for transition in transitions %}
            {{ transition.input_value }} => {{ condition_type }}::{{ transition.condition_name }},
            {% endfor %}
            _ => {{ condition_type }}::Invalid,
        }
    }

    fn admit(_field: {{ field_type }}, condition: Self::Condition) -> Self::Admitted {
        condition
    }

    fn receipt(admitted: Self::Admitted, sequence: u64) -> Self::Receipt {
        format!("{}:{:?}:{}", "{{ law_id }}", admitted, sequence)
    }

    fn exit(_receipt: Self::Receipt) -> Self::Exit {
        0
    }
}
