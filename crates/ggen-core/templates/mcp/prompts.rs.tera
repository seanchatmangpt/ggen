{# Prompt list and get handler — rmcp 1.3.0 | Context: server_name, prompts #}
{# Renders prompt-related methods for the ServerHandler implementation.        #}
{#                                                                                       #}
{# Context variables:                                                                     #}
{#   server_name  — snake_case server identifier                                         #}
{#   prompts      — array of prompt objects:                                             #}
{#     name             — prompt name (e.g. "explain-schema")                           #}
{#     description      — human-readable description                                      #}
{#     arguments        — array of argument objects:                                      #}
{#       name            — argument name (snake_case)                                    #}
{#       description     — doc comment text                                             #}
{#       required        — boolean (true/false)                                          #}

// ==============================================================================
// Prompts — list_prompts + get_prompt
// ==============================================================================
// Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
// SDK: rmcp 1.3.0

{% set type_name = server_name | default(value="mcp_server") | pascal %}

{% if prompts and prompts|length > 0 %}

// ---------------------------------------------------------------------------
// Prompt helpers (inherent impl)
// ---------------------------------------------------------------------------

impl {{ type_name }} {
    /// Build the full list of prompts registered with this server.
    fn all_prompts() -> Vec<Prompt> {
        vec![
    {% for prompt in prompts %}
            Prompt::new(
                "{{ prompt.name }}",
                Some("{{ prompt.description | default(value=prompt.name) }}"),
                Some(vec![
        {% for arg in prompt.arguments %}
                    PromptArgument::new("{{ arg.name }}")
                        .with_description("{{ arg.description | default(value=arg.name) }}")
                        .with_required({{ arg.required | default(value=true) }}),
        {% endfor %}
                ]),
            ),
    {% endfor %}
        ]
    }

    /// Render a prompt by name with the given arguments.
    fn render_prompt(
        &self,
        name: &str,
        args: &std::collections::HashMap<String, String>,
    ) -> Option<GetPromptResult> {
        match name {
    {% for prompt in prompts %}
            "{{ prompt.name }}" => {
                // TODO: implement prompt rendering for "{{ prompt.name }}"
        {% for arg in prompt.arguments %}
                let {{ arg.name }} = args
                    .get("{{ arg.name }}")
                    .cloned()
                    .unwrap_or_default();
        {% endfor %}
                Some(
                    GetPromptResult::new(vec![
                        PromptMessage::new_text(
                            PromptMessageRole::User,
                            format!("TODO: implement prompt template for {{ prompt.name }}"),
                        ),
                    ])
                    .with_description("{{ prompt.description | default(value=prompt.name) }}"),
                )
            }
    {% endfor %}
            _ => None,
        }
    }
}

// ---------------------------------------------------------------------------
// ServerHandler prompt methods
// ---------------------------------------------------------------------------

// Copy into the #[tool_handler(router = self.tool_router)] impl.

    async fn list_prompts(
        &self,
        _request: Option<PaginatedRequestParams>,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<ListPromptsResult, McpError> {
        tracing::info!("list_prompts called");
        Ok(ListPromptsResult::with_all_items(Self::all_prompts()))
    }

    async fn get_prompt(
        &self,
        request: GetPromptRequestParams,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<GetPromptResult, McpError> {
        tracing::info!(name = %request.name, "get_prompt called");
        let args: std::collections::HashMap<String, String> = request
            .arguments
            .as_ref()
            .map(|m| {
                m.iter()
                    .filter_map(|(k, v)| v.as_str().map(|s| (k.clone(), s.to_string())))
                    .collect()
            })
            .unwrap_or_default();

        self.render_prompt(&request.name, &args).ok_or_else(|| {
            McpError::invalid_params(format!("Unknown prompt: {}", request.name), None)
        })
    }

{% else %}
// No prompts defined in ontology. Generating empty stubs.

impl {{ type_name }} {
    /// Build the full list of prompts (empty — none defined).
    fn all_prompts() -> Vec<Prompt> {
        vec![]
    }

    /// Render a prompt by name (no-op — none defined).
    fn render_prompt(
        &self,
        name: &str,
        _args: &std::collections::HashMap<String, String>,
    ) -> Option<GetPromptResult> {
        tracing::warn!(name = %name, "render_prompt: no prompts registered");
        None
    }
}

// ServerHandler prompt methods — empty stubs.
    async fn list_prompts(
        &self,
        _request: Option<PaginatedRequestParams>,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<ListPromptsResult, McpError> {
        Ok(ListPromptsResult::with_all_items(vec![]))
    }

    async fn get_prompt(
        &self,
        request: GetPromptRequestParams,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<GetPromptResult, McpError> {
        Err(McpError::invalid_params(
            format!("Unknown prompt: {}", request.name),
            None,
        ))
    }

{% endif %}
