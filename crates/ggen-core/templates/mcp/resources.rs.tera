    /// Build the full list of static resources (empty — none defined).
    fn build_resources(&self) -> Vec<Resource> {
        vec![]
    }

    /// Read a single resource by URI (no-op — none defined).
    fn read_resource_by_uri(&self, _uri: &str) -> Option<ReadResourceResult> {
        None
    }
}

// ServerHandler resource methods — empty stubs.
    async fn list_resources(
        &self,
        _request: Option<PaginatedRequestParams>,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<ListResourcesResult, McpError> {
        Ok(ListResourcesResult::with_all_items(vec![]))
    }

    async fn read_resource(
        &self,
        request: ReadResourceRequestParams,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<ReadResourceResult, McpError> {
        Err(McpError::resource_not_found(
            format!("Resource not found: {}", request.uri),
        ))
    }

{% endif %}
