{# Resource list and read handler — rmcp 1.3.0 | Context: server_name, resources #}
{# Renders resource-related methods for the ServerHandler implementation.      #}
{#                                                                                       #}
{# Context variables:                                                                     #}
{#   server_name  — snake_case server identifier                                         #}
{#   resources    — array of resource objects:                                           #}
{#     uri_pattern      — URI template (e.g. "myapp://items/{id}")                      #}
{#     name             — resource name (used as display name)                          #}
{#     description      — human-readable description                                     #}
{#     mime_type        — MIME type (default: "text/plain")                             #}

// ==============================================================================
// Resources — list_resources + read_resource
// ==============================================================================
// Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
// SDK: rmcp 1.3.0

{% set type_name = server_name | default(value="mcp_server") | pascal %}
{% set page_size = page_size | default(value=20) %}

{% if resources and resources|length > 0 %}

// ---------------------------------------------------------------------------
// Resource helpers (inherent impl)
// ---------------------------------------------------------------------------

impl {{ type_name }} {
    /// Build the full list of static resources registered with this server.
    fn build_resources(&self) -> Vec<Resource> {
        vec![
    {% for resource in resources %}
            RawResource::new("{{ resource.uri_pattern }}", "{{ resource.name }}")
                .with_description("{{ resource.description | default(value=resource.name) }}")
                .with_mime_type("{{ resource.mime_type | default(value="text/plain") }}")
                .no_annotation(),
    {% endfor %}
        ]
    }

    /// Read a single resource by URI. Returns `None` if the URI does not
    /// match any registered resource pattern.
    fn read_resource_by_uri(&self, uri: &str) -> Option<ReadResourceResult> {
        // TODO: implement resource reading logic for each URI pattern
        // Example dispatch:
        // match uri {
        //     "myapp://items/{id}" => { /* load item content */ },
        //     _ => None,
        // }
        tracing::warn!(uri = %uri, "read_resource_by_uri: no handler registered");
        None
    }
}

// ---------------------------------------------------------------------------
// ServerHandler resource methods
// ---------------------------------------------------------------------------

// These methods are added to the ServerHandler impl block.
// Copy into the #[tool_handler(router = self.tool_router)] impl.

    async fn list_resources(
        &self,
        request: Option<PaginatedRequestParams>,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<ListResourcesResult, McpError> {
        tracing::info!("list_resources called");
        let all = self.build_resources();
        let start = request
            .as_ref()
            .and_then(|r| r.cursor.as_deref())
            .and_then(|c| c.parse::<usize>().ok())
            .unwrap_or(0);
        let page: Vec<Resource> = all.iter().skip(start).take({{ page_size }}).cloned().collect();
        let next_cursor = if start + {{ page_size }} < all.len() {
            Some(Cursor::from((start + {{ page_size }}).to_string()))
        } else {
            None
        };
        Ok(ListResourcesResult {
            meta: None,
            next_cursor,
            resources: page,
        })
    }

    async fn read_resource(
        &self,
        request: ReadResourceRequestParams,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<ReadResourceResult, McpError> {
        tracing::info!(uri = %request.uri, "read_resource called");
        self.read_resource_by_uri(&request.uri).ok_or_else(|| {
            McpError::invalid_params(
                format!("Resource not found: {}", request.uri),
                None,
            )
        })
    }

{% else %}
