{# Argument completion handler — rmcp 1.3.0 | Context: server_name, completions #}
{# Renders the complete() method for the ServerHandler implementation.          #}
{#                                                                                       #}
{# Context variables:                                                                     #}
{#   server_name  — snake_case server identifier                                         #}
{#   completions  — array of completion objects:                                         #}
{#     argument_name     — the parameter name to provide completions for                 #}
{#     reference_type    — "prompt" or "resource"                                        #}
{#     reference_name    — the prompt or resource name to match against                  #}
{#     values            — array of static completion values (strings)                  #}
{#     filter_fn         — optional: "case_insensitive_prefix" (default)                #}

// ==============================================================================
// Completions — complete()
// ==============================================================================
// Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
// SDK: rmcp 1.3.0

{% set type_name = server_name | default(value="mcp_server") | pascal %}

{% if completions and completions|length > 0 %}

// ---------------------------------------------------------------------------
// Completion helpers (inherent impl)
// ---------------------------------------------------------------------------

impl {{ type_name }} {
    /// Resolve completion values for a given argument name.
    ///
    /// The `prefix` parameter is the partial input typed by the user.
    /// Returns a list of candidate values that start with the prefix
    /// (case-insensitive), limited to `CompletionInfo::MAX_VALUES`.
    fn resolve_completions(&self, argument_name: &str, prefix: &str) -> Vec<String> {
        let prefix_lower = prefix.to_lowercase();
        match argument_name {
    {% for comp in completions %}
            "{{ comp.argument_name }}" => {
                let candidates = vec![
            {% for val in comp.values %}
                "{{ val }}".to_string(),
            {% endfor %}
                ];
                candidates
                    .into_iter()
                    .filter(|v| v.to_lowercase().starts_with(&prefix_lower))
                    .take(CompletionInfo::MAX_VALUES)
                    .collect()
            }
    {% endfor %}
            _ => vec![],
        }
    }
}

// ---------------------------------------------------------------------------
// ServerHandler completion method
// ---------------------------------------------------------------------------

// Copy into the #[tool_handler(router = self.tool_router)] impl.

    async fn complete(
        &self,
        request: CompleteRequestParams,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<CompleteResult, McpError> {
        let prefix = request.argument.value.to_lowercase();
        tracing::info!(
            argument = %request.argument.name,
            prefix = %prefix,
            "complete called"
        );

        let values = match &request.ref_ {
    {% for comp in completions %}
            Reference::{{ comp.reference_type | default(value="Prompt") | pascal }} { name } => {
        {% if comp.reference_name %}
                // Only provide completions for the matching reference name
                if name.as_str() == "{{ comp.reference_name }}" {
                    self.resolve_completions("{{ comp.argument_name }}", &prefix)
                } else {
                    vec![]
                }
        {% else %}
                // Provide completions for any prompt/resource with this argument
                self.resolve_completions("{{ comp.argument_name }}", &prefix)
        {% endif %}
            }
    {% endfor %}
            _ => vec![],
        };

        let completion = CompletionInfo::with_all_values(values).unwrap_or_default();
        Ok(CompleteResult::new(completion))
    }

{% else %}
// No completions defined in ontology. Generating empty stub.

impl {{ type_name }} {
    /// Resolve completion values (no completions defined).
    fn resolve_completions(&self, _argument_name: &str, _prefix: &str) -> Vec<String> {
        vec![]
    }
}

// ServerHandler completion method — empty stub.
    async fn complete(
        &self,
        request: CompleteRequestParams,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<CompleteResult, McpError> {
        tracing::info!(
            argument = %request.argument.name,
            "complete called (no completions registered)"
        );
        Ok(CompleteResult::new(CompletionInfo::default()))
    }

{% endif %}
