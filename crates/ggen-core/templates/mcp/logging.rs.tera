{# MCP logging protocol — rmcp 1.3.0 | Context: server_name, logging #}
{# Renders set_logging_level() and list_logging_levels() handlers.            #}
{#                                                                                       #}
{# Context variables:                                                                     #}
{#   server_name  — snake_case server identifier                                         #}
{#   logging      — object with:                                                         #}
{#     enabled    — boolean (default: false); if false, renders stubs only               #}
{#     default_level — default logging level (default: "info")                           #}
{#     supported_levels — array of level strings (default: all MCP levels)               #}

// ==============================================================================
// Logging — set_logging_level + list_logging_levels
// ==============================================================================
// Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
// SDK: rmcp 1.3.0

{% set type_name = server_name | default(value="mcp_server") | pascal %}
{% set logging_enabled = logging.enabled | default(value=false) %}
{% set default_level = logging.default_level | default(value="info") %}
{% set supported_levels = logging.supported_levels | default(value=["debug", "info", "notice", "warning", "error", "critical", "alert", "emergency"]) %}

{% if logging_enabled %}

// ---------------------------------------------------------------------------
// Logging helpers (inherent impl)
// ---------------------------------------------------------------------------

impl {{ type_name }} {
    /// Map an MCP logging level string to a `tracing::Level` filter directive.
    fn map_mcp_to_tracing_level(level: &str) -> tracing::LevelFilter {
        match level {
            "debug" | "Debug" => tracing::LevelFilter::DEBUG,
            "info" | "Info" | "notice" | "Notice" => tracing::LevelFilter::INFO,
            "warning" | "Warning" | "warn" | "Warn" => tracing::LevelFilter::WARN,
            "error" | "Error" | "critical" | "Critical"
            | "alert" | "Alert" | "emergency" | "Emergency" => tracing::LevelFilter::ERROR,
            _ => tracing::LevelFilter::INFO,
        }
    }

    /// Apply a new tracing log level filter at runtime.
    ///
    /// This updates the global max level filter so subsequent log output
    /// respects the client's requested verbosity.
    fn apply_logging_level(&self, level: &str) {
        let filter = Self::map_mcp_to_tracing_level(level);
        tracing::info!(
            mcp_level = %level,
            tracing_filter = ?filter,
            "Setting MCP logging level"
        );
        // Reload the global subscriber filter.
        // The simplest approach: set the max level filter directly.
        tracing::level_filters::set_global_default(filter)
            .expect("global tracing filter already set — this should only be called once");
    }
}

// ---------------------------------------------------------------------------
// ServerHandler logging methods
// ---------------------------------------------------------------------------

// Copy into the #[tool_handler(router = self.tool_router)] impl.

    async fn set_logging_level(
        &self,
        request: SetLoggingLevelRequestParam,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<(), McpError> {
        tracing::info!(level = %request.level, "set_logging_level called");
        self.apply_logging_level(request.level.as_str());
        Ok(())
    }

    async fn list_logging_levels(
        &self,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<Vec<LoggingLevel>, McpError> {
        tracing::info!("list_logging_levels called");
        Ok(vec![
    {% for level in supported_levels %}
            LoggingLevel::new("{{ level }}"),
    {% endfor %}
        ])
    }

{% else %}
// Logging capability not enabled. Generating stubs.

impl {{ type_name }} {
    /// Logging is not enabled for this server.
    fn apply_logging_level(&self, level: &str) {
        tracing::warn!(level = %level, "set_logging_level called but logging capability is not enabled");
    }
}

// ServerHandler logging methods — no-op stubs.
// These will only be called if the client requests the logging capability,
// which this server does not advertise.

    async fn set_logging_level(
        &self,
        request: SetLoggingLevelRequestParam,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<(), McpError> {
        tracing::warn!(level = %request.level, "set_logging_level: capability not enabled");
        Ok(())
    }

    async fn list_logging_levels(
        &self,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<Vec<LoggingLevel>, McpError> {
        Ok(vec![
    {% for level in supported_levels %}
            LoggingLevel::new("{{ level }}"),
    {% endfor %}
        ])
    }

{% endif %}
