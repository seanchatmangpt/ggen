{%- endif %}
#[derive(Debug, Clone)]
pub struct {{ type_name }} {
    /// Tool router generated by the `#[tool_router]` macro.
    /// Dispatches `list_tools` and `call_tool` requests to the
    /// corresponding `#[tool]` methods on this struct.
    tool_router: ToolRouter<Self>,
}

impl {{ type_name }} {
    /// Construct a new `{{ type_name }}` with all tools registered.
    ///
    /// The `#[tool_router]` macro generates `Self::tool_router()` which
    /// discovers all `#[tool]`-annotated methods and builds the dispatch
    /// table.
    pub fn new() -> Self {
        Self {
            tool_router: Self::tool_router(),
        }
    }

    /// Serve the MCP protocol over standard I/O.
    ///
    /// Reads JSON-RPC messages from stdin and writes responses to stdout.
    /// Blocks until the transport is closed (e.g. stdin EOF).
    pub async fn serve_stdio(self) -> anyhow::Result<()> {
        let transport = rmcp::transport::stdio();
        tracing::info!("Serving over STDIO");
        self.serve(transport).await
    }

    /// Serve the MCP protocol over HTTP.
    ///
    /// Binds to the specified address and accepts HTTP POST requests
    /// carrying JSON-RPC payloads.
    pub async fn serve_http(self, addr: &str) -> anyhow::Result<()> {
        let transport = rmcp::transport::http().bind(addr).await?;
        tracing::info!(addr = %addr, "Serving over HTTP");
        self.serve(transport).await
    }

    /// Serve the MCP protocol over Server-Sent Events (SSE).
    ///
    /// Binds to the specified address and exposes the MCP protocol
    /// via the SSE transport.
    pub async fn serve_sse(self, addr: &str) -> anyhow::Result<()> {
        let transport = rmcp::transport::sse().bind(addr).await?;
        tracing::info!(addr = %addr, "Serving over SSE");
        self.serve(transport).await
    }

    /// Serve the MCP protocol over an arbitrary transport.
    ///
    /// This is the core serve method. All other `serve_*` methods delegate
    /// to this. The caller must NOT drop the returned future — use
    /// `waiting().await` to block until the client disconnects.
    ///
    /// # Type parameters
    /// - `T`: Transport type implementing `IntoTransport<RoleServer, E, A>`
    /// - `E`: Error type for the transport
    /// - `A`: Additional transport context
    pub async fn serve<T, E, A>(self, transport: T) -> anyhow::Result<()>
    where
        T: rmcp::transport::IntoTransport<rmcp::RoleServer, E, A>,
        E: std::error::Error + Send + Sync + 'static,
        A: 'static,
    {
        let running = rmcp::ServiceExt::serve(self, transport).await?;
        running
            .waiting()
            .await
            .map_err(|e| anyhow::anyhow!("{e}"))?;
        Ok(())
    }
}

impl Default for {{ type_name }} {
    fn default() -> Self {
        Self::new()
    }
}
