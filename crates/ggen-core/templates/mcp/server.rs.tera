// ==============================================================================
// Server struct — rmcp 1.3.0
// ==============================================================================
// Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
// SDK: rmcp 1.3.0
//
// Lifecycle:
//   1. {{ type_name }}::new()          — construct with tool router
//   2. server.serve(transport).await   — start serving
//   3. running.waiting().await         — block until transport closes
//
// CRITICAL (rmcp 1.3.0):
//   `serve()` returns RunningService<R, S> which carries a DropGuard.
//   If you write `let _ = server.serve(transport).await`, the `_` binding
//   immediately drops RunningService and the connection closes.
//   Always chain: `server.serve(transport).await?.waiting().await?`

{% set type_name = server_name | default(value="mcp_server") | pascal %}
{% set server_id = server_name | default(value="mcp-server") %}

/// MCP server: {{ server_id }}
///
/// {{ server_description | default(value="Generated MCP server") }}
///
/// Capabilities:
{%- if capabilities %}
