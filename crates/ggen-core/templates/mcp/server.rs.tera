#[tokio::main]
async fn main() -> anyhow::Result<()> {
{% if transport_type == "http" %}
    let transport = rmcp::transport::http().bind("0.0.0.0:3000").await?;
{% elif transport_type == "sse" %}
    let transport = rmcp::transport::sse().bind("0.0.0.0:3000").await?;
{% else %}
    let transport = rmcp::transport::stdio();
{% endif %}

    let server = {{ server_name | default(value="McpServer") | pascal }}::new();

    let running = server.serve(transport).await?;
    running.waiting().await?;

    Ok(())
}
