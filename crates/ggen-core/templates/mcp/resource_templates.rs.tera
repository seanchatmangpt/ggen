{# Resource template list handler — rmcp 1.3.0 | Context: server_name, resource_templates #}
{# Renders list_resource_templates for the ServerHandler implementation.          #}
{#                                                                                       #}
{# Context variables:                                                                     #}
{#   server_name         — snake_case server identifier                                 #}
{#   resource_templates  — array of resource template objects:                          #}
{#     uri_pattern        — URI template (e.g. "myapp://items/{id}")                    #}
{#     name               — template name                                                #}
{#     description        — human-readable description                                   #}
{#     mime_type          — MIME type (default: "text/plain")                           #}

// ==============================================================================
// Resource Templates — list_resource_templates
// ==============================================================================
// Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
// SDK: rmcp 1.3.0

{% set type_name = server_name | default(value="mcp_server") | pascal %}

{% if resource_templates and resource_templates|length > 0 %}

// ---------------------------------------------------------------------------
// Resource template helpers (inherent impl)
// ---------------------------------------------------------------------------

impl {{ type_name }} {
    /// Build the full list of resource templates registered with this server.
    fn build_resource_templates(&self) -> Vec<ResourceTemplate> {
        vec![
    {% for tmpl in resource_templates %}
            ResourceTemplate::new("{{ tmpl.uri_pattern }}", "{{ tmpl.name }}")
                .with_description("{{ tmpl.description | default(value=tmpl.name) }}")
                .with_mime_type("{{ tmpl.mime_type | default(value="text/plain") }}"),
    {% endfor %}
        ]
    }
}

// ---------------------------------------------------------------------------
// ServerHandler resource template methods
// ---------------------------------------------------------------------------

// Copy into the #[tool_handler(router = self.tool_router)] impl.

    async fn list_resource_templates(
        &self,
        _request: Option<PaginatedRequestParams>,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<ListResourceTemplatesResult, McpError> {
        tracing::info!("list_resource_templates called");
        let templates = self.build_resource_templates();
        Ok(ListResourceTemplatesResult::with_all_items(templates))
    }

{% else %}
// No resource templates defined in ontology. Generating empty stub.

impl {{ type_name }} {
    /// Build the full list of resource templates (empty — none defined).
    fn build_resource_templates(&self) -> Vec<ResourceTemplate> {
        vec![]
    }
}

// ServerHandler resource template methods — empty stub.
    async fn list_resource_templates(
        &self,
        _request: Option<PaginatedRequestParams>,
        _context: rmcp::service::RequestContext<rmcp::RoleServer>,
    ) -> Result<ListResourceTemplatesResult, McpError> {
        Ok(ListResourceTemplatesResult::with_all_items(vec![]))
    }

{% endif %}
