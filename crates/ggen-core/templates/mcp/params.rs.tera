{# MCP Parameter extraction template #}
{# Pipeline: extract-mcp-params.rq -> this template -> generated Rust params module #}
{# #}
{# Input context: sparql_results = JSON array of {tool_name, param_name, ...} rows #}

// Generated by ggen from MCP ontology
// Pipeline: ontology (.ttl) -> SPARQL SELECT (.rq) -> Tera (.tera) -> this file

{# Group params by tool_name #}
{#- set tools_with_params = {} -#}
{%- for row in sparql_results -%}
  {%- set tn = row.tool_name -#}
  {%- if tn not in tools_with_params -#}
    {#- set _ = tools_with_params.update({tn: []}) -#}
  {%- endif -%}
  {#- set _ = tools_with_params[tn].append({
      "name": row.param_name,
      "description": row.param_description,
      "rust_type": row.rust_type,
      "json_schema": row.json_schema,
      "is_required": row.is_required,
      "default_value": row.default_value,
      "enum_values": row.enum_values
    }) -#}
{%- endfor -%}

{% for tool_name, params in tools_with_params.items() %}
// Parameters for tool: {{ tool_name }}

{% for param in params %}
/// {{ param.description | default(value=param.name) }}
{% if param.is_required == "true" %}
pub {{ param.name | snake }}: {{ param.rust_type | default(value="String") }},
{% else %}
#[serde(default)]
pub {{ param.name | snake }}: Option<{{ param.rust_type | default(value="String") }}>,
{% endif %}

{% endfor %}
{% endfor %}
