{# get_info handler — rmcp 1.3.0 | Context: server_name, server_version, capabilities #}
{# Renders the ServerHandler::get_info() implementation for a generated MCP server.  #}
{#                                                                                            #}
{# Context variables:                                                                         #}
{#   server_name          — snake_case server identifier                                     #}
{#   server_version       — semver string (default: "0.1.0")                                #}
{#   server_description   — human-readable description                                        #}
{#   protocol_version     — MCP protocol version (default: "2025-03-26")                    #}
{#   capabilities — object with boolean flags: tools, resources, prompts, completions,       #}
{#                   resource_templates, logging                                             #}

// ==============================================================================
// get_info — ServerHandler initialization result
// ==============================================================================
// Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
// SDK: rmcp 1.3.0

{% set type_name = server_name | default(value="mcp_server") | pascal %}
{% set server_id = server_name | default(value="mcp-server") %}

impl {{ type_name }} {
    /// Return the MCP `InitializeResult` describing this server's identity and
    /// capabilities. Called once by the client during the initialization
    /// handshake.
    ///
    /// # Capability flags
    {%- if capabilities %}
    {%- if capabilities.tools %}  - tools: enabled{%- endif %}
    {%- if capabilities.resources %}  - resources: enabled{%- endif %}
    {%- if capabilities.resource_templates %}  - resource_templates: enabled{%- endif %}
    {%- if capabilities.prompts %}  - prompts: enabled{%- endif %}
    {%- if capabilities.completions %}  - completions: enabled{%- endif %}
    {%- if capabilities.logging %}  - logging: enabled{%- endif %}
    {%- else %}
    /// All capabilities enabled by default.
    {%- endif %}
    pub fn get_info(&self) -> InitializeResult {
        let capabilities = ServerCapabilities::builder()
    {%- if capabilities.tools != false %}
            .enable_tools()
    {%- endif %}
    {%- if capabilities.resources %}
            .enable_resources()
    {%- endif %}
    {%- if capabilities.resource_templates %}
            .enable_resource_templates()
    {%- endif %}
    {%- if capabilities.prompts %}
            .enable_prompts()
    {%- endif %}
    {%- if capabilities.completions %}
            .enable_completions()
    {%- endif %}
            .build();

        InitializeResult::new(capabilities)
            .with_server_info(Implementation::new(
                "{{ server_id }}",
                "{{ server_version | default(value="0.1.0") }}",
            ))
    }
}
