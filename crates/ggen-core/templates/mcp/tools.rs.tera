{# Tool router and handler template — rmcp 1.3.0 | Context: server_name, tools #}
{# Renders the #[tool_router] impl block with parameter structs and tool methods. #}
{#                                                                                       #}
{# Context variables:                                                                     #}
{#   server_name  — snake_case server identifier (e.g. "my_server")                      #}
{#   tools        — array of tool objects, each with:                                      #}
{#     name             — tool name (snake_case)                                          #}
{#     description      — human-readable description for #[tool]                         #}
{#     params           — array of param objects:                                         #}
{#       name            — param name (snake_case)                                       #}
{#       description     — doc comment text                                              #}
{#       rust_type       — Rust type (String, bool, i64, etc.)                           #}
{#       is_required     — "true" or "false"                                             #}
{#       default_value   — optional default expression                                   #}
{#       enum_values     — optional array of valid values                                 #}

// ==============================================================================
// Tool router — rmcp 1.3.0
// ==============================================================================
// Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
// SDK: rmcp 1.3.0
//
// Wire diagram:
//   #[tool_router]  -> generates Self::tool_router() (ToolRouter<Self>)
//   #[tool_handler] -> wires tool_router into ServerHandler::list_tools + call_tool
//
// CRITICAL: Both macros are REQUIRED. Missing #[tool_handler] causes
// list_tools() to return empty and call_tool() to return -32601.

{% set type_name = server_name | default(value="mcp_server") | pascal %}

{% if tools and tools|length > 0 %}
// ---------------------------------------------------------------------------
// Parameter structs
// ---------------------------------------------------------------------------

{% for tool in tools %}
/// Parameters for the `{{ tool.name }}` tool.
///
/// {{ tool.description | default(value="") }}
#[derive(Debug, Deserialize, schemars::JsonSchema)]
pub struct {{ tool.name | pascal }}Params {
    {% for param in tool.params %}
    /// {{ param.description | default(value=param.name) }}
    {% if param.is_required == "true" %}
    pub {{ param.name | snake }}: {{ param.rust_type | default(value="String") }},
    {% else %}
    #[serde(default)]
    pub {{ param.name | snake }}: Option<{{ param.rust_type | default(value="String") }}>,
    {% endif %}
    {% endfor %}
}

{% endfor %}
// ---------------------------------------------------------------------------
// Tool implementations
// ---------------------------------------------------------------------------

#[tool_router]
impl {{ type_name }} {
    /// Construct a new `{{ type_name }}` with all tools registered.
    pub fn new() -> Self {
        Self {
            tool_router: Self::tool_router(),
        }
    }

{% for tool in tools %}
    /// {{ tool.description | default(value=tool.name) }}
    #[tool(
        description = "{{ tool.description | default(value=tool.name) }}"
    )]
    async fn {{ tool.name | snake }}(
        &self,
        Parameters(params): Parameters<{{ tool.name | pascal }}Params>,
    ) -> Result<CallToolResult, McpError> {
        // OTEL span for tool invocation
        let span = tracing::info_span!(
            "mcp.tool.call",
            mcp.tool.name = %{{ tool.name | default(value="unknown") }},
        );
        let _guard = span.enter();

        // TODO: implement {{ tool.name }}
        let result = CallToolResult::success(vec![Content::text(
            format!("{{ tool.name }} executed with params: {:?}", params)
        )]);

        // Receipt emission
        tracing::info!(
            mcp.tool.name = %{{ tool.name | default(value="unknown") }},
            "Tool invocation completed"
        );

        Ok(result)
    }

{% endfor %}
}

{% else %}
// No tools defined in ontology. Generating empty tool router.

#[tool_router]
impl {{ type_name }} {
    /// Construct a new `{{ type_name }}` with no tools registered.
    pub fn new() -> Self {
        Self {
            tool_router: Self::tool_router(),
        }
    }
}

{% endif %}
