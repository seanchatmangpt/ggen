{# Server bootstrap — rmcp 1.3.0 | Context: server_name, transport_type #}
{# Renders the #[tokio::main] async main with transport selection.              #}
{#                                                                                       #}
{# Context variables:                                                                     #}
{#   server_name    — snake_case server identifier (e.g. "my_server")                  #}
{#   transport_type — "stdio" (default), "http", or "sse"                             #}
{#   http_host      — bind address for HTTP transport (default: "0.0.0.0")            #}
{#   http_port      — bind port for HTTP/SSE transport (default: 3000)                #}
{#   log_level      — tracing filter level (default: "info")                          #}

// ==============================================================================
// Main — Server bootstrap
// ==============================================================================
// Generated by ggen from {{ server_name | default(value="mcp_server") }} ontology
// SDK: rmcp 1.3.0

{% set type_name = server_name | default(value="mcp_server") | pascal %}
{% set transport = transport_type | default(value="stdio") %}
{% set host = http_host | default(value="0.0.0.0") %}
{% set port = http_port | default(value=3000) %}
{% set log_level = log_level | default(value="info") %}

use tracing::info;
use tracing_subscriber::EnvFilter;

#[tokio::main]
async fn main() -> anyhow::Result<()> {
    // Initialize tracing with RUST_LOG env var support.
    // Override with "{{ log_level }}" if RUST_LOG is not set.
    tracing_subscriber::fmt()
        .with_env_filter(
            EnvFilter::try_from_env("RUST_LOG")
                .unwrap_or_else(|_| EnvFilter::new("{{ log_level }}")),
        )
        .with_target(true)
        .with_thread_ids(false)
        .init();

    info!(
        server = "{{ server_name | default(value="mcp_server") }}",
        transport = "{{ transport }}",
        "Starting MCP server"
    );

    let server = {{ type_name }}::new();

{% if transport == "stdio" %}
    // STDIO transport — reads JSON-RPC from stdin, writes to stdout.
    // CRITICAL: `waiting()` is consuming. Do NOT assign to `_`.
    let transport = rmcp::transport::stdio();
    info!("Serving over STDIO");
    server.serve(transport).await?;

{% elif transport == "http" %}
    // HTTP transport — binds to {{ host }}:{{ port }}.
    let addr = "{{ host }}:{{ port }}";
    let transport = rmcp::transport::http().bind(addr).await?;
    info!(addr = %addr, "Serving over HTTP");
    server.serve(transport).await?;

{% elif transport == "sse" %}
    // Server-Sent Events transport — binds to {{ host }}:{{ port }}.
    let addr = "{{ host }}:{{ port }}";
    let transport = rmcp::transport::sse().bind(addr).await?;
    info!(addr = %addr, "Serving over SSE");
    server.serve(transport).await?;

{% else %}
    // Unknown transport type, falling back to STDIO.
    let transport = rmcp::transport::stdio();
    info!(requested = "{{ transport }}", "Unknown transport type, falling back to STDIO");
    server.serve(transport).await?;

{% endif %}
    Ok(())
}
