// SPARQLQueryRequest represents a SPARQL query request
type SPARQLQueryRequest struct {
	Query string `json:"query"`
}

// SPARQLQueryResponse represents the response from a SPARQL query
type SPARQLQueryResponse struct {
	Results struct {
		Bindings []map[string]struct {
			Type  string `json:"type"`
			Value string `json:"value"`
		} `json:"bindings"`
	} `json:"results"`
	Boolean bool `json:"boolean,omitempty"`
}

// executeSPARQLQuery executes a SPARQL query against the endpoint
func executeSPARQLQuery(ctx context.Context, query string) (*SPARQLQueryResponse, time.Duration, error) {
	start := time.Now()

	reqBody := SPARQLQueryRequest{Query: query}
	jsonData, err := json.Marshal(reqBody)
	if err != nil {
		return nil, 0, fmt.Errorf("failed to marshal query: %w", err)
	}

	req, err := http.NewRequestWithContext(ctx, "POST", sparqlEndpoint, nil)
	if err != nil {
		return nil, 0, fmt.Errorf("failed to create request: %w", err)
	}

	req.Header.Set("Content-Type", "application/json")
	req.Header.Set("Accept", "application/json")
	req.Body = io.NopCloser(bytes.NewReader(jsonData))

	client := &http.Client{Timeout: defaultTimeout}
	resp, err := client.Do(req)
	if err != nil {
		return nil, 0, fmt.Errorf("query failed: %w", err)
	}
	defer resp.Body.Close()

	duration := time.Since(start)

	if resp.StatusCode != http.StatusOK {
		return nil, duration, fmt.Errorf("query failed with status %d", resp.StatusCode)
	}

	var result SPARQLQueryResponse
	if err := json.NewDecoder(resp.Body).Decode(&result); err != nil {
		return nil, duration, fmt.Errorf("failed to decode response: %w", err)
	}

	return &result, duration, nil
}

