// Parallel benchmarks for concurrent query execution
func BenchmarkParallelQueries(b *testing.B) {
	ctx := context.Background()
	query := "SELECT ?s ?p ?o WHERE { ?s ?p ?o } LIMIT 10"

	b.ResetTimer()
	b.RunParallel(func(pb *testing.PB) {
		for pb.Next() {
			_, _, err := executeSPARQLQuery(ctx, query)
			if err != nil {
				b.Errorf("Parallel query failed: %v", err)
			}
		}
	})
}

// Sub-benchmark: Small result sets
func BenchmarkSmallResultSet(b *testing.B) {
	ctx := context.Background()
	query := "SELECT ?s ?p ?o WHERE { ?s ?p ?o } LIMIT 5"

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		result, _, err := executeSPARQLQuery(ctx, query)
		if err != nil {
			b.Fatalf("Query failed: %v", err)
		}
		if len(result.Results.Bindings) > 5 {
			b.Fatalf("Expected ≤5 results, got %d", len(result.Results.Bindings))
		}
	}
}

