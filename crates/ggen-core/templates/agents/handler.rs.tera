// Generated by ggen from {{ agent_name }} ontology
// Pipeline: ontology (.ttl) -> SPARQL-star CONSTRUCT (.rq) -> Tera (.tera) -> this file
// A = mu(O)
//
// TOGAF {{ phase }} Agent Handler: {{ handler_name }}
// {{ agent_description }}

use serde::{Deserialize, Serialize};
use std::collections::HashMap;
use thiserror::Error;

// ---------------------------------------------------------------------------
// Error types
// ---------------------------------------------------------------------------

#[derive(Debug, Error)]
pub enum {{ handler_name }}Error {
    #[error("Invalid input: {0}")]
    InvalidInput(String),

    #[error("FIBO concept validation failed: {concept} - {reason}")]
    FiboValidation { concept: String, reason: String },

    #[error("Artifact generation failed: {artifact} - {reason}")]
    ArtifactGeneration { artifact: String, reason: String },

    #[error("Phase handoff failed: {0}")]
    HandoffFailed(String),

    #[error("Turn out of range: {current}, expected {start}-{end}")]
    TurnOutOfRange { current: usize, start: usize, end: usize },

    #[error("ARB gate violation: gate {gate}, reviewer {reviewer}")]
    ArbGateViolation { gate: usize, reviewer: String },

    #[error("Serialization error: {0}")]
    Serialization(#[from] serde_json::Error),

    #[error("IO error: {0}")]
    Io(#[from] std::io::Error),
}

// ---------------------------------------------------------------------------
// Agent handler
// ---------------------------------------------------------------------------

pub struct {{ handler_name }} {
    phase: String,
    turn_start: usize,
    turn_end: usize,
    arb_gate: usize,
    arb_reviewer: String,
    fibo_concepts: HashMap<String, String>,
    system_prompt: String,
}

impl {{ handler_name }} {
    /// Create a new handler for the {{ phase }} phase agent.
    ///
    /// # Errors
    ///
    /// Returns an error if `turn_start > turn_end` or if `arb_gate` is not
    /// within the turn range.
    pub fn new(
        phase: String,
        turn_start: usize,
        turn_end: usize,
        arb_gate: usize,
        arb_reviewer: String,
        fibo_concepts: HashMap<String, String>,
        system_prompt: String,
    ) -> Result<Self, {{ handler_name }}Error> {
        if turn_start > turn_end {
            return Err({{ handler_name }}Error::TurnOutOfRange {
                current: turn_start,
                start: turn_start,
                end: turn_end,
            });
        }
        if arb_gate < turn_start || arb_gate > turn_end {
            return Err({{ handler_name }}Error::ArbGateViolation {
                gate: arb_gate,
                reviewer: arb_reviewer,
            });
        }
        Ok(Self {
            phase,
            turn_start,
            turn_end,
            arb_gate,
            arb_reviewer,
            fibo_concepts,
            system_prompt,
        })
    }

    /// Returns the phase identifier (e.g. "A", "B", ...).
    pub fn phase(&self) -> &str {
        &self.phase
    }

    /// Returns the turn range `[start, end]` for this phase.
    pub fn turn_range(&self) -> (usize, usize) {
        (self.turn_start, self.turn_end)
    }

    /// Returns the ARB (Architecture Review Board) gate turn number.
    pub fn arb_gate(&self) -> usize {
        self.arb_gate
    }

    /// Returns the ARB reviewer role for this phase.
    pub fn arb_reviewer(&self) -> &str {
        &self.arb_reviewer
    }

    /// Validate that a turn number falls within this phase's range.
    pub fn validate_turn(&self, turn: usize) -> Result<(), {{ handler_name }}Error> {
        if turn < self.turn_start || turn > self.turn_end {
            return Err({{ handler_name }}Error::TurnOutOfRange {
                current: turn,
                start: self.turn_start,
                end: self.turn_end,
            });
        }
        Ok(())
    }

    /// Validate FIBO concepts referenced in a message payload.
    ///
    /// Checks that every FIBO concept key used in `payload` exists in this
    /// phase's FIBO concept mapping.
    pub fn validate_fibo_concepts(
        &self,
        payload: &serde_json::Value,
    ) -> Result<Vec<(String, String)>, {{ handler_name }}Error> {
        let mut validated = Vec::new();

        if let Some(obj) = payload.as_object() {
            for key in obj.keys() {
                if key.starts_with("fibo") {
                    if let Some(mapping) = self.fibo_concepts.get(key) {
                        validated.push((key.clone(), mapping.clone()));
                    } else {
                        return Err({{ handler_name }}Error::FiboValidation {
                            concept: key.clone(),
                            reason: format!(
                                "concept '{}' is not mapped in phase {} (turns {}-{})",
                                key, self.phase, self.turn_start, self.turn_end,
                            ),
                        });
                    }
                }
            }
        }

        Ok(validated)
    }

    /// Process an incoming message for this phase.
    ///
    /// Validates the turn number, FIBO concepts, and produces an output
    /// containing the generated artifacts and updated state.
    pub fn process_message(
        &self,
        turn: usize,
        payload: &serde_json::Value,
    ) -> Result<{{ handler_name }}Output, {{ handler_name }}Error> {
        self.validate_turn(turn)?;
        let fibo_validated = self.validate_fibo_concepts(payload)?;

        // Check if this turn is an ARB gate
        let requires_arb = turn == self.arb_gate;

        Ok({{ handler_name }}Output {
            phase: self.phase.clone(),
            turn,
            requires_arb_review: requires_arb,
            arb_reviewer: if requires_arb {
                Some(self.arb_reviewer.clone())
            } else {
                None
            },
            fibo_concepts_validated: fibo_validated,
            artifacts: self.generate_artifacts(turn, payload)?,
        })
    }

    /// Generate phase-specific artifacts from the input payload.
    fn generate_artifacts(
        &self,
        turn: usize,
        payload: &serde_json::Value,
    ) -> Result<Vec<String>, {{ handler_name }}Error> {
        let mut artifacts = Vec::new();

        {% for artifact in artifacts | default(value = ["Phase Artifact"]) %}
        let {{ artifact | replace("-", "_") | replace(" ", "_") }}_key = "{{ artifact }}";
        if let Some(value) = payload.get("{{ artifact | replace(" ", "_") | lower }}") {
            if !value.is_null() {
                artifacts.push(format!("{}: {}", {{ artifact | replace("-", "_") | replace(" ", "_") }}_key, value));
            }
        } else {
            artifacts.push(format!("{}: pending (turn {})", {{ artifact | replace("-", "_") | replace(" ", "_") }}_key, turn));
        }
        {% endfor %}

        Ok(artifacts)
    }
}

// ---------------------------------------------------------------------------
// Output types
// ---------------------------------------------------------------------------

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct {{ handler_name }}Output {
    pub phase: String,
    pub turn: usize,
    pub requires_arb_review: bool,
    pub arb_reviewer: Option<String>,
    pub fibo_concepts_validated: Vec<(String, String)>,
    pub artifacts: Vec<String>,
}

// ---------------------------------------------------------------------------
// Tests (Chicago TDD: real collaborators, no mocks)
// ---------------------------------------------------------------------------

#[cfg(test)]
mod tests {
    use super::*;

    fn make_handler() -> {{ handler_name }} {
        let mut fibo = HashMap::new();
        fibo.insert("fibo-fnd:LegalPerson".to_string(), "Legal entity mapping".to_string());
        fibo.insert("fibo-fnd:Organization".to_string(), "Organization mapping".to_string());
        {{ handler_name }}::new(
            "{{ phase }}".to_string(),
            {{ turn_start | default(value = 1) }},
            {{ turn_end | default(value = 8) }},
            {{ arb_gate | default(value = 5) }},
            "Chief Architect".to_string(),
            fibo,
            "System prompt".to_string(),
        )
        .expect("handler construction should succeed")
    }

    #[test]
    fn test_handler_construction_valid() {
        let handler = make_handler();
        assert_eq!(handler.phase(), "{{ phase }}");
        assert_eq!(handler.turn_range(), ({{ turn_start | default(value = 1) }}, {{ turn_end | default(value = 8) }}));
        assert_eq!(handler.arb_gate(), {{ arb_gate | default(value = 5) }});
        assert_eq!(handler.arb_reviewer(), "Chief Architect");
    }

    #[test]
    fn test_handler_construction_invalid_turns() {
        let result = {{ handler_name }}::new(
            "X".to_string(), 10, 5, 7, "Reviewer".to_string(),
            HashMap::new(), "prompt".to_string(),
        );
        assert!(result.is_err());
    }

    #[test]
    fn test_handler_construction_invalid_arb_gate() {
        let result = {{ handler_name }}::new(
            "X".to_string(), 1, 8, 0, "Reviewer".to_string(),
            HashMap::new(), "prompt".to_string(),
        );
        assert!(result.is_err());
    }

    #[test]
    fn test_validate_turn_in_range() {
        let handler = make_handler();
        assert!(handler.validate_turn({{ turn_start | default(value = 1) }}).is_ok());
        assert!(handler.validate_turn({{ turn_end | default(value = 8) }}).is_ok());
        assert!(handler.validate_turn({{ arb_gate | default(value = 5) }}).is_ok());
    }

    #[test]
    fn test_validate_turn_out_of_range() {
        let handler = make_handler();
        assert!(handler.validate_turn(0).is_err());
        assert!(handler.validate_turn(9).is_err());
        assert!(handler.validate_turn(100).is_err());
    }

    #[test]
    fn test_fibo_concepts_valid() {
        let handler = make_handler();
        let payload = serde_json::json!({
            "fibo-fnd:LegalPerson": "Bank A",
            "fibo-fnd:Organization": "Org Structure"
        });
        let result = handler.validate_fibo_concepts(&payload);
        assert!(result.is_ok());
        let validated = result.expect("validation should succeed");
        assert_eq!(validated.len(), 2);
    }

    #[test]
    fn test_fibo_concepts_unknown() {
        let handler = make_handler();
        let payload = serde_json::json!({
            "fibo-unknown:Concept": "unknown"
        });
        let result = handler.validate_fibo_concepts(&payload);
        assert!(result.is_err());
    }

    #[test]
    fn test_process_message_at_arb_gate() {
        let handler = make_handler();
        let payload = serde_json::json!({
            "fibo-fnd:LegalPerson": "Bank A"
        });
        let output = handler.process_message({{ arb_gate | default(value = 5) }}, &payload)
            .expect("processing should succeed");
        assert!(output.requires_arb_review);
        assert_eq!(output.arb_reviewer.as_deref(), Some("Chief Architect"));
    }

    #[test]
    fn test_process_message_not_at_arb_gate() {
        let handler = make_handler();
        let payload = serde_json::json!({});
        let output = handler.process_message({{ turn_start | default(value = 1) }}, &payload)
            .expect("processing should succeed");
        assert!(!output.requires_arb_review);
        assert!(output.arb_reviewer.is_none());
    }

    #[test]
    fn test_process_message_out_of_range() {
        let handler = make_handler();
        let payload = serde_json::json!({});
        let result = handler.process_message(99, &payload);
        assert!(result.is_err());
    }

    #[test]
    fn test_output_serialization() {
        let handler = make_handler();
        let payload = serde_json::json!({});
        let output = handler.process_message({{ turn_start | default(value = 1) }}, &payload)
            .expect("processing should succeed");
        let json = serde_json::to_string(&output)
            .expect("serialization should succeed");
        assert!(json.contains("{{ phase }}"));
    }
}
