# Generated by ggen from FIBO-TOGAF ontology
# Pipeline: ontology (.ttl) -> SPARQL SELECT (.rq) -> Tera (.tera) -> this file
# A = mu(O)
#
# TOGAF Phase B: Business Architecture Agent Configuration
# {{ generated_at | default(value = "2026-03-31") }}

[agent]
name = "{{ phase_b.name | default(value = 'Business Architecture Agent') }}"
description = "{{ phase_b.description | default(value = 'Handles TOGAF Phase B: Business Architecture. Define capabilities, organization structure, business services using FIBO-derived concepts. Map banking products to FIBO financial instruments.') }}"
version = "{{ phase_b.version | default(value = '1.0.0') }}"
phase = "B"
phase_number = {{ phase_b.phase_number | default(value = 2) }}

[agent.system_prompt]
text = "{{ phase_b.system_prompt | default(value = 'You are the Business Architecture Agent. Define capabilities, organization structure, business services using FIBO-derived concepts. Map banking products to FIBO financial instruments.') }}"

[agent.metadata]
turns_required = "{{ phase_b.turns_required | default(value = '5-8') }}"
total_turns_in_protocol = 70
collaboration_approach = "{{ phase_b.approach | default(value = 'Iterative Refinement with FIBO Semantic Validation') }}"

[[skills]]
id = "phase-b-capability-mapping"
name = "Business Capability Mapping"
description = "Map current and target business capabilities using FIBO concepts"

[skills.input]
type = "TogafPhaseB_Input"
fields = ["stakeholder_requirements", "current_capabilities", "business_context"]

[skills.output]
type = "TogafPhaseB_Output"
artifacts = [{% for artifact in phase_b.artifacts | default(value = ["Current Capability Map", "Target Capability Map", "Gap Analysis Report", "Business Architecture Document"]) %}"{{ artifact }}",{% endfor %}]

[skills.fibo_concepts]
{% for fibo in phase_b.fibo_concepts | default(value = [{"concept": "fibo-fnd:Capability", "mapping": "Core business capability taxonomy"}, {"concept": "fibo-sec:Loan", "mapping": "Lending products mapped to capabilities"}, {"concept": "fibo-sec:Deposit", "mapping": "Deposit products mapped to capabilities"}]) %}
"{{ fibo.concept }}" = "{{ fibo.mapping }}"
{% endfor %}

[skills.turns]
start = {{ phase_b.turn_start | default(value = 9) }}
end = {{ phase_b.turn_end | default(value = 22) }}
arb_gate = {{ phase_b.arb_gate | default(value = 15) }}
arb_reviewer = "{{ phase_b.arb_reviewer | default(value = 'Chief Architect') }}"

[[skills]]
id = "phase-b-fibo-product-mapping"
name = "FIBO Product Mapping"
description = "Map banking products to FIBO financial instruments and regulatory concepts"

[skills.input]
type = "TogafPhaseB_ProductInput"
fields = ["product_catalog", "fibo_concepts", "regulatory_requirements"]

[skills.output]
type = "TogafPhaseB_ProductOutput"
artifacts = ["FIBO Product Mapping", "Regulatory-Capability Matrix"]

[skills.fibo_concepts]
"fibo-sec:Loan" = "Credit products and lending instruments"
"fibo-sec:Deposit" = "Deposit products and account structures"
"fibo-sec:Security" = "Securities and investment products"
"fibo-sec:RegulatoryFramework" = "Regulatory compliance mapping"

[skills.turns]
start = 11
end = 16
arb_gate = 14
arb_reviewer = "Compliance Officer"

[handoff]
from_phase = "B"
to_phase = "C"
validation_criteria = "FIBO semantic consistency maintained; all capabilities mapped"
approval_required_from = ["Chief Architect", "Compliance Officer"]
