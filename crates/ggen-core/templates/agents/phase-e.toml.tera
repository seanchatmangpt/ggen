# Generated by ggen from FIBO-TOGAF ontology
# Pipeline: ontology (.ttl) -> SPARQL SELECT (.rq) -> Tera (.tera) -> this file
# A = mu(O)
#
# TOGAF Phase E: Opportunities and Solutions Agent Configuration
# {{ generated_at | default(value = "2026-03-31") }}

[agent]
name = "{{ phase_e.name | default(value = 'Opportunities and Solutions Agent') }}"
description = "{{ phase_e.description | default(value = 'Handles TOGAF Phase E: Opportunities and Solutions. Identify implementation projects, migration planning. Align solutions with FIBO regulatory requirements and banking standards.') }}"
version = "{{ phase_e.version | default(value = '1.0.0') }}"
phase = "E"
phase_number = {{ phase_e.phase_number | default(value = 5) }}

[agent.system_prompt]
text = "{{ phase_e.system_prompt | default(value = 'You are the Opportunities and Solutions Agent. Identify implementation projects, migration planning. Align solutions with FIBO regulatory requirements and banking standards.') }}"

[agent.metadata]
turns_required = "{{ phase_e.turns_required | default(value = '5-8') }}"
total_turns_in_protocol = 70
collaboration_approach = "{{ phase_e.approach | default(value = 'Iterative Refinement with FIBO Semantic Validation') }}"

[[skills]]
id = "phase-e-opportunity-analysis"
name = "Opportunity Analysis"
description = "Identify and prioritize implementation opportunities"

[skills.input]
type = "TogafPhaseE_Input"
fields = ["technology_architecture", "business_capabilities", "gaps", "regulatory_requirements"]

[skills.output]
type = "TogafPhaseE_Output"
artifacts = [{% for artifact in phase_e.artifacts | default(value = ["Implementation and Migration Strategy", "Opportunity Assessment", "Solution Roadmap", "Investment Analysis"]) %}"{{ artifact }}",{% endfor %}]

[skills.fibo_concepts]
{% for fibo in phase_e.fibo_concepts | default(value = [{"concept": "fibo-fnd:ComplianceRequirement", "mapping": "Maps solution compliance to FIBO regulatory requirements"}, {"concept": "fibo-sec:RegulatoryFramework", "mapping": "Maps solution alignment to FIBO regulatory framework"}]) %}
"{{ fibo.concept }}" = "{{ fibo.mapping }}"
{% endfor %}

[skills.turns]
start = {{ phase_e.turn_start | default(value = 55) }}
end = {{ phase_e.turn_end | default(value = 62) }}
arb_gate = {{ phase_e.arb_gate | default(value = 58) }}
arb_reviewer = "{{ phase_e.arb_reviewer | default(value = 'Chief Architect') }}"

[[skills]]
id = "phase-e-solution-design"
name = "Solution Design"
description = "Design solutions aligned with FIBO regulatory requirements"

[skills.input]
type = "TogafPhaseE_SolutionInput"
fields = ["opportunities", "fibo_requirements", "technology_constraints"]

[skills.output]
type = "TogafPhaseE_SolutionOutput"
artifacts = ["Solution Architecture Document", "FIBO Compliance Matrix", "Cost-Benefit Analysis"]

[skills.fibo_concepts]
"fibo-fnd:ComplianceRequirement" = "Regulatory compliance tracking per solution"
"fibo-sec:RegulatoryFramework" = "Basel III, Dodd-Frank, GDPR alignment"

[skills.turns]
start = 57
end = 61
arb_gate = 59
arb_reviewer = "Compliance Officer"

[handoff]
from_phase = "E"
to_phase = "F"
validation_criteria = "Solutions comply with FIBO regulatory requirements; implementation feasibility verified"
approval_required_from = ["Chief Architect", "Compliance Officer"]
