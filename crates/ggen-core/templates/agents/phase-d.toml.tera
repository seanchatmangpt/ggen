# Generated by ggen from FIBO-TOGAF ontology
# Pipeline: ontology (.ttl) -> SPARQL SELECT (.rq) -> Tera (.tera) -> this file
# A = mu(O)
#
# TOGAF Phase D: Technology Architecture Agent Configuration
# {{ generated_at | default(value = "2026-03-31") }}

[agent]
name = "{{ phase_d.name | default(value = 'Technology Architecture Agent') }}"
description = "{{ phase_d.description | default(value = 'Handles TOGAF Phase D: Technology Architecture. Define platform services, infrastructure, and deployment models. Ensure FIBO semantic interoperability across technology stack.') }}"
version = "{{ phase_d.version | default(value = '1.0.0') }}"
phase = "D"
phase_number = {{ phase_d.phase_number | default(value = 4) }}

[agent.system_prompt]
text = "{{ phase_d.system_prompt | default(value = 'You are the Technology Architecture Agent. Define platform services, infrastructure, and deployment models. Ensure FIBO semantic interoperability across technology stack.') }}"

[agent.metadata]
turns_required = "{{ phase_d.turns_required | default(value = '8-12') }}"
total_turns_in_protocol = 70
collaboration_approach = "{{ phase_d.approach | default(value = 'Iterative Refinement with FIBO Semantic Validation') }}"

[[skills]]
id = "phase-d-platform-architecture"
name = "Platform Architecture"
description = "Define platform services and technology infrastructure"

[skills.input]
type = "TogafPhaseD_Input"
fields = ["data_architecture", "business_requirements", "fibo_semantic_requirements"]

[skills.output]
type = "TogafPhaseD_Output"
artifacts = [{% for artifact in phase_d.artifacts | default(value = ["Technology Architecture Catalog", "Platform Service Inventory", "Infrastructure Model", "Integration Architecture"]) %}"{{ artifact }}",{% endfor %}]

[skills.fibo_concepts]
{% for fibo in phase_d.fibo_concepts | default(value = [{"concept": "fibo-fnd:PlatformService", "mapping": "Maps to reusable technology capabilities"}, {"concept": "fibo-fnd:TechnologyInterface", "mapping": "Maps to standardized integration interfaces"}]) %}
"{{ fibo.concept }}" = "{{ fibo.mapping }}"
{% endfor %}

[skills.turns]
start = {{ phase_d.turn_start | default(value = 41) }}
end = {{ phase_d.turn_end | default(value = 54) }}
arb_gate = {{ phase_d.arb_gate | default(value = 48) }}
arb_reviewer = "{{ phase_d.arb_reviewer | default(value = 'Chief Architect') }}"

[[skills]]
id = "phase-d-fibo-interoperability"
name = "FIBO Interoperability Design"
description = "Ensure FIBO semantic interoperability across technology stack"

[skills.input]
type = "TogafPhaseD_InteropInput"
fields = ["platform_services", "fibo_concepts", "integration_patterns"]

[skills.output]
type = "TogafPhaseD_InteropOutput"
artifacts = ["FIBO Interoperability Specification", "API Semantic Contract", "Technology-FIBO Mapping"]

[skills.fibo_concepts]
"fibo-fnd:PlatformService" = "Customer Data API, Account Aggregation, Risk Engine"
"fibo-fnd:TechnologyInterface" = "REST API, GraphQL, gRPC, Message Queue"

[skills.turns]
start = 46
end = 52
arb_gate = 49
arb_reviewer = "Chief Architect"

[handoff]
from_phase = "D"
to_phase = "E"
validation_criteria = "FIBO semantic interoperability verified; technology stack supports all FIBO concepts"
approval_required_from = ["Chief Architect"]
