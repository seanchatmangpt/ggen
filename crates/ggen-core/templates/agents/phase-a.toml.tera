# Generated by ggen from FIBO-TOGAF ontology
# Pipeline: ontology (.ttl) -> SPARQL SELECT (.rq) -> Tera (.tera) -> this file
# A = mu(O)
#
# TOGAF Phase A: Architecture Vision Agent Configuration
# {{ generated_at | default(value = "2026-03-31") }}

[agent]
name = "{{ phase_a.name | default(value = 'Architecture Vision Agent') }}"
description = "{{ phase_a.description | default(value = 'Handles TOGAF Phase A: Architecture Vision. Gather stakeholder requirements, define vision, establish scope for Fortune 500 bank transformation.') }}"
version = "{{ phase_a.version | default(value = '1.0.0') }}"
phase = "A"
phase_number = {{ phase_a.phase_number | default(value = 1) }}

[agent.system_prompt]
text = "{{ phase_a.system_prompt | default(value = 'You are the Architecture Vision Agent. Gather stakeholder requirements, define vision, establish scope for Fortune 500 bank transformation. Use FIBO concepts to map regulatory requirements and business entities.') }}"

[agent.metadata]
turns_required = "{{ phase_a.turns_required | default(value = '3-5') }}"
total_turns_in_protocol = 70
collaboration_approach = "{{ phase_a.approach | default(value = 'Iterative Refinement with FIBO Semantic Validation') }}"

[[skills]]
id = "phase-a-stakeholder-analysis"
name = "Stakeholder Analysis"
description = "Identify and map stakeholders, capture requirements and constraints"

[skills.input]
type = "TogafPhaseA_Input"
fields = ["stakeholder_list", "business_context", "constraints"]

[skills.output]
type = "TogafPhaseA_Output"
artifacts = [{% for artifact in phase_a.artifacts | default(value = ["Stakeholder Map", "Requirements Statement", "Architecture Vision", "Statement of Architecture Work"]) %}"{{ artifact }}",{% endfor %}]

[skills.fibo_concepts]
{% for fibo in phase_a.fibo_concepts | default(value = [{"concept": "fibo-fnd:LegalPerson", "mapping": "Maps to stakeholder identification and organizational entities"}, {"concept": "fibo-fnd:Organization", "mapping": "Maps to organizational structure and governance"}]) %}
"{{ fibo.concept }}" = "{{ fibo.mapping }}"
{% endfor %}

[skills.turns]
start = {{ phase_a.turn_start | default(value = 1) }}
end = {{ phase_a.turn_end | default(value = 8) }}
arb_gate = {{ phase_a.arb_gate | default(value = 5) }}
arb_reviewer = "{{ phase_a.arb_reviewer | default(value = 'Chief Architect') }}"

[[skills]]
id = "phase-a-vision-definition"
name = "Architecture Vision Definition"
description = "Define the architecture vision and scope aligned with business strategy"

[skills.input]
type = "TogafPhaseA_VisionInput"
fields = ["business_requirements", "constraints", "regulatory_context"]

[skills.output]
type = "TogafPhaseA_VisionOutput"
artifacts = ["Architecture Vision Document", "Scope Definition", "Key Decisions"]

[skills.fibo_concepts]
"fibo-fnd:LegalPerson" = "Legal entity definitions for scope boundary"
"fibo-fnd:Organization" = "Organizational boundaries and governance"

[skills.turns]
start = 3
end = 6
arb_gate = 5
arb_reviewer = "Chief Architect"

[handoff]
from_phase = "A"
to_phase = "B"
validation_criteria = "FIBO semantic consistency maintained"
approval_required_from = ["Chief Architect"]
