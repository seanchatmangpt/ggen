# Generated by ggen from FIBO-TOGAF ontology
# Pipeline: ontology (.ttl) -> SPARQL SELECT (.rq) -> Tera (.tera) -> this file
# A = mu(O)
#
# TOGAF Phase C: Data Architecture Agent Configuration (Heaviest FIBO)
# {{ generated_at | default(value = "2026-03-31") }}

[agent]
name = "{{ phase_c.name | default(value = 'Information Systems Architectures Agent') }}"
description = "{{ phase_c.description | default(value = 'Handles TOGAF Phase C: Information Systems Architectures (Data & Application). Define data entities, services, and contracts using FIBO semantic structures. Map banking data to FIBO legal entities and financial instruments.') }}"
version = "{{ phase_c.version | default(value = '1.0.0') }}"
phase = "C"
phase_number = {{ phase_c.phase_number | default(value = 3) }}

[agent.system_prompt]
text = "{{ phase_c.system_prompt | default(value = 'You are the Data Architecture Agent. Define data entities, services, and contracts using FIBO semantic structures. Map banking data to FIBO legal entities and financial instruments. This phase has the heaviest FIBO semantic mapping requirements.') }}"

[agent.metadata]
turns_required = "{{ phase_c.turns_required | default(value = '8-12') }}"
total_turns_in_protocol = 70
collaboration_approach = "{{ phase_c.approach | default(value = 'Iterative Refinement with FIBO Semantic Validation') }}"
fibo_intensity = "heaviest"

[[skills]]
id = "phase-c-data-entity-definition"
name = "Data Entity Definition"
description = "Define data entities with FIBO semantic alignment for banking domain"

[skills.input]
type = "TogafPhaseC_Input"
fields = ["business_architecture", "fibo_concepts", "data_requirements"]

[skills.output]
type = "TogafPhaseC_Output"
artifacts = [{% for artifact in phase_c.artifacts | default(value = ["Data Entity Catalog", "Data Entity Relationship Diagram", "FIBO Concept Alignment Report", "Application Architecture Document"]) %}"{{ artifact }}",{% endfor %}]

[skills.fibo_concepts]
{% for fibo in phase_c.fibo_concepts | default(value = [{"concept": "fibo-fnd:LegalPerson", "mapping": "Core data entity for legal entity identification"}, {"concept": "fibo-fnd:Contract", "mapping": "Contract data model with FIBO contract semantics"}, {"concept": "fibo-sec:Security", "mapping": "Financial instrument data model"}, {"concept": "fibo-sec:Loan", "mapping": "Loan entity with FIBO lending semantics"}, {"concept": "fibo-sec:LoanContract", "mapping": "Loan contract data with covenant structures"}, {"concept": "fibo-sec:Deposit", "mapping": "Deposit account data model"}]) %}
"{{ fibo.concept }}" = "{{ fibo.mapping }}"
{% endfor %}

[skills.turns]
start = {{ phase_c.turn_start | default(value = 23) }}
end = {{ phase_c.turn_end | default(value = 40) }}
arb_gate = {{ phase_c.arb_gate | default(value = 30) }}
arb_reviewer = "{{ phase_c.arb_reviewer | default(value = 'Chief Architect') }}"

[[skills]]
id = "phase-c-fibo-semantic-mapping"
name = "FIBO Semantic Mapping"
description = "Map data entities to FIBO ontology concepts with full semantic alignment"

[skills.input]
type = "TogafPhaseC_FiboInput"
fields = ["data_entities", "fibo_ontology", "validation_rules"]

[skills.output]
type = "TogafPhaseC_FiboOutput"
artifacts = ["FIBO Semantic Mapping Document", "SHACL Validation Shapes", "FIBO Alignment Report"]

[skills.fibo_concepts]
"fibo-fnd:LegalPerson" = "Legal person data model with jurisdiction attributes"
"fibo-fnd:Organization" = "Organization hierarchy and governance structures"
"fibo-fnd:Contract" = "Contract lifecycle with terms, parties, dates"
"fibo-sec:Loan" = "Loan principal, rate, term, collateral"
"fibo-sec:LoanContract" = "Loan covenants, default conditions"
"fibo-sec:Security" = "Instrument ID, issuer, type, price"
"fibo-sec:Deposit" = "Account, balance, rate, maturity"
"fibo-fnd:ComplianceRequirement" = "Regulatory requirement tracking"

[skills.turns]
start = 28
end = 38
arb_gate = 33
arb_reviewer = "Compliance Officer"

[handoff]
from_phase = "C"
to_phase = "D"
validation_criteria = "FIBO semantic consistency maintained; all data entities mapped to FIBO concepts; SHACL validation passes"
approval_required_from = ["Chief Architect", "Compliance Officer"]
