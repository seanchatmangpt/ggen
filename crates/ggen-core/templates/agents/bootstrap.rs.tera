        {% for phase in phases | default(value = [{"id": "A", "handler": "PhaseAHandler", "start": 1, "end": 8}, {"id": "B", "handler": "PhaseBHandler", "start": 9, "end": 22}, {"id": "C", "handler": "PhaseCHandler", "start": 23, "end": 40}, {"id": "D", "handler": "PhaseDHandler", "start": 41, "end": 54}, {"id": "E", "handler": "PhaseEHandler", "start": 55, "end": 62}, {"id": "F", "handler": "PhaseFHandler", "start": 63, "end": 70}]) %}
        // Phase {{ phase.id }}: {{ phase.description | default(value = "TOGAF Phase " + phase.id) }}
