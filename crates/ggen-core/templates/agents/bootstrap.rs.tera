}

// ---------------------------------------------------------------------------
// Bootstrap
// ---------------------------------------------------------------------------

pub struct TogafAgentBootstrap {
    agents: HashMap<String, AgentHandle>,
    config: BootstrapConfig,
}

impl TogafAgentBootstrap {
    /// Create a new bootstrap instance with default configuration.
    pub fn new(config: BootstrapConfig) -> Self {
        Self {
            agents: HashMap::new(),
            config,
        }
    }

    /// Register an agent handler for a phase.
    ///
    /// # Errors
    ///
    /// Returns `BootstrapError::AgentAlreadyRegistered` if a handler for the
    /// given phase is already registered.
    pub fn register_agent(
        &mut self,
        phase: String,
        handler: String,
        turn_start: usize,
        turn_end: usize,
    ) -> Result<(), BootstrapError> {
        if self.agents.contains_key(&phase) {
            return Err(BootstrapError::AgentAlreadyRegistered(phase));
        }
        self.agents.insert(
            phase.clone(),
            AgentHandle {
                phase,
                handler,
                turn_start,
                turn_end,
                status: AgentHandleStatus::Stopped,
            },
        );
        Ok(())
    }

    /// Start all registered agents, transitioning them from `Stopped` to `Running`.
    ///
    /// # Errors
    ///
    /// Returns an error if any agent fails to start (e.g., missing handler).
    pub fn start_all(&mut self) -> Result<Vec<&AgentHandle>, BootstrapError> {
        let mut started = Vec::new();
        for (phase, handle) in self.agents.iter_mut() {
            handle.status = AgentHandleStatus::Starting;
            handle.status = AgentHandleStatus::Running;
            started.push(handle);
            tracing::info!(
                phase = phase.as_str(),
                handler = handle.handler.as_str(),
                turns = format!("{}-{}", handle.turn_start, handle.turn_end),
                "TOGAF agent started",
            );
        }
        Ok(started)
    }

    /// Stop all running agents.
    pub fn stop_all(&mut self) {
        for (phase, handle) in self.agents.iter_mut() {
            handle.status = AgentHandleStatus::Stopped;
            tracing::info!(phase = phase.as_str(), "TOGAF agent stopped");
        }
    }

    /// Get the agent handle for a specific phase.
    pub fn get_agent(&self, phase: &str) -> Option<&AgentHandle> {
        self.agents.get(phase)
    }

    /// Get the agent handle for a specific phase (mutable).
    pub fn get_agent_mut(&mut self, phase: &str) -> Option<&mut AgentHandle> {
        self.agents.get_mut(phase)
    }

    /// Get all registered agent handles.
    pub fn list_agents(&self) -> Vec<&AgentHandle> {
        self.agents.values().collect()
    }

    /// Get the bootstrap configuration.
    pub fn config(&self) -> &BootstrapConfig {
        &self.config
    }

    /// Resolve which phase agent should handle a given turn number.
    ///
    /// # Errors
    ///
    /// Returns `BootstrapError::HandlerNotFound` if no agent covers the turn.
    pub fn resolve_turn(&self, turn: usize) -> Result<&AgentHandle, BootstrapError> {
        for handle in self.agents.values() {
            if turn >= handle.turn_start && turn <= handle.turn_end {
                return Ok(handle);
            }
        }
        Err(BootstrapError::HandlerNotFound(format!(
            "no agent registered for turn {}",
            turn,
        )))
    }

    /// Count the total number of registered agents.
    pub fn agent_count(&self) -> usize {
        self.agents.len()
    }
}

