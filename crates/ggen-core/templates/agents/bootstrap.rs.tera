}

#[derive(Debug, Error)]
pub enum BootstrapError {
    #[error("Agent already registered for phase: {0}")]
    AgentAlreadyRegistered(String),

    #[error("Phase handler not found: {0}")]
    HandlerNotFound(String),

    #[error("Phase out of order: expected {expected}, got {actual}")]
    PhaseOutOfOrder { expected: String, actual: String },

