// ---------------------------------------------------------------------------
// Tests (Chicago TDD: real collaborators, no mocks)
// ---------------------------------------------------------------------------

#[cfg(test)]
mod tests {
    use super::*;

    fn default_bootstrap() -> TogafAgentBootstrap {
        TogafAgentBootstrapBuilder::new().build().expect("bootstrap build should succeed")
    }

    #[test]
    fn test_bootstrap_registers_all_six_phases() {
        let bootstrap = default_bootstrap();
        assert_eq!(bootstrap.agent_count(), 6);
    }

    #[test]
    fn test_bootstrap_phase_order() {
        let bootstrap = default_bootstrap();
        assert!(bootstrap.get_agent("A").is_some());
        assert!(bootstrap.get_agent("B").is_some());
        assert!(bootstrap.get_agent("C").is_some());
        assert!(bootstrap.get_agent("D").is_some());
        assert!(bootstrap.get_agent("E").is_some());
        assert!(bootstrap.get_agent("F").is_some());
    }

    #[test]
    fn test_bootstrap_turn_ranges() {
        let bootstrap = default_bootstrap();
        let phase_a = bootstrap.get_agent("A").expect("phase A should exist");
        assert_eq!(phase_a.turn_start, 1);
        assert_eq!(phase_a.turn_end, 8);

        let phase_f = bootstrap.get_agent("F").expect("phase F should exist");
        assert_eq!(phase_f.turn_start, 63);
        assert_eq!(phase_f.turn_end, 70);
    }

    #[test]
    fn test_bootstrap_turn_resolution() {
        let bootstrap = default_bootstrap();
        assert_eq!(bootstrap.resolve_turn(1).expect("turn 1").phase, "A");
        assert_eq!(bootstrap.resolve_turn(8).expect("turn 8").phase, "A");
        assert_eq!(bootstrap.resolve_turn(9).expect("turn 9").phase, "B");
        assert_eq!(bootstrap.resolve_turn(22).expect("turn 22").phase, "B");
        assert_eq!(bootstrap.resolve_turn(23).expect("turn 23").phase, "C");
        assert_eq!(bootstrap.resolve_turn(40).expect("turn 40").phase, "C");
        assert_eq!(bootstrap.resolve_turn(41).expect("turn 41").phase, "D");
        assert_eq!(bootstrap.resolve_turn(54).expect("turn 54").phase, "D");
        assert_eq!(bootstrap.resolve_turn(55).expect("turn 55").phase, "E");
        assert_eq!(bootstrap.resolve_turn(62).expect("turn 62").phase, "E");
        assert_eq!(bootstrap.resolve_turn(63).expect("turn 63").phase, "F");
        assert_eq!(bootstrap.resolve_turn(70).expect("turn 70").phase, "F");
    }

    #[test]
    fn test_bootstrap_turn_out_of_range() {
        let bootstrap = default_bootstrap();
        assert!(bootstrap.resolve_turn(0).is_err());
        assert!(bootstrap.resolve_turn(71).is_err());
        assert!(bootstrap.resolve_turn(100).is_err());
    }

    #[test]
    fn test_bootstrap_start_all() {
        let mut bootstrap = default_bootstrap();
        let started = bootstrap.start_all().expect("start should succeed");
        assert_eq!(started.len(), 6);
        for handle in &started {
            assert_eq!(handle.status, AgentHandleStatus::Running);
        }
    }

    #[test]
    fn test_bootstrap_stop_all() {
        let mut bootstrap = default_bootstrap();
        let _ = bootstrap.start_all();
        bootstrap.stop_all();
        for handle in bootstrap.list_agents() {
            assert_eq!(handle.status, AgentHandleStatus::Stopped);
        }
    }

    #[test]
    fn test_bootstrap_duplicate_registration() {
        let mut bootstrap = TogafAgentBootstrap::new(BootstrapConfig::default());
        let result = bootstrap.register_agent("A".to_string(), "Handler".to_string(), 1, 8);
        assert!(result.is_ok());
        let result = bootstrap.register_agent("A".to_string(), "Handler2".to_string(), 1, 8);
        assert!(result.is_err());
    }

    #[test]
    fn test_bootstrap_config_defaults() {
        let bootstrap = default_bootstrap();
        let config = bootstrap.config();
        assert_eq!(config.total_turns, 70);
        assert_eq!(config.total_phases, 6);
        assert!(!config.collaboration_approach.is_empty());
    }

    #[test]
    fn test_bootstrap_config_custom() {
        let config = BootstrapConfig {
            total_turns: 100,
            total_phases: 6,
            collaboration_approach: "Custom".to_string(),
            validation_frequency: "Every turn".to_string(),
        };
        let bootstrap = TogafAgentBootstrapBuilder::new()
            .with_config(config)
            .build()
            .expect("build should succeed");
        assert_eq!(bootstrap.config().total_turns, 100);
        assert_eq!(bootstrap.config().validation_frequency, "Every turn");
    }

    #[test]
    fn test_agent_handle_status_display() {
        assert_eq!(format!("{}", AgentHandleStatus::Running), "running");
        assert_eq!(format!("{}", AgentHandleStatus::Stopped), "stopped");
        assert_eq!(format!("{}", AgentHandleStatus::Error), "error");
    }

    #[test]
    fn test_agent_handle_serialization() {
        let handle = AgentHandle {
            phase: "A".to_string(),
            handler: "PhaseAHandler".to_string(),
            turn_start: 1,
            turn_end: 8,
            status: AgentHandleStatus::Running,
        };
        let json = serde_json::to_string(&handle).expect("serialization should succeed");
        assert!(json.contains("\"phase\":\"A\""));
        assert!(json.contains("\"status\":\"running\""));
    }
}
