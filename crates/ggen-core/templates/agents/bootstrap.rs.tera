impl Default for BootstrapConfig {
    fn default() -> Self {
        Self {
            total_turns: 70,
            total_phases: 6,
            collaboration_approach: "Iterative Refinement with FIBO Semantic Validation".to_string(),
            validation_frequency: "Every 5 turns".to_string(),
        }
