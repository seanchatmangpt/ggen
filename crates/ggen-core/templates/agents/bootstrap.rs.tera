    pub turn_start: usize,
    pub turn_end: usize,
    pub status: AgentHandleStatus,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
#[serde(rename_all = "lowercase")]
pub enum AgentHandleStatus {
    Stopped,
    Starting,
    Running,
    Stopping,
    Error,
}

impl std::fmt::Display for AgentHandleStatus {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            AgentHandleStatus::Stopped => write!(f, "stopped"),
            AgentHandleStatus::Starting => write!(f, "starting"),
            AgentHandleStatus::Running => write!(f, "running"),
            AgentHandleStatus::Stopping => write!(f, "stopping"),
            AgentHandleStatus::Error => write!(f, "error"),
        }
    }
}

#[derive(Debug, Clone, Serialize, Deserialize)]
