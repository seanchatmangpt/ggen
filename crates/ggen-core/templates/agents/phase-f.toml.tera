# Generated by ggen from FIBO-TOGAF ontology
# Pipeline: ontology (.ttl) -> SPARQL SELECT (.rq) -> Tera (.tera) -> this file
# A = mu(O)
#
# TOGAF Phase F: Migration Planning Agent Configuration
# {{ generated_at | default(value = "2026-03-31") }}

[agent]
name = "{{ phase_f.name | default(value = 'Migration Planning Agent') }}"
description = "{{ phase_f.description | default(value = 'Handles TOGAF Phase F: Migration Planning. Create detailed migration plans, transition architectures. Ensure FIBO semantic continuity during migration phases.') }}"
version = "{{ phase_f.version | default(value = '1.0.0') }}"
phase = "F"
phase_number = {{ phase_f.phase_number | default(value = 6) }}

[agent.system_prompt]
text = "{{ phase_f.system_prompt | default(value = 'You are the Migration Planning Agent. Create detailed migration plans, transition architectures. Ensure FIBO semantic continuity during migration phases.') }}"

[agent.metadata]
turns_required = "{{ phase_f.turns_required | default(value = '5-8') }}"
total_turns_in_protocol = 70
collaboration_approach = "{{ phase_f.approach | default(value = 'Iterative Refinement with FIBO Semantic Validation') }}"

[[skills]]
id = "phase-f-migration-planning"
name = "Migration Planning"
description = "Create detailed migration plans with FIBO semantic continuity"

[skills.input]
type = "TogafPhaseF_Input"
fields = ["implementation_strategy", "solution_architecture", "fibo_concepts", "transition_requirements"]

[skills.output]
type = "TogafPhaseF_Output"
artifacts = [{% for artifact in phase_f.artifacts | default(value = ["Migration Plan", "Transition Architecture", "Implementation Roadmap", "Risk Assessment"]) %}"{{ artifact }}",{% endfor %}]

[skills.fibo_concepts]
{% for fibo in phase_f.fibo_concepts | default(value = [{"concept": "fibo-fnd:TransitionState", "mapping": "Maps migration state transitions to FIBO concepts"}, {"concept": "fibo-fnd:GovernanceProcess", "mapping": "Maps migration governance to FIBO governance processes"}]) %}
"{{ fibo.concept }}" = "{{ fibo.mapping }}"
{% endfor %}

[skills.turns]
start = {{ phase_f.turn_start | default(value = 63) }}
end = {{ phase_f.turn_end | default(value = 70) }}
arb_gate = {{ phase_f.arb_gate | default(value = 66) }}
arb_reviewer = "{{ phase_f.arb_reviewer | default(value = 'Chief Architect') }}"

[[skills]]
id = "phase-f-fibo-continuity"
name = "FIBO Semantic Continuity"
description = "Ensure FIBO semantic continuity throughout migration phases"

[skills.input]
type = "TogafPhaseF_ContinuityInput"
fields = ["migration_plan", "fibo_concepts", "state_transitions", "validation_rules"]

[skills.output]
type = "TogafPhaseF_ContinuityOutput"
artifacts = ["FIBO Continuity Verification", "Migration Validation Report", "Semantic Consistency Audit"]

[skills.fibo_concepts]
"fibo-fnd:TransitionState" = "State machine for FIBO concept migrations"
"fibo-fnd:GovernanceProcess" = "Governance checkpoints during migration"

[skills.turns]
start = 65
end = 69
arb_gate = 67
arb_reviewer = "Chief Architect"

[handoff]
from_phase = "F"
to_phase = "complete"
validation_criteria = "FIBO semantic continuity verified; migration plan complete; all artifacts finalized"
approval_required_from = ["Chief Architect", "Executive Sponsor"]
