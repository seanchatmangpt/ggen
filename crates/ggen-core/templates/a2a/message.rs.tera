use chrono::{DateTime, Utc};
use serde::{Deserialize, Serialize};
use uuid::Uuid;

// ============================================================================
// MESSAGE ROLE
// ============================================================================

/// Role of the message sender in the conversation
///
/// Represents the standard roles in agent-to-agent communication
/// following the conversational agent pattern.
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]
#[serde(rename_all = "lowercase")]
pub enum MessageRole {
    /// Message from a human user or external system
    User,

    /// Message from an AI agent or assistant
    Assistant,

    /// System-level message for configuration or control
    System,
}

impl MessageRole {
    /// Check if this role represents an automated agent
    #[must_use]
    pub const fn is_agent(self) -> bool {
        matches!(self, Self::Assistant | Self::System)
    }

    /// Check if this role represents a human user
    #[must_use]
    pub const fn is_human(self) -> bool {
        matches!(self, Self::User)
    }

    /// Get the display name for this role
    #[must_use]
    pub const fn display_name(self) -> &'static str {
        match self {
            Self::User => "User",
            Self::Assistant => "Assistant",
            Self::System => "System",
        }
    }
}

impl Default for MessageRole {
    fn default() -> Self {
        Self::User
    }
}

impl std::fmt::Display for MessageRole {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self.display_name())
    }
}

// ============================================================================
// MESSAGE PART
// ============================================================================

/// A single part of a multi-part message
///
/// Parts contain the actual content data with associated MIME type
/// for content negotiation and proper rendering by receiving agents.
#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
pub struct Part {
    /// The content data as text
    pub data: String,

    /// MIME type specifying content format
    ///
    /// Common types:
    /// - `text/plain`: Plain text content
    /// - `text/markdown`: Markdown formatted text
    /// - `application/json`: Structured JSON data
    /// - `application/xml`: XML data
    /// - `image/png`, `image/jpeg`: Binary image data (base64 encoded)
    /// - `application/octet-stream`: Generic binary data
    #[serde(rename = "mimeType")]
    pub mime_type: String,

    /// Optional metadata for this part
    #[serde(skip_serializing_if = "Option::is_none")]
    pub metadata: Option<PartMetadata>,
}

/// Additional metadata for a message part
#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
pub struct PartMetadata {
    /// Optional content size in bytes
    #[serde(skip_serializing_if = "Option::is_none")]
    pub size: Option<usize>,

    /// Optional hash for content verification
    #[serde(skip_serializing_if = "Option::is_none")]
    pub hash: Option<String>,

    /// Optional encoding (e.g., "base64" for binary data)
    #[serde(skip_serializing_if = "Option::is_none")]
    pub encoding: Option<String>,

    /// Additional custom properties
    #[serde(flatten)]
    pub extra: std::collections::HashMap<String, serde_json::Value>,
}

impl Part {
    /// Create a new part with data and MIME type
    #[must_use]
    pub fn new(data: String, mime_type: String) -> Self {
        Self {
            data,
            mime_type,
            metadata: None,
        }
    }

    /// Create a plain text part
    #[must_use]
    pub fn text(data: String) -> Self {
        Self::new(data, "text/plain".to_string())
    }

    /// Create a markdown part
    #[must_use]
    pub fn markdown(data: String) -> Self {
        Self::new(data, "text/markdown".to_string())
    }

    /// Create a JSON part
    #[must_use]
    pub fn json(data: serde_json::Value) -> Self {
        Self::new(
            data.to_string(),
            "application/json".to_string(),
        )
    }

    /// Create a binary part with base64 encoding
    #[must_use]
    pub fn binary(data: Vec<u8>, mime_type: String) -> Self {
        use base64::prelude::*;
        Self {
            data: BASE64_STANDARD.encode(data),
            mime_type,
            metadata: Some(PartMetadata {
                size: Some(data.len()),
                encoding: Some("base64".to_string()),
                hash: None,
                extra: std::collections::HashMap::new(),
            }),
        }
    }

    /// Add metadata to this part
    #[must_use]
    pub fn with_metadata(mut self, metadata: PartMetadata) -> Self {
        self.metadata = Some(metadata);
        self
    }

    /// Check if this part contains text content
    #[must_use]
    pub fn is_text(&self) -> bool {
        self.mime_type.starts_with("text/")
    }

    /// Check if this part contains binary content
    #[must_use]
    pub fn is_binary(&self) -> bool {
        !self.is_text() || self.metadata.as_ref().and_then(|m| m.encoding.as_ref()).map_or(false, |e| e == "base64")
    }

    /// Decode binary data if base64 encoded
    ///
    /// # Errors
    /// Returns error if data is not valid base64
    pub fn decode_binary(&self) -> Result<Vec<u8>, String> {
        use base64::prelude::*;
        if self.is_binary() {
            BASE64_STANDARD
                .decode(&self.data)
                .map_err(|e| format!("Failed to decode base64 data: {}", e))
        } else {
            Err("Part does not contain binary data".to_string())
        }
    }
}

impl Default for Part {
    fn default() -> Self {
        Self::text(String::new())
    }
}

// ============================================================================
// MESSAGE
// ============================================================================

/// A message in agent-to-agent communication
///
/// Messages are the fundamental unit of communication between agents,
/// containing parts (content blocks), role information, and timestamps.
/// Compatible with JSON-RPC 2.0 serialization.
#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
pub struct Message {
    /// Unique message identifier
    #[serde(rename = "messageId")]
    pub message_id: Uuid,

    /// Role of the message sender
    pub role: MessageRole,

    /// Message parts containing the actual content
    ///
    /// Multiple parts support multi-modal content (text + images, etc.)
    pub parts: Vec<Part>,

    /// Message creation timestamp
    #[serde(rename = "timestamp")]
    pub timestamp: DateTime<Utc>,

    /// Optional parent message ID for threading
    #[serde(skip_serializing_if = "Option::is_none")]
    pub parent_id: Option<Uuid>,

    /// Optional conversation ID for grouping related messages
    #[serde(skip_serializing_if = "Option::is_none")]
    pub conversation_id: Option<Uuid>,

    /// Optional metadata for extensibility
    #[serde(skip_serializing_if = "Option::is_none")]
    pub metadata: Option<std::collections::HashMap<String, serde_json::Value>>,
}

impl Message {
    /// Get the primary text content from the first text part
    ///
    /// Returns the first part with a text MIME type, or empty string if none found.
    #[must_use]
    pub fn text_content(&self) -> String {
        self.parts
            .iter()
            .find(|p| p.is_text())
            .map(|p| p.data.clone())
            .unwrap_or_default()
    }

    /// Get all text parts
    #[must_use]
    pub fn text_parts(&self) -> Vec<&Part> {
        self.parts.iter().filter(|p| p.is_text()).collect()
    }

    /// Get all binary parts
    #[must_use]
    pub fn binary_parts(&self) -> Vec<&Part> {
        self.parts.iter().filter(|p| p.is_binary()).collect()
    }

    /// Check if this is a reply to another message
    #[must_use]
    pub fn is_reply(&self) -> bool {
        self.parent_id.is_some()
    }

    /// Get the total size of all parts in bytes
    #[must_use]
    pub fn total_size(&self) -> usize {
        self.parts.iter().map(|p| p.data.len()).sum()
    }
}

impl Default for Message {
    fn default() -> Self {
        Self {
            message_id: Uuid::new_v4(),
            role: MessageRole::default(),
            parts: Vec::new(),
            timestamp: Utc::now(),
            parent_id: None,
            conversation_id: None,
            metadata: None,
        }
    }
}

