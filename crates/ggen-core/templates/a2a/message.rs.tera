impl Default for PartMetadata {
    fn default() -> Self {
        Self {
            size: None,
            hash: None,
            encoding: None,
            extra: std::collections::HashMap::new(),
        }
    }
}

// ============================================================================
// VALIDATION
// ============================================================================

impl Message {
    /// Validate the message structure
    ///
    /// # Errors
    /// Returns a String describing validation failures
    pub fn validate(&self) -> Result<(), String> {
        if self.parts.is_empty() {
            return Err("Message must have at least one part".to_string());
        }

        for (idx, part) in self.parts.iter().enumerate() {
            if part.mime_type.is_empty() {
                return Err(format!("Part {} has empty MIME type", idx));
            }
        }

        Ok(())
    }

    /// Check if the message is valid
    #[must_use]
    pub fn is_valid(&self) -> bool {
        self.validate().is_ok()
    }
}

