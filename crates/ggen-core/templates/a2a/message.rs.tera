/// Builder for creating Message instances with a fluent API
///
/// Provides a convenient, chainable interface for constructing messages
/// with all optional fields.
#[derive(Debug, Default)]
pub struct MessageBuilder {
    message_id: Option<Uuid>,
    role: MessageRole,
    parts: Vec<Part>,
    timestamp: Option<DateTime<Utc>>,
    parent_id: Option<Uuid>,
    conversation_id: Option<Uuid>,
    metadata: Option<std::collections::HashMap<String, serde_json::Value>>,
}

impl MessageBuilder {
    /// Create a new message builder with default values
    #[must_use]
    pub fn new() -> Self {
        Self::default()
    }

    /// Set a specific message ID
    ///
    /// If not set, a random UUID will be generated on build.
    #[must_use]
    pub fn message_id(mut self, id: Uuid) -> Self {
        self.message_id = Some(id);
        self
    }

    /// Set the message role
    #[must_use]
    pub const fn role(mut self, role: MessageRole) -> Self {
        self.role = role;
        self
    }

    /// Set the message role to User
    #[must_use]
    pub const fn as_user(mut self) -> Self {
        self.role = MessageRole::User;
        self
    }

    /// Set the message role to Assistant
    #[must_use]
    pub const fn as_assistant(mut self) -> Self {
        self.role = MessageRole::Assistant;
        self
    }

    /// Set the message role to System
    #[must_use]
    pub const fn as_system(mut self) -> Self {
        self.role = MessageRole::System;
        self
    }

    /// Add a part to the message
    #[must_use]
    pub fn add_part(mut self, part: Part) -> Self {
        self.parts.push(part);
        self
    }

    /// Add a text part to the message
    #[must_use]
    pub fn add_text(mut self, text: String) -> Self {
        self.parts.push(Part::text(text));
        self
    }

    /// Add a markdown part to the message
    #[must_use]
    pub fn add_markdown(mut self, text: String) -> Self {
        self.parts.push(Part::markdown(text));
        self
    }

    /// Set all parts for the message
    #[must_use]
    pub fn parts(mut self, parts: Vec<Part>) -> Self {
        self.parts = parts;
        self
    }

    /// Set a single text part (replaces all existing parts)
    #[must_use]
    pub fn text(mut self, text: String) -> Self {
        self.parts = vec![Part::text(text)];
        self
    }

    /// Set the message timestamp
    #[must_use]
    pub fn timestamp(mut self, timestamp: DateTime<Utc>) -> Self {
        self.timestamp = Some(timestamp);
        self
    }

    /// Set the parent message ID for threading
    #[must_use]
    pub fn parent_id(mut self, parent_id: Uuid) -> Self {
        self.parent_id = Some(parent_id);
        self
    }

    /// Set the conversation ID
    #[must_use]
    pub fn conversation_id(mut self, conversation_id: Uuid) -> Self {
        self.conversation_id = Some(conversation_id);
        self
    }

    /// Add metadata to the message
    #[must_use]
    pub fn add_metadata(mut self, key: String, value: serde_json::Value) -> Self {
        self.metadata
            .get_or_insert_with(std::collections::HashMap::new)
            .insert(key, value);
        self
    }

    /// Set the entire metadata map
    #[must_use]
    pub fn metadata(mut self, metadata: std::collections::HashMap<String, serde_json::Value>) -> Self {
        self.metadata = Some(metadata);
        self
    }

    /// Build the Message instance
    ///
    /// # Panics
    /// Panics if no parts are added to the message.
    #[must_use]
    pub fn build(self) -> Message {
        assert!(!self.parts.is_empty(), "Message must have at least one part");

        Message {
            message_id: self.message_id.unwrap_or_else(Uuid::new_v4),
            role: self.role,
            parts: self.parts,
            timestamp: self.timestamp.unwrap_or_else(Utc::now),
            parent_id: self.parent_id,
            conversation_id: self.conversation_id,
            metadata: self.metadata,
        }
    }

    /// Build the Message instance, returning None if validation fails
    #[must_use]
    pub fn try_build(self) -> Option<Message> {
        if self.parts.is_empty() {
            return None;
        }
        Some(Message {
            message_id: self.message_id.unwrap_or_else(Uuid::new_v4),
            role: self.role,
            parts: self.parts,
            timestamp: self.timestamp.unwrap_or_else(Utc::now),
            parent_id: self.parent_id,
            conversation_id: self.conversation_id,
            metadata: self.metadata,
        })
    }
}

// ============================================================================
// CONVENIENCE FUNCTIONS
// ============================================================================

/// Create a simple user message with text content
#[must_use]
pub fn user_message(text: String) -> Message {
    MessageBuilder::new()
        .as_user()
        .text(text)
        .build()
}

/// Create a simple assistant message with text content
#[must_use]
pub fn assistant_message(text: String) -> Message {
    MessageBuilder::new()
        .as_assistant()
        .text(text)
        .build()
}

/// Create a simple system message with text content
#[must_use]
pub fn system_message(text: String) -> Message {
    MessageBuilder::new()
        .as_system()
        .text(text)
        .build()
}

/// Create a reply to an existing message
#[must_use]
pub fn reply_to(original: &Message, text: String, role: MessageRole) -> Message {
    MessageBuilder::new()
        .role(role)
        .text(text)
        .parent_id(original.message_id)
        .conversation_id(original.conversation_id.unwrap_or_else(|| {
            // If no conversation ID, use the original message's ID as conversation root
            original.message_id
        }))
        .build()
}

/// Create a user reply to a message
#[must_use]
pub fn user_reply(original: &Message, text: String) -> Message {
    reply_to(original, text, MessageRole::User)
}

/// Create an assistant reply to a message
#[must_use]
pub fn assistant_reply(original: &Message, text: String) -> Message {
    reply_to(original, text, MessageRole::Assistant)
}

