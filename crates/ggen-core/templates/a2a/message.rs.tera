/// JSON-RPC 2.0 request wrapper for messages
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct MessageRequest {
    /// JSON-RPC version
    pub jsonrpc: String,

    /// Request method name
    pub method: String,

    /// Request parameters containing the message
    pub params: MessageParams,

    /// Request identifier
    pub id: serde_json::Value,
}

/// Parameters for a message request
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct MessageParams {
    /// The message being sent
    pub message: Message,

    /// Target agent ID (optional for broadcast)
    #[serde(skip_serializing_if = "Option::is_none")]
    pub target: Option<String>,
}

impl MessageRequest {
    /// Create a new JSON-RPC request for a message
    #[must_use]
    pub fn new(method: String, message: Message, id: serde_json::Value) -> Self {
        Self {
            jsonrpc: "2.0".to_string(),
            method,
            params: MessageParams {
                message,
                target: None,
            },
            id,
        }
    }

    /// Set the target agent
    #[must_use]
    pub fn with_target(mut self, target: String) -> Self {
        self.params.target = Some(target);
        self
    }
}

/// JSON-RPC 2.0 response wrapper for messages
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct MessageResponse {
    /// JSON-RPC version
    pub jsonrpc: String,

    /// Response result (if successful)
    #[serde(skip_serializing_if = "Option::is_none")]
    pub result: Option<MessageResponseResult>,

    /// Error (if failed)
    #[serde(skip_serializing_if = "Option::is_none")]
    pub error: Option<MessageError>,

    /// Response identifier matching the request
    pub id: serde_json::Value,
}

/// Result data for a successful message response
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct MessageResponseResult {
    /// The processed message (optional)
    #[serde(skip_serializing_if = "Option::is_none")]
    pub message: Option<Message>,

    /// Additional response data
    #[serde(flatten)]
    pub extra: std::collections::HashMap<String, serde_json::Value>,
}

/// JSON-RPC error structure
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct MessageError {
    /// Error code
    pub code: i32,

    /// Error message
    pub message: String,

    /// Additional error data
    #[serde(skip_serializing_if = "Option::is_none")]
    pub data: Option<serde_json::Value>,
}

impl MessageResponse {
    /// Create a successful response
    #[must_use]
    pub fn success(id: serde_json::Value, result: MessageResponseResult) -> Self {
        Self {
            jsonrpc: "2.0".to_string(),
            result: Some(result),
            error: None,
            id,
        }
    }

    /// Create an error response
    #[must_use]
    pub fn error(id: serde_json::Value, error: MessageError) -> Self {
        Self {
            jsonrpc: "2.0".to_string(),
            result: None,
            error: Some(error),
            id,
        }
    }

    /// Check if response is successful
    #[must_use]
    pub fn is_success(&self) -> bool {
        self.error.is_none()
    }
}

// ============================================================================
// TESTS
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_message_role_display() {
        assert_eq!(MessageRole::User.display_name(), "User");
        assert_eq!(MessageRole::Assistant.display_name(), "Assistant");
        assert_eq!(MessageRole::System.display_name(), "System");
    }

    #[test]
    fn test_message_role_is_agent() {
        assert!(MessageRole::Assistant.is_agent());
        assert!(MessageRole::System.is_agent());
        assert!(!MessageRole::User.is_agent());
    }

    #[test]
    fn test_message_role_is_human() {
        assert!(MessageRole::User.is_human());
        assert!(!MessageRole::Assistant.is_human());
        assert!(!MessageRole::System.is_human());
    }

    #[test]
    fn test_part_creation() {
        let part = Part::text("Hello, world!".to_string());
        assert_eq!(part.data, "Hello, world!");
        assert_eq!(part.mime_type, "text/plain");
        assert!(part.is_text());
        assert!(!part.is_binary());
    }

    #[test]
    fn test_part_markdown() {
        let part = Part::markdown("**Bold** text".to_string());
        assert_eq!(part.data, "**Bold** text");
        assert_eq!(part.mime_type, "text/markdown");
    }

    #[test]
    fn test_part_binary() {
        let data = b"Hello, world!";
        let part = Part::binary(data.to_vec(), "application/octet-stream".to_string());
        assert!(part.is_binary());
        assert_eq!(part.metadata.as_ref().unwrap().encoding, Some("base64".to_string()));
        assert_eq!(part.metadata.as_ref().unwrap().size, Some(data.len()));
    }

    #[test]
    fn test_part_decode_binary() {
        let original = b"Hello, world!";
        let part = Part::binary(original.to_vec(), "application/octet-stream".to_string());
        let decoded = part.decode_binary().unwrap();
        assert_eq!(decoded, original);
    }

    #[test]
    fn test_message_builder() {
        let message = MessageBuilder::new()
            .as_user()
            .text("Test message".to_string())
            .build();

        assert_eq!(message.role, MessageRole::User);
        assert_eq!(message.text_content(), "Test message");
        assert_eq!(message.parts.len(), 1);
    }

    #[test]
    fn test_message_builder_multiple_parts() {
        let message = MessageBuilder::new()
            .as_assistant()
            .add_text("Text part".to_string())
            .add_markdown("**Markdown**".to_string())
            .build();

        assert_eq!(message.parts.len(), 2);
        assert_eq!(message.text_parts().len(), 2);
    }

    #[test]
    fn test_message_conversation() {
        let conv_id = Uuid::new_v4();
        let message = MessageBuilder::new()
            .text("Test".to_string())
            .conversation_id(conv_id)
            .build();

        assert_eq!(message.conversation_id, Some(conv_id));
    }

    #[test]
    fn test_convenience_functions() {
        let user_msg = user_message("User text".to_string());
        assert_eq!(user_msg.role, MessageRole::User);
        assert_eq!(user_msg.text_content(), "User text");

        let asst_msg = assistant_message("Assistant text".to_string());
        assert_eq!(asst_msg.role, MessageRole::Assistant);

        let sys_msg = system_message("System text".to_string());
        assert_eq!(sys_msg.role, MessageRole::System);
    }

    #[test]
    fn test_reply_to() {
        let original = user_message("Original".to_string());
        let reply = assistant_reply(&original, "Reply".to_string());

        assert_eq!(reply.role, MessageRole::Assistant);
        assert_eq!(reply.parent_id, Some(original.message_id));
        assert_eq!(reply.conversation_id, Some(original.message_id));
    }

    #[test]
    fn test_message_validation() {
        let valid = MessageBuilder::new()
            .text("Valid".to_string())
            .build();
        assert!(valid.validate().is_ok());

        let invalid = Message {
            parts: Vec::new(),
            ..Default::default()
        };
        assert!(invalid.validate().is_err());
    }

    #[test]
    fn test_message_text_content() {
        let message = MessageBuilder::new()
            .add_text("Text".to_string())
            .add_markdown("**Markdown**".to_string())
            .build();

        assert_eq!(message.text_content(), "Text");
        assert_eq!(message.text_parts().len(), 2);
    }

    #[test]
    fn test_message_total_size() {
        let message = MessageBuilder::new()
            .add_text("Hello".to_string())
            .add_text("World".to_string())
            .build();

        assert_eq!(message.total_size(), 10); // "Hello".len() + "World".len()
    }

    #[test]
    fn test_message_is_reply() {
        let original = user_message("Original".to_string());
        assert!(!original.is_reply());

        let reply = assistant_reply(&original, "Reply".to_string());
        assert!(reply.is_reply());
    }

    #[test]
    fn test_json_rpc_request() {
        let message = user_message("Test".to_string());
        let request = MessageRequest::new(
            "agent.message".to_string(),
            message,
            serde_json::json!(1),
        );

        assert_eq!(request.jsonrpc, "2.0");
        assert_eq!(request.method, "agent.message");
        assert_eq!(request.params.message.role, MessageRole::User);
    }

    #[test]
    fn test_json_rpc_response_success() {
        let message = assistant_message("Response".to_string());
        let result = MessageResponseResult {
            message: Some(message),
            extra: std::collections::HashMap::new(),
        };

        let response = MessageResponse::success(serde_json::json!(1), result);
        assert!(response.is_success());
        assert!(response.result.is_some());
        assert!(response.error.is_none());
    }

    #[test]
    fn test_json_rpc_response_error() {
        let error = MessageError {
            code: -32600,
            message: "Invalid Request".to_string(),
            data: None,
        };

        let response = MessageResponse::error(serde_json::json!(1), error);
        assert!(!response.is_success());
        assert!(response.result.is_none());
        assert!(response.error.is_some());
    }

    #[test]
    fn test_message_serialization() {
        let message = user_message("Test message".to_string());
        let json = serde_json::to_string(&message).unwrap();
        let deserialized: Message = serde_json::from_str(&json).unwrap();

        assert_eq!(message.message_id, deserialized.message_id);
        assert_eq!(message.role, deserialized.role);
        assert_eq!(message.text_content(), deserialized.text_content());
    }

    #[test]
    fn test_try_build_none() {
        let builder = MessageBuilder::new();
        assert!(builder.try_build().is_none());
    }

    #[test]
    fn test_try_build_some() {
        let builder = MessageBuilder::new().text("Test".to_string());
        assert!(builder.try_build().is_some());
    }

    #[test]
    #[should_panic(expected = "Message must have at least one part")]
    fn test_build_panics_without_parts() {
        MessageBuilder::new().build();
    }

    #[test]
    fn test_part_metadata_default() {
        let metadata = PartMetadata::default();
        assert!(metadata.size.is_none());
        assert!(metadata.hash.is_none());
        assert!(metadata.encoding.is_none());
        assert!(metadata.extra.is_empty());
    }

    #[test]
    fn test_part_with_metadata() {
        let metadata = PartMetadata {
            size: Some(100),
            hash: Some("abc123".to_string()),
            encoding: None,
            extra: std::collections::HashMap::new(),
        };

        let part = Part::text("Test".to_string()).with_metadata(metadata);
        assert!(part.metadata.is_some());
        assert_eq!(part.metadata.as_ref().unwrap().size, Some(100));
    }
}
