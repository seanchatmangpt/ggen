/// Internal A2A client wrapper
#[derive(Debug)]
struct AgentClient {
    id: String,
    endpoint: String,
    timeout: std::time::Duration,
    client: reqwest::Client,
}

impl AgentClient {
    /// Connect to an A2A endpoint
    async fn connect(endpoint: &str, timeout_secs: u64) -> Result<Self, AgentError> {
        let client = reqwest::Client::builder()
            .timeout(std::time::Duration::from_secs(timeout_secs))
            .build()
            .map_err(|e| AgentError::Communication(e.to_string()))?;

        // Perform initial connection/handshake
        let agent_id = Self::discover_agent_id(endpoint, &client).await?;

        Ok(Self {
            id: agent_id,
            endpoint: endpoint.to_string(),
            timeout: std::time::Duration::from_secs(timeout_secs),
            client,
        })
    }

    /// Discover agent ID via handshake
    async fn discover_agent_id(endpoint: &str, client: &reqwest::Client) -> Result<String, AgentError> {
        let url = format!("{}/agent", endpoint);
        let response = client.get(&url)
            .send()
            .await
            .map_err(|e| AgentError::Communication(e.to_string()))?;

        if !response.status().is_success() {
            return Err(AgentError::Communication(format!("Connection failed: {}", response.status())));
        }

        let agent: UnifiedAgent = response.json()
            .await
            .map_err(|e| AgentError::Serialization(e.to_string()))?;

        Ok(agent.identity.id)
    }

    /// Send a message and wait for response
    async fn send_message(&self, message: ConvergedMessage) -> Result<ConvergedMessage, AgentError> {
        let url = format!("{}/message", self.endpoint);

        let response = self.client
            .post(&url)
            .json(&message)
            .send()
            .await
            .map_err(|e| AgentError::Communication(e.to_string()))?;

        if !response.status().is_success() {
            return Err(AgentError::Communication(format!("Send failed: {}", response.status())));
        }

        response.json()
            .await
            .map_err(|e| AgentError::Serialization(e.to_string()))
    }

    {% if supportsStreaming %}
    /// Send a message with streaming response
    async fn send_message_streaming(&self, message: ConvergedMessage) -> Result<tokio::sync::mpsc::Receiver<serde_json::Value>, AgentError> {
        let (tx, rx) = tokio::sync::mpsc::channel(100);
        let url = format!("{}/stream", self.endpoint);

        let client = self.client.clone();

        tokio::spawn(async move {
            match client.post(&url).json(&message).send().await {
                Ok(response) => {
                    if !response.status().is_success() {
                        let _ = tx.send(serde_json::json!({"error": response.status().as_u16()})).await;
                        return;
                    }

                    // Stream response chunks
                    match response.bytes().await {
                        Ok(bytes) => {
                            if let Ok(text) = std::str::from_utf8(&bytes) {
                                for line in text.lines() {
                                    if let Ok(value) = serde_json::from_str::<serde_json::Value>(line) {
                                        let _ = tx.send(value).await;
                                    }
                                }
                            }
                        }
                        Err(e) => {
                            eprintln!("Stream error: {:?}", e);
                        }
                    }
                }
                Err(e) => {
                    eprintln!("Stream connection error: {:?}", e);
                }
            }
        });

        Ok(rx)
    }
    {% endif %}

    /// Health check
    async fn health_check(&self) -> Result<AgentHealth, AgentError> {
        let url = format!("{}/health", self.endpoint);

        let response = self.client
            .get(&url)
            .send()
            .await
            .map_err(|e| AgentError::Communication(e.to_string()))?;

        if !response.status().is_success() {
            return Err(AgentError::Communication(format!("Health check failed: {}", response.status())));
        }

        response.json()
            .await
            .map_err(|e| AgentError::Serialization(e.to_string()))
    }

    /// Get capabilities
    async fn capabilities(&self) -> Result<AgentCapabilities, AgentError> {
        let url = format!("{}/capabilities", self.endpoint);

        let response = self.client
            .get(&url)
            .send()
            .await
            .map_err(|e| AgentError::Communication(e.to_string()))?;

        if !response.status().is_success() {
            return Err(AgentError::Communication(format!("Failed to get capabilities: {}", response.status())));
        }

        response.json()
            .await
            .map_err(|e| AgentError::Serialization(e.to_string()))
    }

    /// Get client ID
    fn id(&self) -> String {
        self.id.clone()
    }
}

impl Clone for AgentClient {
    fn clone(&self) -> Self {
        Self {
            id: self.id.clone(),
            endpoint: self.endpoint.clone(),
            timeout: self.timeout,
            client: self.client.clone(),
        }
    }
}

