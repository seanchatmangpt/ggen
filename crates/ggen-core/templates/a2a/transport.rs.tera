// ============================================================================
// STDIO TRANSPORT (MCP)
// ============================================================================

/// Stdio transport for MCP (Model Context Protocol) communication
///
/// Implements JSON-RPC 2.0 over stdin/stdout for integration with
/// MCP clients and servers.
#[derive(Debug, Clone)]
pub struct StdioTransport {
    /// Connection state
    connected: Arc<RwLock<bool>>,
    /// Message buffer
    messages: Arc<RwLock<Vec<A2aMessage>>>,
}

impl StdioTransport {
    /// Create a new stdio transport
    #[must_use]
    pub fn new() -> Self {
        Self {
            connected: Arc::new(RwLock::new(false)),
            messages: Arc::new(RwLock::new(Vec::new())),
        }
    }

    /// Read a line from stdin
    fn read_line(&self) -> TransportResult<String> {
        let stdin = std::io::stdin();
        let mut reader = BufReader::new(stdin);
        let mut line = String::new();
        reader
            .read_line(&mut line)
            .map_err(AgentError::from)?;
        Ok(line)
    }

    /// Write a line to stdout
    fn write_line(&self, line: &str) -> TransportResult<()> {
        let mut stdout = std::io::stdout().lock();
        writeln!(stdout, "{}", line).map_err(AgentError::from)?;
        stdout.flush().map_err(AgentError::from)
    }

    /// Convert JSON-RPC request to A2A message
    fn jsonrpc_to_message(&self, json: &str) -> TransportResult<A2aMessage> {
        let value: serde_json::Value =
            serde_json::from_str(json).map_err(|e| AgentError::DeserializationFailed(e.to_string()))?;

        let method = value
            .get("method")
            .and_then(|m| m.as_str())
            .ok_or_else(|| AgentError::InvalidMessage("Missing method".to_string()))?;

        let params = value.get("params").cloned().unwrap_or_else(|| serde_json::json!({}));

        let source = value
            .get("source")
            .and_then(|s| s.as_str())
            .unwrap_or("unknown")
            .to_string();

        let payload = MessagePayload::Data { data: params };

        let message_type = match method {
            "request" => MessageType::Request,
            "response" => MessageType::Response,
            "notify" | "notification" => MessageType::Notification,
            _ => MessageType::Notification,
        };

        let mut message = A2aMessage::new(source, message_type, payload);

        // Set correlation ID from request ID if present
        if let Some(id) = value.get("id") {
            if let Ok(uuid) = serde_json::from_value::<Uuid>(id.clone()) {
                message = message.with_correlation_id(uuid);
            }
        }

        Ok(message)
    }

    /// Convert A2A message to JSON-RPC response
    fn message_to_jsonrpc(&self, message: &A2aMessage) -> TransportResult<String> {
        let mut response = serde_json::json!({
            "jsonrpc": "2.0",
            "id": message.correlation_id.unwrap_or_else(Uuid::new_v4),
            "source": message.source,
            "messageType": serde_json::to_value(message.message_type)
                .map_err(AgentError::from)?,
        });

        // Add payload based on message type
        match &message.payload {
            MessagePayload::Text { content } => {
                response["result"] = serde_json::json!({ "text": content });
            }
            MessagePayload::Data { data } => {
                response["result"] = data.clone();
            }
            MessagePayload::Binary { data, .. } => {
                response["result"] = serde_json::json!({ "data": data });
            }
            MessagePayload::Empty => {
                response["result"] = serde_json::json!({});
            }
        }

        serde_json::to_string(&response).map_err(AgentError::from)
    }
}

impl Default for StdioTransport {
    fn default() -> Self {
        Self::new()
    }
}

#[async_trait]
impl Transport for StdioTransport {
    async fn connect(&mut self) -> TransportResult<()> {
        let mut connected = self.connected.write().await;
        if *connected {
            return Err(AgentError::AlreadyConnected);
        }
        *connected = true;

        // Send initialization message
        let init = serde_json::json!({
            "jsonrpc": "2.0",
            "method": "initialize",
            "id": 1,
            "params": {
                "protocolVersion": "2024-11-05",
                "capabilities": {},
                "serverInfo": {
                    "name": "ggen-a2a",
                    "version": env!("CARGO_PKG_VERSION")
                }
            }
        });

        self.write_line(&init.to_string())?;
        Ok(())
    }

    async fn send(&mut self, message: A2aMessage) -> TransportResult<()> {
        let json = self.message_to_jsonrpc(&message)?;
        self.write_line(&json)
    }

    async fn receive(&mut self) -> TransportResult<A2aMessage> {
        // First check buffered messages
        {
            let mut messages = self.messages.write().await;
            if !messages.is_empty() {
                return Ok(messages.remove(0));
            }
        }

        // Read from stdin
        let line = self.read_line()?;
        let trimmed = line.trim();

        if trimmed.is_empty() {
            return Err(AgentError::ReceiveFailed("Empty message".to_string()));
        }

        self.jsonrpc_to_message(trimmed)
    }

    fn is_connected(&self) -> bool {
        // Check if we have a connection
        // In a real implementation, we'd track this more carefully
        true
    }

    async fn close(&mut self) -> TransportResult<()> {
        let mut connected = self.connected.write().await;
        *connected = false;

        // Send shutdown notification
        let shutdown = serde_json::json!({
            "jsonrpc": "2.0",
            "method": "shutdown",
            "id": null
        });

        let _ = self.write_line(&shutdown.to_string());
        Ok(())
    }

    fn transport_type(&self) -> &'static str {
        "stdio"
    }
}

// ============================================================================
// TRANSPORT FACTORY
// ============================================================================

/// Factory for creating transport instances
///
/// Provides a unified interface for creating different transport types
/// based on URL schemes or configuration.
#[derive(Debug, Default)]
pub struct TransportFactory;

impl TransportFactory {
    /// Create a transport from a URL string
    ///
    /// # Errors
    /// Returns error if the URL scheme is not supported
    ///
    /// # Examples
    ///
    /// ```ignore
    /// let transport = TransportFactory::from_url("http://localhost:8080")?;
    /// let transport = TransportFactory::from_url("memory://local")?;
    /// let transport = TransportFactory::from_url("stdio://")?;
    /// ```
    pub fn from_url(url: &str) -> TransportResult<Box<dyn Transport>> {
        let parsed = url::Url::parse(url)?;

        match parsed.scheme() {
            "http" | "https" => {
                #[cfg(feature = "http-transport")]
                {
                    Ok(Box::new(HttpTransport::new(parsed.to_string())))
                }
                #[cfg(not(feature = "http-transport"))]
                {
                    Err(AgentError::TransportNotSupported(
                        "HTTP transport requires 'http-transport' feature".to_string(),
                    ))
                }
            }
            "ws" | "wss" => {
                #[cfg(feature = "websocket-transport")]
                {
                    Ok(Box::new(WebSocketTransport::new(parsed.to_string())))
                }
                #[cfg(not(feature = "websocket-transport"))]
                {
                    Err(AgentError::TransportNotSupported(
                        "WebSocket transport requires 'websocket-transport' feature".to_string(),
                    ))
                }
            }
            "memory" | "in-process" => Ok(Box::new(MemoryTransport::new())),
            "stdio" => Ok(Box::new(StdioTransport::new())),
            scheme => Err(AgentError::TransportNotSupported(format!(
                "Unknown URL scheme: {}",
                scheme
            ))),
        }
    }

    /// Create a transport from configuration
    ///
    /// # Errors
    /// Returns error if configuration is invalid
    pub fn from_config(config: &TransportConfig) -> TransportResult<Box<dyn Transport>> {
        match config.transport_type {
            TransportType::Http => {
                #[cfg(feature = "http-transport")]
                {
                    let mut transport = HttpTransport::new(config.url.clone());
                    if let Some(timeout) = config.timeout {
                        transport = transport.with_timeout(timeout);
                    }
                    if let Some(token) = &config.auth_token {
                        transport = transport.with_auth(token.clone());
                    }
                    Ok(Box::new(transport))
                }
                #[cfg(not(feature = "http-transport"))]
                {
                    Err(AgentError::TransportNotSupported(
                        "HTTP transport requires 'http-transport' feature".to_string(),
                    ))
                }
            }
            TransportType::Memory => Ok(Box::new(MemoryTransport::new())),
            TransportType::WebSocket => {
                #[cfg(feature = "websocket-transport")]
                {
                    Ok(Box::new(WebSocketTransport::new(config.url.clone())))
                }
                #[cfg(not(feature = "websocket-transport"))]
                {
                    Err(AgentError::TransportNotSupported(
                        "WebSocket transport requires 'websocket-transport' feature".to_string(),
                    ))
                }
            }
            TransportType::Stdio => Ok(Box::new(StdioTransport::new())),
        }
    }
}

// ============================================================================
// TRANSPORT CONFIGURATION
// ============================================================================

/// Transport type enumeration
#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub enum TransportType {
    /// HTTP/HTTPS transport
    Http,
    /// In-memory transport
    Memory,
    /// WebSocket transport
    WebSocket,
    /// Stdio transport (MCP)
    Stdio,
}

/// Configuration for transport creation
#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct TransportConfig {
    /// Transport type
    pub transport_type: TransportType,

    /// URL for the transport endpoint
    pub url: String,

    /// Optional timeout
    pub timeout: Option<std::time::Duration>,

    /// Optional authentication token
    #[serde(skip_serializing_if = "Option::is_none")]
    pub auth_token: Option<String>,

    /// Additional options
    #[serde(skip_serializing_if = "Option::is_none")]
    pub options: Option<HashMap<String, serde_json::Value>>,
}

impl TransportConfig {
    /// Create a new transport configuration
    #[must_use]
    pub fn new(transport_type: TransportType, url: String) -> Self {
        Self {
            transport_type,
            url,
            timeout: None,
            auth_token: None,
            options: None,
        }
    }

    /// Set timeout
    #[must_use]
    pub const fn timeout(mut self, timeout: std::time::Duration) -> Self {
        self.timeout = Some(timeout);
        self
    }

    /// Set auth token
    #[must_use]
    pub fn auth_token(mut self, token: String) -> Self {
        self.auth_token = Some(token);
        self
    }

    /// Set options
    #[must_use]
    pub fn options(mut self, options: HashMap<String, serde_json::Value>) -> Self {
        self.options = Some(options);
        self
    }
}

// ============================================================================
// TRANSPORT ADAPTER
// ============================================================================

/// Adapter providing high-level transport operations
///
/// Wraps a transport and provides additional functionality like
/// request-response patterns, message queuing, and error handling.
#[derive(Debug)]
pub struct TransportAdapter {
    /// Underlying transport
    transport: Box<dyn Transport>,
    /// Pending requests (correlation_id -> sender)
    pending_requests: Arc<RwLock<HashMap<Uuid, mpsc::UnboundedSender<A2aMessage>>>>,
    /// Message queue
    message_queue: Arc<RwLock<Vec<A2aMessage>>>,
}

impl TransportAdapter {
    /// Create a new transport adapter
    #[must_use]
    pub fn new(transport: Box<dyn Transport>) -> Self {
        Self {
            transport,
            pending_requests: Arc::new(RwLock::new(HashMap::new())),
            message_queue: Arc::new(RwLock::new(Vec::new())),
        }
    }

    /// Send a request and wait for response
    pub async fn request(&mut self, mut message: A2aMessage) -> TransportResult<A2aMessage> {
        if !self.transport.is_connected() {
            self.transport.connect().await?;
        }

        let correlation_id = Uuid::new_v4();
        message = message
            .with_correlation_id(correlation_id)
            .with_message_type(MessageType::Request);

        // Create channel for response
        let (tx, mut rx) = mpsc::unbounded_channel();
        self.pending_requests
            .write()
            .await
            .insert(correlation_id, tx);

        // Send the request
        self.transport.send(message.clone()).await?;

        // Wait for response with timeout
        let timeout_duration = std::time::Duration::from_secs(30);
        let response = tokio::time::timeout(timeout_duration, rx.recv())
            .await
            .map_err(|_| AgentError::RequestTimeout("Request timed out".to_string()))?
            .ok_or_else(|| AgentError::ReceiveFailed("Response channel closed".to_string()))?;

        Ok(response)
    }

    /// Send a notification (fire and forget)
    pub async fn notify(&mut self, message: A2aMessage) -> TransportResult<()> {
        if !self.transport.is_connected() {
            self.transport.connect().await?;
        }

        let msg = message.with_message_type(MessageType::Notification);
        self.transport.send(msg).await
    }

    /// Send a response
    pub async fn respond(&mut self, message: A2aMessage) -> TransportResult<()> {
        if !self.transport.is_connected() {
            self.transport.connect().await?;
        }

        let msg = message.with_message_type(MessageType::Response);
        self.transport.send(msg).await
    }

    /// Receive and dispatch incoming messages
    pub async fn receive_and_dispatch(&mut self) -> TransportResult<A2aMessage> {
        if !self.transport.is_connected() {
            self.transport.connect().await?;
        }

        let message = self.transport.receive().await?;

        // If this is a response, dispatch to pending request
        if let Some(correlation_id) = message.correlation_id {
            let mut pending = self.pending_requests.write().await;
            if let Some(tx) = pending.remove(&correlation_id) {
                let _ = tx.send(message.clone());
            }
        }

        Ok(message)
    }

    /// Check if underlying transport is connected
    #[must_use]
    pub fn is_connected(&self) -> bool {
        self.transport.is_connected()
    }

    /// Close the transport
    pub async fn close(&mut self) -> TransportResult<()> {
        self.transport.close().await
    }

    /// Get transport type
    #[must_use]
    pub fn transport_type(&self) -> &str {
        self.transport.transport_type()
    }
}

// Helper method for A2aMessage builder
trait A2aMessageBuilder: Sized {
    fn with_message_type(self, message_type: MessageType) -> Self;
}

impl A2aMessageBuilder for A2aMessage {
    fn with_message_type(mut self, message_type: MessageType) -> Self {
        self.message_type = message_type;
        self
    }
}

// ============================================================================
// TESTS
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_message_creation() {
        let payload = MessagePayload::Text {
            content: "Hello, World!".to_string(),
        };
        let message = A2aMessage::new("agent1".to_string(), MessageType::Request, payload);

        assert_eq!(message.source, "agent1");
        assert_eq!(message.message_type, MessageType::Request);
    }

    #[test]
    fn test_message_with_target() {
        let payload = MessagePayload::Text {
            content: "Hello".to_string(),
        };
        let message = A2aMessage::new("agent1".to_string(), MessageType::Request, payload)
            .with_target("agent2".to_string());

        assert_eq!(message.target, Some("agent2".to_string()));
    }

    #[test]
    fn test_message_serialization() {
        let payload = MessagePayload::Text {
            content: "Test".to_string(),
        };
        let message = A2aMessage::new("agent1".to_string(), MessageType::Request, payload);

        let json = message.to_json().unwrap();
        let deserialized = A2aMessage::from_json(&json).unwrap();

        assert_eq!(message.source, deserialized.source);
        assert_eq!(message.message_type, deserialized.message_type);
    }

    #[test]
    fn test_message_request_helper() {
        let payload = MessagePayload::Text {
            content: "Request".to_string(),
        };
        let message = A2aMessage::request("agent1".to_string(), payload);

        assert_eq!(message.message_type, MessageType::Request);
    }

    #[test]
    fn test_message_response_helper() {
        let correlation_id = Uuid::new_v4();
        let payload = MessagePayload::Text {
            content: "Response".to_string(),
        };
        let message =
            A2aMessage::response("agent2".to_string(), correlation_id, payload);

        assert_eq!(message.message_type, MessageType::Response);
        assert_eq!(message.correlation_id, Some(correlation_id));
    }

    #[test]
    fn test_memory_transport_pair() {
        let (mut transport1, mut transport2) = MemoryTransport::pair();

        // Create runtime for async test
        let rt = tokio::runtime::Runtime::new().unwrap();

        rt.block_on(async move {
            transport1.connect().await.unwrap();
            transport2.connect().await.unwrap();

            let payload = MessagePayload::Text {
                content: "Test message".to_string(),
            };
            let message =
                A2aMessage::new("agent1".to_string(), MessageType::Request, payload);

            transport1.send(message.clone()).await.unwrap();
            let received = transport2.receive().await.unwrap();

            assert_eq!(received.source, "agent1");
        });
    }

    #[test]
    fn test_transport_factory_memory() {
        let transport = TransportFactory::from_url("memory://local").unwrap();
        assert_eq!(transport.transport_type(), "memory");
    }

    #[test]
    fn test_transport_factory_stdio() {
        let transport = TransportFactory::from_url("stdio://").unwrap();
        assert_eq!(transport.transport_type(), "stdio");
    }

    #[test]
    fn test_transport_config() {
        let config = TransportConfig::new(TransportType::Memory, "memory://local".to_string());
        assert_eq!(config.transport_type, TransportType::Memory);

        let config = config.timeout(std::time::Duration::from_secs(10));
        assert_eq!(config.timeout, Some(std::time::Duration::from_secs(10)));

        let config = config.auth_token("test-token".to_string());
        assert_eq!(config.auth_token, Some("test-token".to_string()));
    }

    #[test]
    fn test_agent_error_display() {
        let error = AgentError::ConnectionFailed("test".to_string());
        assert_eq!(error.to_string(), "Connection failed: test");
    }

    #[test]
    fn test_message_types() {
        assert_eq!(MessageType::Request, MessageType::Request);
        assert_ne!(MessageType::Request, MessageType::Response);
    }

    #[test]
    fn test_empty_payload() {
        let payload = MessagePayload::Empty;
        let message = A2aMessage::new("agent1".to_string(), MessageType::Notification, payload);

        assert!(matches!(message.payload, MessagePayload::Empty));
    }

    #[test]
    fn test_data_payload() {
        let data = serde_json::json!({"key": "value"});
        let payload = MessagePayload::Data { data };
        let message = A2aMessage::new("agent1".to_string(), MessageType::Request, payload);

        assert!(matches!(message.payload, MessagePayload::Data { .. }));
    }

    #[tokio::test]
    async fn test_memory_transport_clone() {
        let transport1 = MemoryTransport::new();
        let transport2 = transport1.shared();

        assert_eq!(transport1.id(), transport2.id());
    }

    #[test]
    fn test_stdio_transport_jsonrpc_conversion() {
        let transport = StdioTransport::new();
        let json = r#"{"jsonrpc":"2.0","method":"request","params":{"text":"hello"},"source":"agent1"}"#;

        let message = transport.jsonrpc_to_message(json).unwrap();
        assert_eq!(message.source, "agent1");
    }
}
