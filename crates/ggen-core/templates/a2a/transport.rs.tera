use async_trait::async_trait;
use serde::{Deserialize, Serialize};
use std::collections::HashMap;
use std::io::{BufRead, BufReader, Write};
use std::sync::Arc;
use tokio::sync::{mpsc, RwLock};
use uuid::Uuid;

// ============================================================================
// AGENT ERROR TYPE
// ============================================================================

/// Comprehensive error type for A2A transport operations
#[derive(Debug, thiserror::Error)]
pub enum AgentError {
    /// Connection failed to establish
    #[error("Connection failed: {0}")]
    ConnectionFailed(String),

    /// Connection was lost
    #[error("Connection lost: {0}")]
    ConnectionLost(String),

    /// Connection timeout
    #[error("Connection timeout after {0:?}")]
    ConnectionTimeout(std::time::Duration),

    /// Request timeout
    #[error("Request timeout: {0}")]
    RequestTimeout(String),

    /// Send operation failed
    #[error("Send failed: {0}")]
    SendFailed(String),

    /// Receive operation failed
    #[error("Receive failed: {0}")]
    ReceiveFailed(String),

    /// Message serialization failed
    #[error("Serialization failed: {0}")]
    SerializationFailed(#[from] serde_json::Error),

    /// Message deserialization failed
    #[error("Deserialization failed: {0}")]
    DeserializationFailed(String),

    /// Invalid message format
    #[error("Invalid message format: {0}")]
    InvalidMessage(String),

    /// Transport not supported
    #[error("Transport not supported: {0}")]
    TransportNotSupported(String),

    /// Transport already connected
    #[error("Transport already connected")]
    AlreadyConnected,

    /// Transport not connected
    #[error("Transport not connected")]
    NotConnected,

    /// IO error
    #[error("IO error: {0}")]
    Io(#[from] std::io::Error),

    /// URL parsing error
    #[error("URL error: {0}")]
    Url(#[from] url::ParseError),

    /// HTTP error
    #[cfg(feature = "http-transport")]
    #[error("HTTP error: {0}")]
    Http(String),

    /// WebSocket error
    #[cfg(feature = "websocket-transport")]
    #[error("WebSocket error: {0}")]
    WebSocket(String),

    /// Generic error
    #[error("Error: {0}")]
    Generic(String),
}

/// Result type for transport operations
pub type TransportResult<T> = Result<T, AgentError>;

// ============================================================================
// MESSAGE TYPES
// ============================================================================

/// A2A message with envelope and payload
#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct A2aMessage {
    /// Unique message identifier
    pub message_id: Uuid,

    /// Source agent identifier
    pub source: String,

    /// Target agent identifier (None for broadcast)
    #[serde(skip_serializing_if = "Option::is_none")]
    pub target: Option<String>,

    /// Message type
    pub message_type: MessageType,

    /// Message payload
    pub payload: MessagePayload,

    /// Message timestamp
    pub timestamp: chrono::DateTime<chrono::Utc>,

    /// Correlation ID for request/response
    #[serde(skip_serializing_if = "Option::is_none")]
    pub correlation_id: Option<Uuid>,

    /// Additional metadata
    #[serde(skip_serializing_if = "Option::is_none")]
    pub metadata: Option<HashMap<String, serde_json::Value>>,
}

/// Message type enumeration
#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub enum MessageType {
    /// Request message
    Request,
    /// Response message
    Response,
    /// Notification message
    Notification,
    /// Error message
    Error,
}

/// Message payload
#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(tag = "payloadKind", rename_all = "camelCase")]
pub enum MessagePayload {
    /// Text payload
    Text { content: String },
    /// JSON data payload
    Data { data: serde_json::Value },
    /// Binary payload (base64 encoded)
    Binary { data: String, encoding: String },
    /// Empty payload
    Empty,
}

impl A2aMessage {
    /// Create a new message
    #[must_use]
    pub fn new(source: String, message_type: MessageType, payload: MessagePayload) -> Self {
        Self {
            message_id: Uuid::new_v4(),
            source,
            target: None,
            message_type,
            payload,
            timestamp: chrono::Utc::now(),
            correlation_id: None,
            metadata: None,
        }
    }

    /// Set the target agent
    #[must_use]
    pub fn with_target(mut self, target: String) -> Self {
        self.target = Some(target);
        self
    }

    /// Set the correlation ID
    #[must_use]
    pub fn with_correlation_id(mut self, correlation_id: Uuid) -> Self {
        self.correlation_id = Some(correlation_id);
        self
    }

    /// Set metadata
    #[must_use]
    pub fn with_metadata(mut self, metadata: HashMap<String, serde_json::Value>) -> Self {
        self.metadata = Some(metadata);
        self
    }

    /// Create a request message
    #[must_use]
    pub fn request(source: String, payload: MessagePayload) -> Self {
        Self::new(source, MessageType::Request, payload)
    }

    /// Create a response message
    #[must_use]
    pub fn response(source: String, correlation_id: Uuid, payload: MessagePayload) -> Self {
        Self::new(source, MessageType::Response, payload)
            .with_correlation_id(correlation_id)
    }

    /// Create a notification message
    #[must_use]
    pub fn notification(source: String, payload: MessagePayload) -> Self {
        Self::new(source, MessageType::Notification, payload)
    }

    /// Create an error message
    #[must_use]
    pub fn error(source: String, error_message: String) -> Self {
        Self::new(
            source,
            MessageType::Error,
            MessagePayload::Text {
                content: error_message,
            },
        )
    }

    /// Serialize message to JSON string
    pub fn to_json(&self) -> TransportResult<String> {
        serde_json::to_string(self).map_err(AgentError::from)
    }

    /// Deserialize message from JSON string
    pub fn from_json(json: &str) -> TransportResult<Self> {
        serde_json::from_str(json).map_err(|e| AgentError::DeserializationFailed(e.to_string()))
    }
}

// ============================================================================
// TRANSPORT TRAIT
// ============================================================================

/// Core transport trait for A2A communication
///
/// All transports must implement this trait to enable agent communication
/// over different protocols (HTTP, WebSocket, memory, stdio, etc.)
#[async_trait]
pub trait Transport: Send + Sync {
    /// Establish connection to the transport endpoint
    ///
    /// # Errors
    /// Returns error if connection fails
    async fn connect(&mut self) -> TransportResult<()>;

    /// Send a message through the transport
    ///
    /// # Errors
    /// Returns error if send fails
    async fn send(&mut self, message: A2aMessage) -> TransportResult<()>;

    /// Receive a message from the transport
    ///
    /// This method should block until a message is available or an error occurs.
    ///
    /// # Errors
    /// Returns error if receive fails
    async fn receive(&mut self) -> TransportResult<A2aMessage>;

    /// Check if transport is connected
    #[must_use]
    fn is_connected(&self) -> bool;

    /// Close the transport connection
    ///
    /// # Errors
    /// Returns error if close fails
    async fn close(&mut self) -> TransportResult<()>;

    /// Get transport type identifier
    #[must_use]
    fn transport_type(&self) -> &'static str;
}

// ============================================================================
// HTTP TRANSPORT
// ============================================================================

/// HTTP transport for A2A communication over HTTP/HTTPS
///
/// Uses reqwest for HTTP client functionality.
#[cfg(feature = "http-transport")]
#[derive(Debug)]
pub struct HttpTransport {
    /// Base URL for the HTTP endpoint
    base_url: String,
    /// HTTP client
    client: reqwest::Client,
    /// Connection state
    connected: bool,
    /// Authentication token
    auth_token: Option<String>,
    /// Request timeout
    timeout: std::time::Duration,
}

#[cfg(feature = "http-transport")]
impl HttpTransport {
    /// Create a new HTTP transport
    #[must_use]
    pub fn new(base_url: String) -> Self {
        let timeout = std::time::Duration::from_secs(30);
        let client = reqwest::Client::builder()
            .timeout(timeout)
            .build()
            .unwrap_or_default();

        Self {
            base_url,
            client,
            connected: false,
            auth_token: None,
            timeout,
        }
    }

    /// Set authentication token for requests
    #[must_use]
    pub fn with_auth(mut self, token: String) -> Self {
        self.auth_token = Some(token);
        self
    }

    /// Set request timeout
    #[must_use]
    pub fn with_timeout(mut self, timeout: std::time::Duration) -> Self {
        self.timeout = timeout;
        self.client = reqwest::Client::builder()
            .timeout(timeout)
            .build()
            .unwrap_or_else(|_| reqwest::Client::new());
        self
    }

    /// Build the full URL for an endpoint
    fn build_url(&self, endpoint: &str) -> TransportResult<String> {
        let base = self.base_url.trim_end_matches('/');
        let endpoint = endpoint.trim_start_matches('/');
        url::Url::parse(&format!("{}/{}", base, endpoint))
            .map(|url| url.to_string())
            .map_err(AgentError::from)
    }

    /// Send POST request with message
    async fn post(&self, endpoint: &str, message: &A2aMessage) -> TransportResult<serde_json::Value> {
        let url = self.build_url(endpoint)?;
        let json = message.to_json()?;

        let mut request = self.client.post(&url).header("Content-Type", "application/json");

        if let Some(token) = &self.auth_token {
            request = request.header("Authorization", format!("Bearer {}", token));
        }

        let response = request
            .body(json)
            .send()
            .await
            .map_err(|e| AgentError::Http(e.to_string()))?;

        if response.status().is_success() {
            response
                .json()
                .await
                .map_err(|e| AgentError::Http(e.to_string()))
        } else {
            let status = response.status();
            let error_text = response
                .text()
                .await
                .unwrap_or_else(|_| "Unknown error".to_string());
            Err(AgentError::Http(format!(
                "HTTP {}: {}",
                status.as_u16(),
                error_text
            )))
        }
    }
}

#[cfg(feature = "http-transport")]
#[async_trait]
impl Transport for HttpTransport {
    async fn connect(&mut self) -> TransportResult<()> {
        if self.connected {
            return Err(AgentError::AlreadyConnected);
        }

        // Verify connectivity with a simple health check
        let health_url = self.build_url("/health")?;
        let response = self
            .client
            .get(&health_url)
            .send()
            .await
            .map_err(|e| AgentError::ConnectionFailed(e.to_string()))?;

        if response.status().is_success() {
            self.connected = true;
            Ok(())
        } else {
            Err(AgentError::ConnectionFailed(format!(
                "Health check failed: {}",
                response.status()
            )))
        }
    }

    async fn send(&mut self, message: A2aMessage) -> TransportResult<()> {
        if !self.connected {
            return Err(AgentError::NotConnected);
        }

        self.post("/messages", &message).await?;
        Ok(())
    }

    async fn receive(&mut self) -> TransportResult<A2aMessage> {
        if !self.connected {
            return Err(AgentError::NotConnected);
        }

        // HTTP is request/response, so we use a polling mechanism
        // In production, you'd use WebSockets or Server-Sent Events
        let url = self.build_url("/messages/poll")?;
        let response = self
            .client
            .get(&url)
            .query(&[("timeout", "30")])
            .send()
            .await
            .map_err(|e| AgentError::ReceiveFailed(e.to_string()))?;

        if response.status().is_success() {
            let json = response
                .text()
                .await
                .map_err(|e| AgentError::ReceiveFailed(e.to_string()))?;
            A2aMessage::from_json(&json)
        } else {
            Err(AgentError::ReceiveFailed(format!(
                "Poll failed: {}",
                response.status()
            )))
        }
    }

    fn is_connected(&self) -> bool {
        self.connected
    }

    async fn close(&mut self) -> TransportResult<()> {
        self.connected = false;
        Ok(())
    }

    fn transport_type(&self) -> &'static str {
        "http"
    }
}

// ============================================================================
// MEMORY TRANSPORT
// ============================================================================

/// In-memory transport for same-process communication
///
/// Uses Tokio channels for message passing between agents
/// running in the same process.
#[derive(Debug, Clone)]
pub struct MemoryTransport {
    /// Sender channel
    tx: mpsc::UnboundedSender<A2aMessage>,
    /// Receiver channel
    rx: Arc<RwLock<mpsc::UnboundedReceiver<A2aMessage>>>,
    /// Connection state
    connected: Arc<RwLock<bool>>,
    /// Transport identifier
    id: String,
}

impl MemoryTransport {
    /// Create a new memory transport
    #[must_use]
    pub fn new() -> Self {
        let (tx, rx) = mpsc::unbounded_channel();
        Self {
            tx,
            rx: Arc::new(RwLock::new(rx)),
            connected: Arc::new(RwLock::new(false)),
            id: Uuid::new_v4().to_string(),
        }
    }

    /// Create a connected pair of memory transports
    ///
    /// Returns two transports that can communicate with each other
    #[must_use]
    pub fn pair() -> (Self, Self) {
        let (tx1, rx1) = mpsc::unbounded_channel();
        let (tx2, rx2) = mpsc::unbounded_channel();

        let transport1 = Self {
            tx: tx1,
            rx: Arc::new(RwLock::new(rx2)),
            connected: Arc::new(RwLock::new(false)),
            id: Uuid::new_v4().to_string(),
        };

        let transport2 = Self {
            tx: tx2,
            rx: Arc::new(RwLock::new(rx1)),
            connected: Arc::new(RwLock::new(false)),
            id: Uuid::new_v4().to_string(),
        };

        (transport1, transport2)
    }

    /// Get the transport ID
    #[must_use]
    pub fn id(&self) -> &str {
        &self.id
    }

    /// Create a clone that shares the same channels
    #[must_use]
    pub fn shared(&self) -> Self {
        Self {
            tx: self.tx.clone(),
            rx: self.rx.clone(),
            connected: self.connected.clone(),
            id: self.id.clone(),
        }
    }
}

impl Default for MemoryTransport {
    fn default() -> Self {
        Self::new()
    }
}

#[async_trait]
impl Transport for MemoryTransport {
    async fn connect(&mut self) -> TransportResult<()> {
        let mut connected = self.connected.write().await;
        if *connected {
            return Err(AgentError::AlreadyConnected);
        }
        *connected = true;
        Ok(())
    }

    async fn send(&mut self, message: A2aMessage) -> TransportResult<()> {
        self.tx
            .send(message)
            .map_err(|e| AgentError::SendFailed(e.to_string()))
    }

    async fn receive(&mut self) -> TransportResult<A2aMessage> {
        let mut rx = this.rx.write().await;
        rx.recv()
            .await
            .ok_or_else(|| AgentError::ReceiveFailed("Channel closed".to_string()))
    }

    fn is_connected(&self) -> bool {
        // Note: This is a synchronous check of an async value
        // In practice, we'd use a different approach for production
        true
    }

    async fn close(&mut self) -> TransportResult<()> {
        let mut connected = self.connected.write().await;
        *connected = false;
        Ok(())
    }

    fn transport_type(&self) -> &'static str {
        "memory"
    }
}

