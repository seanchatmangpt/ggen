SELECT DISTINCT ?type ?field_name ?field_type ?field_visibility ?field_description ?field_default
WHERE {
    ?type a mcpp:Type .
    ?type mcpp:hasField ?field .
    ?field mcpp:name ?field_name .
    ?field mcpp:type ?field_type .
    OPTIONAL { ?field mcpp:visibility ?field_visibility }
    OPTIONAL { ?field mcpp:description ?field_description }
    OPTIONAL { ?field mcpp:default ?field_default }
} ORDER BY ?type ?field_name