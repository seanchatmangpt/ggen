PREFIX sos: <https://ggen.io/semantic-os/>

SELECT ?law_id ?input_value ?condition_name ?description WHERE {
    ?law a sos:Law ;
         sos:lawId ?law_id ;
         sos:hasTransition ?transition .
    ?transition sos:inputValue ?input_value ;
                sos:selectCondition ?condition_name ;
                sos:description ?description .
}
