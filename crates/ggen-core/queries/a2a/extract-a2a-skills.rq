# SPARQL SELECT Query: Extract A2A Skills (one row per skill)
#
# Returns one row per skill. The template uses sparql_results to iterate
# all rows and build the skills array.
#
# Pipeline: mcp-a2a-protocol.ttl + mcp-a2a-protocol-example.ttl -> this query -> a2a-elixir.tera

PREFIX a2a: <https://ggen.dev/ontology/a2a#>
PREFIX mcp: <https://ggen.dev/ontology/mcp#>

SELECT ?skill_name ?skill_description ?skill_tags ?streaming ?timeout_ms ?retry_policy
       ?input_type ?output_type ?system_prompt ?implementation_hint ?test_example ?auto_implementation
WHERE {
  << ?agent a2a:hasSkill ?skill >>
    a2a:skillName ?skill_name ;
    a2a:skillDescription ?skill_desc_raw ;
    a2a:skillTags ?skill_tags .

  BIND(COALESCE(?skill_desc_raw, "") AS ?skill_description)

  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:streaming ?strm . }
  BIND(COALESCE(?strm, "false") AS ?streaming)

  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:timeout_ms ?tm . }
  BIND(COALESCE(?tm, "30000") AS ?timeout_ms)

  OPTIONAL { << ?agent a2a:hasSkill ?skill >> a2a:retryPolicy ?rp . }
  BIND(COALESCE(?rp, "none") AS ?retry_policy)

  # Input/output type schemas
  OPTIONAL { ?skill a2a:hasInputType ?input_type . }
  OPTIONAL { ?skill a2a:hasOutputType ?output_type . }

  # LLM Generation predicates (new for Phase 2)
  OPTIONAL { ?skill a2a:hasSystemPrompt ?system_prompt . }
  OPTIONAL { ?skill a2a:hasImplementationHint ?implementation_hint . }
  OPTIONAL { ?skill a2a:hasTestExample ?test_example . }
  OPTIONAL { ?skill mcp:hasAutoImplementation ?auto_impl_raw . }
  BIND(COALESCE(?auto_impl_raw, "false") AS ?auto_implementation)
}
ORDER BY ?skill_name
