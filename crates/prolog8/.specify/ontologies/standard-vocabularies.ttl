@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix gv6: <http://ggen.dev/v6#> .
@prefix meta: <http://ggen.ai/ontology/meta#> .
@prefix ggen: <https://ggen.io/marketplace/> .

# Standard Vocabulary Definitions for v26.5.4 Release
# This file defines the "Authorized Baseline" for all Genesis admissions.

gv6:StandardVocabulary a owl:Class ;
    rdfs:label "Standard Vocabulary" ;
    rdfs:comment "A namespace authorized for use in ggen v6 projects." .

<http://www.w3.org/1999/02/22-rdf-syntax-ns#> a gv6:StandardVocabulary ;
    gv6:prefix "rdf" ;
    rdfs:label "RDF syntax vocabulary" .

<http://www.w3.org/2000/01/rdf-schema#> a gv6:StandardVocabulary ;
    gv6:prefix "rdfs" ;
    rdfs:label "RDF Schema vocabulary" .

<http://www.w3.org/2002/07/owl#> a gv6:StandardVocabulary ;
    gv6:prefix "owl" ;
    rdfs:label "Web Ontology Language" .

<http://ggen.dev/v6#> a gv6:StandardVocabulary ;
    gv6:prefix "gv6" ;
    rdfs:label "ggen v6 ontology" .

<http://ggen.ai/ontology/meta#> a gv6:StandardVocabulary ;
    gv6:prefix "meta" ;
    rdfs:label "ggen meta-ontology" .

<http://www.w3.org/2001/XMLSchema#> a gv6:StandardVocabulary ;
    gv6:prefix "xsd" ;
    rdfs:label "XML Schema Definition" .

<https://ggen.io/marketplace/> a gv6:StandardVocabulary ;
    gv6:prefix "ggen" ;
    rdfs:label "ggen marketplace vocabulary" .

<https://prolog8.dev/ontology#> a gv6:StandardVocabulary ;
    gv6:prefix "p8" ;
    rdfs:label "Prolog8 core ontology" .

<https://prolog8.dev/type#> a gv6:StandardVocabulary ;
    gv6:prefix "type" ;
    rdfs:label "Prolog8 type definitions" .

<https://prolog8.dev/cap#> a gv6:StandardVocabulary ;
    gv6:prefix "cap" ;
    rdfs:label "Prolog8 implementation capabilities" .

<https://prolog8.dev/error#> a gv6:StandardVocabulary ;
    gv6:prefix "error" ;
    rdfs:label "Prolog8 admission errors" .

<https://prolog8.dev/feat#> a gv6:StandardVocabulary ;
    gv6:prefix "feat" ;
    rdfs:label "Prolog8 feature bits" .

<https://prolog8.dev/module#> a gv6:StandardVocabulary ;
    gv6:prefix "module" ;
    rdfs:label "Prolog8 module definitions" .

<https://prolog8.dev/function#> a gv6:StandardVocabulary ;
    gv6:prefix "fn" ;
    rdfs:label "Prolog8 function definitions" .

<http://www.w3.org/ns/prov#> a gv6:StandardVocabulary ;
    gv6:prefix "prov" ;
    rdfs:label "PROV-O vocabulary" .

<https://prolog8.dev/artifact#> a gv6:StandardVocabulary ;
    gv6:prefix "artifact" ;
    rdfs:label "Prolog8 artifact definitions" .

<https://prolog8.dev/crate#> a gv6:StandardVocabulary ;
    gv6:prefix "crate" ;
    rdfs:label "Prolog8 crate definitions" .

<https://prolog8.dev/demo#> a gv6:StandardVocabulary ;
    gv6:prefix "demo" ;
    rdfs:label "Prolog8 demo definitions" .

<https://prolog8.dev/feature#> a gv6:StandardVocabulary ;
    gv6:prefix "feature" ;
    rdfs:label "Prolog8 feature definitions" .

<https://prolog8.dev/implementation#> a gv6:StandardVocabulary ;
    gv6:prefix "impl" ;
    rdfs:label "Prolog8 implementation vocabulary" .

<https://prolog8.dev/test#> a gv6:StandardVocabulary ;
    gv6:prefix "test" ;
    rdfs:label "Prolog8 test definitions" .

<http://purl.org/dc/terms/> a gv6:StandardVocabulary ;
    gv6:prefix "dcterms" ;
    rdfs:label "Dublin Core Metadata Terms" .

<http://www.w3.org/ns/shacl#> a gv6:StandardVocabulary ;
    gv6:prefix "sh" ;
    rdfs:label "Shapes Constraint Language" .
