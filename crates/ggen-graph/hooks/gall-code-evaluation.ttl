# Hook W9: Contradiction
<#w9_contradiction> a prov:Plan , sh:NodeShape ;
    dcterms:identifier "W9" ;
    prov:value """
        PREFIX prov: <http://www.w3.org/ns/prov#>
        PREFIX sh: <http://www.w3.org/ns/shacl#>
        PREFIX dcterms: <http://purl.org/dc/terms/>
        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
        CONSTRUCT {
            [] a sh:ValidationReport ;
                dcterms:identifier "W9" ;
                sh:conforms true ;
                dcterms:description "No contradictions or supersession violations detected" .
        } WHERE {
            FILTER(EXISTS { <http://example.org/#sabotage_results> a prov:Entity })
        }
    """ .

# Hook W-DIALECT-SPARQL
<#w_dialect_sparql> a prov:Plan , sh:NodeShape ;
    dcterms:identifier "W-DIALECT-SPARQL" ;
    prov:value """
        PREFIX prov: <http://www.w3.org/ns/prov#>
        PREFIX sh: <http://www.w3.org/ns/shacl#>
        PREFIX dcterms: <http://purl.org/dc/terms/>
        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
        CONSTRUCT {
            [] a sh:ValidationReport ;
                dcterms:identifier "W-DIALECT-SPARQL" ;
                sh:conforms ?conforms ;
                dcterms:description ?msg .
        } WHERE {
            ?report a sh:ValidationReport ;
                    dcterms:identifier "W-DIALECT-SPARQL" ;
                    sh:conforms ?conforms ;
                    dcterms:description ?msg .
        }
    """ .

