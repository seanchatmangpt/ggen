<#case_11_diff> a prov:Entity ;
    rdfs:label "diff" ;
    prov:value "diff --git a/crates/ggen-graph/hooks/gall-code-evaluation.ttl b/crates/ggen-graph/hooks/gall-code-evaluation.ttl\ndeleted file mode 100644\nindex 5f406e9..0000000\n--- a/crates/ggen-graph/hooks/gall-code-evaluation.ttl\n+++ /dev/null\n@@ -1,379 +0,0 @@\n-@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .\n-@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .\n-@prefix owl: <http://www.w3.org/2002/07/owl#> .\n-@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .\n-@prefix prov: <http://www.w3.org/ns/prov#> .\n-@prefix dcat: <http://www.w3.org/ns/dcat#> .\n-@prefix dcterms: <http://purl.org/dc/terms/> .\n-@prefix skos: <http://www.w3.org/2004/02/skos/core#> .\n-@prefix sh: <http://www.w3.org/ns/shacl#> .\n-@prefix time: <http://www.w3.org/2006/time#> .\n-@prefix spdx: <http://spdx.org/rdf/terms#> .\n-@prefix ocel: <http://www.w3.org/ns/ocel#> .\n-@base <http://example.org/> .\n-\n-# OFMF HookPack \u2014 all subject IRIs in example.org namespace, no private terms\n-<#hook_pack> a dcat:Dataset , prov:Entity ;\n-    dcterms:identifier \"hook_pack\" ;\n-    dcterms:description \"Witnessed Agent Truthfulness Knowledge Hook Pack\" .\n-\n-# Hook W0: Worktree Scan\n-<#w0_worktree> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W0\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX spdx: <http://spdx.org/rdf/terms#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W0\" ;\n-                sh:conforms ?conforms ;\n-                dcterms:description ?msg .\n-        } WHERE {\n-            {\n-                SELECT (IF(COUNT(?file) > 0, true, false) AS ?conforms)\n-                       (IF(COUNT(?file) > 0, \"Worktree files verified\", \"No files found\") AS ?msg)\n-                WHERE {\n-                    ?file a spdx:File .\n-                }\n-            }\n-        }\n-    \"\"\" .\n-\n-# Hook W1: Command Transcripts Verification (with indirect BoundaryExecutionRequest)\n-<#w1_commands> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W1\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            ?req a prov:Activity ;\n-                 dcterms:type \"BoundaryExecutionRequest\" ;\n-                 dcterms:identifier \"run_commands\" ;\n-                 dcterms:description \"Request execution of command transcripts\" .\n-\n-            ?report a sh:ValidationReport ;\n-                    dcterms:identifier \"W1\" ;\n-                    sh:conforms ?conforms ;\n-                    dcterms:description ?msg .\n-        } WHERE {\n-            {\n-                FILTER(NOT EXISTS { ?cmd a prov:Activity ; prov:value ?exit })\n-                BIND(BNODE() AS ?req)\n-            }\n-            UNION\n-            {\n-                {\n-                    SELECT (IF(COUNT(?cmd) = 14 && SUM(IF(?exit = 0, 1, 0)) = 14, true, false) AS ?conforms)\n-                           (IF(COUNT(?cmd) = 14 && SUM(IF(?exit = 0, 1, 0)) = 14, \"All 14 command executions passed\", \"Some commands failed or missing\") AS ?msg)\n-                    WHERE {\n-                        ?cmd a prov:Activity ;\n-                             prov:value ?exit .\n-                    }\n-                }\n-                BIND(BNODE() AS ?report)\n-            }\n-        }\n-    \"\"\" .\n-\n-# Hook W2: Doctests Verification\n-<#w2_doctests> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W2\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            ?req a prov:Activity ;\n-                 dcterms:type \"BoundaryExecutionRequest\" ;\n-                 dcterms:identifier \"run_doctests\" ;\n-                 dcterms:description \"Request execution of doctests\" .\n-\n-            ?report a sh:ValidationReport ;\n-                    dcterms:identifier \"W2\" ;\n-                    sh:conforms ?conforms ;\n-                    dcterms:description ?msg .\n-        } WHERE {\n-            {\n-                FILTER(NOT EXISTS { <http://example.org/#doctest_results> sh:conforms ?any })\n-                BIND(BNODE() AS ?req)\n-            }\n-            UNION\n-            {\n-                <http://example.org/#doctest_results> sh:conforms ?conforms ;\n-                                                    dcterms:description ?msg .\n-                BIND(BNODE() AS ?report)\n-            }\n-        }\n-    \"\"\" .\n-\n-# Hook W3: Clean Room Verification\n-<#w3_clean_room> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W3\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            ?req a prov:Activity ;\n-                 dcterms:type \"BoundaryExecutionRequest\" ;\n-                 dcterms:identifier \"run_clean_room\" ;\n-                 dcterms:description \"Request execution of clean room rebuild\" .\n-\n-            ?report a sh:ValidationReport ;\n-                    dcterms:identifier \"W3\" ;\n-                    sh:conforms ?conforms ;\n-                    dcterms:description ?msg .\n-        } WHERE {\n-            {\n-                FILTER(NOT EXISTS { <http://example.org/#clean_room_rebuild> sh:conforms ?any })\n-                BIND(BNODE() AS ?req)\n-            }\n-            UNION\n-            {\n-                <http://example.org/#clean_room_rebuild> sh:conforms ?conforms .\n-                BIND(IF(?conforms = true, \"Clean room rebuild verified\", \"Clean room rebuild failed\") AS ?msg)\n-                BIND(BNODE() AS ?report)\n-            }\n-        }\n-    \"\"\" .\n-\n-# Hook W4: Sabotage Verification\n-<#w4_sabotage> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W4\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            ?req a prov:Activity ;\n-                 dcterms:type \"BoundaryExecutionRequest\" ;\n-                 dcterms:identifier \"run_sabotage\" ;\n-                 dcterms:description \"Request execution of sabotage checks\" .\n-\n-            ?report a sh:ValidationReport ;\n-                    dcterms:identifier \"W4\" ;\n-                    sh:conforms ?conforms ;\n-                    dcterms:description ?msg .\n-        } WHERE {\n-            {\n-                FILTER(NOT EXISTS { <http://example.org/#sabotage_results> sh:conforms ?any })\n-                BIND(BNODE() AS ?req)\n-            }\n-            UNION\n-            {\n-                <http://example.org/#sabotage_results> sh:conforms ?conforms ;\n-                                                     prov:value ?msg .\n-                BIND(BNODE() AS ?report)\n-            }\n-        }\n-    \"\"\" .\n-\n-# Hook W5: Docs Tree Verification\n-<#w5_docs_tree> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W5\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W5\" ;\n-                sh:conforms ?conforms ;\n-                dcterms:description \"Required documentation verified\" .\n-        } WHERE {\n-            {\n-                SELECT (IF(COUNT(?doc) > 0, true, false) AS ?conforms)\n-                WHERE {\n-                    ?doc a prov:Entity ;\n-                         sh:conforms true .\n-                    FILTER(STRSTARTS(STR(?doc), \"http://example.org/#doc_\"))\n-                }\n-            }\n-        }\n-    \"\"\" .\n-\n-# Hook W6: Causal Consistency\n-<#w6_causal_consistency> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W6\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W6\" ;\n-                sh:conforms true ;\n-                dcterms:description \"Causal consistency verified successfully\" .\n-        } WHERE {\n-            FILTER(EXISTS { <http://example.org/#doctest_results> a prov:Entity })\n-        }\n-    \"\"\" .\n-\n-# Hook W7: Cross-Artifact Consistency\n-<#w7_cross_artifact> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W7\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W7\" ;\n-                sh:conforms true ;\n-                dcterms:description \"Cross-artifact consistency verified successfully\" .\n-        } WHERE {\n-            FILTER(EXISTS { <http://example.org/#clean_room_rebuild> a prov:Entity })\n-        }\n-    \"\"\" .\n-\n-# Hook W8: Causal Sufficiency\n-<#w8_causal_sufficiency> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W8\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W8\" ;\n-                sh:conforms true ;\n-                dcterms:description \"Causal sufficiency verified successfully\" .\n-        } WHERE {\n-            FILTER(EXISTS { <http://example.org/#doctest_results> a prov:Entity })\n-        }\n-    \"\"\" .\n-\n-# Hook W9: Contradiction\n-<#w9_contradiction> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W9\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W9\" ;\n-                sh:conforms true ;\n-                dcterms:description \"No contradictions or supersession violations detected\" .\n-        } WHERE {\n-            FILTER(EXISTS { <http://example.org/#sabotage_results> a prov:Entity })\n-        }\n-    \"\"\" .\n-\n-# Hook W-DIALECT-SPARQL\n-<#w_dialect_sparql> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W-DIALECT-SPARQL\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W-DIALECT-SPARQL\" ;\n-                sh:conforms ?conforms ;\n-                dcterms:description ?msg .\n-        } WHERE {\n-            ?report a sh:ValidationReport ;\n-                    dcterms:identifier \"W-DIALECT-SPARQL\" ;\n-                    sh:conforms ?conforms ;\n-                    dcterms:description ?msg .\n-        }\n-    \"\"\" .\n-\n-# Hook W-DIALECT-SHACL\n-<#w_dialect_shacl> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W-DIALECT-SHACL\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W-DIALECT-SHACL\" ;\n-                sh:conforms ?conforms ;\n-                dcterms:description ?msg .\n-        } WHERE {\n-            ?report a sh:ValidationReport ;\n-                    dcterms:identifier \"W-DIALECT-SHACL\" ;\n-                    sh:conforms ?conforms ;\n-                    dcterms:description ?msg .\n-        }\n-    \"\"\" .\n-\n-# Hook W-DIALECT-N3\n-<#w_dialect_n3> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W-DIALECT-N3\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W-DIALECT-N3\" ;\n-                sh:conforms ?conforms ;\n-                dcterms:description ?msg .\n-        } WHERE {\n-            ?report a sh:ValidationReport ;\n-                    dcterms:identifier \"W-DIALECT-N3\" ;\n-                    sh:conforms ?conforms ;\n-                    dcterms:description ?msg .\n-        }\n-    \"\"\" .\n-\n-# Hook W-DIALECT-DATALOG\n-<#w_dialect_datalog> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W-DIALECT-DATALOG\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W-DIALECT-DATALOG\" ;\n-                sh:conforms ?conforms ;\n-                dcterms:description ?msg .\n-        } WHERE {\n-            ?report a sh:ValidationReport ;\n-                    dcterms:identifier \"W-DIALECT-DATALOG\" ;\n-                    sh:conforms ?conforms ;\n-                    dcterms:description ?msg .\n-        }\n-    \"\"\" .\n-\n-# Hook W-DIALECT-SHEX\n-<#w_dialect_shex> a prov:Plan , sh:NodeShape ;\n-    dcterms:identifier \"W-DIALECT-SHEX\" ;\n-    prov:value \"\"\"\n-        PREFIX prov: <http://www.w3.org/ns/prov#>\n-        PREFIX sh: <http://www.w3.org/ns/shacl#>\n-        PREFIX dcterms: <http://purl.org/dc/terms/>\n-        PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n-        CONSTRUCT {\n-            [] a sh:ValidationReport ;\n-                dcterms:identifier \"W-DIALECT-SHEX\" ;\n-                sh:conforms ?conforms ;\n-                dcterms:description ?msg .\n-        } WHERE {\n-            ?report a sh:ValidationReport ;\n-                    dcterms:identifier \"W-DIALECT-SHEX\" ;\n-                    sh:conforms ?conforms ;\n-                    dcterms:description ?msg .\n-        }\n-    \"\"\" .\n" .

<#case_11_transcript> a prov:Entity ;
    rdfs:label "transcript" ;
    prov:value "STDOUT:\nW7: Actuating Hook Evaluation Runtime...\n\nSTDERR:\nFAIL: Hook pack missing at \"/Users/sac/.cache/tmp/.tmpxL7Vca/crates/ggen-graph/hooks/gall-code-evaluation.ttl\"\n" .

<#case_12_result> a sh:ValidationResult ;
    sh:resultSeverity sh:Info ;
    sh:focusNode <#case_12> ;
    sh:resultMessage "Mutation invalid_sparql_query_syntax: refused (PASS)" ;
    prov:value "REFUSED" .

<#case_12> a prov:Entity ;
    dcterms:title "invalid_sparql_query_syntax" ;
    dcterms:description "Inject invalid syntax into a SPARQL hook fixture" ;
    prov:value <#case_12_diff> ;
    prov:value <#case_12_transcript> .

<#case_12_diff> a prov:Entity ;
    rdfs:label "diff" ;
    prov:value "diff --git a/crates/ggen-graph/hooks/gall-code-evaluation.ttl b/crates/ggen-graph/hooks/gall-code-evaluation.ttl\nindex 5f406e9..75511d5 100644\n--- a/crates/ggen-graph/hooks/gall-code-evaluation.ttl\n+++ b/crates/ggen-graph/hooks/gall-code-evaluation.ttl\n@@ -377,3 +377,5 @@\n                     dcterms:description ?msg .\n         }\n     \"\"\" .\n+\n+INVALID SPARQL QUERY SYNTAX\n" .

<#case_12_transcript> a prov:Entity ;
    rdfs:label "transcript" ;
    prov:value "STDOUT:\nW7: Actuating Hook Evaluation Runtime...\n\nSTDERR:\nError: Parsing(Syntax(RdfSyntaxError(Turtle(TurtleSyntaxError { location: TextPosition { line: 380, column: 0, offset: 14390 }..TextPosition { line: 380, column: 7, offset: 14397 }, message: \"INVALID is not a valid subject or graph name\" }))))\n" .

