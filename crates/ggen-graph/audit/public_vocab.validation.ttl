@base <http://example.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<#public_vocab_report> a sh:ValidationReport ;
    sh:conforms "false"^^xsd:boolean ;
    dcterms:identifier "public_vocab.validation" ;
    dcterms:description "R7 Public Vocabulary Gate Report" ;
    sh:result [
        a sh:ValidationResult ;
        sh:resultSeverity sh:Violation ;
        sh:resultMessage "Project-private prefix/namespace violations: [(\"/Users/sac/ggen/schema/stpnt-shapes-welcome.ttl\", \"Namespace laundering detected: URI http://www.w3.org/ns/shacl#name is in namespace http://www.w3.org/ns/shacl# but local name 'name' is not whitelisted\")]"
    ] .
