@base <http://example.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<#hook_actuation_report> a sh:ValidationReport ;
    sh:conforms "true"^^xsd:boolean ;
    dcterms:identifier "hook_actuation.validation" ;
    dcterms:description "Hook Actuation and Execution Conformance Report" ;
    dcterms:title "All hooks executed successfully and conformed." .
