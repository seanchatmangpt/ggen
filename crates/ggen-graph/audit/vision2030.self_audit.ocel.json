{
  "objects": [
    {
      "id": "obj_crate_ggen",
      "type": "RustCrate",
      "attributes": {
        "name": "ggen-graph",
        "version": "0.1.0"
      }
    },
    {
      "id": "obj_prd_compliance",
      "type": "PRDRequirement",
      "attributes": {
        "title": "Self-Audit Compliance Log",
        "description": "The system must generate a self-audit log containing all required activities and objects."
      }
    },
    {
      "id": "obj_ard_mapping",
      "type": "ARDRequirement",
      "attributes": {
        "description": "Self-audit logs must project deterministically to and from RDF triple graphs.",
        "title": "Deterministic Graph Mapping"
      }
    },
    {
      "id": "req_r1_one_crate",
      "type": "PRDRequirement",
      "attributes": {
        "title": "One-Crate Package Boundary and No Feature Flags",
        "description": "The substrate must be implemented as a single standalone Rust package at crates/ggen-graph with no feature flags."
      }
    },
    {
      "id": "req_r2_ontology",
      "type": "PRDRequirement",
      "attributes": {
        "title": "Public Ontology Governance and Vocabulary Emission",
        "description": "Vocabulary constants must be emitted directly from public ontology profiles."
      }
    },
    {
      "id": "req_r3_deterministic",
      "type": "PRDRequirement",
      "attributes": {
        "title": "Deterministic Graph Substrate and Delta Conservation",
        "description": "Graph parsing, serialization, canonical byte generation, hashing, and RdfDelta transitions must be deterministic."
      }
    },
    {
      "id": "req_r4_knowledge_hook",
      "type": "PRDRequirement",
      "attributes": {
        "title": "Knowledge Hook Runtime & Deterministic Scheduling",
        "description": "Turtle-based hook packs must load dynamically as graph laws and schedule deterministically."
      }
    },
    {
      "id": "req_r5_ocel_prov",
      "type": "PRDRequirement",
      "attributes": {
        "description": "Every graph transition must produce a replayable cryptographic receipt bundle and project PROV-O/OCEL.",
        "title": "OCEL/PROV Evidence Projection & Replayable Receipts"
      }
    },
    {
      "id": "req_r6_compliance",
      "type": "PRDRequirement",
      "attributes": {
        "title": "Compliance Checks & Anti-Fake Gates",
        "description": "Must pass structural analyses checking for forbidden execution surfaces and zero placeholder/stub/mock/fake-success patterns."
      }
    },
    {
      "id": "req_r7_ocel_self_audit",
      "type": "PRDRequirement",
      "attributes": {
        "title": "OCEL v2 Self-Audit Log Emission",
        "description": "Implement self-audit log generator emitting vision2030.self_audit.ocel.json."
      }
    },
    {
      "id": "req_r8_coverage_matrix",
      "type": "PRDRequirement",
      "attributes": {
        "title": "Coverage Matrix & Verification Scripts",
        "description": "Implement coverage mapping in coverage.rs and verify via scripts."
      }
    },
    {
      "id": "req_r9_proof_report",
      "type": "PRDRequirement",
      "attributes": {
        "title": "Vision 2030 Durable Proof Report",
        "description": "Establish Vision 2030 durable proof report."
      }
    },
    {
      "id": "req_r10_interchangeable",
      "type": "PRDRequirement",
      "attributes": {
        "description": "Ensure interchangeable parts where Genesis is the embedded core and ggen forms the outer membrane, adapter layer, and projection layer.",
        "title": "Genesis-bearing Interchangeable Part Architecture"
      }
    },
    {
