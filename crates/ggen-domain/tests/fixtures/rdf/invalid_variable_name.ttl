@prefix mcpp: <http://mcpp.dev/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/template1> a mcpp:Template ;
  mcpp:templateName "Template with Invalid Variable Name" ;
  mcpp:templateVersion "1.0.0" ;
  mcpp:hasVariable [
    a mcpp:Variable ;
    mcpp:variableName "123-invalid-name" ;
    mcpp:variableType "string" ;
    mcpp:isRequired "true"^^xsd:boolean
  ] .
