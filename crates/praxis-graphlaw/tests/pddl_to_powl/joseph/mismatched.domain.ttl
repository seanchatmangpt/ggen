@prefix ex: <http://example.org/joseph#> .
@prefix ceng: <urn:chatman:engine#> .

ex:mismatched a ex:RefusalFixture .

ex:mismatched ceng:pddlDomain """
(define (domain not-joseph-famine)
  (:requirements :strips)
  (:predicates
    (stray-pre ?x)
    (stray-eff ?x))
  (:action stray-action
    :parameters (?x)
    :precondition (and (stray-pre ?x))
    :effect (and (stray-eff ?x))))
""" .
