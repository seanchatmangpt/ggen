# Genesis Creation Week, day-07-rest-sanctification (domain fragment): the work is complete; rest is blessed and sanctified.
# One admitted PDDL Turtle planning artifact. Days are planning sources, not
# workflows: every fragment shares the domain name 'creation-week' and merges
# structurally into ONE combined seven-day plan whose projection is the one
# creation-week POWL v2 workflow. Formal process example; argues no doctrine,
# claims no historicity.
@prefix ex: <http://example.org/genesis#> .
@prefix ceng: <urn:chatman:engine#> .

ex:day-07-rest-sanctification a ex:CreationDay ;
  ex:daySequence 7 ;
  ex:intends ex:complete-work, ex:bless-seventh-day, ex:rest .

ex:day-07-rest-sanctification ceng:pddlDomain """
(define (domain creation-week)
  (:requirements :strips)
  (:predicates
    (humanity-created ?x)
    (work-complete ?x)
    (seventh-day-blessed ?x)
    (rest-taken ?x))
  (:action complete-work
    :parameters (?x)
    :precondition (and (humanity-created ?x))
    :effect (and (work-complete ?x)))
  (:action bless-seventh-day
    :parameters (?x)
    :precondition (and (work-complete ?x))
    :effect (and (seventh-day-blessed ?x)))
  (:action rest
    :parameters (?x)
    :precondition (and (seventh-day-blessed ?x))
    :effect (and (rest-taken ?x))))
""" .
