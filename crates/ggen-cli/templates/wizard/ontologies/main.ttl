@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix mcpp: <https://mcpp.io/ontology#> .

# mcpp Main Ontology
# Generated by mcpp wizard

mcpp:Output a rdfs:Class ;
    rdfs:label "Output" ;
    rdfs:comment "A generated output artifact" .

mcpp:path a rdf:Property ;
    rdfs:domain mcpp:Output ;
    rdfs:range rdfs:Literal ;
    rdfs:label "path" ;
    rdfs:comment "File path of the output" .

mcpp:format a rdf:Property ;
    rdfs:domain mcpp:Output ;
    rdfs:range rdfs:Literal ;
    rdfs:label "format" ;
    rdfs:comment "Format of the output (json, yaml, mermaid, etc.)" .

mcpp:validator a rdf:Property ;
    rdfs:domain mcpp:Output ;
    rdfs:range rdfs:Literal ;
    rdfs:label "validator" ;
    rdfs:comment "Validator to use for this output" .
