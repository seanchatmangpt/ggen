{#
  Elixir Benchee SPARQL Benchmark Generator
  Generates Benchee benchmarks for OSA/Canopy SPARQL operations

  Query types: SELECT, ASK, CONSTRUCT, DESCRIBE
  Metrics: execution time, memory usage, result count
#}
defmodule {{ module_prefix }}.SPARQLBenchmarks do
  @moduledoc """
  Auto-generated SPARQL query benchmarks for {{ project_name }}.

  Generated by: ggen-ontology-core
  Date: {{ date }}
  Source ontology: {{ ontology_uri }}

  Benchmark coverage:
  {% for category in query_categories -%}
  - {{ category.name }} ({{ category.count }} queries)
  {% endfor %}

  Performance SLOs:
  {% for target in performance_targets -%}
  - {{ target.query_type }}: p95 < {{ target.target_ms }}ms
  {% endfor %}

  ## Running Benchmarks

  ```bash
  # Run all SPARQL benchmarks
  mix test test/sparql_benchmarks_test.exs

  # Run specific benchmark suite
  mix test test/sparql_benchmarks_test.exs:line_number

  # Generate HTML report
  mix bench --output bench_output
  ```

  ## Requirements

  - Oxigraph running at localhost:7878
  - Test ontologies loaded in priv/ontologies/
  """

  use Benchee

  alias {{ module_prefix }}.Ontology.Registry
  alias {{ module_prefix }}.Ontology.OxigraphClient

  @moduletag :benchmark
  @moduletag :sparql

  @doc """
  Setup all benchmarks: ensure Oxigraph is available and load ontologies.
  """
  setup_all do
    # Ensure Oxigraph is available
    case OxigraphClient.health_check() do
      {:ok, _} -> :ok
      {:error, reason} -> flunk("Oxigraph unavailable: #{inspect(reason)}")
    end

    # Load test ontologies
    :ok = Registry.load_ontologies()

    :ok
  end

  {% for category in query_categories %}
  @doc """
  Benchmark {{ category.name }} queries.

  Complexity: {{ category.complexity }}
  Query count: {{ category.count }}
  """
  describe "{{ category.name }}" do
    @tag timeout: {{ category.timeout_ms }}

    {% for query in category.queries %}
    test "{{ query.name }}" do
      query = {{ query.query_literal }}

      Benchee.run(%{
        "{{ query.name }}" => fn ->
          Registry.execute_sparql(query)
        end
      },
      warmup: {{ config.warmup | default(value=2) }},
      time: {{ config.time | default(value=5) }},
      memory_time: {{ config.memory_time | default(value=2) }},
      print: [fast_warning: false],
      formatters: [
        {Benchee.Formatters.Console, extended_statistics: true},
        {Benchee.Formatters.HTML, file: "bench_output/{{ query.name }}.html"}
      ])

      # Verify SLO: p95 latency < {{ query.target_ms }}ms
      assert statistics.percentiles.{:p95} < {{ query.target_ms }}
    end

    {% endfor %}
  end

  {% endfor %}

  @doc """
  Benchmark mixed workload with different query types.
  """
  test "mixed workload" do
    queries = [
      {% for query in representative_queries %}
      {{"{{ query.name }}", {{ query.query_literal }}}{% if not loop.last %},{% endif %}
      {% endfor %}
    ]

    Benchee.run(%{
      "mixed_queries" => fn ->
        Enum.each(queries, fn {_name, query} ->
          Registry.execute_sparql(query)
        end)
      end
    },
    warmup: 2,
    time: 10,
    memory_time: 2,
    print: [fast_warning: false],
    formatters: [
      {Benchee.Formatters.Console, extended_statistics: true}
    ])
  end

  @doc """
  Benchmark concurrent query execution.
  """
  test "concurrent queries" do
    query = {{ representative_queries[0].query_literal }}

    Benchee.run(%{
      "single_thread" => fn ->
        Registry.execute_sparql(query)
      end,
      "parallel_2" => fn ->
        task1 = Task.async(fn -> Registry.execute_sparql(query) end)
        task2 = Task.async(fn -> Registry.execute_sparql(query) end)

        Task.await(task1)
        Task.await(task2)
      end,
      "parallel_4" => fn ->
        tasks = for _ <- 1..4 do
          Task.async(fn -> Registry.execute_sparql(query) end)
        end

        Task.await_many(tasks)
      end
    },
    warmup: 1,
    time: 5,
    memory_time: 1,
    print: [fast_warning: false])
  end

  @doc """
  Benchmark query result streaming for large result sets.
  """
  test "streaming large results" do
    query = """
      PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
      PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

      SELECT ?subject ?predicate ?object
      WHERE {
        ?subject ?predicate ?object
      }
      LIMIT 10000
    """

    Benchee.run(%{
      "stream_results" => fn ->
        {:ok, stream} = Registry.execute_sparql_stream(query)

        stream
        |> Stream.take(1000)
        |> Enum.to_list()
      end
    },
    warmup: 1,
    time: 5,
    memory_time: 2,
    print: [fast_warning: false])
  end
end
