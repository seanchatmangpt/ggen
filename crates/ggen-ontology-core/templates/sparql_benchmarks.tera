{#
  SPARQL Query Benchmark Generator for Criterion.rs
  Generates comprehensive SPARQL query benchmarks from RDF ontology

  Query types: SELECT, ASK, CONSTRUCT, DESCRIBE
  Complexity levels: Simple, Medium, Complex
  Metrics: latency, throughput, result size
#}
//! Criterion.rs SPARQL Query Benchmark Suite
//!
//! Auto-generated by ggen from {{ ontology_uri }}
//! Generation date: {{ date }}
//!
//! Benchmark coverage:
//! {% for query in queries -%}
//! - {{ query.name }} ({{ query.complexity }})
//! {% endfor -%}
//!
//! Performance targets:
//! {% for target in performance_targets -%}
//!   - {{ target.query_type }}: {{ target.target_ms }}ms (p95)
//! {% endfor -%}
//!
//! Run with:
//!   cargo bench --bench sparql_benchmarks

use criterion::{black_box, criterion_group, criterion_main, BenchmarkId, Criterion, ThroughputData};
use ggen_ontology_core::{
    triple_store::TripleStore,
    sparql_generator::SparqlGenerator,
};
use std::time::Duration;

/// Helper function to get ontology path
fn get_ontology_path(filename: &str) -> String {
    format!("{}/ontologies/{}", env!("CARGO_MANIFEST_DIR"), filename)
}

{% for category in query_categories %}
// ========== {{ category.name }} Queries ==========

{% for query in category.queries %}
fn bench_{{ query.name | snake_case }}(c: &mut Criterion) {
    let mut group = c.benchmark_group("{{ category.name }}");
    group.measurement_time(Duration::from_secs(10));
    group.warm_up_time(Duration::from_secs(2));

    // Setup: load required ontologies
    let store = TripleStore::new().unwrap();
    {% for ontology in query.required_ontologies %}
    let _ = store.load_turtle(get_ontology_path("{{ ontology }}"));
    {% endfor %}

    let query_text = {{ query.query_literal }};

    {% if query.has_result_size %}
    group.throughput(ThroughputData::Elements({{ query.expected_result_size }} as u64));
    {% endif %}

    group.bench_with_input(
        BenchmarkId::new("{{ query.name }}", {{ query.complexity_score }}),
        &query_text,
        |b, query| {
            b.iter(|| {
                black_box(store.query_sparql(query))
            })
        },
    );

    group.finish();
}

{% endfor %}
{% endfor %}

// ========== Aggregate Benchmarks ==========

fn bench_sparql_mixed_workload(c: &mut Criterion) {
    let mut group = c.benchmark_group("mixed_workload");
    group.measurement_time(Duration::from_secs(15));

    let store = TripleStore::new().unwrap();

    // Load all test ontologies
    let ontologies = vec![
        {% for ontology in all_ontologies %}
        "{{ ontology }}",
        {% endfor %}
    ];

    for ontology in ontologies {
        let _ = store.load_turtle(get_ontology_path(ontology));
    }

    // Mix of different query types
    let queries = vec![
        {% for query in representative_queries %}
        ("{{ query.name }}", {{ query.query_literal }}),
        {% endfor %}
    ];

    group.bench_function("mixed_queries", |b| {
        b.iter(|| {
            for (name, query) in &queries {
                black_box(store.query_sparql(query));
            }
        })
    });

    group.finish();
}

fn bench_sparql_concurrent(c: &mut Criterion) {
    use std::sync::Arc;
    use std::thread;

    let mut group = c.benchmark_group("concurrent");
    group.measurement_time(Duration::from_secs(5));

    let store = Arc::new(TripleStore::new().unwrap());

    // Load ontologies once
    {% for ontology in all_ontologies %}
    let _ = store.load_turtle(get_ontology_path("{{ ontology }}"));
    {% endfor %}

    for thread_count in [1, 2, 4, 8].iter() {
        group.bench_with_input(
            BenchmarkId::new("concurrent_queries", thread_count),
            thread_count,
            |b, &thread_count| {
                b.iter(|| {
                    let handles: Vec<_> = (0..thread_count)
                        .map(|_| {
                            let store_clone = Arc::clone(&store);
                            thread::spawn(move || {
                                {% for query in representative_queries %}
                                let query = {{ query.query_literal }};
                                let _ = store_clone.query_sparql(query);
                                {% endfor %}
                            })
                        })
                        .collect();

                    for handle in handles {
                        let _ = handle.join();
                    }
                })
            },
        );
    }

    group.finish();
}

criterion_group!(
    benches,
    {% for category in query_categories -%}
    {% for query in category.queries -%}
    bench_{{ query.name | snake_case }},
    {% endfor -%}
    {% endfor -%}
    bench_sparql_mixed_workload,
    bench_sparql_concurrent,
);
criterion_main!(benches);
