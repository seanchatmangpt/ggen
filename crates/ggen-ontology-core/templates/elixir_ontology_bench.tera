{#
  Elixir Ontology Benchmark Generator
  Generates Benchee benchmarks for OSA and Canopy ontology operations
#}
defmodule {{ module }}.Benchmarks do
  @moduledoc """
  Auto-generated ontology benchmarks for {{ project }}.

  Generated by: ggen-ontology-core
  Date: {{ date }}
  Operations: {{ operations | join(", ") }}

  Benchmark SLOs:
  {% for slo in slo_targets %}
  - {{ slo.operation }}: {{ slo.target_ms }}ms target
  {% endfor %}
  """

  use Benchee

  alias {{ module }}.Ontology.Registry
  alias {{ module }}.Ontology.OxigraphClient

  @moduletag :benchmark
  @moduletag :ontology

  # All benchmarks require Oxigraph running at localhost:7878
  setup_all do
    # Ensure Oxigraph is available
    case OxigraphClient.health_check() do
      {:ok, _} -> :ok
      {:error, reason} -> flunk("Oxigraph unavailable: #{inspect(reason)}")
    end

    # Load test ontologies
    :ok = Registry.load_ontologies()

    :ok
  end

  {% for operation in operations %}
  @tag {{ operation.name | snake_case }}: true
  bench "{{ operation.name }}" do
    {{ operation.benchmark_code }}
  end

  {% endfor %}
end
