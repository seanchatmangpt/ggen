    public sealed interface ApiError
        permits ApiError.NotFound, ApiError.ValidationFailed, ApiError.Conflict, ApiError.Forbidden, ApiError.Unexpected {

        record NotFound(String resourceType, {{ id_t }} id) implements ApiError {}
        record ValidationFailed(String field, String reason) implements ApiError {}
