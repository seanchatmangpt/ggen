{%- if jv >= 23 %}
    /// Immutable response record for [{{ entity_name }}].
{%- else %}
    /**
     * Immutable response record for {@link {{ entity_name }}}.
     */
{%- endif %}
    public record {{ entity_name }}Response(
        {{ id_t }} id{% if attributes | default(value=[]) | length > 0 %},{% endif %}

{%- for attr in attributes | default(value=[]) %}
        {{ attr.type | default(value="String") }} {{ attr.name }}{% if not loop.last %},{% endif %}

{%- endfor %}
    ) {
