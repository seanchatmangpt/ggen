{%- if fw == "spring" %}

    @ExceptionHandler({{ entity_name }}NotFoundException.class)
    public ResponseEntity<ProblemDetail> handleNotFound({{ entity_name }}NotFoundException ex) {
        var problem = ProblemDetail.forStatus(HttpStatus.NOT_FOUND);
        problem.setTitle("{{ entity_name }} Not Found");
        problem.setDetail(ex.getMessage());
        return ResponseEntity.status(HttpStatus.NOT_FOUND).body(problem);
    }

    @ExceptionHandler({{ entity_name }}ValidationException.class)
    public ResponseEntity<ProblemDetail> handleValidation({{ entity_name }}ValidationException ex) {
        var problem = ProblemDetail.forStatus(HttpStatus.UNPROCESSABLE_ENTITY);
        problem.setTitle("Validation Failed");
        problem.setDetail(ex.getMessage());
        problem.setProperty("field", ex.field());
        return ResponseEntity.status(HttpStatus.UNPROCESSABLE_ENTITY).body(problem);
    }

    @ExceptionHandler({{ entity_name }}ConflictException.class)
    public ResponseEntity<ProblemDetail> handleConflict({{ entity_name }}ConflictException ex) {
        var problem = ProblemDetail.forStatus(HttpStatus.CONFLICT);
        problem.setTitle("Conflict");
        problem.setDetail(ex.getMessage());
        return ResponseEntity.status(HttpStatus.CONFLICT).body(problem);
    }

    @ExceptionHandler(Exception.class)
    public ResponseEntity<ProblemDetail> handleUnexpected(Exception ex) {
        var problem = ProblemDetail.forStatus(HttpStatus.INTERNAL_SERVER_ERROR);
        problem.setTitle("Internal Server Error");
        problem.setDetail("An unexpected error occurred");
        return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR).body(problem);
    }
{%- elif fw == "micronaut" %}

    @Error
    public HttpResponse<{{ entity_name }}ErrorResponse> handleDomainException({{ entity_name }}DomainException ex) {
        var status = switch (ex) {
            case {{ entity_name }}NotFoundException e -> HttpStatus.NOT_FOUND;
            case {{ entity_name }}ValidationException e -> HttpStatus.UNPROCESSABLE_ENTITY;
            case {{ entity_name }}ConflictException e -> HttpStatus.CONFLICT;
        };
        return HttpResponse.<{{ entity_name }}ErrorResponse>status(status)
            .body(new {{ entity_name }}ErrorResponse(ex.getMessage()));
    }
{%- elif fw == "quarkus" %}

