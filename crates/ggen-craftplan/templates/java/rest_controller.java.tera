{%- endif %}
{%- if fw == "spring" %}
    @GetMapping
{%- if jv >= 21 %}
    @Async
{%- endif %}
    public {% if jv >= 21 %}CompletableFuture<{% endif %}ResponseEntity<List<{{ entity_name }}Response>>{% if jv >= 21 %}>{% endif %} listAll() {
{%- if jv >= 21 %}
        return CompletableFuture.supplyAsync(() ->
            ResponseEntity.ok({{ entity_lower }}Service.findAll().stream()
                .map({{ entity_name }}Response::from)
                .toList()),
            VIRTUAL_EXECUTOR
        );
{%- else %}
        return ResponseEntity.ok({{ entity_lower }}Service.findAll().stream()
            .map({{ entity_name }}Response::from)
            .toList());
{%- endif %}
    }
{%- elif fw == "micronaut" %}
    @Get
    @ExecuteOn(TaskExecutors.VIRTUAL)
    public HttpResponse<List<{{ entity_name }}Response>> listAll() {
        return HttpResponse.ok({{ entity_lower }}Service.findAll().stream()
            .map({{ entity_name }}Response::from)
            .toList());
    }
{%- elif fw == "quarkus" %}
    @GET
    @RunOnVirtualThread
    public Response listAll() {
        return Response.ok({{ entity_lower }}Service.findAll().stream()
            .map({{ entity_name }}Response::from)
            .toList()).build();
    }
{%- endif %}

{%- if jv >= 23 %}
    /// Find a [{{ entity_name }}] by its primary key.
