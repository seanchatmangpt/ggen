{%- endfor %}
    ) {
        public {{ entity_name }}Request {
{%- for attr in attributes | default(value=[]) %}
{%- if attr.constraints is defined and (attr.constraints.not_null | default(value=false) or attr.constraints.not_blank | default(value=false)) %}
            Objects.requireNonNull({{ attr.name }}, "{{ attr.name }} must not be null");
{%- endif %}
{%- endfor %}
        }
