{%- if fw == "spring" %}
    @GetMapping("/{id}")
    public ResponseEntity<{{ entity_name }}Response> getById(@PathVariable {{ id_t }} id) {
        return {{ entity_lower }}Service.findById(id)
            .map({{ entity_name }}Response::from)
            .map(ResponseEntity::ok)
            .orElseThrow(() -> new {{ entity_name }}NotFoundException(id));
    }
{%- elif fw == "micronaut" %}
    @Get("/{id}")
    @ExecuteOn(TaskExecutors.VIRTUAL)
    public HttpResponse<{{ entity_name }}Response> getById(@PathVariable {{ id_t }} id) {
        return {{ entity_lower }}Service.findById(id)
