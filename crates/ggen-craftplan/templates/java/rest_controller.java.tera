/// - `GET    /{{ entity_plural }}/{id}`    - find by id
/// - `POST   /{{ entity_plural }}`         - create
/// - `PUT    /{{ entity_plural }}/{id}`    - update
/// - `DELETE /{{ entity_plural }}/{id}`    - delete
///
/// Framework: {{ fw }} | Java {{ jv }}+
/// Generated from RDF specification.
{%- else %}
/**
 * REST controller for {@link {{ entity_name }}} CRUD operations.
 *
 * <p>Endpoints:
 * <ul>
 *   <li>{@code GET    /{{ entity_plural }}}       - list all</li>
 *   <li>{@code GET    /{{ entity_plural }}/{id}}  - find by id</li>
 *   <li>{@code POST   /{{ entity_plural }}}       - create</li>
 *   <li>{@code PUT    /{{ entity_plural }}/{id}}  - update</li>
 *   <li>{@code DELETE /{{ entity_plural }}/{id}}  - delete</li>
