    @RunOnVirtualThread
    public Response getById(@PathParam("id") {{ id_t }} id) {
        return {{ entity_lower }}Service.findById(id)
            .map({{ entity_name }}Response::from)
            .map(r -> Response.ok(r).build())
            .orElseThrow(() -> new {{ entity_name }}NotFoundException(id));
    }
{%- endif %}

{%- if jv >= 23 %}
    /// Create a new [{{ entity_name }}].
    /// @param request validated request body
    /// @return 201 Created with Location header
{%- else %}
    /**
     * Create a new {@link {{ entity_name }}}.
     * @param request validated request body
     * @return 201 Created with Location header
     */
{%- endif %}
{%- if fw == "spring" %}
    @PostMapping
    public ResponseEntity<{{ entity_name }}Response> create(@Valid @RequestBody {{ entity_name }}Request request) {
        var created = {{ entity_lower }}Service.create(toEntity(request));
        var response = {{ entity_name }}Response.from(created);
        var location = URI.create("/{{ entity_plural }}/" + response.id());
        return ResponseEntity.created(location).body(response);
    }
{%- elif fw == "micronaut" %}
    @Post
    @ExecuteOn(TaskExecutors.VIRTUAL)
    public HttpResponse<{{ entity_name }}Response> create(@Valid @Body {{ entity_name }}Request request) {
        var created = {{ entity_lower }}Service.create(toEntity(request));
        var response = {{ entity_name }}Response.from(created);
        return HttpResponse.created(response, URI.create("/{{ entity_plural }}/" + response.id()));
    }
{%- elif fw == "quarkus" %}
    @POST
    @RunOnVirtualThread
    public Response create(@Valid {{ entity_name }}Request request) {
        var created = {{ entity_lower }}Service.create(toEntity(request));
        var response = {{ entity_name }}Response.from(created);
        var location = UriBuilder.fromPath("/{{ entity_plural }}/{id}").build(response.id());
        return Response.created(location).entity(response).build();
    }
{%- endif %}

