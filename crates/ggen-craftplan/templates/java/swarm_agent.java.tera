    public String id() { return id; }
    public AgentStatus status() { return status; }

    @Override
    public void close() {
        status = AgentStatus.IDLE;
        state.clear();
    }

    // --- Supporting types ---

    public enum AgentStatus { IDLE, RUNNING, FAILED }

    public enum ExecutionMode { SEQUENTIAL, PARALLEL, RACE }

    public record AgentConfig(
        List<AgentStage> stages,
        ExecutionMode executionMode,
        int maxRetries
    ) {
        public AgentConfig {
            java.util.Objects.requireNonNull(stages, "stages must not be null");
            java.util.Objects.requireNonNull(executionMode, "executionMode must not be null");
        }
    }

    public record AgentContext(
        String requestId,
        Map<String, Object> parameters,
        java.time.Instant deadline
    ) {}

    public record StageResult(
        String stageName,
        boolean success,
        Object output,
        String errorMessage
    ) {}

    public record AgentOutput(
        String agentId,
        List<StageResult> results,
        AgentStatus finalStatus
    ) {
        public boolean succeeded() {
            return results.stream().allMatch(StageResult::success);
        }
    }

    @FunctionalInterface
    public interface AgentStage {
        StageResult execute(AgentContext context, Map<String, Object> state) throws Exception;
    }
}
