    }

    // =========================================================================
    // Object contract
    // =========================================================================

    @Override
    public boolean equals(Object o) {
        return switch (o) {
            case {{ aggregate_name }} that -> Objects.equals(this.id, that.id);
            case null, default            -> false;
        };
    }

    @Override
    public int hashCode() { return Objects.hash(id); }

    @Override
    public String toString() {
        return "{{ aggregate_name }}[id=" + id + ", version=" + version + "]";
