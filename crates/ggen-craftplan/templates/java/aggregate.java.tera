{%- endfor %}

{%- if jv >= 23 %}
    /// Pending (unpublished) domain events.
{%- else %}
    /** Pending (unpublished) domain events. */
{%- endif %}
    public List<{{ aggregate_name }}Event> pendingDomainEvents() {
