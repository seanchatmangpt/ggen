{#- Application Properties Template - Spring Boot / Micronaut / Quarkus config -#}
{#- Context: app_name, port, db_url, java_version, framework (spring|micronaut|quarkus) -#}
{%- set jv = java_version | default(value=21) -%}
{%- set fw = framework | default(value="spring") -%}
{%- set svc_port = port | default(value=8080) -%}
{%- set mgmt_port = management_port | default(value=8081) -%}
{%- set db = db_url | default(value="jdbc:postgresql://localhost:5432/appdb") -%}

# =============================================================================
# {{ app_name | default(value="app") }} — generated by ggen v6.0.0
# Framework : {{ fw }}
# Java      : {{ jv }}
# =============================================================================

{%- if fw == "spring" %}

# ─── Spring Boot ──────────────────────────────────────────────────────────────

## Application identity
spring.application.name={{ app_name | default(value="app") }}

## Server
server.port={{ svc_port }}
server.shutdown=graceful
spring.lifecycle.timeout-per-shutdown-phase=30s

## Virtual threads (Spring Boot 3.2+ / Spring Framework 6.1+ with Java 21+)
{%- if jv >= 21 %}
spring.threads.virtual.enabled=true
{%- endif %}

## Thread pool (Tomcat embedded)
## With virtual threads the container thread pool is not the bottleneck,
## but we still cap acceptors to avoid fd exhaustion.
server.tomcat.threads.max=200
server.tomcat.threads.min-spare=10
server.tomcat.accept-count=100
server.tomcat.connection-timeout=5000

## ─── Database ───────────────────────────────────────────────────────────────

spring.datasource.url={{ db }}
spring.datasource.username=${DB_USERNAME:appuser}
spring.datasource.password=${DB_PASSWORD:changeme}
spring.datasource.driver-class-name=org.postgresql.Driver

## HikariCP — tuned for virtual threads
## Virtual threads block on I/O, not on CPU, so a larger pool is fine.
## See https://github.com/brettwooldridge/HikariCP/wiki/About-Pool-Sizing
spring.datasource.hikari.pool-name=HikariPool-{{ app_name | default(value="app") }}
spring.datasource.hikari.maximum-pool-size=20
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.connection-timeout=20000
spring.datasource.hikari.max-lifetime=1200000
spring.datasource.hikari.keepalive-time=60000
spring.datasource.hikari.validation-timeout=3000
spring.datasource.hikari.leak-detection-threshold=60000
{%- if jv >= 21 %}
# Allow virtual threads to park during JDBC calls
spring.datasource.hikari.thread-factory=virtual
{%- endif %}

## JPA / Hibernate
spring.jpa.open-in-view=false
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=false
spring.jpa.properties.hibernate.jdbc.time_zone=UTC

## ─── Logging ────────────────────────────────────────────────────────────────

logging.level.root=WARN
logging.level.{{ group_id | default(value="com.example") }}=INFO
logging.level.org.springframework.web=INFO
logging.level.org.hibernate.SQL=WARN
logging.level.com.zaxxer.hikari=INFO
logging.pattern.console=%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n

## ─── Actuator / Observability ───────────────────────────────────────────────

management.server.port={{ mgmt_port }}
management.endpoints.web.exposure.include=health,info,metrics,prometheus,loggers
management.endpoint.health.show-details=when-authorized
management.endpoint.health.probes.enabled=true
management.health.livenessState.enabled=true
management.health.readinessState.enabled=true
management.metrics.export.prometheus.enabled=true
management.tracing.sampling.probability=1.0

## ─── Jackson ────────────────────────────────────────────────────────────────

spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.time-zone=UTC
spring.jackson.default-property-inclusion=NON_NULL

{%- elif fw == "micronaut" %}

# ─── Micronaut ────────────────────────────────────────────────────────────────

micronaut.application.name={{ app_name | default(value="app") }}

## Server
micronaut.server.port={{ svc_port }}
micronaut.server.idle-timeout=5m

{%- if jv >= 21 %}
## Virtual thread executor (Micronaut 4.x)
micronaut.executors.io.type=FIXED
micronaut.executors.io.virtual-threads=true
{%- endif %}

## ─── Database ───────────────────────────────────────────────────────────────

datasources.default.url={{ db }}
datasources.default.username=${DB_USERNAME:appuser}
datasources.default.password=${DB_PASSWORD:changeme}
datasources.default.driver-class-name=org.postgresql.Driver

## HikariCP — tuned for virtual threads
datasources.default.maximum-pool-size=20
datasources.default.minimum-idle=5
datasources.default.idle-timeout=300000
datasources.default.connection-timeout=20000
datasources.default.max-lifetime=1200000

## ─── Logging ────────────────────────────────────────────────────────────────

logger.levels.root=WARN
logger.levels.{{ group_id | default(value="com.example") }}=INFO
logger.levels.io.micronaut.http=INFO

## ─── Management ─────────────────────────────────────────────────────────────

endpoints.all.port={{ mgmt_port }}
endpoints.health.enabled=true
endpoints.health.sensitive=false
endpoints.metrics.enabled=true
endpoints.prometheus.enabled=true

{%- elif fw == "quarkus" %}

# ─── Quarkus ──────────────────────────────────────────────────────────────────

quarkus.application.name={{ app_name | default(value="app") }}

## HTTP
quarkus.http.port={{ svc_port }}
quarkus.http.idle-timeout=5M

{%- if jv >= 21 %}
## Virtual thread executor (Quarkus 3.x — annotate endpoints with @RunOnVirtualThread)
quarkus.vertx.worker-pool-size=200
{%- endif %}

## ─── Database ───────────────────────────────────────────────────────────────

quarkus.datasource.db-kind=postgresql
quarkus.datasource.jdbc.url={{ db }}
quarkus.datasource.username=${DB_USERNAME:appuser}
quarkus.datasource.password=${DB_PASSWORD:changeme}

## Agroal connection pool (Quarkus default) — tuned for virtual threads
quarkus.datasource.jdbc.max-size=20
quarkus.datasource.jdbc.min-size=5
quarkus.datasource.jdbc.acquisition-timeout=20S
quarkus.datasource.jdbc.idle-removal-interval=5M
quarkus.datasource.jdbc.max-lifetime=20M

## Hibernate ORM
quarkus.hibernate-orm.database.generation=validate
quarkus.hibernate-orm.log.sql=false

## ─── Logging ────────────────────────────────────────────────────────────────

quarkus.log.level=WARN
quarkus.log.category."{{ group_id | default(value="com.example") }}".level=INFO
quarkus.log.console.format=%d{yyyy-MM-dd HH:mm:ss,SSS} %-5p [%c{3.}] (%t) %s%e%n

## ─── Management ─────────────────────────────────────────────────────────────

quarkus.management.enabled=true
quarkus.management.port={{ mgmt_port }}
quarkus.smallrye-health.root-path=/health
quarkus.smallrye-metrics.path=/metrics

{%- else %}

# ─── Generic / Plain Java ─────────────────────────────────────────────────────

app.name={{ app_name | default(value="app") }}
app.port={{ svc_port }}

{%- if jv >= 21 %}
app.executor.virtual-threads=true
{%- endif %}

## Database
app.datasource.url={{ db }}
app.datasource.username=${DB_USERNAME:appuser}
app.datasource.password=${DB_PASSWORD:changeme}
app.datasource.max-pool-size=20

## Logging
app.logging.level=INFO

{%- endif %}
