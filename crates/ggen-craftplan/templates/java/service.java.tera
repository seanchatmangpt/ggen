     * @return the updated entity
     */
{%- endif %}
    public {{ entity_name }} update({{ id_type | default(value="Long") }} id, {{ entity_name }} {{ entity_lower }}) {
        if (repository.findById(id).isEmpty()) {
            throw new {{ entity_name }}NotFoundException(id);
        }
        return repository.save({{ entity_lower }});
    }

{%- if jv >= 23 %}

    /// Delete {{ entity_name }} by ID.
{%- else %}

    /**
     * Delete {{ entity_name }} by ID.
     * @param id the entity ID
     */
{%- endif %}
    public void delete({{ id_type | default(value="Long") }} id) {
        if (repository.findById(id).isEmpty()) {
            throw new {{ entity_name }}NotFoundException(id);
        }
        repository.deleteById(id);
    }

{%- for attr in attributes | default(value=[]) %}
{%- if attr.searchable | default(value=false) %}

    public List<{{ entity_name }}> findBy{{ attr.name | capitalize }}({{ attr.type }} {{ attr.name }}) {
