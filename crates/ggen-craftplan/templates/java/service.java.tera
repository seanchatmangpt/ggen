     * List all {{ entity_name }} entities.
     * @return all entities
     */
{%- endif %}
    public List<{{ entity_name }}> findAll() {
        return repository.findAll();
    }

{%- if jv >= 23 %}

    /// Create a new {{ entity_name }}.
{%- else %}

    /**
     * Create a new {{ entity_name }}.
     * @param {{ entity_lower }} the entity to create
     * @return the created entity
     */
{%- endif %}
    public {{ entity_name }} create({{ entity_name }} {{ entity_lower }}) {
        java.util.Objects.requireNonNull({{ entity_lower }}, "{{ entity_lower }} must not be null");
{%- for attr in attributes | default(value=[]) %}
{%- if attr.constraints is defined and attr.constraints.not_blank | default(value=false) %}
        if ({{ entity_lower }}.{{ attr.name }}() == null || {{ entity_lower }}.{{ attr.name }}().isBlank()) {
            throw new IllegalArgumentException("{{ attr.name }} must not be blank");
        }
{%- endif %}
{%- endfor %}
        return repository.save({{ entity_lower }});
    }

{%- if jv >= 23 %}

    /// Update an existing {{ entity_name }}.
{%- else %}

