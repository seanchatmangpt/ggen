     * @return the entity if found
     */
{%- endif %}
    public Optional<{{ entity_name }}> findById({{ id_type | default(value="Long") }} id) {
        return repository.findById(id);
    }

{%- if jv >= 23 %}

    /// List all {{ entity_name }} entities.
{%- else %}

