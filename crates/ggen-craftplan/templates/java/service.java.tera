 */
{%- endif %}
public final class {{ entity_name }}Service {

    private final {{ entity_name }}Repository repository;

    public {{ entity_name }}Service({{ entity_name }}Repository repository) {
        this.repository = java.util.Objects.requireNonNull(repository, "repository must not be null");
    }

{%- if jv >= 23 %}

    /// Find {{ entity_name }} by ID.
