@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://example.org/stewards#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# Stewardship Part: WelcomeOneAnotherPart
# Scripture: "Welcome one another, therefore, as Christ has welcomed you, for the glory of God." (Romans 15:7)

ex:WelcomeActivity a rdfs:Class ;
    rdfs:label "Welcome Activity" ;
    rdfs:comment "An activity where a steward welcomes a visitor." .

ex:Steward a rdfs:Class ;
    rdfs:label "Steward" .

ex:Visitor a rdfs:Class ;
    rdfs:label "Visitor" .

ex:WelcomeOneAnotherPartShape
    a sh:NodeShape ;
    sh:targetClass ex:WelcomeActivity ;
    sh:property [
        sh:path prov:wasAssociatedWith ;
        sh:class ex:Steward ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path prov:used ;
        sh:class ex:Visitor ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ex:scriptureBasis ;
        sh:datatype xsd:string ;
        sh:hasValue "Romans 15:7" ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path ex:terminalState ;
        sh:hasValue ex:ReceivedAndRemembered ;
        sh:minCount 1 ;
    ] .

ex:VisitorShape
    a sh:NodeShape ;
    sh:targetClass ex:Visitor ;
    sh:property [
        sh:path ex:hasArrivalEvent ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:path ex:status ;
        sh:in (ex:Arrived ex:ReceivedAndRemembered) ;
        sh:minCount 1 ;
    ] .
