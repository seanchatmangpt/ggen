# pack-l5-promotion.ttl — the Level 5 Pack-Closure Promotion Program.
#
# GENERATED-DOC SOURCE: docs/l5-promotion/L5_PROMOTION_PROGRAM.md is GENERATED
# from this file by the `docs-l5-promotion-program` rule in ggen.toml. Edit
# THIS file, not the doc.
#
# GOVERNING MANDATE (verbatim intent, see repo memory / session record):
#   P = all compatible ggen packs
#   L5(p) = pack p satisfies the full Level 5 contract (12 capabilities below)
#   Promote(p) = the lawful manufacturing process that raises p to Level 5
#   P_L5 = { Promote(p) | p in P }
#   autosel = ggen(MaximalClosure(P_L5))
#
# Current maturity (see .specify/maturity.ttl / docs/packs/PACK_MATURITY_MODEL.md)
# is an OBSERVATION, not a scope boundary. Every l5p:Pack individual below is a
# promotion OBLIGATION until it reaches a terminal l5p:standing: l5p:Level5,
# l5p:Incompatible, l5p:Superseded, or l5p:RejectedWithProof. l5p:CensusPending
# and l5p:InProgress are non-terminal working states, not resting states.
#
# This file's own honesty bar: do not mark a pack l5p:Level5 by editing this
# file. l5p:Level5 standing requires a named, checkable artifact for EACH of
# the 12 l5p:Capability individuals below (see mat:cg_* rows'/tcps rows' own
# "not yet L5 because..." disclosures in .specify/maturity.ttl for the honesty
# precedent this file must match). Per that file's own calibration rule,
# nothing in this repo has closed all 12 today -- including the 6 TCPS
# packs, which are the REFERENCE BASIS for promotion machinery, not already-
# finished Level 5 packs themselves.
@prefix l5p:  <http://ggen.org/l5-promotion#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mat:  <http://ggen.org/maturity#> .

l5p:Pack a rdfs:Class ; rdfs:label "a ggen pack under Level 5 promotion" .
l5p:Capability a rdfs:Class ; rdfs:label "one of the 12 required Level 5 capabilities" .
l5p:PromotionWave a rdfs:Class ; rdfs:label "a stage in the promotion sequence" .
l5p:Standing a rdfs:Class ; rdfs:label "terminal or working standing state" .
l5p:DocSection a rdfs:Class ; rdfs:label "authored prose section rendered verbatim" .

# ---------------------------------------------------------------------------
# Standing states (l5p:standing takes one of these five IRIs)
# ---------------------------------------------------------------------------
l5p:CensusPending a l5p:Standing ; rdfs:label "counted, not yet adjudicated against the 12-capability bar" .
l5p:InProgress a l5p:Standing ; rdfs:label "promotion actively underway; ≥1 capability closed, ≥1 open" .
l5p:ReferenceBasis a l5p:Standing ; rdfs:label "furthest-advanced pack(s); source of reusable promotion machinery, itself not yet full Level5" .
l5p:Level5 a l5p:Standing ; rdfs:label "TERMINAL: all 12 capabilities closed with named artifacts" .
l5p:Incompatible a l5p:Standing ; rdfs:label "TERMINAL: mechanically proven incompatible with the closure (named proof required)" .
l5p:Superseded a l5p:Standing ; rdfs:label "TERMINAL: replaced by another pack; replacement relationship recorded" .
l5p:RejectedWithProof a l5p:Standing ; rdfs:label "TERMINAL: explicit refusal witness recorded" .

# ---------------------------------------------------------------------------
# The 12 required Level 5 capabilities
# ---------------------------------------------------------------------------
l5p:cap01 a l5p:Capability ; l5p:order "01" ; l5p:capName "Authoritative semantic source" ;
    l5p:capDesc "The pack's ontology is the sole source of truth for what gets built; no fact lives only in a template or hand-written module." .
l5p:cap02 a l5p:Capability ; l5p:order "02" ; l5p:capName "Complete generation surface" ;
    l5p:capDesc "Every file the consumer needs (types, logic, tests, docs, provenance, release surface) is generated -- no hand-authored production file required." .
l5p:cap03 a l5p:Capability ; l5p:order "03" ; l5p:capName "Deterministic regeneration" ;
    l5p:capDesc "The same ontology + templates produce byte-identical output on repeated ggen sync run, verified live, not asserted." .
l5p:cap04 a l5p:Capability ; l5p:order "04" ; l5p:capName "Fixed-point convergence" ;
    l5p:capDesc "Regeneration from a fully-deleted consumer converges to the same result as incremental regeneration -- erase-and-rebuild is a real, exercised path." .
l5p:cap05 a l5p:Capability ; l5p:order "05" ; l5p:capName "Generated verification" ;
    l5p:capDesc "The proof suite is itself generated from the ontology (not hand-written against generated code), and its expected values derive from ontology facts, not hardcoded literals." .
l5p:cap06 a l5p:Capability ; l5p:order "06" ; l5p:capName "Generated negative witnesses" ;
    l5p:capDesc "Sabotage/falsification fixtures (compile-fail, refusal-path, adversarial input) are generated, proving the pack fails closed, not just that it succeeds." .
l5p:cap07 a l5p:Capability ; l5p:order "07" ; l5p:capName "Generated documentation" ;
    l5p:capDesc "Reference docs are projected from the ontology, not hand-written prose describing generated code after the fact." .
l5p:cap08 a l5p:Capability ; l5p:order "08" ; l5p:capName "Generated provenance" ;
    l5p:capDesc "Every generated artifact traces to the ontology facts and template version that produced it (source-manifest / digest chain), machine-checkable." .
l5p:cap09 a l5p:Capability ; l5p:order "09" ; l5p:capName "Generated receipts" ;
    l5p:capDesc "Sync emits a cryptographic receipt covering this pack's contribution, chained and verifiable (ggen receipt verify)." .
l5p:cap10 a l5p:Capability ; l5p:order "10" ; l5p:capName "Generated release surface" ;
    l5p:capDesc "Packaging/CI/release artifacts for the generated subsystem are themselves generated, not hand-maintained alongside it." .
l5p:cap11 a l5p:Capability ; l5p:order "11" ; l5p:capName "Generated evolution path" ;
    l5p:capDesc "An upstream ontology or target-API change flows through to a re-synced consumer with a semantic diff and no manual repair." .
l5p:cap12 a l5p:Capability ; l5p:order "12" ; l5p:capName "Consumer replacement" ;
    l5p:capDesc "A consumer with zero knowledge of the target's own implementation can delete its generated tree and regenerate a working, tested, receipted subsystem from ggen.toml + the pack alone." .

# ---------------------------------------------------------------------------
# Promotion waves (the strategic sequence)
# ---------------------------------------------------------------------------
l5p:wave1 a l5p:PromotionWave ; l5p:order "1" ; l5p:waveName "Level 5 reference packs" ;
    l5p:waveDesc "The 6 TCPS packs: furthest along today, source of the fidelity-oracle pattern (examples/tcps-generated) every later wave reuses." .
l5p:wave2 a l5p:PromotionWave ; l5p:order "2" ; l5p:waveName "Reusable Level 5 promotion machinery" ;
    l5p:waveDesc "Extract from wave 1: generic idempotent-regen verification, generic CI-wiring gate, a generation-rule pattern for ontology-derived (not hardcoded) test expectations, a generic negative-witness/sabotage harness pattern. The ontology-derived-test-expectations pattern is now proven, not just designed: a sparql:-frontmatter proof template (packs/praxis-core-pack/templates/refusal_taxonomy_sparql_derived_proof.rs.tmpl, commit 92bbe5339) ran through a real ggen sync run, passed 4/4, and was shown drift-sensitive against a live ontology.ttl edit -- praxis-core-pack is the reference implementation; star-toml-pack is the named next pack to reapply it to." .
l5p:wave3 a l5p:PromotionWave ; l5p:order "3" ; l5p:waveName "Foundational packs" ;
    l5p:waveDesc "Packs other packs' ontologies reuse vocabulary from (clap-noun-verb-pack's cnv: namespace is reused by mcpp-pack and cargo-cicd-pack; wasm4pm-facts-pack/wasm4pm-algorithms-pack underlie wasm4pm-cognition-pack)." .
l5p:wave4 a l5p:PromotionWave ; l5p:order "4" ; l5p:waveName "Composition packs" ;
    l5p:waveDesc "Packs whose generated surface composes multiple foundational vocabularies (wasm4pm-cognition-pack, wasm4pm-compat-pack, chicago-tdd-tools-pack)." .
l5p:wave5 a l5p:PromotionWave ; l5p:order "5" ; l5p:waveName "Domain packs" ;
    l5p:waveDesc "Packs modeling one external target crate/repo's domain (affidavit-pack, osx-clnr-pack, mfact-pack, mfw-pack, cargo-cicd-pack, mcpp-pack, anti-llm-cheat-lsp-pack, star-toml-pack, praxis-core-pack, wasm4pm-pack, lsp-max-pack)." .
l5p:wave6 a l5p:PromotionWave ; l5p:order "6" ; l5p:waveName "Interface packs" ;
    l5p:waveDesc "Knowledge-hook and case-study packs: self-monitoring-pack, dogfood-lifecycle-pack, ggen-verify-pack, ma-case-study-pack -- governance/verdict surfaces layered over the domain packs." .
l5p:wave7 a l5p:PromotionWave ; l5p:order "7" ; l5p:waveName "Consumer packs" ;
    l5p:waveDesc "Packs describing ggen/repo-self surfaces: claude-code-pack, gh-terraform-pack, github-actions-pack, level-five-book-pack, ggen-constitution-pack, ggen-release-pack -- census-pending as of this program's creation, unscored in .specify/maturity.ttl." .
l5p:wave8 a l5p:PromotionWave ; l5p:order "8" ; l5p:waveName "Maximal closure" ;
    l5p:waveDesc "Every non-terminal pack has reached Level5/Incompatible/Superseded/RejectedWithProof; compute MaximalClosure(P_L5)." .
l5p:wave9 a l5p:PromotionWave ; l5p:order "9" ; l5p:waveName "autosel" ;
    l5p:waveDesc "Generate autosel from MaximalClosure(P_L5). Not before wave 8 completes." .

