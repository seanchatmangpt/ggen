@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix gv26: <http://ggen.dev/v26.5.19#> .
@prefix meta: <http://ggen.ai/ontology/meta#> .
@prefix ggen: <https://ggen.io/marketplace/> .

# Standard Vocabulary Definitions for v26.5.19 Release
# This file defines the "Authorized Baseline" for all Genesis admissions.

gv26:StandardVocabulary a owl:Class ;
    rdfs:label "Standard Vocabulary" ;
    rdfs:comment "A namespace authorized for use in ggen v26.5.19 projects." .

<http://www.w3.org/1999/02/22-rdf-syntax-ns#> a gv26:StandardVocabulary ;
    gv26:prefix "rdf" ;
    rdfs:label "RDF syntax vocabulary" .

<http://www.w3.org/2000/01/rdf-schema#> a gv26:StandardVocabulary ;
    gv26:prefix "rdfs" ;
    rdfs:label "RDF Schema vocabulary" .

<http://www.w3.org/2002/07/owl#> a gv26:StandardVocabulary ;
    gv26:prefix "owl" ;
    rdfs:label "Web Ontology Language" .

<http://ggen.dev/v26.5.19#> a gv26:StandardVocabulary ;
    gv26:prefix "gv26" ;
    rdfs:label "ggen v26.5.19 ontology" .

<http://ggen.ai/ontology/meta#> a gv26:StandardVocabulary ;
    gv26:prefix "meta" ;
    rdfs:label "ggen meta-ontology" .

<http://www.w3.org/2001/XMLSchema#> a gv26:StandardVocabulary ;
    gv26:prefix "xsd" ;
    rdfs:label "XML Schema Definition" .

<https://ggen.io/marketplace/> a gv26:StandardVocabulary ;
    gv26:prefix "ggen" ;
    rdfs:label "ggen marketplace vocabulary" .

<https://prolog8.dev/ontology#> a gv26:StandardVocabulary ;
    gv26:prefix "p8" ;
    rdfs:label "Prolog8 core ontology" .

<https://prolog8.dev/type#> a gv26:StandardVocabulary ;
    gv26:prefix "type" ;
    rdfs:label "Prolog8 type definitions" .

<https://prolog8.dev/cap#> a gv26:StandardVocabulary ;
    gv26:prefix "cap" ;
    rdfs:label "Prolog8 implementation capabilities" .

<https://prolog8.dev/error#> a gv26:StandardVocabulary ;
    gv26:prefix "error" ;
    rdfs:label "Prolog8 admission errors" .

<https://prolog8.dev/feat#> a gv26:StandardVocabulary ;
    gv26:prefix "feat" ;
    rdfs:label "Prolog8 feature bits" .

<https://prolog8.dev/module#> a gv26:StandardVocabulary ;
    gv26:prefix "module" ;
    rdfs:label "Prolog8 module definitions" .

<https://prolog8.dev/function#> a gv26:StandardVocabulary ;
    gv26:prefix "fn" ;
    rdfs:label "Prolog8 function definitions" .

<http://www.w3.org/ns/prov#> a gv26:StandardVocabulary ;
    gv26:prefix "prov" ;
    rdfs:label "PROV-O vocabulary" .

<https://prolog8.dev/artifact#> a gv26:StandardVocabulary ;
    gv26:prefix "artifact" ;
    rdfs:label "Prolog8 artifact definitions" .

<https://prolog8.dev/crate#> a gv26:StandardVocabulary ;
    gv26:prefix "crate" ;
    rdfs:label "Prolog8 crate definitions" .

<https://prolog8.dev/demo#> a gv26:StandardVocabulary ;
    gv26:prefix "demo" ;
    rdfs:label "Prolog8 demo definitions" .

<https://prolog8.dev/feature#> a gv26:StandardVocabulary ;
    gv26:prefix "feature" ;
    rdfs:label "Prolog8 feature definitions" .

<https://prolog8.dev/implementation#> a gv26:StandardVocabulary ;
    gv26:prefix "impl" ;
    rdfs:label "Prolog8 implementation vocabulary" .

<https://prolog8.dev/test#> a gv26:StandardVocabulary ;
    gv26:prefix "test" ;
    rdfs:label "Prolog8 test definitions" .

<http://purl.org/dc/terms/> a gv26:StandardVocabulary ;
    gv26:prefix "dcterms" ;
    rdfs:label "Dublin Core Metadata Terms" .

<http://www.w3.org/ns/shacl#> a gv26:StandardVocabulary ;
    gv26:prefix "sh" ;
    rdfs:label "Shapes Constraint Language" .
