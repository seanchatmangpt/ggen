# build_static_html.py -> generate_manifest.py run fully independently in
# each, 2026-07-20.
gen:IndependentArtifactRegenTest a gen:Generation ;
    gen:inspects gen:ReproducibleBuildTest ;
    gen:commit "bde338129b93bcc43745b860779c581fa8d95b96" ;
    gen:regenACommand "assemble_book.py + build_static_html.py + generate_manifest.py run in /tmp/book-regen-a" ;
    gen:regenBCommand "assemble_book.py + build_static_html.py + generate_manifest.py run in /tmp/book-regen-b" ;
