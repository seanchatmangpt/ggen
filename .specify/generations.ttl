    # newer schema added. It refused loudly (a typed FM-CONFIG-002 error) rather
    # than silently proceeding or corrupting state; confirmed via `git status`/
    # `git diff .ggen-v2/receipt.json` that the failed run touched nothing.
    gen:refusalCode "FM-CONFIG-002" ;
    gen:corruptedNoState true .

