    # G2Heterogeneous -- .specify/generations.ttl` -> bde338129 (PR #302).
    # The REFUSED run itself produced no receipt/binary hash to pin — this
    # pins the ledger entry, not a manufactured artifact.
    gen:commit "bde338129b93bcc43745b860779c581fa8d95b96" ;
    gen:outcome "REFUSED" ;
    # verified: `~/.cargo/bin/ggen sync run` on the live tree failed closed with
    # "[FM-CONFIG-002] invalid ggen.toml ... unknown field `version`, expected
    # `name`" -- a real, honest divergence between the two independently-built
