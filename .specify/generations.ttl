@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .

gen:Generation  a rdfs:Class ; rdfs:label "one round of self-manufacture, receipted separately from the round that inspects it" .
gen:DoDCondition a rdfs:Class ; rdfs:label "one row of the 15-condition doctrine Definition-of-Done" .

