@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix cm: <http://chatmangpt.com/ontology#> .
@prefix wvda: <http://chatmangpt.com/wvda#> .
@prefix armstrong: <http://chatmangpt.com/armstrong#> .
@prefix semconv: <http://chatmangpt.com/semconv#> .

# =============================================================================
# CHATMANGPT SPRINT ONTOLOGY
# =============================================================================
# Formal specification of sprint deliverables, verification status,
# project state, and cross-system integration chain.
# Drives: MORNING_BRIEF.md, diataxis reference docs, sprint reports.
# =============================================================================

<http://chatmangpt.com/sprint-ontology>
  a owl:Ontology ;
  rdfs:label "ChatmanGPT Sprint Ontology" ;
  rdfs:comment "Source of truth for sprint deliverables, verification status, and cross-system integration. Generated docs use Tera templates." ;
  owl:versionInfo "1.0.0" ;
  .

# =============================================================================
# PROJECTS
# =============================================================================

cm:Project a owl:Class ;
  rdfs:label "Project" ;
  rdfs:comment "A subproject in the ChatmanGPT workspace" ;
  .

cm:osa a cm:Project ;
  rdfs:label "OSA" ;
  cm:techStack "Elixir/OTP + Rust + SvelteKit" ;
  cm:port "8089" ;
  cm:purpose "Multi-agent orchestration runtime" ;
  cm:testCount "7289"^^xsd:integer ;
  cm:testFailures "0"^^xsd:integer ;
  cm:testExcluded "3809"^^xsd:integer ;
  cm:compileWarnings "0"^^xsd:integer ;
  cm:weaverStatus "exit_0" ;
  cm:lastCommit "0512307" ;
  cm:branch "feat/weaver-automation" ;
  .

cm:businessos a cm:Project ;
  rdfs:label "BusinessOS" ;
  cm:techStack "Go 1.24 + SvelteKit + Electron" ;
  cm:port "8001" ;
  cm:purpose "Self-hosted AI business OS" ;
  cm:testCount "56"^^xsd:integer ;
  cm:testFailures "0"^^xsd:integer ;
  cm:compileWarnings "0"^^xsd:integer ;
  cm:lastCommit "f10342f" ;
  cm:branch "feat/weaver-automation" ;
  .

cm:canopy a cm:Project ;
  rdfs:label "Canopy" ;
  cm:techStack "Elixir/Phoenix + SvelteKit/Tauri" ;
  cm:port "9089" ;
  cm:purpose "Workspace protocol + command center" ;
  cm:testCount "1220"^^xsd:integer ;
  cm:testFailures "21"^^xsd:integer ;
  cm:compileWarnings "0"^^xsd:integer ;
  cm:lastCommit "7113057" ;
  cm:branch "feat/weaver-automation" ;
  .

cm:pm4py_rust a cm:Project ;
  rdfs:label "pm4py-rust" ;
  cm:techStack "Rust + Python bindings" ;
  cm:port "8090" ;
  cm:purpose "Process mining engine" ;
  cm:testCount "722"^^xsd:integer ;
  cm:testFailures "0"^^xsd:integer ;
  cm:compileWarnings "0"^^xsd:integer ;
  cm:lastCommit "3b07aa39e" ;
  cm:branch "feat/weaver-automation" ;
  .

# =============================================================================
# INTEGRATION CHAIN
# =============================================================================

cm:IntegrationChain a owl:Class ;
  rdfs:label "Integration Chain" ;
  rdfs:comment "The ordered chain of system integration" ;
  .

cm:integration_chain a cm:IntegrationChain ;
  rdfs:label "Full Integration Chain" ;
  cm:chainOrder "pm4py-rust(8090) -> YAWL(8080) -> BusinessOS(8001) -> Canopy(9089) -> OSA(8089)" ;
  cm:healthEndpoint "/health" ;
  cm:bootCommand "make dev" ;
  cm:verifyCommand "make verify" ;
  .

# =============================================================================
# SPRINT DELIVERABLES
# =============================================================================

cm:SprintItem a owl:Class ;
  rdfs:label "Sprint Item" ;
  rdfs:comment "A deliverable shipped during the sprint" ;
  .

cm:WvdASoundness a cm:SprintItem ;
  rdfs:label "WvdA Soundness + Canopy Marketplace + Armstrong Fixes" ;
  cm:date "2026-03-29" ;
  cm:category "verification" ;
  cm:status "complete" ;
  cm:testCount "62"^^xsd:integer ;
  cm:testPass "62"^^xsd:integer ;
  rdfs:comment "StateGraph, CycleDetector (Tarjan's), LivenessChecker, BoundednessChecker, SoundnessVerifier" ;
  .

cm:CanopyMarketplace a cm:SprintItem ;
  rdfs:label "Canopy Marketplace + Agent Worker" ;
  cm:date "2026-03-29" ;
  cm:category "feature" ;
  cm:status "complete" ;
  cm:testCount "24"^^xsd:integer ;
  cm:testPass "24"^^xsd:integer ;
  .

cm:AgentFixes a cm:SprintItem ;
  rdfs:label "OSA Agent Fixes (Elixir 1.19 Compat)" ;
  cm:date "2026-03-29" ;
  cm:category "fix" ;
  cm:status "complete" ;
  cm:filesChanged "13"^^xsd:integer ;
  rdfs:comment "execute/2 vs execute/3 arity, | operator in keyword list, Logger.warn -> Logger.warning" ;
  .

cm:YawlIntegration a cm:SprintItem ;
  rdfs:label "YAWL Integration Fixes" ;
  cm:date "2026-03-29" ;
  cm:category "fix" ;
  cm:status "complete" ;
  cm:smokeTests "30"^^xsd:integer ;
  cm:smokePass "30"^^xsd:integer ;
  rdfs:comment "decode_body: false for health.jsp, YAWLV6_SPECS_PATH env var" ;
  .

cm:TestFixes a cm:SprintItem ;
  rdfs:label "OSA Test Fixes" ;
  cm:date "2026-03-29" ;
  cm:category "fix" ;
  cm:status "complete" ;
  rdfs:comment "tdd_memory_test type violations, tools_registry validate_input, 7 test files tagged :requires_application" ;
  .

# =============================================================================
# VERIFICATION PROOF ARTIFACTS (Three-Layer AND)
# =============================================================================

cm:VerificationProof a owl:Class ;
  rdfs:label "Verification Proof" ;
  rdfs:comment "Evidence-based verification artifact following three-layer AND standard" ;
  .

cm:OtelSpan a cm:VerificationProof ;
  rdfs:label "OpenTelemetry Span Proof" ;
  cm:requirement "Service name, span name, timestamp, attributes, status field" ;
  cm:location "Jaeger UI at http://localhost:16686" ;
  cm:status "pending" ;
  .

cm:TestAssertion a cm:VerificationProof ;
  rdfs:label "Test Assertion Proof" ;
  cm:requirement "Test file with _test.{exs,go,rs}, test name, assertion, GREEN status" ;
  cm:status "complete" ;
  cm:evidence "7289 OSA tests, 0 failures; 56 Go tests; 722 Rust tests; 1220 Canopy tests" ;
  .

cm:SchemaConformance a cm:VerificationProof ;
  rdfs:label "Weaver Schema Conformance Proof" ;
  cm:requirement "weaver registry check exits 0, typed semconv constants used in tests" ;
  cm:status "complete" ;
  cm:evidence "weaver registry check -r ./semconv/model -p ./semconv/policies/ --quiet exits 0" ;
  .

# =============================================================================
# WvdA SOUNDNESS PROPERTIES
# =============================================================================

wvda:SoundnessProperty a owl:Class ;
  rdfs:label "WvdA Soundness Property" ;
  rdfs:comment "Van der Aalst soundness verification property" ;
  .

wvda:DeadlockFreedom a wvda:SoundnessProperty ;
  rdfs:label "Deadlock Freedom" ;
  wvda:verificationMethod "Tarjan's SCC algorithm" ;
  wvda:testCount "20"^^xsd:integer ;
  wvda:implementation "CycleDetector.find_cycles/1 via StateGraph.adjacency_list/1" ;
  wvda:status "verified" ;
  .

wvda:Liveness a wvda:SoundnessProperty ;
  rdfs:label "Liveness" ;
  wvda:verificationMethod "BFS termination path check + timeout coverage" ;
  wvda:testCount "22"^^xsd:integer ;
  wvda:implementation "LivenessChecker.check_all/1" ;
  wvda:status "verified" ;
  .

wvda:Boundedness a wvda:SoundnessProperty ;
  rdfs:label "Boundedness" ;
  wvda:verificationMethod "Queue bounds + memory limits check" ;
  wvda:testCount "20"^^xsd:integer ;
  wvda:implementation "BoundednessChecker.check_all/1" ;
  wvda:status "verified" ;
  .

# =============================================================================
# ARMSTRONG FAULT TOLERANCE
# =============================================================================

armstrong:ArmstrongPrinciple a owl:Class ;
  rdfs:label "Armstrong Principle" ;
  rdfs:comment "Joe Armstrong fault tolerance principle" ;
  .

armstrong:LetItCrash a armstrong:ArmstrongPrinciple ;
  rdfs:label "Let-It-Crash" ;
  armstrong:verification "No bare try/rescue swallowing errors in production code" ;
  armstrong:status "verified" ;
  .

armstrong:SupervisionTree a armstrong:ArmstrongPrinciple ;
  rdfs:label "Supervision Tree" ;
  armstrong:verification "Every worker has explicit supervisor; no orphans" ;
  armstrong:status "verified" ;
  armstrong:evidence "AgentSupervisor DynamicSupervisor + Canopy.Agent GenServer worker created" ;
  .

armstrong:NoSharedState a armstrong:ArmstrongPrinciple ;
  rdfs:label "No Shared Mutable State" ;
  armstrong:verification "All inter-process communication via message passing" ;
  armstrong:status "verified" ;
  .

armstrong:BudgetConstraints a armstrong:ArmstrongPrinciple ;
  rdfs:label "Budget Constraints" ;
  armstrong:verification "Every operation has time/resource limit" ;
  armstrong:status "verified" ;
  .

# =============================================================================
# OPEN ITEMS (Ranked by 80/20 Impact)
# =============================================================================

cm:OpenItem a owl:Class ;
  rdfs:label "Open Item" ;
  rdfs:comment "Remaining work item ranked by impact" ;
  .

cm:OtelSpanProof a cm:OpenItem ;
  rdfs:label "OTEL spans proof in Jaeger" ;
  cm:priority "1"^^xsd:integer ;
  cm:effort "needs make dev" ;
  cm:project "all" ;
  rdfs:comment "make dev then verify a2a.task.create + 3 other spans in Jaeger; required for merge gate" ;
  .

cm:OpenPR a cm:OpenItem ;
  rdfs:label "Open PR" ;
  cm:priority "2"^^xsd:integer ;
  cm:effort "quick" ;
  cm:project "root" ;
  rdfs:comment "feat/weaver-automation -> main" ;
  .

cm:A2AStackTest a cm:OpenItem ;
  rdfs:label "make test-a2a-stack with live stack" ;
  cm:priority "3"^^xsd:integer ;
  cm:effort "needs make dev" ;
  cm:project "all" ;
  rdfs:comment "verify 8/8 E2E smoke checks pass" ;
  .

cm:CanopyStubs a cm:OpenItem ;
  rdfs:label "Canopy stub replacement Wave 2" ;
  cm:priority "4"^^xsd:integer ;
  cm:effort "medium" ;
  cm:project "canopy" ;
  rdfs:comment "11 remaining stubs (Oxigraph PROV-O, org-aware dispatch, workspace_context plug, board controller)" ;
  .

