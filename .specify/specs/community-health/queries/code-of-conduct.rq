PREFIX doap:    <http://usefulinc.com/ns/doap#>
PREFIX foaf:    <http://xmlns.com/foaf/0.1/>
PREFIX dcterms: <http://purl.org/dc/terms/>

SELECT ?repoName ?maintainerEmail ?maintainerName
WHERE {
  ?project a doap:Project ;
           doap:name ?repoName .
  OPTIONAL {
    ?project doap:maintainer ?person .
    ?person foaf:name ?maintainerName .
    OPTIONAL { ?person foaf:mbox ?maintainerEmail . }
  }
}
ORDER BY ?repoName
