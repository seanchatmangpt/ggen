PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX doap:    <http://usefulinc.com/ns/doap#>
PREFIX foaf:    <http://xmlns.com/foaf/0.1/>
PREFIX spdx:    <http://spdx.org/rdf/terms#>

SELECT ?repoName ?authorName ?spdxId ?year
WHERE {
  ?project a doap:Project ;
           doap:name ?repoName .
  OPTIONAL { ?project doap:maintainer ?p . ?p foaf:name ?authorName . }
  OPTIONAL { ?project dcterms:license ?lic . BIND(STRAFTER(STR(?lic), "licenses/") AS ?spdxId) }
  OPTIONAL { ?project doap:created ?created . BIND(STRBEFORE(?created, "-") AS ?year) }
}
ORDER BY ?repoName
