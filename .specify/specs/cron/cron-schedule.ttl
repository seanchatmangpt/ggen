@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix ggen:    <https://ggen.dev/ontology/core#> .
@prefix cron:    <https://ggen.dev/ontology/cron#> .

<https://ggen.dev/specs/cron>
    a owl:Ontology ;
    dcterms:title "ggen Cron Schedule Ontology" ;
    dcterms:description "Models 7-day automated commit schedules for cross-repo generation campaigns." ;
    dcterms:created "2026-06-24"^^xsd:date ;
    owl:imports <https://ggen.dev/specs/universal> .

# ─── Core scheduling classes ────────────────────────────────────────────────────

cron:Schedule
    a owl:Class ;
    rdfs:label "Schedule" ;
    rdfs:comment "A named cron schedule for automated ggen commits." .

cron:DailyBatch
    a owl:Class ;
    rdfs:subClassOf cron:Schedule ;
    rdfs:label "Daily Batch" ;
    rdfs:comment "A set of commit bundles to execute on a specific day." .

cron:CommitWindow
    a owl:Class ;
    rdfs:label "Commit Window" ;
    rdfs:comment "A time window within a day during which commits are dispatched." .

cron:BundleDispatch
    a owl:Class ;
    rdfs:label "Bundle Dispatch" ;
    rdfs:comment "One bundle type applied to one batch of repositories." .

cron:CampaignPlan
    a owl:Class ;
    rdfs:label "Campaign Plan" ;
    rdfs:comment "The full 7-day plan across all repos and bundle types." .

# ─── Properties ─────────────────────────────────────────────────────────────────

cron:day
    a owl:DatatypeProperty ;
    rdfs:domain cron:DailyBatch ;
    rdfs:range xsd:integer ;
    rdfs:label "day (1-7)" .

cron:windowStart
    a owl:DatatypeProperty ;
    rdfs:domain cron:CommitWindow ;
    rdfs:range xsd:time ;
    rdfs:label "window start UTC" .

cron:windowEnd
    a owl:DatatypeProperty ;
    rdfs:domain cron:CommitWindow ;
    rdfs:range xsd:time ;
    rdfs:label "window end UTC" .

cron:maxCommitsPerHour
    a owl:DatatypeProperty ;
    rdfs:domain cron:CommitWindow ;
    rdfs:range xsd:integer ;
    rdfs:label "max commits per hour" .

cron:dispatchBundle
    a owl:ObjectProperty ;
    rdfs:domain cron:DailyBatch ;
    rdfs:range cron:BundleDispatch ;
    rdfs:label "dispatch bundle" .

cron:appliesTo
    a owl:ObjectProperty ;
    rdfs:domain cron:BundleDispatch ;
    rdfs:range ggen:LanguagePrimary ;
    rdfs:label "applies to language" .

cron:bundleKind
    a owl:ObjectProperty ;
    rdfs:domain cron:BundleDispatch ;
    rdfs:range ggen:BundleType ;
    rdfs:label "bundle kind" .

cron:estimatedCommits
    a owl:DatatypeProperty ;
    rdfs:domain cron:BundleDispatch ;
    rdfs:range xsd:integer ;
    rdfs:label "estimated commits" .

cron:cronExpression
    a owl:DatatypeProperty ;
    rdfs:domain cron:Schedule ;
    rdfs:range xsd:string ;
    rdfs:label "cron expression" ;
    rdfs:comment "Standard 5-field cron expression: min hour dom month dow" .

cron:specManifest
    a owl:DatatypeProperty ;
    rdfs:domain cron:BundleDispatch ;
    rdfs:range xsd:string ;
    rdfs:label "spec manifest path" ;
    rdfs:comment "Path to the ggen.toml spec manifest for this bundle." .

# ─── 7-Day Campaign Plan ────────────────────────────────────────────────────────

cron:Campaign2026
    a cron:CampaignPlan ;
    dcterms:title "ggen 7-Day 1500-Commit Campaign" ;
    dcterms:description "Automated 7-day schedule to generate 1,527 real commits across 177 repos." ;
    dcterms:created "2026-06-24"^^xsd:date ;
    cron:totalTargetCommits 1527 ;
    cron:totalRepos 177 .

# Day 1 — Community Health (all repos)
cron:Day1
    a cron:DailyBatch ;
    dcterms:title "Day 1: Community Health + GitHub Templates" ;
    cron:day 1 ;
    cron:dispatchBundle cron:Day1-CommunityHealth-All, cron:Day1-GithubTemplates-All .

cron:Day1-CommunityHealth-All
    a cron:BundleDispatch ;
    cron:bundleKind ggen:CommunityHealth ;
    cron:estimatedCommits 177 ;
    cron:specManifest ".specify/specs/community-health/ggen.toml" ;
    cron:cronExpression "0 9 * * *" .

cron:Day1-GithubTemplates-All
    a cron:BundleDispatch ;
    cron:bundleKind ggen:GithubTemplates ;
    cron:estimatedCommits 115 ;
    cron:specManifest ".specify/specs/github-templates/ggen.toml" ;
    cron:cronExpression "0 10 * * *" .

