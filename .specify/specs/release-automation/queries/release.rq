PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX doap:    <http://usefulinc.com/ns/doap#>
PREFIX foaf:    <http://xmlns.com/foaf/0.1/>
PREFIX ggen:    <https://ggen.dev/ontology/core#>

SELECT ?repoName ?shortdesc ?homepage ?authorName ?primaryLanguage ?licenseId
WHERE {
  ?project a doap:Project ;
           doap:name ?repoName ;
           doap:shortdesc ?shortdesc .
  OPTIONAL { ?project doap:homepage ?homepage . }
  OPTIONAL { ?project ggen:primaryLanguage ?lang . ?lang rdfs:label ?primaryLanguage . }
  OPTIONAL { ?project doap:maintainer ?p . ?p foaf:name ?authorName . }
  OPTIONAL { ?project dcterms:license ?lic . BIND(STRAFTER(STR(?lic), "licenses/") AS ?licenseId) }
}
ORDER BY ?repoName
