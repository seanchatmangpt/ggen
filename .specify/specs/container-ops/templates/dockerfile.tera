# Generated by ggen container-ops spec bundle
# Project: {{ repoName }}
# Language: {{ primaryLanguage | default(value="unknown") }}

{% set builder_image = baseImage | default(value="rust:1.79-slim") -%}
{% set port = servicePort | default(value=8080) -%}

# ── Stage 1: builder ───────────────────────────────────────
FROM {{ builder_image }} AS builder

WORKDIR /build

{% if primaryLanguage == "Rust" %}
# Cache dependency compilation layer
COPY Cargo.toml Cargo.lock ./
RUN mkdir -p src && echo "fn main() {}" > src/main.rs && \
    cargo build --release && \
    rm -f target/release/deps/{{ repoName | replace(from="-", to="_") }}*

# Build application
COPY . .
RUN cargo build --release
{% elif primaryLanguage == "Go" %}
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /build/app .
{% elif primaryLanguage == "Java" %}
COPY pom.xml ./
RUN mvn dependency:go-offline -B

COPY src ./src
RUN mvn package -DskipTests -B
{% elif primaryLanguage == "Python" %}
COPY requirements*.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
{% elif primaryLanguage == "Node" or primaryLanguage == "TypeScript" or primaryLanguage == "JavaScript" %}
COPY package*.json ./
RUN npm ci --only=production

COPY . .
RUN npm run build --if-present
{% else %}
COPY . .
RUN {{ buildTool | default(value="make") }} build
{% endif %}

# ── Stage 2: runtime ───────────────────────────────────────
{% if primaryLanguage == "Rust" or primaryLanguage == "Go" %}
FROM debian:bookworm-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*
{% elif primaryLanguage == "Java" %}
FROM eclipse-temurin:21-jre-jammy AS runtime
{% elif primaryLanguage == "Python" %}
FROM python:3.12-slim AS runtime

COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
{% elif primaryLanguage == "Node" or primaryLanguage == "TypeScript" or primaryLanguage == "JavaScript" %}
FROM node:20-alpine AS runtime
{% else %}
FROM debian:bookworm-slim AS runtime
{% endif %}

WORKDIR /app

{% if primaryLanguage == "Rust" %}
COPY --from=builder /build/target/release/{{ repoName | replace(from="-", to="_") }} /app/{{ repoName }}
{% elif primaryLanguage == "Go" %}
COPY --from=builder /build/app /app/{{ repoName }}
{% elif primaryLanguage == "Java" %}
COPY --from=builder /build/target/*.jar /app/app.jar
{% elif primaryLanguage == "Python" %}
COPY --from=builder /build /app
{% elif primaryLanguage == "Node" or primaryLanguage == "TypeScript" or primaryLanguage == "JavaScript" %}
COPY --from=builder /build /app
{% else %}
COPY --from=builder /build /app
{% endif %}

EXPOSE {{ port }}

{% if healthCheckPath %}
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:{{ port }}{{ healthCheckPath }} || exit 1
{% endif %}

{% if primaryLanguage == "Rust" %}
ENTRYPOINT ["/app/{{ repoName }}"]
{% elif primaryLanguage == "Go" %}
ENTRYPOINT ["/app/{{ repoName }}"]
{% elif primaryLanguage == "Java" %}
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
{% elif primaryLanguage == "Python" %}
ENTRYPOINT ["python", "-m", "{{ repoName | replace(from="-", to="_") }}"]
{% elif primaryLanguage == "Node" or primaryLanguage == "TypeScript" or primaryLanguage == "JavaScript" %}
ENTRYPOINT ["node", "dist/index.js"]
{% else %}
ENTRYPOINT ["/app/{{ repoName }}"]
{% endif %}
