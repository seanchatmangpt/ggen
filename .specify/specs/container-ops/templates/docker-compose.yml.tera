# Generated by ggen container-ops spec bundle
# Project: {{ repoName }}
{% set port = servicePort | default(value=8080) -%}

version: "3.9"

services:
  {{ repoName }}:
    build:
      context: .
      dockerfile: Dockerfile
    image: {{ repoName }}:latest
    container_name: {{ repoName }}
    restart: unless-stopped
    ports:
      - "{{ port }}:{{ port }}"
{% if healthCheckPath %}
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:{{ port }}{{ healthCheckPath }}"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
{% endif %}
    environment:
      - RUST_LOG=${RUST_LOG:-info}
      - PORT={{ port }}
    networks:
      - {{ repoName }}_net

networks:
  {{ repoName }}_net:
    driver: bridge
