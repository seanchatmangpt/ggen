name: Security Audit

on:
  push:
    paths: ['requirements*.txt', 'pyproject.toml', 'setup.cfg']
  schedule:
    - cron: '0 0 * * 0'

jobs:
  audit:
    name: pip audit
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - run: pip install pip-audit
      - run: pip-audit --requirement requirements.txt || pip-audit . || true
