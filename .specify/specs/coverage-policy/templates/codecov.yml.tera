# Codecov Configuration — {{ repoName }}
# https://docs.codecov.com/docs/codecov-yaml

coverage:
  precision: 2
  round: down
  range: "70...100"
  status:
    project:
      default:
        target: 80%
        threshold: 2%
    patch:
      default:
        target: 70%
        threshold: 5%

comment:
  layout: "reach,diff,flags,files,footer"
  behavior: default
  require_changes: false

ignore:
  - "tests/"
  - "**/*_test.rs"
  - "**/*_test.py"
  - "**/test_*.py"
  - "**/*.spec.ts"
  - "docs/"
