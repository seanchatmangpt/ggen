# .gitignore — generated by ggen code-hygiene spec

# ── OS / editor artefacts ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.iml

# Environment
.env
.env.*
!.env.example
!.env.sample

{% if primaryLanguage == "Rust" %}
# Rust
/target/
Cargo.lock
**/*.rs.bk
*.pdb

{% elif primaryLanguage == "Python" %}
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
ENV/
env/
.tox/
.coverage
.coverage.*
.cache
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

{% elif primaryLanguage == "TypeScript" or primaryLanguage == "JavaScript" %}
# Node / TypeScript / JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
dist/
build/
out/
.next/
.nuxt/
.cache/
coverage/
*.tsbuildinfo
.eslintcache
.parcel-cache

{% elif primaryLanguage == "Go" %}
# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/
/bin/

{% elif primaryLanguage == "Ruby" %}
# Ruby
/.bundle/
/vendor/bundle
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
*.rbc
capybara-*.html
.rspec
/spec/tmp
*.orig
rerun.txt
pickle-email-*.html
.ruby-version
coverage/

{% elif primaryLanguage == "Java" %}
# Java / Gradle / Maven
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/
target/
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

{% elif primaryLanguage == "Elixir" %}
# Elixir
/_build/
/cover/
/deps/
/doc/
/.fetch
erl_crash.dump
*.ez
{{ repoName }}-*.tar
tmp/

{% elif primaryLanguage == "Vue" %}
# Vue / Node
node_modules/
dist/
.nuxt/
.output/
coverage/
*.tsbuildinfo
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

{% else %}
# Generic build output
build/
dist/
out/
target/
*.o
*.a
*.so
*.dll

{% endif %}

# ggen
.ggen/keys/
.ggen/receipts/
