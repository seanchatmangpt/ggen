# .gitattributes — generated by ggen code-hygiene spec

# Default: normalise line endings to LF on checkin
* text=auto eol=lf

# Explicitly declare text files
*.toml    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.sh      text eol=lf
*.env     text eol=lf

{% if primaryLanguage == "Rust" %}
# Rust
*.rs      text eol=lf diff=rust
Cargo.lock text eol=lf merge=binary

{% elif primaryLanguage == "Python" %}
# Python
*.py      text eol=lf diff=python
*.pyi     text eol=lf diff=python
*.ipynb   text eol=lf

{% elif primaryLanguage == "TypeScript" or primaryLanguage == "JavaScript" %}
# JavaScript / TypeScript
*.ts      text eol=lf diff=typescript
*.tsx     text eol=lf diff=typescript
*.js      text eol=lf diff=javascript
*.jsx     text eol=lf diff=javascript
*.mjs     text eol=lf
*.cjs     text eol=lf
package-lock.json text eol=lf merge=binary
yarn.lock text eol=lf merge=binary

{% elif primaryLanguage == "Go" %}
# Go
*.go      text eol=lf diff=golang
go.sum    text eol=lf merge=binary

{% elif primaryLanguage == "Ruby" %}
# Ruby
*.rb      text eol=lf diff=ruby
Gemfile.lock text eol=lf merge=binary

{% elif primaryLanguage == "Java" %}
# Java
*.java    text eol=lf diff=java
*.gradle  text eol=lf
*.xml     text eol=lf diff=xml

{% elif primaryLanguage == "Elixir" %}
# Elixir
*.ex      text eol=lf
*.exs     text eol=lf
mix.lock  text eol=lf merge=binary

{% elif primaryLanguage == "Vue" %}
# Vue
*.vue     text eol=lf
*.ts      text eol=lf diff=typescript
*.js      text eol=lf diff=javascript
package-lock.json text eol=lf merge=binary

{% endif %}

# Binary files — never diff or mangle
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.svg  text eol=lf
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.wasm binary
