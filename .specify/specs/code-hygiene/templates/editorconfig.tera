# .editorconfig — generated by ggen code-hygiene spec
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

{% if primaryLanguage == "Rust" %}
[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

[*.toml]
indent_style = space
indent_size = 4

{% elif primaryLanguage == "Python" %}
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

[*.toml]
indent_style = space
indent_size = 4

{% elif primaryLanguage == "TypeScript" or primaryLanguage == "JavaScript" %}
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size = 2
max_line_length = 120

[*.json]
indent_style = space
indent_size = 2

[*.{yaml,yml}]
indent_style = space
indent_size = 2

{% elif primaryLanguage == "Go" %}
[*.go]
indent_style = tab
indent_size = 4
max_line_length = 120

{% elif primaryLanguage == "Ruby" %}
[*.rb]
indent_style = space
indent_size = 2
max_line_length = 120

{% elif primaryLanguage == "Java" %}
[*.java]
indent_style = space
indent_size = 4
max_line_length = 120

{% elif primaryLanguage == "Elixir" %}
[*.{ex,exs}]
indent_style = space
indent_size = 2
max_line_length = 98

{% elif primaryLanguage == "Vue" %}
[*.vue]
indent_style = space
indent_size = 2

[*.{ts,js}]
indent_style = space
indent_size = 2

{% else %}
[*]
indent_style = space
indent_size = 4
{% endif %}

[*.{md,txt}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
