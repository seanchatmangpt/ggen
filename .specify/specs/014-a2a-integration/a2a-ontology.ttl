# A2A Ontology - Agent-to-Agent Communication Protocol
# Base URI: https://a2a.dev/ontology#
# Version: 1.0.0

@prefix a2a: <https://a2a.dev/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://a2a.dev/ontology> rdf:type owl:Ontology ;
    rdfs:label "A2A Ontology"@en ;
    rdfs:comment "An ontology for Agent-to-Agent communication protocols, defining core concepts for autonomous agent interactions including agents, tasks, messages, skills, and transport mechanisms."@en ;
    dcterms:title "Agent-to-Agent Communication Ontology"@en ;
    dcterms:description "Formal specification of concepts and relationships for autonomous agent communication and coordination."@en ;
    dcterms:created "2026-02-08"^^xsd:date ;
    dcterms:modified "2026-02-08"^^xsd:date ;
    vann:preferredNamespacePrefix "a2a" ;
    vann:preferredNamespaceUri "https://a2a.dev/ontology#" ;
    owl:versionInfo "1.0.0" .

#################################################################
#    Classes
#################################################################

a2a:Agent rdf:type owl:Class ;
    rdfs:label "Agent"@en ;
    rdfs:comment "An autonomous software entity capable of performing tasks, communicating with other agents, and exposing skills. Agents can process messages, execute workflows, and coordinate with other agents through various transport protocols."@en ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasName ;
        owl:cardinality "1"^^xsd:nonNegativeInteger ;
        rdfs:comment "Every agent must have exactly one name"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasSkill ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        rdfs:comment "An agent may have zero or more skills"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasTransport ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        rdfs:comment "An agent may support zero or more transport protocols"
    ] .

a2a:Message rdf:type owl:Class ;
    rdfs:label "Message"@en ;
    rdfs:comment "A communication unit exchanged between agents. Messages contain parts with actual content and have a defined role within the conversation context (user, assistant, or system)."@en ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasRole ;
        owl:cardinality "1"^^xsd:nonNegativeInteger ;
        rdfs:comment "Every message must have exactly one role"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasPart ;
        owl:minCardinality "1"^^xsd:nonNegativeInteger ;
        rdfs:comment "Every message must contain at least one part"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:timestamp ;
        owl:cardinality "1"^^xsd:nonNegativeInteger ;
        rdfs:comment "Every message must have exactly one timestamp"
    ] .

a2a:Part rdf:type owl:Class ;
    rdfs:label "Part"@en ;
    rdfs:comment "A discrete piece of content within a message. Parts contain the actual data payload and specify the MIME type for proper content interpretation (e.g., text/plain, application/json, image/png)."@en ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasData ;
        owl:cardinality "1"^^xsd:nonNegativeInteger ;
        rdfs:comment "Every part must contain exactly one data payload"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasMimeType ;
        owl:cardinality "1"^^xsd:nonNegativeInteger ;
        rdfs:comment "Every part must specify exactly one MIME type"
    ] .

a2a:Task rdf:type owl:Class ;
    rdfs:label "Task"@en ;
    rdfs:comment "A unit of work assigned to or executed by an agent. Tasks have a lifecycle with defined states and are associated with messages that contain task-related data and potentially multiple agents in collaborative scenarios."@en ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasStatus ;
        owl:cardinality "1"^^xsd:nonNegativeInteger ;
        rdfs:comment "Every task must have exactly one status"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasMessage ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        rdfs:comment "A task may be associated with zero or more messages"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasAgent ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        rdfs:comment "A task may involve zero or more agents"
    ] .

a2a:Skill rdf:type owl:Class ;
    rdfs:label "Skill"@en ;
    rdfs:comment "A capability that an agent can perform. Skills are typed with defined input and output schemas, enabling agents to advertise their capabilities and for other agents to discover and invoke them appropriately."@en ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasName ;
        owl:cardinality "1"^^xsd:nonNegativeInteger ;
        rdfs:comment "Every skill must have exactly one name"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasInputType ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        rdfs:comment "A skill may specify zero or more input types"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasOutputType ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        rdfs:comment "A skill may specify zero or more output types"
    ] .

a2a:Transport rdf:type owl:Class ;
    rdfs:label "Transport"@en ;
    rdfs:comment "A communication protocol mechanism that agents can use to exchange messages. Transports define how agents connect (e.g., HTTP, STDIO, gRPC) and include the endpoint URL for establishing connections."@en ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasType ;
        owl:cardinality "1"^^xsd:nonNegativeInteger ;
        rdfs:comment "Every transport must specify exactly one type"
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty a2a:hasUrl ;
        owl:minCardinality "0"^^xsd:nonNegativeInteger ;
        rdfs:comment "A transport may specify zero or more URLs (some transports like STDIO don't use URLs)"
    ] .

a2a:Artifact rdf:type owl:Class ;
    rdfs:label "Artifact"@en ;
    rdfs:comment "A produced output or result from agent execution. Artifacts represent tangible outcomes such as generated code, documents, data files, or any other deliverable created by an agent during task execution."@en .

#################################################################
#    Enumerations
#################################################################

a2a:MessageRole rdf:type owl:Class ;
    rdfs:label "Message Role"@en ;
    rdfs:comment "Enumeration defining the role of a message within a conversation. Roles determine how the message content should be interpreted and processed."@en ;
    owl:equivalentClass [
        rdf:type owl:Class ;
        owl:oneOf (
            a2a:UserRole
            a2a:AssistantRole
            a2a:SystemRole
        )
    ] .

a2a:UserRole rdf:type a2a:MessageRole ;
    rdfs:label "User Role"@en ;
    rdfs:comment "A message originating from a user or external client, typically containing requests, prompts, or input data for agent processing."@en .

a2a:AssistantRole rdf:type a2a:MessageRole ;
    rdfs:label "Assistant Role"@en ;
    rdfs:comment "A message originating from an agent as a response to a user request, containing results, explanations, or requested information."@en .

a2a:SystemRole rdf:type a2a:MessageRole ;
    rdfs:label "System Role"@en ;
    rdfs:comment "A message providing system-level context, instructions, or metadata that guides agent behavior but is not direct user input."@en .

a2a:TaskStatus rdf:type owl:Class ;
    rdfs:label "Task Status"@en ;
    rdfs:comment "Enumeration defining the lifecycle states of a task. Tasks progress through these states as they are processed by agents."@en ;
    owl:equivalentClass [
        rdf:type owl:Class ;
        owl:oneOf (
            a2a:PendingStatus
            a2a:InProgressStatus
            a2a:CompletedStatus
            a2a:FailedStatus
        )
    ] .

a2a:PendingStatus rdf:type a2a:TaskStatus ;
    rdfs:label "Pending Status"@en ;
    rdfs:comment "The task has been created but not yet started processing. It is queued and awaiting agent assignment or execution."@en .

a2a:InProgressStatus rdf:type a2a:TaskStatus ;
    rdfs:label "In Progress Status"@en ;
    rdfs:comment "The task is currently being processed by an agent. Work is actively being performed toward completion."@en .

a2a:CompletedStatus rdf:type a2a:TaskStatus ;
    rdfs:label "Completed Status"@en ;
    rdfs:comment "The task has been successfully processed and all work has been completed. Results are available."@en .

a2a:FailedStatus rdf:type a2a:TaskStatus ;
    rdfs:label "Failed Status"@en ;
    rdfs:comment "The task processing encountered an error and could not be completed successfully. Error details should be available."@en .

#################################################################
#    Object Properties
#################################################################

a2a:hasSkill rdf:type owl:ObjectProperty ;
    rdfs:label "has skill"@en ;
    rdfs:comment "Relates an agent to a skill that the agent can perform. This property enables agents to advertise their capabilities for discovery and invocation."@en ;
    rdfs:domain a2a:Agent ;
    rdfs:range a2a:Skill .

a2a:hasTransport rdf:type owl:ObjectProperty ;
    rdfs:label "has transport"@en ;
    rdfs:comment "Relates an agent to a transport protocol it supports for communication. This enables agents to specify how they can be contacted (HTTP, STDIO, etc.)."@en ;
    rdfs:domain a2a:Agent ;
    rdfs:range a2a:Transport .

a2a:hasPart rdf:type owl:ObjectProperty ;
    rdfs:label "has part"@en ;
    rdfs:comment "Relates a message to one of its constituent parts. Messages contain one or more parts that hold the actual message content."@en ;
    rdfs:domain a2a:Message ;
    rdfs:range a2a:Part .

a2a:hasMessage rdf:type owl:ObjectProperty ;
    rdfs:label "has message"@en ;
    rdfs:comment "Relates a task to messages associated with the task execution. This includes request messages and response messages exchanged during task processing."@en ;
    rdfs:domain a2a:Task ;
    rdfs:range a2a:Message .

a2a:hasAgent rdf:type owl:ObjectProperty ;
    rdfs:label "has agent"@en ;
    rdfs:comment "Relates a task to an agent involved in the task execution. A task may involve multiple agents in collaborative or delegation scenarios."@en ;
    rdfs:domain a2a:Task ;
    rdfs:range a2a:Agent .

a2a:hasRole rdf:type owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    rdfs:comment "Relates a message to its role within the conversation (user, assistant, or system). The role determines how the message should be interpreted."@en ;
    rdfs:domain a2a:Message ;
    rdfs:range a2a:MessageRole .

a2a:hasStatus rdf:type owl:ObjectProperty ;
    rdfs:label "has status"@en ;
    rdfs:comment "Relates a task to its current processing status. The status indicates where the task is in its lifecycle (pending, in progress, completed, or failed)."@en ;
    rdfs:domain a2a:Task ;
    rdfs:range a2a:TaskStatus .

a2a:producesArtifact rdf:type owl:ObjectProperty ;
    rdfs:label "produces artifact"@en ;
    rdfs:comment "Relates a task or agent to an artifact produced as a result of execution. Artifacts are tangible outputs like code, documents, or data files."@en ;
    rdfs:domain a2a:Task ;
    rdfs:range a2a:Artifact .

#################################################################
#    Datatype Properties
#################################################################

a2a:hasName rdf:type owl:DatatypeProperty ;
    rdfs:label "has name"@en ;
    rdfs:comment "A human-readable identifier for an entity (agent, skill, or transport). Names should be unique within their scope and follow naming conventions."@en ;
    rdfs:range xsd:string .

a2a:hasEndpoint rdf:type owl:DatatypeProperty ;
    rdfs:label "has endpoint"@en ;
    rdfs:comment "The network address or location where an agent can be contacted. Endpoints are typically URLs or connection strings for supported transports."@en ;
    rdfs:domain a2a:Agent ;
    rdfs:range xsd:anyURI .

a2a:hasData rdf:type owl:DatatypeProperty ;
    rdfs:label "has data"@en ;
    rdfs:comment "The actual content payload of a message part. The data format should match the declared MIME type for proper interpretation."@en ;
    rdfs:domain a2a:Part ;
    rdfs:range xsd:string .

a2a:hasMimeType rdf:type owl:DatatypeProperty ;
    rdfs:label "has MIME type"@en ;
    rdfs:comment "The MIME type identifier for a message part's data content (e.g., text/plain, application/json, image/png). This enables proper content interpretation and validation."@en ;
    rdfs:domain a2a:Part ;
    rdfs:range xsd:string .

a2a:timestamp rdf:type owl:DatatypeProperty ;
    rdfs:label "timestamp"@en ;
    rdfs:comment "The timestamp indicating when a message was created or sent. Timestamps are expressed as ISO 8601 date-time strings for interoperability."@en ;
    rdfs:domain a2a:Message ;
    rdfs:range xsd:dateTime .

a2a:hasInputType rdf:type owl:DatatypeProperty ;
    rdfs:label "has input type"@en ;
    rdfs:comment "Specifies the expected input type or schema for a skill. This enables type validation and proper invocation of the skill."@en ;
    rdfs:domain a2a:Skill ;
    rdfs:range xsd:string .

a2a:hasOutputType rdf:type owl:DatatypeProperty ;
    rdfs:label "has output type"@en ;
    rdfs:comment "Specifies the output type or schema that a skill produces. This enables consumers to understand and process skill results correctly."@en ;
    rdfs:domain a2a:Skill ;
    rdfs:range xsd:string .

a2a:hasType rdf:type owl:DatatypeProperty ;
    rdfs:label "has type"@en ;
    rdfs:comment "Specifies the type of transport protocol (e.g., http, stdio, grpc). This determines how messages are formatted and transmitted."@en ;
    rdfs:domain a2a:Transport ;
    rdfs:range xsd:string .

a2a:hasUrl rdf:type owl:DatatypeProperty ;
    rdfs:label "has URL"@en ;
    rdfs:comment "The URL endpoint for a transport protocol. Not all transports use URLs (e.g., STDIO), so this is optional."@en ;
    rdfs:domain a2a:Transport ;
    rdfs:range xsd:anyURI .

a2a:hasDescription rdf:type owl:DatatypeProperty ;
    rdfs:label "has description"@en ;
    rdfs:comment "A human-readable description providing additional context about an entity. Descriptions help with discovery and understanding of capabilities."@en ;
    rdfs:range xsd:string .

a2a:hasVersion rdf:type owl:DatatypeProperty ;
    rdfs:label "has version"@en ;
    rdfs:comment "The version identifier for an agent, skill, or protocol. Versions enable compatibility checking and evolution of capabilities."@en ;
    rdfs:range xsd:string .

a2a:hasId rdf:type owl:DatatypeProperty ;
    rdfs:label "has ID"@en ;
    rdfs:comment "A unique identifier for an entity. IDs provide stable references that are independent of names or other mutable properties."@en ;
    rdfs:range xsd:string .

#################################################################
#    Annotation Properties
#################################################################

a2a:protocolVersion rdf:type owl:AnnotationProperty ;
    rdfs:label "protocol version"@en ;
    rdfs:comment "Indicates the version of the A2A protocol being used. This enables compatibility checking between communicating agents."@en ;
    rdfs:range xsd:string .

a2a:requiresCapability rdf:type owl:AnnotationProperty ;
    rdfs:label "requires capability"@en ;
    rdfs:comment "Indicates that a task or skill requires a specific capability to execute properly. This enables capability matching and validation."@en ;
    rdfs:range xsd:string .

#################################################################
#    Individuals (Example Instances)
#################################################################

# Example Transport Types
a2a:HTTPTransport rdf:type a2a:Transport ;
    a2a:hasType "http" ;
    a2a:hasDescription "HTTP/HTTPS transport for REST-based agent communication" .

a2a:STDIOTransport rdf:type a2a:Transport ;
    a2a:hasType "stdio" ;
    a2a:hasDescription "Standard input/output transport for local agent communication" .

a2a:GRPCTransport rdf:type a2a:Transport ;
    a2a:hasType "grpc" ;
    a2a:hasDescription "gRPC transport for high-performance agent communication" .

# Common MIME Types
a2a:TextPlain rdf:type a2a:Part ;
    a2a:hasMimeType "text/plain" ;
    a2a:hasDescription "Plain text content" .

a2a:ApplicationJson rdf:type a2a:Part ;
    a2a:hasMimeType "application/json" ;
    a2a:hasDescription "JSON structured data" .

a2a:TextMarkdown rdf:type a2a:Part ;
    a2a:hasMimeType "text/markdown" ;
    a2a:hasDescription "Markdown formatted text" .
