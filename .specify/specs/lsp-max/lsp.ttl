@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix lsp:  <http://ggen.io/ontology/lsp#> .

# ── Ontology declaration ────────────────────────────────────────────────────

<http://ggen.io/ontology/lsp>
    a owl:Ontology ;
    rdfs:label "lsp-max server ontology"^^xsd:string ;
    rdfs:comment "OWL ontology for specification-driven lsp-max rule-pack language servers."^^xsd:string .

# ── Core classes ────────────────────────────────────────────────────────────

lsp:Server
    a owl:Class ;
    rdfs:label "LspServer" ;
    rdfs:comment "A rule-pack language server generated by ggen from this ontology." .

lsp:RulePack
    a owl:Class ;
    rdfs:label "RulePack" ;
    rdfs:comment "A named, versioned collection of law rules enforced by a server." .

lsp:Rule
    a owl:Class ;
    rdfs:label "Rule" ;
    rdfs:comment "A single regex-pattern law within a RulePack." .

lsp:CrossFileRule
    a owl:Class ;
    rdfs:label "CrossFileRule" ;
    rdfs:comment "A law constraint that spans multiple workspace documents." .

lsp:LawAxis
    a owl:Class ;
    rdfs:label "LawAxis" ;
    rdfs:comment "A named dimension of conformance (Protocol, Domain, Receipt, etc.)." .

# ── Server properties ───────────────────────────────────────────────────────

lsp:serverName
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Server ;
    rdfs:range xsd:string ;
    rdfs:label "serverName" ;
    rdfs:comment "Stable human-readable server identifier used in diagnostic source fields." .

lsp:diagnosticSourceId
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Server ;
    rdfs:range xsd:string ;
    rdfs:label "diagnosticSourceId" ;
    rdfs:comment "Short source tag attached to every published diagnostic (e.g. 'pattern-lsp')." .

lsp:grammarCrate
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Server ;
    rdfs:range xsd:string ;
    rdfs:label "grammarCrate" ;
    rdfs:comment "Rust crate providing the tree-sitter grammar (e.g. 'tree_sitter_rust')." .

lsp:hasRulePack
    a owl:ObjectProperty ;
    rdfs:domain lsp:Server ;
    rdfs:range lsp:RulePack ;
    rdfs:label "hasRulePack" .

# ── RulePack properties ─────────────────────────────────────────────────────

lsp:packId
    a owl:DatatypeProperty ;
    rdfs:domain lsp:RulePack ;
    rdfs:range xsd:string ;
    rdfs:label "packId" .

lsp:packVersion
    a owl:DatatypeProperty ;
    rdfs:domain lsp:RulePack ;
    rdfs:range xsd:string ;
    rdfs:label "packVersion" .

lsp:dependsOn
    a owl:ObjectProperty ;
    rdfs:domain lsp:RulePack ;
    rdfs:range lsp:RulePack ;
    rdfs:label "dependsOn" ;
    rdfs:comment "Dependency edge: this pack must be resolved after the target pack." .

lsp:hasRule
    a owl:ObjectProperty ;
    rdfs:domain lsp:RulePack ;
    rdfs:range lsp:Rule ;
    rdfs:label "hasRule" .

# ── Rule properties ─────────────────────────────────────────────────────────

lsp:ruleId
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Rule ;
    rdfs:range xsd:string ;
    rdfs:label "ruleId" .

lsp:ruleName
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Rule ;
    rdfs:range xsd:string ;
    rdfs:label "ruleName" .

lsp:severity
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Rule ;
    rdfs:range xsd:string ;
    rdfs:label "severity" ;
    rdfs:comment "One of: error, warning, info, hint." .

lsp:pattern
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Rule ;
    rdfs:range xsd:string ;
    rdfs:label "pattern" ;
    rdfs:comment "Rust regex pattern matched against source text." .

lsp:message
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Rule ;
    rdfs:range xsd:string ;
    rdfs:label "message" .

lsp:rationale
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Rule ;
    rdfs:range xsd:string ;
    rdfs:label "rationale" .

lsp:evalBudget
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Rule ;
    rdfs:range xsd:string ;
    rdfs:label "evalBudget" ;
    rdfs:comment "Latency classification: 'sync' or 'background'." .

# ── LawAxis individuals ─────────────────────────────────────────────────────

lsp:AxisProtocol    a lsp:LawAxis ; rdfs:label "Protocol" .
lsp:AxisDomain      a lsp:LawAxis ; rdfs:label "Domain" .
lsp:AxisReceipt     a lsp:LawAxis ; rdfs:label "Receipt" .
lsp:AxisSecurity    a lsp:LawAxis ; rdfs:label "Security" .
lsp:AxisFixture     a lsp:LawAxis ; rdfs:label "Fixture" .
lsp:AxisDocumentation a lsp:LawAxis ; rdfs:label "Documentation" .

# ── anti-llm-cheat-lsp server instance ──────────────────────────────────────

lsp:AntiLlmCheatServer
    a lsp:Server ;
    lsp:serverName         "anti-llm-cheat-lsp"^^xsd:string ;
    lsp:diagnosticSourceId "anti-llm-cheat-lsp"^^xsd:string ;
    lsp:grammarCrate       "tree_sitter_rust"^^xsd:string ;
    lsp:hasRulePack        lsp:CheatSmellsPack ;
    lsp:hasRulePack        lsp:CheatClaimsPack ;
    lsp:hasRulePack        lsp:CheatReceiptsPack ;
    lsp:hasRulePack        lsp:CheatTestPack ;
    lsp:hasRulePack        lsp:CheatSurfacePack .

# ── Pack: raw text smells ────────────────────────────────────────────────────

lsp:CheatSmellsPack
    a lsp:RulePack ;
    lsp:packId      "cheat-smells@1.0.0"^^xsd:string ;
    lsp:packVersion "1.0.0"^^xsd:string ;
    lsp:hasRule     lsp:CheatSmell001 ;
    lsp:hasRule     lsp:CheatSmell002 ;
    lsp:hasRule     lsp:CheatSmell003 ;
    lsp:hasRule     lsp:CheatSmell004 ;
    lsp:hasRule     lsp:CheatSmell005 .

lsp:CheatSmell001
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-STRANGE-001"^^xsd:string ;
    lsp:ruleName   "no-clap-debug"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "CLAP-DEBUG"^^xsd:string ;
    lsp:message    "Debug diagnostic name found in admissible path"^^xsd:string ;
    lsp:rationale  "CLAP-DEBUG constructs are test scaffolding and must not appear in production paths"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatSmell002
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-STRANGE-002"^^xsd:string ;
    lsp:ruleName   "no-content-leak"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "Content was:"^^xsd:string ;
    lsp:message    "Raw content leak found — diagnostic leaks document text into message"^^xsd:string ;
    lsp:rationale  "Leaking raw content through diagnostics exposes user source to log infrastructure"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatSmell003
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-STRANGE-003"^^xsd:string ;
    lsp:ruleName   "no-path-leak"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "Path was:"^^xsd:string ;
    lsp:message    "Raw path leak found — diagnostic leaks filesystem path into message"^^xsd:string ;
    lsp:rationale  "Leaking paths through diagnostics exposes local filesystem layout"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatSmell004
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-OCEL-001"^^xsd:string ;
    lsp:ruleName   "no-ocel-trigger-001"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "ANTI-LLM-OCEL-001-TRIGGER"^^xsd:string ;
    lsp:message    "Diagnostic emitted without corresponding OCEL process event"^^xsd:string ;
    lsp:rationale  "Every diagnostic must be traceable to an OCEL event in the process log"^^xsd:string ;
    lsp:evalBudget "background"^^xsd:string .

lsp:CheatSmell005
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-OCEL-002"^^xsd:string ;
    lsp:ruleName   "no-ocel-trigger-002"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "ANTI-LLM-OCEL-002-TRIGGER"^^xsd:string ;
    lsp:message    "Receipt claim exists without OCEL object/event binding"^^xsd:string ;
    lsp:rationale  "Receipt claims require a bound OCEL object to be admissible"^^xsd:string ;
    lsp:evalBudget "background"^^xsd:string .

# ── Pack: victory/done claims ────────────────────────────────────────────────

lsp:CheatClaimsPack
    a lsp:RulePack ;
    lsp:packId      "cheat-claims@1.0.0"^^xsd:string ;
    lsp:packVersion "1.0.0"^^xsd:string ;
    lsp:hasRule     lsp:CheatClaim001 ;
    lsp:hasRule     lsp:CheatClaim002 ;
    lsp:hasRule     lsp:CheatClaim003 ;
    lsp:hasRule     lsp:CheatClaim004 .

lsp:CheatClaim001
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-CLAIM-001"^^xsd:string ;
    lsp:ruleName   "no-victory-confirmed"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "Victory confirmed"^^xsd:string ;
    lsp:message    "Forbidden victory claim: 'Victory confirmed'"^^xsd:string ;
    lsp:rationale  "Completion claims without process evidence violate AGENTS.md bounded-status rules"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatClaim002
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-CLAIM-002"^^xsd:string ;
    lsp:ruleName   "no-fully-admitted"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "fully admitted"^^xsd:string ;
    lsp:message    "Forbidden completion claim: 'fully admitted'"^^xsd:string ;
    lsp:rationale  "Completion claims without process evidence violate AGENTS.md bounded-status rules"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatClaim003
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-CLAIM-003"^^xsd:string ;
    lsp:ruleName   "no-all-gaps-resolved"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "all gaps resolved"^^xsd:string ;
    lsp:message    "Forbidden completion claim: 'all gaps resolved'"^^xsd:string ;
    lsp:rationale  "Gap claims require process evidence; text assertions are insufficient"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatClaim004
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-CLAIM-004"^^xsd:string ;
    lsp:ruleName   "no-successfully-proven"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "successfully proven"^^xsd:string ;
    lsp:message    "Forbidden proof claim: 'successfully proven'"^^xsd:string ;
    lsp:rationale  "Proof requires a receipt chain, not a string assertion"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

# ── Pack: receipt law ────────────────────────────────────────────────────────

lsp:CheatReceiptsPack
    a lsp:RulePack ;
    lsp:packId      "cheat-receipts@1.0.0"^^xsd:string ;
    lsp:packVersion "1.0.0"^^xsd:string ;
    lsp:hasRule     lsp:CheatReceipt001 ;
    lsp:hasRule     lsp:CheatReceipt002 ;
    lsp:hasRule     lsp:CheatReceipt003 .

lsp:CheatReceipt001
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-RECEIPT-001"^^xsd:string ;
    lsp:ruleName   "no-test-result-as-receipt"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "test result: ok"^^xsd:string ;
    lsp:message    "Test stdout treated as receipt — test output is not a cryptographically signed receipt"^^xsd:string ;
    lsp:rationale  "receipts require Ed25519 signature and BLAKE3 input/output hashes"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatReceipt002
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-RECEIPT-002"^^xsd:string ;
    lsp:ruleName   "no-bypassed-compat"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "[\\x22]bypassed_compat[\\x22]: true"^^xsd:string ;
    lsp:message    "Compatibility bypass flag found in receipt or config"^^xsd:string ;
    lsp:rationale  "bypassed_compat:true invalidates the receipt chain"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatReceipt003
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-RECEIPT-003"^^xsd:string ;
    lsp:ruleName   "no-routing-claim"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "Routing to PackPlan"^^xsd:string ;
    lsp:message    "Route log treated as route execution — a print of the route does not prove execution"^^xsd:string ;
    lsp:rationale  "Route logs are observational; execution requires a receipt"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

# ── Pack: test law ───────────────────────────────────────────────────────────

lsp:CheatTestPack
    a lsp:RulePack ;
    lsp:packId      "cheat-tests@1.0.0"^^xsd:string ;
    lsp:packVersion "1.0.0"^^xsd:string ;
    lsp:hasRule     lsp:CheatTest001 ;
    lsp:hasRule     lsp:CheatTest002 .

lsp:CheatTest001
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-TEST-001"^^xsd:string ;
    lsp:ruleName   "no-static-scan-as-proof"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "static scan as route proof"^^xsd:string ;
    lsp:message    "Static scan substituted for route proof"^^xsd:string ;
    lsp:rationale  "Absence of bad strings does not prove mutation was safely routed"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatTest002
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-VERSION-001"^^xsd:string ;
    lsp:ruleName   "no-default-version"^^xsd:string ;
    lsp:severity   "warning"^^xsd:string ;
    lsp:pattern    "version = [\\x22]1\\.0\\.0[\\x22]"^^xsd:string ;
    lsp:message    "Default template version '1.0.0' found in project configuration"^^xsd:string ;
    lsp:rationale  "Default versions indicate a project was never properly versioned"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

# ── Pack: surface law (tower-lsp detection) ──────────────────────────────────

lsp:CheatSurfacePack
    a lsp:RulePack ;
    lsp:packId      "cheat-surface@1.0.0"^^xsd:string ;
    lsp:packVersion "1.0.0"^^xsd:string ;
    lsp:hasRule     lsp:CheatSurface001 ;
    lsp:hasRule     lsp:CheatSurface002 .

lsp:CheatSurface001
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-SURFACE-001"^^xsd:string ;
    lsp:ruleName   "no-tower-lsp"^^xsd:string ;
    lsp:severity   "error"^^xsd:string ;
    lsp:pattern    "tower-lsp"^^xsd:string ;
    lsp:message    "Plain tower-lsp found — all LSP hosts must use lsp-max"^^xsd:string ;
    lsp:rationale  "tower-lsp lacks the ConformanceVector, max/ protocol, and receipt infrastructure"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

lsp:CheatSurface002
    a lsp:Rule ;
    lsp:ruleId     "ANTI-LLM-SURFACE-002"^^xsd:string ;
    lsp:ruleName   "no-wasm4pm-direct"^^xsd:string ;
    lsp:severity   "warning"^^xsd:string ;
    lsp:pattern    "use wasm4pm::"^^xsd:string ;
    lsp:message    "Direct wasm4pm import — use the abstraction layer instead"^^xsd:string ;
    lsp:rationale  "Direct wasm4pm imports bypass the admission layer"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

# ── Example server instance (drives template generation) ────────────────────

lsp:MyRulePackServer
    a lsp:Server ;
    lsp:serverName        "my-lsp"^^xsd:string ;
    lsp:diagnosticSourceId "my-lsp"^^xsd:string ;
    lsp:grammarCrate      "tree_sitter_rust"^^xsd:string ;
    lsp:hasRulePack       lsp:ExamplePack .

lsp:ExamplePack
    a lsp:RulePack ;
    lsp:packId      "example@1.0.0"^^xsd:string ;
    lsp:packVersion "1.0.0"^^xsd:string ;
    lsp:hasRule     lsp:ExampleRule001 .

lsp:ExampleRule001
    a lsp:Rule ;
    lsp:ruleId    "EXAMPLE-001"^^xsd:string ;
    lsp:ruleName  "no-unwrap"^^xsd:string ;
    lsp:severity  "error"^^xsd:string ;
    lsp:pattern   "\\.(unwrap|expect)\\(\\)"^^xsd:string ;
    lsp:message   "Replace unwrap()/expect() with ? or map_err"^^xsd:string ;
    lsp:rationale "Panics abort async tasks; use Result propagation"^^xsd:string ;
    lsp:evalBudget "sync"^^xsd:string .

# ── File glob property ───────────────────────────────────────────────────────

lsp:fileGlob
    a owl:DatatypeProperty ;
    rdfs:domain lsp:Server ;
    rdfs:range xsd:string ;
    rdfs:label "fileGlob" ;
    rdfs:comment "Glob pattern for files this server proactively scans on workspace open." .

# ── File globs per server ────────────────────────────────────────────────────

lsp:AntiLlmCheatServer
    lsp:fileGlob "**/*.rs"^^xsd:string ;
    lsp:fileGlob "**/*.md"^^xsd:string ;
    lsp:fileGlob "**/*.toml"^^xsd:string ;
    lsp:fileGlob "**/*.json"^^xsd:string ;
    lsp:fileGlob "**/*.jsonl"^^xsd:string .

lsp:MyRulePackServer
    lsp:fileGlob "**/*.rs"^^xsd:string .
