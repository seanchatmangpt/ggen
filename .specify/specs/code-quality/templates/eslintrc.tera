{
  "$schema": "https://json.schemastore.org/eslintrc",
  "_generated_for": "{{ repoName }}",
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"{% if primaryLanguage == "TypeScript" %},
    "plugin:@typescript-eslint/recommended"{% endif %}
  ],
  "plugins": [{% if primaryLanguage == "TypeScript" %}
    "@typescript-eslint"{% endif %}
  ],{% if primaryLanguage == "TypeScript" %}
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "project": "./tsconfig.json"
  },{% else %}
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },{% endif %}
  "rules": {
    "no-unused-vars": {% if primaryLanguage == "TypeScript" %}"off"{% else %}"warn"{% endif %},
    "no-console": "warn",
    "no-debugger": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"]{% if primaryLanguage == "TypeScript" %},
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/no-explicit-any": "warn"{% endif %}
  },
  "ignorePatterns": [
    "dist/",
    "build/",
    "coverage/",
    "node_modules/"
  ]
}
