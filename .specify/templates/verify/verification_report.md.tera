    own copy of each ggen-verify-pack template). -#}
{%- set checks = sparql(query='PREFIX ver: <http://seanchatmangpt.github.io/packs/ggen-verify#> SELECT ?name ?exitCode ?tool ?summary WHERE { ?c a ver:Check ; ver:name ?name ; ver:exitCode ?exitCode . OPTIONAL { ?c ver:tool ?tool } OPTIONAL { ?c ver:summary ?summary } } ORDER BY ?name') -%}
{%- set divergences = sparql(query='PREFIX ver: <http://seanchatmangpt.github.io/packs/ggen-verify#> PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#> SELECT ?name ?why WHERE { ?kd a ver:KnownDivergence ; ver:name ?name ; rdfs:comment ?why . } ORDER BY ?name') -%}
