{#- scripts/produce-receipts-check.sh — generated mirror of packs/ggen-verify-pack's
    templates/produce_receipts_check_sh.tmpl. Root ggen.toml is the
    "declarative-rules" schema (has [[generation.rules]]), which does NOT
    read a template's own frontmatter `sparql:` block (only the "frontmatter"
    schema, ggen_engine::config::GgenConfig, does that -- see
    verify_evidence_sh.sh.tera / produce_docs_manifest_sh.sh.tera's identical
    note, which this file follows). This template needs no data from
    sparql() itself (the pack's own frontmatter query only filters for the
    "receipts" producer's existence, which [[generation.rules]]'s own query
    below already establishes), so the body is otherwise byte-identical to
    the pack's own producer: schema-validates .ggen-v2/receipt-log.jsonl,
    replays the chain's hash linkage, and re-derives the head judgment as
    ver:ReceiptsCheck facts. Keep this in sync with
    packs/ggen-verify-pack/templates/produce_receipts_check_sh.tmpl if that
    changes -- ONE DELIBERATE DIVERGENCE: the pack's own template checks
    each record for a "schema" field; ggen's real .ggen-v2/receipt-log.jsonl
    records (crates/praxis-core/src/receipt_record.rs) have no such field --
    the actual per-record version marker is named "version" (confirmed:
    every record in this repo's real log carries `"version": 1`). Checking
    for the pack's literal "schema" key against ggen's real receipt format
    would report every record as invalid (missing field) unconditionally,
    which is not an honest reflection of this repo's real receipt-chain
    health -- so this mirror checks "version" instead. This is a genuine,
    evidence-based field-name correction for THIS repo's real data, not a
    guess; do not "fix" it back to match the pack's template without first
    checking whether the pack's own record schema differs from ggen's. -#}
#!/usr/bin/env bash
# GENERATED by `ggen sync` from .specify/templates/verify/produce_receipts_check_sh.sh.tera
# (ggen.toml's own declarative-rules mirror of packs/ggen-verify-pack's
# templates/produce_receipts_check_sh.tmpl -- see that file's header for the
# schema note on why this repo needs its own copy). Receipts-class producer:
# schema-validates .ggen-v2/receipt-log.jsonl, replays the chain's hash
# linkage (each record's prev_chain_hash_hex must equal its predecessor's
# chain_hash_hex, genesis all-zeros), and re-derives the head judgment (last
# record's chain_hash_hex must equal .ggen-v2/receipt.json's). Emits
# ver:ReceiptsCheck with the REAL exit code + the replayed chain head hash.
# Always exits 0 itself; judgment happens at sync (a red check lowers the
# gate axis by the meet law and the receipts class only goes Equivalent when
# the replayed head matches the verified previous head the next receipt
# chains from).
set -uo pipefail
cd "$(dirname "$0")/.."
mkdir -p evidence/producers

CODE=0
HEAD_HASH="absent"
if [ ! -f .ggen-v2/receipt-log.jsonl ]; then
  CODE=1
else
  RESULT="$(python3 - <<'PYEOF'
import json, sys
prev = "0" * 64
head = "absent"
required = ["chain_hash_hex", "prev_chain_hash_hex", "payload_hash_hex", "version"]
try:
    with open(".ggen-v2/receipt-log.jsonl") as fh:
        for lineno, line in enumerate(fh, 1):
            if not line.strip():
                continue
            rec = json.loads(line)["record"]
            for key in required:
                if key not in rec or not rec[key]:
                    raise ValueError(f"line {lineno}: missing {key}")
            if rec["prev_chain_hash_hex"] != prev:
                raise ValueError(f"line {lineno}: chain linkage broken")
            prev = rec["chain_hash_hex"]
            head = prev
    with open(".ggen-v2/receipt.json") as fh:
        if json.load(fh)["record"]["chain_hash_hex"] != head:
            raise ValueError("head receipt does not match log tail")
except Exception as exc:
    print(f"1 {head} {exc}")
    sys.exit(0)
print(f"0 {head} ok")
PYEOF
)"
  CODE="$(echo "$RESULT" | cut -d' ' -f1)"
  HEAD_HASH="$(echo "$RESULT" | cut -d' ' -f2)"
fi

OUT=evidence/producers/receipts-check.ttl
{
  echo "# GENERATED by scripts/produce-receipts-check.sh -- do not edit."
  echo "@prefix ver: <http://seanchatmangpt.github.io/packs/ggen-verify#> ."
  echo
  echo "ver:receipts-check a ver:ReceiptsCheck ;"
  echo "    ver:exitCode $CODE ;"
  echo "    ver:chainHead \"$HEAD_HASH\" ."
} > "$OUT"
echo "produce-receipts-check.sh: exit $CODE, head $HEAD_HASH -> $OUT"
exit 0
