//! Auto-generated commands reference
//! DO NOT EDIT — generated by root ggen.toml rule `cli-commands-reference`
//! from `.specify/cli-commands.ttl`. Edit the ontology, then `ggen sync run`.

/// (command IRI, label, description) rows, ontology-ordered by label.
pub const COMMANDS_REFERENCE: &[(&str, &str, &str)] = &[
{%- for row in results %}
    ("{{ row["cmd"] | default(value="") }}", "{{ row["label"] | default(value="") }}", "{{ row["comment"] | default(value="") }}"),
{%- endfor %}
];

/// Look up the ontology-declared description for a CLI command by its label.
///
/// Returns `None` when the label is not declared as a `cli:Command`
/// individual in `.specify/cli-commands.ttl`.
pub fn describe_command(label: &str) -> Option<&'static str> {
    COMMANDS_REFERENCE
        .iter()
        .find(|(_, l, _)| *l == label)
        .map(|(_, _, comment)| *comment)
}
