#[test]
fn {{ test_id }}() {
    // Axiom: {{ covers }}

    // Arrange
    let ws = TempWorkspace::new().expect("TempWorkspace");

    // Act — spawn real ggen binary
    let mut cmd_args: Vec<&str> = vec![];
    {%- set parts = command | split(pat=" ") %}
    {%- for part in parts %}
    {%- if part != "" %}
    cmd_args.push("{{ part }}");
    {%- endif %}
    {%- endfor %}
    {%- if args != "" %}
    {%- set arg_parts = args | split(pat=" ") %}
    {%- for arg in arg_parts %}
    {%- if arg != "" %}
    cmd_args.push("{{ arg }}");
    {%- endif %}
    {%- endfor %}
    {%- endif %}

    let result = CliHarness::cargo_bin("ggen")
        .args(cmd_args)
        .workspace(&ws)
        .run()
        .expect("ggen binary executed");

    // Assert
    result.assert_exit_code({{ expect_code }});
    {%- if stdout_contains != "" %}
    result.assert_stdout_contains("{{ stdout_contains }}");
    {%- endif %}
    {%- if stderr_contains != "" %}
    result.assert_stderr_contains("{{ stderr_contains }}");
    {%- endif %}
    {%- if file_exists != "" %}
