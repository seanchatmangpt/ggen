{#- docs/l5-promotion/L5_PROMOTION_PROGRAM.md — full projection of
    .specify/pack-l5-promotion.ttl. Ten named artifacts as sections of one
    generated doc: pack census, capability model, dependency graph
    (per-pack wave placement stands in for dependency ordering until a
    finer-grained l5p:dependsOn edge set is authored), promotion-wave plan,
    per-pack obligations, consumer-replacement status, standing ledger,
    incompatibility/supersession ledger, maximal-closure manifest, autosel
    admission manifest. -#}
{%- set S = sparql(query='PREFIX l5p: <http://ggen.org/l5-promotion#> SELECT ?sid ?text WHERE { ?x a l5p:DocSection ; l5p:sid ?sid ; l5p:text ?text . } ORDER BY ?sid') -%}
{%- set intro = S | filter(attribute="sid", value="intro") | first -%}
{%- set completion = S | filter(attribute="sid", value="completion") | first -%}
{%- set packs = sparql(query='PREFIX l5p: <http://ggen.org/l5-promotion#> PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#> SELECT ?id ?wave ?standing ?ceiling ?obligation WHERE { ?p a l5p:Pack ; l5p:packId ?id ; l5p:wave ?w ; l5p:standing ?s ; l5p:currentCeiling ?ceiling ; l5p:nextPromotionObligation ?obligation . ?w l5p:order ?wave . ?s rdfs:label ?standing . } ORDER BY ?wave ?id') -%}
{%- set waves = sparql(query='PREFIX l5p: <http://ggen.org/l5-promotion#> SELECT ?order ?name ?desc WHERE { ?w a l5p:PromotionWave ; l5p:order ?order ; l5p:waveName ?name ; l5p:waveDesc ?desc . } ORDER BY ?order') -%}
{%- set caps = sparql(query='PREFIX l5p: <http://ggen.org/l5-promotion#> SELECT ?order ?name ?desc WHERE { ?c a l5p:Capability ; l5p:order ?order ; l5p:capName ?name ; l5p:capDesc ?desc . } ORDER BY ?order') -%}
{%- set missing = sparql(query='PREFIX l5p: <http://ggen.org/l5-promotion#> SELECT ?id ?capOrder ?capName WHERE { ?p a l5p:Pack ; l5p:packId ?id ; l5p:missingCap ?c . ?c l5p:order ?capOrder ; l5p:capName ?capName . } ORDER BY ?id ?capOrder') -%}
