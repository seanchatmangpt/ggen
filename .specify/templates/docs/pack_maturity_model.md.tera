{#- docs/packs/PACK_MATURITY_MODEL.md — full projection of .specify/maturity.ttl.
    Scored cells come from mat:ScoreRow individuals; every prose/rubric section is a
    mat:DocSection literal rendered verbatim (authored in the ontology, not here). -#}
{%- set S = sparql(query='PREFIX mat: <http://ggen.org/maturity#> SELECT ?sid ?text WHERE { ?x a mat:DocSection ; mat:sid ?sid ; mat:text ?text . } ORDER BY ?sid') -%}
{%- set intro = S | filter(attribute="sid", value="intro") | first -%}
{%- set spine = S | filter(attribute="sid", value="spine-and-matrices") | first -%}
{%- set scoring_intro = S | filter(attribute="sid", value="scoring-intro") | first -%}
{%- set narrative = S | filter(attribute="sid", value="codegen-narrative") | first -%}
{%- set tcps_intro = S | filter(attribute="sid", value="tcps-intro") | first -%}
{%- set tcps_artifacts = S | filter(attribute="sid", value="tcps-artifacts") | first -%}
{%- set gap = S | filter(attribute="sid", value="reading-gap") | first -%}
{%- set see_also = S | filter(attribute="sid", value="see-also") | first -%}
{%- set cg = sparql(query='PREFIX mat: <http://ggen.org/maturity#> SELECT ?o ?pack ?d1 ?d2 ?d3 ?d4 ?d5 ?d6 ?d7 WHERE { ?r a mat:ScoreRow ; mat:packType "codegen" ; mat:order ?o ; mat:pack ?pack ; mat:d1 ?d1 ; mat:d2 ?d2 ; mat:d3 ?d3 ; mat:d4 ?d4 ; mat:d5 ?d5 ; mat:d6 ?d6 ; mat:d7 ?d7 . } ORDER BY ?o') -%}
{%- set tc = sparql(query='PREFIX mat: <http://ggen.org/maturity#> SELECT ?o ?pack ?d1 ?d2 ?d3 ?d4 ?d5 ?d6 ?d7 WHERE { ?r a mat:ScoreRow ; mat:packType "tcps" ; mat:order ?o ; mat:pack ?pack ; mat:d1 ?d1 ; mat:d2 ?d2 ; mat:d3 ?d3 ; mat:d4 ?d4 ; mat:d5 ?d5 ; mat:d6 ?d6 ; mat:d7 ?d7 . } ORDER BY ?o') -%}
{%- set kh = sparql(query='PREFIX mat: <http://ggen.org/maturity#> SELECT ?o ?pack ?d1 ?d2 ?d3 ?d4 ?d5 ?d6 ?d7 WHERE { ?r a mat:ScoreRow ; mat:packType "hook" ; mat:order ?o ; mat:pack ?pack ; mat:d1 ?d1 ; mat:d2 ?d2 ; mat:d3 ?d3 ; mat:d4 ?d4 ; mat:d5 ?d5 ; mat:d6 ?d6 ; mat:d7 ?d7 . } ORDER BY ?o') -%}
{%- set cs = sparql(query='PREFIX mat: <http://ggen.org/maturity#> SELECT ?o ?pack ?d1 ?d2 ?d3 ?d4 ?d5 ?d6 ?d7 WHERE { ?r a mat:ScoreRow ; mat:packType "case" ; mat:order ?o ; mat:pack ?pack ; mat:d1 ?d1 ; mat:d2 ?d2 ; mat:d3 ?d3 ; mat:d4 ?d4 ; mat:d5 ?d5 ; mat:d6 ?d6 ; mat:d7 ?d7 . } ORDER BY ?o') -%}
