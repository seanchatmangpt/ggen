{#- .claude/rules/architecture.md — full projection of .specify/repo-facts.ttl.
    Crate tables come from rf:Crate individuals (rf:archPurpose carries the
    authored judgment prose per crate, verbatim); every prose section is an
    rf:ArchSection literal rendered verbatim; the pack inventory table comes
    from imported rf:Pack individuals. -#}
{%- set A = sparql(query='PREFIX rf: <http://ggen.org/repo-facts#> SELECT ?sid ?text WHERE { ?x a rf:ArchSection ; rf:sid ?sid ; rf:text ?text . } ORDER BY ?sid') -%}
{%- set s_intro = A | filter(attribute="sid", value="intro-and-codegen-core") | first -%}
{%- set s_praxis = A | filter(attribute="sid", value="two-schemas-and-praxis") | first -%}
{%- set s_testing = A | filter(attribute="sid", value="testing") | first -%}
{%- set s_agent = A | filter(attribute="sid", value="agent-lsp") | first -%}
{%- set s_genesis = A | filter(attribute="sid", value="genesis") | first -%}
{%- set s_mapping = A | filter(attribute="sid", value="mapping") | first -%}
{%- set s_removed = A | filter(attribute="sid", value="removed") | first -%}
{%- set s_tail = A | filter(attribute="sid", value="tail") | first -%}
{%- set cg = sparql(query='PREFIX rf: <http://ggen.org/repo-facts#> SELECT ?o ?dir ?p WHERE { ?c a rf:Crate ; rf:group "codegen-core" ; rf:order ?o ; rf:dir ?dir ; rf:archPurpose ?p . } ORDER BY ?o') -%}
{%- set pk = sparql(query='PREFIX rf: <http://ggen.org/repo-facts#> SELECT ?o ?dir ?p WHERE { ?c a rf:Crate ; rf:group "praxis-kernel" ; rf:order ?o ; rf:dir ?dir ; rf:archPurpose ?p . } ORDER BY ?o') -%}
{%- set ts = sparql(query='PREFIX rf: <http://ggen.org/repo-facts#> SELECT ?o ?dir ?p WHERE { ?c a rf:Crate ; rf:group "testing" ; rf:order ?o ; rf:dir ?dir ; rf:archPurpose ?p . } ORDER BY ?o') -%}
{%- set ag = sparql(query='PREFIX rf: <http://ggen.org/repo-facts#> SELECT ?o ?dir ?p WHERE { ?c a rf:Crate ; rf:group "agent-lsp" ; rf:order ?o ; rf:dir ?dir ; rf:archPurpose ?p . } ORDER BY ?o') -%}
{%- set gn = sparql(query='PREFIX rf: <http://ggen.org/repo-facts#> SELECT ?o ?dir ?p WHERE { ?c a rf:Crate ; rf:group "genesis" ; rf:order ?o ; rf:dir ?dir ; rf:archPurpose ?p . } ORDER BY ?o') -%}
{%- set mp = sparql(query='PREFIX rf: <http://ggen.org/repo-facts#> SELECT ?o ?dir ?p WHERE { ?c a rf:Crate ; rf:group "mapping" ; rf:order ?o ; rf:dir ?dir ; rf:archPurpose ?p . } ORDER BY ?o') -%}
{%- set packs = sparql(query='PREFIX rf: <http://ggen.org/repo-facts#> SELECT ?o ?dir ?v ?d WHERE { ?p a rf:Pack ; rf:order ?o ; rf:dir ?dir ; rf:version ?v ; rf:description ?d . } ORDER BY ?o') -%}
