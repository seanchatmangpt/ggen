rf:recipe_01 a rf:Recipe ;
    rf:order "001" ;
    rf:command "`just check`" ;
    rf:purpose "`timeout 300s cargo check --workspace`" ;
    rf:timeout "300s" .

rf:recipe_02 a rf:Recipe ;
    rf:order "002" ;
