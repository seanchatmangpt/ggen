@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ggen: <https://ggen.dev/ontology/> .
@prefix rev: <https://ggen.dev/ontology/review/> .
@prefix ex: <https://ggen.dev/ontology/example/> .

# ==============================================================================
# OWL Ontology: Code Review Rules for Prompt Manufacturing
# ==============================================================================

<https://ggen.dev/ontology/review>
    a owl:Ontology ;
    rdfs:label "Code Review Rules Ontology" ;
    rdfs:comment "Defines code review rules for deterministic AI code review prompt generation." ;
    owl:versionInfo "1.0.0" .

# ==============================================================================
# Classes
# ==============================================================================

rev:ReviewRule a owl:Class ;
    rdfs:label "Review Rule" ;
    rdfs:comment "A single code review rule with check pattern and suggestion." .

rev:RuleCategory a owl:Class ;
    rdfs:label "Rule Category" ;
    rdfs:comment "A category of review rules." .

rev:Severity a owl:Class ;
    rdfs:label "Severity" ;
    rdfs:comment "Severity level for a review rule." .

rev:ProjectRuleSet a owl:Class ;
    rdfs:label "Project Rule Set" ;
    rdfs:comment "A collection of review rules scoped to a project." .

rev:LanguageScope a owl:Class ;
    rdfs:label "Language Scope" ;
    rdfs:comment "A programming language that a rule applies to." .

rev:FilePattern a owl:Class ;
    rdfs:label "File Pattern" ;
    rdfs:comment "A glob pattern that a rule applies to." .

# ==============================================================================
# Object Properties
# ==============================================================================

rev:hasRule a owl:ObjectProperty ;
    rdfs:label "has rule" ;
    rdfs:domain rev:ProjectRuleSet ;
    rdfs:range rev:ReviewRule .

rev:hasCategory a owl:ObjectProperty ;
    rdfs:label "has category" ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range rev:RuleCategory .

rev:hasSeverity a owl:ObjectProperty ;
    rdfs:label "has severity" ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range rev:Severity .

rev:appliesToLanguage a owl:ObjectProperty ;
    rdfs:label "applies to language" ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range rev:LanguageScope .

rev:appliesToPattern a owl:ObjectProperty ;
    rdfs:label "applies to pattern" ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range rev:FilePattern .

# ==============================================================================
# Datatype Properties
# ==============================================================================

rev:ruleId a owl:DatatypeProperty ;
    rdfs:label "rule ID" ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:string .

rev:ruleDescription a owl:DatatypeProperty ;
    rdfs:label "rule description" ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:string .

rev:checkPattern a owl:DatatypeProperty ;
    rdfs:label "check pattern" ;
    rdfs:comment "A regex or SPARQL pattern to detect the violation." ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:string .

rev:checkType a owl:DatatypeProperty ;
    rdfs:label "check type" ;
    rdfs:comment "Type of check: regex, sparql, ast, or semantic." ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:string .

rev:suggestion a owl:DatatypeProperty ;
    rdfs:label "suggestion" ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:string .

rev:severityLevel a owl:DatatypeProperty ;
    rdfs:label "severity level" ;
    rdfs:domain rev:Severity ;
    rdfs:range xsd:integer .

rev:categoryName a owl:DatatypeProperty ;
    rdfs:label "category name" ;
    rdfs:domain rev:RuleCategory ;
    rdfs:range xsd:string .

rev:languageName a owl:DatatypeProperty ;
    rdfs:label "language name" ;
    rdfs:domain rev:LanguageScope ;
    rdfs:range xsd:string .

rev:patternGlob a owl:DatatypeProperty ;
    rdfs:label "pattern glob" ;
    rdfs:domain rev:FilePattern ;
    rdfs:range xsd:string .

rev:ruleSetName a owl:DatatypeProperty ;
    rdfs:label "rule set name" ;
    rdfs:domain rev:ProjectRuleSet ;
    rdfs:range xsd:string .

# ==============================================================================
# RDF 1.2 Triple-Term Annotation Properties
# ==============================================================================

rev:appliesToContext a owl:AnnotationProperty ;
    rdfs:label "applies to context" ;
    rdfs:comment "Code context where this rule fires (async, test, api_handler, module_boundary, unsafe_block)." .

rev:conflictsWithRule a owl:AnnotationProperty ;
    rdfs:label "conflicts with rule" ;
    rdfs:comment "Another rule that contradicts this one." .

rev:triggersMergeGate a owl:AnnotationProperty ;
    rdfs:label "triggers merge gate" ;
    rdfs:comment "Whether this rule violation blocks merge (true/false)." .

rev:rulePriority a owl:AnnotationProperty ;
    rdfs:label "rule priority" ;
    rdfs:comment "Numeric priority when multiple rules match (higher = more important)." .

rev:supersededByVersion a owl:AnnotationProperty ;
    rdfs:label "superseded by version" ;
    rdfs:comment "Ontology version that deprecated this rule." .

rev:autoFixable a owl:AnnotationProperty ;
    rdfs:label "auto fixable" ;
    rdfs:comment "Whether this rule can be auto-fixed (true/false)." .

rev:fixCommand a owl:AnnotationProperty ;
    rdfs:label "fix command" ;
    rdfs:comment "CLI command to auto-fix this rule violation." .

# ==============================================================================
# RDF 1.2 Datatype Properties (CONSTRUCT output)
# ==============================================================================

rev:contextName a owl:DatatypeProperty ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:string .

rev:conflictingRuleId a owl:DatatypeProperty ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:string .

rev:isMergeGate a owl:DatatypeProperty ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:boolean .

rev:priority a owl:DatatypeProperty ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:integer .

rev:isAutoFixable a owl:DatatypeProperty ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:boolean .

rev:autoFixCommand a owl:DatatypeProperty ;
    rdfs:domain rev:ReviewRule ;
    rdfs:range xsd:string .

# ==============================================================================
# Severity Instances
# ==============================================================================

rev:severity-critical a rev:Severity ;
    rev:severityLevel 4 ;
    rdfs:label "Critical" .

rev:severity-high a rev:Severity ;
    rev:severityLevel 3 ;
    rdfs:label "High" .

rev:severity-medium a rev:Severity ;
    rev:severityLevel 2 ;
    rdfs:label "Medium" .

rev:severity-low a rev:Severity ;
    rev:severityLevel 1 ;
    rdfs:label "Low" .

# ==============================================================================
# Category Instances
# ==============================================================================

rev:cat-safety a rev:RuleCategory ;
    rev:categoryName "safety" ;
    rdfs:comment "Rules that prevent security vulnerabilities, data corruption, or crashes." .

rev:cat-performance a rev:RuleCategory ;
    rev:categoryName "performance" ;
    rdfs:comment "Rules that prevent performance degradation, unbounded growth, or resource leaks." .

rev:cat-correctness a rev:RuleCategory ;
    rev:categoryName "correctness" ;
    rdfs:comment "Rules that prevent logic errors, silent failures, or hidden defects." .

rev:cat-style a rev:RuleCategory ;
    rev:categoryName "style" ;
    rdfs:comment "Rules that enforce consistent code formatting and naming conventions." .

rev:cat-documentation a rev:RuleCategory ;
    rev:categoryName "documentation" ;
    rdfs:comment "Rules that enforce documentation requirements." .

rev:cat-testing a rev:RuleCategory ;
    rev:categoryName "testing" ;
    rdfs:comment "Rules that enforce test coverage and TDD discipline." .

# ==============================================================================
# Language Scope Instances
# ==============================================================================

rev:lang-rust a rev:LanguageScope ;
    rev:languageName "Rust" .

rev:lang-go a rev:LanguageScope ;
    rev:languageName "Go" .

rev:lang-elixir a rev:LanguageScope ;
    rev:languageName "Elixir" .

rev:lang-typescript a rev:LanguageScope ;
    rev:languageName "TypeScript" .

rev:lang-all a rev:LanguageScope ;
    rev:languageName "all" .

# ==============================================================================
# File Pattern Instances
# ==============================================================================

rev:pat-rust a rev:FilePattern ;
    rev:patternGlob "**/*.rs" .

rev:pat-go a rev:FilePattern ;
    rev:patternGlob "**/*.go" .

rev:pat-elixir a rev:FilePattern ;
    rev:patternGlob "**/*.ex" .

rev:pat-elixir-test a rev:FilePattern ;
    rev:patternGlob "**/*_test.exs" .

rev:pat-typescript a rev:FilePattern ;
    rev:patternGlob "**/*.ts" .

rev:pat-all a rev:FilePattern ;
    rev:patternGlob "**/*" .

# ==============================================================================
# Project Rule Set: ChatmanGPT (from .claude/rules/)
# ==============================================================================

ex:chatmangpt-rules a rev:ProjectRuleSet ;
    rev:ruleSetName "ChatmanGPT" ;
    rev:hasRule ex:rule-no-unsafe-without-doc ;
    rev:hasRule ex:rule-no-bare-try-rescue ;
    rev:hasRule ex:rule-no-bare-try-catch ;
    rev:hasRule ex:rule-no-hardcoded-credentials ;
    rev:hasRule ex:rule-no-parameterized-queries ;
    rev:hasRule ex:rule-no-any-type-ts ;
    rev:hasRule ex:rule-all-blocking-has-timeout ;
    rev:hasRule ex:rule-all-loops-bounded ;
    rev:hasRule ex:rule-all-queues-bounded ;
    rev:hasRule ex:rule-test-first-tdd ;
    rev:hasRule ex:rule-no-skip-tags ;
    rev:hasRule ex:rule-commit-convention ;
    rev:hasRule ex:rule-never-rebase ;
    rev:hasRule ex:rule-no-global-mutable-state ;
    rev:hasRule ex:rule-no-unbounded-recursion ;
    rev:hasRule ex:rule-otel-span-required ;
    rev:hasRule ex:rule-weaver-schema-required ;
    rev:hasRule ex:rule-no-shared-memory ;
    rev:hasRule ex:rule-supervision-required ;
    rev:hasRule ex:rule-budget-constraints .

# --- Safety Rules ---

ex:rule-no-unsafe-without-doc a rev:ReviewRule ;
    rev:ruleId "SAF-001" ;
    rev:ruleDescription "No unsafe Rust blocks without explicit documentation comment explaining why safety is guaranteed." ;
    rev:checkPattern "unsafe\\s*\\{[^}]*\\}" ;
    rev:checkType "regex" ;
    rev:suggestion "Add a `// SAFETY:` comment above the unsafe block explaining why the invariants hold." ;
    rev:hasCategory rev:cat-safety ;
    rev:hasSeverity rev:severity-critical ;
    rev:appliesToLanguage rev:lang-rust ;
    rev:appliesToPattern rev:pat-rust .

<< ex:rule-no-unsafe-without-doc rev:ruleId "SAF-001" >> rev:appliesToContext "unsafe_block" ;
                                                                  rev:triggersMergeGate true ;
                                                                  rev:rulePriority 95 ;
                                                                  rev:autoFixable false .

ex:rule-no-bare-try-rescue a rev:ReviewRule ;
    rev:ruleId "SAF-002" ;
    rev:ruleDescription "No bare try/rescue blocks that swallow exceptions and continue with corrupt state (Armstrong violation)." ;
    rev:checkPattern "try\\s+do[\\s\\S]*?rescue" ;
    rev:checkType "regex" ;
    rev:suggestion "Let the process crash. Add a supervisor to restart it. Remove try/rescue from production code." ;
    rev:hasCategory rev:cat-safety ;
    rev:hasSeverity rev:severity-critical ;
    rev:appliesToLanguage rev:lang-elixir ;
    rev:appliesToPattern rev:pat-elixir .

<< ex:rule-no-bare-try-rescue rev:ruleId "SAF-002" >> rev:appliesToContext "module_boundary" ;
                                                              rev:triggersMergeGate true ;
                                                              rev:rulePriority 98 ;
                                                              rev:autoFixable false ;
                                                              rev:conflictsWithRule "COR-003" .

ex:rule-no-bare-try-catch a rev:ReviewRule ;
    rev:ruleId "SAF-003" ;
    rev:ruleDescription "No bare try/catch blocks in Go that recover from panics without escalation." ;
    rev:checkPattern "defer\\s+func\\(\\)\\s*\\{[\\s\\S]*?recover\\(\\)" ;
    rev:checkType "regex" ;
    rev:suggestion "Let the goroutine crash. Supervisor pattern: spawn a fresh goroutine instead of recovering." ;
    rev:hasCategory rev:cat-safety ;
    rev:hasSeverity rev:severity-critical ;
    rev:appliesToLanguage rev:lang-go ;
    rev:appliesToPattern rev:pat-go .

<< ex:rule-no-bare-try-catch rev:ruleId "SAF-003" >> rev:appliesToContext "async" ;
                                                             rev:triggersMergeGate true ;
                                                             rev:rulePriority 98 ;
                                                             rev:autoFixable false .

ex:rule-no-hardcoded-credentials a rev:ReviewRule ;
    rev:ruleId "SAF-004" ;
    rev:ruleDescription "No hardcoded credentials, API keys, or secrets in source code." ;
    rev:checkPattern "(password|secret|api_key|token|credentials?)\\s*[:=]\\s*[\"'][^\"']+[\"']" ;
    rev:checkType "regex" ;
    rev:suggestion "Move secrets to environment variables or a secrets manager. Use .env files (never committed)." ;
    rev:hasCategory rev:cat-safety ;
    rev:hasSeverity rev:severity-critical ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

<< ex:rule-no-hardcoded-credentials rev:ruleId "SAF-004" >> rev:appliesToContext "module_boundary" ;
                                                                      rev:triggersMergeGate true ;
                                                                      rev:rulePriority 100 ;
                                                                      rev:autoFixable false .

ex:rule-no-parameterized-queries a rev:ReviewRule ;
    rev:ruleId "SAF-005" ;
    rev:ruleDescription "No string interpolation in SQL queries. Use parameterized queries only." ;
    rev:checkPattern "(execute|query)\\s*\\([^)]*\\+\\s*|format!\\s*\\(.*SELECT|format!\\s*\\(.*INSERT" ;
    rev:checkType "regex" ;
    rev:suggestion "Use parameterized queries: `query($1, params)` instead of string concatenation." ;
    rev:hasCategory rev:cat-safety ;
    rev:hasSeverity rev:severity-critical ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

# --- Performance / Soundness Rules (WvdA) ---

ex:rule-all-blocking-has-timeout a rev:ReviewRule ;
    rev:ruleId "WVD-001" ;
    rev:ruleDescription "All blocking operations (await, receive, get, call) must have explicit timeout_ms (WvdA deadlock freedom)." ;
    rev:checkPattern "(GenServer\\.call\\s*\\([^,]+\\)\\s*\\)|<-\\s*ch\\s*$|\\.await\\s*;)" ;
    rev:checkType "regex" ;
    rev:suggestion "Add timeout: `GenServer.call(pid, msg, 5000)`, `select { case <-ch: ... case <-time.After(5s): ... }`." ;
    rev:hasCategory rev:cat-performance ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

<< ex:rule-all-blocking-has-timeout rev:ruleId "WVD-001" >> rev:appliesToContext "async" ;
                                                                     rev:triggersMergeGate true ;
                                                                     rev:rulePriority 90 ;
                                                                     rev:autoFixable false .

ex:rule-all-loops-bounded a rev:ReviewRule ;
    rev:ruleId "WVD-002" ;
    rev:ruleDescription "All loops must have bounded iteration or explicit exit condition (WvdA liveness)." ;
    rev:checkPattern "(for\\s+\\{\\s*\\}|while\\s+true\\s*\\{|loop\\s*\\{\\s*$)" ;
    rev:checkType "regex" ;
    rev:suggestion "Add escape condition: `for i in 0..MAX`, `while condition && attempt < MAX`, or `loop { if condition { break; } }`." ;
    rev:hasCategory rev:cat-performance ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

<< ex:rule-all-loops-bounded rev:ruleId "WVD-002" >> rev:appliesToContext "async" ;
                                                                 rev:triggersMergeGate true ;
                                                                 rev:rulePriority 88 ;
                                                                 rev:autoFixable false .

ex:rule-all-queues-bounded a rev:ReviewRule ;
    rev:ruleId "WVD-003" ;
    rev:ruleDescription "All queues and collections must have max_size or explicit eviction (WvdA boundedness)." ;
    rev:checkPattern "(Vec::new\\(\\)|VecDeque::new\\(\\)|:queue\\.new\\(\\)|LinkedList\\s)" ;
    rev:checkType "regex" ;
    rev:suggestion "Use bounded collections: `VecDeque::with_capacity(MAX)`, add size checks on push." ;
    rev:hasCategory rev:cat-performance ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

# --- Correctness Rules ---

ex:rule-no-any-type-ts a rev:ReviewRule ;
    rev:ruleId "COR-001" ;
    rev:ruleDescription "No `any` type in TypeScript. Use proper type annotations." ;
    rev:checkPattern ":\\s*any\\b" ;
    rev:checkType "regex" ;
    rev:suggestion "Replace `any` with the specific type: `Record<string, unknown>`, `unknown`, or the actual interface." ;
    rev:hasCategory rev:cat-correctness ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-typescript ;
    rev:appliesToPattern rev:pat-typescript .

ex:rule-no-global-mutable-state a rev:ReviewRule ;
    rev:ruleId "COR-002" ;
    rev:ruleDescription "No global mutable state. All inter-process communication via message passing (Armstrong)." ;
    rev:checkPattern "(var\\s+\\w+\\s+[a-zA-Z\\[\\]]+\\s*$|Agent\\.start_link.*:shared_state)" ;
    rev:checkType "regex" ;
    rev:suggestion "Move state into a process (GenServer, goroutine with channels) and communicate via messages." ;
    rev:hasCategory rev:cat-correctness ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

ex:rule-no-unbounded-recursion a rev:ReviewRule ;
    rev:ruleId "COR-003" ;
    rev:ruleDescription "All recursive functions must have a base case and max depth limit." ;
    rev:checkPattern "fn\\s+\\w+\\([^)]*\\)\\s*\\{[^}]*\\1\\s*\\(" ;
    rev:checkType "regex" ;
    rev:suggestion "Add a depth parameter with guard: `fn traverse(node, depth) where depth < 1000`. Add base case return." ;
    rev:hasCategory rev:cat-correctness ;
    rev:hasSeverity rev:severity-medium ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

<< ex:rule-no-unbounded-recursion rev:ruleId "COR-003" >> rev:appliesToContext "module_boundary" ;
                                                                    rev:triggersMergeGate false ;
                                                                    rev:rulePriority 70 ;
                                                                    rev:autoFixable false ;
                                                                    rev:conflictsWithRule "SAF-002" .

# --- Testing Rules (Chicago TDD) ---

ex:rule-test-first-tdd a rev:ReviewRule ;
    rev:ruleId "TDD-001" ;
    rev:ruleDescription "Every feature must have a failing test written before implementation (Chicago TDD Red phase)." ;
    rev:checkPattern "" ;
    rev:checkType "semantic" ;
    rev:suggestion "Write a failing test first. Test name must describe the claim. Then implement minimal code to pass." ;
    rev:hasCategory rev:cat-testing ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

<< ex:rule-test-first-tdd rev:ruleId "TDD-001" >> rev:appliesToContext "test" ;
                                                              rev:triggersMergeGate true ;
                                                              rev:rulePriority 85 ;
                                                              rev:autoFixable false .

ex:rule-no-skip-tags a rev:ReviewRule ;
    rev:ruleId "TDD-002" ;
    rev:ruleDescription "No @tag :skip or @moduletag :skip on production tests (hides defects)." ;
    rev:checkPattern "@(module)?tag\\s*:\\s*skip" ;
    rev:checkType "regex" ;
    rev:suggestion "Remove skip tag. If test needs OTP, use `@moduletag :integration` instead. Fix the root cause." ;
    rev:hasCategory rev:cat-testing ;
    rev:hasSeverity rev:severity-critical ;
    rev:appliesToLanguage rev:lang-elixir ;
    rev:appliesToPattern rev:pat-elixir-test .

<< ex:rule-no-skip-tags rev:ruleId "TDD-002" >> rev:appliesToContext "test" ;
                                                           rev:triggersMergeGate true ;
                                                           rev:rulePriority 97 ;
                                                           rev:autoFixable true ;
                                                           rev:fixCommand "sed -i '' '/@moduletag :skip/d' $FILE" .

ex:rule-otel-span-required a rev:ReviewRule ;
    rev:ruleId "VER-001" ;
    rev:ruleDescription "Every feature claim must have an OpenTelemetry span with service_name, span_name, and status." ;
    rev:checkPattern "" ;
    rev:checkType "semantic" ;
    rev:suggestion "Add OTEL span instrumentation. Span must have service, name, attributes, and status='ok'. Verify in Jaeger." ;
    rev:hasCategory rev:cat-testing ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

ex:rule-weaver-schema-required a rev:ReviewRule ;
    rev:ruleId "VER-002" ;
    rev:ruleDescription "Every OTEL span must have a schema entry in semconv/model/ and pass weaver registry check." ;
    rev:checkPattern "" ;
    rev:checkType "semantic" ;
    rev:suggestion "Add span definition to semconv/model/<domain>/spans.yaml. Run `weaver registry check` until exit=0." ;
    rev:hasCategory rev:cat-testing ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

# --- Style Rules ---

ex:rule-commit-convention a rev:ReviewRule ;
    rev:ruleId "STY-001" ;
    rev:ruleDescription "Commit messages must follow conventional commit format: type(scope): description." ;
    rev:checkPattern "^(feat|fix|docs|refactor|test|chore)\\(\\w+\\):" ;
    rev:checkType "regex" ;
    rev:suggestion "Use format: `type(scope): description`. Types: feat, fix, docs, refactor, test, chore." ;
    rev:hasCategory rev:cat-style ;
    rev:hasSeverity rev:severity-medium ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

<< ex:rule-commit-convention rev:ruleId "STY-001" >> rev:appliesToContext "module_boundary" ;
                                                                  rev:triggersMergeGate false ;
                                                                  rev:rulePriority 40 ;
                                                                  rev:autoFixable true ;
                                                                  rev:fixCommand "git commit --amend -m 'type(scope): description'" .

ex:rule-never-rebase a rev:ReviewRule ;
    rev:ruleId "STY-002" ;
    rev:ruleDescription "Never rebase. Only merge commits. Force-push to main/master is blocked." ;
    rev:checkPattern "" ;
    rev:checkType "semantic" ;
    rev:suggestion "Use `git merge` instead of `git rebase`. Never force-push to main or master." ;
    rev:hasCategory rev:cat-style ;
    rev:hasSeverity rev:severity-critical ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

# --- Armstrong Fault Tolerance Rules ---

ex:rule-no-shared-memory a rev:ReviewRule ;
    rev:ruleId "ARM-001" ;
    rev:ruleDescription "No shared mutable memory between processes. Use message passing only (Armstrong)." ;
    rev:checkPattern "(Arc<Mutex<|RwLock<|sync/atomic|unsafe\\s+\\{)" ;
    rev:checkType "regex" ;
    rev:suggestion "Replace shared memory with message passing: channels (Go), GenServer (Elixir), mpsc (Rust)." ;
    rev:hasCategory rev:cat-correctness ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

ex:rule-supervision-required a rev:ReviewRule ;
    rev:ruleId "ARM-002" ;
    rev:ruleDescription "Every worker process must have an explicit supervisor. No orphan processes." ;
    rev:checkPattern "(spawn\\(|Task::spawn|go\\s+func\\()" ;
    rev:checkType "regex" ;
    rev:suggestion "Spawn processes under a supervisor: `Task.Supervisor.start_child/1`, `Supervisor.start_link/1`." ;
    rev:hasCategory rev:cat-correctness ;
    rev:hasSeverity rev:severity-high ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .

<< ex:rule-supervision-required rev:ruleId "ARM-002" >> rev:appliesToContext "async" ;
                                                                   rev:triggersMergeGate true ;
                                                                   rev:rulePriority 92 ;
                                                                   rev:autoFixable false .

ex:rule-budget-constraints a rev:ReviewRule ;
    rev:ruleId "ARM-003" ;
    rev:ruleDescription "Every operation must have time/resource budget. No unbounded resource consumption." ;
    rev:checkPattern "" ;
    rev:checkType "semantic" ;
    rev:suggestion "Add timeout_ms to every operation. Define per-tier budgets: critical=100ms, high=500ms, normal=5s, low=30s." ;
    rev:hasCategory rev:cat-performance ;
    rev:hasSeverity rev:severity-medium ;
    rev:appliesToLanguage rev:lang-all ;
    rev:appliesToPattern rev:pat-all .
