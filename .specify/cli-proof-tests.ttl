# --- NEGATIVE: sync --locked without lockfile exits nonzero ---
proof:sync-locked-no-lockfile-exits-nonzero
  a proof:CliProofTest ;
  tdd:testCaseId "sync_locked_no_lockfile_exits_nonzero" ;
  tdd:assertionType "negative" ;
  proof:command "sync" ;
  proof:args "--locked" ;
  proof:fixture "minimal" ;
  proof:expectExitCode 1 ;
  tdd:confidence 0.9 ;
  tdd:coversAxiom "sync --locked without ggen.lock exits 1 (fail-closed)" .

# --- NEGATIVE: graph load nonexistent TTL exits nonzero ---
proof:graph-load-missing-file-exits-nonzero
