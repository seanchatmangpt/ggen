  tdd:testCaseId "graph_load_missing_file_exits_nonzero" ;
  tdd:assertionType "negative" ;
  proof:command "graph" ;
  proof:args "load nonexistent.ttl" ;
  proof:fixture "minimal" ;
  proof:expectExitCode 1 ;
  tdd:confidence 1.0 ;
  tdd:coversAxiom "graph load with nonexistent file exits 1" .

# --- BOUNDARY: sync --audit exits 0 on valid project ---
proof:sync-audit-valid-project-exits-zero
  a proof:CliProofTest ;
  tdd:testCaseId "sync_audit_valid_project_exits_zero" ;
  tdd:assertionType "boundary" ;
  proof:command "sync" ;
  proof:args "--audit true --dry-run true" ;
  proof:fixture "minimal" ;
  proof:expectExitCode 0 ;
  tdd:confidence 0.85 ;
  tdd:coversAxiom "sync --audit on valid project exits 0" .
