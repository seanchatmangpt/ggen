  "title": "Level Five Certification Bundle",
  "type": "object",
  "required": [
    "pack",
    "reference",
    "dimensions",
    "consumers",
    "receipts"
  ],
  "properties": {
    "pack": {
      "type": "string"
    },
    "reference": {
      "type": "object"
    },
    "dimensions": {
      "type": "array",
      "minItems": 7
    },
    "consumers": {
      "type": "array",
      "minItems": 2
    },
    "receipts": {
      "type": "array",
      "minItems": 1
    }
  }
}
