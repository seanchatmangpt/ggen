    book:sourcePath "listings/181-181-content-hashes.sh" ;
    book:sourceText """#!/usr/bin/env bash
set -euo pipefail

subject=\"181. Content Hashes\"
before=\"$(mktemp -d)\"
after=\"$(mktemp -d)\"

ggen sync run
cp -R src \"$before/\"
cargo test --all-targets
ggen sync run
cp -R src \"$after/\"

diff -ru \"$before/src\" \"$after/src\"
printf 'verified: %s\\n' \"$subject\"
""" .

