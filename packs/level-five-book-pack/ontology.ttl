  \"chapter\": 216,
  \"subject\": \"216. Build the Dimension-to-Acceptance Matrix\",
  \"version\": \"v26.7.19\",
  \"inputs\": {
    \"ontology_sha256\": \"<record-at-run-time>\",
    \"template_sha256\": \"<record-at-run-time>\"
  },
  \"checks\": [
    \"shape-admission\",
    \"sync\",
    \"compile\",
    \"test\",
    \"sync-twice\",
    \"manifest-diff\"
  ],
  \"outcome\": \"must-be-recorded-not-assumed\"
}
```

