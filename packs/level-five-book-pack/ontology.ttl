  \"schema\": \"https://example.org/ggen/receipt/v1\",
  \"chapter\": 148,
  \"subject\": \"148. Proof Receipts\",
  \"version\": \"v26.7.19\",
  \"inputs\": {
    \"ontology_sha256\": \"<record-at-run-time>\",
    \"template_sha256\": \"<record-at-run-time>\"
  },
  \"checks\": [
    \"shape-admission\",
    \"sync\",
    \"compile\",
    \"test\",
    \"sync-twice\",
    \"manifest-diff\"
  ],
  \"outcome\": \"must-be-recorded-not-assumed\"
}
```

