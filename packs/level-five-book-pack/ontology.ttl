    book:sourceText """[pack]
name = "chapter-259-259-generate-the-workspace-cargo-toml"
version = "26.7.19"
description = "259. Generate the Workspace `Cargo.toml`"

[law]
ontology = "ontology.ttl"
gates = ["gates/010_admission.rq"] # SPARQL admission gates; a legacy shapes.ttl now refuses with FM-PACK-012

[verification]
