    book:sourcePath "listings/293-293-record-cargo-test-all-targets.json" ;
    book:sourceText """{
  \"schema\": \"https://example.org/ggen/receipt/v1\",
  \"chapter\": 293,
  \"subject\": \"293. Record `cargo test --all-targets`\",
  \"version\": \"v26.7.19\",
  \"inputs\": {
