    book:sourcePath "listings/314-314-generate-the-proof-suite.sh" ;
    book:sourceText """#!/usr/bin/env bash
set -euo pipefail

subject=\"314. Generate the Proof Suite\"
before=\"$(mktemp -d)\"
after=\"$(mktemp -d)\"

ggen sync run
cp -R src \"$before/\"
cargo test --all-targets
ggen sync run
cp -R src \"$after/\"

diff -ru \"$before/src\" \"$after/src\"
printf 'verified: %s\\n' \"$subject\"
""" .

