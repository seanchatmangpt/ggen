  rows: |
    PREFIX pack: <https://example.org/ggen/pack#>
    SELECT ?name ?body WHERE {
      pack:章19 pack:name ?name ; pack:sourceText ?body .
    }
---
//! Generated for chapter 19: 19. Pack Templates
{% for row in rows %}
{{ row.body }}
{% endfor %}
""" .

