# fixtures/session-not-yet-overdue.ttl — NEGATIVE fire case (Fire precision):
# identical shape to session-escalated.ttl except only TWO further events
# follow the Blocked one (event-4, sequenceIndex 4; event-5, sequenceIndex 5;
# event-6, sequenceIndex 6). i1+3 = 7, and the highest sequenceIndex present
# is 6 < 7, so escalate_overdue_obligation's FILTER(?i3 >= ?i1 + 3) must NOT
# match any binding: the Obligation derived from event-4 must end up with NO
# dfl:escalatedBy triple at all. This is the adjacent-boundary case fire
# precision needs beyond a single adversarial fixture — proves the threshold
# is exact (>=7 fires, <=6 does not), not merely "eventually fires given
# enough later events". Verified by the scratch consumer test.

@prefix dfl:     <http://seanchatmangpt.github.io/packs/dogfood-lifecycle#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@base <http://seanchatmangpt.github.io/packs/dogfood-lifecycle/fixtures/session-not-yet-overdue#> .

<#operator>  a prov:Agent , prov:Person ; dcterms:description "Operator." .
<#mainAgent> a prov:Agent , prov:SoftwareAgent ; prov:actedOnBehalfOf <#operator> ; dcterms:description "Main agent." .

<#session>
    a                     dfl:Session ;
    dcterms:identifier    "not-yet-overdue-session-001" ;
    prov:wasAssociatedWith <#mainAgent> ;
    dcterms:description    "Boundary case: only 2 later events, one short of the escalation threshold." .

<urn:blake3:b2153b9c9a970f97be72df7d4ef039b1b2dcdc83a15c34b73d2e835b504e0bae>
    a prov:Entity ; dcterms:description "Bash input." .
<urn:blake3:61b3a3d4b48db9233fa8e0fe0743dd2f9aab0947107066a8502cbbbbdb774bc8>
    a prov:Entity ; dcterms:description "Bash output." .

<#event-4>
    a dfl:ToolEvent ; dcterms:isPartOf <#session> ; skos:notation "Bash" ;
    dfl:sequenceIndex 4 ; time:inXSDDateTimeStamp "2026-07-19T11:00:00Z"^^xsd:dateTimeStamp ;
    dfl:outcome dfl:Blocked ; prov:wasAssociatedWith <#mainAgent> ;
    prov:used <urn:blake3:b2153b9c9a970f97be72df7d4ef039b1b2dcdc83a15c34b73d2e835b504e0bae> ;
    prov:generated <urn:blake3:61b3a3d4b48db9233fa8e0fe0743dd2f9aab0947107066a8502cbbbbdb774bc8> ;
    dcterms:description "Blocked; derives the Obligation." .

<#event-5>
    a dfl:ToolEvent ; dcterms:isPartOf <#session> ; skos:notation "Bash" ;
    dfl:sequenceIndex 5 ; time:inXSDDateTimeStamp "2026-07-19T11:01:00Z"^^xsd:dateTimeStamp ;
    dfl:outcome dfl:Ok ; prov:wasAssociatedWith <#mainAgent> ;
    prov:used <urn:blake3:b2153b9c9a970f97be72df7d4ef039b1b2dcdc83a15c34b73d2e835b504e0bae> ;
    prov:generated <urn:blake3:61b3a3d4b48db9233fa8e0fe0743dd2f9aab0947107066a8502cbbbbdb774bc8> ;
    dcterms:description "Discharges the Obligation." .

<#event-6>
    a dfl:ToolEvent ; dcterms:isPartOf <#session> ; skos:notation "Read" ;
    dfl:sequenceIndex 6 ; time:inXSDDateTimeStamp "2026-07-19T11:02:00Z"^^xsd:dateTimeStamp ;
    dfl:outcome dfl:Error ; prov:wasAssociatedWith <#mainAgent> ;
    prov:used <urn:blake3:b2153b9c9a970f97be72df7d4ef039b1b2dcdc83a15c34b73d2e835b504e0bae> ;
    prov:generated <urn:blake3:61b3a3d4b48db9233fa8e0fe0743dd2f9aab0947107066a8502cbbbbdb774bc8> ;
    dcterms:description "Last event; sequenceIndex 6 < i1+3=7, so no escalation must fire. Deliberately dfl:Error (not Ok) to keep this fixture to exactly one discharging event -- see session-escalated.ttl's event-6 note on discharge_review_obligation_action's disclosed multi-fire precision gap." .
