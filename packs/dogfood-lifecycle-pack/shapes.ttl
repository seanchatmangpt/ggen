# shapes.ttl — SHACL shapes for a Claude Code session log produced under
# dogfood-lifecycle-pack/ontology.ttl. Authored now for the follow-up
# `ggen graph validate --files <session.ttl> --shapes shapes.ttl` layer.
#
# NOTE ON THE CURRENT VERIFIER: at v26.7.13 `ggen graph validate --files`
# performs Turtle PARSE validation, not SHACL constraint evaluation, so what
# is verified today is that this file PARSES as valid Turtle/SHACL. The
# constraints below are authored to bite once the SHACL layer lands.
#
# The tool-event shape (dfl:ToolEventShape) is what OperationDogfood targets:
# a tool-event node MUST carry a session ref, a tool name, a sequence index
# OR a timestamp, and an outcome from the closed vocabulary. A node missing
# any required property is a violation.
#
# Closed enumerations are expressed with sh:in (self-contained: it does not
# depend on the value node's rdf:type being co-loaded, so validating a
# session.ttl standalone still enforces membership). The dfl:outcome sh:in
# list and the skos:notation sh:in list MUST be kept in step with
# ontology.ttl's dfl:OutcomeScheme and dfl:ToolNameScheme respectively.

@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix dfl:     <http://seanchatmangpt.github.io/packs/dogfood-lifecycle#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix time:    <http://www.w3.org/2006/time#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# Every tool-event node must carry the four required attributes (session ref,
# tool name, ordering, outcome) plus its acting agent and its input/output
# entities. Any missing property is a violation.
dfl:ToolEventShape
    a sh:NodeShape ;
    sh:targetClass dfl:ToolEvent ;

    # session ref — the session this event belongs to (dcterms:isPartOf).
    sh:property [
        sh:path        dcterms:isPartOf ;
        sh:minCount    1 ;
        sh:class       dfl:Session ;
        sh:message     "A tool event must reference its session via dcterms:isPartOf." ;
    ] ;

    # tool name — the deterministic notation handle, closed to the known set.
    sh:property [
        sh:path        skos:notation ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:datatype    xsd:string ;
        sh:in          ( "Bash" "Edit" "Write" "Read" "Grep" "Glob" "Task" "WebFetch" "WebSearch" ) ;
        sh:message     "A tool event must carry exactly one skos:notation from the closed tool-name scheme." ;
    ] ;

    # ordering — at least one of a monotonic sequence index or a timestamp.
    sh:or (
        [ sh:path dfl:sequenceIndex ; sh:minCount 1 ]
        [ sh:path time:inXSDDateTimeStamp ; sh:minCount 1 ]
    ) ;

    # outcome — required, closed to {ok, error, blocked} by resource identity.
    sh:property [
        sh:path        dfl:outcome ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:in          ( dfl:Ok dfl:Error dfl:Blocked ) ;
        sh:message     "A tool event must carry exactly one dfl:outcome from {dfl:Ok, dfl:Error, dfl:Blocked}." ;
    ] ;

    # acting agent — the session agent or a subagent that ran the tool.
    sh:property [
        sh:path        prov:wasAssociatedWith ;
        sh:minCount    1 ;
        sh:message     "A tool event must be associated with the agent that ran it (prov:wasAssociatedWith)." ;
    ] ;

    # input / output — content-addressed entities the event used and generated.
    sh:property [
        sh:path        prov:used ;
        sh:minCount    1 ;
        sh:message     "A tool event must record its input entity (prov:used, a urn:blake3: handle)." ;
    ] ;
    sh:property [
        sh:path        prov:generated ;
        sh:minCount    1 ;
        sh:message     "A tool event must record its result entity (prov:generated, a urn:blake3: handle)." ;
    ] .

# Every session node must carry an identifier and its acting agent. Lightweight
# companion shape so a session missing its id is a violation too.
dfl:SessionShape
    a sh:NodeShape ;
    sh:targetClass dfl:Session ;
    sh:property [
        sh:path        dcterms:identifier ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:message     "A session must carry exactly one dcterms:identifier." ;
    ] ;
    sh:property [
        sh:path        prov:wasAssociatedWith ;
        sh:minCount    1 ;
        sh:message     "A session must be associated with its acting agent (prov:wasAssociatedWith)." ;
    ] .

# ── Obligation shape (v26.7.18 obligation-derivation extension) ────────────
# Every dfl:Obligation node -- whether hand-asserted in a fixture or
# CONSTRUCTed by hook.ttl's derive_review_obligation hook -- must carry its
# source event, target agent, severity, deadline, and status. A discharged
# obligation additionally carries dfl:dischargedBy (not required at the
# Open state, hence sh:minCount 0 on it here).
dfl:ObligationShape
    a sh:NodeShape ;
    sh:targetClass dfl:Obligation ;
    sh:property [
        sh:path        dfl:derivedFrom ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:class       dfl:ToolEvent ;
        sh:message     "An Obligation must record the ToolEvent it was derived from (dfl:derivedFrom)." ;
    ] ;
    sh:property [
        sh:path        dfl:obligationTarget ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:class       prov:Agent ;
        sh:message     "An Obligation must name the agent responsible for discharging it (dfl:obligationTarget)." ;
    ] ;
    sh:property [
        sh:path        dfl:severity ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:in          ( dfl:High dfl:Medium dfl:Low ) ;
        sh:message     "An Obligation must carry exactly one dfl:severity from {dfl:High, dfl:Medium, dfl:Low}." ;
    ] ;
    sh:property [
        sh:path        dfl:deadline ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:datatype    xsd:duration ;
        sh:message     "An Obligation must carry exactly one dfl:deadline (xsd:duration)." ;
    ] ;
    # dfl:obligationStatus is OPTIONAL (sh:minCount 0), not required: the
    # derive_review_obligation hook (hook.ttl) deliberately never asserts
    # dfl:Open (praxis-graphlaw's kh:effect "emit-delta" is append-only, so
    # asserting Open would make it permanently coexist with a later
    # dfl:Discharged rather than being superseded -- see hook.ttl's own
    # disclosure comment). An Obligation with NO obligationStatus triple at
    # all is the "open" state; discharge_review_obligation asserts
    # dfl:Discharged exactly once when it fires. Hand-authored fixtures MAY
    # still assert dfl:Open explicitly (the value remains valid), but the
    # hook itself does not.
    sh:property [
        sh:path        dfl:obligationStatus ;
        sh:minCount    0 ;
        sh:maxCount    1 ;
        sh:in          ( dfl:Open dfl:Discharged dfl:Refused ) ;
        sh:message     "If present, dfl:obligationStatus must be exactly one of {dfl:Open, dfl:Discharged, dfl:Refused}." ;
    ] ;
    sh:property [
        sh:path        dfl:dischargedBy ;
        sh:minCount    0 ;
        sh:maxCount    1 ;
        sh:class       dfl:ToolEvent ;
        sh:message     "If present, dfl:dischargedBy must name exactly one ToolEvent." ;
    ] ;
    # v26.7.19: escalatedBy (Obligation-lifecycle L3->L4's third hook, see
    # hook.ttl's escalate_overdue_obligation). Optional and independent of
    # dischargedBy/obligationStatus -- both may be present simultaneously
    # (escalated-then-discharged is truthful append-only history).
    sh:property [
        sh:path        dfl:escalatedBy ;
        sh:minCount    0 ;
        sh:maxCount    1 ;
        sh:class       dfl:ToolEvent ;
        sh:message     "If present, dfl:escalatedBy must name exactly one ToolEvent (the event whose sequenceIndex crossed the escalation threshold)." ;
    ] .
