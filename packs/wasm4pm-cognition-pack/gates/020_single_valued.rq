# MESSAGE: every compat:CognitionBreed property is single-valued (translated from shapes.ttl sh:maxCount 1; any row = a breed carrying two distinct values for ?p)
PREFIX compat: <https://wasm4pm.dev/ns#>
SELECT ?s ?p WHERE {
  ?s a compat:CognitionBreed .
  VALUES ?p {
    compat:breedId compat:breedLabel compat:breedDoc
    compat:citation compat:breedFamily compat:modulePath
  }
  ?s ?p ?v1 , ?v2 .
  FILTER(?v1 != ?v2)
}
ORDER BY ?s ?p
