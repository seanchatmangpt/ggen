@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix compat: <https://wasm4pm.dev/ns#> .

# Cognition breed catalog surface for the wasm4pm platform.
#
# Vocabulary reused from wasm4pm/packs/wasm4pm-breeds-rust/ggen/ontology/
# breed-vocabulary.ttl (self-contained compat:CognitionBreed class + predicates,
# purpose-built for pack redistribution). Instances carried over verbatim from
# wasm4pm/ggen/ontology/breeds.ttl (16 of 55 representative breeds spanning
# planning, reasoning, uncertainty, and classic-systems families).
#
# breedStatus is NEVER asserted here — it is CONSTRUCT-derived from evidence
# via the alive-gate in wasm4pm. This pack generates catalog/caller surfaces
# only; evidence, witnesses, and receipts belong to the compat family.

compat:CognitionBreed a rdfs:Class ;
  rdfs:comment "A registered cognition algorithm breed in the wasm4pm platform." .

compat:breedId    a rdf:Property ; rdfs:domain compat:CognitionBreed ; rdfs:range xsd:string .
compat:breedLabel a rdf:Property ; rdfs:domain compat:CognitionBreed ; rdfs:range xsd:string .
compat:breedDoc   a rdf:Property ; rdfs:domain compat:CognitionBreed ; rdfs:range xsd:string .
compat:citation   a rdf:Property ; rdfs:domain compat:CognitionBreed ; rdfs:range xsd:string .
compat:modulePath a rdf:Property ; rdfs:domain compat:CognitionBreed ; rdfs:range xsd:string .

# ---- Planning family ----

compat:Breed_strips a compat:CognitionBreed ;
  compat:breedId    "strips" ;
  compat:breedLabel "Strips" ;
  compat:breedDoc   "STRIPS-style precondition-based planner with iterative deepening goal-regression search (Fikes & Nilsson 1971)." ;
  compat:citation   "Fikes, R. E., & Nilsson, N. J. (1971). STRIPS: A new approach to the application of theorem proving to problem solving. Artificial Intelligence, 2(3–4), 189–208." .

compat:Breed_gps a compat:CognitionBreed ;
  compat:breedId    "gps" ;
  compat:breedLabel "Gps" ;
  compat:breedDoc   "GPS (General Problem Solver) — means-ends gap reduction (Newell & Shaw 1963)." ;
  compat:citation   "A. Newell and H. A. Simon, \"GPS, A Program That Simulates Human Thought,\" RAND Corporation, P-2257, March 30, 1961 (Revised April 10, 1961). Presented at the Conference on Learning Automata, Karlsruhe, Germany, April 11–14, 1961." .

compat:Breed_htn_planning a compat:CognitionBreed ;
  compat:breedId    "htn_planning" ;
  compat:breedLabel "HtnPlanning" ;
  compat:breedDoc   "HTN planning — SHOP2-style total-order decomposition (Nau et al." ;
  compat:citation   "Nau, D., Au, T.-C., Ilghami, O., Kuter, U., Murdock, J. W., Wu, D., & Yaman, F. (2003). SHOP2: An HTN Planning System. Journal of Artificial Intelligence Research, 20, 379-404." .

compat:Breed_partial_order_plan a compat:CognitionBreed ;
  compat:breedId    "partial_order_plan" ;
  compat:breedLabel "PartialOrderPlan" ;
  compat:breedDoc   "SNLP partial-order planning (McAllester & Rosenblitt, 'Systematic Nonlinear Planning', AAAI 1991)." ;
  compat:citation   "McAllester, D., & Rosenblitt, D. (1991). Systematic Nonlinear Planning. In: Proceedings of the Ninth National Conference on Artificial Intelligence (AAAI-91), pp. 634–639." .

