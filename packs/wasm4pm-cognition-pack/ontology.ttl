compat:Breed_bayesian_network a compat:CognitionBreed ;
  compat:breedId    "bayesian_network" ;
  compat:breedLabel "BayesianNetwork" ;
  compat:breedDoc   "Bayesian network inference — Pearl 1988." ;
  compat:citation   "Pearl, J. (1988). Probabilistic Reasoning in Intelligent Systems: Networks of Plausible Inference. Morgan Kaufmann." .

compat:Breed_dempster_shafer a compat:CognitionBreed ;
  compat:breedId    "dempster_shafer" ;
  compat:breedLabel "DempsterShafer" ;
  compat:breedDoc   "Dempster–Shafer theory of evidence — Shafer 1976." ;
