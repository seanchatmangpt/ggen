compat:Breed_prolog a compat:CognitionBreed ;
  compat:breedId    "prolog" ;
  compat:breedLabel "Prolog" ;
  compat:breedDoc   "Breed: Prolog — flat-term Robinson unification over positional ?N variables." ;
  compat:citation   "Kowalski, R. A. (1974). Predicate logic as programming language. IFIP Congress 74, Stockholm, pp. 569–574." .

compat:Breed_default_logic a compat:CognitionBreed ;
  compat:breedId    "default_logic" ;
  compat:breedLabel "DefaultLogic" ;
  compat:breedDoc   "Default logic — Reiter 1980 (normal defaults with justifications)." ;
  compat:citation   "Reiter, R. (1980). A Logic for Default Reasoning. Artificial Intelligence, 13(1-2), 81-132." .

compat:Breed_circumscription a compat:CognitionBreed ;
  compat:breedId    "circumscription" ;
  compat:breedLabel "Circumscription" ;
  compat:breedDoc   "Predicate circumscription via minimal-model enumeration (McCarthy 1980)." ;
  compat:citation   "McCarthy, J. (1980). Artificial Intelligence, 13(1-2), 27-39." .

compat:Breed_description_logic a compat:CognitionBreed ;
  compat:breedId    "description_logic" ;
  compat:breedLabel "DescriptionLogic" ;
  compat:breedDoc   "Description Logic: EL completion-rule classification (Baader, Brandt & Lutz, 'Pushing the EL Envelope', IJCAI 2005)." ;
  compat:citation   "Baader, F., Brandt, S., & Lutz, C. (2005). Pushing the EL Envelope. In: Proceedings of the 19th International Joint Conference on Artificial Intelligence (IJCAI 2005), pp. 364–369." .

