---
to: src/w4pm_cognition_catalog.rs
sparql:
  breeds: |
    PREFIX compat: <https://wasm4pm.dev/ns#>
    SELECT ?breed_id ?breed_label ?breed_doc ?citation WHERE {
      ?b a compat:CognitionBreed ;
         compat:breedId ?breed_id ;
         compat:breedLabel ?breed_label ;
         compat:breedDoc ?breed_doc ;
         compat:citation ?citation .
    } ORDER BY ?breed_id
---
//! wasm4pm cognition breed catalog (generated by `wasm4pm-cognition-pack`).
//!
//! First-class source rendered from `compat:CognitionBreed` individuals in
//! the pack ontology. To change a breed, edit the pack ontology and re-run
//! `ggen sync`. Catalog surface only: breed status/standing is derived from
//! evidence inside wasm4pm and is never asserted here.

/// Stable identifier for every cognition breed in this catalog.
#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord, Hash)]
pub enum CognitionBreedId {
{% for row in breeds %}    /// `{{ row.breed_id }}`
    {{ row.breed_label }},
{% endfor %}}

/// Static metadata for one cognition breed.
pub struct CognitionBreedInfo {
    pub id: CognitionBreedId,
    pub label: &'static str,
    pub citation: &'static str,
}

/// Every catalogued cognition breed, in stable (id-sorted) order.
pub const BREED_CATALOG: &[CognitionBreedInfo] = &[
{% for row in breeds %}    CognitionBreedInfo {
        id: CognitionBreedId::{{ row.breed_label }},
        label: "{{ row.breed_label }}",
        citation: "{{ row.citation | addslashes }}",
    },
{% endfor %}];

impl CognitionBreedId {
    /// The wire-level breed id string passed to `cognition_run`.
    pub fn as_str(self) -> &'static str {
        match self {
{% for row in breeds %}            Self::{{ row.breed_label }} => "{{ row.breed_id }}",
{% endfor %}        }
    }
}

/// Parse a wire-level breed id string into its `CognitionBreedId` variant.
pub fn from_breed_id(s: &str) -> Option<CognitionBreedId> {
    match s {
{% for row in breeds %}        "{{ row.breed_id }}" => Some(CognitionBreedId::{{ row.breed_label }}),
{% endfor %}        _ => None,
    }
}
