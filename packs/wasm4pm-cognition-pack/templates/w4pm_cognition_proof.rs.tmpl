#[test]
fn dispatch_cognition_run_fails_closed_for_strips() {
    let err =
        dispatch_cognition_run("strips", "{}").expect_err("must fail closed, no runtime wired yet");
    assert!(err.contains("strips"), "error must name the breed id, got: {err}");
    assert!(
        err.contains("not wired to a wasm4pm runtime yet"),
        "error must state the fails-closed reason, got: {err}"
    );
}

#[test]
fn run_strips_and_run_mycin_do_not_cross_contaminate_breed_ids() {
    // Regression guard against a real bug class: a Tera for-loop variable
    // misalignment that would silently wire `run_X` to a sibling row's
    // breed_id. Checking cross-row independence is not something a broken
    // per-row rendering could accidentally satisfy by reusing the same
    // wrong value twice.
    let strips_err = run_strips("{}").expect_err("run_strips must fail closed");
    let mycin_err = run_mycin("{}").expect_err("run_mycin must fail closed");

    assert!(strips_err.contains("strips"), "got: {strips_err}");
    assert!(
        !strips_err.contains("mycin"),
        "run_strips output must not mention mycin, got: {strips_err}"
    );

    assert!(mycin_err.contains("mycin"), "got: {mycin_err}");
    assert!(
        !mycin_err.contains("strips"),
        "run_mycin output must not mention strips, got: {mycin_err}"
    );
}
