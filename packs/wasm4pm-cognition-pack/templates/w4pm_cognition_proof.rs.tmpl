//! Proof tests for `wasm4pm-cognition-pack`'s generated catalog and
//! dispatch surfaces (`src/w4pm_cognition_catalog.rs`,
//! `src/w4pm_cognition_dispatch.rs`), asserted against literal values
//! hand-transcribed from `packs/wasm4pm-cognition-pack/ontology.ttl`.
//!
//! Fully static template: no `sparql:` frontmatter, no Tera substitution.
//! Every expected value below is a literal the author copied from the
//! ontology, never a value recomputed via the same SPARQL query path that
//! produced `BREED_CATALOG`/`CognitionBreedId` -- so a broken `ORDER BY`, a
//! dropped row, or a Tera for-loop variable misalignment (wiring `run_X` to
//! the wrong breed id) fails these tests even though it would not fail a
//! tautological self-comparison.
//!
//! Generated by `wasm4pm-cognition-pack`.

#[path = "../src/w4pm_cognition_catalog.rs"]
mod w4pm_cognition_catalog;
#[path = "../src/w4pm_cognition_dispatch_handler.rs"]
mod w4pm_cognition_dispatch_handler;
#[path = "../src/w4pm_cognition_dispatch.rs"]
mod w4pm_cognition_dispatch;

use w4pm_cognition_catalog::{from_breed_id, CognitionBreedId, BREED_CATALOG};
use w4pm_cognition_dispatch::{dispatch_cognition_run, run_mycin, run_strips};

#[test]
fn breed_catalog_has_fifty_five_entries() {
    assert_eq!(BREED_CATALOG.len(), 55);
}

#[test]
fn breed_strips_matches_ontology() {
    let entry = BREED_CATALOG
        .iter()
        .find(|b| b.id == CognitionBreedId::Strips)
        .expect("Strips must be in BREED_CATALOG");
    assert_eq!(entry.label, "Strips");
    assert_eq!(
        entry.citation,
        "Fikes, R. E., & Nilsson, N. J. (1971). STRIPS: A new approach to the application of theorem proving to problem solving. Artificial Intelligence, 2(3–4), 189–208."
    );
    assert_eq!(CognitionBreedId::Strips.as_str(), "strips");
    assert_eq!(from_breed_id("strips"), Some(CognitionBreedId::Strips));
}

