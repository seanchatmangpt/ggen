{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tcps:schema:build-receipt.schema.json",
  "title": "TCPS Build Receipt",
  "type": "object",
  "required": [
    "schema",
    "step",
    "recorded_at",
    "source_digest",
    "status"
  ],
  "properties": {
    "schema": {
      "type": "string"
    },
    "step": {
      "type": "string"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "status": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "product": {
      "type": "string"
    },
    "tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    }
  },
  "additionalProperties": true
}
