#################################################################
# PackagingTarget individuals
#################################################################

tcps:DebPackagingTarget a tcps:PackagingTarget ;
    rdfs:label "Debian package manifest (control file)" ;
    tcps:ecosystem "deb" ;
    tcps:manifestPath "packaging/deb/control.in" ;
    tcps:manifestBody """Package: tcps
Version: 26.7.19
Section: devel
Priority: optional
Architecture: @ARCH@
Maintainer: Sean Chatman
Description: Toyota Code Production System Rust library and CLI
 Japanese canonical domain model with Rust production lifecycle tooling.
""" .

tcps:NpmPackagingTarget a tcps:PackagingTarget ;
    rdfs:label "npm package manifest (package.json)" ;
    tcps:ecosystem "npm" ;
    tcps:manifestPath "packaging/npm/package.json.in" ;
    tcps:manifestBody """{
  "name": "@tcps/core",
  "version": "26.7.19",
  "description": "Toyota Code Production System WebAssembly capability boundary",
  "license": "MIT OR Apache-2.0",
  "files": ["tcps_wasm.wasm", "README.md"]
}
""" .

tcps:NugetPackagingTarget a tcps:PackagingTarget ;
    rdfs:label "NuGet package manifest (nuspec)" ;
    tcps:ecosystem "nuget" ;
    tcps:manifestPath "packaging/nuget/tcps.nuspec.in" ;
    tcps:manifestBody """<?xml version="1.0"?>
<package>
  <metadata>
    <id>TCPS.Native</id>
    <version>26.7.19</version>
    <authors>Sean Chatman</authors>
    <description>Toyota Code Production System native Rust library.</description>
    <license type="expression">MIT OR Apache-2.0</license>
  </metadata>
</package>
""" .

#################################################################
# CiWorkflow individuals
#################################################################

tcps:Tier1Workflow a tcps:CiWorkflow ;
    rdfs:label "tier-1 build matrix workflow" ;
    tcps:workflowName "tier-1" ;
    tcps:triggerEvent "push" ;
    tcps:triggerEvent "pull_request" ;
    tcps:triggerEvent "workflow_dispatch" ;
    tcps:workflowBody """name: tier-1

on:
  push:
    branches: [main]
  pull_request:
  workflow_dispatch:

permissions:
  contents: read

jobs:
  build:
    strategy:
      fail-fast: false
      matrix:
        include:
          - os: ubuntu-24.04
            target: x86_64-unknown-linux-gnu
          - os: ubuntu-24.04
            target: i686-unknown-linux-gnu
          - os: ubuntu-24.04
            target: aarch64-unknown-linux-gnu
          - os: macos-14
            target: aarch64-apple-darwin
          - os: windows-2022
            target: x86_64-pc-windows-msvc
          - os: windows-2022
            target: i686-pc-windows-msvc
          - os: windows-2022
            target: aarch64-pc-windows-msvc
          - os: windows-2022
            target: x86_64-pc-windows-gnu
    runs-on: ${{ matrix.os }}
    steps:
      - uses: actions/checkout@v4
      - name: Install pinned Rust
        shell: bash
        run: |
          rustup toolchain install 1.97.1 --profile minimal --component rust-src
          rustup default 1.97.1
      - name: Build universal core
        run: python tools/lifecycle.py build --target ${{ matrix.target }} --product core
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: tier1-${{ matrix.target }}
          path: receipts/
""" .

tcps:VerifyWorkflow a tcps:CiWorkflow ;
    rdfs:label "cross-host verify workflow" ;
    tcps:workflowName "verify" ;
    tcps:triggerEvent "push" ;
    tcps:triggerEvent "pull_request" ;
    tcps:triggerEvent "workflow_dispatch" ;
    tcps:workflowBody """name: verify

on:
  push:
  pull_request:
  workflow_dispatch:

permissions:
  contents: read

jobs:
  host-verification:
    name: host-${{ matrix.os }}
    strategy:
      fail-fast: false
      matrix:
        os: [ubuntu-24.04, macos-14, windows-2022]
    runs-on: ${{ matrix.os }}
    steps:
      - uses: actions/checkout@v4
      - name: Install pinned Rust
        shell: bash
        run: |
          rustup toolchain install 1.97.1 --profile minimal --component rustfmt --component clippy --component rust-src
          rustup default 1.97.1
      - name: Verify full workspace
        run: python tools/lifecycle.py verify
      - name: Generate target matrix
        run: python tools/lifecycle.py matrix
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: receipts-${{ matrix.os }}
          path: |
            receipts/
            dist/target-matrix.json
""" .

tcps:SecurityWorkflow a tcps:CiWorkflow ;
    rdfs:label "supply-chain security policy workflow" ;
    tcps:workflowName "security" ;
    tcps:triggerEvent "pull_request" ;
    tcps:triggerEvent "push" ;
    tcps:triggerEvent "schedule" ;
    tcps:triggerEvent "workflow_dispatch" ;
    tcps:workflowBody """name: security

on:
  pull_request:
  push:
    branches: [main]
  schedule:
    - cron: "43 3 * * 4"
  workflow_dispatch:

permissions:
  contents: read

jobs:
  supply-chain-policy:
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@v4
      - name: Install pinned Rust
        run: |
          rustup toolchain install 1.97.1 --profile minimal --component rust-src
          rustup default 1.97.1
      - name: Install quality tools
        run: ./scripts/ci/install-quality-tools.sh
      - name: Audit
        run: cargo audit
      - name: Dependency and license policy
        run: cargo deny check
      - name: Coverage
        run: cargo llvm-cov --workspace --all-targets --lcov --output-path dist/lcov.info
      - uses: actions/upload-artifact@v4
        with:
          name: security-evidence
          path: |
            dist/lcov.info
            receipts/
""" .
