tcps:RustToolchainTomlArtifact a tcps:ReleaseArtifact ;
    rdfs:label "rustup toolchain pin" ;
    tcps:artifactPath "rust-toolchain.toml" ;
    tcps:artifactBody """[toolchain]
channel = "1.97.1"
profile = "minimal"
components = ["rustfmt", "clippy", "rust-src"]
""" .

tcps:AbiSmokeCArtifact a tcps:ReleaseArtifact ;
    rdfs:label "C ABI smoke test" ;
    tcps:artifactPath "tests/c/abi_smoke.c" ;
    tcps:artifactBody """#include <stdint.h>
#include <stdio.h>
#include "tcps.h"

int main(void) {
    if (tcps_version_v1() != 0x1A0713u) {
        fputs("version mismatch\\n", stderr);
        return 1;
    }
    const tcps_request_v1 request = {
        .authority_mask = 1,
        .ready_mask = 3,
        .maximum_time = 999,
        .deterministic_required = 1,
        .receipt_required = 1,
        .reserved = {0, 0},
        .timestamp = 1000,
    };
    const tcps_outcome_v1 outcome = tcps_select_v1(request);
    if (outcome.kind != 1 || outcome.tool != 1 || outcome.eligible_mask != 3 || outcome.ready_mask != 3) {
        fprintf(stderr, "unexpected outcome kind=%u tool=%u eligible=%llu ready=%llu\\n",
            (unsigned)outcome.kind,
            (unsigned)outcome.tool,
            (unsigned long long)outcome.eligible_mask,
            (unsigned long long)outcome.ready_mask);
        return 2;
    }
    puts("c-abi-smoke: accepted");
    return 0;
}
""" .

tcps:WasmSmokeMjsArtifact a tcps:ReleaseArtifact ;
    rdfs:label "WebAssembly smoke test" ;
    tcps:artifactPath "tests/wasm/smoke.mjs" ;
    tcps:artifactBody """import { readFile } from "node:fs/promises";

const path = process.argv[2];
if (!path) throw new Error("wasm path is required");
const bytes = await readFile(path);
const { instance } = await WebAssembly.instantiate(bytes, {});
const version = instance.exports.tcps_wasm_version_v1();
if (version !== 0x1A0713) throw new Error(`version mismatch: ${version}`);
const outcome = instance.exports.tcps_wasm_select_canonical_v1(1n, 3n, 999, 1000n);
const selected = (outcome >> 63n) & 1n;
const tool = (outcome >> 48n) & 0x7fffn;
if (selected !== 1n || tool !== 1n) throw new Error(`unexpected outcome: ${outcome}`);
console.log("wasm-smoke: accepted");
""" .


#################################################################
# New class (this fragment)
#################################################################

tcps:ReleaseArtifact a rdfs:Class ;
    rdfs:label "A miscellaneous verbatim release-engineering artifact (packaging, target metadata, JSON schema)" .

#################################################################
# PackagingTarget individuals (new, this fragment)
#################################################################

tcps:RpmPackagingTarget a tcps:PackagingTarget ;
    rdfs:label "rpm spec template" ;
    tcps:ecosystem "rpm" ;
    tcps:manifestPath "packaging/rpm/tcps.spec.in" ;
    tcps:manifestBody """Name: tcps
Version: 26.7.19
Release: 1%{?dist}
Summary: Toyota Code Production System Rust library
License: MIT OR Apache-2.0
BuildArch: @ARCH@

%description
Japanese canonical Toyota Code Production System domain model in Rust.

%files
/usr/bin/tcps
/usr/include/tcps.h
""" .

tcps:AndroidManifestTarget a tcps:ReleaseArtifact ;
    rdfs:label "Android manifest" ;
    tcps:artifactPath "packaging/android/AndroidManifest.xml" ;
    tcps:artifactBody """<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-sdk android:minSdkVersion="24" />
</manifest>
""" .

tcps:AppleModulemapTarget a tcps:ReleaseArtifact ;
    rdfs:label "Apple modulemap" ;
    tcps:artifactPath "packaging/apple/module.modulemap" ;
    tcps:artifactBody """module TCPS {
    header "tcps.h"
    export *
}
""" .

