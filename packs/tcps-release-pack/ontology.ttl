@prefix tcps: <http://seanchatmangpt.github.io/packs/tcps-release#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Classes
#################################################################

tcps:Tier a rdfs:Class ;
    rdfs:label "Release tier (rustup target-tier grouping)" .

tcps:PackagingTarget a rdfs:Class ;
    rdfs:label "A packaging ecosystem output (deb/npm/nuget) driven from a manifest template" .

tcps:CiWorkflow a rdfs:Class ;
    rdfs:label "A GitHub Actions CI workflow definition" .

#################################################################
# Tier individuals
#################################################################

tcps:Tier1 a tcps:Tier ;
    rdfs:label "Tier 1 (guaranteed to build and pass tests)" ;
    tcps:tierName "tier1" ;
    tcps:targetList """aarch64-apple-darwin
aarch64-pc-windows-msvc
aarch64-unknown-linux-gnu
i686-pc-windows-msvc
i686-unknown-linux-gnu
x86_64-pc-windows-gnu
x86_64-pc-windows-msvc
x86_64-unknown-linux-gnu
""" .

