""" .

tcps:DenyTomlArtifact a tcps:ReleaseArtifact ;
    rdfs:label "cargo-deny supply-chain policy" ;
    tcps:artifactPath "deny.toml" ;
    tcps:artifactBody """[graph]
all-features = true

[advisories]
version = 2
yanked = "deny"

[licenses]
version = 2
allow = ["MIT", "Apache-2.0", "Unicode-3.0"]
confidence-threshold = 0.9

[bans]
