wildcards = "deny"

[sources]
unknown-registry = "deny"
unknown-git = "deny"
allow-registry = ["https://github.com/rust-lang/crates.io-index"]
""" .

tcps:ReleaseJsonArtifact a tcps:ReleaseArtifact ;
    rdfs:label "release line and product family manifest" ;
    tcps:artifactPath "release.json" ;
    tcps:artifactBody """{
  "release": "v26.7.19",
  "flavor": "production.2",
  "rust": "1.97.1",
