@prefix tcps: <http://seanchatmangpt.github.io/packs/tcps-release#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

tcps:PackagingTargetShape a sh:NodeShape ;
    sh:targetClass tcps:PackagingTarget ;
    sh:property [
        sh:path tcps:manifestPath ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "Every tcps:PackagingTarget must have a non-empty tcps:manifestPath." ;
    ] .

tcps:CiWorkflowShape a sh:NodeShape ;
    sh:targetClass tcps:CiWorkflow ;
    sh:property [
        sh:path tcps:triggerEvent ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "Every tcps:CiWorkflow must have at least one non-empty tcps:triggerEvent." ;
    ] .

tcps:CiPlatformConfigShape a sh:NodeShape ;
    sh:targetClass tcps:CiPlatformConfig ;
    sh:property [
        sh:path tcps:workflowBody ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "Every tcps:CiPlatformConfig must have a non-empty tcps:workflowBody." ;
    ] .

tcps:ReleaseArtifactShape a sh:NodeShape ;
    sh:targetClass tcps:ReleaseArtifact ;
    sh:property [
        sh:path tcps:artifactBody ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "Every tcps:ReleaseArtifact must have a non-empty tcps:artifactBody." ;
    ] .

tcps:TierShape a sh:NodeShape ;
    sh:targetClass tcps:Tier ;
    sh:property [
        sh:path tcps:targetList ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message "Every tcps:Tier must have a non-empty tcps:targetList." ;
    ] .
