@prefix tcps_ffi: <http://seanchatmangpt.github.io/packs/tcps-ffi#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

tcps_ffi:LibModuleShape
    a sh:NodeShape ;
    sh:targetClass tcps_ffi:LibModule ;
    rdfs:comment "Every tcps_ffi:LibModule individual must carry non-empty verbatim Rust source text -- refuses empty/placeholder generation sources." ;
    sh:property [
        sh:path tcps_ffi:sourceText ;
        sh:minCount 1 ;
        sh:minLength 1 ;
        sh:message "tcps_ffi:LibModule must have a non-empty tcps_ffi:sourceText (verbatim source, not a placeholder)." ;
    ] .

tcps_ffi:HeaderFileShape
    a sh:NodeShape ;
    sh:targetClass tcps_ffi:HeaderFile ;
    rdfs:comment "Every tcps_ffi:HeaderFile individual must carry non-empty verbatim C header source text." ;
    sh:property [
        sh:path tcps_ffi:sourceText ;
        sh:minCount 1 ;
        sh:minLength 1 ;
        sh:message "tcps_ffi:HeaderFile must have a non-empty tcps_ffi:sourceText (verbatim source, not a placeholder)." ;
    ] .

tcps_ffi:CargoManifestShape
    a sh:NodeShape ;
    sh:targetClass tcps_ffi:CargoManifest ;
    rdfs:comment "Every tcps_ffi:CargoManifest individual must carry non-empty verbatim Cargo.toml source text." ;
    sh:property [
        sh:path tcps_ffi:sourceText ;
        sh:minCount 1 ;
        sh:minLength 1 ;
        sh:message "tcps_ffi:CargoManifest must have a non-empty tcps_ffi:sourceText (verbatim source, not a placeholder)." ;
    ] .

tcps_ffi:DependsOnModuleShape
    a sh:NodeShape ;
    sh:targetSubjectsOf tcps_ffi:dependsOnModule ;
    rdfs:comment "Every tcps_ffi:dependsOnModule reference must resolve to a declared individual carrying a tcps_ffi:name -- refuses dangling references." ;
    sh:property [
        sh:path tcps_ffi:dependsOnModule ;
        sh:node tcps_ffi:ReferencedIndividualShape ;
        sh:message "tcps_ffi:dependsOnModule must point at a declared individual (no dangling reference)." ;
    ] .

tcps_ffi:ReferencedIndividualShape
    a sh:NodeShape ;
    sh:property [
        sh:path tcps_ffi:name ;
        sh:minCount 1 ;
        sh:message "Referenced individual must have a tcps_ffi:name (i.e. must actually be declared in the graph, not merely typed)." ;
    ] .
