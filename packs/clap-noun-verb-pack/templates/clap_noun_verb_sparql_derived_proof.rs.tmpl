/// (noun:verb key, the exact `Ok(<static response>)` text the production
/// template inlines as that command's whole body) for every live
/// `cnv:staticResponse` fact. Kept as raw string literals (`r#"..."#`)
/// rather than a `LiveCommand` field: the response text is arbitrary Rust
/// source (typically a `json!({...})` call) carrying literal `"`
/// characters that would need escaping to live inside a normal `&str`
/// literal built by this same Tera render -- a raw string sidesteps that
/// without reformatting the value, so the comparison stays byte-exact
/// against what `clap_noun_verb_routes.rs.tmpl` itself renders. This is
/// safe for every value currently in `ontology.ttl` (none contain the
/// `"#` sequence); a future value that did would need a longer raw-string
/// delimiter (`r##"..."##`).
const LIVE_STATIC_RESPONSES: &[(&str, &str)] = &[
{%- for cmd in commands %}
{%- if cmd.static_response %}
    ("{{ cmd.noun }}:{{ cmd.verb }}", r#"Ok({{ cmd.static_response }})"#),
{%- endif %}
{%- endfor %}
];

/// `routes.rs`'s own embedded Tier 2 proof (`routes_only()`) slices off the
/// `#[cfg(test)]` module before counting `#[verb(`/`register_noun(`
/// occurrences, because the test module's own source text (assertion
/// arguments, doc comments) contains those exact substrings too. This proof
/// reads the SAME file from the OUTSIDE (a separate `tests/*.rs` crate), so
/// it needs the identical slice for the identical reason.
fn routes_only() -> &'static str {
    ROUTES
        .split("#[cfg(test)]")
        .next()
        .expect("ROUTES is a non-empty &str; split always yields >=1 part")
}

fn assert_command_in_routes(cmd: &LiveCommand) {
    assert!(
        ROUTES.contains(&format!("/// {}", cmd.doc)),
        "live ontology has command `{} {}` with doc {:?} but generated \
         src/clap_noun_verb_routes.rs does not contain that doc comment -- \
         generated routes have drifted behind ontology.ttl",
        cmd.noun, cmd.verb, cmd.doc
    );
    assert!(
        ROUTES.contains(&format!("#[verb(\"{}\", \"{}\")]", cmd.verb, cmd.noun)),
        "live ontology has command `{} {}` but generated src/clap_noun_verb_routes.rs \
         does not contain #[verb(\"{}\", \"{}\")] -- drift detected",
        cmd.noun, cmd.verb, cmd.verb, cmd.noun
    );
    assert!(
        ROUTES.contains(&format!("fn {}(", cmd.fn_name)),
        "live ontology's `{} {}` should generate wrapper fn `{}` but generated \
         src/clap_noun_verb_routes.rs does not declare `fn {}(` -- drift detected",
        cmd.noun, cmd.verb, cmd.fn_name, cmd.fn_name
    );
    // Built via concatenation, not a format! string carrying two adjacent
    // open-brace characters for Rust's own escaping: this whole template
    // file is itself parsed by Tera before it becomes Rust source, and
    // Tera treats two adjacent open-brace characters in the template text
    // as the start of its own variable-substitution syntax -- so writing
    // that Rust-level escape sequence literally would break Tera's parse
    // of THIS template, not just look ugly (the exact failure mode a
    // sibling pack's proof template hit and fixed the same way -- see
    // maturity.ttl's "Real bugs this verification pass surfaced", item 3).
    // Concatenating a separate single-open-brace string sidesteps that (a
    // lone open brace not immediately followed by another open brace, a
    // percent, or a hash is plain text to Tera, exactly like the
    // production template's own trailing open brace after its rendered
    // return-type variable).
    let expected_return = format!(") -> Result<{}> ", cmd.return_type) + "{";
    assert!(
        ROUTES.contains(&expected_return),
        "live ontology says `{} {}` has cnv:returnType `{}` but generated \
         src/clap_noun_verb_routes.rs's `{}` wrapper does not return that type -- \
         drift detected",
        cmd.noun, cmd.verb, cmd.return_type, cmd.fn_name
    );
    for arg in cmd.args {
        let expected_param = if arg.required {
            format!("    {}: {},", arg.ident, arg.rust_type)
        } else {
            format!("    {}: Option<{}>,", arg.ident, arg.rust_type)
        };
        assert!(
            ROUTES.contains(&expected_param),
            "live ontology's cnv:args for `{} {}` declares field `{}` (rustType \
             `{}`, required={}) but generated src/clap_noun_verb_routes.rs does not \
             contain the parameter line {:?} -- drift detected",
            cmd.noun, cmd.verb, arg.ident, arg.rust_type, arg.required, expected_param
        );
    }
    if !cmd.has_static_response {
        assert!(
            ROUTES.contains(&format!("crate::verbs::handlers::{}(", cmd.handler)),
            "live ontology says `{} {}` has cnv:handler `{}` (no cnv:staticResponse) \
             but generated src/clap_noun_verb_routes.rs's `{}` wrapper does not call \
             crate::verbs::handlers::{}(...) -- drift detected",
            cmd.noun, cmd.verb, cmd.handler, cmd.fn_name, cmd.handler
        );
    }
}

fn assert_command_in_docs_md(cmd: &LiveCommand) {
    let row = format!(
        "| `{}` | `{}` | `{}` | {} |",
        cmd.noun, cmd.verb, cmd.handler, cmd.doc
    );
    assert!(
        DOCS_MD.contains(&row),
        "live ontology has command `{} {}` but generated \
         docs/clap_noun_verb_routes.md does not contain the row {:?} -- generated \
         doc has drifted behind ontology.ttl",
        cmd.noun, cmd.verb, row
    );
}

fn assert_noun_in_routes(noun: &LiveNoun) {
    assert!(
        ROUTES.contains(&format!(
            "static REGISTER_{}_NOUN: fn() = register_{}_noun;",
            noun.noun_upper, noun.noun
        )),
        "live ontology has noun `{}` but generated src/clap_noun_verb_routes.rs does \
         not declare its REGISTER_{}_NOUN static -- drift detected",
        noun.noun, noun.noun_upper
    );
    assert!(
        ROUTES.contains(&format!("\"{}\",", noun.noun))
            && ROUTES.contains(&format!("\"{}\",", noun.about)),
        "live ontology says noun `{}` has rdfs:comment {:?} but generated \
         src/clap_noun_verb_routes.rs's register_{}_noun body does not contain that \
         pairing -- drift detected",
        noun.noun, noun.about, noun.noun
    );
}

/// Floor sanity check: guards against a silently-broken or silently-empty
/// SPARQL query (e.g. a query engine regression, a typo in the query text
/// that still parses but matches nothing) making every loop-based assertion
/// below vacuously true. If this fails, the failure is in a query itself,
/// not in drift between the ontology and the generated artifacts.
#[test]
fn sparql_queries_returned_at_least_one_row_each() {
    assert!(
        !LIVE_COMMANDS.is_empty(),
        "the `commands` SPARQL query against the synced ontology graph returned zero \
         cnv:Command rows -- either every individual was lost or the query itself is \
         broken; every other assertion in this file would otherwise pass vacuously"
    );
    assert!(
        !LIVE_NOUNS.is_empty(),
        "the `nouns` SPARQL query against the synced ontology graph returned zero \
         cnv:Noun rows -- either every individual was lost or the query itself is \
         broken"
    );
    assert!(
        !LIVE_STATIC_RESPONSES.is_empty(),
        "the live ontology graph currently declares zero cnv:staticResponse facts, but \
         clap-noun-verb-pack's own ontology.ttl declares exactly one (cnv:SessionPing) \
         -- either that fact was lost or the query itself is broken"
    );
}

/// Row-count parity between what the live (possibly multi-source-unioned)
/// ontology graph says right now and what is actually checked into
/// `src/clap_noun_verb_routes.rs`. Unlike the embedded Tier 2 proof's `>=`
/// counts (which only know THIS pack's own 4 commands / 2 nouns and must
/// tolerate a consuming project adding more under the same predicates),
/// this query runs against the SAME live graph the routes file was (or
/// should have been) generated from -- so an exact match is the correct,
/// stronger check: any divergence here means the checked-in file is stale
/// relative to the graph as it stands right now, not merely relative to
/// this one pack's own facts.
#[test]
fn command_and_noun_counts_match_generated_routes_right_now() {
    let verb_count = routes_only().matches("#[verb(").count();
    assert_eq!(
        verb_count,
        LIVE_COMMANDS.len(),
        "the live ontology graph has {} cnv:Command individuals right now, but the \
         checked-in src/clap_noun_verb_routes.rs has {verb_count} #[verb(...)] \
         attributes -- the generated routes have drifted behind ontology.ttl (a \
         `ggen:local-override` freeze marker predating a later ontology edit is the \
         most likely cause; see this file's module doc)",
        LIVE_COMMANDS.len()
    );

    let noun_count = routes_only().matches("CommandRegistry::register_noun(").count();
    assert_eq!(
        noun_count,
        LIVE_NOUNS.len(),
        "the live ontology graph has {} cnv:Noun individuals right now, but the \
         checked-in src/clap_noun_verb_routes.rs has {noun_count} \
         CommandRegistry::register_noun(...) calls -- the generated routes have \
         drifted behind ontology.ttl",
        LIVE_NOUNS.len()
    );
}

/// The core check: every command the live ontology graph reports right now
/// is still reflected, verbatim, in `src/clap_noun_verb_routes.rs` as it
/// actually sits on disk. Failing here means the checked-in generated file
/// no longer matches the ontology -- exactly the silent-drift failure mode
/// cap05's obligation text names, and the embedded proof cannot catch it
/// once `skip_if: "ggen:local-override"` has frozen this file (see this
/// file's module doc).
#[test]
fn every_live_command_matches_generated_routes_right_now() {
    for cmd in LIVE_COMMANDS {
        assert_command_in_routes(cmd);
    }
}

/// Companion check against the SEPARATE `clap_noun_verb_routes.md.tmpl`
/// output -- a different template, a different (narrower) SPARQL query,
/// rendered in its own pass. A bug local to only one of the two templates'
/// projections would leave this file's independent comparison unaffected.
#[test]
fn every_live_command_matches_generated_docs_md_right_now() {
    for cmd in LIVE_COMMANDS {
        assert_command_in_docs_md(cmd);
    }
}

/// Every live `cnv:staticResponse` fact is still reflected, verbatim, as
/// the literal `Ok(...)` body of its command's wrapper fn -- closes the
/// specific gap the pack's own doc names as the mechanism letting a command
/// require zero hand-written handler code: a value pre-condition that a
/// mere signature/type check (the rest of this proof) cannot express.
#[test]
fn every_live_static_response_matches_generated_routes_right_now() {
    for (key, expected_body) in LIVE_STATIC_RESPONSES {
        assert!(
            ROUTES.contains(expected_body),
            "live ontology's cnv:staticResponse for `{}` (noun:verb) is not reflected \
             verbatim as that command's wrapper body in generated \
             src/clap_noun_verb_routes.rs -- drift detected",
            key
        );
    }
}

/// Every live `cnv:Noun` individual is still reflected, verbatim, in the
/// generated noun-registration statics/fns.
#[test]
fn every_live_noun_matches_generated_routes_right_now() {
    for noun in LIVE_NOUNS {
        assert_noun_in_routes(noun);
    }
}

/// `ORDER BY ?noun ?verb` in the live `commands` query is expected to sort
/// lexically ascending by (noun, verb). This is a live regression guard on
/// the query engine's own collation, not a hand-asserted fact about how
/// the array happens to be typed -- if the engine's ORDER BY collation
/// ever changes, this fails on the very next sync instead of silently
/// reordering the generated routes and having nothing notice.
#[test]
fn live_command_order_is_lexical_ascending_by_noun_then_verb() {
    let keys: Vec<(&str, &str)> = LIVE_COMMANDS.iter().map(|c| (c.noun, c.verb)).collect();
    let mut sorted_keys = keys.clone();
    sorted_keys.sort_unstable();
    assert_eq!(
        keys, sorted_keys,
        "LIVE_COMMANDS is not in lexically-ascending (noun, verb) order -- the \
         `commands` query's own `ORDER BY ?noun ?verb` did not produce sorted \
         results this sync"
    );
}

/// `ORDER BY ?noun` in the live `nouns` query is expected to sort lexically
/// ascending, mirroring the check above for commands.
#[test]
fn live_noun_order_is_lexical_ascending() {
    let names: Vec<&str> = LIVE_NOUNS.iter().map(|n| n.noun).collect();
    let mut sorted_names = names.clone();
    sorted_names.sort_unstable();
    assert_eq!(
        names, sorted_names,
        "LIVE_NOUNS is not in lexically-ascending noun order -- the `nouns` query's \
         own `ORDER BY ?noun` did not produce sorted results this sync"
    );
}

/// Negative sanity check: a fabricated noun/verb pair that does not exist
/// in the live ontology graph must not spuriously appear in the generated
/// artifacts. Guards against a naive `contains()`-based check in this
/// proof silently matching everything.
#[test]
fn generated_artifacts_reject_unknown_command() {
    let bogus_attr = "#[verb(\"not-a-real-verb\", \"not-a-real-noun\")]";
    assert!(
        !ROUTES.contains(bogus_attr),
        "sanity: bogus #[verb(...)] attribute must not appear in generated routes"
    );
    let bogus_row = "| `not-a-real-noun` |";
    assert!(
        !DOCS_MD.contains(bogus_row),
        "sanity: bogus command row must not appear in generated docs"
    );
}
