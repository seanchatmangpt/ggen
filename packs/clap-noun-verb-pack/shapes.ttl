# shapes.ttl -- SHACL shapes constraining cnv:Command/cnv:Noun individuals.
#
# These close part of the ontology-expressiveness gap named in
# docs/packs/L5_VALIDATION_REPORT.md's clap-noun-verb-pack section: "Reaching
# even L3 requires the ontology to state relations/cardinality/error cases so
# templates become thin projections instead of hardcoding structure." Before
# this file existed, nothing prevented a malformed cnv:Command (missing
# cnv:doc, a cnv:args literal with a blank field name, a Noun with zero
# Commands) from silently reaching the templates, which would then either
# render broken Rust or silently drop the row. These shapes make that
# structure a checked, machine-verifiable fact of the ontology instead of an
# unstated convention every template author has to independently know.

@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix cnv:  <http://seanchatmangpt.github.io/packs/clap-noun-verb#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

cnv:CommandShape
    a sh:NodeShape ;
    sh:targetClass cnv:Command ;

    sh:property [
        sh:path     cnv:noun ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A Command must carry exactly one non-empty cnv:noun." ;
    ] ;
    sh:property [
        sh:path     cnv:verb ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A Command must carry exactly one non-empty cnv:verb." ;
    ] ;
    sh:property [
        sh:path     cnv:handler ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A Command must carry exactly one non-empty cnv:handler (recorded even when cnv:staticResponse makes it unused, for documentation/consistency)." ;
    ] ;
    sh:property [
        sh:path     cnv:doc ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A Command must carry exactly one non-empty cnv:doc (becomes the generated fn's /// comment)." ;
    ] ;
    sh:property [
        sh:path     cnv:returnType ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A Command must carry exactly one non-empty cnv:returnType." ;
    ] ;
    sh:property [
        sh:path     cnv:args ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "A Command must carry exactly one cnv:args literal (empty string is valid for zero-arg commands)." ;
    ] ;
    sh:property [
        sh:path     cnv:staticResponse ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "cnv:staticResponse, when present, must be a single string literal (the template inlines it verbatim as a Rust expression)." ;
    ] .

cnv:NounShape
    a sh:NodeShape ;
    sh:targetClass cnv:Noun ;

    sh:property [
        sh:path     rdfs:label ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A Noun must carry exactly one non-empty rdfs:label (its CLI-visible noun name)." ;
    ] ;
    sh:property [
        sh:path     rdfs:comment ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A Noun must carry exactly one non-empty rdfs:comment (its generated --help about text)." ;
    ] ;
    sh:property [
        sh:path     cnv:hasCommand ;
        sh:minCount 1 ;
        sh:class    cnv:Command ;
        sh:message  "A Noun must own at least one cnv:Command via cnv:hasCommand -- an unreferenced noun is dead ontology weight the CLI never actually routes to." ;
    ] .
