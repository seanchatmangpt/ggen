---
to: "docs/retrofit/as-found/現況調査票.md"
sparql:
  repos: |
    PREFIX ret: <https://seanchatmangpt.github.io/ontology/retrofit#>
    SELECT ?name ?url ?branch WHERE { ?r a ret:Repository ; ret:repositoryName ?name ; ret:repositoryUrl ?url ; ret:defaultBranch ?branch . }
  surfaces: |
    PREFIX ret: <https://seanchatmangpt.github.io/ontology/retrofit#>
    SELECT ?kind ?name ?path ?owner ?criticality WHERE {
      ?s a ret:ObservedSurface ; ret:surfaceKind ?kind ; ret:surfaceName ?name ; ret:effectiveOwner ?owner ; ret:criticality ?criticality .
      OPTIONAL { ?s ret:surfacePath ?path }
    } ORDER BY ?kind ?name
---
