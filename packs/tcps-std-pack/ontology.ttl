@prefix tcps_std: <http://seanchatmangpt.github.io/packs/tcps-std#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

tcps_std:LibModule a tcps_std:Module ;
    rdfs:comment "tcps-std lib.rs: receipt persistence (受領証を保存する/受領証を文字列化する) and environment observation (実行環境), std-dependent, depends on tcps-core." ;
    tcps_std:sourceText """#![forbid(unsafe_code)]
#![deny(missing_debug_implementations)]

use std::fs::{self, File};
use std::io::{self, Write};
use std::path::{Path, PathBuf};
use std::time::{SystemTime, UNIX_EPOCH};

use tcps_core::受領証_impl::{受領証, 受領種別, 要約値};
use tcps_core::語彙::{有無, 理由番号, 道具番号};

#[derive(Clone, Debug, PartialEq, Eq)]
pub struct 実行環境 {
    pub 操作体系: String,
    pub 機械種別: String,
    pub 処理系: String,
    pub 版: String,
}

impl 実行環境 {
    #[must_use]
    pub fn 現在() -> Self {
        Self {
            操作体系: std::env::consts::OS.to_owned(),
            機械種別: std::env::consts::ARCH.to_owned(),
            処理系: "rust".to_owned(),
            版: tcps_core::版.to_owned(),
        }
    }
}

#[derive(Clone, Debug, PartialEq, Eq)]
pub struct 永続化結果 {
    pub 経路: PathBuf,
    pub バイト数: u64,
}

pub fn 現在時刻() -> io::Result<u64> {
    SystemTime::now()
        .duration_since(UNIX_EPOCH)
        .map(|値| 値.as_secs())
        .map_err(io::Error::other)
}

#[must_use]
pub fn 十六進(要約: 要約値) -> String {
    const 表: &[u8; 16] = b"0123456789abcdef";
    let mut 出力 = String::with_capacity(64);
    for 値 in 要約.0 {
        出力.push(char::from(表[usize::from(値 >> 4)]));
        出力.push(char::from(表[usize::from(値 & 0x0f)]));
    }
    出力
}

fn 種別名(種別: 受領種別) -> &'static str {
    match 種別 {
        受領種別::生産 => "生産",
        受領種別::停止 => "停止",
        受領種別::改善 => "改善",
        受領種別::標準更新 => "標準更新",
        受領種別::引取り => "引取り",
        受領種別::補充 => "補充",
        受領種別::選択 => "選択",
        受領種別::許可 => "許可",
        受領種別::実行 => "実行",
        受領種別::拒否 => "拒否",
    }
}

fn 道具値(値: 有無<道具番号>) -> String {
    match 値 {
        有無::有る(番号) => 番号.to_string(),
        有無::無い => "null".to_owned(),
    }
}

fn 理由値(値: 有無<理由番号>) -> String {
    match 値 {
        有無::有る(番号) => 番号.to_string(),
        有無::無い => "null".to_owned(),
    }
}

#[must_use]
pub fn 受領証を文字列化する(受領証: &受領証) -> String {
    format!(
        concat!(
            "{{\\n",
            "  \\"受領番号\\": {},\\n",
            "  \\"種別\\": \\"{}\\",\\n",
            "  \\"工程\\": {},\\n",
            "  \\"時刻\\": {},\\n",
            "  \\"標準番号\\": {},\\n",
            "  \\"道具\\": {},\\n",
            "  \\"理由\\": {},\\n",
            "  \\"前要約\\": \\"{}\\",\\n",
            "  \\"後要約\\": \\"{}\\"\\n",
            "}}\\n"
        ),
        受領証.受領番号,
        種別名(受領証.種別),
        受領証.工程,
        受領証.時刻,
        受領証.標準番号,
        道具値(受領証.道具),
        理由値(受領証.理由),
        十六進(受領証.前要約),
        十六進(受領証.後要約),
    )
}

pub fn 受領証を保存する(根: &Path, 受領証: &受領証) -> io::Result<永続化結果> {
    fs::create_dir_all(根)?;
    let 経路 = 根.join(format!("受領証-{}.json", 受領証.受領番号));
    let 一時 = 根.join(format!(".受領証-{}.tmp", 受領証.受領番号));
    let 内容 = 受領証を文字列化する(受領証);

    let mut ファイル = File::create(&一時)?;
    ファイル.write_all(内容.as_bytes())?;
    ファイル.sync_all()?;
    fs::rename(&一時, &経路)?;

    Ok(永続化結果 {
        経路,
        バイト数: 内容.len() as u64,
    })
}

#[cfg(test)]
mod 試験 {
    use super::*;
    use tcps_core::品質::異常;
    use tcps_core::語彙::有無;

    #[test]
    fn 受領証文字列は日本語項目を保つ() {
        let 受領証 = 受領証 {
            受領番号: 1,
            種別: 受領種別::停止,
            工程: 2,
            時刻: 3,
            標準番号: 4,
            異常: 有無::有る(異常::品質不良),
            道具: 有無::無い,
            理由: 有無::有る(7),
            前要約: 要約値::零(),
            後要約: 要約値::零(),
        };
        let 内容 = 受領証を文字列化する(&受領証);
        assert!(内容.contains("停止"));
        assert!(内容.contains("受領番号"));
    }
}
""" .

tcps_std:CargoManifest a tcps_std:Manifest ;
    rdfs:comment "tcps-std Cargo.toml: crate manifest declaring the tcps-core path dependency." ;
    tcps_std:manifestText """[package]
name = "tcps-std"
version.workspace = true
edition.workspace = true
rust-version.workspace = true
license.workspace = true
authors.workspace = true
description = "豊田コード生産方式の標準ライブラリ統合、受領証永続化、環境観測"

[lib]
name = "tcps_std"
path = "src/lib.rs"

[dependencies]
tcps-core = { path = "../..", package = "tcps-generated" }

[dev-dependencies]
tempfile = "3"

[lints]
workspace = true
""" .

# ---------------------------------------------------------------------------
# Persistence sabotage cases (l5p:cap06 -- Generated negative witnesses)
#
# Source for `templates/persistence_sabotage_proof.rs.tmpl`, which projects
# these via a real `sparql:` frontmatter query (no hardcoded EXPECTED array)
# into a generated integration test that calls the REAL
# `受領証を保存する` (crates/tcps-std/src/lib.rs, transcribed verbatim above
# as tcps_std:sourceText) with a genuinely adversarial filesystem
# precondition. `受領証を保存する`'s own logic never branches on the
# receipt's field values -- its only real conditional behavior is the
# `io::Result` outcome of `fs::create_dir_all(根)?`, so this pack has
# exactly one real failure mode to prove fails closed (not panics, not
# silently succeeds): a `根` path whose parent component is a pre-existing
# regular file, which makes `create_dir_all` fail at the OS level. A
# 2-case suite (this adversarial case plus a positive control on a
# genuinely writable root) is therefore exhaustive of this crate's testable
# surface, not artificially thin -- unlike tcps-core-pack's guard-condition
# cap06 closure, which has a much larger boundary-value space because its
# guards branch on numeric input.
# ---------------------------------------------------------------------------

tcps_std:PersistCase a rdfs:Class ;
    rdfs:comment "Class of ontology-declared cases for 受領証を保存するのsabotage/positive-control proof: case name, expected io::Result outcome (\"Ok\"/\"Err\"), and a 受領番号 to construct the sample receipt with." .

tcps_std:pscValidRoot a tcps_std:PersistCase ;
    tcps_std:caseName "valid_writable_root_succeeds" ;
    tcps_std:rootScenario "Writable" ;
    tcps_std:expectedOutcome "Ok" ;
    tcps_std:receiptNumber 101 ;
    rdfs:comment "根 resolves to a genuinely writable, not-yet-existing subdirectory of a real TempDir: fs::create_dir_all(根) must succeed and 受領証を保存する must return Ok(永続化結果) with 経路 under 根 -- positive control proving the guard isn't trivially fail-closed on everything." .

tcps_std:pscRootBlockedByFile a tcps_std:PersistCase ;
    tcps_std:caseName "root_blocked_by_existing_file_fails_closed" ;
    tcps_std:rootScenario "FileBlocked" ;
    tcps_std:expectedOutcome "Err" ;
    tcps_std:receiptNumber 102 ;
    rdfs:comment "根 is a child path of a location where a REGULAR FILE already exists in place of a directory: fs::create_dir_all(根) fails at the OS level (parent path component is not a directory), and 受領証を保存する must propagate that as Err, not panic and not silently succeed -- adversarial precondition violation, proving the persistence path fails closed. tcps_std:rootScenario is deliberately a SEPARATE predicate from tcps_std:expectedOutcome (not derived from it): an earlier draft of this fixture branched the test's own precondition construction on expectedOutcome directly, which made the assertion pass no matter what expectedOutcome said (the precondition always matched whatever outcome was expected) -- a live self-check caught it as tautological before this closure was recorded (see l5-promotion ontology's cap06 evidence for tcps-std-pack). Only rootScenario drives which filesystem precondition gets constructed; expectedOutcome is compared independently against the real result." .
