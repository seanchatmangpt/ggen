@prefix tcps_std: <http://seanchatmangpt.github.io/packs/tcps-std#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

tcps_std:LibModuleShape
    a sh:NodeShape ;
    sh:targetClass tcps_std:Module ;
    rdfs:comment "Every tcps_std:LibModule must carry a non-empty tcps_std:sourceText -- refuses an empty/missing lib.rs body." ;
    sh:property [
        sh:path tcps_std:sourceText ;
        sh:minCount 1 ;
        sh:minLength 1 ;
        sh:message "tcps_std:LibModule must have a non-empty tcps_std:sourceText." ;
    ] .
