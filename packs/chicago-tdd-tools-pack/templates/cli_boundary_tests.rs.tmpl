---
to: tests/chicago_tdd_tools_boundary.rs
sparql:
  tests: |
    PREFIX ctt: <http://seanchatmangpt.github.io/packs/chicago-tdd-tools#>
    SELECT ?test_name ?binary ?args ?exit_code ?stdout_needle ?stderr_needle ?axiom
    WHERE {
      ?t a ctt:CliBoundaryTest ;
         ctt:testName ?test_name ;
         ctt:binary ?binary ;
         ctt:args ?args ;
         ctt:expectExitCode ?exit_code ;
         ctt:coversAxiom ?axiom .
      OPTIONAL { ?t ctt:stdoutNeedle ?stdout_needle }
      OPTIONAL { ?t ctt:stderrNeedle ?stderr_needle }
    }
    ORDER BY ?test_name
---
//! Chicago-style CLI boundary proofs — GENERATED by chicago-tdd-tools-pack.
//!
//! Each `#[test]` spawns a real binary via
//! `chicago_tdd_tools::cli_proof::CliHarness` and asserts on observable
//! exit codes and output. No mocks. No stubs. The binary must exist on disk.

use chicago_tdd_tools::cli_proof::CliHarness;
{% for row in tests %}
/// Covers: {{ row.axiom }}
#[test]
fn {{ row.test_name }}() {
    // Arrange + Act: real subprocess boundary crossing.
    let output = CliHarness::cargo_bin("{{ row.binary }}")
        .args("{{ row.args }}".split_whitespace())
        .run()
        .expect("CliHarness run for {{ row.test_name }}");

    // Assert: observable state, not mock interactions.
    output.assert_exit_code({{ row.exit_code }});
{%- if row.stdout_needle is defined %}
    output.assert_stdout_contains("{{ row.stdout_needle }}");
{%- endif %}
{%- if row.stderr_needle is defined %}
    output.assert_stderr_contains("{{ row.stderr_needle }}");
{%- endif %}
}
{% endfor %}
