use chicago_tdd_tools::cli_proof::CliHarness;

/// One CLI-boundary invocation to dispatch: parsed argv + expected
/// observable result. Constructed by the generated `#[test]` fns from
/// `ctt:CliBoundaryTest` individuals — this struct itself carries no
/// per-test-case data, only the shape.
pub struct BoundarySpec {
    pub test_name: &'static str,
    pub binary: &'static str,
    pub args: &'static str,
    pub exit_code: i32,
    pub stdout_needle: Option<&'static str>,
    pub stderr_needle: Option<&'static str>,
}

/// Dispatch one `BoundarySpec` across the real CLI-binary boundary and
/// return `Ok(())` iff every expectation held. No mocks, no stubs: `run()`
/// spawns a real subprocess via `CliHarness::cargo_bin`.
///
/// # Errors
///
/// Returns `Err` (never panics) describing exactly which expectation failed:
/// the harness itself failing to spawn, an exit-code mismatch, or a missing
/// stdout/stderr needle.
pub fn run_boundary_spec(spec: &BoundarySpec) -> Result<(), String> {
    let output = CliHarness::cargo_bin(spec.binary)
        .args(spec.args.split_whitespace())
        .run()
        .map_err(|e| format!("{}: CliHarness run failed: {e}", spec.test_name))?;

    if output.exit_code != spec.exit_code {
        return Err(format!(
            "{}: expected exit code {} but got {}\nstdout:\n{}\nstderr:\n{}",
            spec.test_name, spec.exit_code, output.exit_code, output.stdout, output.stderr
        ));
    }
    if let Some(needle) = spec.stdout_needle {
        if !output.stdout.contains(needle) {
            return Err(format!(
                "{}: expected stdout to contain {needle:?} but it did not\nstdout:\n{}",
                spec.test_name, output.stdout
            ));
        }
    }
    if let Some(needle) = spec.stderr_needle {
        if !output.stderr.contains(needle) {
            return Err(format!(
                "{}: expected stderr to contain {needle:?} but it did not\nstderr:\n{}",
                spec.test_name, output.stderr
            ));
        }
    }
    Ok(())
}
