# chicago-tdd-tools pack ontology — CLI boundary proofs.
#
# Modeled on the CliProofTest shape: each individual describes one
# Chicago-style test that spawns a real binary via
# chicago_tdd_tools::cli_proof::CliHarness and asserts on observable
# exit codes and output (no mocks, no behavior verification).

@prefix ctt:  <http://seanchatmangpt.github.io/packs/chicago-tdd-tools#> .
@prefix cnv:  <http://seanchatmangpt.github.io/packs/clap-noun-verb#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ── Schema ──────────────────────────────────────────────────────────

ctt:CliBoundaryTest
  a rdfs:Class ;
  rdfs:label "CLI Boundary Test" ;
  rdfs:comment "A test that crosses a real CLI binary boundary via CliHarness and asserts on exit code / stdout / stderr." .

ctt:testName      a rdfs:Property ; rdfs:label "test function name" ; rdfs:range xsd:string .
ctt:binary        a rdfs:Property ; rdfs:label "cargo binary name"  ; rdfs:range xsd:string .
ctt:args          a rdfs:Property ; rdfs:label "space-separated argv" ; rdfs:range xsd:string .
ctt:expectExitCode a rdfs:Property ; rdfs:label "expected exit code" ; rdfs:range xsd:integer .
ctt:stdoutNeedle  a rdfs:Property ; rdfs:label "required stdout substring" ; rdfs:range xsd:string .
ctt:stderrNeedle  a rdfs:Property ; rdfs:label "required stderr substring" ; rdfs:range xsd:string .
ctt:coversAxiom   a rdfs:Property ; rdfs:label "axiom this proof covers" ; rdfs:range xsd:string .
ctt:composesCommand a rdfs:Property ;
  rdfs:label "clap-noun-verb Command this boundary test composes its argv from" ;
  rdfs:comment "Points at a cnv:Command individual (defined by clap-noun-verb-pack or a consuming project's own domain.ttl, not by this pack) so ctt:args for THIS test is derived by joining ?cmd cnv:noun/cnv:verb rather than hand-typed as a free-text literal -- partial closure of the Handler-gap axis: the invocation SHAPE (noun+verb) is composed from another pack's generated command surface; the expected exit code/needle remain this pack's own observed axiom, not (yet) derivable from cnv:Command alone since clap-noun-verb-pack's ontology carries no success-postcondition property." ;
  rdfs:range cnv:Command .

# ── Individuals ─────────────────────────────────────────────────────

ctt:receiptctl-help
  a ctt:CliBoundaryTest ;
  rdfs:label "receiptctl --help boundary proof" ;
  ctt:testName "receiptctl_help_lists_verbs" ;
  ctt:binary "receiptctl" ;
  ctt:args "--help" ;
  ctt:expectExitCode 0 ;
  ctt:stdoutNeedle "Usage" ;
  ctt:coversAxiom "receiptctl --help exits 0 with usage text" .

ctt:receiptctl-version
  a ctt:CliBoundaryTest ;
  rdfs:label "receiptctl --version boundary proof" ;
  ctt:testName "receiptctl_version_emits_name" ;
  ctt:binary "receiptctl" ;
  ctt:args "--version" ;
  ctt:expectExitCode 0 ;
  # NOTE (verified live against a real clap-noun-verb 26.7.4 consumer binary,
  # 2026-07-18): --version prints a generic "cli <version>" string, NOT the
  # actual binary/package name -- a real clap-noun-verb quirk, not something
  # this pack's consumer controls. The axiom is corrected to what's actually
  # true rather than what was originally assumed.
  ctt:stdoutNeedle "cli " ;
  ctt:coversAxiom "receiptctl --version exits 0 and prints a version string" .

ctt:receiptctl-algorithm-list
  a ctt:CliBoundaryTest ;
  rdfs:label "receiptctl algorithm list boundary proof (argv composed from clap-noun-verb-pack)" ;
  ctt:testName "receiptctl_algorithm_list_succeeds" ;
  ctt:binary "receiptctl" ;
  # NOTE: no ctt:args literal here -- the invocation argv is composed at
  # sync time by joining ctt:composesCommand's target cnv:Command's
  # cnv:noun/cnv:verb (see cli_boundary_tests.rs.tmpl's SPARQL, which BINDs
  # CONCAT(?noun, " ", ?verb) as ?args when a literal ctt:args is absent).
  # This is a real generated command from clap-noun-verb-pack + this
  # project's own domain.ttl (schema/domain.ttl's cnv:AlgorithmList), not a
  # value this pack's ontology invented.
  ctt:composesCommand cnv:AlgorithmList ;
  ctt:expectExitCode 0 ;
  ctt:stdoutNeedle "[" ;
  ctt:coversAxiom "receiptctl algorithm list (argv composed from clap-noun-verb-pack's AlgorithmList command) exits 0 and prints a JSON array" .

ctt:receiptctl-unknown-verb
  a ctt:CliBoundaryTest ;
  rdfs:label "receiptctl unknown-verb boundary proof" ;
  ctt:testName "receiptctl_unknown_verb_fails_closed" ;
  ctt:binary "receiptctl" ;
  ctt:args "frobnicate" ;
  # NOTE (verified live, 2026-07-18): clap-noun-verb's own argument-parsing
  # failure exits 1, not 2 -- corrected from an unverified assumption.
  ctt:expectExitCode 1 ;
  ctt:stderrNeedle "error" ;
  ctt:coversAxiom "an unknown subcommand exits nonzero with a clap error on stderr" .

# ── Negative-witness suite (cap06) ──────────────────────────────────
#
# The four individuals above are all happy-path (3) plus one incidental
# sabotage case (receiptctl-unknown-verb). The five below were added
# 2026-07-22 to turn that single incidental case into a systematic sabotage
# suite covering the distinct real clap-noun-verb failure modes actually
# observed against the built `examples/receiptctl` binary (verified live:
# `cargo build -q` in examples/receiptctl, then each argv run directly with
# stdout/stderr captured separately via shell redirection, matching exactly
# how `chicago_tdd_tools::cli_proof::CliHarness::run` captures them via
# `std::process::Command::output()` -- both are OS-level fd capture, not a
# simulation). Every stderrNeedle below is a substring transcribed verbatim
# from that real captured stderr, not invented.
#
# Three of the five reuse ctt:composesCommand against a REAL required-arg
# command (cnv:ReceiptEmit / cnv:UserCreate / cnv:SessionLogin, all defined
# with a required cnv:args field) precisely because composesCommand's SPARQL
# binds argv to CONCAT(noun, " ", verb) only -- no flags -- which is exactly
# the "required flag omitted" shape these sabotage cases need. This is the
# second real use of composesCommand (previously exercised by exactly one
# happy-path test, receiptctl-algorithm-list), now also proven on a sad path.

ctt:receiptctl-receipt-emit-missing-required-arg
  a ctt:CliBoundaryTest ;
  rdfs:label "receiptctl receipt emit missing required --sync-receipt-id boundary proof" ;
  ctt:testName "receiptctl_receipt_emit_fails_without_required_arg" ;
  ctt:binary "receiptctl" ;
  ctt:composesCommand cnv:ReceiptEmit ;
  ctt:expectExitCode 1 ;
  # NOTE (verified live, 2026-07-22): `receiptctl receipt emit` with its
  # required `--sync-receipt-id` flag omitted exits 1; stderr (captured
  # separately from stdout) contains this exact substring.
  ctt:stderrNeedle "required arguments were not provided" ;
  ctt:coversAxiom "receipt emit without its required --sync-receipt-id flag fails closed via clap's own required-argument enforcement" .

ctt:receiptctl-user-create-missing-required-arg
  a ctt:CliBoundaryTest ;
  rdfs:label "receiptctl user create missing required --name boundary proof" ;
  ctt:testName "receiptctl_user_create_fails_without_required_arg" ;
  ctt:binary "receiptctl" ;
  ctt:composesCommand cnv:UserCreate ;
  ctt:expectExitCode 1 ;
  # NOTE (verified live, 2026-07-22): same clap required-argument enforcement
  # as receipt emit, exercised on a different noun/verb/flag combination.
  ctt:stderrNeedle "required arguments were not provided" ;
  ctt:coversAxiom "user create without its required --name flag fails closed via clap's own required-argument enforcement" .

ctt:receiptctl-session-login-missing-required-arg
  a ctt:CliBoundaryTest ;
  rdfs:label "receiptctl session login missing required --token boundary proof" ;
  ctt:testName "receiptctl_session_login_fails_without_required_arg" ;
  ctt:binary "receiptctl" ;
  ctt:composesCommand cnv:SessionLogin ;
  ctt:expectExitCode 1 ;
  # NOTE (verified live, 2026-07-22): same clap required-argument enforcement
  # as receipt emit / user create, third distinct noun/verb/flag combination.
  ctt:stderrNeedle "required arguments were not provided" ;
  ctt:coversAxiom "session login without its required --token flag fails closed via clap's own required-argument enforcement" .

ctt:receiptctl-known-noun-unrecognized-verb
  a ctt:CliBoundaryTest ;
  rdfs:label "receiptctl known-noun unrecognized-verb boundary proof" ;
  ctt:testName "receiptctl_known_noun_unrecognized_verb_fails_closed" ;
  ctt:binary "receiptctl" ;
  # A distinct failure mode from receiptctl-unknown-verb above: there the
  # TOP-LEVEL token itself is unrecognized (no noun matches "frobnicate" at
  # all); here the noun "algorithm" IS registered but the verb under it is
  # not, which clap resolves via its per-noun subcommand tree rather than
  # the top-level command list -- a different code path, confirmed to
  # produce a different message ("unrecognized subcommand" vs. the top-level
  # "error:" text) when actually run.
  ctt:args "algorithm frobnicate" ;
  ctt:expectExitCode 1 ;
  # NOTE (verified live, 2026-07-22).
  ctt:stderrNeedle "unrecognized subcommand" ;
  ctt:coversAxiom "a known noun with an unrecognized verb exits nonzero with a clap error on stderr, distinct from an entirely-unknown top-level noun" .

ctt:receiptctl-unexpected-flag
  a ctt:CliBoundaryTest ;
  rdfs:label "receiptctl unexpected-flag boundary proof" ;
  ctt:testName "receiptctl_unexpected_flag_fails_closed" ;
  ctt:binary "receiptctl" ;
  # A third distinct failure mode: a fully valid noun+verb pair
  # ("algorithm list", zero required args) rejected only because of one
  # unrecognized flag -- clap's unknown-argument enforcement, not its
  # subcommand-resolution or required-argument enforcement.
  ctt:args "algorithm list --bogus-flag" ;
  ctt:expectExitCode 1 ;
  # NOTE (verified live, 2026-07-22).
  ctt:stderrNeedle "unexpected argument" ;
  ctt:coversAxiom "an unrecognized flag on an otherwise-valid command exits nonzero with a clap error on stderr" .
