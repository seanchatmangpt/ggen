---
to: src/rmcp_transport_catalog.rs
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/rmcp-pack
sparql:
  rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?transport_name ?transport_role ?feature_flag ?transport_purpose ?source_file WHERE {
      ?t a rmcp:Transport ; rmcp:transportName ?transport_name ; rmcp:transportRole ?transport_role ;
         rmcp:featureFlag ?feature_flag ; rmcp:transportPurpose ?transport_purpose ;
         rmcp:sourceFile ?source_file .
    } ORDER BY ?transport_name
---
//! Typed catalog of the real transport implementations reachable from
//! `rmcp::transport` (7 total).
//!
//! Generated by `rmcp-pack` from `packs/rmcp-pack/ontology.ttl`, read
//! directly from `src/transport.rs`'s own `#[cfg(feature = ...)]`-gated
//! `pub use` declarations in the real vendored `rmcp` v2.2.0 source.

/// One real `rmcp::transport` implementation.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct RmcpTransport {
    pub transport_name: &'static str,
    /// "client", "server", or "helper".
    pub transport_role: &'static str,
    /// The real Cargo feature gating this transport. One real transport
    /// (`SinkStreamTransport`) has none at all -- its value states that
    /// fact explicitly rather than being empty.
    pub feature_flag: &'static str,
    pub transport_purpose: &'static str,
    /// file:line citation into the real vendored `rmcp-2.2.0` source.
    pub source_file: &'static str,
}

/// All 7 real `rmcp::transport` implementations, ordered by name.
pub const RMCP_TRANSPORTS: &[RmcpTransport] = &[
{% for row in rows %}    RmcpTransport { transport_name: "{{ row.transport_name }}", transport_role: "{{ row.transport_role }}", feature_flag: "{{ row.feature_flag | replace(from='"', to="'") }}", transport_purpose: "{{ row.transport_purpose | replace(from='"', to="'") }}", source_file: "{{ row.source_file | replace(from='"', to="'") }}" },
{% endfor %}];
