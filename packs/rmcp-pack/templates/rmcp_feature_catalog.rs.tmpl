---
to: src/rmcp_feature_catalog.rs
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/rmcp-pack
sparql:
  rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?feature_name ?feature_desc ?feature_default WHERE {
      ?f a rmcp:Feature ; rmcp:featureName ?feature_name ; rmcp:featureDesc ?feature_desc ;
         rmcp:featureDefault ?feature_default .
    } ORDER BY ?feature_name
---
{%- set documented_count = rows | length -%}
{%- set undocumented_count = 26 - documented_count -%}
//! Typed catalog of the {{ documented_count }} real Cargo feature flags
//! `rmcp`'s own README.md documents across its 3 real markdown tables
//! ("Feature Flags", "Transport features", "TLS backend options").
//!
//! Generated by `rmcp-pack` from `packs/rmcp-pack/ontology.ttl`. NOT a
//! complete account of `rmcp`'s `Cargo.toml` `[features]` table, which
//! defines 26 flags total -- see the ontology's own header for the
//! {{ undocumented_count }} undocumented flags this pass deliberately left
//! out of scope.

/// One real Cargo feature flag documented in `rmcp`'s README.md.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct RmcpFeature {
    pub feature_name: &'static str,
    /// Verbatim one-line description from README.md's own feature tables.
    pub feature_desc: &'static str,
    /// true only for the 2 rows README.md's own "Default" column marks
    /// (server, macros). `Cargo.toml`'s real default array additionally
    /// includes `base64`, out of this pass's modeled scope -- see
    /// ontology.ttl's rmcp:featureDefault comment.
    pub feature_default: bool,
}

/// All 15 real, README-documented Cargo feature flags, ordered by name.
pub const RMCP_FEATURES: &[RmcpFeature] = &[
{% for row in rows %}    RmcpFeature { feature_name: "{{ row.feature_name }}", feature_desc: "{{ row.feature_desc | replace(from='"', to="'") }}", feature_default: {{ row.feature_default }} },
{% endfor %}];
