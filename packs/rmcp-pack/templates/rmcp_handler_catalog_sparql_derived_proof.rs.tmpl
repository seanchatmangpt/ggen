//! sibling proof hand-transcribes its expected literals from `ontology.ttl` and
//! deliberately carries no `sparql:` frontmatter key, for a real, disclosed reason
//! (its own header): looping the SAME query that produced `RMCP_SERVER_METHODS`/
//! `RMCP_CLIENT_METHODS` into that test's own expectations would let a wrong
//! field-mapping bug corrupt both identically, and the test could never catch it.
//! That reasoning is correct for what THAT proof checks -- spot-checked rows plus
//! structural invariants (sortedness, no duplicates) -- but it leaves a gap: a
//! hand-transcribed literal is authored once and never auto-updates, so it cannot
//! detect the case where `ontology.ttl` changes LATER and the checked-in generated
//! artifact falls behind it.
//!
//! This proof closes that gap by checking a DIFFERENT thing, not the same thing more
//! strictly: whether `src/rmcp_handler_catalog.rs`, as it actually sits on disk right
//! now, still agrees with what `rmcp:HandlerMethod` individuals say RIGHT NOW. It
//! cannot and does not claim to validate "is the ontology itself correct" (nothing
//! can, that is definitional) -- only "has the checked-in generated module silently
//! drifted from the ontology since it was last written."
//!
//! ## Why this is not the same tautology the sibling proof's header warns about
//! (reapplying `star-toml-pack`'s wave-2 cap05 reference pattern verbatim, see
//! `packs/star-toml-pack/templates/star_toml_config_sparql_derived_proof.rs.tmpl`)
//!
//! 1. Asymmetric freshness, not identical-execution self-agreement.
//!    `rmcp_handler_catalog.rs.tmpl` writes its output under `freeze_policy: checksum`
//!    (`freeze_slots_dir: .ggen/freeze/rmcp-pack`): once a consumer hand-edits
//!    `src/rmcp_handler_catalog.rs`, or an ontology-driven content change lands
//!    without `force: true`, a further sync can leave the checked-in file behind
//!    whatever `ontology.ttl` now says while `ggen sync run` still (eventually)
//!    exits 0. This template carries NO `freeze_policy` of its own: its `LIVE_*`
//!    arrays below are re-baked from a live query against whatever `ontology.ttl`
//!    says at the moment THIS file is (re)generated. So the two sides of every
//!    assertion below are not guaranteed to come from the same sync execution --
//!    one (`RS_CONTENT`, via `include_str!`) is whatever was last actually written
//!    to disk, frozen or not; the other (`LIVE_*`) is always "right now." A
//!    hand-transcribed expectation frozen at authoring time cannot distinguish
//!    those two states from each other; this one can, and fails loudly when they
//!    diverge.
//! 2. Independent rendering, not the same substitution checked twice.
//!    This template's own for-loops over the `server_rows`/`client_rows` SPARQL
//!    results are a SEPARATE Tera render pass from `rmcp_handler_catalog.rs.tmpl`'s
//!    own loops over the identical queries. A field-mapping bug local to ONE of the
//!    two templates (wrong variable, dropped row, stray whitespace, a broken
//!    `replace(from='"', ...)` transform) produces a generated-module string that
//!    this proof's independently-rendered `LIVE_*` values will not match, and the
//!    assertions below fail.
//!
//! ## Honest scope
//!
//! This still compares rendered TEXT via substring search, not a parsed Rust AST --
//! the same limitation the sibling proof's structural test avoids by
//! literal-construction-must-compile instead. It does not repeat the sibling proof's
//! spot-checks / sortedness / no-duplicate invariants (that is that proof's job;
//! duplicating it here would be scope creep, not a second check), nor does it repeat
//! `rmcp_stub_handler_proof.rs`'s real-crate behavioral coverage. It cannot prove
//! ggen's own SPARQL/Tera pipeline is bug-free in some absolute sense -- only that,
//! on the sync run that (re)generated this file, the live ontology and the
//! checked-in generated module said the same thing.

const RS_CONTENT: &str = include_str!("../src/rmcp_handler_catalog.rs");

/// Every `rmcp:HandlerMethod` individual with `rmcp:role "server"` as of the sync
/// run that generated THIS file -- (method_name, params_type, return_type,
/// default_behavior, source_file) -- freshly baked from the `server_rows` SPARQL
/// result, never hand-typed. `default_behavior`/`source_file` go through the exact
/// same `replace(from='"', to="'")` transform `rmcp_handler_catalog.rs.tmpl` itself
/// applies, so the two sides compare like for like.
const LIVE_SERVER_ROWS: &[(&str, &str, &str, &str, &str)] = &[
{% for row in server_rows %}    (
        "{{ row.method_name }}",
        "{{ row.params_type }}",
        "{{ row.return_type }}",
        "{{ row.default_behavior | replace(from='"', to="'") }}",
        "{{ row.source_file | replace(from='"', to="'") }}",
    ),
{% endfor %}];

/// Every `rmcp:HandlerMethod` individual with `rmcp:role "client"` -- same shape as
/// `LIVE_SERVER_ROWS`, freshly baked from the `client_rows` SPARQL result.
const LIVE_CLIENT_ROWS: &[(&str, &str, &str, &str, &str)] = &[
{% for row in client_rows %}    (
        "{{ row.method_name }}",
        "{{ row.params_type }}",
        "{{ row.return_type }}",
        "{{ row.default_behavior | replace(from='"', to="'") }}",
        "{{ row.source_file | replace(from='"', to="'") }}",
    ),
{% endfor %}];

fn assert_row_present(role: &str, row: &(&str, &str, &str, &str, &str)) {
    let (method_name, params_type, return_type, default_behavior, source_file) = *row;
    let needle = format!(
        "role: \"{role}\", method_name: \"{method_name}\", params_type: \"{params_type}\", \
         return_type: \"{return_type}\", default_behavior: \"{default_behavior}\", \
         source_file: \"{source_file}\" }},"
    );
    assert!(
        RS_CONTENT.contains(&needle),
        "live ontology has rmcp:HandlerMethod `{method_name}` (role {role}) with \
         params_type={params_type:?} return_type={return_type:?} \
         default_behavior={default_behavior:?} source_file={source_file:?}, but generated \
         src/rmcp_handler_catalog.rs does not contain a matching RmcpHandlerMethod row -- \
         generated module has drifted behind ontology.ttl. Looked for: {needle:?}"
    );
}

/// Floor sanity check: guards against a silently-broken or silently-empty SPARQL
/// query (e.g. a query engine regression, a typo in the query text that still
/// parses but matches nothing) making every loop-based assertion below vacuously
/// true. If this fails, the failure is in a query itself, not in drift between the
/// ontology and the generated module.
#[test]
fn sparql_queries_returned_at_least_one_row_each() {
    assert!(
        !LIVE_SERVER_ROWS.is_empty(),
        "the `server_rows` SPARQL query against ontology.ttl returned zero \
         rmcp:HandlerMethod(role=server) rows -- either the ontology lost every \
         individual or the query itself is broken"
    );
    assert!(
        !LIVE_CLIENT_ROWS.is_empty(),
        "the `client_rows` SPARQL query against ontology.ttl returned zero \
         rmcp:HandlerMethod(role=client) rows -- either the ontology lost every \
         individual or the query itself is broken"
    );
}

/// Row-count parity between what the live ontology says right now (43 total: 27
/// server + 16 client, per ontology.ttl's own header) and what the query actually
/// returned this sync run.
#[test]
fn live_row_counts_match_the_ontologys_own_43_total() {
    assert_eq!(
        LIVE_SERVER_ROWS.len(),
        27,
        "live ontology query returned {} rmcp:HandlerMethod(role=server) rows, expected 27",
        LIVE_SERVER_ROWS.len()
    );
    assert_eq!(
        LIVE_CLIENT_ROWS.len(),
        16,
        "live ontology query returned {} rmcp:HandlerMethod(role=client) rows, expected 16",
        LIVE_CLIENT_ROWS.len()
    );
}

/// Every one of the 27 live `rmcp:HandlerMethod(role=server)` rows is present,
