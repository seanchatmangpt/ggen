      ?m a rmcp:HandlerMethod ; rmcp:role "client" ; rmcp:methodName ?method_name ;
         rmcp:paramsType ?params_type ; rmcp:returnType ?return_type ;
         rmcp:defaultBehavior ?default_behavior ; rmcp:sourceFile ?source_file .
    } ORDER BY ?method_name
