---
to: docs/rmcp_reference.md
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/rmcp-pack
sparql:
  server_rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?method_name ?params_type ?return_type ?default_behavior ?source_file WHERE {
      ?m a rmcp:HandlerMethod ; rmcp:role "server" ; rmcp:methodName ?method_name ;
         rmcp:paramsType ?params_type ; rmcp:returnType ?return_type ;
         rmcp:defaultBehavior ?default_behavior ; rmcp:sourceFile ?source_file .
    } ORDER BY ?method_name
  client_rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?method_name ?params_type ?return_type ?default_behavior ?source_file WHERE {
      ?m a rmcp:HandlerMethod ; rmcp:role "client" ; rmcp:methodName ?method_name ;
         rmcp:paramsType ?params_type ; rmcp:returnType ?return_type ;
         rmcp:defaultBehavior ?default_behavior ; rmcp:sourceFile ?source_file .
    } ORDER BY ?method_name
  macro_rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?macro_name ?macro_kind ?applies_to ?macro_fields ?source_file WHERE {
      ?m a rmcp:Macro ; rmcp:macroName ?macro_name ; rmcp:macroKind ?macro_kind ;
         rmcp:appliesTo ?applies_to ; rmcp:macroFields ?macro_fields ;
         rmcp:sourceFile ?source_file .
    } ORDER BY ?macro_name
  transport_rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?transport_name ?transport_role ?feature_flag ?transport_purpose ?source_file WHERE {
      ?t a rmcp:Transport ; rmcp:transportName ?transport_name ; rmcp:transportRole ?transport_role ;
         rmcp:featureFlag ?feature_flag ; rmcp:transportPurpose ?transport_purpose ;
         rmcp:sourceFile ?source_file .
    } ORDER BY ?transport_name
  feature_rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?feature_name ?feature_desc ?feature_default WHERE {
      ?f a rmcp:Feature ; rmcp:featureName ?feature_name ; rmcp:featureDesc ?feature_desc ;
         rmcp:featureDefault ?feature_default .
    } ORDER BY ?feature_name
