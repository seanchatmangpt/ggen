//! Hand-transcribed proof that `rmcp_handler_catalog.rs` (GENERATED by
//! `rmcp-pack` from `packs/rmcp-pack/ontology.ttl`) matches the ontology's
//! literal `rmcp:HandlerMethod` individuals.
//!
//! Deliberately NO `sparql:` frontmatter key in this template (see
//! `rmcp_handler_catalog.rs.tmpl` for the query that *does* exist):
//! re-deriving the "expected" side via the same SPARQL query that produced
//! `RMCP_SERVER_METHODS`/`RMCP_CLIENT_METHODS` would make every assertion a
//! tautology (actual == actual, computed twice). Every literal value below
//! was transcribed by hand from `packs/rmcp-pack/ontology.ttl`, not queried.
//!
//! Scope: this proof covers `rmcp:HandlerMethod` (43 individuals, the
//! largest and most heavily-cited class). `rmcp:Macro`/`rmcp:Transport`/
//! `rmcp:Feature` do not yet have a dedicated hand-transcribed proof this
//! pass -- a disclosed, real gap (mirrors mcpp-pack's own "partial command
//! surface, not every #[verb]" honesty posture), not a silent omission.
//!
//! For real (non-tautological) behavior coverage of the generated
//! subsystem against the actual `rmcp` crate, see
//! `rmcp_stub_handler_proof.rs` (same pack).

#[path = "../src/rmcp_handler_catalog.rs"]
mod rmcp_handler_catalog;

use rmcp_handler_catalog::{RMCP_CLIENT_METHODS, RMCP_SERVER_METHODS, RmcpHandlerMethod};

/// The ontology defines exactly 27 `rmcp:HandlerMethod` individuals with
/// `rmcp:role "server"` (packs/rmcp-pack/ontology.ttl) -- hand count
/// against `rmcp::ServerHandler`'s real 27 trait methods, not a query
/// result.
#[test]
fn server_catalog_has_exactly_twenty_seven_methods() {
    assert_eq!(RMCP_SERVER_METHODS.len(), 27);
}

/// The ontology defines exactly 16 `rmcp:HandlerMethod` individuals with
/// `rmcp:role "client"` -- hand count against `rmcp::ClientHandler`'s real
/// 16 trait methods.
#[test]
fn client_catalog_has_exactly_sixteen_methods() {
    assert_eq!(RMCP_CLIENT_METHODS.len(), 16);
}

/// `call_tool` sorts first among the 27 server method names (ASCII
/// lexicographic `ORDER BY ?method_name`: "call_tool" precedes every other
/// server method name, including "cancel_task" -- '_' < 't' at the first
/// differing position after the shared "ca" + digraph check confirms
/// "call_tool" < "cancel_task" since 'l' < 'n'). Its default behavior text
/// is grounded in the method's own real doc comment
/// (src/handler/server.rs:283-310), a genuine API-design subtlety about
/// `Ok(CallToolResult::error(...))` vs `Err(McpError)`.
#[test]
fn first_server_row_is_call_tool_with_its_real_doc_grounded_default_behavior() {
    let row = RMCP_SERVER_METHODS[0];
    assert_eq!(row.method_name, "call_tool");
    assert_eq!(row.params_type, "CallToolRequestParams");
    assert_eq!(row.return_type, "CallToolResult");
    assert!(row.default_behavior.contains("CallToolResult::error"));
    assert_eq!(row.source_file, "src/handler/server.rs:311-317");
}

/// `unsubscribe` sorts last among the 27 server method names.
#[test]
fn last_server_row_is_unsubscribe() {
    let row = RMCP_SERVER_METHODS[26];
    assert_eq!(row.method_name, "unsubscribe");
    assert_eq!(row.params_type, "UnsubscribeRequestParams");
    assert_eq!(row.return_type, "()");
    assert_eq!(
        row.default_behavior,
        "Returns Err(McpError::method_not_found::<UnsubscribeRequestMethod>())."
    );
}

/// `create_elicitation` sorts first among the 16 client method names. Its
/// default behavior is grounded in the method's own real doc comment
/// (src/handler/client.rs:114-169), which includes a complete real
/// `impl ClientHandler for MyClient` example.
#[test]
fn first_client_row_is_create_elicitation() {
    let row = RMCP_CLIENT_METHODS[0];
    assert_eq!(row.method_name, "create_elicitation");
    assert_eq!(row.params_type, "ElicitRequestParams");
    assert_eq!(row.return_type, "ElicitResult");
    assert!(row.default_behavior.contains("Decline"));
    assert_eq!(row.source_file, "src/handler/client.rs:170-182");
}

/// `ping` sorts last among the 16 client method names.
#[test]
fn last_client_row_is_ping() {
    let row = RMCP_CLIENT_METHODS[15];
    assert_eq!(row.method_name, "ping");
    assert_eq!(row.params_type, "");
    assert_eq!(row.return_type, "()");
    assert_eq!(row.default_behavior, "Returns Ok(()) unconditionally.");
    assert_eq!(row.source_file, "src/handler/client.rs:90-95");
}

/// Exactly 4 real `ServerHandler` methods take no typed parameter beyond
/// `&self`/context (`ping`, `on_initialized`, `on_roots_list_changed`,
/// `get_info`) -- hand count against the real trait signatures in
/// src/handler/server.rs.
#[test]
fn exactly_four_server_methods_have_no_typed_params() {
    let count = RMCP_SERVER_METHODS
        .iter()
        .filter(|r| r.params_type.is_empty())
        .count();
    assert_eq!(count, 4);
}

/// Exactly 6 real `ClientHandler` methods take no typed parameter beyond
/// `&self`/context (`ping`, `list_roots`, `on_resource_list_changed`,
/// `on_tool_list_changed`, `on_prompt_list_changed`, `get_info`) -- hand
/// count against the real trait signatures in src/handler/client.rs.
#[test]
fn exactly_six_client_methods_have_no_typed_params() {
    let count = RMCP_CLIENT_METHODS
        .iter()
        .filter(|r| r.params_type.is_empty())
        .count();
    assert_eq!(count, 6);
}

/// General structural invariant: both catalogs must already be sorted
/// ascending by `method_name`. Not tautological: the "expected" side is a
/// fresh sort of a *copy* via `Ord`, not a second pass through the SPARQL
/// query that produced the arrays in the first place.
#[test]
fn both_catalogs_are_sorted_by_method_name() {
    let mut server_sorted: Vec<RmcpHandlerMethod> = RMCP_SERVER_METHODS.to_vec();
    server_sorted.sort_by_key(|r| r.method_name);
    assert_eq!(RMCP_SERVER_METHODS.to_vec(), server_sorted);

    let mut client_sorted: Vec<RmcpHandlerMethod> = RMCP_CLIENT_METHODS.to_vec();
    client_sorted.sort_by_key(|r| r.method_name);
    assert_eq!(RMCP_CLIENT_METHODS.to_vec(), client_sorted);
}

/// General structural invariant: no two rows within either role's catalog
/// may share the same `method_name` -- catches an accidentally duplicated
/// individual in the ontology that the hand-picked spot checks above would
/// not, by construction, ever notice.
#[test]
fn neither_catalog_has_duplicate_method_names() {
    for catalog in [RMCP_SERVER_METHODS, RMCP_CLIENT_METHODS] {
        let mut seen: Vec<&str> = Vec::new();
        for row in catalog {
            assert!(
                !seen.contains(&row.method_name),
                "duplicate method_name found: {:?}",
                row.method_name
            );
            seen.push(row.method_name);
        }
    }
}

/// Every row in both catalogs must carry a non-empty `source_file`
/// citation and a non-empty `default_behavior` -- every real trait method
/// has a real default body and a real location; an empty value would mean
/// an ontology edit added a method individual without grounding it.
#[test]
fn every_row_has_a_source_citation_and_default_behavior() {
    for catalog in [RMCP_SERVER_METHODS, RMCP_CLIENT_METHODS] {
        for row in catalog {
            assert!(
                !row.source_file.is_empty(),
                "row {:?}/{:?} has no source_file",
                row.role,
                row.method_name
            );
            assert!(
                !row.default_behavior.is_empty(),
                "row {:?}/{:?} has no default_behavior",
                row.role,
                row.method_name
            );
        }
    }
}

/// `role` is either "server" or "client", and matches which array the row
/// lives in -- catches a copy-paste error in a future ontology edit that
/// tagged a client method with `rmcp:role "server"` or vice versa.
#[test]
fn role_field_matches_the_array_each_row_lives_in() {
    for row in RMCP_SERVER_METHODS {
        assert_eq!(row.role, "server");
    }
    for row in RMCP_CLIENT_METHODS {
        assert_eq!(row.role, "client");
    }
}
