use rmcp::ServerHandler;

/// A handler with ZERO method overrides -- every behavior exercised below
/// comes exclusively from `rmcp::ServerHandler`'s own default trait-method
/// bodies (rmcp-2.2.0 `src/handler/server.rs`, `server_handler_methods!`),
/// not from this pack's `RmcpStubHandler` or any `#[tool]`/`#[tool_router]`/
/// `#[tool_handler]` macro.
#[derive(Debug, Clone, Default)]
struct RmcpDefaultHandler;

impl ServerHandler for RmcpDefaultHandler {}

{% for row in get_tool_row %}
/// Live ontology fact for `get_tool` as of this sync run (params_type
/// "{{ row.params_type }}", return_type "{{ row.return_type }}", source_file
/// "{{ row.source_file }}"), freshly baked from the `get_tool_row` SPARQL
/// result -- never hand-typed.
const LIVE_GET_TOOL_DEFAULT_BEHAVIOR: &str = "{{ row.default_behavior | replace(from='"', to="'") }}";
{% endfor %}

/// Floor sanity check: the `get_tool_row` SPARQL query must have returned
/// its one row (the ontology models `get_tool` exactly once) AND that row's
/// own text must still claim the behavior this proof is about to exercise
/// live. If this fails, either the ontology lost/changed the individual or
/// the query itself is broken -- catch that BEFORE trusting the
/// refusal-path assertions below.
#[test]
fn ontology_still_claims_get_tool_returns_none() {
    assert!(
        LIVE_GET_TOOL_DEFAULT_BEHAVIOR.contains("None"),
        "packs/rmcp-pack/ontology.ttl's own rmcp:defaultBehavior for get_tool no longer \
         mentions returning None -- either the ontology changed or the sparql: query \
         returned the wrong row (LIVE_GET_TOOL_DEFAULT_BEHAVIOR = {LIVE_GET_TOOL_DEFAULT_BEHAVIOR:?})"
    );
}

/// REAL refusal-path proof: calling `get_tool` on a handler with NO
/// overrides and NO macros returns `None` for an arbitrary, nonexistent
/// tool name -- exercising the actual compiled `rmcp::ServerHandler`
/// default body, not a mock and not this pack's own generated catalog text.
#[test]
fn default_handler_get_tool_genuinely_returns_none_for_an_unregistered_name() {
    let handler = RmcpDefaultHandler;
    let result = handler.get_tool("this-tool-does-not-exist-and-never-will");
    assert_eq!(
        result, None,
        "rmcp::ServerHandler's real default get_tool() body no longer returns None for an \
         unregistered handler -- either rmcp's own behavior changed or this proof's call \
         path is wrong"
    );
}

/// Adversarial input: an empty tool name still refuses (returns `None`),
/// not a panic and not `Some(..)` -- rules out a coincidental match against
/// one "normal-looking" probe string.
#[test]
fn default_handler_get_tool_refuses_an_empty_name_without_panicking() {
    let handler = RmcpDefaultHandler;
    assert_eq!(handler.get_tool(""), None);
}

/// Adversarial input: a long, adversarial-looking tool name (path-traversal
/// / injection-shaped) still just refuses cleanly -- `get_tool`'s real
/// default body does no parsing or lookup at all (`fn get_tool(&self,
/// _name: &str) -> Option<Tool> { None }`, rmcp-2.2.0
/// `src/handler/server.rs:329-331`), so no input shape can make it panic or
/// return `Some(..)`.
#[test]
fn default_handler_get_tool_refuses_an_adversarial_looking_name() {
    let handler = RmcpDefaultHandler;
    let adversarial = "../../../etc/passwd\0; DROP TABLE tools; --".repeat(4);
    assert_eq!(handler.get_tool(&adversarial), None);
}

/// `RmcpDefaultHandler` is real, constructible, `Default`-derived, and
/// genuinely distinct from `rmcp_stub_handler::RmcpStubHandler` (a
/// different type, defined only in this file, zero macro attributes) --
/// not an alias or a re-export of the stub.
#[test]
fn default_handler_is_constructible_via_default() {
    let handler = RmcpDefaultHandler::default();
    assert_eq!(handler.get_tool("echo"), None);
}
