---
to: src/rmcp_macro_catalog.rs
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/rmcp-pack
sparql:
  rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?macro_name ?macro_kind ?applies_to ?macro_fields ?source_file WHERE {
      ?m a rmcp:Macro ; rmcp:macroName ?macro_name ; rmcp:macroKind ?macro_kind ;
         rmcp:appliesTo ?applies_to ; rmcp:macroFields ?macro_fields ;
         rmcp:sourceFile ?source_file .
    } ORDER BY ?macro_name
---
//! Typed catalog of the real `#[proc_macro_attribute]` fns exported by the
//! `rmcp-macros` sibling crate (7 total): `tool`, `tool_router`,
//! `tool_handler`, `prompt`, `prompt_router`, `prompt_handler`,
//! `task_handler`.
//!
//! Generated by `rmcp-pack` from `packs/rmcp-pack/ontology.ttl`. Reference
//! only -- see `rmcp_stub_handler.rs` (same pack) for a real, compiling
//! invocation of `tool_router`/`tool`/`tool_handler`.

/// One real `rmcp-macros` `#[proc_macro_attribute]` fn.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct RmcpMacro {
    pub macro_name: &'static str,
    /// "attribute" for all 7 -- every one is `#[proc_macro_attribute]`.
    pub macro_kind: &'static str,
    /// The real `syn` AST node the macro's implementation parses its
    /// `input` `TokenStream` into: "fn" (`syn::ImplItemFn`) or "impl"
    /// (`syn::ItemImpl`).
    pub applies_to: &'static str,
    /// `field|type|usage` groups, `@@`-joined, transcribed verbatim from
    /// the macro's own real doc table (3 columns -- no "required" column
    /// exists in the real source; see ontology.ttl's rmcp:macroFields
    /// comment for why this differs from clap-noun-verb-pack's 4-column
    /// cnv:args grammar).
    pub macro_fields: &'static str,
    /// file:line citation into the real vendored `rmcp-macros-2.2.0`
    /// source.
    pub source_file: &'static str,
}

/// All 7 real `rmcp-macros` attribute macros, ordered by name.
pub const RMCP_MACROS: &[RmcpMacro] = &[
{% for row in rows %}    RmcpMacro { macro_name: "{{ row.macro_name }}", macro_kind: "{{ row.macro_kind }}", applies_to: "{{ row.applies_to }}", macro_fields: "{{ row.macro_fields | replace(from='"', to="'") }}", source_file: "{{ row.source_file | replace(from='"', to="'") }}" },
{% endfor %}];
