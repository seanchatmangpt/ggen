---
to: src/rmcp_handler_catalog.rs
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/rmcp-pack
sparql:
  server_rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?role ?method_name ?params_type ?return_type ?default_behavior ?source_file WHERE {
      ?m a rmcp:HandlerMethod ; rmcp:role ?role ; rmcp:methodName ?method_name ;
         rmcp:paramsType ?params_type ; rmcp:returnType ?return_type ;
         rmcp:defaultBehavior ?default_behavior ; rmcp:sourceFile ?source_file .
      FILTER(?role = "server")
    } ORDER BY ?method_name
  client_rows: >
    PREFIX rmcp: <http://seanchatmangpt.github.io/packs/rmcp#>
    SELECT ?role ?method_name ?params_type ?return_type ?default_behavior ?source_file WHERE {
      ?m a rmcp:HandlerMethod ; rmcp:role ?role ; rmcp:methodName ?method_name ;
         rmcp:paramsType ?params_type ; rmcp:returnType ?return_type ;
         rmcp:defaultBehavior ?default_behavior ; rmcp:sourceFile ?source_file .
      FILTER(?role = "client")
    } ORDER BY ?method_name
---
{%- set server_count = server_rows | length -%}
{%- set client_count = client_rows | length -%}
{%- set total_count = server_count + client_count -%}
//! Typed catalog of the real `rmcp::ServerHandler` / `rmcp::ClientHandler`
//! trait methods ({{ total_count }} total: {{ server_count }} server +
//! {{ client_count }} client).
//!
//! Generated by `rmcp-pack` from `packs/rmcp-pack/ontology.ttl`, which was
//! read directly from the real vendored `rmcp` v2.2.0 source (see the
//! ontology's own header for the grounding method and file:line citations).
//! Reference only -- this module does not implement either trait; see
//! `rmcp_stub_handler.rs` (same pack) for a real, compiling
//! `impl ServerHandler` exercising the macro-based subset of this surface.

/// One `rmcp::ServerHandler` or `rmcp::ClientHandler` trait method row.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct RmcpHandlerMethod {
    pub role: &'static str,
    pub method_name: &'static str,
    /// The real Rust type of the method's request/notification parameter,
    /// exactly as it appears in the trait signature. Empty string for
    /// methods that take no typed parameter beyond `&self`/context.
    pub params_type: &'static str,
    /// The real `Ok(T)` (or plain, for sync/notification methods) return
    /// type.
    pub return_type: &'static str,
    /// One real sentence summarizing the method's actual default
    /// trait-method body, transcribed from the real source.
    pub default_behavior: &'static str,
    /// file:line citation into the real vendored `rmcp-2.2.0` source.
    pub source_file: &'static str,
}

/// All 27 real `rmcp::ServerHandler` methods, ordered by method name.
pub const RMCP_SERVER_METHODS: &[RmcpHandlerMethod] = &[
{% for row in server_rows %}    RmcpHandlerMethod { role: "{{ row.role }}", method_name: "{{ row.method_name }}", params_type: "{{ row.params_type }}", return_type: "{{ row.return_type }}", default_behavior: "{{ row.default_behavior | replace(from='"', to="'") }}", source_file: "{{ row.source_file | replace(from='"', to="'") }}" },
{% endfor %}];

/// All 16 real `rmcp::ClientHandler` methods, ordered by method name.
pub const RMCP_CLIENT_METHODS: &[RmcpHandlerMethod] = &[
{% for row in client_rows %}    RmcpHandlerMethod { role: "{{ row.role }}", method_name: "{{ row.method_name }}", params_type: "{{ row.params_type }}", return_type: "{{ row.return_type }}", default_behavior: "{{ row.default_behavior | replace(from='"', to="'") }}", source_file: "{{ row.source_file | replace(from='"', to="'") }}" },
{% endfor %}];
