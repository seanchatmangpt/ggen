# body (lines 182-428); get_tool (329-331) and get_info (389-391) are the
# two real sync (non-async, non-Result) methods in the whole trait.

rmcp:server-enqueue-task
    a rmcp:HandlerMethod ; rmcp:role "server" ; rmcp:methodName "enqueue_task" ;
    rmcp:paramsType "CallToolRequestParams" ; rmcp:returnType "CreateTaskResult" ;
    rmcp:defaultBehavior "Returns Err(McpError::internal_error(\"Task processing not implemented\", None)) -- task-based tool invocation is opt-in via #[task_handler]." ;
    rmcp:sourceFile "src/handler/server.rs:184-193" .

rmcp:server-ping
    a rmcp:HandlerMethod ; rmcp:role "server" ; rmcp:methodName "ping" ;
    rmcp:paramsType "" ; rmcp:returnType "()" ;
    rmcp:defaultBehavior "Returns Ok(()) unconditionally." ;
    rmcp:sourceFile "src/handler/server.rs:194-199" .

