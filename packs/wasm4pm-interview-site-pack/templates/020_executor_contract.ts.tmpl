/**
 * InterviewAssist Phase 0 executor dispatch contract (generated by
 * `wasm4pm-interview-site-pack`).
 *
 * Pure typed request/response/refusal shapes plus a precondition helper.
 * Contains no subprocess, filesystem, or execution code -- a real
 * implementation (isolation, timeout, stdout/stderr/exit-code capture)
 * belongs in the consuming project's hand-written `lib/executor.ts`. Same
 * boundary as `sandbox_actuator_trait.rs` on the Rust side.
 */

import type { CapabilityId } from "./capabilities";

export interface ExecutionRequest {
  capability: CapabilityId;
  /** path (relative to the isolated workspace root) -> file content. */
  files: Record<string, string>;
  /**
   * The capability's admitted timeout, in milliseconds -- populated by the
   * generated route from `capabilityInfo(capability).timeoutMs`. Carrying
   * this on the request itself (rather than leaving each executor to look
   * it up on its own) means the contract structurally guarantees every
   * executor implementation receives the catalog's declared bound, instead
   * of relying on implementation discipline.
   */
  timeoutMs: number;
}

export interface ExecutionReceipt {
  capability: CapabilityId;
  exitCode: number;
  stdout: string;
  stderr: string;
  durationMs: number;
}

export type ExecutionRefusal =
  | { kind: "no_source_provided" }
  | { kind: "timeout" }
  | { kind: "payload_too_large"; maxBytes: number }
  | { kind: "executor_unavailable"; reason: string };

export interface Executor {
  execute(request: ExecutionRequest): Promise<ExecutionReceipt | ExecutionRefusal>;
}

export function isExecutionRefusal(result: ExecutionReceipt | ExecutionRefusal): result is ExecutionRefusal {
  return "kind" in result;
}
