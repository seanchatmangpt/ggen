---
to: "package.json"
sparql:
  apps: |
    PREFIX site: <https://ggen.dev/packs/wasm4pm-interview-site#>
    SELECT ?packageName WHERE {
      ?app a site:Application ; site:packageName ?packageName .
    } LIMIT 1
---
{% for app in apps %}{
  "name": "{{ app.packageName }}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "next": "16.2.11",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@types/node": "24.1.0",
    "@types/react": "19.1.9",
    "@types/react-dom": "19.1.7",
    "typescript": "5.8.3",
    "vite": "7.0.6",
    "vitest": "3.2.4"
  }
}
{% endfor %}
