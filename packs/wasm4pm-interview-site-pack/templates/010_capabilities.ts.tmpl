---
to: "lib/capabilities.ts"
sparql:
  capabilities: |
    PREFIX site: <https://ggen.dev/packs/wasm4pm-interview-site#>
    SELECT ?capability_id ?capability_label ?category ?http_method ?route ?doc ?timeout_ms ?authority_scope ?executes_code WHERE {
      ?c a site:InterviewCapability ;
         site:capabilityId ?capability_id ;
         site:capabilityLabel ?capability_label ;
         site:category ?category ;
         site:httpMethod ?http_method ;
         site:route ?route ;
         site:doc ?doc ;
         site:timeoutMs ?timeout_ms ;
         site:authorityScope ?authority_scope ;
         site:executesCode ?executes_code .
    } ORDER BY ?capability_id
---
/**
 * InterviewAssist Phase 0 sandbox capability catalog (generated by
 * `wasm4pm-interview-site-pack`).
 *
 * First-class source rendered from `site:InterviewCapability` individuals
 * in the pack ontology. To change a capability, edit the pack ontology and
 * re-run `ggen sync`. Catalog surface only: this file contains no
 * subprocess/execution code -- the real executor is `lib/executor.ts`
 * (hand-written, implements the contract in `lib/executor-contract.ts`).
 *
 * `compile_python`/`execute_python`/`run_pytest`/`compile_rust`/
 * `execute_rust`/`run_cargo_test` intentionally share their capabilityId
 * strings with `wasm4pm-sandbox-pack`'s Rust `CapabilityId` enum -- both
 * describe the same six capabilities from two runtime surfaces.
 */

export type CapabilityId =
{% for row in capabilities %}  | "{{ row.capability_id }}"
{% endfor %};

export type Category = "session" | "problem" | "editor" | "runtime" | "verification";
export type HttpMethod = "GET" | "POST";

export interface CapabilityInfo {
  id: CapabilityId;
  label: string;
  category: Category;
  httpMethod: HttpMethod;
  route: string;
  doc: string;
  timeoutMs: number;
  authorityScope: string;
  /** Whether this capability's route dispatches to the real executor. */
  executesCode: boolean;
}

export const CAPABILITY_CATALOG: readonly CapabilityInfo[] = [
{% for row in capabilities %}  {
    id: "{{ row.capability_id }}",
    label: "{{ row.capability_label }}",
    category: "{{ row.category }}",
    httpMethod: "{{ row.http_method }}",
    route: "{{ row.route }}",
    doc: "{{ row.doc | addslashes }}",
    timeoutMs: {{ row.timeout_ms }},
    authorityScope: "{{ row.authority_scope }}",
    executesCode: {{ row.executes_code }},
  },
{% endfor %}];

const BY_ID: ReadonlyMap<string, CapabilityInfo> = new Map(CAPABILITY_CATALOG.map((c) => [c.id, c]));

export function capabilityInfo(id: CapabilityId): CapabilityInfo {
  const info = BY_ID.get(id);
  if (!info) throw new Error(`no CAPABILITY_CATALOG entry for capabilityId=${id}`);
  return info;
}

export function isCapabilityId(value: string): value is CapabilityId {
  return BY_ID.has(value);
}

/** All capability ids whose route dispatches to the real executor. */
export function executingCapabilityIds(): CapabilityId[] {
  return CAPABILITY_CATALOG.filter((c) => c.executesCode).map((c) => c.id);
}
