@prefix gec: <http://seanchatmangpt.github.io/packs/rust-dialect#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Grounded ABox fixtures for the GEC ontology + shapes. Every
# individual below corresponds to a real file:line in this repo
# as re-verified on 2026-07-21 (see ontology.ttl header). These
# exist so shapes.ttl's sh:sparql rules have real conforming AND
# real violating cases to run against, not synthetic examples.
#################################################################

#################################################################
# Artifacts
#################################################################

gec:Artifact_TcpsFfiLib a gec:Artifact ;
    gec:sourcePack "tcps-ffi-pack" ;
    gec:templatePath "packs/tcps-ffi-pack/templates/lib.rs.tmpl" ;
    gec:outputPath "crates/tcps-ffi/src/lib.rs" ;
    gec:ffiBoundary true ;
    gec:crateAttribute "#![deny(unsafe_op_in_unsafe_fn)]", "#![deny(missing_debug_implementations)]" ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "Real unsafe keyword via #[unsafe(export_name=...)] on pub extern \"C\" fn — lib.rs.tmpl:37,42" .

gec:Artifact_AffidavitTypes a gec:Artifact ;
    gec:sourcePack "affidavit-pack" ;
    gec:templatePath "packs/affidavit-pack/templates/affidavit_types.rs.tmpl" ;
    gec:outputPath "src/affidavit_types.rs" ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason
        "Lifetime-generic trait impl impl<'de> Deserialize<'de> for Receipt — L112",
        "Bounded generic fn canonical_bytes<T: Serialize> — L186",
        "impl Into<String> argument-position impl-Trait — L77",
        "Hand-written (non-derived) Deserialize with nested in-fn struct and closure-driven BTreeMap sort — L193-208" .

gec:Artifact_CargoCicdCatalog a gec:Artifact ;
    gec:sourcePack "cargo-cicd-pack" ;
    gec:templatePath "packs/cargo-cicd-pack/templates/cargo_cicd_catalog.rs.tmpl" ;
    gec:outputPath "src/cargo_cicd_catalog.rs" ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "-> impl Iterator<Item = &'static CargoCicdCommand> + '_ return-position impl-Trait with anonymous lifetime and move closure — L75" .

gec:Artifact_TcpsCoreOntology_実行器 a gec:Artifact ;
    gec:sourcePack "tcps-core-pack" ;
    gec:templatePath "packs/tcps-core-pack/ontology.ttl (tcps:sourceText literal)" ;
    gec:outputPath "src/青い川のダム.rs" ;
    gec:crateAttribute "#![no_std]" ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "pub trait 実行器 { type 成果; type 失敗; ... } — associated types, Self:: projection — ontology.ttl:1433-1442" .

gec:Artifact_TcpsCoreOntology_ポカヨケ a gec:Artifact ;
    gec:sourcePack "tcps-core-pack" ;
    gec:templatePath "packs/tcps-core-pack/ontology.ttl (tcps:sourceText literal)" ;
    gec:outputPath "src/ポカヨケ.rs" ;
    gec:crateAttribute "#![no_std]" ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "pub trait 防止条件<入力> { ... } generic trait + two concrete impls — ontology.ttl:1577-1616" .

gec:Artifact_TcpsFfiCargoCicdOsxClnrDispatchProofs a gec:Artifact ;
    gec:sourcePack "cargo-cicd-pack" ;
    gec:templatePath "packs/cargo-cicd-pack/templates/cargo_cicd_dispatch_proof.rs.tmpl" ;
    gec:outputPath "tests/cargo_cicd_dispatch_proof.rs" ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "&dyn Fn(&[String]) -> std::io::Result<std::process::Output> trait object — L137" .

gec:Artifact_OsxClnrDispatch a gec:Artifact ;
    gec:sourcePack "osx-clnr-pack" ;
    gec:templatePath "packs/osx-clnr-pack/templates/osx_clnr_dispatch.rs.tmpl" ;
    gec:outputPath "src/osx_clnr_dispatch.rs" ;
    gec:dialectStatus gec:InCore ;
    gec:crateAttribute "" .
    # Non-generic project trait (OclnrHandlerSeam, L50) with plain &self methods stays InCore.
    # Its own dispatch_proof.rs.tmpl sibling (below) is the NamedException file — the trait
    # *definition* and the *test that exercises it as &dyn* are different Artifacts.

gec:Artifact_OsxClnrDispatchProof a gec:Artifact ;
    gec:sourcePack "osx-clnr-pack" ;
    gec:templatePath "packs/osx-clnr-pack/templates/osx_clnr_dispatch_proof.rs.tmpl" ;
    gec:outputPath "tests/osx_clnr_dispatch_proof.rs" ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "let h: &dyn OclnrHandlerSeam = &DummyHandlers; — L69" .

gec:Artifact_AntiLlmCheatCatalog a gec:Artifact ;
    gec:sourcePack "anti-llm-cheat-lsp-pack" ;
    gec:templatePath "packs/anti-llm-cheat-lsp-pack/templates/anti_llm_cheat_catalog.rs.tmpl" ;
    gec:outputPath "src/anti_llm_cheat_catalog.rs" ;
    gec:dialectStatus gec:InCoreHeightenedComplexity ;
    gec:exceptionReason "N/A (not a NamedException — HeightenedComplexity only): byte-slicing lexer extract_fn_name, static OnceLock<Regex> + get_or_init (L65,277,284), stateful mutable-flag for loop over block comments" .

#################################################################
# Trait definitions + impls
#################################################################

gec:Trait_OclnrHandlerSeam a gec:TraitDefinition ;
    gec:traitName "OclnrHandlerSeam" ;
    gec:definedIn gec:Artifact_OsxClnrDispatch ;
    gec:dialectStatus gec:InCore .
    # zero gec:hasAssociatedType, zero gec:genericParam — osx_clnr_dispatch.rs.tmpl:50-55

gec:Trait_実行器 a gec:TraitDefinition ;
    gec:traitName "実行器" ;
    gec:definedIn gec:Artifact_TcpsCoreOntology_実行器 ;
    gec:hasAssociatedType gec:AssocType_成果, gec:AssocType_失敗 ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "trait declares associated types 成果/失敗 — tcps ontology.ttl:1434-1435" .

gec:AssocType_成果 a gec:AssociatedTypeDecl ; gec:assocName "成果" .
gec:AssocType_失敗 a gec:AssociatedTypeDecl ; gec:assocName "失敗" .

gec:Trait_防止条件 a gec:TraitDefinition ;
    gec:traitName "防止条件" ;
    gec:definedIn gec:Artifact_TcpsCoreOntology_ポカヨケ ;
    gec:genericParam gec:GenericParam_防止条件_入力 ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "generic trait definition, generic over 入力 — tcps ontology.ttl:1577" .

gec:GenericParam_防止条件_入力 a gec:TypeGenericParam ;
    gec:paramName "入力" .
    # unbounded on its own, but the trait is still NamedException because it is a *generic
    # trait definition* — the exception rule keys on generic-trait-DEFINITION, not on any
    # particular param having a bound (see gec:TraitDefinitionExceptionRule in shapes.ttl).

gec:Impl_防止条件_u32_範囲防止 a gec:TraitImpl ;
    gec:implementsTrait gec:Trait_防止条件 ;
    gec:forType [ a gec:PathType ; gec:typePath "範囲防止" ] ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "inherits NamedException from gec:Trait_防止条件 (implements a generic trait) — tcps ontology.ttl:1588" .
    # inherits NamedException from gec:Trait_防止条件 per gec:TraitImplInheritsTraitExceptionShape
    # even though this impl block itself (ontology.ttl:1588) carries no generic/lifetime params.

gec:ExternalTrait_Deserialize a gec:TraitDefinition ;
    gec:traitName "Deserialize" ;
    gec:externalTrait true ;
    gec:dialectStatus gec:InCore ;
    gec:exceptionReason "N/A — the external trait declaration itself is not the exception; the *impl*'s own LifetimeGenericParam ('de) is what makes gec:Impl_Deserialize_Receipt a NamedException. dialectStatus is asserted InCore here only to satisfy TraitDefinitionShape's cardinality; the interesting exception lives on the TraitImpl, not this stub." .

gec:Impl_Deserialize_Receipt a gec:TraitImpl ;
    gec:implementsTrait gec:ExternalTrait_Deserialize ;
    gec:forType [ a gec:PathType ; gec:typePath "Receipt" ] ;
    gec:genericParam [ a gec:LifetimeGenericParam ; gec:paramName "de" ] ;
    gec:definedIn gec:Artifact_AffidavitTypes ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "impl<'de> Deserialize<'de> for Receipt — lifetime-generic trait impl — affidavit_types.rs.tmpl:112" .

gec:Impl_有無_値 a gec:InherentImpl ;
    gec:forType [ a gec:GenericType ;
        gec:baseType [ a gec:PathType ; gec:typePath "有無" ] ;
        gec:hasArgument [ a gec:TypeArgumentType ; gec:argPosition 0 ;
            gec:argType [ a gec:TypeParamRef ; gec:refersToParam "値" ] ] ] ;
    gec:genericParam [ a gec:TypeGenericParam ; gec:paramName "値" ] ;
    gec:dialectStatus gec:InCore .
    # Genuinely an INHERENT impl (no trait), corrected from an earlier gec:TraitImpl typing
    # that failed gec:implementsTrait's min-count-1 constraint under real pyshacl validation.
    # ontology.ttl:13. Zero paramBound on 値.

gec:Impl_成否_成功_失敗 a gec:InherentImpl ;
    gec:forType [ a gec:GenericType ;
        gec:baseType [ a gec:PathType ; gec:typePath "成否" ] ;
        gec:hasArgument [ a gec:TypeArgumentType ; gec:argPosition 0 ;
                          gec:argType [ a gec:TypeParamRef ; gec:refersToParam "成功" ] ],
                        [ a gec:TypeArgumentType ; gec:argPosition 1 ;
                          gec:argType [ a gec:TypeParamRef ; gec:refersToParam "失敗" ] ] ] ;
    gec:genericParam [ a gec:TypeGenericParam ; gec:paramName "成功" ],
                     [ a gec:TypeGenericParam ; gec:paramName "失敗" ] ;
    gec:dialectStatus gec:InCore .
    # ontology.ttl:29 — INHERENT impl (no trait), TWO unbounded type params, both zero
    # gec:paramBound. This is the instance that corrects the "single-type-param" paraphrase:
    # the rule is "any count of unbounded type params", grounded here directly against the
    # corpus, not "single".

gec:Impl_系譜台帳_constN a gec:InherentImpl ;
    gec:forType [ a gec:GenericType ;
        gec:baseType [ a gec:PathType ; gec:typePath "系譜台帳" ] ;
        gec:hasArgument [ a gec:TypeArgumentConst ; gec:argPosition 0 ;
            gec:argConstValue "上限" ; gec:argConstIsParamRef true ] ] ;
    gec:genericParam [ a gec:ConstGenericParam ; gec:paramName "上限" ; gec:constParamType "usize" ] ;
    gec:dialectStatus gec:InCore .
    # ontology.ttl:200 — INHERENT impl<const 上限: usize> 系譜台帳<上限>

