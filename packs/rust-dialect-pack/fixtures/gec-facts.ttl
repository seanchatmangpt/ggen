gec:Fn_canonical_bytes a gec:FunctionSignature ;
    gec:fnName "canonical_bytes" ;
    gec:definedIn gec:Artifact_AffidavitTypes ;
    gec:receiverKind gec:NoReceiver ;
    gec:genericParam [ a gec:TypeGenericParam ; gec:paramName "T" ; gec:paramBound "Serialize" ] ;
    gec:hasParameter [ a gec:Parameter ; gec:paramIndex 0 ; gec:paramName "value" ;
        gec:paramType [ a gec:ReferenceType ; gec:mutable false ;
            gec:referent [ a gec:TypeParamRef ; gec:refersToParam "T" ] ] ] ;
    gec:returnType [ a gec:GenericType ;
        gec:baseType [ a gec:PathType ; gec:typePath "Result" ] ;
        gec:hasArgument
            [ a gec:TypeArgumentType ; gec:argPosition 0 ;
              gec:argType [ a gec:GenericType ;
                  gec:baseType [ a gec:PathType ; gec:typePath "Vec" ] ;
                  gec:hasArgument [ a gec:TypeArgumentType ; gec:argPosition 0 ;
                      gec:argType [ a gec:PrimitiveType ; gec:primitiveName "u8" ] ] ] ],
            [ a gec:TypeArgumentType ; gec:argPosition 1 ;
              gec:argType [ a gec:PathType ; gec:typePath "serde_json::Error" ] ] ] ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "bounded generic param T: Serialize — affidavit_types.rs.tmpl:186" .

gec:Fn_handle_snapshot_thin_bytes_budget a gec:FunctionSignature ;
    gec:fnName "handle_snapshot_thin_bytes_budget" ;
    gec:definedIn gec:Artifact_OsxClnrDispatch ;
    gec:receiverKind gec:NoReceiver ;
    gec:hasParameter [ a gec:Parameter ; gec:paramIndex 0 ; gec:paramName "bytes" ;
        gec:paramType [ a gec:ReferenceType ; gec:mutable false ;
            gec:referent [ a gec:PrimitiveType ; gec:primitiveName "str" ] ] ] ;
    gec:returnType [ a gec:GenericType ;
        gec:baseType [ a gec:PathType ; gec:typePath "Result" ] ;
        gec:hasArgument [ a gec:TypeArgumentType ; gec:argPosition 0 ;
                          gec:argType [ a gec:PrimitiveType ; gec:primitiveName "u64" ] ],
                        [ a gec:TypeArgumentType ; gec:argPosition 1 ;
                          gec:argType [ a gec:PathType ; gec:typePath "String" ] ] ] .
