    gec:definedIn gec:Artifact_TcpsFfiLib ;
    gec:receiverKind gec:NoReceiver ;
    gec:abi "C" ;
    gec:hasParameter [ a gec:Parameter ; gec:paramIndex 0 ; gec:paramName "要求" ;
        gec:paramType [ a gec:PathType ; gec:typePath "外部選択要求" ] ] ;
    gec:returnType [ a gec:PathType ; gec:typePath "外部選択結果" ] .
    # lib.rs.tmpl:42-79

gec:Effect_選択する外部関数_unsafe a gec:UnsafeAttributeEffect ;
    gec:effectOf gec:Fn_選択する外部関数 ;
    gec:exportName "tcps_select_v1" ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "#[unsafe(export_name = \"tcps_select_v1\")] — lib.rs.tmpl:42" .

gec:Effect_選択する外部関数_extern a gec:ExternAbiEffect ;
    gec:effectOf gec:Fn_選択する外部関数 ;
