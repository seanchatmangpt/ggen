#################################################################
# Ownership-transfer edges (worked example: 選択する外部関数)
#################################################################

gec:Local_方策 a gec:LocalBinding ;
    gec:bindingName "方策" ; gec:isMutBinding false ;
    gec:bindingType [ a gec:PathType ; gec:typePath "正準方策" ] .
    # let 方策 = 正準方策(); — lib.rs.tmpl:44

gec:Local_作業領域 a gec:LocalBinding ;
    gec:bindingName "作業領域" ; gec:isMutBinding true ;
    gec:bindingType [ a gec:GenericType ;
        gec:baseType [ a gec:PathType ; gec:typePath "作業領域" ] ;
        gec:hasArgument [ a gec:TypeArgumentConst ; gec:argPosition 0 ; gec:argConstValue "3" ] ] .
    # let mut 作業領域 = 作業領域::<3>::新規(); — lib.rs.tmpl:45

gec:Local_要求 a gec:LocalBinding ;
    gec:bindingName "要求" ; gec:isMutBinding false ;
    gec:bindingType [ a gec:PathType ; gec:typePath "選択要求" ] .
    # let 要求 = 選択要求 { ... }; (shadows the fn param) — lib.rs.tmpl:46-53

gec:Edge_方策_sharedBorrow a gec:OwnershipEdge ;
    gec:ownershipTransferKind gec:BorrowSharedTransfer ;
    gec:fromSite gec:Local_方策 ;
    gec:toSite [ a gec:Parameter ; gec:paramIndex 0 ; gec:paramName "方策" ] ;
    gec:withinFunction gec:Fn_選択する外部関数 .
    # 選択する(&方策, 要求, &mut 作業領域) — lib.rs.tmpl:55

gec:Edge_作業領域_mutBorrow a gec:OwnershipEdge ;
    gec:ownershipTransferKind gec:BorrowMutTransfer ;
    gec:fromSite gec:Local_作業領域 ;
    gec:toSite [ a gec:Parameter ; gec:paramIndex 2 ; gec:paramName "作業領域" ] ;
    gec:withinFunction gec:Fn_選択する外部関数 .

gec:Edge_要求_move a gec:OwnershipEdge ;
    gec:ownershipTransferKind gec:MoveTransfer ;
    gec:fromSite gec:Local_要求 ;
    gec:toSite [ a gec:Parameter ; gec:paramIndex 1 ; gec:paramName "要求" ] ;
    gec:withinFunction gec:Fn_選択する外部関数 .
    # 要求 passed by value, not by reference, into 選択する(...) — a real move, distinct
    # from the field-level copies (取得権限 etc., all u64/u32/u8 Copy types) that built it.

gec:Field_要求_取得権限 a gec:StructFieldSite ;
    gec:ownerStruct [ a gec:PathType ; gec:typePath "選択要求" ] ;
    gec:fieldName "取得権限" .

gec:Edge_取得権限_copy a gec:OwnershipEdge ;
    gec:ownershipTransferKind gec:CopyTransfer ;
    gec:fromSite [ a gec:StructFieldSite ; gec:ownerStruct [ a gec:PathType ; gec:typePath "外部選択要求" ] ; gec:fieldName "取得権限" ] ;
    gec:toSite gec:Field_要求_取得権限 ;
    gec:withinFunction gec:Fn_選択する外部関数 .
    # 取得権限: 要求.取得権限 — u64 is Copy — lib.rs.tmpl:47

#################################################################
# Effect facts: macro consumption + panic/regex (heightened complexity)
#################################################################

gec:Effect_AffidavitChain_thiserror a gec:MacroConsumptionEffect ;
    gec:macroKindProp gec:DeriveMacro ;
    gec:macroPath "thiserror::Error" .
    # #[derive(Debug, thiserror::Error)] — affidavit_chain.rs.tmpl:37

gec:Variant_AffidavitChain_IoError a gec:ThiserrorVariant ;
    gec:variantName "Io" ;
    gec:errorMessageTemplate "io error at {path}: {source}" ;
    gec:hasFromConversion true ;
    gec:belongsToErrorEnum [ a gec:PathType ; gec:typePath "AffidavitChainError" ] .
    # #[error("io error at {path}: {source}")] — affidavit_chain.rs.tmpl:43

gec:Effect_ClapNounVerb_verb a gec:MacroConsumptionEffect ;
    gec:macroKindProp gec:AttributeMacro ;
    gec:macroPath "clap_noun_verb_macros::verb" .
    # #[verb("{{ cmd.verb }}", "{{ cmd.noun }}")] — clap_noun_verb_routes.rs.tmpl:29

gec:Effect_AntiLlmCheat_regex a gec:RegexCompilationEffect ;
    gec:effectOf gec:Artifact_AntiLlmCheatCatalog .
    # static RE: OnceLock<Regex> = OnceLock::new(); ... Regex::new(pattern).unwrap() — L277,284

gec:Effect_AntiLlmCheat_panic a gec:PotentialPanicEffect ;
    gec:effectOf gec:Artifact_AntiLlmCheatCatalog ;
    gec:panicSite ".unwrap()" .
    # Regex::new(pattern).unwrap() — L284; owning Artifact stays InCoreHeightenedComplexity,
    # not NamedException, per gec:PotentialPanicNeverForcesExceptionShape.

#################################################################
# Impl-Trait / dyn-Trait structural instances
#
# Added to exercise rules/060 and rules/070 (packs/rust-dialect-pack/rules/) —
# ontology.ttl's own gec:ImplPosition/gec:DynTraitObjectConstruct comments cited
# these five sites by file:line already; every citation below was independently
# re-read against the live template on 2026-07-21 before transcription (not
# carried over from ontology.ttl's prose unverified).
#################################################################

gec:Fn_from_hex a gec:FunctionSignature ;
    gec:fnName "from_hex" ;
    gec:definedIn gec:Artifact_AffidavitTypes ;
    gec:receiverKind gec:NoReceiver ;
    gec:hasParameter [ a gec:Parameter ; gec:paramIndex 0 ; gec:paramName "hex" ;
        gec:paramType gec:ImplTrait_from_hex_hex ] ;
    gec:returnType [ a gec:PathType ; gec:typePath "Self" ] .
    # pub fn from_hex(hex: impl Into<String>) -> Self — affidavit_types.rs.tmpl:77

gec:ImplTrait_from_hex_hex a gec:ImplTraitType ;
    gec:implPosition gec:ArgumentPosition ;
    gec:boundTrait [ a gec:GenericType ;
        gec:baseType [ a gec:PathType ; gec:typePath "Into" ] ;
        gec:hasArgument [ a gec:TypeArgumentType ; gec:argPosition 0 ;
            gec:argType [ a gec:PathType ; gec:typePath "String" ] ] ] ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "argument-position impl Trait — affidavit_types.rs.tmpl:77" .

gec:Fn_commands_for_noun a gec:FunctionSignature ;
    gec:fnName "commands_for_noun" ;
    gec:definedIn gec:Artifact_CargoCicdCatalog ;
    gec:receiverKind gec:NoReceiver ;
    gec:hasParameter [ a gec:Parameter ; gec:paramIndex 0 ; gec:paramName "noun" ;
        gec:paramType [ a gec:ReferenceType ; gec:mutable false ;
            gec:referent [ a gec:PrimitiveType ; gec:primitiveName "str" ] ] ] ;
    gec:returnType gec:ImplTrait_commands_for_noun_return .
    # pub fn commands_for_noun(noun: &str) -> impl Iterator<Item = &'static CargoCicdCommand> + '_
    # — cargo_cicd_catalog.rs.tmpl:75. The trailing `+ '_` captured-lifetime bound on the opaque
    # return type itself is not separately modeled — the ontology has no property for an extra
    # lifetime bound on an ImplTraitType beyond gec:boundTrait. Honest gap; not needed for
    # rule 060's quantifier classification (which only reads gec:implPosition).

gec:ImplTrait_commands_for_noun_return a gec:ImplTraitType ;
    gec:implPosition gec:ReturnPosition ;
    gec:boundTrait [ a gec:GenericType ;
        gec:baseType [ a gec:PathType ; gec:typePath "Iterator" ] ;
        gec:hasArgument [ a gec:TypeArgumentType ; gec:argPosition 0 ;
            gec:argType [ a gec:ReferenceType ; gec:mutable false ;
                gec:lifetime [ a gec:Lifetime ; gec:lifetimeLabel "'static" ; gec:lifetimeKindProp gec:StaticLifetime ] ;
                gec:referent [ a gec:PathType ; gec:typePath "CargoCicdCommand" ] ] ] ] ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "return-position impl Trait — cargo_cicd_catalog.rs.tmpl:75" .

gec:Local_h_dyn_OclnrHandlerSeam a gec:LocalBinding ;
    gec:bindingName "h" ; gec:isMutBinding false ;
    gec:bindingType [ a gec:ReferenceType ; gec:mutable false ;
        gec:referent gec:TraitObjType_OclnrHandlerSeam ] .
    # let h: &dyn OclnrHandlerSeam = &DummyHandlers; — osx_clnr_dispatch_proof.rs.tmpl:69

gec:TraitObjType_OclnrHandlerSeam a gec:TraitObjectType ;
    gec:dynBound [ a gec:PathType ; gec:typePath "OclnrHandlerSeam" ] ;
    gec:dialectStatus gec:NamedException ;
    gec:exceptionReason "&dyn OclnrHandlerSeam — osx_clnr_dispatch_proof.rs.tmpl:69" .

gec:Local_wrapper_as_dynFn_cargo a gec:LocalBinding ;
    gec:bindingName "wrapper" ; gec:isMutBinding false ;
    gec:bindingType [ a gec:ReferenceType ; gec:mutable false ;
        gec:referent gec:TraitObjType_DynFn_cargo ] .
    # let _ = wrapper as &dyn Fn(&[String]) -> std::io::Result<std::process::Output>;
    # — cargo_cicd_dispatch_proof.rs.tmpl:137. Grounded as the `as`-cast TARGET type, not a
    # literal `let wrapper: &dyn Fn(...) = ...` declaration — gec:LocalBinding is reused here
