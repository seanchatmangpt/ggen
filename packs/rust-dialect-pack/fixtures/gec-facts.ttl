gec:ErrorPath_handle_snapshot a gec:StdResultPath ;
    gec:errorPathOf gec:Fn_handle_snapshot_thin_bytes_budget ;
    gec:okType [ a gec:PrimitiveType ; gec:primitiveName "u64" ] ;
    gec:errType [ a gec:PathType ; gec:typePath "String" ] ;
