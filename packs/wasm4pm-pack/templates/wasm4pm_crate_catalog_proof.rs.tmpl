//! Data-fidelity proof for `wasm4pm-pack`'s generated catalog
//! (`src/wasm4pm_crate_catalog.rs`), asserted against literal values
//! hand-transcribed from `packs/wasm4pm-pack/ontology.ttl`.
//!
//! Deliberately carries NO `sparql:` frontmatter key: `wasm4pm_crate_catalog.rs.tmpl`
//! and `wasm4pm_crate_reference.md.tmpl` both already run
//! `SELECT ?label ?purpose ... ORDER BY ?label` to *produce* the artifact
//! under test here. Re-deriving the "expected" side via that same query
//! would make this test's oracle and the code-under-test share one
//! generative mechanism -- any templating bug that survives into the
//! catalog would survive into the "expected" values too, and the test
//! could only ever agree with itself (CHEAT-T02). Every literal value
//! below was transcribed by hand from `packs/wasm4pm-pack/ontology.ttl`,
//! never queried.
//!
//! Generated by `wasm4pm-pack`.

#[path = "../src/wasm4pm_crate_catalog.rs"]
mod wasm4pm_crate_catalog;

use wasm4pm_crate_catalog::{Wasm4pmCrate, WASM4PM_CRATES};

fn find(name: &str) -> &'static Wasm4pmCrate {
    WASM4PM_CRATES
        .iter()
        .find(|c| c.name == name)
        .unwrap_or_else(|| panic!("no crate named {name:?} in WASM4PM_CRATES"))
}

/// `ontology.ttl` declares exactly 9 `w4c:Crate` individuals -- hand count,
/// not a query result.
#[test]
fn catalog_has_exactly_nine_crates() {
    assert_eq!(WASM4PM_CRATES.len(), 9);
}

#[test]
fn wasm4pm_matches_ontology() {
    assert_eq!(
        find("wasm4pm").purpose,
        "High-performance process mining algorithms in WebAssembly for JavaScript/TypeScript."
    );
}

#[test]
fn tps_metrics_matches_ontology() {
    assert_eq!(
        find("tps-metrics").purpose,
        "Toyota Production System metrics collection and analysis."
    );
}

#[test]
fn wasm4pm_cognition_matches_ontology() {
    assert_eq!(
        find("wasm4pm-cognition").purpose,
        "AutoSystems old-AI cognition kernel: frames, production rules, Prolog, STRIPS, Hearsay-II blackboard, BLAKE3 receipt chain, adversarial gates."
    );
}

#[test]
fn ocpq_matches_ontology() {
    assert_eq!(
        find("ocpq").purpose,
        "Object-centric process querying & constraints (binding boxes, query trees, E2O/O2O/TBE predicates, CHILD SET) per Kuesters & van der Aalst 2025."
    );
}

#[test]
fn wasm4pm_planner_matches_ontology() {
    assert_eq!(
        find("wasm4pm-planner").purpose,
        "wasm4pm-native PDDL-subset temporal planner with prolog8 admission gating and an MCP server -- a fresh design drawing on bcinr-pddl's durative-action scheduler and capability-router pattern."
    );
}

#[test]
fn bench_tools_matches_ontology() {
    assert_eq!(
        find("bench-tools").purpose,
        "Benchmark tools for the wasm4pm workspace."
    );
}

/// Structural invariant on the *generated* array itself -- `ORDER BY ?label`
/// means the catalog must already be sorted ascending by name. Gives
/// indirect coverage of `wasm4pm-cli`, `miniml`, and `prolog8`, the
/// three individuals not spot-checked by name/purpose above: any of them
/// missing, duplicated, or shuffled out of place would break this check
/// even though no test above names them directly. Computed by a fresh
/// pairwise scan of the compiled array, not by re-running the query.
#[test]
fn catalog_is_sorted_by_name() {
    for pair in WASM4PM_CRATES.windows(2) {
        assert!(
            pair[0].name < pair[1].name,
            "catalog out of order: {:?} should sort before {:?}",
            pair[0].name,
            pair[1].name
        );
    }
}

/// No two rows may share the same `name` -- catches an accidentally
/// duplicated `w4c:Crate` individual in the ontology.
#[test]
fn catalog_has_no_duplicate_names() {
    let mut seen: Vec<&str> = Vec::new();
    for row in WASM4PM_CRATES {
        assert!(
            !seen.contains(&row.name),
            "duplicate crate name found in WASM4PM_CRATES: {:?}",
            row.name
        );
        seen.push(row.name);
    }
}

/// Every entry must have a non-empty name and purpose -- covers all 9
/// individuals directly, independent of the spot checks above.
#[test]
fn every_crate_has_non_empty_name_and_purpose() {
    for row in WASM4PM_CRATES {
        assert!(!row.name.is_empty(), "empty name in WASM4PM_CRATES entry");
        assert!(
            !row.purpose.is_empty(),
            "empty purpose for crate {:?} in WASM4PM_CRATES",
            row.name
        );
    }
}
