//! Behavioral proof for `wasm4pm-pack`'s generated dependency-graph module
//! (`src/wasm4pm_crate_deps.rs`). Deliberately carries no `sparql:`
//! frontmatter key, for the same CHEAT-T02 reason as
//! `wasm4pm_crate_catalog_proof.rs.tmpl`: every expected edge below was
//! transcribed by hand from `packs/wasm4pm-pack/ontology.ttl`'s
//! `w4c:dependsOn` facts, never queried, so this test's oracle does not
//! share a generative mechanism with the code under test.
//!
//! Unlike the catalog proof (pure data-fidelity assertions), these tests
//! exercise real control flow: direct lookup, multi-hop transitive closure,
//! and the "unknown crate" error path (empty result, not a panic).
//!
//! Generated by `wasm4pm-pack`.

#[path = "../src/wasm4pm_crate_deps.rs"]
mod wasm4pm_crate_deps;

use wasm4pm_crate_deps::{
    depends_on, transitive_dependencies, transitive_dependencies_over, CrateDepEdge, CRATE_DEPS,
};

/// `ontology.ttl` declares exactly 4 `w4c:dependsOn` subjects covering 7
/// directed edges -- hand count, not a query result.
#[test]
fn edge_count_matches_ontology() {
    assert_eq!(CRATE_DEPS.len(), 7);
}

#[test]
fn direct_dependency_lookup() {
    assert_eq!(depends_on("wasm4pm-cli"), vec!["wasm4pm"]);
    assert_eq!(depends_on("wasm4pm-cognition"), vec!["prolog8"]);
}

/// `wasm4pm` depends on two crates directly (`miniml-core`, `wasm4pm-cognition`)
/// -- order-independent membership check since SPARQL's `ORDER BY ?from_label
/// ?to_label` sorts them alphabetically by target label, not by declaration
/// order in ontology.ttl.
#[test]
fn wasm4pm_has_two_direct_dependencies() {
    let deps = depends_on("wasm4pm");
    assert_eq!(deps.len(), 2);
    assert!(deps.contains(&"miniml-core"));
    assert!(deps.contains(&"wasm4pm-cognition"));
}

/// A crate genuinely present in the ontology but with zero recorded
/// `w4c:dependsOn` edges (e.g. `prolog8`, a dependency leaf) returns an
/// empty vec, not an error -- the "known, zero deps" case.
#[test]
fn leaf_crate_has_no_dependencies() {
    assert!(depends_on("prolog8").is_empty());
    assert!(depends_on("tps-metrics").is_empty());
}

/// An unrecognized crate name also returns an empty vec (documented
/// behavior: this module cannot itself distinguish "unknown" from "known,
/// zero deps" -- see the function's doc comment) rather than panicking.
#[test]
fn unknown_crate_name_returns_empty_not_panic() {
    assert!(depends_on("does-not-exist").is_empty());
}

/// Real multi-hop traversal: `wasm4pm-planner` depends directly on `prolog8`,
/// `wasm4pm`, and `wasm4pm-cognition`; `wasm4pm` itself depends on
/// `wasm4pm-cognition` and `miniml-core`; `wasm4pm-cognition` depends on
/// `prolog8`. The transitive closure must include every one of those,
/// deduplicated (`prolog8` and `wasm4pm-cognition` are each reachable via
/// two paths).
#[test]
fn transitive_closure_covers_multi_hop_reachable_set() {
    let closure = transitive_dependencies("wasm4pm-planner");
    for expect in ["prolog8", "wasm4pm", "wasm4pm-cognition", "miniml-core"] {
        assert!(
            closure.contains(&expect),
            "transitive_dependencies(\"wasm4pm-planner\") missing {expect:?}: {closure:?}"
        );
    }
    let mut seen = Vec::new();
    for c in &closure {
        assert!(!seen.contains(c), "duplicate {c:?} in transitive closure: {closure:?}");
        seen.push(*c);
    }
}

/// A leaf crate's transitive closure is empty, same as its direct closure.
#[test]
fn transitive_closure_of_leaf_is_empty() {
    assert!(transitive_dependencies("prolog8").is_empty());
}

/// Every edge names two ends known independently to be real: since this
/// proof cannot depend on the catalog module's own crate list without
/// re-introducing the tautology this file avoids elsewhere, this instead
/// verifies the weaker but still real invariant that no edge is a
/// self-loop (a `w4c:dependsOn` fact where `from == to`) -- catches an
/// obviously malformed ontology edit even without cross-referencing
/// `WASM4PM_CRATES`.
#[test]
fn no_edge_is_a_self_loop() {
    for CrateDepEdge { from, to } in CRATE_DEPS {
        assert_ne!(from, to, "self-loop dependency edge: {from} -> {to}");
    }
}

/// The real `w4c:dependsOn` graph (7 edges, hand-verified against
/// ~/wasm4pm's own Cargo.toml files) happens to be acyclic, so nothing above
/// exercises `transitive_dependencies`'s explicit `visited`-set cycle guard.
/// This test proves that guard on a hand-built 3-node cycle (a -> b -> c ->
/// a) via `transitive_dependencies_over`, the same traversal parameterized
/// over an arbitrary edge slice: it must terminate (not loop forever /
/// overflow the stack) and visit each reachable node exactly once, even
/// though the cycle makes the start node itself transitively reachable
/// (b -> c -> a is a real path back to "a", so "a" legitimately appears in
/// its own closure here -- this is correct cyclic-graph behavior, not a
/// bug, and is exactly the case the current 7-edge acyclic `CRATE_DEPS`
/// graph can never surface).
#[test]
fn cycle_guard_terminates_on_a_synthetic_cycle() {
    const CYCLE: &[CrateDepEdge] = &[
        CrateDepEdge { from: "a", to: "b" },
        CrateDepEdge { from: "b", to: "c" },
        CrateDepEdge { from: "c", to: "a" },
    ];
    let closure = transitive_dependencies_over(CYCLE, "a");
    assert_eq!(
        closure.len(),
        3,
        "cycle guard must visit each of a/b/c exactly once, not loop or under-visit: {closure:?}"
    );
    for expect in ["a", "b", "c"] {
        assert!(closure.contains(&expect), "missing {expect:?}: {closure:?}");
    }
    let mut seen = Vec::new();
    for c in &closure {
        assert!(!seen.contains(c), "duplicate {c:?}: {closure:?}");
        seen.push(*c);
    }
}

/// `transitive_dependencies` (the real, `CRATE_DEPS`-bound entry point) and
/// `transitive_dependencies_over(CRATE_DEPS, ..)` must agree -- the former is
/// defined purely as a call to the latter, so this pins that relationship.
#[test]
fn transitive_dependencies_delegates_to_the_parameterized_form() {
    assert_eq!(
        transitive_dependencies("wasm4pm-planner"),
        transitive_dependencies_over(CRATE_DEPS, "wasm4pm-planner")
    );
}
