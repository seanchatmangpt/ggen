---
to: src/wasm4pm_crate_deps.rs
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/wasm4pm-pack
sparql:
  edges: |
    PREFIX w4c: <http://seanchatmangpt.github.io/packs/wasm4pm-crate#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?from_label ?to_label WHERE {
      ?from w4c:dependsOn ?to .
      ?from rdfs:label ?from_label .
      ?to rdfs:label ?to_label .
    } ORDER BY ?from_label ?to_label
---
//! Intra-workspace dependency graph over `WASM4PM_CRATES`
//! (`src/wasm4pm_crate_catalog.rs`), derived from `w4c:dependsOn` facts in
//! `packs/wasm4pm-pack/ontology.ttl`.
//!
//! Unlike the flat catalog, this module carries real control flow --
//! [`depends_on`] and [`transitive_dependencies`] traverse the generated edge
//! list at call time; nothing here is a pre-computed constant. Both functions
//! are driven entirely by `CRATE_DEPS`, which is itself SPARQL-derived, so
//! adding/removing a `w4c:dependsOn` triple changes traversal behavior with
//! no template or logic edit required.
//!
//! Generated by `wasm4pm-pack`.

/// One directed `(dependent, dependency)` edge.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct CrateDepEdge {
    pub from: &'static str,
    pub to: &'static str,
}

/// All intra-workspace dependency edges, ordered by (from, to).
pub const CRATE_DEPS: &[CrateDepEdge] = &[
{% for row in edges %}    CrateDepEdge { from: "{{ row.from_label }}", to: "{{ row.to_label }}" },
{% endfor %}];

/// Direct dependencies of `name`, in `CRATE_DEPS` order. Empty slice (not an
/// error) for a crate with no recorded intra-workspace dependency, or for a
/// name absent from the graph entirely -- callers that must distinguish
/// "known, zero deps" from "unknown crate" should first check
/// `super::wasm4pm_crate_catalog::WASM4PM_CRATES`.
pub fn depends_on(name: &str) -> Vec<&'static str> {
    let mut out = Vec::new();
    for edge in CRATE_DEPS {
        if edge.from == name {
            out.push(edge.to);
        }
    }
    out
}

/// Full transitive dependency closure of `name` (depth-first), deduplicated,
/// in first-visited order. Guards against a cyclic `w4c:dependsOn` graph with
/// an explicit `visited` set -- a cycle terminates traversal instead of
/// overflowing the stack, even though the current 7-edge graph is acyclic.
pub fn transitive_dependencies(name: &str) -> Vec<&'static str> {
    let mut visited: Vec<&'static str> = Vec::new();
    let mut stack: Vec<&str> = depends_on(name);
    while let Some(dep) = stack.pop() {
        if visited.contains(&dep) {
            continue;
        }
        visited.push(dep);
        for next in depends_on(dep) {
            if !visited.contains(&next) {
                stack.push(next);
            }
        }
    }
    visited
}
