---
to: src/wasm4pm_crate_catalog.rs
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/wasm4pm-pack
sparql:
  crates: |
    PREFIX w4c: <http://seanchatmangpt.github.io/packs/wasm4pm-crate#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?label ?purpose WHERE {
      ?c a w4c:Crate ; rdfs:label ?label ; w4c:purpose ?purpose .
    } ORDER BY ?label
---
//! Typed catalog of the ~/wasm4pm workspace's own member crates,
//! transcribed from `packs/wasm4pm-pack/ontology.ttl`.
//!
//! Generated by `wasm4pm-pack`. Distinct in scope from
//! `wasm4pm-{algorithms,cognition,compat,facts}-pack`, which model
//! wasm4pm's process-intelligence ontology, not its crate structure.

/// One member crate of the wasm4pm workspace.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct Wasm4pmCrate {
    pub name: &'static str,
    pub purpose: &'static str,
}

/// All member crates, alphabetized.
pub const WASM4PM_CRATES: &[Wasm4pmCrate] = &[
{% for row in crates %}    Wasm4pmCrate { name: "{{ row.label }}", purpose: "{{ row.purpose }}" },
{% endfor %}];
