# shapes.ttl -- SHACL shapes constraining w4c:Crate individuals and the
# w4c:dependsOn relation between them.
#
# Round-3 addition: turns the previously-unstated conventions this pack's
# templates already assumed (every crate has exactly one label and one
# purpose string; every dependsOn edge points at another *known* w4c:Crate,
# never at a bare IRI or a literal) into a checked, machine-verifiable fact.
# Closes part of the ontology-expressiveness gap noted in the prior round's
# results ("no behavior/pre-post-condition contracts... ontology models
# structure... not behavior") by at least making the *structural* half of
# the contract explicit and gated, even though it does not add behavioral
# pre/post-conditions (that remainder is still open -- see pack.toml).
#
# Run with:
#   ggen graph validate --files packs/wasm4pm-pack/ontology.ttl \
#                        --shapes packs/wasm4pm-pack/shapes.ttl

@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix w4c:  <http://seanchatmangpt.github.io/packs/wasm4pm-crate#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

w4c:CrateShape
    a sh:NodeShape ;
    sh:targetClass w4c:Crate ;

    sh:property [
        sh:path     rdfs:label ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A w4c:Crate must carry exactly one non-empty rdfs:label." ;
    ] ;
    sh:property [
        sh:path     w4c:purpose ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A w4c:Crate must carry exactly one non-empty w4c:purpose." ;
    ] ;
    sh:property [
        sh:path     w4c:dependsOn ;
        sh:class    w4c:Crate ;
        sh:message  "Every w4c:dependsOn target must itself be a w4c:Crate individual (no dangling/external-crate edges in this closed graph)." ;
    ] .

# Note on what this shape file deliberately does NOT check: SHACL's
# property-shape sh:class constraint above already forces every dependsOn
# target to be some w4c:Crate individual, but SHACL has no native
# not-equal-to-self (no-self-loop) constraint without a SPARQL-based
# sh:sparql constraint component, and this pack's proof test
# (`no_edge_is_a_self_loop` in wasm4pm_crate_deps_proof.rs.tmpl) already
# covers that invariant at the generated-code layer, so it is not
# duplicated here.
