# wasm4pm-pack ontology — the real crate map of the ~/wasm4pm workspace,
# transcribed from ~/wasm4pm/Cargo.toml's members list and each crate's own
# Cargo.toml description. Distinct in scope from packs/wasm4pm-{algorithms,
# cognition,compat,facts}-pack, which model wasm4pm's process-intelligence
# ANALYSIS ontology, not its crate structure.

@prefix w4c:  <http://seanchatmangpt.github.io/packs/wasm4pm-crate#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

w4c:Crate a rdfs:Class ; rdfs:label "wasm4pm workspace crate" .
w4c:purpose a rdf:Property ; rdfs:domain w4c:Crate ; rdfs:range xsd:string .

w4c:wasm4pm
    a w4c:Crate ; rdfs:label "wasm4pm" ;
    w4c:purpose "High-performance process mining algorithms in WebAssembly for JavaScript/TypeScript." .

w4c:tps-metrics
    a w4c:Crate ; rdfs:label "tps-metrics" ;
    w4c:purpose "Toyota Production System metrics collection and analysis." .

w4c:wasm4pm-cli
    a w4c:Crate ; rdfs:label "wasm4pm-cli" ;
    w4c:purpose "The official wasm4pm process mining command-line interface." .

w4c:miniml-core
    a w4c:Crate ; rdfs:label "miniml-core" ;
    w4c:purpose "A minimal, blazing-fast WASM-powered machine learning library with SIMD acceleration." .

w4c:wasm4pm-cognition
    a w4c:Crate ; rdfs:label "wasm4pm-cognition" ;
    w4c:purpose "AutoSystems old-AI cognition kernel: frames, production rules, Prolog, STRIPS, Hearsay-II blackboard, BLAKE3 receipt chain, adversarial gates." .

w4c:prolog8
    a w4c:Crate ; rdfs:label "prolog8" ;
    w4c:purpose "Byte-capped proof engine for policy, workflow, and agent action admission." .

w4c:ocpq
    a w4c:Crate ; rdfs:label "ocpq" ;
    w4c:purpose "Object-centric process querying & constraints (binding boxes, query trees, E2O/O2O/TBE predicates, CHILD SET) per Kuesters & van der Aalst 2025." .

w4c:bench-tools
    a w4c:Crate ; rdfs:label "bench-tools" ;
    w4c:purpose "Benchmark tools for the wasm4pm workspace." .

w4c:wasm4pm-planner
    a w4c:Crate ; rdfs:label "wasm4pm-planner" ;
    w4c:purpose "wasm4pm-native PDDL-subset temporal planner with prolog8 admission gating and an MCP server -- a fresh design drawing on bcinr-pddl's durative-action scheduler and capability-router pattern." .
