//! Proof tests for `wasm4pm-algorithms-pack`'s generated catalog
//! (`src/w4pm_algorithms_catalog.rs`), asserted against literal values
//! hand-transcribed from `packs/wasm4pm-algorithms-pack/ontology.ttl`.
//!
//! Fully static template: no SPARQL, no Tera substitution. Every expected
//! value below is a literal the author copied from the ontology, never a
//! value recomputed via the same SPARQL query path that produced `CATALOG`
//! -- so a broken `ORDER BY`, a dropped row, or a copy-paste mismatch
//! between `algorithm_id` and `wasm_export` fails these tests even though
//! it would not fail a tautological self-comparison. `AlgorithmInfo` only
//! carries 6 runtime fields (id, algorithm_id, label, category, wasm_export,
//! cli_alias) -- speed_tier/quality_tier/doc/citation exist only as Rust
//! doc-comments on the `AlgorithmId` enum or in the separate
//! `docs/w4pm_algorithms.md`, so this file does not (and cannot) assert on
//! them.
//!
//! Generated by `wasm4pm-algorithms-pack`.

#[path = "../src/w4pm_algorithms_catalog.rs"]
mod w4pm_algorithms_catalog;

use std::collections::HashSet;
use w4pm_algorithms_catalog::{by_wasm_export, AlgorithmId, AlgorithmInfo, CATALOG};

/// Linear lookup by `algorithm_id`. A plain search over the generated table,
/// not a re-derivation of any expected field value.
fn find(algorithm_id: &str) -> &'static AlgorithmInfo {
    CATALOG
        .iter()
        .find(|row| row.algorithm_id == algorithm_id)
        .unwrap_or_else(|| panic!("no CATALOG row for algorithm_id={algorithm_id:?}"))
}

// ---------------------------------------------------------------------------
// Cardinality -- hand-counted from ontology.ttl's own section headers.
// ---------------------------------------------------------------------------

#[test]
fn catalog_has_all_60_algorithms() {
    assert_eq!(CATALOG.len(), 60);
}

#[test]
fn category_counts_match_ontology_section_headers() {
    fn count(category: &str) -> usize {
        CATALOG.iter().filter(|row| row.category == category).count()
    }
    assert_eq!(count("discovery"), 20);
    assert_eq!(count("discovery_analytics"), 10);
    assert_eq!(count("object_centric"), 6);
    assert_eq!(count("ml_analytics"), 8);
    assert_eq!(count("conformance"), 4);
    assert_eq!(count("prediction"), 5);
    assert_eq!(count("simulation"), 2);
    assert_eq!(count("import_export"), 4);
    assert_eq!(count("agentic"), 1);
}

// ---------------------------------------------------------------------------
// Structural invariants -- uniqueness `by_wasm_export`'s correctness depends
// on. These check a property of the whole table, not any single row's value.
// ---------------------------------------------------------------------------

#[test]
fn wasm_export_values_are_unique_across_the_catalog() {
    let mut seen: HashSet<&str> = HashSet::new();
    for row in CATALOG {
        assert!(
            seen.insert(row.wasm_export),
            "duplicate wasm_export {:?} would make by_wasm_export ambiguous",
            row.wasm_export
        );
    }
    assert_eq!(seen.len(), 60);
}

#[test]
fn algorithm_id_values_are_unique_across_the_catalog() {
    let mut seen: HashSet<&str> = HashSet::new();
    for row in CATALOG {
        assert!(
            seen.insert(row.algorithm_id),
            "duplicate algorithm_id {:?}",
            row.algorithm_id
        );
    }
    assert_eq!(seen.len(), 60);
}

