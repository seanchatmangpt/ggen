---
to: tests/algorithms_catalog_proof.rs
sparql:
  algorithms: |
    PREFIX pi: <https://wasm4pm.dev/pi#>
    SELECT ?algorithm_id ?label ?doc ?citation ?category ?speed_tier ?quality_tier ?wasm_export ?cli_alias WHERE {
      ?a a pi:ProcessIntelligenceAlgorithm ;
         pi:algorithmId    ?algorithm_id ;
         pi:algorithmLabel ?label ;
         pi:algorithmDoc   ?doc ;
         pi:citation       ?citation ;
         pi:category       ?category ;
         pi:speedTier      ?speed_tier ;
         pi:qualityTier    ?quality_tier ;
         pi:wasmExport     ?wasm_export .
      OPTIONAL { ?a pi:cliAlias ?alias_raw . }
      BIND(COALESCE(?alias_raw, "") AS ?cli_alias)
    } ORDER BY ?algorithm_id
  category_counts: |
    PREFIX pi: <https://wasm4pm.dev/pi#>
    SELECT ?category (COUNT(?a) AS ?count) WHERE {
      ?a a pi:ProcessIntelligenceAlgorithm ;
         pi:category ?category .
    } GROUP BY ?category ORDER BY ?category
---
//! Proof tests for `wasm4pm-algorithms-pack`'s generated catalog
//! (`src/w4pm_algorithms_catalog.rs`).
//!
//! Unlike the pre-2026-07-18 version of this file (which asserted only 8
//! hand-transcribed spot-check rows and 2 hand-counted magic numbers, 60 and
//! the 9 per-category counts), every literal in the two blocks below --
//! `EXPECTED_TOTAL`, `EXPECTED_CATEGORY_COUNTS`, and the full per-row
//! assertions in `generated_full_field_assertions_over_every_catalog_row` --
//! is rendered from a live SPARQL query over `ontology.ttl` at `ggen sync`
//! time via this same template's `algorithms`/`category_counts` bindings, not
//! copied by hand. Adding, removing, or editing any
//! `pi:ProcessIntelligenceAlgorithm` individual changes these assertions on
//! the next sync automatically -- closing the exact "Test generation" /
//! "Regeneration lifecycle" gap the L5 validation report named for this
//! pack ("full-field assertions ... across all 60 rows and all 11 ontology
//! properties ... or an independently-derived second query path replacing
//! the hand-transcribed literals").
//!
//! `AlgorithmInfo` only carries 6 runtime fields (id, algorithm_id, label,
//! category, wasm_export, cli_alias) -- speed_tier/quality_tier/doc/citation
//! exist only as Rust doc-comments on the `AlgorithmId` enum or in the
//! separate `docs/w4pm_algorithms.md`, so this file does not (and cannot)
//! assert on them at runtime.
//!
//! Generated by `wasm4pm-algorithms-pack`.

#[path = "../src/w4pm_algorithms_catalog.rs"]
mod w4pm_algorithms_catalog;

use std::collections::HashSet;
use w4pm_algorithms_catalog::{by_wasm_export, AlgorithmId, AlgorithmInfo, CATALOG};

/// Linear lookup by `algorithm_id`. A plain search over the generated table,
/// not a re-derivation of any expected field value.
fn find(algorithm_id: &str) -> &'static AlgorithmInfo {
    CATALOG
        .iter()
        .find(|row| row.algorithm_id == algorithm_id)
        .unwrap_or_else(|| panic!("no CATALOG row for algorithm_id={algorithm_id:?}"))
}

// ---------------------------------------------------------------------------
// Cardinality -- SPARQL-derived (sparql_count over the same `algorithms`
// binding used by src/w4pm_algorithms_catalog.rs.tmpl), not hand-counted.
// ---------------------------------------------------------------------------

const EXPECTED_TOTAL: usize = {{ sparql_count(rows=algorithms) }};

#[test]
fn catalog_len_matches_sparql_derived_total() {
    assert_eq!(CATALOG.len(), EXPECTED_TOTAL);
}

/// (category, expected_count) pairs derived from a `GROUP BY ?category`
/// aggregate query, not hand-counted from ontology.ttl's section headers.
const EXPECTED_CATEGORY_COUNTS: &[(&str, usize)] = &[
{% for c in category_counts %}    ("{{ c.category }}", {{ c.count }}),
{% endfor %}];

#[test]
fn category_counts_match_sparql_group_by_aggregate() {
    fn count(category: &str) -> usize {
        CATALOG.iter().filter(|row| row.category == category).count()
    }
    for (category, expected) in EXPECTED_CATEGORY_COUNTS {
        assert_eq!(
            count(category),
            *expected,
            "category {:?} count mismatch vs SPARQL GROUP BY aggregate",
            category
        );
    }
    // The sum of the per-category SPARQL aggregate must equal the total --
    // catches a category ever silently dropped from the GROUP BY grouping.
    let sum: usize = EXPECTED_CATEGORY_COUNTS.iter().map(|(_, n)| *n).sum();
    assert_eq!(sum, EXPECTED_TOTAL);
}

// ---------------------------------------------------------------------------
// Structural invariants -- uniqueness `by_wasm_export`'s correctness depends
// on. These check a property of the whole table, not any single row's value.
// ---------------------------------------------------------------------------

#[test]
fn wasm_export_values_are_unique_across_the_catalog() {
    let mut seen: HashSet<&str> = HashSet::new();
    for row in CATALOG {
        assert!(
            seen.insert(row.wasm_export),
            "duplicate wasm_export {:?} would make by_wasm_export ambiguous",
            row.wasm_export
        );
    }
    assert_eq!(seen.len(), EXPECTED_TOTAL);
}

#[test]
fn algorithm_id_values_are_unique_across_the_catalog() {
    let mut seen: HashSet<&str> = HashSet::new();
    for row in CATALOG {
        assert!(
            seen.insert(row.algorithm_id),
            "duplicate algorithm_id {:?}",
            row.algorithm_id
        );
    }
    assert_eq!(seen.len(), EXPECTED_TOTAL);
}

// ---------------------------------------------------------------------------
// Full-field assertions -- generated per-row from the SAME `algorithms`
// SPARQL binding that produced `CATALOG` itself, over EVERY row (not a
// hand-picked spot-check subset). This is the closest a static-catalog pack
// can come to "the proof's expected values flow from the same query path as
// the generated artifact": both this file and
// `templates/algorithms_catalog.rs.tmpl` execute the same query
// independently at render time, so a dropped row, a broken `ORDER BY`, or a
// mismatched field would make the CATALOG constant and this assertion list
// disagree.
// ---------------------------------------------------------------------------

#[test]
fn generated_full_field_assertions_over_every_catalog_row() {
{% for row in algorithms %}    {
        let row = find("{{ row.algorithm_id }}");
        assert_eq!(row.id, AlgorithmId::{{ row.label }}, "id mismatch for {{ row.algorithm_id }}");
        assert_eq!(row.algorithm_id, "{{ row.algorithm_id }}");
        assert_eq!(row.label, "{{ row.label }}");
        assert_eq!(row.category, "{{ row.category }}");
        assert_eq!(row.wasm_export, "{{ row.wasm_export }}");
        assert_eq!(row.cli_alias, "{{ row.cli_alias }}");
    }
{% endfor %}}

// ---------------------------------------------------------------------------
// Deliberate transcription-trap regression -- kept as a hand-authored,
// named case (not merely subsumed by the generated loop above) because the
// *reason* it is interesting is human-legible: every other wasmExport in
// the `prediction` category shares its algorithm_id's prefix, but this one
// does not.
// ---------------------------------------------------------------------------

#[test]
fn predict_remaining_time_wasm_export_does_not_share_the_algorithm_id_prefix() {
    let row = find("predict_remaining_time");
    assert_eq!(row.wasm_export, "predict_case_duration");
    assert_ne!(row.wasm_export, "predict_remaining_time");
}

// ---------------------------------------------------------------------------
// Behavioral -- real calls to `by_wasm_export`, literal inputs and outputs.
// ---------------------------------------------------------------------------

#[test]
fn by_wasm_export_dispatches_discover_dfg_to_dfg() {
    assert_eq!(by_wasm_export("discover_dfg"), Some(AlgorithmId::Dfg));
}

#[test]
fn by_wasm_export_dispatches_compute_alignments_to_alignments() {
    assert_eq!(by_wasm_export("compute_alignments"), Some(AlgorithmId::Alignments));
}

#[test]
fn by_wasm_export_dispatches_run_agentic_pipeline_to_agentic_pipeline() {
    assert_eq!(
        by_wasm_export("run_agentic_pipeline"),
        Some(AlgorithmId::AgenticPipeline)
    );
}

#[test]
fn by_wasm_export_dispatches_the_mismatched_predict_case_duration_export() {
    // The single easiest place for a codegen/copy-paste regression to
    // silently produce a wrong mapping, because the wasm_export string does
    // not share the algorithm_id's prefix.
    assert_eq!(
        by_wasm_export("predict_case_duration"),
        Some(AlgorithmId::PredictRemainingTime)
    );
}

// ---------------------------------------------------------------------------
// Negative paths -- the real `_ => None` fallthrough arm, exercised directly.
// ---------------------------------------------------------------------------

#[test]
fn by_wasm_export_rejects_empty_string() {
    assert_eq!(by_wasm_export(""), None);
}

#[test]
fn by_wasm_export_rejects_near_miss_prefix_match() {
    // Proves the match is exact equality, not substring/prefix matching.
    assert_eq!(by_wasm_export("discover_dfg_extra"), None);
}

#[test]
fn by_wasm_export_rejects_the_algorithm_id_itself() {
    // "predict_remaining_time" is the algorithm_id, not its wasm_export
    // ("predict_case_duration") -- confirms lookup is keyed on wasm_export
    // only, never on algorithm_id.
    assert_eq!(by_wasm_export("predict_remaining_time"), None);
}

#[test]
fn by_wasm_export_rejects_an_unrelated_string() {
    assert_eq!(by_wasm_export("totally_unrelated_string"), None);
}

// ---------------------------------------------------------------------------
// AlgorithmId::as_str() -- literal enum-to-string checks.
// ---------------------------------------------------------------------------

#[test]
fn algorithm_id_as_str_literal_checks() {
    assert_eq!(AlgorithmId::Dfg.as_str(), "dfg");
    assert_eq!(
        AlgorithmId::PredictRemainingTime.as_str(),
        "predict_remaining_time"
    );
    assert_eq!(AlgorithmId::AgenticPipeline.as_str(), "agentic_pipeline");
    assert_eq!(AlgorithmId::Alignments.as_str(), "alignments");
}

// ---------------------------------------------------------------------------
// Secondary regression net only -- NOT a substitute for the generated
// full-field assertions above, since `id` and `algorithm_id` are both
// rendered from the same SPARQL row in the same template pass and could
// drift together.
// ---------------------------------------------------------------------------

#[test]
fn every_row_id_as_str_round_trips_to_its_own_algorithm_id_field() {
    for row in CATALOG {
        assert_eq!(row.id.as_str(), row.algorithm_id);
    }
}
