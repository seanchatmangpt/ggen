//! Target-API fidelity proof for `wasm4pm-algorithms-pack`.
//!
//! Addresses the "Target-API fidelity" gap named in
//! `docs/packs/L5_VALIDATION_REPORT.md`'s wasm4pm-algorithms-pack section:
//! "At minimum, an automated check that compiles/links against the real
//! wasm4pm crate or WASM artifact and asserts each wasmExport literal
//! actually resolves, re-run on target version bumps." This file is
//! generated from `pi:verifiedAgainst` facts in `ontology.ttl` (SPARQL
//! query over the same `?a a pi:ProcessIntelligenceAlgorithm` individuals),
//! not hand-picked -- so a future ontology edit that adds or removes a
//! `pi:verifiedAgainst` triple changes the set of rows checked here on the
//! next `ggen sync`.
//!
//! Honest scope: only rows whose `pi:wasmExport` names a function that
//! actually exists in `wasm4pm-compat` (this workspace's real, pinned,
//! compilable dependency) can be checked this way. As of 2026-07-18 that is
//! 1 of 60 rows (`ocel_dfg` -> `discover_ocel_dfg`). The other 59 rows name
//! WASM exports of the separate `wasm4pm` crate, which is not a reachable
//! dependency here (and, per this workspace's process-intelligence-boundary
//! rule, never should be a native dependency of any ggen crate) -- so they
//! remain UNVERIFIED by this proof, not silently assumed correct.
//!
//! Generated by `wasm4pm-algorithms-pack`.

#[path = "../src/w4pm_algorithms_catalog.rs"]
mod w4pm_algorithms_catalog;

use w4pm_algorithms_catalog::{by_wasm_export, AlgorithmId};

/// Every `(algorithm_id, label, wasm_export)` row this ontology currently
/// claims has been hand-verified against a real target crate function,
/// SPARQL-derived from `pi:verifiedAgainst` -- not a hardcoded list.
const VERIFIED_ROWS: &[(&str, &str, &str)] = &[
{% for row in verified %}    ("{{ row.algorithm_id }}", "{{ row.label }}", "{{ row.wasm_export }}"),
{% endfor %}];

#[test]
fn exactly_one_row_is_currently_target_verified_and_it_is_ocel_dfg() {
    // A cardinality tripwire: this repo's own honesty depends on this count
    // only growing when a NEW real, checked call is added below, not when
    // someone merely adds another `pi:verifiedAgainst` triple to the
    // ontology without a matching compiled call in this file.
    assert_eq!(VERIFIED_ROWS.len(), 1);
    assert_eq!(VERIFIED_ROWS[0].0, "ocel_dfg");
    assert_eq!(VERIFIED_ROWS[0].2, "discover_ocel_dfg");
}

#[test]
fn every_verified_row_wasm_export_resolves_via_by_wasm_export() {
    for (algorithm_id, label, wasm_export) in VERIFIED_ROWS {
        let expected_id = match *label {
            "OcelDfg" => AlgorithmId::OcelDfg,
            other => panic!(
                "VERIFIED_ROWS grew a new label ({other:?}) this test doesn't \
                 know how to map -- add the new match arm before trusting \
                 target-API fidelity for {algorithm_id:?}"
            ),
        };
        assert_eq!(by_wasm_export(wasm_export), Some(expected_id));
    }
}

/// The real, load-bearing check: actually call the pinned `wasm4pm-compat`
/// 26.6.29 function named by `pi:Algo_ocel_dfg`'s `pi:wasmExport` literal
/// ("discover_ocel_dfg") on a minimal real `OCEL` value and assert it
/// produces the DFG shape a directly-follows miner must produce for a
/// 2-event, 1-object-type log: one arc, frequency 1. This is not a stub or
/// a signature-only compile check -- it exercises the actual algorithm body
/// wasm4pm-compat ships, proving the wasmExport literal names something
/// real and callable, not merely a string that happens to compile.
#[test]
fn wasm_export_discover_ocel_dfg_actually_resolves_and_runs_against_pinned_wasm4pm_compat() {
    use chrono::DateTime;
    use wasm4pm_compat::ocel::{OCELEvent, OCELRelationship, OCELType, OCEL};

    let time_a = DateTime::parse_from_rfc3339("2026-07-18T00:00:00+00:00")
        .expect("literal RFC 3339 timestamp must parse");
    let time_b = DateTime::parse_from_rfc3339("2026-07-18T00:01:00+00:00")
        .expect("literal RFC 3339 timestamp must parse");

    // `discover_ocel_dfg` groups events by shared OBJECT membership (via
    // `relationships`), not raw log order -- both events below relate to the
    // same "order-1" object so a directly-follows arc is actually formed.
    let ocel = OCEL {
        event_types: vec![
            OCELType { name: "receive_order".to_string(), attributes: Vec::new() },
            OCELType { name: "ship_order".to_string(), attributes: Vec::new() },
        ],
        object_types: Vec::new(),
        events: vec![
            OCELEvent {
                id: "e1".to_string(),
                event_type: "receive_order".to_string(),
                time: time_a,
                attributes: Vec::new(),
                relationships: vec![OCELRelationship {
                    object_id: "order-1".to_string(),
                    qualifier: "order".to_string(),
                }],
            },
            OCELEvent {
                id: "e2".to_string(),
                event_type: "ship_order".to_string(),
                time: time_b,
                attributes: Vec::new(),
                relationships: vec![OCELRelationship {
                    object_id: "order-1".to_string(),
                    qualifier: "order".to_string(),
                }],
            },
        ],
        objects: Vec::new(),
    };

    // This is the real, pinned `wasm4pm-compat` function named by
    // `pi:Algo_ocel_dfg`'s `pi:wasmExport` -- not a hand-written stand-in.
    let dfg = wasm4pm_compat::dfg::discover_ocel_dfg(&ocel);

    assert_eq!(
        dfg.nodes.len(),
        2,
        "discover_ocel_dfg must register one DFGNode per event type"
    );
    assert_eq!(
        dfg.edges.len(),
        1,
        "discover_ocel_dfg must discover exactly one directly-follows arc \
         (receive_order -> ship_order) for this 2-event single-case log"
    );
    let arc = &dfg.edges[0];
    assert_eq!(arc.source, "receive_order");
    assert_eq!(arc.target, "ship_order");
    assert_eq!(arc.frequency, 1);
}
