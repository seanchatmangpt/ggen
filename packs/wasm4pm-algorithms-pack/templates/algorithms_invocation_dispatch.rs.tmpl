to: src/w4pm_algorithms_invocation_dispatch.rs
sparql:
  verified: |
    PREFIX pi: <https://wasm4pm.dev/pi#>
    SELECT ?algorithm_id ?label ?wasm_export WHERE {
      ?a a pi:ProcessIntelligenceAlgorithm ;
