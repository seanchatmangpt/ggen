//! Real invocation composition, closing (partially) the "Handler-gap size"
//! dimension for `wasm4pm-algorithms-pack`.
//!
//! This is NOT a claim that the catalog can invoke all 60 algorithms ŌĆö it
//! genuinely cannot: 59 of the 60 `pi:wasmExport` literals name exports of
//! the `wasm4pm` crate itself, which this workspace's own
//! process-intelligence-boundary rule forbids depending on natively (see
//! CLAUDE.md). What this file DOES do, honestly: for every row that carries
//! a `pi:verifiedAgainst` fact (SPARQL-derived, not hand-picked ŌĆö as of
//! 2026-07-18 that is 1 of 60 rows, `ocel_dfg`), it generates a real
//! `AlgorithmId -> compiled external call` dispatch arm that actually
//! invokes the pinned `wasm4pm-compat` function, not a stub. Every
//! non-verified `AlgorithmId` returns `DispatchError::NotComposable`
//! instead of silently succeeding or panicking ŌĆö the gap is visible in the
//! type, not hidden.
//!
//! Generated by `wasm4pm-algorithms-pack`.

#[path = "w4pm_algorithms_catalog.rs"]
mod w4pm_algorithms_catalog;

pub use w4pm_algorithms_catalog::{AlgorithmId, AlgorithmInfo, CATALOG};

/// Why `dispatch_verified` could not run a given `AlgorithmId`.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum DispatchError {
    /// This algorithm's `pi:wasmExport` has no matching real, callable
    /// function reachable from this workspace (no `pi:verifiedAgainst`
    /// fact in the ontology). Not a bug ŌĆö an honest, typed refusal.
    NotComposable(AlgorithmId),
}

/// Real, callable dispatch for every `AlgorithmId` this ontology currently
/// marks `pi:verifiedAgainst` (SPARQL-derived ŌĆö grows only when a new row
/// gets a real verified fact AND a matching arm is added below).
///
/// # Errors
/// Returns `Err(DispatchError::NotComposable(id))` for every `AlgorithmId`
/// not in that verified set.
pub fn dispatch_verified(
    id: AlgorithmId,
    ocel: &wasm4pm_compat::ocel::OCEL,
) -> Result<wasm4pm_compat::models::DFG, DispatchError> {
    match id {
{% for row in verified %}{% if row.label == "OcelDfg" %}        AlgorithmId::{{ row.label }} => Ok(wasm4pm_compat::dfg::discover_ocel_dfg(ocel)),
{% endif %}{% endfor %}        other => Err(DispatchError::NotComposable(other)),
    }
}

/// The exact set of `AlgorithmId`s `dispatch_verified` can actually run,
/// SPARQL-derived from `pi:verifiedAgainst` facts ŌĆö used by the proof to
/// keep this file honest as the ontology changes.
pub const COMPOSABLE: &[AlgorithmId] = &[
{% for row in verified %}{% if row.label == "OcelDfg" %}    AlgorithmId::{{ row.label }},
{% endif %}{% endfor %}];
