---
to: src/w4pm_algorithms_catalog.rs
sparql:
  algorithms: |
    PREFIX pi: <https://wasm4pm.dev/pi#>
    SELECT ?algorithm_id ?label ?doc ?citation ?category ?speed_tier ?quality_tier ?wasm_export ?cli_alias WHERE {
      ?a a pi:ProcessIntelligenceAlgorithm ;
         pi:algorithmId    ?algorithm_id ;
         pi:algorithmLabel ?label ;
         pi:algorithmDoc   ?doc ;
         pi:citation       ?citation ;
         pi:category       ?category ;
         pi:speedTier      ?speed_tier ;
         pi:qualityTier    ?quality_tier ;
         pi:wasmExport     ?wasm_export .
      OPTIONAL { ?a pi:cliAlias ?alias_raw . }
      BIND(COALESCE(?alias_raw, "") AS ?cli_alias)
    } ORDER BY ?algorithm_id
---
//! Typed catalog of the wasm4pm process-intelligence ALGORITHM surface.
//!
//! Generated by `wasm4pm-algorithms-pack` from `pi:ProcessIntelligenceAlgorithm`
//! individuals carried over from the wasm4pm algorithm ontology. This is a
//! CATALOG/CALLER surface only: discovery, conformance, fitness, and variant
//! analysis all execute inside wasm4pm, never here.

/// Every wasm4pm process-intelligence algorithm this catalog knows about.
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub enum AlgorithmId {
{% for row in algorithms %}    /// `{{ row.algorithm_id }}` ({{ row.category }}) — {{ row.doc }}
    {{ row.label }},
{% endfor %}}

/// One catalog row: identity + call metadata for a wasm4pm algorithm.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct AlgorithmInfo {
    pub id: AlgorithmId,
    /// Canonical snake_case identifier (matches the wasm4pm Rust enum id()).
    pub algorithm_id: &'static str,
    /// PascalCase label (the enum variant name).
    pub label: &'static str,
    /// Functional category (discovery | conformance | prediction | simulation | ...).
    pub category: &'static str,
    /// WASM-exported function name callable on the wasm4pm module.
    pub wasm_export: &'static str,
    /// CLI alias for `wpm run` — empty when the algorithm has no alias.
    pub cli_alias: &'static str,
}

/// The full catalog, ordered by `algorithm_id`.
pub const CATALOG: &[AlgorithmInfo] = &[
{% for row in algorithms %}    AlgorithmInfo {
        id: AlgorithmId::{{ row.label }},
        algorithm_id: "{{ row.algorithm_id }}",
        label: "{{ row.label }}",
        category: "{{ row.category }}",
        wasm_export: "{{ row.wasm_export }}",
        cli_alias: "{{ row.cli_alias }}",
    },
{% endfor %}];

impl AlgorithmId {
    /// Canonical snake_case identifier for this algorithm.
    pub fn as_str(self) -> &'static str {
        match self {
{% for row in algorithms %}            Self::{{ row.label }} => "{{ row.algorithm_id }}",
{% endfor %}        }
    }
}

/// Look an algorithm up by the WASM export name it is dispatched through.
pub fn by_wasm_export(export: &str) -> Option<AlgorithmId> {
    match export {
{% for row in algorithms %}        "{{ row.wasm_export }}" => Some(AlgorithmId::{{ row.label }}),
{% endfor %}        _ => None,
    }
}
