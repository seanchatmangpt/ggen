# shapes.ttl -- SHACL shapes constraining pi:ProcessIntelligenceAlgorithm
# individuals.
#
# Closes part of the "Ontology expressiveness" gap named in
# docs/packs/L5_VALIDATION_REPORT.md's wasm4pm-algorithms-pack section:
# "Needs structural or behavioral triples (input/output relations with
# cardinality, composability constraints, or pre/post-conditions) so a
# differently designed template set could regenerate an equivalent-behaving
# system, not merely an equivalent-looking data catalog." Before this file
# existed, nothing in the ontology itself asserted that every algorithm must
# carry exactly one algorithmId/label/category/wasmExport, that
# pi:cliAlias is genuinely optional (only pi:wasmExport and friends are
# required), or that pi:category/pi:outputType/pi:inputFormat are drawn from
# a closed enumeration -- all of that was implicit in the templates and in
# this file's own header comment, not checkable against the graph. These
# shapes make each of those requirements a machine-verifiable SHACL fact,
# runnable via `ggen graph validate --files ontology.ttl,shapes.ttl` (or
# whichever combined validation path a consumer wires), instead of an
# unstated convention.
#
# This does NOT reach the L5 bar ("Ontology is a complete specification; a
# different template set could regenerate an equivalent system") -- it adds
# cardinality/closed-enumeration structure, not behavioral pre/post
# conditions or composability constraints, so a different template author
# still could not derive algorithmic *behavior* (what discover_dfg actually
# computes) from the graph alone, only the catalog's shape.

@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix pi:   <https://wasm4pm.dev/pi#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

pi:ProcessIntelligenceAlgorithmShape
    a sh:NodeShape ;
    sh:targetClass pi:ProcessIntelligenceAlgorithm ;

    sh:property [
        sh:path     pi:algorithmId ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "Every algorithm must carry exactly one non-empty pi:algorithmId (the Rust enum id() / TS AlgorithmId string)." ;
    ] ;
    sh:property [
        sh:path     pi:algorithmLabel ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern  "^[A-Z][A-Za-z0-9]*$" ;
        sh:message  "Every algorithm must carry exactly one pi:algorithmLabel matching PascalCase (the generated Rust enum variant name)." ;
    ] ;
    sh:property [
        sh:path     pi:algorithmDoc ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "Every algorithm must carry exactly one non-empty pi:algorithmDoc." ;
    ] ;
    sh:property [
        sh:path     pi:citation ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "Every algorithm must carry exactly one non-empty pi:citation." ;
    ] ;
    sh:property [
        sh:path     pi:category ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "discovery" "discovery_analytics" "object_centric" "ml_analytics"
                "conformance" "simulation" "prediction" "import_export" "agentic" ) ;
        sh:message  "pi:category must be exactly one of the 9 closed functional categories." ;
    ] ;
    sh:property [
        sh:path     pi:outputType ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "dfg" "petrinet" "declare" "tree" "analytics" "ml_result" "model" ) ;
        sh:message  "pi:outputType must be exactly one of the 7 closed artifact types." ;
    ] ;
    sh:property [
        sh:path     pi:inputFormat ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "xes" "ocel" "bpmn" "pnml" "petri_net_handle" "any" ) ;
        sh:message  "pi:inputFormat must be exactly one of the 6 closed input formats." ;
    ] ;
    sh:property [
        sh:path     pi:speedTier ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ; sh:maxInclusive 80 ;
        sh:message  "pi:speedTier must be exactly one integer in [1, 80]." ;
    ] ;
    sh:property [
        sh:path     pi:qualityTier ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ; sh:maxInclusive 100 ;
        sh:message  "pi:qualityTier must be exactly one integer in [0, 100]." ;
    ] ;
    sh:property [
        sh:path     pi:wasmExport ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "Every algorithm must carry exactly one pi:wasmExport literal (empty string permitted only for algorithms with no direct WASM export)." ;
    ] ;
    sh:property [
        sh:path     pi:cliAlias ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "pi:cliAlias is genuinely optional (maxCount 1, no minCount) -- but when present must be non-empty; templates default a missing alias to \"\" via SPARQL COALESCE." ;
    ] .
