//! InterviewAssist Phase 0 sandbox actuator dispatch surface (generated by
//! `wasm4pm-sandbox-pack`).
//!
//! This trait is a pure dispatch contract: catalog-driven admission
//! (precondition checking against `CapabilityId::info().requires`) plus a
//! typed request/response/refusal shape. It contains no subprocess,
//! filesystem, or execution code -- a real implementation (isolation,
//! timeout enforcement, stdout/stderr/exit-code capture, BLAKE3 receipt
//! chaining) belongs in wasm4pm's own `wasm4pm-sandbox` crate.

use crate::sandbox_catalog::CapabilityId;

/// Input to a sandbox capability dispatch.
pub struct CapabilityRequest {
    pub capability: CapabilityId,
    /// Source files for this request, path relative to the isolated
    /// workspace root -> file content.
    pub files: Vec<(String, String)>,
    /// Capability ids already admitted with a `Pass` outcome earlier in the
    /// same session -- used to check `CapabilityId::info().requires`
    /// before dispatch is attempted.
    pub already_passed: Vec<CapabilityId>,
}

/// Real, executed outcome of a dispatched capability.
pub struct CapabilityReceipt {
    pub capability: CapabilityId,
    pub exit_code: i32,
    pub stdout: String,
    pub stderr: String,
    pub duration_ms: u64,
    /// BLAKE3 digest of (capability_id, files, exit_code, stdout, stderr) --
    /// content-addressed so replay can prove the receipt matches its inputs.
    pub digest: String,
}

/// Typed refusal -- dispatch never occurred, or occurred but was refused
/// before producing a receipt.
#[derive(Debug, Clone, PartialEq, Eq)]
pub enum CapabilityRefusal {
    /// A required precondition capability has not yet passed in this session.
    PreconditionNotMet { missing: CapabilityId },
    /// The request declared no files for a capability that requires them.
    NoSourceProvided,
    /// The real actuator exceeded `CapabilityId::info().timeout_ms`.
    Timeout,
    /// The real actuator could not be reached at all (e.g. process spawn failed).
    ActuatorUnavailable { reason: String },
}

/// Implemented by the real sandbox (wasm4pm's `wasm4pm-sandbox` crate).
/// The catalog and this trait live in ggen-generated source; the body does
/// not.
pub trait SandboxActuator {
    fn actuate(&self, request: CapabilityRequest) -> Result<CapabilityReceipt, CapabilityRefusal>;
}

/// Precondition check shared by every real actuator implementation: refuse
/// before spawning any process if a required capability hasn't passed yet.
pub fn check_preconditions(request: &CapabilityRequest) -> Result<(), CapabilityRefusal> {
    for required in request.capability.info().requires {
        if !request.already_passed.contains(required) {
            return Err(CapabilityRefusal::PreconditionNotMet { missing: *required });
        }
    }
    Ok(())
}
