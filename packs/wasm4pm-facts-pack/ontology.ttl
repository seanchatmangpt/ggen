pi:Algo_ocel_oc_declare a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "ocel_oc_declare" ;
  pi:algorithmLabel "OcelOcDeclare" ;
  pi:algorithmDoc   "Object-centric Declare constraint discovery — mines LTL-based temporal constraints from the OCEL log, relating events across different object types." ;
  pi:citation       "van der Aalst, W.M.P. (2019). Object-Centric Process Mining. ICSOC 2019, LNCS 11895. Springer." ;
  pi:outputType     "declare" ;
  pi:category       "object_centric" ;
