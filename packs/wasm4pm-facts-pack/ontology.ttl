  pi:algorithmId    "log_to_trie" ;
  pi:algorithmLabel "LogToTrie" ;
  pi:algorithmDoc   "Prefix-tree (trie) representation — inserts all traces into a trie where each path from root to leaf represents a unique trace variant." ;
