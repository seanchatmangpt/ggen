  pi:algorithmId    "compute_trace_similarity_matrix" ;
  pi:algorithmLabel "ComputeTraceSimilarityMatrix" ;
  pi:algorithmDoc   "Pairwise trace similarity matrix — computes edit-distance or Jaccard similarity for all trace pairs; used as input to clustering and variant analysis." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
