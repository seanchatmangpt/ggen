  pi:speedTier      "30"^^xsd:integer ;
  pi:qualityTier    "80"^^xsd:integer ;
  pi:wasmExport     "predict_next_activity" ;
  pi:inputFormat    "xes" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_predict_outcome a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "predict_outcome" ;
  pi:algorithmLabel "PredictOutcome" ;
  pi:algorithmDoc   "Case outcome prediction — predicts the final outcome of a running case from its prefix using a trained binary or multi-class classifier." ;
  pi:citation       "Teinemaa, I., Dumas, M., Rosa, M.L., & Maggi, F.M. (2019). Outcome-Oriented Predictive Process Monitoring. ACM TKDD, 13(2), Article 17." ;
  pi:outputType     "ml_result" ;
  pi:category       "prediction" ;
  pi:speedTier      "28"^^xsd:integer ;
  pi:qualityTier    "82"^^xsd:integer ;
  pi:wasmExport     "predict_outcome" ;
  pi:inputFormat    "xes" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_predict_remaining_time a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "predict_remaining_time" ;
  pi:algorithmLabel "PredictRemainingTime" ;
  pi:algorithmDoc   "Remaining time prediction from trace prefix — estimates time until case completion using a regression model trained on completed cases." ;
  pi:citation       "Teinemaa, I., Dumas, M., Rosa, M.L., & Maggi, F.M. (2019). Outcome-Oriented Predictive Process Monitoring. ACM TKDD, 13(2), Article 17." ;
