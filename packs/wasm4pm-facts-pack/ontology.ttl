  pi:algorithmId    "correlation_miner" ;
  pi:algorithmLabel "CorrelationMiner" ;
  pi:algorithmDoc   "Correlation-based dependency miner — discovers dependencies from statistical correlation of activity occurrences without requiring case identifiers." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
