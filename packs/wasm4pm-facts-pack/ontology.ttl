  pi:algorithmId    "simulated_annealing" ;
  pi:algorithmLabel "SimulatedAnnealing" ;
  pi:algorithmDoc   "Simulated Annealing stochastic search — probabilistically accepts worse candidate models according to a cooling schedule to escape local optima." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
