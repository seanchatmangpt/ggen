pi:Algo_playout a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "playout" ;
  pi:algorithmLabel "Playout" ;
  pi:algorithmDoc   "Stochastic playout from Petri net — generates synthetic event logs by firing enabled transitions according to stochastic weights until all tokens reach the final marking." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
  pi:outputType     "analytics" ;
  pi:category       "simulation" ;
