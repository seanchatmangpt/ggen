pi:Algo_smart_engine a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "smart_engine" ;
  pi:algorithmLabel "SmartEngine" ;
  pi:algorithmDoc   "Auto-selects the best algorithm for the input characteristics — inspects log size, variant count, and noise level, then dispatches to the most appropriate discovery algorithm." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
