  pi:algorithmId    "simd_streaming_dfg" ;
  pi:algorithmLabel "SimdStreamingDfg" ;
  pi:algorithmDoc   "SIMD-accelerated streaming DFG — processes the event log in a single pass using SIMD vector intrinsics for maximum throughput on large logs." ;
