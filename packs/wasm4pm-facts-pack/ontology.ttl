  pi:algorithmId    "causal_graph" ;
  pi:algorithmLabel "CausalGraph" ;
  pi:algorithmDoc   "Causal dependency graph — applies causal inference to distinguish spurious correlations in the DFG from genuine causal dependencies between activities." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
  pi:outputType     "analytics" ;
