# Consumer breed instances for wasm4pm cognition layer.
# breedStatus is NEVER set here — it is CONSTRUCT-derived from evidence.ttl via alive-gate.
# modulePath is only set when the Rust module name differs from breedId.

compat:Breed_abductive_ibe a compat:CognitionBreed ;
