  pi:algorithmId    "genetic_algorithm" ;
  pi:algorithmLabel "GeneticAlgorithm" ;
  pi:algorithmDoc   "Genetic algorithm process model search — evolves a population of candidate Petri nets using fitness, precision, generalization and simplicity as multi-objective fitness functions." ;
  pi:citation       "van der Aalst, W.M.P., de Medeiros, A.K.A., & Weijters, A.J.M.M. (2005). Genetic process mining. Petri Nets 2005, LNCS 3536. Springer." ;
