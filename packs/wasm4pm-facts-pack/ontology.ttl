  pi:qualityTier    "65"^^xsd:integer ;
  pi:wasmExport     "discover_ocel_ocla" ;
  pi:inputFormat    "ocel" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_ocel_petri_net a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "ocel_petri_net" ;
  pi:algorithmLabel "OcelPetriNet" ;
  pi:algorithmDoc   "Per-type flattened Petri nets — applies the Inductive Miner to each object-type-flattened sub-log to produce a sound Petri net per type." ;
  pi:citation       "van der Aalst, W.M.P. (2019). Object-Centric Process Mining. ICSOC 2019, LNCS 11895. Springer." ;
  pi:outputType     "petrinet" ;
  pi:category       "object_centric" ;
  pi:speedTier      "30"^^xsd:integer ;
  pi:qualityTier    "78"^^xsd:integer ;
  pi:wasmExport     "discover_ocel_petri_net" ;
  pi:inputFormat    "ocel" ;
  pi:standing     "REPLAYABLE" .

