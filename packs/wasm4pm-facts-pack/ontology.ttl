  pi:standing     "REPLAYABLE" .

pi:Algo_batches a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "batches" ;
  pi:algorithmLabel "Batches" ;
  pi:algorithmDoc   "Detects batch-execution patterns — identifies when a resource processes multiple cases simultaneously (sequential, concurrent, simultaneous, or interleaved batches)." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
