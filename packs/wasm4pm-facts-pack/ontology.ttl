  pi:algorithmId    "optimized_dfg" ;
  pi:algorithmLabel "OptimizedDfg" ;
  pi:algorithmDoc   "DFG with arc-weight optimisation pass — builds a standard DFG then applies pruning to remove statistically insignificant arcs." ;
