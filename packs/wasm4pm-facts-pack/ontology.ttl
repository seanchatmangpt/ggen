pi:Algo_streaming_log a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "streaming_log" ;
  pi:algorithmLabel "StreamingLog" ;
  pi:algorithmDoc   "Streaming event log ingestion — processes events in arrival order without materialising the full log in memory; emits running DFG statistics." ;
