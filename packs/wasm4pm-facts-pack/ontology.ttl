  pi:algorithmId    "compute_activity_transition_matrix" ;
  pi:algorithmLabel "ComputeActivityTransitionMatrix" ;
  pi:algorithmDoc   "Activity-to-activity transition probability matrix — computes the n x n matrix of empirical transition probabilities between all activity pairs." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
