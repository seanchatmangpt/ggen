  pi:algorithmId    "ilp" ;
  pi:algorithmLabel "Ilp" ;
  pi:algorithmDoc   "ILP Miner — solves an integer linear programming problem to find a Petri net fitting the directly-follows relations; produces high-precision sound models." ;
