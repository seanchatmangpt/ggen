  pi:algorithmId    "ocel_ocla" ;
  pi:algorithmLabel "OcelOcla" ;
  pi:algorithmDoc   "Object-centric log abstraction analytics — computes summary statistics: object interaction counts, event density, and type co-occurrence matrices." ;
  pi:citation       "van der Aalst, W.M.P. (2019). Object-Centric Process Mining. ICSOC 2019, LNCS 11895. Springer." ;
  pi:outputType     "analytics" ;
  pi:category       "object_centric" ;
