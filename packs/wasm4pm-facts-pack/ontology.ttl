  pi:algorithmId    "process_skeleton" ;
  pi:algorithmLabel "ProcessSkeleton" ;
  pi:algorithmDoc   "Minimal skeleton DFG — retains only the highest-frequency directly-follows arcs to produce a sparse backbone of the process." ;
