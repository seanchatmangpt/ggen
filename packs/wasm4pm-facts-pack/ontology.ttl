# ============================================================
# CONFORMANCE (4)
# ============================================================

pi:Algo_alignments a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "alignments" ;
  pi:algorithmLabel "Alignments" ;
  pi:algorithmDoc   "Alignment-based conformance checking — synchronously replays each trace on the Petri net, computing optimal alignment cost using A* over the synchronous product automaton." ;
  pi:citation       "van der Aalst, W.M.P., Adriansyah, A., & van Dongen, B.F. (2012). Replaying History on Process Models for Conformance Checking. WIREs DMKD, 2(2), 182-192." ;
  pi:outputType     "analytics" ;
  pi:category       "conformance" ;
  pi:speedTier      "25"^^xsd:integer ;
  pi:qualityTier    "95"^^xsd:integer ;
  pi:wasmExport     "compute_alignments" ;
  pi:cliAlias       "alignment" ;
  pi:inputFormat    "xes" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_complexity_metrics a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "complexity_metrics" ;
  pi:algorithmLabel "ComplexityMetrics" ;
  pi:algorithmDoc   "Structural complexity metrics (size, CFC, depth) — computes Control Flow Complexity, model size, connector degree distribution, and depth without replaying the log." ;
  pi:citation       "van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer." ;
  pi:outputType     "analytics" ;
  pi:category       "conformance" ;
  pi:speedTier      "15"^^xsd:integer ;
  pi:qualityTier    "90"^^xsd:integer ;
  pi:wasmExport     "compute_complexity_metrics" ;
  pi:cliAlias       "complexity" ;
  pi:inputFormat    "xes" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_etconformance_precision a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "etconformance_precision" ;
  pi:algorithmLabel "EtconformancePrecision" ;
  pi:algorithmDoc   "ETConformance precision — measures how much of the model's behaviour is actually observed in the log using escaping-edges token-based precision." ;
  pi:citation       "Munoz-Gama, J., & Carmona, J. (2010). A Fresh Look at Precision in Process Conformance. BPM 2010, LNCS 6336. Springer." ;
  pi:outputType     "analytics" ;
  pi:category       "conformance" ;
  pi:speedTier      "20"^^xsd:integer ;
  pi:qualityTier    "92"^^xsd:integer ;
  pi:wasmExport     "compute_align_etconformance_precision" ;
  pi:cliAlias       "etconformance" ;
  pi:inputFormat    "petri_net_handle" ;
  pi:standing     "REPLAYABLE" .

pi:Algo_generalization a pi:ProcessIntelligenceAlgorithm ;
  pi:algorithmId    "generalization" ;
  pi:algorithmLabel "Generalization" ;
  pi:algorithmDoc   "Van der Aalst generalization score — measures how well the model generalises beyond the observed log by penalising infrequently visited transitions." ;
  pi:citation       "Buijs, J.C.A.M., van Dongen, B.F., & van der Aalst, W.M.P. (2012). On the Role of Fitness, Precision, Generalization and Simplicity in Process Discovery. CoopIS 2012, LNCS 7565. Springer." ;
  pi:outputType     "analytics" ;
  pi:category       "conformance" ;
  pi:speedTier      "20"^^xsd:integer ;
  pi:qualityTier    "90"^^xsd:integer ;
  pi:wasmExport     "generalization" ;
  pi:cliAlias       "generalization" ;
  pi:inputFormat    "petri_net_handle" ;
  pi:standing     "REPLAYABLE" .

