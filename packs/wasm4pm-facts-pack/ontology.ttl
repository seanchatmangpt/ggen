  pi:algorithmId    "pso" ;
  pi:algorithmLabel "Pso" ;
  pi:algorithmDoc   "Particle Swarm Optimisation discovery — maintains a swarm of candidate models whose positions evolve toward the global best according to social and cognitive acceleration." ;
