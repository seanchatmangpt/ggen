/// Covers: `pi:Algo_agentic_pipeline` -- the sole member of category
/// "agentic" -- renders verbatim, AND its `pi:speedTier`/`pi:qualityTier`/
/// `pi:wasmExport` ontology values (80, 90, "run_agentic_pipeline") are
/// confirmed absent from the rendered artifact, since the template's SPARQL
/// SELECT never binds those variables.
#[test]
fn algorithm_agentic_pipeline_row_renders_verbatim_and_omits_unselected_fields() {
    let content = read_registry();
    assert!(
        content.contains(
            "| `agentic_pipeline` | AgenticPipeline | agentic | REPLAYABLE | van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer. |"
        ),
        "agentic_pipeline row not found verbatim:\n{content}"
    );
    assert!(
        !content.contains("run_agentic_pipeline"),
        "wasmExport is not SELECTed by the template and must not leak into the rendered artifact"
    );
}

/// Covers: `pi:Algo_playout` renders verbatim under THIS pack's provenance.
/// `pi:inputFormat` ("petri_net_handle" in this pack's ontology.ttl) is
/// deliberately never asserted here: the template's SELECT does not bind
/// `?inputFormat`, so it cannot leak into the rendered text -- which matters
/// because `wasm4pm-algorithms-pack` asserts a conflicting `pi:inputFormat`
/// value ("xes") on the identical subject IRI `pi:Algo_playout`. This test
/// stays correct regardless of which pack's `pi:inputFormat` assertion a
/// SPARQL query elsewhere might observe, because it never queries the graph.
#[test]
fn algorithm_playout_row_renders_verbatim_without_conflicting_input_format() {
    let content = read_registry();
    assert!(
        content.contains(
            "| `playout` | Playout | simulation | REPLAYABLE | van der Aalst, W.M.P. (2016). Process Mining: Data Science in Action (2nd ed.). Springer. |"
        ),
        "playout row not found verbatim:\n{content}"
    );
}
