//! Artifact-fidelity proof for `wasm4pm-facts-pack`'s rendered registry catalog.
//!
//! This pack is pure data: its only template, `breed_algorithm_registry.md.tmpl`,
//! SPARQL-projects the admitted graph into
//! `docs/releases/v26.7.6/BREED_ALGORITHM_REGISTRY.md`. No `emit_*`, no
//! dispatch match, no Rust code at all is generated by this pack -- so there is
//! no generated function to call behaviorally. Instead these tests do real
//! `std::fs::read_to_string` (no mocks) on the ALREADY-RENDERED sibling
//! artifact and assert its content against literal values hand-transcribed
//! from `packs/wasm4pm-facts-pack/ontology.ttl`, cross-checked against the
//! currently-generated file. This proves the full pipeline (SPARQL binding ->
//! Tera rendering -> file write) stayed faithful to the admitted facts,
//! WITHOUT ever re-running the SPARQL that produced the artifact -- so none of
//! these assertions can be tautological with the template's own query.
//!
//! Provenance note: `compat:CognitionBreed` is independently re-asserted,
//! verbatim, on the identical 55 subject IRIs by `wasm4pm-cognition-pack`, and
//! `pi:ProcessIntelligenceAlgorithm` on the identical 60 subject IRIs by
//! `wasm4pm-algorithms-pack` -- including one genuine cross-pack value
//! conflict on `pi:Algo_playout`'s `pi:inputFormat` ("petri_net_handle" here
//! vs "xes" there). Because these are the SAME subject IRIs (not merely the
//! same class with pack-distinct individuals), no SPARQL `FILTER(STRSTARTS(...))`
//! namespace guard can disambiguate provenance the way it does elsewhere in
//! this pack cluster -- so this proof issues NO SPARQL of its own and inspects
//! only the terminal rendered markdown text.

use std::fs;
use std::path::PathBuf;

/// Path to the sibling artifact rendered by `breed_algorithm_registry.md.tmpl`,
/// resolved from `CARGO_MANIFEST_DIR` so this test is independent of the
/// directory `cargo test` happens to be invoked from.
fn registry_path() -> PathBuf {
    PathBuf::from(env!("CARGO_MANIFEST_DIR"))
        .join("docs/releases/v26.7.6/BREED_ALGORITHM_REGISTRY.md")
}

fn read_registry() -> String {
    let path = registry_path();
    fs::read_to_string(&path)
        .unwrap_or_else(|e| panic!("read {}: {e}", path.display()))
}

/// Covers: the rendered breed section header reports exactly 55 rows -- an
/// independently-obtained count (`grep -c "a compat:CognitionBreed"
/// ontology.ttl` => 55) mechanically distinct from the template's own SPARQL
/// SELECT that produced the rendered count.
#[test]
fn breed_section_header_reports_55() {
    let content = read_registry();
    assert!(
        content.contains("## Cognition breeds (55)"),
        "expected the breed section header to report 55 rows, got:\n{content}"
    );
}

/// Covers: the rendered algorithm section header reports exactly 60 rows --
/// independently confirmed via `grep -c "a pi:ProcessIntelligenceAlgorithm"
/// ontology.ttl` => 60.
#[test]
fn algorithm_section_header_reports_60() {
    let content = read_registry();
    assert!(
        content.contains("## Process-intelligence algorithms (60)"),
        "expected the algorithm section header to report 60 rows, got:\n{content}"
    );
}

/// Covers: the breed table actually contains 55 data rows (`| \`...\` |`),
/// not merely a header claiming 55 -- counts literal markdown table rows via
/// a `starts_with` scan bounded to the breed section, independent of both the
/// SPARQL SELECT and the header-count assertion above.
#[test]
fn breed_table_has_55_data_rows() {
    let content = read_registry();
    let breed_section_end = content
        .find("## Process-intelligence algorithms")
        .unwrap_or(content.len());
    let breed_section = &content[..breed_section_end];
    let row_count = breed_section
        .lines()
        .filter(|line| line.starts_with("| `"))
        .count();
    assert_eq!(
        row_count, 55,
        "expected 55 breed data rows, found {row_count}"
    );
}

/// Covers: the algorithm table actually contains 60 data rows.
#[test]
fn algorithm_table_has_60_data_rows() {
    let content = read_registry();
    let algo_section_start = content
        .find("## Process-intelligence algorithms")
        .expect("algorithm section header must be present in the rendered artifact");
    let algo_section = &content[algo_section_start..];
    let row_count = algo_section
        .lines()
        .filter(|line| line.starts_with("| `"))
        .count();
    assert_eq!(
        row_count, 60,
        "expected 60 algorithm data rows, found {row_count}"
    );
}

/// Covers: `compat:Breed_eliza` -- the one breed with a non-default
/// `compat:modulePath` ("frame") -- renders its projected fields
/// (id/label/status/citation) verbatim. `modulePath` itself is not SELECTed
/// by the template, so it never appears in the rendered text either.
#[test]
fn breed_eliza_row_renders_verbatim() {
    let content = read_registry();
    assert!(
        content.contains(
            "| `eliza` | Eliza | ADMITTED | Weizenbaum, J. (1966). ELIZA—A computer program for the study of natural language communication between man and machine. Communications of the ACM, 9(1), 36–45. https://doi.org/10.1145/365153.365168 |"
        ),
        "eliza row not found verbatim:\n{content}"
    );
}

