sparql:
  breeds: |
    PREFIX compat: <https://wasm4pm.dev/ns#>
    SELECT ?id ?label ?citation (COALESCE(?standing, "ADMITTED") AS ?status)
    WHERE {
      ?b a compat:CognitionBreed ;
         compat:breedId ?id ;
         compat:breedLabel ?label ;
         compat:citation ?citation .
      OPTIONAL { ?b <http://seanchatmangpt.github.io/praxis/law#standing> ?standing }
    }
    ORDER BY ?id
  algorithms: |
    PREFIX pi: <https://wasm4pm.dev/pi#>
    SELECT ?id ?label ?category ?citation ?standing
    WHERE {
      ?a a pi:ProcessIntelligenceAlgorithm ;
         pi:algorithmId ?id ;
         pi:algorithmLabel ?label ;
         pi:category ?category ;
         pi:citation ?citation ;
         pi:standing ?standing .
    }
    ORDER BY ?id
