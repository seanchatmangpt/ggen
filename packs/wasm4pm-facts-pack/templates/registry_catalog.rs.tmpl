---
to: "src/wasm4pm_facts_registry.rs"
sparql:
  breeds: |
    PREFIX compat: <https://wasm4pm.dev/ns#>
    SELECT ?id ?label ?doc ?citation
    WHERE {
      ?b a compat:CognitionBreed ;
         compat:breedId ?id ;
         compat:breedLabel ?label ;
         compat:breedDoc ?doc ;
         compat:citation ?citation .
    }
    ORDER BY ?id
  algorithms: |
    PREFIX pi: <https://wasm4pm.dev/pi#>
    SELECT ?id ?label ?doc ?citation ?category ?output_type ?speed_tier ?quality_tier ?wasm_export ?input_format ?standing
    WHERE {
      ?a a pi:ProcessIntelligenceAlgorithm ;
         pi:algorithmId ?id ;
         pi:algorithmLabel ?label ;
         pi:algorithmDoc ?doc ;
         pi:citation ?citation ;
         pi:category ?category ;
         pi:outputType ?output_type ;
         pi:speedTier ?speed_tier ;
         pi:qualityTier ?quality_tier ;
         pi:wasmExport ?wasm_export ;
         pi:inputFormat ?input_format ;
         pi:standing ?standing .
    }
    ORDER BY ?id
---
//! Generated `BreedRegistry`/`AlgorithmCatalog` -- GENERATED by `ggen sync`
//! from `packs/wasm4pm-facts-pack/ontology.ttl` via two independent SPARQL
//! SELECTs (distinct from the SELECTs `breed_algorithm_registry.md.tmpl`
//! issues for the markdown report -- this file's queries bind additional
//! algorithm columns the markdown report never surfaces, so this is not a
//! second rendering of the same query). Do not edit by hand: this is a pure
//! projection of the admitted graph, and the whole point of its existence is
//! to give the crate real typed data plus real lookup logic instead of only
//! a doc and a test-of-a-doc.
//!
//! This module is the "generation depth" and "handler-gap" answer for this
//! pack: `lookup_breed`/`lookup_algorithm`/`algorithms_by_category` are real
//! compiled behavior over the admitted facts, not just static string tables.

/// One `compat:CognitionBreed` individual.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct Breed {
    pub id: &'static str,
    pub label: &'static str,
    pub doc: &'static str,
    pub citation: &'static str,
}

/// One `pi:ProcessIntelligenceAlgorithm` individual.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct Algorithm {
    pub id: &'static str,
    pub label: &'static str,
    pub doc: &'static str,
    pub citation: &'static str,
    pub category: &'static str,
    pub output_type: &'static str,
    pub speed_tier: u32,
    pub quality_tier: u32,
    pub wasm_export: &'static str,
    pub input_format: &'static str,
    pub standing: &'static str,
}

/// All {{ breeds | length }} admitted cognition breeds, ordered by `id`.
pub const BREEDS: &[Breed] = &[
{% for row in breeds -%}
    Breed { id: "{{ row.id }}", label: "{{ row.label }}", doc: "{{ row.doc  | replace(from='"', to='\"') }}", citation: "{{ row.citation  | replace(from='"', to='\"') }}" },
{% endfor -%}
];

/// All {{ algorithms | length }} admitted process-intelligence algorithms, ordered by `id`.
pub const ALGORITHMS: &[Algorithm] = &[
{% for row in algorithms -%}
    Algorithm { id: "{{ row.id }}", label: "{{ row.label }}", doc: "{{ row.doc  | replace(from='"', to='\"') }}", citation: "{{ row.citation  | replace(from='"', to='\"') }}", category: "{{ row.category }}", output_type: "{{ row.output_type }}", speed_tier: {{ row.speed_tier }}, quality_tier: {{ row.quality_tier }}, wasm_export: "{{ row.wasm_export }}", input_format: "{{ row.input_format }}", standing: "{{ row.standing }}" },
{% endfor -%}
];

/// Look up a breed by its `compat:breedId`. Real behavior, not a static
/// table dump: this is the "zero handler gap" seam other packs' generated
/// code (or hand-written code in a consumer crate) can call directly.
pub fn lookup_breed(id: &str) -> Option<&'static Breed> {
    BREEDS.iter().find(|b| b.id == id)
}

/// Look up an algorithm by its `pi:algorithmId`.
pub fn lookup_algorithm(id: &str) -> Option<&'static Algorithm> {
    ALGORITHMS.iter().find(|a| a.id == id)
}

/// All algorithms in a given `pi:category`, in `ALGORITHMS` order.
pub fn algorithms_by_category(category: &str) -> Vec<&'static Algorithm> {
    ALGORITHMS.iter().filter(|a| a.category == category).collect()
}

/// Count of admitted breeds -- independently derived (via `BREEDS.len()`)
/// from the same graph the markdown registry's own header-count row
/// summarizes, letting a proof cross-check the two without either being the
/// other's oracle.
pub fn breed_count() -> usize {
    BREEDS.len()
}

/// Count of admitted algorithms.
pub fn algorithm_count() -> usize {
    ALGORITHMS.len()
}
