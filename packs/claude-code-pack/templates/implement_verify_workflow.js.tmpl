---
to: .claude/workflows/implement-verify.js
sparql:
  wf: |
    PREFIX ccw: <http://seanchatmangpt.github.io/packs/claude-code#>
    SELECT ?name ?description WHERE {
      ccw:wf-implement-verify ccw:name ?name ; ccw:description ?description .
    } ORDER BY ?name
  phases: |
    PREFIX ccw: <http://seanchatmangpt.github.io/packs/claude-code#>
    SELECT ?title ?detail ?order WHERE {
      ccw:wf-implement-verify ccw:hasPhase ?p .
      ?p ccw:title ?title ; ccw:detail ?detail ; ccw:order ?order .
    } ORDER BY ?order
  implement_prompt: |
    PREFIX ccw: <http://seanchatmangpt.github.io/packs/claude-code#>
    SELECT ?prompt WHERE {
      ?p ccw:isVerifyPhase false ; ccw:hasJob ?j . ?j ccw:prompt ?prompt .
    } ORDER BY ?prompt
  verify_prompt: |
    PREFIX ccw: <http://seanchatmangpt.github.io/packs/claude-code#>
    SELECT ?prompt WHERE {
      ?p ccw:isVerifyPhase true ; ccw:hasJob ?j . ?j ccw:prompt ?prompt .
    } ORDER BY ?prompt
---
// GENERATED by ggen sync from claude-code-pack/ontology.ttl. Do not edit by
// hand -- edit the ontology and re-run ggen sync. Runnable via the Claude
// Code Workflow tool: Workflow({name: "{{ wf[0].name }}", args: {batches: [...], verifyExtra: "..."}}).
export const meta = {
  name: {{ wf[0].name | json_encode | safe }},
  description: {{ wf[0].description | json_encode | safe }},
  phases: [
{% for p in phases %}    { title: {{ p.title | json_encode | safe }}, detail: {{ p.detail | json_encode | safe }} },
{% endfor %}  ],
}

// args contract: { batches: [{label: string, instructions: string}, ...],
//                  verifyExtra?: string }
const IMPLEMENT_PROMPT = {{ implement_prompt[0].prompt | json_encode | safe }}
const VERIFY_PROMPT = {{ verify_prompt[0].prompt | json_encode | safe }}

{% for p in phases %}{% if p.order == 0 %}phase('{{ p.title }}')
const implResults = await parallel((args.batches || []).map(b => () =>
  agent(IMPLEMENT_PROMPT + '\n\nYOUR BATCH: ' + b.label + '\n' + b.instructions,
    { label: 'impl:' + b.label, phase: '{{ p.title }}' })
))
{% else %}phase('{{ p.title }}')
const verifyResult = await agent(
  VERIFY_PROMPT + (args.verifyExtra ? '\n\nADDITIONAL CHECKS: ' + args.verifyExtra : ''),
  { phase: '{{ p.title }}', effort: 'high' }
)
{% endif %}{% endfor %}
return { implResults, verifyResult }
