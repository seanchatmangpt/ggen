<req/ard-refusal-unauthorized-recording> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#refusal-taxonomy> ; dcterms:title "UNAUTHORIZED_RECORDING" ; rdf:value "UNAUTHORIZED_RECORDING" .
