<req/ard-a11y-non-color-state> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Non-color state communication" ; rdf:value "non-color state communication" ; dcterms:requires <req/ard-a11y-wcag-baseline> .
<req/ard-a11y-content-density> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Content-density constraints" ; rdf:value "content-density constraints" ; dcterms:requires <req/ard-a11y-wcag-baseline> .
<req/ard-a11y-refresh-stability> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Refresh stability" ; rdf:value "refresh stability" ; dcterms:requires <req/ard-a11y-wcag-baseline> .
<req/ard-a11y-caption-timing> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Caption timing" ; rdf:value "caption timing" ; dcterms:requires <req/ard-a11y-wcag-baseline> .
<req/ard-a11y-speech-interruption> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Speech-output interruption behavior" ; rdf:value "speech-output interruption behavior" ; dcterms:requires <req/ard-a11y-wcag-baseline> .
<req/ard-a11y-reduced-motion> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Reduced-motion behavior" ; rdf:value "reduced-motion behavior" ; dcterms:requires <req/ard-a11y-wcag-baseline> .
<req/ard-a11y-zoom-reflow> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Zoom and reflow" ; rdf:value "zoom and reflow" ; dcterms:requires <req/ard-a11y-wcag-baseline> .
<req/ard-a11y-assistive-device-replay> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Assistive-device event replay" ; rdf:value "assistive-device event replay" ; dcterms:requires <req/ard-a11y-wcag-baseline> .

