<req/ard-a11y-zero-keyboard-path> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Zero-keyboard path" ; rdf:value "zero-keyboard path" ; dcterms:requires <req/ard-a11y-wcag-baseline> .
<req/ard-a11y-screenreader-order> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#accessibility-req> ; dcterms:title "Screen-reader order" ; rdf:value "screen-reader order" ; dcterms:requires <req/ard-a11y-wcag-baseline> .
