<req/ard-perf-first-projection> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#performance> ; dcterms:title "First projection after stable event < 250ms" ; rdf:value "first projection after stable event < 250 ms" .
<req/ard-perf-compile-dispatch> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#performance> ; dcterms:title "Compile dispatch < 50ms" ; rdf:value "compile dispatch < 50 ms" .
<req/ard-perf-replay-divergence> a schema:DigitalDocument ; dcterms:isPartOf <doc/ard#performance> ; dcterms:title "Zero session replay divergence" ; rdf:value "session replay divergence 0" .

