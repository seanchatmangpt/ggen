to: "lib/domain/policy-check.ts"
sparql:
  statements: |
    PREFIX odrl: <http://www.w3.org/ns/odrl/2/>
    SELECT ?policy ?kind ?action WHERE {
      ?policy a odrl:Set .
      { ?policy odrl:permission ?stmt . BIND("permission" AS ?kind) }
      UNION
      { ?policy odrl:prohibition ?stmt . BIND("prohibition" AS ?kind) }
      ?stmt odrl:action ?action .
    }
    ORDER BY ?policy ?kind ?action
---
// GENERATED by ggen sync from packs/wasm4pm-interview-assist-pack/ontology/50-policy.ttl
// via queries/policy-permissions.rq (TICKET-028). Do not hand-edit -- edit the ontology.

{% set grouped = statements | group_by(attribute="policy") %}
export type PolicyId =
{% for policy, rows in grouped %}  | "{{ policy | replace(from="https://github.com/seanchatmangpt/ggen/blob/main/packs/wasm4pm-interview-assist-pack/", to="") }}"
{% endfor %};

export type PolicyDecision = "allowed" | "denied" | "unspecified";

interface PolicyStatement {
  kind: "permission" | "prohibition";
  action: string;
}

/** odrl:permission/odrl:prohibition statements per policy/* odrl:Set, keyed by
 * the schema:Action resource each statement's odrl:action points at.
 */
export const POLICY_STATEMENTS: Record<PolicyId, readonly PolicyStatement[]> = {
{% for policy, rows in grouped %}  "{{ policy | replace(from="https://github.com/seanchatmangpt/ggen/blob/main/packs/wasm4pm-interview-assist-pack/", to="") }}": [
{% for r in rows %}    { kind: "{{ r.kind }}", action: "{{ r.action | replace(from="https://github.com/seanchatmangpt/ggen/blob/main/packs/wasm4pm-interview-assist-pack/", to="") }}" },
{% endfor %}  ],
{% endfor %}};

/**
 * Match an action (capability id, authority-action id, or prohibited-action id)
 * against the active policy's odrl:Set. An explicit prohibition wins over a
 * permission for the same action (fail-closed on conflict); an action neither
 * permitted nor prohibited is "unspecified" -- callers needing a boolean
 * should treat unspecified as denied (fail-closed).
 */
export function checkPolicy(action: string, activeMode: PolicyId): PolicyDecision {
  const stmts = POLICY_STATEMENTS[activeMode] ?? [];
  const prohibited = stmts.some((s) => s.kind === "prohibition" && s.action === action);
  if (prohibited) return "denied";
  const permitted = stmts.some((s) => s.kind === "permission" && s.action === action);
  if (permitted) return "allowed";
  return "unspecified";
}
