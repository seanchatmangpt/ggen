// GENERATED by ggen sync from packs/wasm4pm-interview-assist-pack/ontology/30-capabilities.ttl
// dcterms:requires edges via queries/capability-preconditions.rq (TICKET-028).
// Do not hand-edit -- edit the ontology.
import type { CapabilityId } from "./capability";

{% set grouped = edges | group_by(attribute="capability") %}
/** Direct (non-transitive) dcterms:requires edges per capability, as admitted. */
export const DIRECT_REQUIRES: Partial<Record<CapabilityId, readonly CapabilityId[]>> = {
{% for capability, rows in grouped %}  "{{ capability | replace(from="https://github.com/seanchatmangpt/ggen/blob/main/packs/wasm4pm-interview-assist-pack/", to="") }}": [{% for r in rows %}"{{ r.requires | replace(from="https://github.com/seanchatmangpt/ggen/blob/main/packs/wasm4pm-interview-assist-pack/", to="") }}"{% if not loop.last %}, {% endif %}{% endfor %}],
{% endfor %}};

/** Transitive closure of dcterms:requires for a capability, computed at call
 * time (not pre-flattened) so a fixture-added edge is picked up without
 * regenerating this file.
 */
export function transitiveRequires(capabilityId: CapabilityId): CapabilityId[] {
  const seen = new Set<CapabilityId>();
  const stack: CapabilityId[] = [...(DIRECT_REQUIRES[capabilityId] ?? [])];
  while (stack.length > 0) {
    const next = stack.pop() as CapabilityId;
    if (seen.has(next)) continue;
    seen.add(next);
    for (const r of DIRECT_REQUIRES[next] ?? []) stack.push(r);
  }
  return [...seen];
}

/** State = set of capability ids already satisfied/completed in this session. */
export type CapabilityState = ReadonlySet<CapabilityId>;

export interface PreconditionResult {
  met: boolean;
  missing: CapabilityId[];
}

export function checkPreconditions(
  capabilityId: CapabilityId,
  state: CapabilityState
): PreconditionResult {
  const required = transitiveRequires(capabilityId);
  const missing = required.filter((r) => !state.has(r));
  return { met: missing.length === 0, missing };
}
