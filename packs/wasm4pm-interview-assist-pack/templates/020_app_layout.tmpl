---
to: "app/layout.tsx"
sparql:
  products: |
    PREFIX schema: <https://schema.org/>
    SELECT ?name WHERE {
      ?product a schema:SoftwareApplication ;
               schema:name ?name .
    } LIMIT 1
---
{% for p in products %}import type { Metadata } from "next";
import type { ReactNode } from "react";
import "./globals.css";

export const metadata: Metadata = {
  title: "{{ p.name }}",
  description: "Generated App Router root layout (TICKET-012).",
};

export default function RootLayout({ children }: { children: ReactNode }) {
  return (
    <html lang="en">
      <body>{children}</body>
    </html>
  );
}
{% endfor %}
