/**
 * None of ARD §10's performance-target resources name a per-capability
 * timeout figure directly usable as an execution bound -- they are latency
 * budgets for pipeline stages, not a candidate-code execution wall-clock
 * cap. This documents an explicit, reviewable default pending an ARD
 * addition that specifies one.
 */
export const DEFAULT_CAPABILITY_TIMEOUT_MS = 10_000;

export type TimeoutRefusalCode = "capability/runtime/enforce-timeout";
export const TIMEOUT_REFUSAL_CODE: TimeoutRefusalCode = "capability/runtime/enforce-timeout";

export interface AdmissionResult<R = unknown> {
  status: "ok" | "refused";
  result?: R;
  refusal?: TimeoutRefusalCode;
  elapsedMs: number;
}

/**
 * Wrap a capability handler with a bounded-execution timeout. Genuinely
 * races the handler against a timer; does NOT itself kill underlying work --
 * TICKET-035's subprocess executor owns the actual process-kill side effect.
 */
export async function withTimeout<R>(
  _capabilityId: CapabilityId,
  fn: () => Promise<R>,
  timeoutMs: number = DEFAULT_CAPABILITY_TIMEOUT_MS
): Promise<AdmissionResult<R>> {
  const start = Date.now();
  let timer: ReturnType<typeof setTimeout>;
  const timeout = new Promise<AdmissionResult<R>>((resolve) => {
    timer = setTimeout(() => {
      resolve({ status: "refused", refusal: TIMEOUT_REFUSAL_CODE, elapsedMs: Date.now() - start });
    }, timeoutMs);
  });
  const work = fn().then((result): AdmissionResult<R> => ({
    status: "ok",
    result,
    elapsedMs: Date.now() - start,
  }));
  try {
    return await Promise.race([work, timeout]);
  } finally {
    clearTimeout(timer!);
  }
}
