# MESSAGE: every odrl:Permission/odrl:Prohibition object (of odrl:permission/odrl:prohibition) must carry odrl:action (targeting a schema:Action resource, never a bare literal or new ODRL action term) and odrl:assignee (any row = a permission/prohibition missing the bound ?missing property) — translates PermissionShape + ProhibitionShape (TICKET-009)
PREFIX odrl: <http://www.w3.org/ns/odrl/2/>
SELECT ?s ?missing WHERE {
  { ?policy odrl:permission ?s } UNION { ?policy odrl:prohibition ?s }
  VALUES ?missing { odrl:action odrl:assignee }
  FILTER NOT EXISTS { ?s ?missing ?any }
}
ORDER BY ?s ?missing
