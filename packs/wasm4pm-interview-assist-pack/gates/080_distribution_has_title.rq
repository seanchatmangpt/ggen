# MESSAGE: every dcat:Distribution must carry dcterms:title (any row = a distribution missing it) — translates DistributionShape (TICKET-009)
PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dcterms: <http://purl.org/dc/terms/>
SELECT ?s WHERE {
  ?s a dcat:Distribution .
  FILTER NOT EXISTS { ?s dcterms:title ?t }
}
ORDER BY ?s
