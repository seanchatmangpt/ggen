//! Hand-transcribed proof that `mcpp_catalog.rs` (GENERATED by `mcpp-pack`
//! from `packs/mcpp-pack/ontology.ttl`) matches the ontology's literal
//! `cnv:Command` individuals.
//!
//! Deliberately NO `sparql:` frontmatter key in this template (see
//! `mcpp_catalog.rs.tmpl` / `mcpp_reference.md.tmpl` for the query that
//! *does* exist): re-deriving the "expected" side via the same SPARQL query
//! that produced `MCPP_COMMANDS` would make every assertion a tautology
//! (actual == actual, computed twice). Every literal value below was
//! transcribed by hand from `packs/mcpp-pack/ontology.ttl`, not queried.
//!
//! For real (non-tautological) behavior coverage of the generated
//! subsystem, see `mcpp_dispatch_proof.rs` (same pack): it exercises
//! `mcpp_dispatch`'s actual `std::process::Command` construction, which is
//! executable behavior, not just a data-table mirror.

#[path = "../src/mcpp_catalog.rs"]
mod mcpp_catalog;

use mcpp_catalog::{McppCommand, MCPP_COMMANDS};

/// The ontology defines exactly 9 `cnv:Command` individuals under the
/// `mcpp#` namespace (packs/mcpp-pack/ontology.ttl) -- hand count, not a
/// query result.
#[test]
fn catalog_has_exactly_nine_commands() {
    assert_eq!(MCPP_COMMANDS.len(), 9);
}

/// `mcp:aat-live` is the only individual carrying a non-empty
/// `rdfs:comment` among the first two rows, and it sorts first under
/// `ORDER BY ?noun ?verb` ("aat" precedes every other noun in the
/// ontology; "live" precedes "run" and "verify").
#[test]
fn first_row_is_aat_live_with_its_doc_comment_and_args() {
    let row = MCPP_COMMANDS[0];
    assert_eq!(row.noun, "aat");
    assert_eq!(row.verb, "live");
    assert_eq!(row.doc, "Run a live AAT (admissible-action-trace) trace.");
    assert_eq!(
        row.args,
        "release|Option<String>|false|CalVer release tag, e.g. v26.5.19."
    );
}

/// `mcp:aat-run` has no `rdfs:comment` in the ontology, so `doc` must
/// resolve to the empty string via the query's `COALESCE(?comment_raw, "")`,
/// but it does carry one real argument (verified against
/// `~/mcpp/crates/mcpp-server/src/cmds/aat.rs:27`).
#[test]
fn second_row_is_aat_run_with_no_doc_comment() {
    let row = MCPP_COMMANDS[1];
    assert_eq!(row.noun, "aat");
    assert_eq!(row.verb, "run");
    assert_eq!(row.doc, "");
    assert_eq!(
        row.args,
        "release|Option<String>|false|CalVer release tag, e.g. v26.5.19."
    );
}

/// `mcp:completions-install` -- "completions" sorts after "aat".
#[test]
fn fourth_row_is_completions_install() {
    let row = MCPP_COMMANDS[3];
    assert_eq!(row.noun, "completions");
