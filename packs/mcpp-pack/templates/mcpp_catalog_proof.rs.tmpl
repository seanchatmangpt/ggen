/// `mcp:relay-verify-chain` -- "relay" sorts after "receipt". The verb is
/// `verify-chain`, not `verify`: a 2026-07-18 source-verification pass
/// against `~/mcpp/crates/mcpp-server/src/cmds/relay.rs:331`
/// (`fn verify_chain(chain: String, trust_list: Option<PathBuf>)`) found
/// the prior README-grepped `mcp:relay-verify` (verb "verify") named a
/// command that does not exist in real `mcpp` and corrected it.
#[test]
fn seventh_row_is_relay_verify_chain_not_relay_verify() {
    let row = MCPP_COMMANDS[6];
    assert_eq!(row.noun, "relay");
    assert_eq!(row.verb, "verify-chain");
    assert_eq!(
        row.args,
        "chain|String|true|Path to the relay chain file.@@trust_list|Option<PathBuf>|false|Path to a trust-list file to validate hops against."
    );
}

/// `mcp:template-lint` sorts last: "template" is alphabetically after
/// aat/completions/lsp/receipt/relay/settlement, the other six nouns in
/// the ontology.
#[test]
fn last_row_is_template_lint() {
    let row = MCPP_COMMANDS[8];
    assert_eq!(row.noun, "template");
    assert_eq!(row.verb, "lint");
    assert_eq!(row.doc, "");
}

/// General structural invariant: the catalog must already be sorted
/// ascending by `(noun, verb)`. This is a broader contract than any single
/// spot check above and would catch an ontology edit that shuffled row
/// order without touching the rows spot-checked individually.
///
/// Not tautological: the "expected" side is a fresh sort of a *copy* of the
/// data via `Ord`, not a second pass through the SPARQL query that produced
/// `MCPP_COMMANDS` in the first place.
#[test]
fn catalog_is_sorted_by_noun_then_verb() {
    let mut sorted: Vec<McppCommand> = MCPP_COMMANDS.to_vec();
    sorted.sort_by(|a, b| (a.noun, a.verb).cmp(&(b.noun, b.verb)));
    assert_eq!(MCPP_COMMANDS.to_vec(), sorted);
}

/// General structural invariant: no two rows may share the same
/// `(noun, verb)` pair -- catches an accidentally duplicated command
/// individual in the ontology that the hand-picked spot checks above
/// would not, by construction, ever notice.
#[test]
fn catalog_has_no_duplicate_noun_verb_pairs() {
    let mut seen: Vec<(&str, &str)> = Vec::new();
    for row in MCPP_COMMANDS {
        let pair = (row.noun, row.verb);
        assert!(
            !seen.contains(&pair),
            "duplicate (noun, verb) pair found in MCPP_COMMANDS: {:?}",
            pair
        );
        seen.push(pair);
    }
}

/// Every row's `args` string must either be empty or parse cleanly into
/// `@@`-separated `field|type|required|about` groups of exactly 4 pipe
/// fields each -- catches a malformed `cnv:args` literal in the ontology
/// that would otherwise only surface as a confusing runtime string.
#[test]
fn every_row_args_string_parses_into_well_formed_groups() {
    for row in MCPP_COMMANDS {
        if row.args.is_empty() {
            continue;
        }
        for group in row.args.split("@@") {
            let fields: Vec<&str> = group.split('|').collect();
            assert_eq!(
                fields.len(),
                4,
                "malformed args group {:?} in row {:?}/{:?}: expected 4 pipe-separated fields",
                group,
                row.noun,
                row.verb
            );
            assert!(!fields[0].is_empty(), "empty field name in {:?}", group);
            assert!(
                fields[2] == "true" || fields[2] == "false",
                "required column must be 'true' or 'false', got {:?} in {:?}",
                fields[2],
                group
            );
        }
    }
}
