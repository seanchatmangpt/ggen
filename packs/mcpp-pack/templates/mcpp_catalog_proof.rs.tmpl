//! Hand-transcribed proof that `mcpp_catalog.rs` (GENERATED by `mcpp-pack`
//! from `packs/mcpp-pack/ontology.ttl`) matches the ontology's literal
//! `cnv:Command` individuals.
//!
//! Deliberately NO `sparql:` frontmatter key in this template (see
//! `mcpp_catalog.rs.tmpl` / `mcpp_reference.md.tmpl` for the query that
//! *does* exist): re-deriving the "expected" side via the same SPARQL query
//! that produced `MCPP_COMMANDS` would make every assertion a tautology
//! (actual == actual, computed twice). Every literal value below was
//! transcribed by hand from `packs/mcpp-pack/ontology.ttl`, not queried.

#[path = "../src/mcpp_catalog.rs"]
mod mcpp_catalog;

use mcpp_catalog::{McppCommand, MCPP_COMMANDS};

/// The ontology defines exactly 9 `cnv:Command` individuals under the
/// `mcpp#` namespace (packs/mcpp-pack/ontology.ttl) -- hand count, not a
/// query result.
#[test]
fn catalog_has_exactly_nine_commands() {
    assert_eq!(MCPP_COMMANDS.len(), 9);
}

/// `mcp:aat-live` is the only individual carrying a non-empty
/// `rdfs:comment` in the ontology, and it sorts first under
/// `ORDER BY ?noun ?verb` ("aat" precedes every other noun in the
/// ontology; "live" precedes "run" and "verify").
#[test]
fn first_row_is_aat_live_with_its_doc_comment() {
    let row = MCPP_COMMANDS[0];
    assert_eq!(row.noun, "aat");
    assert_eq!(row.verb, "live");
    assert_eq!(row.doc, "Run a live AAT (admissible-action-trace) trace.");
}

/// `mcp:aat-run` has no `rdfs:comment` in the ontology, so `doc` must
/// resolve to the empty string via the query's `COALESCE(?comment_raw, "")`.
#[test]
fn second_row_is_aat_run_with_no_doc_comment() {
    let row = MCPP_COMMANDS[1];
    assert_eq!(row.noun, "aat");
    assert_eq!(row.verb, "run");
    assert_eq!(row.doc, "");
}

/// `mcp:completions-install` -- "completions" sorts after "aat".
#[test]
fn fourth_row_is_completions_install() {
    let row = MCPP_COMMANDS[3];
    assert_eq!(row.noun, "completions");
    assert_eq!(row.verb, "install");
    assert_eq!(row.doc, "");
}

/// `mcp:receipt-list` -- "receipt" sorts after "lsp".
#[test]
fn sixth_row_is_receipt_list() {
    let row = MCPP_COMMANDS[5];
    assert_eq!(row.noun, "receipt");
    assert_eq!(row.verb, "list");
    assert_eq!(row.doc, "");
}

/// `mcp:relay-verify` -- "relay" sorts after "receipt".
#[test]
fn seventh_row_is_relay_verify() {
    let row = MCPP_COMMANDS[6];
    assert_eq!(row.noun, "relay");
    assert_eq!(row.verb, "verify");
    assert_eq!(row.doc, "");
}

/// `mcp:template-lint` sorts last: "template" is alphabetically after
/// aat/completions/lsp/receipt/relay/settlement, the other six nouns in
/// the ontology.
#[test]
fn last_row_is_template_lint() {
    let row = MCPP_COMMANDS[8];
    assert_eq!(row.noun, "template");
    assert_eq!(row.verb, "lint");
    assert_eq!(row.doc, "");
}

/// General structural invariant: the catalog must already be sorted
/// ascending by `(noun, verb)`. This is a broader contract than any single
/// spot check above and would catch an ontology edit that shuffled row
/// order without touching the six rows spot-checked individually.
///
/// Not tautological: the "expected" side is a fresh sort of a *copy* of the
/// data via `Ord`, not a second pass through the SPARQL query that produced
/// `MCPP_COMMANDS` in the first place.
#[test]
fn catalog_is_sorted_by_noun_then_verb() {
    let mut sorted: Vec<McppCommand> = MCPP_COMMANDS.to_vec();
    sorted.sort_by(|a, b| (a.noun, a.verb).cmp(&(b.noun, b.verb)));
    assert_eq!(MCPP_COMMANDS.to_vec(), sorted);
}

/// General structural invariant: no two rows may share the same
/// `(noun, verb)` pair -- catches an accidentally duplicated command
/// individual in the ontology that the six hand-picked spot checks above
/// would not, by construction, ever notice.
#[test]
fn catalog_has_no_duplicate_noun_verb_pairs() {
    let mut seen: Vec<(&str, &str)> = Vec::new();
    for row in MCPP_COMMANDS {
        let pair = (row.noun, row.verb);
        assert!(
            !seen.contains(&pair),
            "duplicate (noun, verb) pair found in MCPP_COMMANDS: {:?}",
            pair
        );
        seen.push(pair);
    }
}
