---
to: src/mcpp_catalog.rs
force: true
sparql:
  rows: |
    PREFIX cnv: <http://seanchatmangpt.github.io/packs/clap-noun-verb#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?noun ?verb ?doc WHERE {
      ?c a cnv:Command ; cnv:noun ?noun ; cnv:verb ?verb .
      FILTER(STRSTARTS(STR(?c), "http://seanchatmangpt.github.io/packs/mcpp#"))
      OPTIONAL { ?c rdfs:comment ?comment_raw . }
      BIND(COALESCE(?comment_raw, "") AS ?doc)
    } ORDER BY ?noun ?verb
---
//! Typed catalog of ~/mcpp's `mcpp <noun> <verb>` commands grepped from its
//! README (known-partial sample, see `packs/mcpp-pack/pack.toml`).
//!
//! Generated by `mcpp-pack`. Reference only -- this crate does not invoke `mcpp`.

/// One `mcpp <noun> <verb>` command row.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct McppCommand {
    pub noun: &'static str,
    pub verb: &'static str,
    pub doc: &'static str,
}

/// The full (partial, README-sampled) catalog, ordered by (noun, verb).
pub const MCPP_COMMANDS: &[McppCommand] = &[
{% for row in rows %}    McppCommand { noun: "{{ row.noun }}", verb: "{{ row.verb }}", doc: "{{ row.doc }}" },
{% endfor %}];
