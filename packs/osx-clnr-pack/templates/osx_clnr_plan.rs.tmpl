---
to: src/osx_clnr_plan.rs
sparql:
  units: |
    PREFIX oclnr: <http://seanchatmangpt.github.io/packs/osx-clnr#>
    SELECT ?suffix ?mult WHERE {
      ?u a oclnr:ByteUnit ; oclnr:unitSuffix ?suffix ; oclnr:unitMultiplier ?mult .
    } ORDER BY ?mult
  policy: |
    PREFIX oclnr: <http://seanchatmangpt.github.io/packs/osx-clnr#>
    SELECT ?len WHERE {
      ?p a oclnr:SnapshotSelectionPolicy ; oclnr:dateSuffixLength ?len .
    } LIMIT 1
---
//! Real, compilable snapshot-selection and byte-size-parsing logic,
//! GENERATED by `osx-clnr-pack` from the `oclnr:ByteUnit` and
//! `oclnr:SnapshotSelectionPolicy` facts in `packs/osx-clnr-pack/ontology.ttl`.
//!
//! This is a reimplementation (not a wrapper) of the real algorithm in
//! `~/osx-clnr/src/domain/time.rs`'s `select_oldest_snapshots` /
//! `parse_snapshot_date` / `parse_size_in_bytes`, source-verified
//! 2026-07-18. The unit table and the date-suffix length below come from
//! the ontology (SPARQL-derived), not hardcoded in this template -- change
//! `ontology.ttl` and this logic's parameters change with it.

/// One accepted `--bytes` unit suffix and its SI-decimal multiplier.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct ByteUnit {
    pub suffix: &'static str,
    pub multiplier: u64,
}

/// Unit table, ascending by multiplier (ontology-derived).
pub const BYTE_UNITS: &[ByteUnit] = &[
{% for row in units %}    ByteUnit { suffix: "{{ row.suffix }}", multiplier: {{ row.mult }} },
{% endfor %}];

/// Required length of a valid zero-padded snapshot date suffix
/// (`YYYY-MM-DD-HHMMSS`), ontology-derived.
pub const SNAPSHOT_DATE_SUFFIX_LEN: usize = {% for row in policy %}{{ row.len }}{% endfor %};

/// Parses a human-entered size string (e.g. `"10GB"`, `"500MB"`, `"2048"`)
/// into a raw byte count, using the ontology-derived `BYTE_UNITS` table.
/// Mirrors `oclnr::domain::time::parse_size_in_bytes`'s parsing rule.
pub fn parse_size_in_bytes(s: &str) -> Result<u64, String> {
    let trimmed = s.trim().to_lowercase();
    if trimmed.is_empty() {
        return Err("Empty size string".to_string());
    }

    let mut unit_idx = trimmed.len();
    for (i, c) in trimmed.char_indices() {
        if !c.is_numeric() && c != '.' {
            unit_idx = i;
            break;
        }
    }

    let val_str = trimmed[..unit_idx].trim();
    let unit_str = trimmed[unit_idx..].trim();

    let val: f64 = val_str.parse().map_err(|e| format!("Invalid number: {e}"))?;

    let multiplier = if unit_str.is_empty() {
        1u64
    } else {
        BYTE_UNITS
            .iter()
            .find(|u| u.suffix == unit_str)
            .map(|u| u.multiplier)
            .ok_or_else(|| format!("Unknown size unit: {unit_str:?}"))?
    };

    Ok((val * multiplier as f64) as u64)
}

/// Returns `Some(date_suffix)` if `name` contains a dot-separated segment
/// that is a valid zero-padded snapshot date suffix (all ASCII digit/`-`,
/// exactly `SNAPSHOT_DATE_SUFFIX_LEN` characters); mirrors
/// `oclnr::domain::time::parse_snapshot_date`.
pub fn parse_snapshot_date(name: &str) -> Option<String> {
    name.split('.')
        .find(|part| {
            part.len() == SNAPSHOT_DATE_SUFFIX_LEN
                && part.chars().all(|c| c.is_ascii_digit() || c == '-')
        })
        .map(str::to_string)
}

/// Selects the `n` oldest local snapshots from `snapshots` by their
/// zero-padded date suffix, ascending (oldest first). Unparsable names are
/// dropped. `n == 0` selects nothing. Mirrors
/// `oclnr::domain::time::select_oldest_snapshots`.
pub fn select_oldest_snapshots(snapshots: &[String], n: usize) -> Vec<String> {
    let mut dated: Vec<String> = snapshots.iter().filter_map(|s| parse_snapshot_date(s)).collect();
    dated.sort();
    dated.truncate(n);
    dated
}

/// Set-difference of two snapshot-name lists: every name present in `before`
/// but absent from `after`, order preserved from `before`. Mirrors
/// `oclnr::domain::time::identify_thinned_snapshots` exactly (source-verified
/// 2026-07-19) -- this function has no free parameter for the ontology to
/// supply (see `oclnr:identify-thinned-snapshots`'s comment in
/// `ontology.ttl`), so it is transcribed here directly rather than templated
/// from a SPARQL result set.
pub fn identify_thinned_snapshots(before: &[String], after: &[String]) -> Vec<String> {
    let after_set: std::collections::HashSet<&String> = after.iter().collect();
    before.iter().filter(|s| !after_set.contains(s)).cloned().collect()
}

/// Terminal receipt of a local-snapshot-thinning execution. Mirrors
/// `oclnr::domain::time::SnapshotThinReceipt` field-for-field (source-verified
/// 2026-07-19; see `oclnr:SnapshotThinReceipt` in `ontology.ttl`).
#[derive(Debug, Clone, serde::Serialize, serde::Deserialize, PartialEq, Eq)]
pub struct SnapshotThinReceipt {
    pub volume: String,
    pub requested_bytes: u64,
    pub timestamp_unix: i64,
    pub snapshots_before: Vec<String>,
    pub snapshots_after: Vec<String>,
    pub snapshots_thinned: Vec<String>,
}

impl SnapshotThinReceipt {
    /// Mirrors `oclnr::domain::time::SnapshotThinReceipt::new` exactly: the
    /// `snapshots_thinned` field is derived via `identify_thinned_snapshots`,
    /// never supplied directly by the caller.
    pub fn new(
        volume: String,
        requested_bytes: u64,
        timestamp_unix: i64,
        snapshots_before: Vec<String>,
        snapshots_after: Vec<String>,
    ) -> Self {
        let snapshots_thinned = identify_thinned_snapshots(&snapshots_before, &snapshots_after);
        Self {
            volume,
            requested_bytes,
            timestamp_unix,
            snapshots_before,
            snapshots_after,
            snapshots_thinned,
        }
    }
}
