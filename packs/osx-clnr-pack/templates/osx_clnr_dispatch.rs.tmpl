---
to: src/osx_clnr_dispatch.rs
force: true
sparql:
  commands: |
    PREFIX oclnr: <http://seanchatmangpt.github.io/packs/osx-clnr#>
    PREFIX cnv: <http://seanchatmangpt.github.io/packs/clap-noun-verb#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?noun ?verb ?dispatch WHERE {
      ?c a cnv:Command ; cnv:noun ?noun ; cnv:verb ?verb .
      FILTER(STRSTARTS(STR(?c), "http://seanchatmangpt.github.io/packs/osx-clnr#"))
      OPTIONAL { ?c oclnr:dispatchesTo ?d . }
      BIND(COALESCE(?d, "") AS ?dispatch)
    } ORDER BY ?noun ?verb
---
//! Generated dispatch layer, GENERATED by `osx-clnr-pack` from each
//! `cnv:Command`'s `oclnr:dispatchesTo` fact in
//! `packs/osx-clnr-pack/ontology.ttl`.
//!
//! Handler-gap closure: commands whose `oclnr:dispatchesTo` names a real
//! function in `osx_clnr_plan.rs` get a fully generated handler below --
//! zero hand-write required. Commands with an empty `oclnr:dispatchesTo`
//! (no real algorithm modeled yet) instead get a method on
//! `OclnrHandlerSeam`, a stable seam a consumer must implement to supply
//! that domain-unique behavior. Which commands land in which bucket is
//! read from the ontology, not decided by this template -- adding a new
//! `cnv:Command` individual with an empty `dispatchesTo` grows the seam
//! automatically on the next `ggen sync run`.

use crate::osx_clnr_plan::{parse_size_in_bytes, select_oldest_snapshots};

/// Real generated handler for `oclnr snapshot delete --which oldest N`.
/// Mirrors `oclnr:snapshot-delete oclnr:dispatchesTo "select_oldest_snapshots"`.
/// Only the oldest-N selection path is modeled (see `osx_clnr_plan.rs`) --
/// `--which <name>`/`--which all` are NOT handled here.
pub fn handle_snapshot_delete_oldest_n(oldest_n: usize, available: &[String]) -> Vec<String> {
    select_oldest_snapshots(available, oldest_n)
}

/// Real generated handler for `oclnr snapshot thin --bytes <budget>`.
/// Mirrors `oclnr:snapshot-thin oclnr:dispatchesTo "parse_size_in_bytes"`.
pub fn handle_snapshot_thin_bytes_budget(bytes: &str) -> Result<u64, String> {
    parse_size_in_bytes(bytes)
}

/// Stable hand-write seam: one method per catalogued command whose
/// ontology-declared `oclnr:dispatchesTo` is empty. A consumer must
/// implement this trait to get real behavior for those commands; commands
/// with a non-empty `dispatchesTo` are NOT members of this trait -- their
/// behavior is fully generated above.
pub trait OclnrHandlerSeam {
{% for row in commands %}{% if row.dispatch == "" %}    /// Domain-unique handler for `oclnr {{ row.noun }}{% if row.verb %} {{ row.verb }}{% endif %}` --
    /// no generated behavior exists for this command yet (empty
    /// `oclnr:dispatchesTo`).
    fn handle_{{ row.noun }}{% if row.verb %}_{{ row.verb }}{% endif %}(&self) -> Result<(), String>;
{% endif %}{% endfor %}}
