---
to: src/osx_clnr_catalog.rs
force: true
sparql:
  stages: |
    PREFIX oclnr: <http://seanchatmangpt.github.io/packs/osx-clnr#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?order ?label ?doc WHERE {
      ?s a oclnr:Stage ; oclnr:order ?order ; rdfs:label ?label ; rdfs:comment ?doc .
    } ORDER BY ?order
  commands: |
    PREFIX cnv: <http://seanchatmangpt.github.io/packs/clap-noun-verb#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?noun ?verb ?doc WHERE {
      ?c a cnv:Command ; cnv:noun ?noun ; cnv:verb ?verb .
      FILTER(STRSTARTS(STR(?c), "http://seanchatmangpt.github.io/packs/osx-clnr#"))
      OPTIONAL { ?c rdfs:comment ?comment_raw . }
      BIND(COALESCE(?comment_raw, "") AS ?doc)
    } ORDER BY ?noun ?verb
---
//! Typed catalog of ~/osx-clnr's plan-bound pipeline and known `oclnr`
//! commands, transcribed from `packs/osx-clnr-pack/ontology.ttl`.
//!
//! Generated by `osx-clnr-pack`. Reference only -- this crate does not
//! invoke `oclnr`.

/// One stage of the audit -> plan -> delete -> receipt pipeline.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct PipelineStage {
    pub order: u32,
    pub label: &'static str,
    pub doc: &'static str,
}

/// Pipeline stages, ordered.
pub const PIPELINE_STAGES: &[PipelineStage] = &[
{% for row in stages %}    PipelineStage { order: {{ row.order }}, label: "{{ row.label }}", doc: "{{ row.doc }}" },
{% endfor %}];

/// One `oclnr <noun> <verb>` command row.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct OclnrCommand {
    pub noun: &'static str,
    pub verb: &'static str,
    pub doc: &'static str,
}

/// Known commands (partial -- no full source audit performed).
pub const OCLNR_COMMANDS: &[OclnrCommand] = &[
{% for row in commands %}    OclnrCommand { noun: "{{ row.noun }}", verb: "{{ row.verb }}", doc: "{{ row.doc }}" },
{% endfor %}];
