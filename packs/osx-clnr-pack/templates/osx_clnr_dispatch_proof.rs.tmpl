//! Chicago-TDD proof for `src/osx_clnr_dispatch.rs`, GENERATED by
//! `osx-clnr-pack`.
//!
//! Exercises the two fully-generated handlers against real inputs
//! (including an adversarial/error path), and proves the
//! `OclnrHandlerSeam` trait is real, implementable Rust -- not just a
//! doc-comment claim -- by giving it a concrete (dummy) implementation and
//! calling every method through the trait object.

#[path = "../src/osx_clnr_plan.rs"]
mod osx_clnr_plan;
#[path = "../src/osx_clnr_dispatch.rs"]
mod osx_clnr_dispatch;

use osx_clnr_dispatch::{
    handle_snapshot_delete_oldest_n, handle_snapshot_thin_bytes_budget, OclnrHandlerSeam,
};

struct DummyHandlers;

impl OclnrHandlerSeam for DummyHandlers {
    fn handle_snapshot_audit(&self) -> Result<(), String> {
        Ok(())
    }
    fn handle_receipt_verify(&self) -> Result<(), String> {
        Ok(())
    }
    fn handle_emergency(&self) -> Result<(), String> {
        Ok(())
    }
}

#[test]
fn generated_handler_selects_the_oldest_snapshot() {
    let snaps = vec![
        "com.apple.TimeMachine.2026-05-26-140000.local".to_string(),
        "com.apple.TimeMachine.2026-05-26-135630.local".to_string(),
    ];
    assert_eq!(
        handle_snapshot_delete_oldest_n(1, &snaps),
        vec!["2026-05-26-135630".to_string()]
    );
}

#[test]
fn generated_handler_selects_nothing_when_n_is_zero() {
    // Adversarial: must not default to "all" or panic.
    let snaps = vec!["com.apple.TimeMachine.2026-05-26-140000.local".to_string()];
    assert!(handle_snapshot_delete_oldest_n(0, &snaps).is_empty());
}

#[test]
fn generated_handler_parses_a_thin_budget() {
    assert_eq!(handle_snapshot_thin_bytes_budget("2gb").unwrap(), 2_000_000_000);
}

#[test]
fn generated_handler_rejects_a_bad_thin_budget() {
    // Adversarial: an unrecognized unit must fail closed, not silently
    // coerce to a multiplier of 1.
    assert!(handle_snapshot_thin_bytes_budget("5pb").is_err());
}

#[test]
fn hand_write_seam_trait_compiles_and_is_callable_through_a_real_impl() {
    let h: &dyn OclnrHandlerSeam = &DummyHandlers;
    assert!(h.handle_snapshot_audit().is_ok());
    assert!(h.handle_receipt_verify().is_ok());
    assert!(h.handle_emergency().is_ok());
}
