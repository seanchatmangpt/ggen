to: tests/osx_clnr_plan_proof.rs
sparql:
  unit_count: |
    PREFIX oclnr: <http://seanchatmangpt.github.io/packs/osx-clnr#>
    SELECT (COUNT(?u) AS ?n) WHERE { ?u a oclnr:ByteUnit . }
---
//! Chicago-TDD proof for `src/osx_clnr_plan.rs`, GENERATED by
//! `osx-clnr-pack`.
//!
//! Unlike `osx_clnr_catalog_proof.rs.tmpl`, the structural count below IS
//! SPARQL-derived (see the `unit_count` query above), not hand-transcribed:
//! if a future ontology edit adds/removes a `oclnr:ByteUnit` individual,
//! this assertion is regenerated to match automatically. Only the
//! *behavioral* assertions (real parsing/selection outputs) are literal,
//! because they encode the real `~/osx-clnr` algorithm being mirrored, not
//! a fact this pack's own ontology states a count for.
//!
//! Exercises real logic end to end, adversarial cases included -- no
//! mocks, no stubs: every assertion below runs the actual generated
//! `parse_size_in_bytes` / `parse_snapshot_date` / `select_oldest_snapshots`
//! functions against real inputs, several of them error/refusal paths.

#[path = "../src/osx_clnr_plan.rs"]
mod osx_clnr_plan;

use osx_clnr_plan::{
    identify_thinned_snapshots, parse_size_in_bytes, parse_snapshot_date, select_oldest_snapshots,
    SnapshotThinReceipt, BYTE_UNITS,
};

#[test]
fn byte_unit_table_has_the_ontology_derived_count() {
    // SPARQL-derived, not hand-copied: {{ unit_count[0].n }} `oclnr:ByteUnit`
    // individuals exist in ontology.ttl today.
    assert_eq!(BYTE_UNITS.len(), {{ unit_count[0].n }});
}

#[test]
fn parses_gb_suffix() {
    assert_eq!(parse_size_in_bytes("10GB").unwrap(), 10_000_000_000);
}

#[test]
fn parses_mb_suffix_case_insensitive() {
    assert_eq!(parse_size_in_bytes("500mb").unwrap(), 500_000_000);
}

#[test]
fn parses_bare_number_as_raw_bytes() {
    assert_eq!(parse_size_in_bytes("2048").unwrap(), 2048);
}

#[test]
fn parses_fractional_gb() {
    assert_eq!(parse_size_in_bytes("1.5gb").unwrap(), 1_500_000_000);
}

#[test]
fn refuses_empty_size_string() {
    // Adversarial / error path: empty input must fail closed, not default
    // to 0 bytes silently.
    assert!(parse_size_in_bytes("").is_err());
    assert!(parse_size_in_bytes("   ").is_err());
}

#[test]
fn refuses_unknown_unit_suffix() {
    // Adversarial: a plausible-looking but unrecognized unit ("pb" -
    // petabytes - is not in the ontology's unit table) must be rejected,
    // not silently coerced to a multiplier of 1.
    assert!(parse_size_in_bytes("5pb").is_err());
}

#[test]
fn refuses_non_numeric_value() {
    assert!(parse_size_in_bytes("abcGB").is_err());
}

#[test]
fn parses_real_time_machine_snapshot_date_suffix() {
    // Same fixture as the real ~/osx-clnr doctest for
    // `parse_snapshot_date`, source-verified 2026-07-18.
    assert_eq!(
        parse_snapshot_date("com.apple.TimeMachine.2026-05-26-135630.local"),
        Some("2026-05-26-135630".to_string())
    );
}

#[test]
fn rejects_names_with_no_valid_date_segment() {
    // Adversarial: a segment that is the wrong length, or contains
    // non-digit/non-dash characters, must not be mistaken for a date.
    assert_eq!(parse_snapshot_date("garbage"), None);
    assert_eq!(parse_snapshot_date("com.apple.TimeMachine.local"), None);
    assert_eq!(parse_snapshot_date("2026-05-26-1356300.local"), None); // 18 chars, one too many
}

#[test]
fn selects_the_two_oldest_snapshots_ascending() {
    // Same fixture as the real ~/osx-clnr doctest for
    // `select_oldest_snapshots`, source-verified 2026-07-18.
    let snaps = vec![
        "com.apple.TimeMachine.2026-05-26-140000.local".to_string(),
        "com.apple.TimeMachine.2026-05-26-135630.local".to_string(),
        "com.apple.TimeMachine.2026-05-27-090000.local".to_string(),
    ];
    assert_eq!(
        select_oldest_snapshots(&snaps, 2),
        vec!["2026-05-26-135630".to_string(), "2026-05-26-140000".to_string()]
    );
}

#[test]
fn zero_n_selects_nothing() {
    // Adversarial / refusal path: n == 0 must select nothing, not panic
    // and not default to "all".
    let snaps = vec!["com.apple.TimeMachine.2026-05-26-140000.local".to_string()];
    assert!(select_oldest_snapshots(&snaps, 0).is_empty());
}

#[test]
fn unparsable_names_are_dropped_not_fatal() {
    // Adversarial: garbage input must not panic and must not be selected.
    assert!(select_oldest_snapshots(&["garbage".to_string()], 1).is_empty());
}

#[test]
fn n_larger_than_available_returns_all_sorted() {
    // Adversarial: requesting more snapshots than exist must return
    // everything available, sorted, not error or pad with junk.
    let snaps = vec![
        "com.apple.TimeMachine.2026-05-27-090000.local".to_string(),
        "com.apple.TimeMachine.2026-05-26-135630.local".to_string(),
    ];
    let selected = select_oldest_snapshots(&snaps, 100);
    assert_eq!(
        selected,
        vec!["2026-05-26-135630".to_string(), "2026-05-27-090000".to_string()]
    );
}

#[test]
fn identifies_thinned_snapshots_as_set_difference() {
    let before = vec!["snap1".to_string(), "snap2".to_string()];
    let after = vec!["snap2".to_string()];
    assert_eq!(identify_thinned_snapshots(&before, &after), vec!["snap1".to_string()]);
    assert!(identify_thinned_snapshots(&before, &before).is_empty());
}

#[test]
fn snapshot_thin_receipt_derives_thinned_field_from_before_and_after() {
    let before = vec!["snap1".to_string(), "snap2".to_string()];
    let after = vec!["snap2".to_string()];
    let receipt =
        SnapshotThinReceipt::new("/".to_string(), 1_000_000, 1_716_768_000, before, after);
    assert_eq!(receipt.snapshots_thinned, vec!["snap1".to_string()]);
}
