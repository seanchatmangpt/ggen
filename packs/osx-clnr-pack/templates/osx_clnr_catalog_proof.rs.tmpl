//! Anti-drift proof for `src/osx_clnr_catalog.rs`, GENERATED by
//! `osx-clnr-pack`.
//!
//! Deliberately carries NO `sparql:` frontmatter key (it defaults to an
//! empty map in `ggen-engine`'s `Frontmatter` struct when omitted), so this
//! file cannot reuse `osx_clnr_catalog.rs.tmpl`'s SPARQL derivation path.
//! Every expected value below was hand-transcribed from
//! `packs/osx-clnr-pack/ontology.ttl` by reading the ontology directly, not
//! computed by evaluating any query -- if a future ontology edit changes a
//! `rdfs:comment`/`rdfs:label`/`oclnr:order` and the catalog template still
//! renders correctly, this proof only keeps passing if a human updates the
//! literal here too. That friction is the point, not a bug.

#[path = "../src/osx_clnr_catalog.rs"]
mod osx_clnr_catalog;

use osx_clnr_catalog::{OclnrCommand, OCLNR_COMMANDS, PIPELINE_STAGES};

fn find_command(noun: &str, verb: &str) -> &'static OclnrCommand {
    OCLNR_COMMANDS
        .iter()
        .find(|c| c.noun == noun && c.verb == verb)
        .unwrap_or_else(|| panic!("no oclnr command found for noun={noun:?} verb={verb:?}"))
}

#[test]
fn catalog_has_five_pipeline_stages_and_five_commands() {
    // ontology.ttl declares exactly 5 oclnr:Stage individuals (Audit, Plan,
    // Review, Delete, Receipt) and exactly 5 osx-clnr-prefixed cnv:Command
    // individuals (snapshot-audit, snapshot-thin, snapshot-delete,
    // receipt-verify, emergency).
    assert_eq!(PIPELINE_STAGES.len(), 5);
    assert_eq!(OCLNR_COMMANDS.len(), 5);
}

#[test]
fn stage_order_1_is_audit() {
    // ORDER BY ?order ascending in the generator query is a real structural
    // guarantee; this index-based check independently re-affirms it with a
    // hand-copied literal rather than re-querying.
    let s = PIPELINE_STAGES[0];
    assert_eq!(s.order, 1);
    assert_eq!(s.label, "Audit");
    assert_eq!(
        s.doc,
        "Scans the filesystem with traversal barriers (skips node_modules/target) to inventory hidden tool caches."
    );
}

#[test]
fn stage_order_3_is_human_review() {
    let s = PIPELINE_STAGES[2];
    assert_eq!(s.order, 3);
    assert_eq!(s.label, "Human review");
    assert_eq!(
        s.doc,
        "User inspects the plan or the emitted OCEL v2 event log before anything is deleted."
    );
}

#[test]
fn stage_order_5_is_receipt() {
    let s = PIPELINE_STAGES[4];
    assert_eq!(s.order, 5);
    assert_eq!(s.label, "Receipt");
    assert_eq!(
        s.doc,
        "Records the result; `oclnr receipt verify` checks measured volume delta against claimed reclaim, surfacing APFS snapshot pinning if space did not come back."
    );
}

#[test]
fn command_snapshot_audit_lists_local_snapshots() {
    let c = find_command("snapshot", "audit");
    assert_eq!(c.doc, "List all local APFS snapshots.");
}

#[test]
fn command_snapshot_thin_thins_to_byte_budget() {
    let c = find_command("snapshot", "thin");
    assert_eq!(c.doc, "Thin snapshots down to a byte budget.");
}

#[test]
fn command_snapshot_delete_deletes_oldest_or_all() {
    let c = find_command("snapshot", "delete");
    assert_eq!(c.doc, "Delete the oldest, or all, local snapshots.");
}

#[test]
fn command_receipt_verify_checks_measured_reclaim() {
    let c = find_command("receipt", "verify");
    assert_eq!(
        c.doc,
        "Verify measured reclaim against the receipt's claim, within tolerance."
    );
}

#[test]
fn command_emergency_is_bare_noun_enospc_recovery() {
    let c = find_command("emergency", "");
    assert_eq!(
        c.doc,
        "Bare noun: dry-run or (--yes) execute deletion of all local snapshots + regenerable-cache sweep, for ENOSPC recovery."
    );
}
