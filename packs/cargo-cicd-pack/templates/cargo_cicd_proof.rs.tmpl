---
to: tests/cargo_cicd_catalog_proof.rs
force: true
sparql:
  rows: |
    PREFIX cnv: <http://seanchatmangpt.github.io/packs/clap-noun-verb#>
    PREFIX cc:  <http://seanchatmangpt.github.io/packs/cargo-cicd#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?noun ?verb ?doc ?src WHERE {
      ?c a cnv:Command ; cnv:noun ?noun ; cnv:verb ?verb .
      FILTER(STRSTARTS(STR(?c), "http://seanchatmangpt.github.io/packs/cargo-cicd#"))
      OPTIONAL { ?c rdfs:comment ?comment_raw . }
      BIND(COALESCE(?comment_raw, "") AS ?doc)
      OPTIONAL { ?c cc:sourceFile ?src_raw . }
      BIND(COALESCE(?src_raw, "") AS ?src)
    } ORDER BY ?noun ?verb
---
//! Proof test for `cargo-cicd-pack`'s generated static catalog
//! (`src/cargo_cicd_catalog.rs`).
//!
//! GENERATED by `cargo-cicd-pack`. Per-row expected-value assertions below
//! are rendered from the SAME SPARQL query that produced
//! `src/cargo_cicd_catalog.rs` -- NOT hand-transcribed literals. This closes
//! the drift gap the prior version of this proof had: editing
//! `ontology.ttl` (adding/removing/renaming a command) and re-running
//! `ggen sync run` now regenerates BOTH the catalog and this proof's
//! expected values in lockstep, with no human hand-edit step required for
//! the per-row checks. What is NOT tautological: every assertion below
//! calls the real `find_command`/`commands_for_noun`/`is_valid_command`
//! functions against the compiled `CARGO_CICD_COMMANDS` table, so a bug in
//! how the catalog template assembles the table (wrong field order, dropped
//! row, typo in a struct literal) still fails this proof even though the
//! expected values are SPARQL-sourced. The structural invariants further
//! below (uniqueness, sortedness, the doctor-migration shape) are computed
//! independently in Rust, not sourced from the query at all.

#[path = "../src/cargo_cicd_catalog.rs"]
mod cargo_cicd_catalog;

use cargo_cicd_catalog::{
    commands_for_noun, distinct_nouns, find_command, is_valid_command, CARGO_CICD_COMMANDS,
};

/// Exact row count, sourced from the same SPARQL query as the catalog
/// (`{{ rows | length }}` rows at generation time) -- not a hand-counted
/// literal, so this assertion never goes stale relative to `ontology.ttl`.
#[test]
fn catalog_row_count_matches_ontology_query() {
    assert_eq!(
        CARGO_CICD_COMMANDS.len(),
        {{ rows | length }},
        "catalog row count drifted from the generating SPARQL query"
    );
}

/// Every row the generating SPARQL query returned must be independently
/// retrievable from the compiled catalog via `find_command`, with the exact
/// doc string and source file the query produced. This is the per-row
/// lockstep check: if the catalog template ever drops, duplicates, or
/// mis-assembles a row, this loop fails even though the expected values
/// come from the same query -- it exercises the *generated table*, not the
/// query result a second time.
#[test]
fn every_queried_row_is_present_with_matching_fields() {
{% for row in rows %}    {
        let row = find_command("{{ row.noun }}", "{{ row.verb }}")
            .unwrap_or_else(|| panic!("missing row noun={:?} verb={:?}", "{{ row.noun }}", "{{ row.verb }}"));
        assert_eq!(row.doc, "{{ row.doc }}", "doc mismatch for {{ row.noun }}/{{ row.verb }}");
        assert_eq!(row.source_file, "{{ row.src }}", "source_file mismatch for {{ row.noun }}/{{ row.verb }}");
    }
{% endfor %}}

/// Structural invariant, computed independently of the query: no duplicate
/// (noun, verb) pair exists in the compiled catalog.
#[test]
fn no_duplicate_noun_verb_pairs() {
    let mut seen: Vec<(&str, &str)> = Vec::new();
    for c in CARGO_CICD_COMMANDS {
        let key = (c.noun, c.verb);
        assert!(
            !seen.contains(&key),
            "duplicate (noun, verb) pair: {:?}",
            key
        );
        seen.push(key);
    }
}

/// Structural invariant: the catalog is generated `ORDER BY ?noun ?verb`,
/// so consecutive rows must be non-decreasing by (noun, verb) -- checked by
/// direct comparison, not by re-sorting and diffing (which would be
/// tautological).
#[test]
fn catalog_is_sorted_by_noun_then_verb() {
    for w in CARGO_CICD_COMMANDS.windows(2) {
        let (a, b) = (w[0], w[1]);
        assert!(
            (a.noun, a.verb) <= (b.noun, b.verb),
            "catalog not sorted: {:?} appears before {:?}",
            a,
            b
        );
    }
}

/// Structural invariant: `distinct_nouns()` (a real function over the real
/// table) returns a sorted, deduplicated noun list with no empty entries.
#[test]
fn distinct_nouns_is_sorted_and_nonempty() {
    let nouns = distinct_nouns();
    assert!(!nouns.is_empty());
    for w in nouns.windows(2) {
        assert!(w[0] < w[1], "distinct_nouns() not strictly sorted: {:?}", w);
    }
    assert!(nouns.iter().all(|n| !n.is_empty()));
}

/// Structural invariant: `commands_for_noun("doctor")` returns at least the
/// three real verbs the 2026-07-18 source audit found (`repo`, `evidence`,
/// `diff`) -- catching any regression back to treating `doctor` as a bare
/// noun.
#[test]
fn doctor_noun_has_real_verbs_not_only_the_deprecated_bare_row() {
    let doctor_verbs: Vec<&str> = commands_for_noun("doctor").map(|c| c.verb).collect();
    assert!(doctor_verbs.contains(&"repo"), "missing doctor repo");
    assert!(doctor_verbs.contains(&"evidence"), "missing doctor evidence");
    assert!(doctor_verbs.contains(&"diff"), "missing doctor diff");
}

/// `is_valid_command` returns `false` for a command that plausibly does not
/// exist -- the negative-path proof this pack lacked before (adversarial:
/// a syntactically-similar but wrong noun/verb pair).
#[test]
fn unknown_command_is_not_valid() {
    assert!(!is_valid_command("status", "delete"));
    assert!(!is_valid_command("nonexistent-noun", "show"));
}

/// `find_command` returns `None`, not a panic or a default value, for an
/// unknown pair.
#[test]
fn find_command_returns_none_for_unknown_pair() {
    assert!(find_command("evidence", "nonexistent-verb").is_none());
}
