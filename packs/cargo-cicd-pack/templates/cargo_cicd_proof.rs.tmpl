//! Proof test for `cargo-cicd-pack`'s generated static catalog
//! (`src/cargo_cicd_catalog.rs`).
//!
//! GENERATED by `cargo-cicd-pack`. `src/cargo_cicd_catalog.rs` is a pure
//! static data catalog (a struct + a const slice) with no function,
//! `emit_*`, or dispatch/match logic to exercise -- so this proof does NOT
//! re-run the generating SPARQL query (that would be tautological, the
//! CHEAT-T02 pattern this repo's cheat scanner flags). Instead every
//! expected value below is a LITERAL, hand-transcribed from
//! `packs/cargo-cicd-pack/ontology.ttl` at proof-authoring time. If the
//! ontology changes, these literals go stale on purpose -- that staleness
//! is the point: it is what makes this a real proof of the generated
//! artifact instead of a mirror of the query that produced it.

#[path = "../src/cargo_cicd_catalog.rs"]
mod cargo_cicd_catalog;

use cargo_cicd_catalog::{CargoCicdCommand, CARGO_CICD_COMMANDS};

fn find(noun: &str, verb: &str) -> &'static CargoCicdCommand {
    CARGO_CICD_COMMANDS
        .iter()
        .find(|c| c.noun == noun && c.verb == verb)
        .unwrap_or_else(|| panic!("no row for noun={noun:?} verb={verb:?} in CARGO_CICD_COMMANDS"))
}

/// `ontology.ttl` defines exactly 26 `cnv:Command` individuals under the
/// `cc:` namespace (hand-counted, 2026-07-18).
#[test]
fn catalog_has_exactly_26_commands() {
    assert_eq!(
        CARGO_CICD_COMMANDS.len(),
        26,
        "expected 26 hand-counted individuals from ontology.ttl, got {}",
        CARGO_CICD_COMMANDS.len()
    );
}

/// The 8 distinct nouns in `ontology.ttl`, hand-transcribed and sorted.
#[test]
fn catalog_has_exactly_8_distinct_nouns() {
    let mut nouns: Vec<&str> = CARGO_CICD_COMMANDS.iter().map(|c| c.noun).collect();
    nouns.sort_unstable();
    nouns.dedup();
    assert_eq!(
        nouns,
        vec![
            "doctor", "evidence", "git", "publish", "status", "target", "test", "workspace",
        ],
        "distinct noun set changed, got {nouns:?}"
    );
}

/// Per-noun row counts, hand-counted from `ontology.ttl`:
/// status=2, workspace=4, target=2, test=3, git=6, publish=3, evidence=5, doctor=1.
#[test]
fn catalog_noun_counts_match_ontology() {
    fn count(noun: &str) -> usize {
        CARGO_CICD_COMMANDS.iter().filter(|c| c.noun == noun).count()
    }
    assert_eq!(count("status"), 2, "status row count");
    assert_eq!(count("workspace"), 4, "workspace row count");
    assert_eq!(count("target"), 2, "target row count");
    assert_eq!(count("test"), 3, "test row count");
    assert_eq!(count("git"), 6, "git row count");
    assert_eq!(count("publish"), 3, "publish row count");
    assert_eq!(count("evidence"), 5, "evidence row count");
    assert_eq!(count("doctor"), 1, "doctor row count");
}

/// Spot-check: `cc:status-show` carries an `rdfs:comment`.
#[test]
fn status_show_doc_matches_ontology() {
    let row = find("status", "show");
    assert_eq!(
        row.doc,
        "Workspace status: dirty files, pending tests, trybuild result, publish readiness."
    );
}

