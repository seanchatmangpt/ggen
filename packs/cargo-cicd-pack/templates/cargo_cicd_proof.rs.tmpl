/// Edge case: `cc:doctor` is a bare noun with an EMPTY verb -- an actual
/// `""` literal asserted by `cnv:verb ""` in `ontology.ttl`, not an absent
/// field -- and it DOES carry a comment.
#[test]
fn bare_doctor_noun_has_empty_verb_and_a_comment() {
    let row = find("doctor", "");
    assert_eq!(row.verb, "");
    assert_eq!(
        row.doc,
        "Bare noun, no verb: diagnoses repository health against a recorded baseline and reports evidence drift."
    );
}

/// Edge case: `cc:git-status` has NO `rdfs:comment` in `ontology.ttl`, so
/// the generating template's `COALESCE(?comment_raw, "")` must render an
/// empty string in the catalog -- not a missing field, not "None".
#[test]
fn git_status_has_no_comment_and_renders_empty_doc() {
    let row = find("git", "status");
    assert_eq!(row.doc, "");
}

/// Ordering: the catalog is generated `ORDER BY ?noun ?verb`. The first row
/// alphabetically is `("doctor", "")` -- "doctor" sorts before every other
/// noun and it is the sole doctor row.
#[test]
fn first_row_is_bare_doctor() {
    let first = CARGO_CICD_COMMANDS
        .first()
        .expect("catalog must be non-empty");
    assert_eq!(first.noun, "doctor");
    assert_eq!(first.verb, "");
}

/// Ordering: the last row alphabetically is `("workspace", "validate")` --
/// "workspace" is the last noun alphabetically, and among its 4 verbs
/// (doctor/list/sync/validate), "validate" sorts last.
#[test]
fn last_row_is_workspace_validate() {
    let last = CARGO_CICD_COMMANDS
        .last()
        .expect("catalog must be non-empty");
    assert_eq!(last.noun, "workspace");
    assert_eq!(last.verb, "validate");
}
