---
to: src/cargo_cicd_catalog.rs
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/cargo-cicd-pack
sparql:
  rows: |
    PREFIX cnv: <http://seanchatmangpt.github.io/packs/clap-noun-verb#>
    PREFIX cc:  <http://seanchatmangpt.github.io/packs/cargo-cicd#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?noun ?verb ?doc ?src ?argCount ?args WHERE {
      ?c a cnv:Command ; cnv:noun ?noun ; cnv:verb ?verb .
      FILTER(STRSTARTS(STR(?c), "http://seanchatmangpt.github.io/packs/cargo-cicd#"))
      OPTIONAL { ?c rdfs:comment ?comment_raw . }
      BIND(COALESCE(?comment_raw, "") AS ?doc)
      OPTIONAL { ?c cc:sourceFile ?src_raw . }
      BIND(COALESCE(?src_raw, "") AS ?src)
      OPTIONAL { ?c cc:argCount ?argCount_raw . }
      BIND(COALESCE(?argCount_raw, 0) AS ?argCount)
      OPTIONAL { ?c cc:args ?args_raw . }
      BIND(COALESCE(?args_raw, "") AS ?args)
    } ORDER BY ?noun ?verb
---
//! Typed catalog of ~/cargo-cicd's real `cargo cicd <noun> <verb>` command
//! surface, transcribed from `packs/cargo-cicd-pack/ontology.ttl`.
//!
//! Generated by `cargo-cicd-pack`. Source-audited 2026-07-18 against
//! `~/cargo-cicd` v26.7.6 (`src/nouns/*.rs`, see each row's `source_file`
//! field) -- not merely README-derived. `arg_count`/`args` are re-read
//! directly from each real `#[verb(...)]`-annotated `pub fn cmd_*` signature
//! (round-3 addition). Reference only -- this crate does not invoke
//! `cargo-cicd`.

/// One `cargo cicd <noun> <verb>` command row.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct CargoCicdCommand {
    pub noun: &'static str,
    pub verb: &'static str,
    pub doc: &'static str,
    /// Path (relative to `~/cargo-cicd`) of the source file this row was
    /// audited against, e.g. `"src/nouns/git.rs"`. Empty string only for
    /// the deprecated `doctor`/`""` compatibility row.
    pub source_file: &'static str,
    /// Number of real CLI-facing arguments the underlying `cmd_*` function
    /// takes, source-verified against `~/cargo-cicd`.
    pub arg_count: u8,
    /// `"name:Type;name:Type;..."` for commands with `arg_count > 0`, else
    /// `""`. Source-verified, not invented.
    pub args: &'static str,
}

/// The full catalog, ordered by (noun, verb).
pub const CARGO_CICD_COMMANDS: &[CargoCicdCommand] = &[
{% for row in rows %}    CargoCicdCommand { noun: "{{ row.noun }}", verb: "{{ row.verb }}", doc: "{{ row.doc }}", source_file: "{{ row.src }}", arg_count: {{ row.argCount }}, args: "{{ row.args }}" },
{% endfor %}];

/// Look up one command row by exact (noun, verb). Real, callable behavior
/// over the generated catalog -- not merely a static table.
pub fn find_command(noun: &str, verb: &str) -> Option<&'static CargoCicdCommand> {
    CARGO_CICD_COMMANDS
        .iter()
        .find(|c| c.noun == noun && c.verb == verb)
}

/// All command rows for a given noun, in catalog order.
pub fn commands_for_noun(noun: &str) -> impl Iterator<Item = &'static CargoCicdCommand> + '_ {
    CARGO_CICD_COMMANDS.iter().filter(move |c| c.noun == noun)
}

/// True iff `(noun, verb)` is a known `cargo cicd` command in this catalog.
pub fn is_valid_command(noun: &str, verb: &str) -> bool {
    find_command(noun, verb).is_some()
}

/// The distinct set of nouns in the catalog, in first-seen (sorted) order.
pub fn distinct_nouns() -> Vec<&'static str> {
    let mut nouns: Vec<&'static str> = CARGO_CICD_COMMANDS.iter().map(|c| c.noun).collect();
    nouns.sort_unstable();
    nouns.dedup();
    nouns
}

/// Parses one command's `args` field into `(name, type)` pairs. Real parsing
/// logic over ontology-sourced data (`cc:args`), not a hand-copied literal --
/// returns an empty `Vec` for `arg_count == 0` commands.
pub fn parse_args(cmd: &CargoCicdCommand) -> Vec<(&'static str, &'static str)> {
    if cmd.args.is_empty() {
        return Vec::new();
    }
    cmd.args
        .split(';')
        .filter_map(|pair| pair.split_once(':'))
        .collect()
}

/// True iff `parse_args` yields exactly `arg_count` entries for every row in
/// the catalog -- a structural consistency check between the two
/// independently-sourced `cc:argCount`/`cc:args` facts.
pub fn args_are_consistent() -> bool {
    CARGO_CICD_COMMANDS
        .iter()
        .all(|c| parse_args(c).len() as u8 == c.arg_count)
}
