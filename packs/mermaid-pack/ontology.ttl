mer:Diagram_RendererArchitecture a mer:Diagram ;
    mer:diagramType mer:Type_flowchart_v2 ;
    mer:outputPath "docs/architecture/mermaid-renderer-architecture.mmd" ;
    mer:authorityClass mer:Normative ;
    mer:generated true ;
    mer:generationIndex 1 ;
    mer:standingCeiling "SourcePinned" ;
    mer:sourceText """flowchart LR
    O[受入済みRDF] --> G[ggen]
    G --> M[Mermaid原文]
    M --> D[detectType]
    D --> L[遅延読込]
    L --> P[parser]
    P --> DB[diagram DB]
    DB --> R[renderer.draw]
    R --> S[SVG]
    S --> V[構文・描画検査]
    V --> RC[受領証]
""" .

mer:Diagram_RendererResolution a mer:Diagram ;
    mer:diagramType mer:Type_sequence ;
    mer:outputPath "docs/architecture/renderer-source-resolution.mmd" ;
    mer:authorityClass mer:Normative ;
    mer:generated true ;
    mer:generationIndex 1 ;
    mer:standingCeiling "SourcePinned" ;
    mer:sourceText """sequenceDiagram
    participant G as ggen
    participant O as diagram-orchestration.ts
    participant D as Detector
    participant F as Diagram Definition
    participant R as Renderer
    G->>O: 登録済み検出器を列挙
    O-->>G: detector path
    G->>D: loaderを解析
    D-->>G: definition path
    G->>F: renderer importを解析
    F-->>G: renderer path
    G->>R: commit固定URLを生成
    R-->>G: 出典受領
""" .

mer:Diagram_AuthorityState a mer:Diagram ;
    mer:diagramType mer:Type_stateDiagram_v2 ;
    mer:outputPath "docs/architecture/diagram-authority-state.mmd" ;
    mer:authorityClass mer:Normative ;
    mer:generated true ;
    mer:generationIndex 1 ;
    mer:standingCeiling "Constitutional" ;
    mer:sourceText """stateDiagram-v2
    [*] --> Observed
    Observed --> Quarantined: 出典不一致
    Observed --> Admitted: 出典固定・構文合格
    Quarantined --> Admitted: 再調査
    Admitted --> Rendered: mmdc
    Rendered --> Receipted: SVG要約保存
    Receipted --> Stale: 上流版又は意味変更
    Stale --> Observed
""" .
