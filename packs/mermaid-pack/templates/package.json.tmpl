---
to: "package.json"
force: false
sparql:
  version: |
    PREFIX mer: <https://seanchatmangpt.github.io/ontology/mermaid#>
    PREFIX dct: <http://purl.org/dc/terms/>
    SELECT ?id WHERE {
      mer:Mermaid_11_16_0 dct:identifier ?id .
    }
---
{
  "private": true,
  "type": "module",
  "scripts": {
    "mermaid:verify": "node scripts/verify-mermaid.mjs",
    "mermaid:render": "bash scripts/render-mermaid.sh"
  },
  "devDependencies": {
    "mermaid": "{{ version[0].id }}",
    "@mermaid-js/mermaid-cli": "{{ version[0].id }}"
  }
}
