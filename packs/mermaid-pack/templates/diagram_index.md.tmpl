---
to: "docs/mermaid/図面台帳.md"
sparql:
  rows: |
    PREFIX mer: <https://seanchatmangpt.github.io/ontology/mermaid#>
    SELECT ?path ?typeId ?authority ?standing WHERE {
      ?diagram a mer:Diagram ;
               mer:outputPath ?path ;
               mer:diagramType ?type ;
               mer:authorityClass ?authority ;
               mer:standingCeiling ?standing .
      ?type mer:diagramId ?typeId .
    } ORDER BY ?path
---
