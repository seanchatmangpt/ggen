# MESSAGE: every lm:LintRule/lm:RulePack property is single-valued (translated from shapes.ttl sh:maxCount 1; any row = a subject carrying two distinct values for ?p)
PREFIX lm:   <http://seanchatmangpt.github.io/packs/lsp-max#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?s ?p WHERE {
  {
    ?s a lm:LintRule .
    VALUES ?p {
      lm:ruleId lm:name lm:severity lm:pattern lm:pathGlobs
      lm:excludeGlobs lm:evalBudget lm:message lm:rationale
    }
  } UNION {
    ?s a lm:RulePack .
    VALUES ?p { rdfs:label lm:packDescription }
  }
  ?s ?p ?v1 , ?v2 .
  FILTER(?v1 != ?v2)
}
ORDER BY ?s ?p
