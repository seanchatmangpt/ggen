---
to: docs/lsp_max_rule_pack.md
sparql:
  rules: >
    PREFIX lm: <http://seanchatmangpt.github.io/packs/lsp-max#>
    SELECT ?ruleId ?name ?severity ?message
    WHERE {
      ?rule a lm:LintRule ;
            lm:ruleId   ?ruleId ;
            lm:name     ?name ;
            lm:severity ?severity ;
            lm:message  ?message .
    }
    ORDER BY ?ruleId
---
