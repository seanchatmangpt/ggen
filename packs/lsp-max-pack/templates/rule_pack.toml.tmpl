---
to: "rules/lsp_max_{{ ruleId | snake_case }}.toml"
sparql:
  rules: >
    PREFIX lm: <http://seanchatmangpt.github.io/packs/lsp-max#>
    SELECT ?ruleId ?name ?severity ?pattern ?message ?rationale
    WHERE {
      ?rule a lm:LintRule ;
            lm:ruleId    ?ruleId ;
            lm:name      ?name ;
            lm:severity  ?severity ;
            lm:pattern   ?pattern ;
            lm:message   ?message ;
            lm:rationale ?rationale .
    }
    ORDER BY ?ruleId
---
# lsp-max RulePackServer rule pack — generated by ggen (lsp-max-pack).
# Loaded by the AhoCorasick rule engine; one [[rules]] table per file.

[[rules]]
id = "{{ ruleId }}"
name = "{{ name }}"
severity = "{{ severity }}"
pattern = '{{ pattern }}'
path_globs = ["src/**", "crates/**"]
exclude_globs = ["target/**", ".git/**"]
message = "{{ message }}"
rationale = "{{ rationale }}"
