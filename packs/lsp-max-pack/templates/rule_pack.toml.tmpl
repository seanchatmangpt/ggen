---
to: "rules/lsp_max_{{ ruleId | snake_case }}.toml"
sparql:
  rules: >
    PREFIX lm: <http://seanchatmangpt.github.io/packs/lsp-max#>
    SELECT ?ruleId ?name ?severity ?pattern ?pathGlobs ?excludeGlobs ?evalBudget ?message ?rationale
    WHERE {
      ?rule a lm:LintRule ;
            lm:ruleId       ?ruleId ;
            lm:name         ?name ;
            lm:severity     ?severity ;
            lm:pattern      ?pattern ;
            lm:pathGlobs    ?pathGlobs ;
            lm:excludeGlobs ?excludeGlobs ;
            lm:evalBudget   ?evalBudget ;
            lm:message      ?message ;
            lm:rationale    ?rationale .
    }
    ORDER BY ?ruleId
---
# lsp-max RulePackServer rule pack — generated by ggen (lsp-max-pack).
# Loaded by the real regex-based rule engine: `~/lsp-max/src/rule_pack_server.rs`'s
# `evaluate()` compiles `Rule::pattern` with `regex::Regex` and runs
# `Regex::find_iter` per source line -- there is no AhoCorasick anywhere in
# that path (verified 2026-07-18 by reading `rule_pack_server.rs` directly;
# an earlier revision of this comment incorrectly claimed AhoCorasick).
# One [[rules]] table per file; every field below (including path_globs /
# exclude_globs / eval_budget) is projected straight from the ontology --
# none of it is a template-hardcoded literal.

[[rules]]
id = "{{ ruleId }}"
name = "{{ name }}"
severity = "{{ severity }}"
pattern = '{{ pattern }}'
path_globs = [{% for g in pathGlobs | split(pat=" ") %}"{{ g }}"{% if not loop.last %}, {% endif %}{% endfor %}]
exclude_globs = [{% for g in excludeGlobs | split(pat=" ") %}"{{ g }}"{% if not loop.last %}, {% endif %}{% endfor %}]
message = "{{ message }}"
rationale = "{{ rationale }}"
eval_budget = "{{ evalBudget }}"
