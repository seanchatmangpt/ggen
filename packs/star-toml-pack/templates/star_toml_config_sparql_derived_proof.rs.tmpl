---
to: tests/star_toml_config_sparql_derived_proof.rs
sparql:
  a_sections: >
    PREFIX stp: <http://seanchatmangpt.github.io/packs/star-toml#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?sectionLabel ?sectionDoc ?closedWorld ?loaderFn WHERE {
      ?sec a stp:ConfigSection ; rdfs:label ?sectionLabel ; stp:doc ?sectionDoc ;
           stp:closedWorld ?closedWorld ; stp:loaderFn ?loaderFn .
    } ORDER BY ?sectionLabel
  fields: >
    PREFIX stp: <http://seanchatmangpt.github.io/packs/star-toml#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?sectionLabel ?fieldName ?rustType ?fieldDoc ?required WHERE {
      ?f a stp:ConfigField ;
         stp:inSection ?sec ;
         stp:fieldName ?fieldName ;
         stp:rustType ?rustType ;
         stp:doc ?fieldDoc ;
         stp:required ?required .
      ?sec rdfs:label ?sectionLabel .
    } ORDER BY ?sectionLabel ?fieldName
  bounds: >
    PREFIX stp: <http://seanchatmangpt.github.io/packs/star-toml#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?sectionLabel ?fieldName ?minValue ?maxValue WHERE {
      ?f a stp:ConfigField ;
         stp:inSection ?sec ;
         stp:fieldName ?fieldName ;
         stp:minValue ?minValue ;
         stp:maxValue ?maxValue .
      ?sec rdfs:label ?sectionLabel .
    } ORDER BY ?sectionLabel ?fieldName
---
//! Generated by star-toml-pack. Do not edit.
//!
//! SECOND proof, ALONGSIDE `star_toml_config_proof.rs.tmpl` (never a
//! replacement for it -- both are generated by every `ggen sync run`). That
//! sibling proof hand-transcribes its expected structural/behavioral
//! literals from `ontology.ttl` and deliberately carries no `sparql:`
//! frontmatter key, for a real, disclosed reason (its own header): looping
//! the SAME query that produced the artifact under test into that test's
//! own expectations would let a wrong field-mapping bug corrupt both
//! identically, and the test could never catch it. That reasoning is
//! correct for what THAT proof checks -- "does the generated module still
//! round-trip and validate the way ontology.ttl said it should, exercised
//! against real TempDir-backed TOML files" -- but it leaves a gap: a
//! hand-transcribed literal is authored once and never auto-updates, so it
//! cannot detect the case where `ontology.ttl` changes LATER and the
//! generated artifact falls behind it.
//!
//! This proof closes that gap by checking a DIFFERENT thing, not the same
//! thing more strictly: whether `src/star_toml_config.rs`, as it actually
//! sits on disk right now, still agrees with what `stp:ConfigSection` /
//! `stp:ConfigField` individuals say RIGHT NOW. It cannot and does not
//! claim to validate "is the ontology itself correct" -- nothing can, that
//! is definitional -- only "has the checked-in generated module silently
//! drifted from the ontology since it was last written."
//!
//! ## Why this is not the same tautology the sibling proof's header warns about
//!
//! 1. Asymmetric freshness, not identical-execution self-agreement.
//!    `star_toml_config_rs.tmpl` writes its output under `freeze_policy:
//!    checksum` (`freeze_slots_dir: .ggen/freeze/star_toml_config`): once a
//!    consumer hand-edits `src/star_toml_config.rs`, or an ontology-driven
//!    content change lands without `force: true`, a further sync can leave
//!    the checked-in file behind whatever `ontology.ttl` now says while
//!    `ggen sync run` still (eventually) exits 0. This template carries NO
//!    `freeze_policy` of its own: its `LIVE_*` arrays below are re-baked
//!    from a live query against whatever `ontology.ttl` says at the moment
//!    THIS file is (re)generated. So the two sides of every assertion below
//!    are not guaranteed to come from the same sync execution -- one
//!    (`RS_CONTENT`, via `include_str!`) is whatever was last actually
//!    written to disk, frozen or not; the other (`LIVE_*`) is always "right
//!    now." A hand-transcribed expectation frozen at authoring time cannot
//!    distinguish those two states from each other; this one can, and fails
//!    loudly when they diverge.
//! 2. Independent rendering, not the same substitution checked twice.
//!    This template's own for-loops over the `a_sections`/`fields`/`bounds`
//!    SPARQL results are a SEPARATE Tera render pass from
//!    `star_toml_config_rs.tmpl`'s own loops over the identical queries. A
//!    field-mapping bug local to ONE of the two templates (wrong variable,
//!    dropped row, stray whitespace) produces a generated-module string
//!    that this proof's independently-rendered `LIVE_*` values will not
//!    match, and the assertions below fail.
//!
//! ## Honest scope
//!
//! This still compares rendered TEXT via substring search, not a parsed
//! Rust AST -- the same limitation the sibling proof's structural test
//! avoids by literal-construction-must-compile instead. It does not repeat
//! the sibling proof's real `TempDir`-backed round-trip / fail-closed /
//! behavior-contract exercises (that is that proof's job; duplicating it
//! here would be scope creep, not a second check). It cannot prove ggen's
//! own SPARQL/Tera pipeline is bug-free in some absolute sense -- only
//! that, on the sync run that (re)generated this file, the live ontology
//! and the checked-in generated module said the same thing.

const RS_CONTENT: &str = include_str!("../src/star_toml_config.rs");

/// Every `stp:ConfigSection` individual as of the sync run that generated
/// THIS file -- (label, pascal_name, doc, closed_world, loader_fn) --
/// freshly baked from the `a_sections` SPARQL result, never hand-typed.
const LIVE_SECTIONS: &[(&str, &str, &str, bool, &str)] = &[
{% for s in a_sections %}    (
        "{{ s.sectionLabel }}",
        "{{ s.sectionLabel | pascal_case }}",
        "{{ s.sectionDoc }}",
        {{ s.closedWorld }},
        "{{ s.loaderFn }}",
    ),
{% endfor %}];

/// Every `stp:ConfigField` individual as of the sync run that generated
/// THIS file -- (section_label, field_name, rust_type, field_doc,
/// required) -- freshly baked from the `fields` SPARQL result.
const LIVE_FIELDS: &[(&str, &str, &str, &str, bool)] = &[
{% for f in fields %}    (
        "{{ f.sectionLabel }}",
        "{{ f.fieldName }}",
        "{{ f.rustType }}",
        "{{ f.fieldDoc }}",
        {{ f.required }},
    ),
{% endfor %}];

/// Every `stp:ConfigField` individual that carries `stp:minValue` /
/// `stp:maxValue` behavior-contract facts -- (section_label, field_name,
/// min_value, max_value), kept as the exact strings Tera rendered so this
/// proof's expected `validate()` text matches
/// `star_toml_config_rs.tmpl`'s own rendering of the identical numeric
/// literal byte for byte, rather than reformatting an f64 and risking a
/// representation mismatch (e.g. "0" vs "0.0").
const LIVE_BOUNDS: &[(&str, &str, &str, &str)] = &[
{% for b in bounds %}    (
        "{{ b.sectionLabel }}",
        "{{ b.fieldName }}",
        "{{ b.minValue }}",
        "{{ b.maxValue }}",
    ),
{% endfor %}];

fn assert_section_present(pascal_name: &str, doc: &str, closed_world: bool) {
    assert!(
        RS_CONTENT.contains(&format!("pub struct {pascal_name}Config")),
        "live ontology has ConfigSection `{pascal_name}` but generated \
         src/star_toml_config.rs does not declare `pub struct {pascal_name}Config` \
         -- generated module has drifted behind ontology.ttl"
    );
    assert!(
        RS_CONTENT.contains(&format!("/// {doc}")),
        "live ontology doc for section `{pascal_name}` not found verbatim in generated \
         src/star_toml_config.rs -- drift detected"
    );
    if closed_world {
        assert!(
            RS_CONTENT.contains(&format!(
                "#[serde(deny_unknown_fields)]\npub struct {pascal_name}Config"
            )),
            "live ontology says section `{pascal_name}` is stp:closedWorld=true but generated \
             src/star_toml_config.rs's struct is not immediately preceded by \
             #[serde(deny_unknown_fields)] -- drift detected"
        );
    }
}

fn assert_field_present(field_name: &str, rust_type: &str, doc: &str, required: bool) {
    assert!(
        RS_CONTENT.contains(&format!("/// {doc}")),
        "live ontology doc for field `{field_name}` not found verbatim in generated \
         src/star_toml_config.rs -- drift detected"
    );
    if required {
        assert!(
            RS_CONTENT.contains(&format!("pub {field_name}: {rust_type},")),
            "live ontology says field `{field_name}` is stp:required=true with rustType \
             `{rust_type}` but generated src/star_toml_config.rs does not declare \
             `pub {field_name}: {rust_type},` -- drift detected"
        );
    } else {
        assert!(
            RS_CONTENT.contains(&format!(
                "#[serde(default)]\n    pub {field_name}: Option<{rust_type}>,"
            )),
            "live ontology says field `{field_name}` is stp:required=false with rustType \
             `{rust_type}` but generated src/star_toml_config.rs does not declare \
             `#[serde(default)] pub {field_name}: Option<{rust_type}>,` -- drift detected"
        );
    }
}

fn assert_bound_present(section_label: &str, field_name: &str, min_value: &str, max_value: &str) {
    assert!(
        RS_CONTENT.contains(&format!(
            "(self.{field_name} as f64) < {min_value}f64 || (self.{field_name} as f64) > {max_value}f64"
        )),
        "live ontology says field `{field_name}` in [{section_label}] has stp:minValue \
         {min_value} / stp:maxValue {max_value} but generated src/star_toml_config.rs's \
         validate() guard condition does not contain that comparison -- drift detected"
    );
    assert!(
        RS_CONTENT.contains(&format!(
            "{section_label}.{field_name} must be within [{min_value}, {max_value}]"
        )),
        "live ontology says field `{field_name}` in [{section_label}] has stp:minValue \
         {min_value} / stp:maxValue {max_value} but generated src/star_toml_config.rs's \
         validate() error message does not contain that bound text -- drift detected"
    );
}

/// Floor sanity check: guards against a silently-broken or silently-empty
/// SPARQL query (e.g. a query engine regression, a typo in the query text
/// that still parses but matches nothing) making every loop-based assertion
/// below vacuously true. If this fails, the failure is in a query itself,
/// not in drift between the ontology and the generated module.
///
/// The `LIVE_BOUNDS` half of this check is honestly scoped to today's
/// ontology state: `ontology.ttl` currently has exactly one
/// `stp:minValue`/`stp:maxValue`-bearing field (`sample_rate`). If a future
/// edit removed every behavior-contract fact, this specific assertion would
/// need updating alongside it -- it is not a claim that bounds must always
/// exist, only that they do right now.
#[test]
fn sparql_queries_returned_at_least_one_row_each() {
    assert!(
        !LIVE_SECTIONS.is_empty(),
        "the `a_sections` SPARQL query against ontology.ttl returned zero \
         stp:ConfigSection rows -- either the ontology lost every individual or the \
         query itself is broken"
    );
    assert!(
        !LIVE_FIELDS.is_empty(),
        "the `fields` SPARQL query against ontology.ttl returned zero stp:ConfigField \
         rows -- either the ontology lost every individual or the query itself is broken"
    );
    assert!(
        !LIVE_BOUNDS.is_empty(),
        "the `bounds` SPARQL query against ontology.ttl returned zero rows, but \
         ontology.ttl currently declares stp:minValue/stp:maxValue on SampleRateField -- \
         either that fact was lost or the query itself is broken"
    );
}

/// Row-count parity between what the live ontology says right now and what
/// is actually checked into `src/star_toml_config.rs`. Counts every
/// 4-space-indented `pub` struct-field declaration line -- the generated
/// module emits exactly one per `stp:ConfigField` individual (on its own
/// section struct) plus one per `stp:ConfigSection` individual (on the
/// root `StarTomlConfig` struct's own per-section field). Excludes
/// `    pub fn ...` lines: `load`/`validate` method signatures are also
/// 4-space-indented (they live inside an `impl` block body), so a naive
/// "starts with 4 spaces then `pub `" count would over-count by exactly the
/// method count -- this discriminator was verified against the real
/// generated output before being trusted, not assumed from the template
/// source alone.
#[test]
fn field_declaration_count_matches_generated_module_right_now() {
    let field_count = RS_CONTENT
        .lines()
        .filter(|l| l.starts_with("    pub ") && !l.starts_with("    pub fn"))
        .count();
    let expected = LIVE_FIELDS.len() + LIVE_SECTIONS.len();
    assert_eq!(
        field_count, expected,
        "ontology.ttl has {} stp:ConfigField + {} stp:ConfigSection individuals right now \
         ({expected} total), but the checked-in src/star_toml_config.rs has {field_count} \
         4-space-indented `pub` field declarations (excluding method signatures) -- the \
         generated module has drifted behind ontology.ttl (a stale freeze checksum or a \
         partial resync are the two known causes; see this file's module doc)",
        LIVE_FIELDS.len(),
        LIVE_SECTIONS.len()
    );
}

/// The core check: every section and field the live ontology reports right
/// now is still reflected, verbatim, in the module as it actually sits on
/// disk. Failing here means the checked-in generated module no longer
/// matches ontology.ttl -- exactly the silent-drift failure mode cap05's
/// obligation text names, and neither the hand-transcribed proof (which
/// never re-reads ontology.ttl after authoring time) nor a plain `diff`
/// against a stale copy would catch it.
#[test]
fn every_live_section_and_field_matches_generated_module_right_now() {
    for (_label, pascal_name, doc, closed_world, _loader) in LIVE_SECTIONS {
        assert_section_present(pascal_name, doc, *closed_world);
    }
    for (_section, field_name, rust_type, doc, required) in LIVE_FIELDS {
        assert_field_present(field_name, rust_type, doc, *required);
    }
}

/// Behavior-contract check: every live `stp:minValue`/`stp:maxValue` pair
/// is still reflected, verbatim, in the generated `validate()` bodies --
/// closes the specific gap `TARGET_API_FIDELITY.md` and the sibling proof's
/// header both name as a *value* pre-condition serde's `Deserialize` cannot
/// express or check.
#[test]
fn every_live_bound_matches_generated_validate_right_now() {
    for (section_label, field_name, min_value, max_value) in LIVE_BOUNDS {
        assert_bound_present(section_label, field_name, min_value, max_value);
    }
}

/// The root `StarTomlConfig::load` delegates to whatever `stp:loaderFn`
/// names for the (lexically) first section -- mirrors
/// `star_toml_config_rs.tmpl`'s own choice of taking Tera's `first` filter
/// over the `a_sections` query result. A live regression guard: if the
/// ontology ever named a different loader function, this fails instead of
/// silently keeping the old one.
#[test]
fn live_loader_fn_matches_generated_load_right_now() {
    let (_label, _pascal, _doc, _closed, loader_fn) =
        LIVE_SECTIONS.first().expect("LIVE_SECTIONS is non-empty per the floor sanity check");
    assert!(
        RS_CONTENT.contains(&format!("{loader_fn}::<Self>(path)")),
        "live ontology's first (lexically) stp:loaderFn is `{loader_fn}` but generated \
         src/star_toml_config.rs's StarTomlConfig::load does not delegate to it -- drift \
         detected"
    );
}

/// `ORDER BY ?sectionLabel ?fieldName` in the live `fields` query is
/// expected to sort lexically ascending, per section. This is a live
/// regression guard on the query engine's own collation, not a
/// hand-asserted fact about how the array happens to be typed -- if the
/// engine's ORDER BY collation ever changes, this fails on the very next
/// sync instead of silently reordering the generated struct fields and
/// having nothing notice.
#[test]
fn live_field_order_is_lexical_ascending_within_each_section() {
    for (section_label, _pascal, ..) in LIVE_SECTIONS {
        let mut names: Vec<&str> = LIVE_FIELDS
            .iter()
            .filter(|(s, ..)| s == section_label)
            .map(|(_, name, ..)| *name)
            .collect();
        let original = names.clone();
        names.sort_unstable();
        assert_eq!(
            original, names,
            "LIVE_FIELDS for section `{section_label}` is not in lexically-ascending \
             fieldName order -- the query's own `ORDER BY ?fieldName` did not produce \
             sorted results this sync"
        );
    }
}

/// Negative sanity check: a fabricated field name that does not exist in
/// `ontology.ttl` must not spuriously appear in the generated module.
/// Guards against a naive `contains()`-based check in this proof silently
/// matching everything.
#[test]
fn generated_module_rejects_unknown_field_name() {
    let bogus = "not_a_real_star_toml_field";
    assert!(
        !RS_CONTENT.contains(bogus),
        "sanity: bogus field name must not appear in the generated module"
    );
}
