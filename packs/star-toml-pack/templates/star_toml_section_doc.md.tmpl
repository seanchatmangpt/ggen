---
to: "docs/star_toml/{{ sectionLabel | snake_case }}.md"
sparql:
  a_sections: >
    PREFIX stp: <http://seanchatmangpt.github.io/packs/star-toml#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?sectionLabel ?sectionDoc WHERE {
      ?sec a stp:ConfigSection ; rdfs:label ?sectionLabel ; stp:doc ?sectionDoc .
    } ORDER BY ?sectionLabel
  fields: >
    PREFIX stp: <http://seanchatmangpt.github.io/packs/star-toml#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?fSectionLabel ?fieldName ?rustType ?fieldDoc WHERE {
      ?f a stp:ConfigField ;
         stp:inSection ?sec ;
         stp:fieldName ?fieldName ;
         stp:rustType ?rustType ;
         stp:doc ?fieldDoc .
      ?sec rdfs:label ?fSectionLabel .
    } ORDER BY ?fSectionLabel ?fieldName
---
