---
to: src/wasm4pm_compat_events.rs
sparql:
  event_types: |
    PREFIX w4pm: <http://seanchatmangpt.github.io/packs/wasm4pm-compat#>
    SELECT ?event_name ?object_type ?requires_non_empty_id WHERE {
      ?et a w4pm:EventType ;
          w4pm:eventName ?event_name ;
          w4pm:hasObjectType ?object_type .
      OPTIONAL { ?et w4pm:requiresNonEmptyId ?requires_non_empty_id . }
    } ORDER BY ?event_name
  attribute_rows: |
    PREFIX w4pm: <http://seanchatmangpt.github.io/packs/wasm4pm-compat#>
    SELECT ?event_name ?attr_name ?requires_non_empty WHERE {
      ?et a w4pm:EventType ;
          w4pm:eventName ?event_name ;
          w4pm:hasAttribute ?attr .
      ?attr w4pm:attrName ?attr_name .
      OPTIONAL { ?attr w4pm:requiresNonEmpty ?requires_non_empty . }
    } ORDER BY ?event_name ?attr_name
  event_count: |
    PREFIX w4pm: <http://seanchatmangpt.github.io/packs/wasm4pm-compat#>
    SELECT (COUNT(DISTINCT ?et) AS ?n) WHERE {
      ?et a w4pm:EventType .
    } ORDER BY ?n
---
//! OCEL event-type emission surface for `wasm4pm-compat`.
//!
//! Generated by `wasm4pm-compat-pack` from EventType individuals in the
//! pack ontology. Emission only: ggen emits `OCELEvent` values; discovery,
//! conformance, fitness, and variants belong to `wasm4pm-compat`.
//!
//! Exactly {{ event_count[0].n }} EventType individuals exist in the
//! ontology as of this render (`event_count` SPARQL, independent of the
//! `event_types` query that drives the enum/emit-fn bodies below).

use chrono::{DateTime, FixedOffset};
use wasm4pm_compat::ocel::{OCELAttributeValue, OCELEvent, OCELEventAttribute, OCELRelationship};

/// Total count of `w4pm:EventType` individuals, per the independent
/// `event_count` SPARQL query above -- used by the generated proof suite
/// as a self-updating cardinality oracle instead of a hand-transcribed
/// literal.
pub const EVENT_TYPE_COUNT: usize = {{ event_count[0].n }};

/// Every OCEL event type this generator emits.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum EmittedEventType {
{% for row in event_types %}    /// `{{ row.event_name }}` — binds a `{{ row.object_type | split(pat="#") | last }}` object.
    {{ row.event_name | pascal_case }},
{% endfor %}}

impl EmittedEventType {
    /// OCEL 2.0 event-type name, as it appears in the log's `eventTypes`.
    pub fn name(self) -> &'static str {
        match self {
{% for row in event_types %}            Self::{{ row.event_name | pascal_case }} => "{{ row.event_name }}",
{% endfor %}        }
    }
}
{% set attrs_by_event = attribute_rows | group_by(attribute="event_name") %}
{% for row in event_types %}
/// Emit a `{{ row.event_name }}` event related to one `{{ row.object_type | split(pat="#") | last }}` object.
///
/// Caller supplies `time` (no wall-clock reads inside the emission surface)
/// and one `String` value per ontology-declared attribute below, in the
/// same order `w4pm:hasAttribute`/`w4pm:attrName` list them.
pub fn emit_{{ row.event_name }}(
    id: String,
    time: DateTime<FixedOffset>,
    {{ row.object_type | split(pat="#") | last | snake_case }}_id: String,
{% if attrs_by_event[row.event_name] %}{% for a in attrs_by_event[row.event_name] %}    {{ a.attr_name }}: String,
{% endfor %}{% endif %}) -> OCELEvent {
{% if row.requires_non_empty_id %}    debug_assert!(!id.is_empty(), "w4pm:requiresNonEmptyId: `{{ row.event_name }}` event id must not be empty");
{% endif %}{% if attrs_by_event[row.event_name] %}{% for a in attrs_by_event[row.event_name] %}{% if a.requires_non_empty %}    debug_assert!(!{{ a.attr_name }}.is_empty(), "w4pm:requiresNonEmpty: `{{ row.event_name }}`'s `{{ a.attr_name }}` attribute must not be empty");
{% endif %}{% endfor %}{% endif %}    OCELEvent {
        id,
        event_type: "{{ row.event_name }}".to_string(),
        time,
        attributes: vec![
{% if attrs_by_event[row.event_name] %}{% for a in attrs_by_event[row.event_name] %}            OCELEventAttribute {
                name: "{{ a.attr_name }}".to_string(),
                value: OCELAttributeValue::String({{ a.attr_name }}),
            },
{% endfor %}{% endif %}        ],
        relationships: vec![OCELRelationship {
            object_id: {{ row.object_type | split(pat="#") | last | snake_case }}_id,
            qualifier: "{{ row.object_type | split(pat="#") | last }}".to_string(),
        }],
    }
}
{% endfor %}