# shapes.ttl -- SHACL shapes constraining mfw:CycleStage, mfw:AuthoritySurface,
# and mfw:Crate individuals in ontology.ttl.
#
# Added this pass to close the "no shapes.ttl at all" gap noted when this
# pack was audited against the maturity model's calibration rule (see
# docs/packs/PACK_MATURITY_MODEL.md's mfw-pack row). Turns conventions the
# templates already assume -- every stage has exactly one order and exactly
# one outgoing mfw:nextStage edge; every surface has a path, a doc, and a
# standingAuthority boolean; mfw:DocsSurface specifically must be false per
# ~/mfw/AGENTS.md's own law ("docs/ ... never standing authority") -- into
# checked, machine-verifiable facts rather than only template assumptions.
#
# Run with:
#   ggen graph validate --files packs/mfw-pack/ontology.ttl \
#                        --shapes packs/mfw-pack/shapes.ttl

@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix mfw:  <http://seanchatmangpt.github.io/packs/mfw#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

mfw:CycleStageShape
    a sh:NodeShape ;
    sh:targetClass mfw:CycleStage ;

    sh:property [
        sh:path     mfw:order ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:message  "A mfw:CycleStage must carry exactly one integer mfw:order >= 1." ;
    ] ;
    sh:property [
        sh:path     rdfs:label ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A mfw:CycleStage must carry exactly one non-empty rdfs:label." ;
    ] ;
    sh:property [
        # Every stage transitions to exactly one next stage -- the cycle is a
        # single closed loop, not a DAG with branches or dead ends. This is
        # the structural half of the "walking next_stage 10 times returns to
        # observe" behavioral proof already in mfw_catalog.rs.tmpl's
        # self_check module -- SHACL catches an ontology edit that breaks
        # this invariant before it ever reaches generated code.
        sh:path     mfw:nextStage ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:class    mfw:CycleStage ;
        sh:message  "A mfw:CycleStage must have exactly one outgoing mfw:nextStage edge, targeting another mfw:CycleStage individual (the cycle must be a single closed loop)." ;
    ] .

mfw:AuthoritySurfaceShape
    a sh:NodeShape ;
    sh:targetClass mfw:AuthoritySurface ;

    sh:property [
        sh:path     mfw:path ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A mfw:AuthoritySurface must carry exactly one non-empty mfw:path." ;
    ] ;
    sh:property [
        sh:path     rdfs:comment ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A mfw:AuthoritySurface must carry exactly one non-empty rdfs:comment describing its authority." ;
    ] ;
    sh:property [
        sh:path     mfw:standingAuthority ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message  "A mfw:AuthoritySurface must carry exactly one mfw:standingAuthority boolean (no surface may be silently undeclared -- fail-closed, not fail-open, per is_standing_authority's own contract in mfw_catalog.rs.tmpl)." ;
    ] .

# ~/mfw/AGENTS.md's law is explicit and singular: "docs/ ... never standing
# authority" -- every other listed surface DOES carry standing authority.
# This closed shape makes that specific rule machine-checkable instead of
# only a comment on mfw:DocsSurface in ontology.ttl: any future edit that
# flips mfw:DocsSurface's mfw:standingAuthority to true, or introduces a
# second surface with mfw:path "docs/", fails validation.
mfw:DocsSurfaceMustNotBeStandingShape
    a sh:NodeShape ;
    sh:targetNode mfw:DocsSurface ;
    sh:property [
        sh:path     mfw:standingAuthority ;
        sh:hasValue false ;
        sh:message  "mfw:DocsSurface must have mfw:standingAuthority false -- ~/mfw/AGENTS.md's law states docs/ is explanations and projections, never standing authority." ;
    ] .

mfw:CrateShape
    a sh:NodeShape ;
    sh:targetClass mfw:Crate ;
    sh:property [
        sh:path     rdfs:label ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:message  "A mfw:Crate must carry exactly one non-empty rdfs:label." ;
    ] .

# Note on what this shape file deliberately does NOT check: SHACL's
# sh:class/sh:hasValue constraints above cannot express "the ten
# mfw:nextStage edges form exactly one cycle of length 10 with no
# sub-cycles" (that needs graph-reachability reasoning SHACL Core does not
# have without a sh:sparql component). That specific invariant remains
# covered at the generated-code layer by
# `walking_next_stage_ten_times_from_observe_returns_to_observe` in
# mfw_catalog.rs.tmpl's self_check module, not duplicated here.
#
# Also deliberately not checked here: whether mfw:AuthoritySurface's
# mfw:path values correspond to directories that actually exist in ~/mfw
# today. ~/mfw/AGENTS.md's own "Repository Authorities" table is explicit
# that these are a governing *authority model*, not a directory-existence
# claim -- "Resolve the actual tree before assuming a listed path exists.
# Do not manufacture empty directories ... merely to match this table."
# (AGENTS.md line 44-45). A live check against ~/mfw's on-disk tree found
# 6 of the 9 listed paths (ontology/, profiles/, transform/, runtime/,
# verifier/, fixtures/) do not exist at the repository root as of this
# pass -- consistent with AGENTS.md's own disclaimer, not a pack defect,
# but a real fidelity caveat this pack's ontology.ttl comments did not
# previously carry. See ontology.ttl's mfw:AuthoritySurface comments for
# the added caveat.
