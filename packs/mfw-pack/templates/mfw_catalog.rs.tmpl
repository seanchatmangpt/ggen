---
to: src/mfw_catalog.rs
force: true
sparql:
  stages: |
    PREFIX mfw: <http://seanchatmangpt.github.io/packs/mfw#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?order ?label ?doc WHERE {
      ?s a mfw:CycleStage ; mfw:order ?order ; rdfs:label ?label .
      OPTIONAL { ?s rdfs:comment ?comment_raw . }
      BIND(COALESCE(?comment_raw, "") AS ?doc)
    } ORDER BY ?order
  surfaces: |
    PREFIX mfw: <http://seanchatmangpt.github.io/packs/mfw#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?path ?doc WHERE {
      ?a a mfw:AuthoritySurface ; mfw:path ?path ; rdfs:comment ?doc .
    } ORDER BY ?path
  crates: |
    PREFIX mfw: <http://seanchatmangpt.github.io/packs/mfw#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?label ?doc WHERE {
      ?c a mfw:Crate ; rdfs:label ?label .
      OPTIONAL { ?c rdfs:comment ?comment_raw . }
      BIND(COALESCE(?comment_raw, "") AS ?doc)
    } ORDER BY ?label
  transitions: |
    PREFIX mfw: <http://seanchatmangpt.github.io/packs/mfw#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?from_label ?to_label WHERE {
      ?f a mfw:CycleStage ; mfw:order ?from_order ; rdfs:label ?from_label ;
         mfw:nextStage ?t .
      ?t rdfs:label ?to_label .
    } ORDER BY ?from_order
  stage_count: |
    PREFIX mfw: <http://seanchatmangpt.github.io/packs/mfw#>
    SELECT (COUNT(?s) AS ?n) WHERE { ?s a mfw:CycleStage }
  surface_count: |
    PREFIX mfw: <http://seanchatmangpt.github.io/packs/mfw#>
    SELECT (COUNT(?a) AS ?n) WHERE { ?a a mfw:AuthoritySurface }
  crate_count: |
    PREFIX mfw: <http://seanchatmangpt.github.io/packs/mfw#>
    SELECT (COUNT(?c) AS ?n) WHERE { ?c a mfw:Crate }
  transition_count: |
    PREFIX mfw: <http://seanchatmangpt.github.io/packs/mfw#>
    SELECT (COUNT(?f) AS ?n) WHERE { ?f mfw:nextStage ?t }
---
//! Typed catalog of ~/mfw's 10-stage consequence cycle, its 9
//! authority-surface directories, and its 5 workspace crates, transcribed
//! from `packs/mfw-pack/ontology.ttl`.
//!
//! Generated by `mfw-pack`. Reference only -- this crate is not mfw itself.

/// One step of the observe->admit->...->replay->observe cycle.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct CycleStage {
    pub order: u32,
    pub label: &'static str,
    pub doc: &'static str,
}

/// Cycle stages, ordered.
pub const MFW_CYCLE: &[CycleStage] = &[
{% for row in stages %}    CycleStage { order: {{ row.order }}, label: "{{ row.label }}", doc: "{{ row.doc }}" },
{% endfor %}];

/// One top-level repository authority surface.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct AuthoritySurface {
    pub path: &'static str,
    pub doc: &'static str,
}

/// Authority surfaces, alphabetized by path.
pub const MFW_AUTHORITY_SURFACES: &[AuthoritySurface] = &[
{% for row in surfaces %}    AuthoritySurface { path: "{{ row.path }}", doc: "{{ row.doc }}" },
{% endfor %}];

/// One mfw workspace crate.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct MfwCrate {
    pub name: &'static str,
    pub doc: &'static str,
}

/// Workspace crates, alphabetized.
pub const MFW_CRATES: &[MfwCrate] = &[
{% for row in crates %}    MfwCrate { name: "{{ row.label }}", doc: "{{ row.doc }}" },
{% endfor %}];

/// `(from_label, to_label)` edges of the consequence cycle, walked directly
/// from `mfw:nextStage` triples in `ontology.ttl` (graph structure), not
/// reconstructed by `order + 1` arithmetic with a special-cased wrap for the
/// last stage.
pub const NEXT_STAGE: &[(&str, &str)] = &[
{% for row in transitions %}    ("{{ row.from_label }}", "{{ row.to_label }}"),
{% endfor %}];

/// Real behavior driven by ontology data: look up the stage that follows
/// `label` in the consequence cycle via the `mfw:nextStage` edges above.
/// Returns `None` for a label that is not a known cycle stage -- this is a
/// genuine dispatch/lookup function, not a data table alone.
pub fn next_stage(label: &str) -> Option<&'static str> {
    NEXT_STAGE
        .iter()
        .find(|(from, _)| *from == label)
        .map(|(_, to)| *to)
}

/// Real behavior driven by ontology data: is `to` the stage that
/// `mfw:nextStage` says immediately follows `from`? Delegates to
/// [`next_stage`], so the validity rule and the lookup table are the same
/// ontology-derived source, not two independently hand-maintained facts.
pub fn is_valid_transition(from: &str, to: &str) -> bool {
    next_stage(from) == Some(to)
}

/// Row counts independently re-derived via `COUNT(...)` SPARQL aggregate
/// queries (a differently-shaped query than the `stages`/`surfaces`/
/// `crates`/`transitions` enumeration queries above), so a self-check
/// against `MFW_CYCLE.len()` etc. below does not require a human to
/// hand-transcribe the same number twice from the same source.
pub const EXPECTED_CYCLE_LEN: usize = {{ stage_count[0].n }};
pub const EXPECTED_SURFACE_LEN: usize = {{ surface_count[0].n }};
pub const EXPECTED_CRATE_LEN: usize = {{ crate_count[0].n }};
pub const EXPECTED_TRANSITION_LEN: usize = {{ transition_count[0].n }};

#[cfg(test)]
mod self_check {
    //! Generated alongside the catalog itself (not in a separate,
    //! hand-maintained proof file): each `EXPECTED_*_LEN` const above comes
    //! from an independently-shaped `COUNT(...)` SPARQL aggregate query, so
    //! this module catches a catalog/ontology drift (e.g. a stage added to
    //! `ontology.ttl` without updating an expectation) the moment `cargo
    //! test` runs on this crate -- no separate proof-file re-sync step, and
    //! no hand transcription for these four counts specifically.
    use super::*;

    #[test]
    fn cycle_len_matches_independent_sparql_count() {
        assert_eq!(MFW_CYCLE.len(), EXPECTED_CYCLE_LEN);
    }

    #[test]
    fn surface_len_matches_independent_sparql_count() {
        assert_eq!(MFW_AUTHORITY_SURFACES.len(), EXPECTED_SURFACE_LEN);
    }

    #[test]
    fn crate_len_matches_independent_sparql_count() {
        assert_eq!(MFW_CRATES.len(), EXPECTED_CRATE_LEN);
    }

    #[test]
    fn transition_len_matches_independent_sparql_count() {
        assert_eq!(NEXT_STAGE.len(), EXPECTED_TRANSITION_LEN);
    }

    /// Every cycle stage must have exactly one outgoing `mfw:nextStage`
    /// edge, and walking all ten must revisit "observe" exactly once,
    /// landing back where it started -- a real behavioral proof of
    /// `next_stage`, not a structural count.
    #[test]
    fn walking_next_stage_ten_times_from_observe_returns_to_observe() {
        let mut label = "observe";
        for _ in 0..MFW_CYCLE.len() {
            label = next_stage(label).expect("every real cycle stage has a next_stage");
        }
        assert_eq!(label, "observe");
    }

    #[test]
    fn is_valid_transition_rejects_a_skip_ahead() {
        // observe -> preserve standing skips "admit" -- must be rejected.
        assert!(!is_valid_transition("observe", "preserve standing"));
        assert!(is_valid_transition("observe", "admit"));
    }

    #[test]
    fn is_valid_transition_rejects_an_unknown_stage() {
        assert!(!is_valid_transition("observe", "not-a-real-stage"));
        assert_eq!(next_stage("not-a-real-stage"), None);
    }
}
