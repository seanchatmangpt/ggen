//! Anti-drift proof for `src/mfw_catalog.rs`, GENERATED by `mfw-pack` from
//! `packs/mfw-pack/ontology.ttl`.
//!
//! Deliberately carries NO `sparql:` frontmatter key (it defaults to an
//! empty map in `ggen-engine`'s `Frontmatter` struct when omitted), so this
//! file cannot reuse `mfw_catalog.rs.tmpl`/`mfw_reference.md.tmpl`'s SPARQL
//! derivation path -- every expected value below was hand-transcribed from
//! `packs/mfw-pack/ontology.ttl` by reading the ontology directly, not
//! computed by evaluating any query. If a future ontology edit changes an
//! `mfw:order`/`rdfs:label`/`rdfs:comment`/`mfw:path` and the catalog
//! template still renders correctly, this proof only keeps passing if a
//! human updates the literal here too. That friction is the point, not a
//! bug.

#[path = "../src/mfw_catalog.rs"]
mod mfw_catalog;

use mfw_catalog::{
    AuthoritySurface, MfwCrate, MFW_AUTHORITY_SURFACES, MFW_CRATES, MFW_CYCLE,
};

fn find_surface(path: &str) -> &'static AuthoritySurface {
    MFW_AUTHORITY_SURFACES
        .iter()
        .find(|s| s.path == path)
        .unwrap_or_else(|| panic!("no mfw authority surface found with path {path:?}"))
}

fn find_crate(name: &str) -> &'static MfwCrate {
    MFW_CRATES
        .iter()
        .find(|c| c.name == name)
        .unwrap_or_else(|| panic!("no mfw crate found named {name:?}"))
}

/// `ontology.ttl` declares exactly 10 `mfw:CycleStage`, 9
/// `mfw:AuthoritySurface`, and 5 `mfw:Crate` individuals -- hand count, not
/// a query result.
#[test]
fn catalogs_have_the_right_row_counts() {
    assert_eq!(MFW_CYCLE.len(), 10);
    assert_eq!(MFW_AUTHORITY_SURFACES.len(), 9);
    assert_eq!(MFW_CRATES.len(), 5);
}

/// `mfw:Observe` has `mfw:order 1` and no `rdfs:comment`, so `doc` must
/// resolve to the empty string via the query's `COALESCE(?comment_raw, "")`
/// -- this is the branch where the COALESCE default fires.
#[test]
fn cycle_stage_one_is_observe_with_empty_doc() {
    let s = MFW_CYCLE[0];
    assert_eq!(s.order, 1);
    assert_eq!(s.label, "observe");
    assert_eq!(s.doc, "");
}

/// `mfw:Replay` has `mfw:order 10` and is the ONLY `mfw:CycleStage`
/// individual carrying a real `rdfs:comment` -- this is the branch where
/// COALESCE keeps the real value instead of falling back to "".
#[test]
fn cycle_stage_ten_is_replay_with_its_doc_comment() {
    let s = MFW_CYCLE[9];
    assert_eq!(s.order, 10);
    assert_eq!(s.label, "replay");
    assert_eq!(s.doc, "Loops back to observe.");
}

/// General structural invariant: the cycle must already be sorted
/// ascending by `order` (`ORDER BY ?order` in the generator query). Not
/// tautological: `expected` is a fresh sort of a *copy* of the data via
/// `Ord` on `u32`, not a second pass through the SPARQL query that produced
/// `MFW_CYCLE` in the first place.
#[test]
fn cycle_stages_are_sorted_ascending_by_order() {
    let mut sorted: Vec<_> = MFW_CYCLE.to_vec();
    sorted.sort_by_key(|s| s.order);
    assert_eq!(MFW_CYCLE.to_vec(), sorted);
}

/// The alphabetized `path` column, hand-transcribed from every
/// `mfw:AuthoritySurface` individual in `ontology.ttl` and sorted the way a
/// human reading the ontology would sort ASCII strings -- catches a
/// row-order regression more cheaply than 9 individual spot checks would.
#[test]
fn authority_surface_paths_match_the_ontologys_alphabetized_column() {
    let expected = vec![
        "docs/",
        "fixtures/",
        "mfw-theory/",
        "ontology/",
        "profiles/",
        "receipts/",
        "runtime/",
        "transform/",
        "verifier/",
    ];
    let actual: Vec<&str> = MFW_AUTHORITY_SURFACES.iter().map(|s| s.path).collect();
    assert_eq!(actual, expected);
}

/// `mfw:DocsSurface` sorts first under `ORDER BY ?path` ("docs/" precedes
/// every other path in the ontology).
#[test]
fn first_authority_surface_is_docs() {
    let s = MFW_AUTHORITY_SURFACES[0];
    assert_eq!(s.path, "docs/");
    assert_eq!(s.doc, "Explanations and projections; never standing authority.");
}

/// `mfw:VerifierSurface` sorts last under `ORDER BY ?path` ("verifier/" is
/// alphabetically after every other path in the ontology).
#[test]
fn last_authority_surface_is_verifier() {
    let s = MFW_AUTHORITY_SURFACES[8];
    assert_eq!(s.path, "verifier/");
    assert_eq!(
        s.doc,
        "Axiom, correspondence, manifest, receipt, and replay validation."
    );
}

/// `mfw:TheorySurface` (`path = "mfw-theory/"`) is a mid-sort boundary
/// case: it must land between "fixtures/" and "ontology/", not near the
/// unrelated "mfw-runtime"/"mfw-shacl" crate names it happens to share a
/// prefix character with.
#[test]
fn middle_boundary_authority_surface_is_mfw_theory() {
    let s = find_surface("mfw-theory/");
    assert_eq!(s.doc, "Constructive Lean definitions and kernel-checked proofs.");
    assert_eq!(MFW_AUTHORITY_SURFACES[2].path, "mfw-theory/");
    assert_eq!(MFW_AUTHORITY_SURFACES[1].path, "fixtures/");
    assert_eq!(MFW_AUTHORITY_SURFACES[3].path, "ontology/");
}

/// The alphabetized `label`/`name` column, hand-transcribed from every
/// `mfw:Crate` individual in `ontology.ttl`.
#[test]
fn crate_names_match_the_ontologys_alphabetized_column() {
    let expected = vec![
        "mfw-meaning",
        "mfw-planner",
        "mfw-powl-miner",
        "mfw-runtime",
        "mfw-shacl",
    ];
    let actual: Vec<&str> = MFW_CRATES.iter().map(|c| c.name).collect();
    assert_eq!(actual, expected);
}

/// `mfw:MfwPlanner` carries the longest doc string in the whole ontology,
/// including parentheses and commas -- an escaping/quoting check for the
/// Tera template's row.doc interpolation in the generating catalog template.
#[test]
fn crate_mfw_planner_has_the_longest_most_punctuated_doc() {
    let c = find_crate("mfw-planner");
    assert_eq!(
        c.doc,
        "Shell-free, receipted external planner runner for MFW (only crate with a populated Cargo.toml description this pass)."
    );
}

/// `mfw:MfwShacl`'s doc contains an embedded slash ("mfw-runtime/") --
/// confirms the literal survives untouched through Tera rendering.
#[test]
fn crate_mfw_shacl_doc_contains_an_embedded_slash() {
    let c = find_crate("mfw-shacl");
    assert_eq!(c.doc, "Nested under mfw-runtime/.");
}

/// `mfw:MfwRuntime` has no `rdfs:comment` and sorts alphabetically 4th of
/// 5, between "mfw-powl-miner" and "mfw-shacl" -- another COALESCE-default
/// branch, at a different position than the cycle-stage check above.
#[test]
fn crate_mfw_runtime_has_no_doc_comment() {
    let c = find_crate("mfw-runtime");
    assert_eq!(c.doc, "");
    assert_eq!(MFW_CRATES[3].name, "mfw-runtime");
    assert_eq!(MFW_CRATES[2].name, "mfw-powl-miner");
    assert_eq!(MFW_CRATES[4].name, "mfw-shacl");
}

/// Structural invariant: no two `MFW_CRATES` rows may share the same
/// `name` -- catches an accidentally duplicated crate individual in the
/// ontology that the spot checks above would not, by construction, notice.
#[test]
fn crate_names_have_no_duplicates() {
    let mut seen: Vec<&str> = Vec::new();
    for c in MFW_CRATES {
        assert!(
            !seen.contains(&c.name),
            "duplicate crate name found in MFW_CRATES: {:?}",
            c.name
        );
        seen.push(c.name);
    }
}
