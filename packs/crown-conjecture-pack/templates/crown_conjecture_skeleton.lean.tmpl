---
to: lean/CrownConjectureSkeleton.lean
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/crown-conjecture-pack
sparql:
  obligation: >
    PREFIX cc: <http://seanchatmangpt.github.io/packs/crown-conjecture#>
    SELECT ?name ?statement ?srcFile ?srcLines ?standing WHERE {
      ?o a cc:ProofObligation ; cc:obligationName ?name ; cc:leanStatement ?statement ;
         cc:sourceFile ?srcFile ; cc:sourceLineRange ?srcLines ; cc:standing ?standingIri .
      BIND(STRAFTER(STR(?standingIri), "crown-conjecture#") AS ?standing)
    }
  definitions: >
    PREFIX cc: <http://seanchatmangpt.github.io/packs/crown-conjecture#>
    SELECT ?defName ?sig ?srcFile ?srcLines ?standing WHERE {
      ?o a cc:ProofObligation ; cc:dependsOnDefinition ?d .
      ?d cc:leanSignature ?sig ; cc:sourceFile ?srcFile ; cc:sourceLineRange ?srcLines ; cc:standing ?standingIri .
      BIND(STRAFTER(STR(?d), "crown-conjecture#def_") AS ?defName)
      BIND(STRAFTER(STR(?standingIri), "crown-conjecture#") AS ?standing)
    }
  steps: >
    PREFIX cc: <http://seanchatmangpt.github.io/packs/crown-conjecture#>
    SELECT ?order ?name ?desc ?sorryLabel ?tactic WHERE {
      ?o a cc:ProofObligation ; cc:hasProofStep ?s .
      ?s cc:stepOrder ?order ; cc:stepName ?name ; cc:stepDescription ?desc ; cc:sorryLabel ?sorryLabel .
      OPTIONAL { ?s cc:leanTacticSketch ?tactic . }
    } ORDER BY ?order
  findings: >
    PREFIX cc: <http://seanchatmangpt.github.io/packs/crown-conjecture#>
    SELECT ?desc ?srcFile ?srcLines ?severity WHERE {
      ?o a cc:ProofObligation ; cc:blockedBy ?f .
      ?f cc:findingDescription ?desc ; cc:sourceFile ?srcFile ; cc:sourceLineRange ?srcLines ; cc:severity ?severity .
    }
---
