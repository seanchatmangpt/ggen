@prefix ret:  <https://seanchatmangpt.github.io/ontology/retrofit#> .
@prefix tcps: <https://seanchatmangpt.github.io/ontology/tcps#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

ret:TemporaryWork a rdfs:Class .
ret:ShadowPath a rdfs:Class .
ret:CompatibilityBridge a rdfs:Class .
ret:FreezeControl a rdfs:Class .
ret:RollbackPlan a rdfs:Class .
ret:Cutover a rdfs:Class .
ret:LoadTransferEvidence a rdfs:Class .
ret:RemovalReceipt a rdfs:Class .

ret:temporaryWorkId a rdf:Property .
ret:owner a rdf:Property .
ret:purpose a rdf:Property .
ret:carriedLoad a rdf:Property .
ret:inspectionMethod a rdf:Property .
ret:expiresAt a rdf:Property .
ret:removalTrigger a rdf:Property .
ret:rollbackPlan a rdf:Property .
ret:oldPath a rdf:Property .
ret:newPath a rdf:Property .
ret:cutoverCriterion a rdf:Property .
ret:transferEvidence a rdf:Property .
ret:removalReceipt a rdf:Property .
ret:status a rdf:Property .
ret:blocking a rdf:Property .

ret:ShadowCI a ret:TemporaryWork, ret:ShadowPath ;
  ret:temporaryWorkId "shadow-ci" ;
  ret:owner "TCPS retrofit owner" ;
  ret:purpose "新CIを非遮断で旧CIと比較する"@ja ;
  ret:carriedLoad "inspection comparison" ;
  ret:inspectionMethod "compare check outcome, artifact manifest, and refusal reason" ;
  ret:expiresAt "2026-12-31T23:59:59Z"^^xsd:dateTime ;
  ret:removalTrigger "新CIが三回の実変更を同等以上に判定し、受領証が発行された時"@ja ;
  ret:status "planned" .

ret:ReleaseRollback a ret:RollbackPlan ;
  dct:title "旧公開路を再有効化し、候補タグを隔離する"@ja ;
  ret:blocking true .

ret:ReleaseCutover a ret:Cutover ;
  ret:oldPath "legacy-release" ;
  ret:newPath "generated-release" ;
  ret:rollbackPlan ret:ReleaseRollback ;
  ret:cutoverCriterion "影運転、実製品一件、drift-free再観測が受領済み"@ja .

ret:TransferEvidence_001 a ret:LoadTransferEvidence ;
  dct:title "第一実製品がgenerated-releaseを通過"@ja ;
  ret:status "pending" .
