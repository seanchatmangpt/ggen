---
to: src/自動選択.rs
sparql:
  rows: |
    PREFIX tcps: <http://seanchatmangpt.github.io/packs/tcps-core#>
    SELECT (COALESCE(?override, ?base) AS ?source) WHERE {
      tcps:自動選択Module tcps:sourceText ?base .
      OPTIONAL { tcps:自動選択Module tcps:sourceTextOverride ?override . }
    } ORDER BY ?source
---
{{ rows[0].source | trim_end }}
