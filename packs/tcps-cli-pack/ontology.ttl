@prefix tcps: <http://seanchatmangpt.github.io/packs/tcps-cli#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

tcps:CargoTomlModule a tcps:Module ;
    tcps:name "Cargo.toml" ;
    tcps:order 0 ;
    tcps:sourceText """[package]
name = "tcps-cli"
version.workspace = true
edition.workspace = true
rust-version.workspace = true
license.workspace = true
authors.workspace = true
description = "豊田コード生産方式の現地検査用CLI"

[[bin]]
name = "tcps"
path = "src/main.rs"

[[bin]]
name = "tcps-bench"
path = "src/基準.rs"

[dependencies]
tcps-core = { path = "../..", package = "tcps-generated" }
tcps-std = { path = "../tcps-std", version = "26.7.19" }

[lints]
workspace = true
""" .

tcps:CargoTomlModule rdfs:comment "Cargo manifest for the tcps-cli crate: declares the two binaries (tcps, tcps-bench) and their dependencies on tcps-core/tcps-std." .

tcps:MainModule a tcps:Module ;
    tcps:name "main" ;
    tcps:order 1 ;
    tcps:dependsOnModule tcps:CargoTomlModule ;
    tcps:sourceText """#![forbid(unsafe_code)]

use std::process::ExitCode;

use tcps_core::全体::豊田生産方式;
use tcps_std::実行環境;

fn 使い方() {
    println!("豊田コード生産方式 {}", tcps_core::版);
    println!("使い方: tcps <検査|環境|版>");
}

fn main() -> ExitCode {
    let 命令 = std::env::args().nth(1).unwrap_or_else(|| "検査".to_owned());
    match 命令.as_str() {
        "検査" => {
            let 方式 = 豊田生産方式::原初形();
            if 方式.二本柱が閉じている() {
                println!("成立: 自働化と必要時生産の二本柱は閉じています");
                ExitCode::SUCCESS
            } else {
                eprintln!("拒否: 二本柱が閉じていません");
                ExitCode::FAILURE
            }
        }
        "環境" => {
            let 環境 = 実行環境::現在();
            println!("操作体系={} 機械種別={} 版={}", 環境.操作体系, 環境.機械種別, 環境.版);
            ExitCode::SUCCESS
        }
        "版" => {
            println!("{} {}", tcps_core::版, tcps_core::配布種別);
            ExitCode::SUCCESS
        }
        _ => {
            使い方();
            ExitCode::from(2)
        }
    }
}
""" .

tcps:MainModule rdfs:comment "tcps main CLI binary entry point (src/main.rs): dispatches 検査 (inspect)/環境 (environment)/版 (version) subcommands over tcps_core::全体::豊田生産方式." .

tcps:KijunModule a tcps:Module ;
    tcps:name "基準" ;
    tcps:order 2 ;
    tcps:dependsOnModule tcps:CargoTomlModule ;
    tcps:sourceText """#![forbid(unsafe_code)]

use std::hint::black_box;
use std::time::Instant;

use tcps_core::正準::{正準方策, 正準要求};
use tcps_core::自動選択::{作業領域, 選択する, 選択結果};

fn main() {
    let 回数 = std::env::args()
        .nth(1)
        .and_then(|値| 値.parse::<u64>().ok())
        .unwrap_or(1_000_000);
    let 方策 = 正準方策();
    let mut 作業領域 = 作業領域::<3>::新規();

    for 時刻 in 0..10_000 {
        black_box(選択する(&方策, 正準要求(時刻), &mut 作業領域));
    }

    let 開始 = Instant::now();
    let mut 選択数 = 0u64;
    for 時刻 in 0..回数 {
        let 結果 = black_box(選択する(&方策, 正準要求(時刻), &mut 作業領域));
        if matches!(結果, 選択結果::選択(_)) {
            選択数 += 1;
        }
    }
    let 経過 = 開始.elapsed();
    let 一回ナノ秒 = 経過.as_nanos() as f64 / 回数 as f64;
    println!(
        "{{\\"版\\":\\"{}\\",\\"回数\\":{},\\"選択数\\":{},\\"総ナノ秒\\":{},\\"一回ナノ秒\\":{:.3}}}",
        tcps_core::版,
        回数,
        選択数,
        経過.as_nanos(),
        一回ナノ秒,
    );
}
""" .

tcps:KijunModule rdfs:comment "tcps-bench binary entry point (src/基準.rs): micro-benchmark harness for tcps_core::自動選択::選択する, printing JSON timing stats." .

# ---------------------------------------------------------------------------
# CLI dispatch sabotage cases (l5p:cap06 -- Generated negative witnesses)
#
# Source for `templates/dispatch_sabotage_proof.rs.tmpl`, which projects
# these via a real `sparql:` frontmatter query (no hardcoded EXPECTED array)
# into a generated integration test that spawns the REAL compiled `tcps`
# binary (env!("CARGO_BIN_EXE_tcps"), no mock process, no re-implemented
# dispatch logic) with each declared argv and asserts on its REAL exit
# code -- a genuine subprocess boundary crossing, same shape as
# chicago-tdd-tools-pack's cap06 closure (real clap-noun-verb binary
# invocations, not re-implemented dispatch). `main.rs`'s dispatch
# (tcps:MainModule sourceText above) has exactly one real refusal path --
# an unrecognized subcommand falls through to `_ => { 使い方();
# ExitCode::from(2) }` -- plus three known-subcommand positive controls.
# `検査`'s own conditional (`二本柱が閉じている()`) is NOT independently
# adversarial-testable through the CLI's argv surface: 豊田生産方式::原初形()
# is a hardcoded `const fn` with every boolean field `true`
# (examples/tcps-generated/src/全体.rs), so 検査 always exits 0 in this
# reference and there is no CLI argument that reaches the false branch --
# out of scope for this closure, not silently ignored (see the
# l5-promotion ontology's cap06 note for tcps-cli-pack for this same
# disclosure at the promotion-program level).
#
# Real exit codes below were captured by actually building and running
# ./target/debug/tcps with each argv (not guessed): 検査/版/環境 each exit
# 0; an unrecognized argv (transcribed here as でたらめ, "nonsense") falls
# through to the usage-and-exit-2 arm.
# ---------------------------------------------------------------------------

tcps:CliCase a rdfs:Class ;
    rdfs:comment "Class of ontology-declared cases for the real `tcps` binary's dispatch sabotage/positive-control proof: argv to pass, and the real exit code that argv must produce." .

tcps:cliInspectSucceeds a tcps:CliCase ;
    tcps:caseName "inspect_known_subcommand_succeeds" ;
    tcps:argv "検査" ;
    tcps:expectedExitCode 0 ;
    rdfs:comment "検査 is a real, recognized subcommand; 豊田生産方式::原初形()'s hardcoded 二本柱が閉じている() is always true in this reference, so this must exit 0 -- positive control." .

tcps:cliVersionSucceeds a tcps:CliCase ;
    tcps:caseName "version_known_subcommand_succeeds" ;
    tcps:argv "版" ;
    tcps:expectedExitCode 0 ;
    rdfs:comment "版 is a real, recognized subcommand with no failure path -- positive control." .

tcps:cliEnvSucceeds a tcps:CliCase ;
    tcps:caseName "env_known_subcommand_succeeds" ;
    tcps:argv "環境" ;
    tcps:expectedExitCode 0 ;
    rdfs:comment "環境 is a real, recognized subcommand with no failure path -- positive control." .

tcps:cliUnknownSubcommandRefuses a tcps:CliCase ;
    tcps:caseName "unknown_subcommand_refuses_with_exit_2" ;
    tcps:argv "でたらめ" ;
    tcps:expectedExitCode 2 ;
    rdfs:comment "Adversarial input: an unrecognized subcommand string hits main.rs's `_ => { 使い方(); ExitCode::from(2) }` fallback arm -- the real binary must exit 2, not panic and not silently succeed as if it were a known command. This is the pack's only real refusal path reachable through the CLI's own argv surface." .
