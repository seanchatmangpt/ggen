@prefix tcps: <http://seanchatmangpt.github.io/packs/tcps-cli#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

tcps:ModuleShape
    a sh:NodeShape ;
    sh:targetClass tcps:Module ;
    rdfs:comment "Every tcps:dependsOnModule reference must resolve to a declared tcps:Module individual -- refuses dangling module references." ;
    sh:property [
        sh:path tcps:dependsOnModule ;
        sh:class tcps:Module ;
        sh:node tcps:ModuleNodeShape ;
        sh:message "tcps:dependsOnModule must point at a declared tcps:Module individual (no dangling reference)." ;
    ] .

tcps:ModuleNodeShape
    a sh:NodeShape ;
    sh:class tcps:Module ;
    sh:property [
        sh:path tcps:name ;
        sh:minCount 1 ;
        sh:message "Referenced tcps:Module must have a tcps:name (i.e. must actually be declared in the graph, not merely typed)." ;
    ] .
