#################################################################
# Enrichment of the seeded individuals (scope / requiredArg / purpose /
# refAttr / testConfigMinimal) — same subjects, additional triples.
# requiredArg values from the provider docs tables; refAttr from the
# provider's own acceptance tests (the attribute dependents reference).
#################################################################

ghtf:GithubRepository ghtf:scope "repository" ;
    ghtf:purpose "Create/manage a repo in an org or personal account" ;
    ghtf:requiredArg "name" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name       = "{{ test_repo }}"
  visibility = "private"
}
""" .

ghtf:GithubBranchProtection ghtf:scope "repository" ;
    ghtf:purpose "Branch protection via GraphQL (pattern-based)" ;
    ghtf:requiredArg "repository_id", "pattern" ;
    ghtf:refAttr "node_id" ;
    ghtf:breakingChange "v6.0.0 restrict-pushes rework (#2045)" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name      = "{{ test_repo }}"
  auto_init = true
}

resource "github_branch_protection" "test" {
  repository_id = github_repository.test.node_id
  pattern       = "main"
}
""" .

ghtf:GithubIssueLabel ghtf:scope "repository" ;
    ghtf:purpose "Manage a single label (non-authoritative)" ;
    ghtf:requiredArg "repository", "name", "color" ;
    ghtf:refAttr "name" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name      = "{{ test_repo }}"
  auto_init = true
}

resource "github_issue_label" "test" {
  repository  = github_repository.test.name
  name        = "foo"
  color       = "000000"
  description = "{{ test_description }}"
}
""" .

ghtf:GithubRepositoryMilestone ghtf:scope "repository" ;
    ghtf:purpose "Manage a repo milestone" ;
    ghtf:requiredArg "owner", "repository", "title" .

ghtf:GithubIssue ghtf:scope "repository" ;
    ghtf:purpose "Create/manage an issue in a repo" ;
    ghtf:requiredArg "repository", "title" ;
    ghtf:refAttr "name" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name       = "{{ test_repo }}"
  has_issues = true
}

resource "github_issue" "test" {
  repository = github_repository.test.name
  title      = github_repository.test.name
}
""" .

ghtf:GithubActionsSecret ghtf:scope "repository" ;
    ghtf:purpose "Repo-level encrypted Actions secret" ;
    ghtf:requiredArg "repository", "secret_name" ;
    ghtf:refAttr "name" ;
    ghtf:testConfigMinimal """resource "github_actions_secret" "test" {
  repository  = "{{ test_repo }}"
  secret_name = "TEST"
  value       = "{{ test_value }}"
}
""" .

ghtf:GithubRepositoryEnvironment ghtf:scope "repository" ;
    ghtf:purpose "Create/manage a deployment environment on a repo" ;
    ghtf:requiredArg "environment", "repository" ;
    ghtf:refAttr "name" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name       = "{{ test_repo }}"
  visibility = "public"
}

resource "github_repository_environment" "test" {
  repository  = github_repository.test.name
  environment = "{{ test_environment }}"
}
""" .

ghtf:GithubRepositoryCollaborator ghtf:scope "repository" ;
    ghtf:purpose "Add a single user as a repo collaborator" ;
    ghtf:requiredArg "repository", "username" ;
    ghtf:refAttr "name" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name      = "{{ test_repo }}"
  auto_init = true
}

resource "github_repository_collaborator" "test_repo_collaborator" {
  repository = github_repository.test.name
  username   = "{{ test_username }}"
  permission = "triage"
}
""" .

ghtf:GithubTeam ghtf:scope "organization" ;
    ghtf:purpose "Create/manage an org team" ;
    ghtf:requiredArg "name" ;
    ghtf:refAttr "id" ;
    ghtf:testConfigMinimal """resource "github_team" "test" {
  name = "{{ test_prefix }}team"
}
""" .

ghtf:GithubRepositoryWebhook ghtf:scope "repository" ;
    ghtf:purpose "Manage a repo webhook" ;
    ghtf:requiredArg "repository", "events", "configuration" ;
    ghtf:refAttr "name" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name        = "{{ test_repo }}"
  description = "Terraform acceptance tests"
}

resource "github_repository_webhook" "test" {
  depends_on = [github_repository.test]
  repository = "{{ test_repo }}"

  configuration {
    url          = "https://google.de/webhook"
    content_type = "json"
    insecure_ssl = true
  }

  events = ["pull_request"]
}
""" .

ghtf:GithubActionsVariable ghtf:scope "repository" ;
    ghtf:purpose "Repo-level Actions variable" ;
    ghtf:requiredArg "repository", "variable_name", "value" ;
    ghtf:testConfigMinimal """resource "github_actions_variable" "test" {
  repository    = "{{ test_repo }}"
  variable_name = "TEST"
  value         = "{{ test_value }}"
}
""" .

ghtf:GithubRepositoryFile ghtf:scope "repository" ;
    ghtf:purpose "Manage a file's content within a repo" ;
    ghtf:requiredArg "repository", "file", "content" ;
    ghtf:refAttr "name" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name      = "{{ test_repo }}"
  auto_init = true
}

resource "github_repository_file" "test" {
  repository     = github_repository.test.name
  branch         = "main"
  file           = "test"
  content        = "bar"
  commit_message = "Managed by Terraform"
  commit_author  = "Terraform User"
  commit_email   = "terraform@example.com"
}
""" .

ghtf:GithubRepositoryRuleset ghtf:scope "repository" ;
    ghtf:purpose "Repo-level ruleset (branch/tag/push protections)" ;
    ghtf:requiredArg "name", "target", "enforcement", "rules", "repository" ;
    ghtf:refAttr "id" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name      = "{{ test_repo }}"
  auto_init = true
}

resource "github_repository_ruleset" "test" {
  name        = "test"
  repository  = github_repository.test.id
  target      = "branch"
  enforcement = "active"

  conditions {
    ref_name {
      include = ["refs/heads/main"]
      exclude = []
    }
  }

  rules {
    creation                = true
    deletion                = true
    required_linear_history = true
  }
}
""" .

#################################################################
# 乙 TCPS desired state — additional RepoManagementInstance individuals
# (第八〜十二章). Risk tiers per 第二十六章: 1=read, 2=low, 3=medium,
# 4=high. Secret NAMES only — never values (第十二章).
#################################################################

ghtf:TcpsRepositorySettings a ghtf:RepoManagementInstance ;
    rdfs:label "repository settings for the managed repo (第八章)" ;
    ghtf:instanceOf ghtf:GithubRepository ;
    ghtf:riskTier 3 ;
    ghtf:hclBody """resource "github_repository" "managed" {
  name                   = var.repository
  description            = "Specification-driven code generation from RDF ontologies — A = μ(O)"
  visibility             = "public"
  has_issues             = true
  has_wiki               = false
  has_projects           = false
  allow_squash_merge     = true
  allow_merge_commit     = false
  allow_rebase_merge     = false
  delete_branch_on_merge = true
  vulnerability_alerts   = true
}
""" .

