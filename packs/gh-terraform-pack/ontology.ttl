        context = "Check"
      }
      required_check {
        context = "Test"
      }
      required_check {
        context = "Build"
      }
      required_check {
        context = "Doctest"
      }
    }
  }
}
""" .

# Declared reasons why the remaining families are INTENTIONALLY empty.
# NOT a ghtf:RepoManagementInstance (the 010_required gate would demand
# hclBody + family); a plain individual whose per-family reason literals
# are rendered as comments into the corresponding empty .tf files.
ghtf:EmptyFamilyReasons rdfs:label "declared reasons for intentionally-empty Terraform families" ;
    ghtf:emptyFamilyReason "issues: issue creation/closure flows through the gh CLI standard work (scripts/gh/issue-create.sh / issue-close.sh), not Terraform — issues are line events, not desired state" ;
    ghtf:emptyFamilyReason "teams: github_team requires organization mode; seanchatmangpt/ggen is a single-user repository with no org teams to declare" ;
    ghtf:emptyFamilyReason "collaborators: github_repository_collaborator requires org/multi-user administration; the single-user repository has no external collaborators to declare" ;
    ghtf:emptyFamilyReason "webhooks: no webhook integrations are needed yet; CI is GitHub Actions (in-platform), so there is no external receiver to register" ;
    ghtf:emptyFamilyReason "files: repository files are managed by ggen itself (A = μ(O), receipted sync), not by github_repository_file — Terraform-managed file content would create a second, competing authority" .

#################################################################
# 丁 gh CLI standard work — 7 additional commands (第十七章), completing
# the 12-script surface. Read/write separated; writes preview + confirm.
#################################################################

ghcli:PrCloseStale a ghcli:Command ;
    ghcli:noun "pr" ; ghcli:verb "close-stale" ;
    ghcli:scriptName "pr-close-stale.sh" ; ghcli:mutating true ;
    ghcli:doc "List stale PRs (default >30d inactive); close only with --confirm" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: pr-close-stale.sh --repo <owner/repo> [--days N] [--confirm]
repo="" ; days=30 ; confirm=0
while [ $# -gt 0 ]; do
  case "$1" in
    --repo) repo="$2"; shift 2 ;;
    --days) days="$2"; shift 2 ;;
    --confirm) confirm=1; shift ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done
[ -n "$repo" ] || { echo "usage: pr-close-stale.sh --repo <owner/repo> [--days N] [--confirm]" >&2; exit 2; }
cutoff=$(date -v-"${days}"d +%Y-%m-%d 2>/dev/null || date -d "-${days} days" +%Y-%m-%d)
stale=$(gh pr list --repo "$repo" --state open --search "updated:<$cutoff" --json number --jq .[].number)
if [ -z "$stale" ]; then echo "no PRs inactive for ${days}+ days"; exit 0; fi
echo "stale PRs (${days}+ days inactive):"
for n in $stale; do
  gh pr view "$n" --repo "$repo" --json number,title,updatedAt --jq '"#" + (.number|tostring) + " " + .title + " (updated " + .updatedAt + ")"'
  echo
done
if [ "$confirm" -ne 1 ]; then
  echo "preview only — re-run with --confirm to close"; exit 0
fi
for n in $stale; do
  gh pr close "$n" --repo "$repo" --comment "Closed as stale (${days}+ days inactive) by TCPS standard work pr-close-stale.sh"
done
""" .

ghcli:RunRerun a ghcli:Command ;
    ghcli:noun "run" ; ghcli:verb "rerun" ;
    ghcli:scriptName "run-rerun.sh" ; ghcli:mutating true ;
    ghcli:doc "Re-run a failed workflow run (equipment-abnormality response, 第二十一章)" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: run-rerun.sh --repo <owner/repo> <run-id> [--failed-only]
repo="" ; failed=""
while [ $# -gt 0 ]; do
  case "$1" in
    --repo) repo="$2"; shift 2 ;;
    --failed-only) failed="--failed"; shift ;;
    *) run="$1"; shift ;;
  esac
done
[ -n "$repo" ] && [ -n "${run:-}" ] || { echo "usage: run-rerun.sh --repo <owner/repo> <run-id> [--failed-only]" >&2; exit 2; }
gh run rerun "$run" --repo "$repo" ${failed}
""" .

ghcli:CiClassify a ghcli:Command ;
    ghcli:noun "ci" ; ghcli:verb "classify" ;
    ghcli:scriptName "ci-classify.sh" ; ghcli:mutating false ;
    ghcli:doc "Mechanized CI abnormality classification (第二十九章 condition 9): bucket each non-passing check as 製品異常 / 設備異常 / 標準異常 with a recommended response" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: ci-classify.sh --repo <owner/repo> --pr <n>
# 第二十九章 condition 9: mechanized step 2 of CI異常対応.
# Buckets: 製品異常 (product defect -> fix-product),
#          設備異常 (equipment: runner/network/timeout/... -> run-rerun.sh),
#          標準異常 (required check not wired/not reported -> drift-report.sh).
repo="" ; pr=""
while [ $# -gt 0 ]; do
  case "$1" in
    --repo) repo="$2"; shift 2 ;;
    --pr) pr="$2"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done
[ -n "$repo" ] && [ -n "$pr" ] || { echo "usage: ci-classify.sh --repo <owner/repo> --pr <n>" >&2; exit 2; }

checks_json="$(gh pr checks "$pr" --repo "$repo" --json name,state,bucket,link 2>/dev/null || true)"
if ! echo "$checks_json" | jq -e 'type == "array"' >/dev/null 2>&1; then
  plain="$(gh pr checks "$pr" --repo "$repo" 2>/dev/null || true)"
  checks_json="$(echo "$plain" | while IFS= read -r line; do
    [ -n "$line" ] || continue
    n="$(echo "$line" | cut -f1)"
    s="$(echo "$line" | cut -f2)"
    jq -cn --arg name "$n" --arg state "$s" --arg link "$line" '{name: $name, state: $state, bucket: $state, link: $link}'
  done | jq -cs '.')"
fi

results="$(echo "$checks_json" | jq -c '.[]' | while IFS= read -r c; do
  state="$(echo "$c" | jq -r '(.state // "") | ascii_upcase')"
  case "$state" in SUCCESS|PASS|NEUTRAL|SKIPPED|SKIPPING) continue ;; esac
  name="$(echo "$c" | jq -r '.name // ""')"
  required=0
  case "$name" in Check|Test|Build|Doctest|"CI Status") required=1 ;; esac
  bucket="製品異常" ; recommend="fix-product"
  if [ "$required" -eq 1 ] && { [ -z "$state" ] || [ "$state" = "MISSING" ] || [ "$state" = "NOT_REPORTED" ] || [ "$state" = "EXPECTED" ] || [ "$state" = "PENDING" ]; }; then
    bucket="標準異常" ; recommend="drift-report.sh"
  elif echo "$c" | grep -qiE 'runner|network|timeout|cancelled|infrastructure|rate.limit'; then
    bucket="設備異常" ; recommend="run-rerun.sh"
  fi
  jq -cn --arg check "$name" --arg bucket "$bucket" --arg recommend "$recommend" '{check: $check, bucket: $bucket, recommend: $recommend}'
done)"

if [ -n "$results" ]; then
  echo "$results"
fi
echo "$results" | jq -cs 'map(select(type == "object")) | {ci_classify: "done", counts: (group_by(.bucket) | map({(.[0].bucket): length}) | add // {})}'
""" .

ghcli:IssueCreate a ghcli:Command ;
    ghcli:noun "issue" ; ghcli:verb "create" ;
    ghcli:scriptName "issue-create.sh" ; ghcli:mutating true ;
    ghcli:doc "Create an issue with title/body/labels (低危険変更, tier 2)" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: issue-create.sh --repo <owner/repo> --title <t> [--body <b>] [--label <l>]...
repo="" ; title="" ; body="" ; labels=()
while [ $# -gt 0 ]; do
  case "$1" in
    --repo) repo="$2"; shift 2 ;;
    --title) title="$2"; shift 2 ;;
    --body) body="$2"; shift 2 ;;
    --label) labels+=(--label "$2"); shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done
[ -n "$repo" ] && [ -n "$title" ] || { echo "usage: issue-create.sh --repo <owner/repo> --title <t> [--body <b>] [--label <l>]..." >&2; exit 2; }
gh issue create --repo "$repo" --title "$title" --body "$body" "${labels[@]}"
""" .

ghcli:IssueClose a ghcli:Command ;
    ghcli:noun "issue" ; ghcli:verb "close" ;
    ghcli:scriptName "issue-close.sh" ; ghcli:mutating true ;
    ghcli:doc "Close an issue; prints current state first (事前表示)" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: issue-close.sh --repo <owner/repo> <issue-number> [--comment <c>]
repo="" ; comment=""
while [ $# -gt 0 ]; do
  case "$1" in
    --repo) repo="$2"; shift 2 ;;
    --comment) comment="$2"; shift 2 ;;
    *) n="$1"; shift ;;
  esac
done
[ -n "$repo" ] && [ -n "${n:-}" ] || { echo "usage: issue-close.sh --repo <owner/repo> <issue-number> [--comment <c>]" >&2; exit 2; }
echo "current state:"; gh issue view "$n" --repo "$repo" --json number,title,state,labels --jq '.'
if [ -n "$comment" ]; then
  gh issue close "$n" --repo "$repo" --comment "$comment"
else
  gh issue close "$n" --repo "$repo"
fi
""" .

ghcli:ReleaseView a ghcli:Command ;
    ghcli:noun "release" ; ghcli:verb "view" ;
    ghcli:scriptName "release-view.sh" ; ghcli:mutating false ;
    ghcli:doc "Read a release's assets/state as JSON (読取り, tier 1)" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: release-view.sh --repo <owner/repo> [<tag>]
repo="" ; tag=""
while [ $# -gt 0 ]; do
  case "$1" in
    --repo) repo="$2"; shift 2 ;;
    *) tag="$1"; shift ;;
  esac
done
[ -n "$repo" ] || { echo "usage: release-view.sh --repo <owner/repo> [<tag>]" >&2; exit 2; }
if [ -n "$tag" ]; then
  gh release view "$tag" --repo "$repo" --json tagName,name,isDraft,isPrerelease,publishedAt,assets
else
  gh release list --repo "$repo" --limit 10
fi
""" .

ghcli:RepoState a ghcli:Command ;
    ghcli:noun "repo" ; ghcli:verb "state" ;
    ghcli:scriptName "repo-state.sh" ; ghcli:mutating false ;
    ghcli:doc "Aggregated single-call repo state read: settings, protection, open PRs, latest run (現地現物, tier 1)" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: repo-state.sh --repo <owner/repo>
repo=""
while [ $# -gt 0 ]; do
  case "$1" in
    --repo) repo="$2"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done
[ -n "$repo" ] || { echo "usage: repo-state.sh --repo <owner/repo>" >&2; exit 2; }
echo "== repository =="
gh repo view "$repo" --json name,visibility,defaultBranchRef,isArchived,deleteBranchOnMerge --jq '.'
echo "== branch protection (default branch) =="
gh api "repos/${repo}/branches/$(gh repo view "$repo" --json defaultBranchRef --jq .defaultBranchRef.name)/protection" 2>/dev/null || echo "(no protection or no access)"
echo "== open PRs =="
gh pr list --repo "$repo" --state open --json number,title,mergeable --jq '.'
echo "== latest workflow runs =="
gh run list --repo "$repo" --limit 5
""" .

ghcli:DriftReport a ghcli:Command ;
    ghcli:noun "drift" ; ghcli:verb "report" ;
    ghcli:scriptName "drift-report.sh" ; ghcli:mutating false ;
    ghcli:doc "Runs terraform plan -detailed-exitcode in the generated module dir; classifies create/update/replace/delete and assigns andon per 第二十三章 (any delete => YELLOW; protection/secret/required-check removal => RED)" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: drift-report.sh [--dir <terraform-dir>] [--owner <o>] [--repo <name>] [--secret-value <v>]
dir="infra/terraform/github" ; owner="" ; repo="" ; secret=""
while [ $# -gt 0 ]; do
  case "$1" in
    --dir) dir="$2"; shift 2 ;;
    --owner) owner="$2"; shift 2 ;;
    --repo) repo="$2"; shift 2 ;;
    --secret-value) secret="$2"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done
[ -d "$dir" ] || { echo "terraform dir not found: $dir" >&2; exit 2; }
cd "$dir"
vars=()
[ -n "$owner" ] && vars+=("-var=github_owner=${owner}")
[ -n "$repo" ] && vars+=("-var=repository=${repo}")
[ -n "$secret" ] && vars+=("-var=ggen_signing_key_value=${secret}")
plan_out=$(mktemp)
set +e
terraform plan -detailed-exitcode -no-color -input=false ${vars[@]+"${vars[@]}"} > "$plan_out" 2>&1
code=$?
set -e
case "$code" in
  0) andon="GREEN" ; drift="none" ;;
  2) andon="YELLOW" ; drift="detected" ;;
  *) andon="RED" ; drift="plan-error" ;;
esac
deletes=$(grep -c "will be destroyed" "$plan_out" || true)
if [ "${deletes:-0}" -gt 0 ]; then andon="YELLOW"; fi
if grep -qE "github_branch_protection.*destroyed|github_actions_secret.*destroyed|required_status_checks" "$plan_out" && [ "${deletes:-0}" -gt 0 ]; then
  andon="RED"
fi
creates=$(grep -c "will be created" "$plan_out" || true)
updates=$(grep -c "will be updated in-place" "$plan_out" || true)
replaces=$(grep -c "must be replaced" "$plan_out" || true)
echo '{"andon":"'"$andon"'","drift":"'"$drift"'","create":'"${creates:-0}"',"update":'"${updates:-0}"',"replace":'"${replaces:-0}"',"delete":'"${deletes:-0}"'}'
rm -f "$plan_out"
[ "$andon" = "GREEN" ]
""" .

