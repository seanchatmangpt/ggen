@prefix ghtf:  <http://seanchatmangpt.github.io/packs/gh-terraform#> .
@prefix ghcli: <http://seanchatmangpt.github.io/packs/gh-terraform#cli-> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Classes
#################################################################

ghtf:TerraformResource a rdfs:Class ;
    rdfs:label "A github Terraform provider resource TYPE this pack knows how to emit, carrying a real example HCL block modeled verbatim on ~/dev/ranchr/bend/modules/integrations/github and ~/dev/beamops" .

ghtf:RepoManagementInstance a rdfs:Class ;
    rdfs:label "A concrete desired-state fact for THIS repo (seanchatmangpt/ggen), referencing a ghtf:TerraformResource type and supplying real argument values as a rendered HCL block" .

ghcli:Command a rdfs:Class ;
    rdfs:label "A reusable gh CLI shell-script command, modeled on clap-noun-verb-pack's cnv:Command noun/verb shape" .

#################################################################
# ghtf:TerraformResource catalog (reference doc only — real example
# bodies, verbatim/adapted from the real ranchr+beamops modules; provider
# pin matches those modules exactly: integrations/github v5.41.0)
#################################################################

ghtf:GithubRepository a ghtf:TerraformResource ;
    rdfs:label "github_repository" ;
    ghtf:resourceType "github_repository" ;
    ghtf:sourceExample "~/dev/beamops modules/integrations/github" ;
    ghtf:hclBody """resource "github_repository" "kanban" {
  name                   = local.repository_name
  description            = "Taking the BEAM to production pragmatically."
  visibility             = "private"
  has_issues             = true
  auto_init              = true
  gitignore_template     = "Terraform"
  delete_branch_on_merge = true
}
""" .

ghtf:GithubBranchProtection a ghtf:TerraformResource ;
    rdfs:label "github_branch_protection" ;
    ghtf:resourceType "github_branch_protection" ;
    ghtf:sourceExample "~/dev/ranchr/bend modules/integrations/github" ;
    ghtf:hclBody """resource "github_branch_protection" "main" {
  repository_id = var.repository
  pattern        = "main"
  lock_branch    = true
  enforce_admins = true
  required_status_checks {
    strict   = true
    contexts = var.status_checks
  }
  required_pull_request_reviews {
    require_code_owner_reviews      = false
    required_approving_review_count = 1
  }
}
""" .

ghtf:GithubIssueLabel a ghtf:TerraformResource ;
    rdfs:label "github_issue_label" ;
    ghtf:resourceType "github_issue_label" ;
    ghtf:sourceExample "~/dev/ranchr/bend modules/integrations/github" ;
    ghtf:hclBody """resource "github_issue_label" "this" {
  repository  = var.repository
  name        = var.label_name
  color       = var.label_color
  description = var.label_description
}
""" .

ghtf:GithubRepositoryMilestone a ghtf:TerraformResource ;
    rdfs:label "github_repository_milestone" ;
    ghtf:resourceType "github_repository_milestone" ;
    ghtf:sourceExample "~/dev/ranchr/bend modules/integrations/github" ;
    ghtf:hclBody """resource "github_repository_milestone" "this" {
  owner       = var.owner
  repository  = var.repository
  title       = var.milestone_title
  description = var.milestone_description
  state       = "open"
}
""" .

ghtf:GithubIssue a ghtf:TerraformResource ;
    rdfs:label "github_issue" ;
    ghtf:resourceType "github_issue" ;
    ghtf:sourceExample "~/dev/ranchr/bend modules/integrations/github" ;
    ghtf:hclBody """resource "github_issue" "this" {
  repository = var.repository
  title      = var.issue_title
  body       = var.issue_body
  labels     = var.issue_labels
}
""" .

ghtf:GithubActionsSecret a ghtf:TerraformResource ;
    rdfs:label "github_actions_secret" ;
    ghtf:resourceType "github_actions_secret" ;
    ghtf:sourceExample "~/dev/ranchr/bend modules/integrations/github" ;
    ghtf:hclBody """resource "github_actions_secret" "this" {
  repository      = var.repository
  secret_name     = var.secret_name
  plaintext_value = var.secret_value
}
""" .

ghtf:GithubRepositoryEnvironment a ghtf:TerraformResource ;
    rdfs:label "github_repository_environment" ;
    ghtf:resourceType "github_repository_environment" ;
    ghtf:sourceExample "natural extension, same provider (integrations/github v5.41.0)" ;
    ghtf:hclBody """resource "github_repository_environment" "this" {
  repository  = var.repository
  environment = var.environment_name
}
""" .

ghtf:GithubRepositoryCollaborator a ghtf:TerraformResource ;
    rdfs:label "github_repository_collaborator" ;
    ghtf:resourceType "github_repository_collaborator" ;
    ghtf:sourceExample "natural extension, same provider (integrations/github v5.41.0)" ;
    ghtf:hclBody """resource "github_repository_collaborator" "this" {
  repository = var.repository
  username   = var.collaborator_username
  permission = var.collaborator_permission
}
""" .

ghtf:GithubTeam a ghtf:TerraformResource ;
    rdfs:label "github_team / github_team_repository" ;
    ghtf:resourceType "github_team" ;
    ghtf:sourceExample "natural extension, same provider (integrations/github v5.41.0)" ;
    ghtf:hclBody """resource "github_team" "this" {
  name        = var.team_name
  description = var.team_description
  privacy     = "closed"
}

resource "github_team_repository" "this" {
  team_id    = github_team.this.id
  repository = var.repository
  permission = var.team_permission
}
""" .

ghtf:GithubRepositoryWebhook a ghtf:TerraformResource ;
    rdfs:label "github_repository_webhook" ;
    ghtf:resourceType "github_repository_webhook" ;
    ghtf:sourceExample "natural extension, same provider (integrations/github v5.41.0)" ;
    ghtf:hclBody """resource "github_repository_webhook" "this" {
  repository = var.repository
  active     = true
  events     = var.webhook_events
  configuration {
    url          = var.webhook_url
    content_type = "json"
  }
}
""" .

ghtf:GithubActionsVariable a ghtf:TerraformResource ;
    rdfs:label "github_actions_variable" ;
    ghtf:resourceType "github_actions_variable" ;
    ghtf:sourceExample "natural extension, same provider (integrations/github v5.41.0)" ;
    ghtf:hclBody """resource "github_actions_variable" "this" {
  repository    = var.repository
  variable_name = var.variable_name
  value         = var.variable_value
}
""" .

ghtf:GithubRepositoryFile a ghtf:TerraformResource ;
    rdfs:label "github_repository_file" ;
    ghtf:resourceType "github_repository_file" ;
    ghtf:sourceExample "natural extension — the provider's own template-driven-file-in-repo resource, directly analogous to ggen's own generation model" ;
    ghtf:hclBody """resource "github_repository_file" "this" {
  repository          = var.repository
  branch              = "main"
  file                = var.file_path
  content             = var.file_content
  commit_message      = var.commit_message
  overwrite_on_create = false
}
""" .

ghtf:GithubRepositoryRuleset a ghtf:TerraformResource ;
    rdfs:label "github_repository_ruleset" ;
    ghtf:resourceType "github_repository_ruleset" ;
    ghtf:sourceExample "the provider's newer, actively-maintained superset of github_branch_protection; included alongside it since the real examples use the older resource" ;
    ghtf:hclBody """resource "github_repository_ruleset" "this" {
  name        = var.ruleset_name
  repository  = var.repository
  target      = "branch"
  enforcement = "active"
  conditions {
    ref_name {
      include = ["~DEFAULT_BRANCH"]
      exclude = []
    }
  }
  rules {
    required_status_checks {
      required_check {
        context = var.required_check_context
      }
    }
    pull_request {
      required_approving_review_count = 1
    }
  }
}
""" .

#################################################################
# ghtf:RepoManagementInstance — concrete desired-state for THIS repo
# (seanchatmangpt/ggen). Rendered to infra/terraform/github/main.tf.
# NOTE: generation only — `terraform apply` is never run by this pack or
# its tests.
#################################################################

ghtf:Variables a ghtf:RepoManagementInstance ;
    rdfs:label "declares the input variables referenced by every hclBody literal below" ;
    ghtf:hclBody """variable "github_owner" {
  description = "GitHub org/user that owns the managed repository."
  type        = string
  default     = "seanchatmangpt"
}

variable "repository" {
  description = "Repository name to manage."
  type        = string
  default     = "ggen"
}

variable "ggen_signing_key_value" {
  description = "Value for the GGEN_SIGNING_KEY actions secret. Supplied at apply time only; never stored in RDF or state committed to the repo."
  type        = string
  sensitive   = true
  default     = ""
}
""" .

ghtf:RequiredProviders a ghtf:RepoManagementInstance ;
    rdfs:label "provider pin, matching the real ranchr/beamops examples exactly" ;
    ghtf:hclBody """terraform {
  required_providers {
    github = {
      source  = "integrations/github"
      version = "5.41.0"
    }
  }
}

provider "github" {
  owner = var.github_owner
}
""" .

ghtf:MainBranchProtection a ghtf:RepoManagementInstance ;
    rdfs:label "main branch requires ci.yml Check/Test/Build/Doctest to pass" ;
    ghtf:instanceOf ghtf:GithubBranchProtection ;
    ghtf:hclBody """resource "github_branch_protection" "main" {
  repository_id  = var.repository
  pattern        = "main"
  enforce_admins = true
  required_status_checks {
    strict = true
    contexts = [
      "Check",
      "Test",
      "Build",
      "Doctest",
      "CI Status",
    ]
  }
  required_pull_request_reviews {
    require_code_owner_reviews      = false
    required_approving_review_count = 1
  }
}
""" .

ghtf:L5ConditionLabel a ghtf:RepoManagementInstance ;
    rdfs:label "the l5-condition label used throughout this session's L5 PRs" ;
    ghtf:instanceOf ghtf:GithubIssueLabel ;
    ghtf:hclBody """resource "github_issue_label" "l5_condition" {
  repository  = var.repository
  name        = "l5-condition"
  color       = "1d76db"
  description = "Work closing one of the 23 L5 publication conditions"
}
""" .

#################################################################
# ghcli:Command — reusable gh CLI shell scripts, modeled on
# clap-noun-verb-pack's cnv:Command noun/verb shape. Rendered to
# scripts/gh/<verb-with-dashes>.sh.
#################################################################

ghcli:PrCreate a ghcli:Command ;
    ghcli:noun "pr" ;
    ghcli:verb "create" ;
    ghcli:scriptName "pr-create.sh" ;
    ghcli:doc "Open a PR from the current branch: gh pr create --fill" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: pr-create.sh [--title TITLE] [--body BODY]
gh pr create --fill "$@"
""" .

ghcli:PrMerge a ghcli:Command ;
    ghcli:noun "pr" ;
    ghcli:verb "merge" ;
    ghcli:scriptName "pr-merge.sh" ;
    ghcli:doc "Squash-merge a PR and delete its branch: gh pr merge --squash --delete-branch" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: pr-merge.sh <pr-number>
pr="${1:?usage: pr-merge.sh <pr-number>}"
gh pr merge "$pr" --squash --delete-branch
""" .

ghcli:PrChecks a ghcli:Command ;
    ghcli:noun "pr" ;
    ghcli:verb "checks" ;
    ghcli:scriptName "pr-checks.sh" ;
    ghcli:doc "List CI check status for a PR: gh pr checks" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: pr-checks.sh <pr-number>
pr="${1:?usage: pr-checks.sh <pr-number>}"
gh pr checks "$pr"
""" .

ghcli:PrViewMergeable a ghcli:Command ;
    ghcli:noun "pr" ;
    ghcli:verb "view-mergeable" ;
    ghcli:scriptName "pr-view-mergeable.sh" ;
    ghcli:doc "Print a PR's mergeable state as JSON: gh pr view --json mergeable" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: pr-view-mergeable.sh <pr-number>
pr="${1:?usage: pr-view-mergeable.sh <pr-number>}"
gh pr view "$pr" --json mergeable,mergeStateStatus
""" .

ghcli:RunView a ghcli:Command ;
    ghcli:noun "run" ;
    ghcli:verb "view" ;
    ghcli:scriptName "run-view.sh" ;
    ghcli:doc "View a workflow run's status and logs: gh run view" ;
    ghcli:scriptBody """#!/usr/bin/env bash
set -euo pipefail
# Usage: run-view.sh <run-id> [--log]
run="${1:?usage: run-view.sh <run-id> [--log]}"
shift || true
gh run view "$run" "$@"
""" .

#################################################################
# Version facts (第十五章 提供者版管理)
#################################################################

ghtf:ProviderVersionFacts a ghtf:VersionFacts ;
    ghtf:pinnedProviderVersion "5.41.0" ;
    ghtf:latestProviderVersion "6.13.0" ;
    ghtf:latestReleaseDate "2026-07-08" ;
    ghtf:breakingChangeNote "v6.0.0: github_branch_protection restrict-pushes rework (#2045) + Terraform Plugin SDK v2 migration (#1780); v6.10.1 reverted allowed_merge_methods Required->Optional; v6.9.0 deprecated duplicate org team-role resources and has_downloads." .

#################################################################
# Full resource catalog (第十四章 組合せ最大化) — knowledge tier.
# Every resource of integrations/github enumerated from docs/resources
# on main (89 doc files). Catalog-only individuals carry NO hclBody —
# an absent hclBody means "cataloged, not yet templated" (no fabricated
# schemas). scope: repository | organization | enterprise | user.
#################################################################

# --- actions family (repo scope) ---
ghtf:CatActionsEnvironmentSecret a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_environment_secret" ; ghtf:scope "repository" ;
    ghtf:purpose "Encrypted Actions secret scoped to a repo environment" ;
    ghtf:requiredArg "environment", "repository", "secret_name" ;
    ghtf:testConfigMinimal """resource "github_actions_environment_secret" "test" {
  repository  = "{{ test_repo }}"
  environment = "{{ test_environment }}"
  secret_name = "TEST"
  value       = "{{ test_value }}"
}
""" .

ghtf:CatActionsEnvironmentVariable a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_environment_variable" ; ghtf:scope "repository" ;
    ghtf:purpose "Plaintext Actions variable scoped to a repo environment" ;
    ghtf:requiredArg "environment", "repository", "variable_name", "value" .

ghtf:CatActionsRepositoryAccessLevel a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_repository_access_level" ; ghtf:scope "repository" ;
    ghtf:purpose "Sets where a repo's actions/workflows may be reused" ;
    ghtf:requiredArg "repository", "access_level" .

ghtf:CatActionsRepositoryOidcTemplate a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_repository_oidc_subject_claim_customization_template" ; ghtf:scope "repository" ;
    ghtf:purpose "Repo-level OIDC subject claim template" ;
    ghtf:requiredArg "use_default" .

ghtf:CatActionsRepositoryPermissions a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_repository_permissions" ; ghtf:scope "repository" ;
    ghtf:purpose "Per-repo Actions enablement/allowed-actions policy" ;
    ghtf:requiredArg "repository", "github_owned_allowed" .

# --- actions family (organization scope) ---
ghtf:CatActionsHostedRunner a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_hosted_runner" ; ghtf:scope "organization" ;
    ghtf:purpose "GitHub-hosted Actions runner for an org" ;
    ghtf:requiredArg "name", "image", "size", "runner_group_id" .

ghtf:CatActionsOrgOidcTemplate a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_organization_oidc_subject_claim_customization_template" ; ghtf:scope "organization" ;
    ghtf:purpose "Org-level OIDC subject claim template" ;
    ghtf:requiredArg "include_claim_keys" .

ghtf:CatActionsOrgPermissions a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_organization_permissions" ; ghtf:scope "organization" ;
    ghtf:purpose "Org Actions policy (which repos/actions allowed)" ;
    ghtf:requiredArg "enabled_repositories" .

ghtf:CatActionsOrgSecret a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_organization_secret" ; ghtf:scope "organization" ;
    ghtf:purpose "Org-level encrypted Actions secret" ;
    ghtf:requiredArg "secret_name", "visibility" .

ghtf:CatActionsOrgSecretRepositories a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_organization_secret_repositories" ; ghtf:scope "organization" ;
    ghtf:purpose "Repo allow-list for a selected org Actions secret" ;
    ghtf:requiredArg "secret_name", "selected_repository_ids" .

ghtf:CatActionsOrgSecretRepository a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_organization_secret_repository" ; ghtf:scope "organization" ;
    ghtf:purpose "Single repo grant to an org Actions secret" ;
    ghtf:requiredArg "secret_name", "repository_id" .

ghtf:CatActionsOrgVariable a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_organization_variable" ; ghtf:scope "organization" ;
    ghtf:purpose "Org-level Actions variable" ;
    ghtf:requiredArg "variable_name", "value", "visibility" .

ghtf:CatActionsOrgVariableRepositories a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_organization_variable_repositories" ; ghtf:scope "organization" ;
    ghtf:purpose "Repo allow-list for a selected org Actions variable" ;
    ghtf:requiredArg "variable_name", "selected_repository_ids" .

ghtf:CatActionsOrgVariableRepository a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_organization_variable_repository" ; ghtf:scope "organization" ;
    ghtf:purpose "Single repo grant to an org Actions variable" ;
    ghtf:requiredArg "variable_name", "repository_id" .

ghtf:CatActionsOrgWorkflowPermissions a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_organization_workflow_permissions" ; ghtf:scope "organization" ;
    ghtf:purpose "Default workflow token/approval permissions for an org" ;
    ghtf:requiredArg "organization_slug" .

ghtf:CatActionsRunnerGroup a ghtf:TerraformResource ;
    ghtf:resourceType "github_actions_runner_group" ; ghtf:scope "organization" ;
    ghtf:purpose "Org self-hosted runner group" ;
    ghtf:requiredArg "name" .

# --- app family ---
ghtf:CatAppInstallationRepositories a ghtf:TerraformResource ;
    ghtf:resourceType "github_app_installation_repositories" ; ghtf:scope "organization" ;
    ghtf:purpose "Installs a GitHub App on a set of repos" ;
    ghtf:requiredArg "installation_id", "selected_repositories" .

ghtf:CatAppInstallationRepository a ghtf:TerraformResource ;
    ghtf:resourceType "github_app_installation_repository" ; ghtf:scope "organization" ;
    ghtf:purpose "Installs a GitHub App on a single repo" ;
    ghtf:requiredArg "installation_id", "repository" ;
    ghtf:refAttr "name" .

# --- branch family (repo scope) ---
ghtf:CatBranch a ghtf:TerraformResource ;
    ghtf:resourceType "github_branch" ; ghtf:scope "repository" ;
    ghtf:purpose "Creates a git branch in a repo" ;
    ghtf:requiredArg "repository", "branch" ;
    ghtf:refAttr "name" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name      = "{{ test_repo }}"
  auto_init = true
}

resource "github_branch" "test" {
  repository = github_repository.test.name
  branch     = "test"
}
""" .

ghtf:CatBranchDefault a ghtf:TerraformResource ;
    ghtf:resourceType "github_branch_default" ; ghtf:scope "repository" ;
    ghtf:purpose "Sets a repo's default branch" ;
    ghtf:requiredArg "repository", "branch" ;
    ghtf:refAttr "name" ;
    ghtf:testConfigMinimal """resource "github_repository" "test" {
  name      = "{{ test_repo }}"
  auto_init = true
}

resource "github_branch_default" "test" {
  repository = github_repository.test.name
  branch     = "main"
}
""" .

ghtf:CatBranchProtectionV3 a ghtf:TerraformResource ;
    ghtf:resourceType "github_branch_protection_v3" ; ghtf:scope "repository" ;
    ghtf:purpose "Branch protection via REST v3 (branch-name-based, older API)" ;
    ghtf:requiredArg "repository", "branch" ;
    ghtf:refAttr "name" .

# --- codespaces family ---
ghtf:CatCodespacesOrgSecret a ghtf:TerraformResource ;
    ghtf:resourceType "github_codespaces_organization_secret" ; ghtf:scope "organization" ;
    ghtf:purpose "Org-level Codespaces secret" ;
    ghtf:requiredArg "secret_name", "visibility" .

ghtf:CatCodespacesOrgSecretRepositories a ghtf:TerraformResource ;
    ghtf:resourceType "github_codespaces_organization_secret_repositories" ; ghtf:scope "organization" ;
    ghtf:purpose "Repo allow-list for an org Codespaces secret" ;
    ghtf:requiredArg "secret_name", "selected_repository_ids" .

ghtf:CatCodespacesSecret a ghtf:TerraformResource ;
    ghtf:resourceType "github_codespaces_secret" ; ghtf:scope "repository" ;
    ghtf:purpose "Repo-level Codespaces secret" ;
    ghtf:requiredArg "repository", "secret_name" .

ghtf:CatCodespacesUserSecret a ghtf:TerraformResource ;
    ghtf:resourceType "github_codespaces_user_secret" ; ghtf:scope "user" ;
    ghtf:purpose "User-level Codespaces secret" ;
    ghtf:requiredArg "secret_name" .

# --- dependabot family ---
ghtf:CatDependabotOrgSecret a ghtf:TerraformResource ;
    ghtf:resourceType "github_dependabot_organization_secret" ; ghtf:scope "organization" ;
    ghtf:purpose "Org-level Dependabot secret" ;
    ghtf:requiredArg "secret_name", "visibility" .

ghtf:CatDependabotOrgSecretRepositories a ghtf:TerraformResource ;
    ghtf:resourceType "github_dependabot_organization_secret_repositories" ; ghtf:scope "organization" ;
    ghtf:purpose "Repo allow-list for an org Dependabot secret" ;
    ghtf:requiredArg "secret_name", "selected_repository_ids" .

ghtf:CatDependabotOrgSecretRepository a ghtf:TerraformResource ;
    ghtf:resourceType "github_dependabot_organization_secret_repository" ; ghtf:scope "organization" ;
    ghtf:purpose "Single repo grant to an org Dependabot secret" ;
    ghtf:requiredArg "secret_name", "repository_id" .

ghtf:CatDependabotSecret a ghtf:TerraformResource ;
    ghtf:resourceType "github_dependabot_secret" ; ghtf:scope "repository" ;
    ghtf:purpose "Repo-level Dependabot secret" ;
    ghtf:requiredArg "repository", "secret_name" .

# --- emu / enterprise family ---
ghtf:CatEmuGroupMapping a ghtf:TerraformResource ;
    ghtf:resourceType "github_emu_group_mapping" ; ghtf:scope "enterprise" ;
    ghtf:purpose "Maps an EMU (Enterprise Managed User) IdP group to a team" ;
    ghtf:requiredArg "team_slug", "group_id" .

ghtf:CatEnterpriseActionsPermissions a ghtf:TerraformResource ;
    ghtf:resourceType "github_enterprise_actions_permissions" ; ghtf:scope "enterprise" ;
    ghtf:purpose "Enterprise-wide Actions policy" ;
    ghtf:requiredArg "enterprise_slug", "enabled_organizations" .

ghtf:CatEnterpriseActionsRunnerGroup a ghtf:TerraformResource ;
    ghtf:resourceType "github_enterprise_actions_runner_group" ; ghtf:scope "enterprise" ;
    ghtf:purpose "Enterprise self-hosted runner group" ;
    ghtf:requiredArg "enterprise_slug", "name", "visibility" .

ghtf:CatEnterpriseActionsWorkflowPermissions a ghtf:TerraformResource ;
    ghtf:resourceType "github_enterprise_actions_workflow_permissions" ; ghtf:scope "enterprise" ;
    ghtf:purpose "Enterprise default workflow token permissions" ;
    ghtf:requiredArg "enterprise_slug" .

ghtf:CatEnterpriseIpAllowListEntry a ghtf:TerraformResource ;
    ghtf:resourceType "github_enterprise_ip_allow_list_entry" ; ghtf:scope "enterprise" ;
    ghtf:purpose "Enterprise IP allow-list entry" ;
    ghtf:requiredArg "enterprise_slug", "ip" .

ghtf:CatEnterpriseOrganization a ghtf:TerraformResource ;
    ghtf:resourceType "github_enterprise_organization" ; ghtf:scope "enterprise" ;
    ghtf:purpose "Creates/manages an org within an enterprise" ;
    ghtf:requiredArg "enterprise_id", "name", "billing_email", "admin_logins" .

ghtf:CatEnterpriseSecurityAnalysisSettings a ghtf:TerraformResource ;
    ghtf:resourceType "github_enterprise_security_analysis_settings" ; ghtf:scope "enterprise" ;
    ghtf:purpose "Enterprise GHAS / secret-scanning / push-protection defaults" ;
    ghtf:requiredArg "enterprise_slug" .

# --- issue / membership / organization / project / release families (f-r) ---
ghtf:CatIssueLabels a ghtf:TerraformResource ;
    ghtf:resourceType "github_issue_labels" ; ghtf:scope "repository" ;
    ghtf:purpose "Manage ALL labels for a repo (authoritative; mutually exclusive with github_issue_label)" ;
    ghtf:requiredArg "repository" .

ghtf:CatMembership a ghtf:TerraformResource ;
    ghtf:resourceType "github_membership" ; ghtf:scope "organization" ;
    ghtf:purpose "Add/remove a user in the org (sends invite)" ;
    ghtf:requiredArg "username" .

ghtf:CatOrganizationBlock a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_block" ; ghtf:scope "organization" ;
    ghtf:purpose "Block a user at org level" ;
    ghtf:requiredArg "username" .

ghtf:CatOrganizationCustomProperties a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_custom_properties" ; ghtf:scope "organization" ;
    ghtf:purpose "Define org custom properties" ;
    ghtf:requiredArg "property_name", "property_type" .

ghtf:CatOrganizationCustomRole a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_custom_role" ; ghtf:scope "organization" ;
    ghtf:purpose "Custom repo role (deprecated)" ;
    ghtf:requiredArg "name", "base_role", "permissions" ;
    ghtf:deprecated true ;
    ghtf:successor "github_organization_repository_role" .

ghtf:CatOrganizationProject a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_project" ; ghtf:scope "organization" ;
    ghtf:purpose "Org-level classic project — GitHub removed the classic Projects API" ;
    ghtf:requiredArg "name" ;
    ghtf:deprecated true ; ghtf:deadApi true .

ghtf:CatOrganizationRepositoryRole a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_repository_role" ; ghtf:scope "organization" ;
    ghtf:purpose "Custom repository role for the org" ;
    ghtf:requiredArg "name", "base_role", "permissions" .

ghtf:CatOrganizationRole a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_role" ; ghtf:scope "organization" ;
    ghtf:purpose "Custom org role" ;
    ghtf:requiredArg "name", "permissions" .

ghtf:CatOrganizationRoleTeam a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_role_team" ; ghtf:scope "organization" ;
    ghtf:purpose "Assign an org role to a team" ;
    ghtf:requiredArg "role_id", "team_slug" .

ghtf:CatOrganizationRoleTeamAssignment a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_role_team_assignment" ; ghtf:scope "organization" ;
    ghtf:purpose "Team-to-org-role association (deprecated)" ;
    ghtf:requiredArg "team_slug", "role_id" ;
    ghtf:deprecated true ;
    ghtf:successor "github_organization_role_team" .

ghtf:CatOrganizationRoleUser a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_role_user" ; ghtf:scope "organization" ;
    ghtf:purpose "Assign an org role to a user" ;
    ghtf:requiredArg "role_id", "login" .

ghtf:CatOrganizationRuleset a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_ruleset" ; ghtf:scope "organization" ;
    ghtf:purpose "Org-wide ruleset (branch/tag/push rules)" ;
    ghtf:requiredArg "name", "enforcement", "target", "rules" .

ghtf:CatOrganizationSecurityManager a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_security_manager" ; ghtf:scope "organization" ;
    ghtf:purpose "Grant a team security-manager role (deprecated)" ;
    ghtf:requiredArg "team_slug" ;
    ghtf:deprecated true ;
    ghtf:successor "github_organization_role_team" .

ghtf:CatOrganizationSettings a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_settings" ; ghtf:scope "organization" ;
    ghtf:purpose "Manage org-wide settings" ;
    ghtf:requiredArg "billing_email" .

ghtf:CatOrganizationWebhook a ghtf:TerraformResource ;
    ghtf:resourceType "github_organization_webhook" ; ghtf:scope "organization" ;
    ghtf:purpose "Org-level webhook" ;
    ghtf:requiredArg "events", "configuration" .

ghtf:CatProjectCard a ghtf:TerraformResource ;
    ghtf:resourceType "github_project_card" ; ghtf:scope "organization" ;
    ghtf:purpose "Card in a classic project — GitHub removed the classic Projects API" ;
    ghtf:requiredArg "column_id" ;
    ghtf:deprecated true ; ghtf:deadApi true .

ghtf:CatProjectColumn a ghtf:TerraformResource ;
    ghtf:resourceType "github_project_column" ; ghtf:scope "organization" ;
    ghtf:purpose "Column in a classic project — GitHub removed the classic Projects API" ;
    ghtf:requiredArg "project_id", "name" ;
    ghtf:deprecated true ; ghtf:deadApi true .

ghtf:CatRelease a ghtf:TerraformResource ;
    ghtf:resourceType "github_release" ; ghtf:scope "repository" ;
    ghtf:purpose "Manage a GitHub release/tag" ;
    ghtf:requiredArg "repository", "tag_name" ;
    ghtf:testConfigMinimal """resource "github_release" "test" {
  repository = "{{ test_repo }}"
  tag_name   = "v1.0.0"
}
""" .

# --- repository family (remaining, beyond the seeded 13) ---
ghtf:CatRepositoryAutolinkReference a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_autolink_reference" ; ghtf:scope "repository" ;
    ghtf:purpose "Autolink references (e.g. JIRA-123 to URL) for a repo" ;
    ghtf:requiredArg "repository", "key_prefix", "target_url_template" .

ghtf:CatRepositoryCollaborators a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_collaborators" ; ghtf:scope "repository" ;
    ghtf:purpose "Authoritatively manage the complete set of user+team collaborators (conflicts with github_repository_collaborator)" ;
    ghtf:requiredArg "repository" .

ghtf:CatRepositoryCustomProperty a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_custom_property" ; ghtf:scope "repository" ;
    ghtf:purpose "Set an org-defined custom property value on a repo" ;
    ghtf:requiredArg "repository", "property_name", "property_type", "property_value" .

ghtf:CatRepositoryDependabotSecurityUpdates a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_dependabot_security_updates" ; ghtf:scope "repository" ;
    ghtf:purpose "Toggle Dependabot automated security fixes for a repo" ;
    ghtf:requiredArg "repository", "enabled" .

ghtf:CatRepositoryDeployKey a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_deploy_key" ; ghtf:scope "repository" ;
    ghtf:purpose "Add/remove an SSH deploy key on a repo (all args ForceNew)" ;
    ghtf:requiredArg "key", "read_only", "repository", "title" ;
    ghtf:refAttr "name" .

ghtf:CatRepositoryDeploymentBranchPolicy a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_deployment_branch_policy" ; ghtf:scope "repository" ;
    ghtf:purpose "Branch-name policy controlling which branches deploy to an env" ;
    ghtf:requiredArg "repository", "environment_name", "name" .

ghtf:CatRepositoryEnvironmentDeploymentPolicy a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_environment_deployment_policy" ; ghtf:scope "repository" ;
    ghtf:purpose "Environment deployment branch policy (branch_pattern or tag_pattern)" ;
    ghtf:requiredArg "environment", "repository" .

ghtf:CatRepositoryPages a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_pages" ; ghtf:scope "repository" ;
    ghtf:purpose "Manage GitHub Pages config for a repo (successor to the deprecated inline pages block)" ;
    ghtf:requiredArg "repository" .

ghtf:CatRepositoryProject a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_project" ; ghtf:scope "repository" ;
    ghtf:purpose "Classic repo-level project board" ;
    ghtf:requiredArg "name", "repository" ;
    ghtf:deprecated true ; ghtf:deadApi true .

ghtf:CatRepositoryPullRequest a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_pull_request" ; ghtf:scope "repository" ;
    ghtf:purpose "Manage/read a single PR" ;
    ghtf:requiredArg "base_repository", "base_ref", "head_ref" .

ghtf:CatRepositoryTopics a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_topics" ; ghtf:scope "repository" ;
    ghtf:purpose "Manage the topics list on a repo (mutually exclusive with github_repository.topics)" ;
    ghtf:requiredArg "repository", "topics" .

ghtf:CatRepositoryVulnerabilityAlerts a ghtf:TerraformResource ;
    ghtf:resourceType "github_repository_vulnerability_alerts" ; ghtf:scope "repository" ;
    ghtf:purpose "Toggle Dependabot vulnerability alerts for a repo" ;
    ghtf:requiredArg "repository" .

# --- team family (remaining) ---
ghtf:CatTeamMembers a ghtf:TerraformResource ;
    ghtf:resourceType "github_team_members" ; ghtf:scope "organization" ;
    ghtf:purpose "Authoritatively manage a team's full member set (conflicts with github_team_membership)" ;
    ghtf:requiredArg "team_id" .

ghtf:CatTeamMembership a ghtf:TerraformResource ;
    ghtf:resourceType "github_team_membership" ; ghtf:scope "organization" ;
    ghtf:purpose "Manage one user's membership in a team" ;
    ghtf:requiredArg "team_id", "username" .

ghtf:CatTeamRepository a ghtf:TerraformResource ;
    ghtf:resourceType "github_team_repository" ; ghtf:scope "organization" ;
    ghtf:purpose "Associate a team with a repo (grant access)" ;
    ghtf:requiredArg "team_id", "repository" ;
    ghtf:refAttr "id" ;
    ghtf:testConfigMinimal """resource "github_team" "test" {
  name        = "{{ test_prefix }}team"
  description = "test"
}

resource "github_repository" "test" {
  name = "{{ test_repo }}"
}

resource "github_team_repository" "test" {
  team_id    = github_team.test.id
  repository = github_repository.test.name
  permission = "pull"
}
""" .

ghtf:CatTeamSettings a ghtf:TerraformResource ;
    ghtf:resourceType "github_team_settings" ; ghtf:scope "organization" ;
    ghtf:purpose "Team settings (review request delegation)" ;
    ghtf:requiredArg "team_id" .

ghtf:CatTeamSyncGroupMapping a ghtf:TerraformResource ;
    ghtf:resourceType "github_team_sync_group_mapping" ; ghtf:scope "organization" ;
    ghtf:purpose "Map a team to IdP group(s) for SCIM/SSO sync" ;
    ghtf:requiredArg "team_slug", "group" .

# --- user family ---
ghtf:CatUserGpgKey a ghtf:TerraformResource ;
    ghtf:resourceType "github_user_gpg_key" ; ghtf:scope "user" ;
    ghtf:purpose "Add a GPG key to the authenticated user" ;
    ghtf:requiredArg "armored_public_key" .

ghtf:CatUserInvitationAccepter a ghtf:TerraformResource ;
    ghtf:resourceType "github_user_invitation_accepter" ; ghtf:scope "user" ;
    ghtf:purpose "Accept a repo collaborator invitation" ;
    ghtf:requiredArg "invitation_id" .

ghtf:CatUserSshKey a ghtf:TerraformResource ;
    ghtf:resourceType "github_user_ssh_key" ; ghtf:scope "user" ;
    ghtf:purpose "Add an SSH key to the authenticated user" ;
    ghtf:requiredArg "title", "key" .

