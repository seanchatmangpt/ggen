---
to: scripts/gh/accept-import.sh
sparql:
  labels: |
    PREFIX ghtf: <http://seanchatmangpt.github.io/packs/gh-terraform#>
    SELECT ?addr ?name WHERE {
      ?s a ghtf:RepoManagementInstance ; ghtf:family "labels" ;
         ghtf:tfAddress ?addr ; ghtf:labelName ?name .
    } ORDER BY ?addr
  branchProtection: |
    PREFIX ghtf: <http://seanchatmangpt.github.io/packs/gh-terraform#>
    SELECT ?addr WHERE {
      ghtf:MainBranchProtection ghtf:tfAddress ?addr .
    }
---
#!/usr/bin/env bash
set -euo pipefail
# GENERATED by `ggen sync` from packs/gh-terraform-pack/ontology.ttl.
# Import-convergence (第二十四章): import every remotely-existing managed
# resource into the current terraform state so apply CONVERGES instead of
# colliding with pre-existing resources. Label list is projected from the
# ontology's desired-state individuals — not hand-maintained.
# Usage: accept-import.sh --dir <tf-dir> --owner <owner> --repo <name>
dir="" ; owner="" ; repo=""
while [ $# -gt 0 ]; do
  case "$1" in
    --dir) dir="$2"; shift 2 ;;
    --owner) owner="$2"; shift 2 ;;
    --repo) repo="$2"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 2 ;;
  esac
done
[ -n "$dir" ] && [ -n "$owner" ] && [ -n "$repo" ] || { echo "usage: accept-import.sh --dir <tf-dir> --owner <owner> --repo <name>" >&2; exit 2; }
if [ ! -d "${dir}/.terraform" ]; then
  (cd "$dir" && terraform init -backend=false -input=false)
fi
tfvars=("-var=github_owner=${owner}" "-var=repository=${repo}" "-var=ggen_signing_key_value=import-placeholder")
import_if_exists() {
  probe_path="$1" ; addr="$2" ; import_id="$3"
  if gh api "$probe_path" >/dev/null 2>&1; then
    (cd "$dir" && terraform import -input=false "${tfvars[@]}" "$addr" "$import_id") \
      || { echo "import failed: $addr" >&2; exit 1; }
  else
    echo "absent remotely, apply will create: $addr"
  fi
}
import_if_exists "repos/${owner}/${repo}" "github_repository.managed" "${repo}"
import_if_exists "repos/${owner}/${repo}/branches/main/protection" "{{ branchProtection[0].addr }}" "${repo}:main"
{% for row in labels %}import_if_exists "repos/${owner}/${repo}/labels/{{ row.name }}" "{{ row.addr }}" "${repo}:{{ row.name }}"
{% endfor %}
