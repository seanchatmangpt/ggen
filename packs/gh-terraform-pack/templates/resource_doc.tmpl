---
to: "docs/gh-terraform/resources/{{ type }}.md"
sparql:
  rows: |
    PREFIX ghtf: <http://seanchatmangpt.github.io/packs/gh-terraform#>
    SELECT ?type ?scope ?purpose
           (GROUP_CONCAT(?arg; separator=", ") AS ?args)
           (SAMPLE(?dep) AS ?deprecated) (SAMPLE(?succ) AS ?successor) (SAMPLE(?dead) AS ?deadapi)
           (SAMPLE(?ref) AS ?refattr) (SAMPLE(?body) AS ?example)
    WHERE {
      ?s a ghtf:TerraformResource ; ghtf:resourceType ?type ; ghtf:scope ?scope ; ghtf:purpose ?purpose .
      OPTIONAL { ?s ghtf:requiredArg ?arg }
      OPTIONAL { ?s ghtf:deprecated ?dep }
      OPTIONAL { ?s ghtf:successor ?succ }
      OPTIONAL { ?s ghtf:deadApi ?dead }
      OPTIONAL { ?s ghtf:refAttr ?ref }
      OPTIONAL { ?s ghtf:hclBody ?body }
    }
    GROUP BY ?type ?scope ?purpose
    ORDER BY ?type
---
