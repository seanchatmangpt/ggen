# MESSAGE: every ghtf:TerraformResource must have a non-empty ghtf:resourceType, a ghtf:scope,
# and >=1 ghtf:requiredArg (catalog-only individuals intentionally carry NO hclBody — see the
# catalog section comment in ontology.ttl); every individual with ghtf:deprecated true must have
# a ghtf:successor OR ghtf:deadApi true; every ghtf:RepoManagementInstance must have a non-empty
# ghtf:hclBody and a ghtf:family; every ghcli:Command must have a non-empty ghcli:scriptBody and
# a ghcli:scriptName; every ghtf:DataSource must have ghtf:dsName, ghtf:scope, and ghtf:purpose;
# every ghtf:L5Condition must have ghtf:standing and ghtf:evidence. Any row = a subject missing
# its required property (for the deprecated branch: missing ghtf:successor while not carrying
# ghtf:deadApi true).
PREFIX ghtf:  <http://seanchatmangpt.github.io/packs/gh-terraform#>
PREFIX ghcli: <http://seanchatmangpt.github.io/packs/gh-terraform#cli->
SELECT ?s ?missing WHERE {
  {
    ?s a ghtf:TerraformResource . BIND(ghtf:resourceType AS ?missing)
  } UNION {
    ?s a ghtf:TerraformResource . BIND(ghtf:scope AS ?missing)
  } UNION {
    ?s a ghtf:TerraformResource . BIND(ghtf:requiredArg AS ?missing)
  } UNION {
    ?s ghtf:deprecated true . BIND(ghtf:successor AS ?missing)
    FILTER NOT EXISTS { ?s ghtf:deadApi true }
  } UNION {
    ?s a ghtf:RepoManagementInstance . BIND(ghtf:hclBody AS ?missing)
  } UNION {
    ?s a ghtf:RepoManagementInstance . BIND(ghtf:family AS ?missing)
  } UNION {
    ?s a ghcli:Command . BIND(ghcli:scriptBody AS ?missing)
  } UNION {
    ?s a ghcli:Command . BIND(ghcli:scriptName AS ?missing)
  } UNION {
    ?s a ghtf:DataSource . BIND(ghtf:dsName AS ?missing)
  } UNION {
    ?s a ghtf:DataSource . BIND(ghtf:scope AS ?missing)
  } UNION {
    ?s a ghtf:DataSource . BIND(ghtf:purpose AS ?missing)
  } UNION {
    ?s a ghtf:L5Condition . BIND(ghtf:standing AS ?missing)
  } UNION {
    ?s a ghtf:L5Condition . BIND(ghtf:evidence AS ?missing)
  }
  FILTER NOT EXISTS { ?s ?missing ?any }
}
ORDER BY ?s ?missing