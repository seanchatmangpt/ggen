# shapes.ttl -- SHACL shapes for a self-monitoring-pack turn log, mirroring
# packs/dogfood-lifecycle-pack/shapes.ttl's own structure exactly (a
# TurnShape targeting smon:Turn, requiring a session ref, a grounding topic,
# an ordering ordinal, and a closed-vocabulary classification -- a node
# missing any required property is a violation) plus a companion
# EscalationObligationShape for the derived-fact node hook.ttl produces.
#
# Closed enumerations are expressed with sh:in against the resource
# individuals themselves (self-contained: it does not depend on the value
# node's rdf:type being co-loaded), matching
# packs/dogfood-lifecycle-pack/shapes.ttl's dfl:outcome sh:in convention. The
# smon:turnKind sh:in list MUST be kept in step with ontology.ttl's
# smon:TurnKindScheme.

@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix smon:    <http://seanchatmangpt.github.io/packs/self-monitoring#> .
@prefix dfl:     <http://seanchatmangpt.github.io/packs/dogfood-lifecycle#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# Every turn node must carry a session ref, a grounding topic, an ordering
# ordinal, and a closed-vocabulary turn kind. smon:immediatelyFollows is
# intentionally NOT required here (sh:minCount 0, the SHACL default) -- most
# turns in a real session have no meaningful "immediately follows a
# GroundingQuestion" fact to assert; only survey/run/blocker responses that
# directly follow a grounding question need it, and hook.ttl's WHERE clause
# only reads it where present.
smon:TurnShape
    a sh:NodeShape ;
    sh:targetClass smon:Turn ;

    # session ref -- reuses dfl:Session (packs/dogfood-lifecycle-pack), not a
    # re-minted smon:Session; see ontology.ttl's header for the rationale.
    sh:property [
        sh:path        dcterms:isPartOf ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:class       dfl:Session ;
        sh:message     "A turn must reference its session via dcterms:isPartOf, typed dfl:Session." ;
    ] ;

    # grounding topic -- the task brief's "grounding_topic"; free-text or IRI
    # tag, so no sh:datatype/sh:nodeKind restriction, just presence.
    sh:property [
        sh:path        dcterms:subject ;
        sh:minCount    1 ;
        sh:message     "A turn must carry a grounding topic via dcterms:subject (free text or an IRI tag naming which system/capability the turn concerns)." ;
    ] ;

    # ordering -- monotonic per-session ordinal.
    sh:property [
        sh:path        smon:sequenceIndex ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:datatype    xsd:integer ;
        sh:message     "A turn must carry exactly one smon:sequenceIndex (xsd:integer)." ;
    ] ;

    # turn kind -- required, closed to the 5-concept scheme by resource identity.
    sh:property [
        sh:path        smon:turnKind ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:in          ( smon:GroundingQuestion smon:SurveyResponse smon:RunResponse smon:BlockerResponse smon:Other ) ;
        sh:message     "A turn must carry exactly one smon:turnKind from the closed 5-concept scheme." ;
    ] .

# The derived-fact node hook.ttl's CONSTRUCT query produces. Not a fixture
# input (see ontology.ttl's CLASSIFICATION-IS-INPUT FENCE) -- this shape
# exists to validate hook.ttl's OWN output, should a caller choose to run
# `ggen graph validate` over a post-materialize() dump.
smon:EscalationObligationShape
    a sh:NodeShape ;
    sh:targetClass smon:EscalationObligation ;

    sh:property [
        sh:path        smon:hasPriorGroundingQuestion ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:class       smon:Turn ;
        sh:message     "An EscalationObligation must link exactly one prior GroundingQuestion turn via smon:hasPriorGroundingQuestion." ;
    ] ;
    sh:property [
        sh:path        smon:hasGroundingQuestion ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:class       smon:Turn ;
        sh:message     "An EscalationObligation must link exactly one repeat GroundingQuestion turn via smon:hasGroundingQuestion." ;
    ] ;
    sh:property [
        sh:path        smon:reason ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:datatype    xsd:string ;
        sh:message     "An EscalationObligation must carry exactly one smon:reason (xsd:string)." ;
    ] ;
    # L5-push: parameterized fields (Derivation power) -- required so every
    # EscalationObligation this pack's hooks ever produce carries a real,
    # planner-usable severity/deadline pair, not just the two turn links.
    sh:property [
        sh:path        smon:severity ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:in          ( smon:Low smon:Medium smon:High ) ;
        sh:message     "An EscalationObligation must carry exactly one smon:severity from the closed 3-concept scheme." ;
    ] ;
    sh:property [
        sh:path        smon:deadlineHint ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:in          ( smon:ActNow smon:NextSession ) ;
        sh:message     "An EscalationObligation must carry exactly one smon:deadlineHint from the closed 2-concept scheme." ;
    ] ;
    # L5-push: lifecycle (Obligation lifecycle) -- status is always required;
    # dischargedAt/refusalReason are required ONLY once status leaves Open.
    sh:property [
        sh:path        smon:status ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:in          ( smon:Open smon:Discharged smon:Refused ) ;
        sh:message     "An EscalationObligation must carry exactly one smon:status from the closed 3-concept lifecycle scheme." ;
    ] ;
    # NOTE ON ENGINE BOUNDARY (confirmed this pass, not assumed): an earlier
    # draft of this shape expressed "if status=Discharged then dischargedAt
    # required" as two sh:sparql SPARQLConstraint nodes. Direct testing
    # against a real fixture (a Discharged obligation deliberately missing
    # smon:dischargedAt) showed shapes_conform: true -- a SILENT NO-OP, not a
    # working conditional check. Reading
    # crates/praxis-graphlaw/src/shacl/sparql.rs::check_sparql_boundary
    # confirmed why: `SHACL_SPARQL_BOUNDARY` in
    # crates/praxis-graphlaw/src/shacl/model.rs is hardcoded "CORE_ONLY",
    # which rejects EVERY sh:sparql constraint at load time by design (a
    # deliberate SHACL-Core-only dialect boundary, not a bug) -- an
    # engine-level fact this pack cannot change (crates/praxis-graphlaw is
    # shared infrastructure, off-limits to this pack-level pass). Replaced
    # below with the equivalent expressed in pure SHACL Core (sh:or + sh:not
    # + sh:hasValue), which the same direct testing confirms DOES enforce
    # (see the pack's verification commands) -- implication "if P then Q" as
    # the standard Core encoding "(NOT P) OR Q".
    sh:or (
        [ sh:not [ sh:property [ sh:path smon:status ; sh:hasValue smon:Discharged ] ] ]
        [ sh:property [ sh:path smon:dischargedAt ; sh:minCount 1 ; sh:datatype xsd:dateTime ] ]
    ) ;
    sh:or (
        [ sh:not [ sh:property [ sh:path smon:status ; sh:hasValue smon:Refused ] ] ]
        [ sh:property [ sh:path smon:refusalReason ; sh:minCount 1 ; sh:datatype xsd:string ] ]
    ) .

# L5-push: catch-all governance-coverage detector's own shape, so its output
# is validatable exactly like smon:EscalationObligation's.
smon:UngovernedTransitionShape
    a sh:NodeShape ;
    sh:targetClass smon:UngovernedTransition ;

    sh:property [
        sh:path        smon:hasUngovernedQuestion ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:class       smon:Turn ;
        sh:message     "An UngovernedTransition must link exactly one GroundingQuestion turn via smon:hasUngovernedQuestion." ;
    ] ;
    sh:property [
        sh:path        smon:hasUngovernedResponse ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:class       smon:Turn ;
        sh:message     "An UngovernedTransition must link exactly one smon:Other-classified response turn via smon:hasUngovernedResponse." ;
    ] .
