# CQ3.2 (COMPETENCY_QUESTIONS.md concept 3): "Which due-diligence items were
# waived rather than satisfied?"
#
# Added in the 2026-07-18 L5-push Round 3 pass. Verified live against
# fixtures/case.ttl (1 row: environmental-phase-2-survey) via the scratch
# consumer at /private/tmp/claude-501/-Users-sac-ggen/70ac08c7-8655-49c4-baa2-018bc441bb4c/
# scratchpad/l5-round3-ma-case-study-pack/. fixtures/case-2.ttl asserts zero
# Waived items (its 2 DDIs are Satisfied/Open) -- confirmed 0 rows there too,
# a real negative check, not an untested assumption.

PREFIX ma: <http://seanchatmangpt.github.io/packs/ma-case-study#>

SELECT ?item WHERE {
  ?item a ma:DueDiligenceItem ;
        ma:dueDiligenceDisposition ma:Waived .
}
