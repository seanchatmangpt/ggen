# CQ9.1 (COMPETENCY_QUESTIONS.md concept 9): "Is the acquisition's financing
# commitment subject to a financing-out condition, and what is that
# condition?"
#
# Added in the 2026-07-18 L5-push Round 3 pass. Verified live against
# fixtures/case.ttl (1 row: debt-commitment-firstcap-partners ->
# condition-no-material-adverse-change) and fixtures/case-2.ttl (1 row:
# debt-commitment-crescent-lending -> condition-shareholder-approval) via
# the scratch consumer at /private/tmp/claude-501/-Users-sac-ggen/
# 70ac08c7-8655-49c4-baa2-018bc441bb4c/scratchpad/l5-round3-ma-case-study-pack/.

PREFIX ma: <http://seanchatmangpt.github.io/packs/ma-case-study#>

SELECT ?commitment ?condition WHERE {
  ?commitment a ma:FinancingCommitment ;
              ma:subjectToCondition ?condition .
}
