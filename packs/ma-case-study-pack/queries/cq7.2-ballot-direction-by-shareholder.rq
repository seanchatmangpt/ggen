# CQ7.2 (COMPETENCY_QUESTIONS.md concept 7): "How did a specific voting
# shareholder cast their ballot?"
#
# General form: every shareholder paired with their cast ballot direction (a
# specific-shareholder answer is a FILTER/binding on ?shareholder away).
# Added in the 2026-07-18 L5-push Round 3 pass. Verified live against
# fixtures/case.ttl (3 rows: alpha->For, beta->For, gamma->Against) and
# fixtures/case-2.ttl (2 rows: delta->Against, epsilon->For) via the scratch
# consumer at /private/tmp/claude-501/-Users-sac-ggen/
# 70ac08c7-8655-49c4-baa2-018bc441bb4c/scratchpad/l5-round3-ma-case-study-pack/.

PREFIX ma: <http://seanchatmangpt.github.io/packs/ma-case-study#>
PREFIX prov: <http://www.w3.org/ns/prov#>

SELECT ?shareholder ?direction WHERE {
  ?ballot a ma:Ballot ;
          prov:wasAttributedTo ?shareholder ;
          ma:ballotDirection ?direction .
}
