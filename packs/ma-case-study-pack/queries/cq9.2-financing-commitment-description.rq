# CQ9.2 (COMPETENCY_QUESTIONS.md concept 9): "What does the lender's
# commitment promise, in general contractual terms?"
#
# Added in the 2026-07-18 L5-push Round 3 pass. Verified live against
# fixtures/case.ttl (1 row: debt-commitment-firstcap-partners ->
# "FirstCap Partners debt-commitment letter for USD 400,000,000 of
# acquisition financing.") and fixtures/case-2.ttl (1 row:
# debt-commitment-crescent-lending -> "Crescent Lending Partners...") via
# the scratch consumer at /private/tmp/claude-501/-Users-sac-ggen/
# 70ac08c7-8655-49c4-baa2-018bc441bb4c/scratchpad/l5-round3-ma-case-study-pack/.

PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX ma: <http://seanchatmangpt.github.io/packs/ma-case-study#>

SELECT ?commitment ?description WHERE {
  ?commitment a ma:FinancingCommitment ;
              dcterms:description ?description .
}
