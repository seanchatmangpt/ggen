# CQ7.3 (COMPETENCY_QUESTIONS.md concept 7): "What fraction of cast ballots
# were For vs. Against vs. Abstain for a given vote?" -- this query answers
# the count half (fraction = count / total, computable by the consumer from
# these rows); grouped per vote so multiple votes in one graph don't collide.
#
# Added in the 2026-07-18 L5-push Round 3 pass. Verified live against
# fixtures/case.ttl (vote target-shareholder-vote-2026-05-15: For=2,
# Against=1) and fixtures/case-2.ttl (vote
# target-shareholder-vote-2026-06-28: For=1, Against=1) via the scratch
# consumer at /private/tmp/claude-501/-Users-sac-ggen/
# 70ac08c7-8655-49c4-baa2-018bc441bb4c/scratchpad/l5-round3-ma-case-study-pack/.

PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX ma: <http://seanchatmangpt.github.io/packs/ma-case-study#>

SELECT ?vote ?direction (COUNT(?ballot) AS ?count) WHERE {
  ?ballot a ma:Ballot ;
          dcterms:isPartOf ?vote ;
          ma:ballotDirection ?direction .
}
GROUP BY ?vote ?direction
