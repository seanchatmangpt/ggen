# shapes.ttl — SHACL shapes for packs/ma-case-study-pack/ontology.ttl.
#
# VERIFIER NOTE (mirrors packs/dogfood-lifecycle-pack/shapes.ttl's own
# disclosure): at the version of `ggen graph validate --files` available
# this session, that command performs Turtle PARSE validation, not SHACL
# constraint evaluation. What is verified today is that this file PARSES
# as valid Turtle/SHACL syntax over a real, non-vacuous target+constraint
# set (not a placeholder like the crown-local-cli fixtures' VACUOUS_SHAPES).
# The constraints below are authored to bite once a SHACL evaluation layer
# is wired to this pack (praxis_graphlaw::shacl::ShapesGraph, the engine
# the bribery-case fixture's own shapes.ttl is proven against).
#
# CLOSED-SHAPE DISCIPLINE: sh:closed true + sh:ignoredProperties (rdf:type)
# is applied ONLY to node shapes targeting this pack's OWN minted ma:
# classes, where this pack fully controls (and fully knows) the property
# set -- exactly the packs/soc2-audit-pack / packs/dogfood-lifecycle-pack
# precedent. It is deliberately NOT applied to node shapes targeting reused
# FIBO/OMG-Commons classes (fibo-be-le-lei:LEIRegisteredEntity,
# fibo-fnd-agr-ctr:Representation, etc.): those are large, externally
# maintained ontologies with property sets far broader than this case
# study's own usage, and a sh:closed shape there would wrongly reject
# legitimate FIBO/Commons properties this pack simply doesn't happen to
# use. Those shapes instead assert only sh:minCount/sh:datatype/sh:class
# requirements on the specific properties this case study actually needs
# -- an open floor, not a closed ceiling, same distinction
# packs/soc2-audit-pack/templates/soc2-shapes.ttl.tmpl draws for its own
# org:Organization shape (dcterms:subject optional there for the same
# externally-shared-vocabulary reason).

@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl:    <http://www.w3.org/ns/odrl/2/> .
@prefix cmns-bauth: <https://www.omg.org/spec/Commons/BusinessAuthorizations/> .
@prefix fibo-be-le-lei: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LEIEntities/> .
@prefix fibo-fnd-agr-ctr: <https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/> .
@prefix fibo-fnd-agr-agr: <https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Agreements/> .
@prefix fibo-cae-ce-act: <https://spec.edmcouncil.org/fibo/ontology/CAE/CorporateEvents/CorporateActions/> .
@prefix ma:      <http://seanchatmangpt.github.io/packs/ma-case-study#> .

# ============================================================================
# OPEN shapes over REUSED public classes (concepts 1, 2, 4-half, 5-half,
# 6-half, 8-half, 9-half, 10-half) — minimum requirements only, not closed.
# ============================================================================

# Concept 1: an LEI-registered legal entity must carry at least one LEI.
#
# GAP CLOSED (2026-07-19, L5-push pass): the shape as originally authored
# checked `sh:inversePath fibo-be-le-lei:isQuantifiedBy` with `sh:minCount 0`
# -- both the WRONG property (fixtures actually link via `cmns-id:
# isIdentifiedBy`, never `isQuantifiedBy`) and a vacuous cardinality (`0`
# means "no requirement", so nothing could ever fail this shape). This was
# the exact disclosed adversarial-resistance gap named in
# `adversarial-negative.ttl`'s header item 3 and in
# `docs/packs/L5_VALIDATION_REPORT.md`'s ma-case-study-pack section
# ("the pack's own disclosed LEI-shape gap means at least one
# deliberately-gamed input is NOT refused today"). Fixed by requiring
# `cmns-id:isIdentifiedBy` (the property every LEI-bearing fixture in this
# pack actually uses) with a real `sh:minCount 1`. Verified this session:
# `adversarial-negative.ttl` (whose target counterparty deliberately omits
# this property, per that file's own header item 3) now fails SHACL
# validation on this shape too, in addition to its other 2 disclosed
# violations -- confirmed via `ggen graph validate` producing 3 violations
# instead of 2 (see this pack's STANDING.md changelog entry).
@prefix cmns-id: <https://www.omg.org/spec/Commons/Identifiers/> .

ma:LEIRegisteredEntityShape
    a sh:NodeShape ;
    sh:targetClass fibo-be-le-lei:LEIRegisteredEntity ;
    sh:property [
        sh:path     cmns-id:isIdentifiedBy ;
        sh:minCount 1 ;
        sh:class    fibo-be-le-lei:LegalEntityIdentifier ;
        sh:message  "An LEI-registered entity must carry at least one cmns-id:isIdentifiedBy link to a fibo-be-le-lei:LegalEntityIdentifier." ;
    ] ;
    sh:property [
        sh:path     fibo-be-le-lei:hasLegalFormAbbreviation ;
        sh:minCount 0 ;
    ] .

# Concept 2: a relationship record must carry exactly one ownership
# percentage in [0, 100].
ma:RelationshipRecordShape
    a sh:NodeShape ;
    sh:targetClass fibo-be-le-lei:RelationshipRecord ;
    sh:property [
        sh:path        fibo-be-le-lei:hasOwnershipPercentage ;
        sh:minCount    1 ;
        sh:maxCount    1 ;
        sh:datatype    xsd:decimal ;
        sh:minInclusive 0 ;
        sh:maxInclusive 100 ;
        sh:message     "A relationship record must carry exactly one hasOwnershipPercentage in [0, 100]." ;
    ] .

# Concept 4: a Representation or Warranty must carry a description
# (reused as rdfs:comment is a TBox-level annotation, not asserted per
# instance -- dcterms:description is the instance-level requirement).
ma:RepresentationShape
    a sh:NodeShape ;
    sh:targetClass fibo-fnd-agr-ctr:Representation ;
    sh:property [
        sh:path     dcterms:description ;
        sh:minCount 1 ;
        sh:message  "A representation must carry a dcterms:description of the fact represented." ;
    ] .

ma:WarrantyShape
    a sh:NodeShape ;
    sh:targetClass fibo-fnd-agr-ctr:Warranty ;
    sh:property [
        sh:path     dcterms:description ;
        sh:minCount 1 ;
        sh:message  "A warranty must carry a dcterms:description of the fact warranted." ;
    ] .

# Concept 6 (reused half): a cmns-bauth:Authorization must record both
# an authorizing and an authorized party.
ma:AuthorizationShape
    a sh:NodeShape ;
    sh:targetClass cmns-bauth:Authorization ;
    sh:property [
        sh:path     cmns-bauth:hasAuthorizingParty ;
        sh:minCount 1 ;
        sh:message  "An authorization must record its authorizing party (cmns-bauth:hasAuthorizingParty)." ;
    ] ;
    sh:property [
        sh:path     cmns-bauth:hasAuthorizedParty ;
        sh:minCount 1 ;
        sh:message  "An authorization must record its authorized party (cmns-bauth:hasAuthorizedParty)." ;
    ] .

# Concept 9 (reused half): a Commitment must carry a description of what
# is promised.
ma:CommitmentShape
    a sh:NodeShape ;
    sh:targetClass fibo-fnd-agr-agr:Commitment ;
    sh:property [
        sh:path     dcterms:description ;
        sh:minCount 1 ;
        sh:message  "A commitment must carry a dcterms:description of what is promised." ;
    ] .

# Concept 10 (reused half): a merger/acquisition must carry exactly one
# classifying deal status.
ma:MergerAcquisitionShape
    a sh:NodeShape ;
    sh:targetClass fibo-cae-ce-act:MergerAcquisition ;
    sh:property [
        sh:path     <https://www.omg.org/spec/Commons/Classifiers/isClassifiedBy> ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    ma:DealStatus ;
        sh:message  "A merger/acquisition must carry exactly one classifying ma:DealStatus (via cmns-cls:isClassifiedBy)." ;
    ] .

# ============================================================================
# CLOSED shapes over this pack's OWN minted ma: classes.
# ============================================================================

# Concept 3: due-diligence item.
ma:DueDiligenceItemShape
    a sh:NodeShape ;
    sh:targetClass ma:DueDiligenceItem ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type odrl:action odrl:target odrl:assigner odrl:assignee ) ;
    sh:property [
        sh:path     ma:dueDiligenceDisposition ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in       ( ma:Open ma:Satisfied ma:Waived ) ;
        sh:message  "A due-diligence item must carry exactly one ma:dueDiligenceDisposition from {ma:Open, ma:Satisfied, ma:Waived}." ;
    ] .

# Concept 4 (private half): disclosure-schedule item.
ma:DisclosureScheduleItemShape
    a sh:NodeShape ;
    sh:targetClass ma:DisclosureScheduleItem ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [
        sh:path     ma:qualifiesClause ;
        sh:minCount 1 ;
        sh:or ( [ sh:class fibo-fnd-agr-ctr:Representation ] [ sh:class fibo-fnd-agr-ctr:Warranty ] ) ;
        sh:message  "A disclosure-schedule item must qualify at least one Representation or Warranty clause (ma:qualifiesClause)." ;
    ] ;
    sh:property [
        sh:path     ma:scheduleItemNumber ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "A disclosure-schedule item must carry exactly one ma:scheduleItemNumber (xsd:string)." ;
    ] .

# Concept 5 (private half): regulatory filing obligation.
ma:RegulatoryFilingObligationShape
    a sh:NodeShape ;
    sh:targetClass ma:RegulatoryFilingObligation ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type odrl:action odrl:target odrl:assigner odrl:assignee ) ;
    sh:property [
        sh:path     ma:filingThresholdAmount ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:message  "A regulatory filing obligation must carry exactly one ma:filingThresholdAmount (xsd:decimal)." ;
    ] ;
    sh:property [
        sh:path     ma:triggeringStatute ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "A regulatory filing obligation must carry exactly one ma:triggeringStatute (xsd:string)." ;
    ] ;
    sh:property [
        sh:path     ma:statutoryWaitingPeriodDays ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:message  "A regulatory filing obligation must carry exactly one ma:statutoryWaitingPeriodDays (xsd:integer)." ;
    ] .

# Concept 6 (private half): board resolution.
ma:BoardResolutionShape
    a sh:NodeShape ;
    sh:targetClass ma:BoardResolution ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type cmns-bauth:hasAuthorizingParty cmns-bauth:hasAuthorizedParty ) ;
    sh:property [
        sh:path     ma:authorizesTransaction ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    fibo-cae-ce-act:MergerAcquisition ;
        sh:message  "A board resolution must authorize exactly one merger/acquisition (ma:authorizesTransaction)." ;
    ] ;
    sh:property [
        sh:path     prov:generatedAtTime ;
        sh:minCount 1 ;
        sh:message  "A board resolution must record its adoption timestamp (prov:generatedAtTime)." ;
    ] .

# Concept 7 (private): shareholder vote.
ma:ShareholderVoteShape
    a sh:NodeShape ;
    sh:targetClass ma:ShareholderVote ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [
        sh:path     ma:quorumPercentage ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
        sh:maxInclusive 100 ;
        sh:message  "A shareholder vote must carry exactly one ma:quorumPercentage in [0, 100]." ;
    ] ;
    sh:property [
        sh:path     ma:voteOutcome ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in       ( ma:Passed ma:Failed ma:Withdrawn ) ;
        sh:message  "A shareholder vote must carry exactly one ma:voteOutcome from {ma:Passed, ma:Failed, ma:Withdrawn}." ;
    ] .

ma:BallotShape
    a sh:NodeShape ;
    sh:targetClass ma:Ballot ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [
        sh:path     dcterms:isPartOf ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    ma:ShareholderVote ;
        sh:message  "A ballot must be part of exactly one shareholder vote (dcterms:isPartOf)." ;
    ] ;
    sh:property [
        sh:path     prov:wasAttributedTo ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "A ballot must be attributed to exactly one casting shareholder (prov:wasAttributedTo)." ;
    ] ;
    sh:property [
        sh:path     ma:ballotDirection ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in       ( ma:For ma:Against ma:Abstain ) ;
        sh:message  "A ballot must carry exactly one ma:ballotDirection from {ma:For, ma:Against, ma:Abstain}." ;
    ] .

# Concept 8 (private half): deal term line item + counter-offer.
ma:DealTermLineItemShape
    a sh:NodeShape ;
    sh:targetClass ma:DealTermLineItem ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [
        sh:path     ma:termType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in       ( ma:PricePerShare ma:ExchangeRatio ma:Earnout ma:EscrowPercentage ) ;
        sh:message  "A deal term line item must carry exactly one ma:termType from the closed DealTermType scheme." ;
    ] ;
    sh:property [
        sh:path     ma:termValue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:message  "A deal term line item must carry exactly one ma:termValue (xsd:decimal)." ;
    ] .

ma:CounterOfferShape
    a sh:NodeShape ;
    sh:targetClass ma:CounterOffer ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [
        sh:path     ma:supersedes ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class    fibo-fnd-agr-ctr:NonBindingTerm ;
        sh:message  "A counter-offer must supersede exactly one prior offer or counter-offer (ma:supersedes)." ;
    ] ;
    sh:property [
        sh:path     prov:wasAttributedTo ;
        sh:minCount 1 ;
        sh:message  "A counter-offer must be attributed to the party that proposed it (prov:wasAttributedTo)." ;
    ] .

# Concept 9 (private half): financing commitment + financing-out condition.
ma:FinancingCommitmentShape
    a sh:NodeShape ;
    sh:targetClass ma:FinancingCommitment ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type dcterms:description ) ;
    sh:property [
        sh:path     ma:subjectToCondition ;
        sh:minCount 1 ;
        sh:class    ma:FinancingOutCondition ;
        sh:message  "A financing commitment must be subject to at least one financing-out condition (ma:subjectToCondition)." ;
    ] .

# Concept 10 (private half): deal status individuals are covered by
# ma:MergerAcquisitionShape's sh:class ma:DealStatus constraint above; no
# separate NodeShape is needed for the 5 closed individuals themselves
# (they carry no further properties in this vocabulary).
