@prefix tcps_wasm: <http://seanchatmangpt.github.io/packs/tcps-wasm#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

tcps_wasm:LibModuleShape
    a sh:NodeShape ;
    sh:targetClass tcps_wasm:Module ;
    rdfs:comment "Every tcps_wasm:LibModule must carry a non-empty tcps_wasm:sourceText -- refuses an empty/missing lib.rs body." ;
    sh:property [
        sh:path tcps_wasm:sourceText ;
        sh:minCount 1 ;
        sh:minLength 1 ;
        sh:message "tcps_wasm:LibModule must have a non-empty tcps_wasm:sourceText." ;
    ] .

tcps_wasm:CargoManifestShape
    a sh:NodeShape ;
    sh:targetClass tcps_wasm:Manifest ;
    rdfs:comment "Every tcps_wasm:CargoManifest must carry a non-empty tcps_wasm:manifestText -- refuses an empty/missing Cargo.toml body." ;
    sh:property [
        sh:path tcps_wasm:manifestText ;
        sh:minCount 1 ;
        sh:minLength 1 ;
        sh:message "tcps_wasm:CargoManifest must have a non-empty tcps_wasm:manifestText." ;
    ] .
