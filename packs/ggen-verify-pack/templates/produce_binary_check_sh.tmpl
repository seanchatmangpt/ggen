---
to: scripts/produce-binary-check.sh
sparql:
  cfg: |
    PREFIX ver: <http://seanchatmangpt.github.io/packs/ggen-verify#>
    SELECT ?crate ?bin WHERE {
      ?p a ver:Producer ; ver:name "compiled-binary" ;
         ver:binaryCrate ?crate ; ver:binaryName ?bin .
    } ORDER BY ?crate
---
{% raw %}#!/usr/bin/env bash
# GENERATED by `ggen sync` from packs/ggen-verify-pack
# (produce_binary_check_sh.tmpl). Compiled-binary-class producer: a DOUBLE
# COLD BUILD of the ggen binary (two fresh CARGO_TARGET_DIRs, --locked)
# plus sha256 compare -- the proven same-host reproducibility pattern.
# EXPENSIVE by design, so `--skip` emits an explicit skipped marker
# (ver:skipped true) instead: absence (producer never ran) and skip
# (producer ran, chose not to build) stay honestly distinguishable, and
# the compiled_binary class stays Unknown either way.
# Always exits 0 itself; judgment happens at sync.
set -uo pipefail
cd "$(dirname "$0")/.."
mkdir -p evidence/producers
OUT=evidence/producers/binary-check.ttl
{% endraw %}
BIN_CRATE='{{ cfg[0].crate }}'
BIN_NAME='{{ cfg[0].bin }}'
{% raw %}
if [ "${1:-}" = "--skip" ]; then
  {
    echo "# GENERATED by scripts/produce-binary-check.sh --skip -- do not edit."
    echo "@prefix ver: <http://seanchatmangpt.github.io/packs/ggen-verify#> ."
    echo
    echo "ver:binary-check a ver:BinaryCheck ;"
    echo "    ver:skipped true ."
  } > "$OUT"
  echo "produce-binary-check.sh: skipped (explicit Unknown marker) -> $OUT"
  exit 0
fi

sha256_of() {
  if command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | cut -d' ' -f1
  else shasum -a 256 "$1" | cut -d' ' -f1; fi
}

TA="$(mktemp -d)"
TB="$(mktemp -d)"
trap 'rm -rf "$TA" "$TB"' EXIT

cargo build --locked --release -p "$BIN_CRATE" --target-dir "$TA"
cargo build --locked --release -p "$BIN_CRATE" --target-dir "$TB"
HASH_A="$(sha256_of "$TA/release/$BIN_NAME")"
HASH_B="$(sha256_of "$TB/release/$BIN_NAME")"
CODE=0
if [ "$HASH_A" != "$HASH_B" ]; then CODE=1; fi

{
  echo "# GENERATED by scripts/produce-binary-check.sh -- do not edit."
  echo "@prefix ver: <http://seanchatmangpt.github.io/packs/ggen-verify#> ."
  echo
  echo "ver:binary-check a ver:BinaryCheck ;"
  echo "    ver:exitCode $CODE ;"
  echo "    ver:hashA \"$HASH_A\" ;"
  echo "    ver:hashB \"$HASH_B\" ."
} > "$OUT"
echo "produce-binary-check.sh: exit $CODE ($HASH_A vs $HASH_B) -> $OUT"
exit 0
{% endraw %}
