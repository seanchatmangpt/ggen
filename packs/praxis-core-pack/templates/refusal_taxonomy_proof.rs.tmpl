/// `ORDER BY ?scenario` sorts lexically ascending: AuthorizationDenied (A) <
/// ConformanceGateFailed (C) < ResourceExhausted (R) < WatchdogDrained (W).
/// Regression guard against any future non-determinism in the row order --
/// checked independently in both generated artifacts.
#[test]
fn row_order_is_lexical_ascending_by_scenario() {
    let rs_a = RS_CONTENT.find("\"AuthorizationDenied\"").expect("AuthorizationDenied present in .rs");
    let rs_c = RS_CONTENT.find("\"ConformanceGateFailed\"").expect("ConformanceGateFailed present in .rs");
    let rs_r = RS_CONTENT.find("\"ResourceExhausted\"").expect("ResourceExhausted present in .rs");
    let rs_w = RS_CONTENT.find("\"WatchdogDrained\"").expect("WatchdogDrained present in .rs");
    assert!(
        rs_a < rs_c && rs_c < rs_r && rs_r < rs_w,
        "src/praxis_core_refusal_table.rs row order is not \
         AuthorizationDenied < ConformanceGateFailed < ResourceExhausted < WatchdogDrained \
         (offsets: {rs_a}, {rs_c}, {rs_r}, {rs_w})"
    );

    let md_a = MD_CONTENT.find("`AuthorizationDenied`").expect("AuthorizationDenied present in .md");
    let md_c = MD_CONTENT.find("`ConformanceGateFailed`").expect("ConformanceGateFailed present in .md");
    let md_r = MD_CONTENT.find("`ResourceExhausted`").expect("ResourceExhausted present in .md");
    let md_w = MD_CONTENT.find("`WatchdogDrained`").expect("WatchdogDrained present in .md");
    assert!(
        md_a < md_c && md_c < md_r && md_r < md_w,
        "docs/praxis_core_refusal_taxonomy.md row order is not \
         AuthorizationDenied < ConformanceGateFailed < ResourceExhausted < WatchdogDrained \
         (offsets: {md_a}, {md_c}, {md_r}, {md_w})"
    );
}

