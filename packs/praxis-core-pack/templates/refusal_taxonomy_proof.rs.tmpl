    let mut sorted_copy = expected_sorted.clone();
    sorted_copy.sort_unstable();
    assert_eq!(
        expected_sorted, sorted_copy,
        "EXPECTED table itself is not in lexically-ascending scenario order"
    );

    let rs_offsets: Vec<usize> = expected_sorted
        .iter()
        .map(|name| {
            RS_CONTENT
                .find(&format!("\"{name}\""))
                .unwrap_or_else(|| panic!("{name} present in .rs"))
        })
        .collect();
    let mut sorted_rs_offsets = rs_offsets.clone();
    sorted_rs_offsets.sort_unstable();
    assert_eq!(
        rs_offsets, sorted_rs_offsets,
        "src/praxis_core_refusal_table.rs row order is not lexically ascending by scenario name"
    );

    let md_offsets: Vec<usize> = expected_sorted
        .iter()
        .map(|name| {
            MD_CONTENT
