/// Floor sanity check: guards against a silently-broken or silently-empty
/// SPARQL query (e.g. a query engine regression, a typo in the query text
/// that still parses but matches nothing) making every loop-based assertion
/// below vacuously true. If this fails, the failure is in the query itself,
/// not in drift between two artifacts.
#[test]
fn sparql_query_returned_at_least_one_scenario() {
    assert!(
        !LIVE_ONTOLOGY_ROWS.is_empty(),
        "the `scenarios` SPARQL query against ontology.ttl returned zero pxc:RefusalScenario \
         rows -- either the ontology lost every individual or the query itself is broken; \
         every other assertion in this file would otherwise pass vacuously"
    );
}

/// Row-count parity between what the live ontology says right now and what
/// is actually checked into `src/praxis_core_refusal_table.rs`. Uses the
/// same "four leading spaces" discriminator as the sibling hand-transcribed
/// proof to avoid double-counting the one-off struct definition line.
#[test]
fn row_count_matches_generated_table_right_now() {
    let row_count = RS_CONTENT.matches("    RefusalTaxonomyRow {").count();
    assert_eq!(
        row_count,
        LIVE_ONTOLOGY_ROWS.len(),
        "ontology.ttl has {} pxc:RefusalScenario individuals right now, but the checked-in \
         src/praxis_core_refusal_table.rs has {row_count} rows -- the generated const table has \
         drifted behind ontology.ttl (a stale freeze checksum or a partial resync are the two \
         known causes; see this file's module doc)",
        LIVE_ONTOLOGY_ROWS.len()
    );
}

/// The core check: every scenario the live ontology reports right now is
/// still reflected, verbatim, in the artifacts as they actually sit on
/// disk. Failing here means the checked-in generated files no longer match
/// ontology.ttl -- exactly the silent-drift failure mode cap05's obligation
/// text names, and neither the hand-transcribed proof nor a plain `diff`
/// against a stale copy would catch it.
#[test]
fn every_live_scenario_matches_generated_artifacts_right_now() {
    for (scenario, category, lane, _kind, note) in LIVE_ONTOLOGY_ROWS {
        assert_row_md(scenario, category, lane, note);
    }
    for (scenario, category, lane, kind, note) in LIVE_ONTOLOGY_ROWS {
        assert_row_rs(scenario, category, lane, kind, note);
    }
}

/// `ORDER BY ?scenario` in the live query is expected to sort lexically
/// ascending. This is a live regression guard on the query engine's own
/// collation (praxis-graphlaw or oxigraph, whichever backend answered this
/// sync), not a hand-asserted fact about how the array happens to be typed
/// -- if the engine's ORDER BY collation ever changes, this fails on the
/// very next sync instead of silently reordering both generated artifacts
/// in lockstep and having nothing notice.
#[test]
fn live_row_order_is_lexical_ascending_by_scenario() {
    let scenario_names: Vec<&str> = LIVE_ONTOLOGY_ROWS.iter().map(|(s, ..)| *s).collect();
    let mut sorted_names = scenario_names.clone();
    sorted_names.sort_unstable();
    assert_eq!(
        scenario_names, sorted_names,
        "LIVE_ONTOLOGY_ROWS is not in lexically-ascending scenario order -- the query's own \
         `ORDER BY ?scenario` did not produce sorted results this sync"
    );

    let rs_offsets: Vec<usize> = sorted_names
        .iter()
        .map(|name| {
            RS_CONTENT
                .find(&format!("\"{name}\""))
                .unwrap_or_else(|| panic!("{name} present in generated src/praxis_core_refusal_table.rs"))
        })
        .collect();
    let mut sorted_rs_offsets = rs_offsets.clone();
    sorted_rs_offsets.sort_unstable();
    assert_eq!(
        rs_offsets, sorted_rs_offsets,
        "src/praxis_core_refusal_table.rs row order does not match the live ontology's lexical \
         scenario order"
    );

    let md_offsets: Vec<usize> = sorted_names
        .iter()
        .map(|name| {
            MD_CONTENT
                .find(&format!("`{name}`"))
                .unwrap_or_else(|| panic!("{name} present in generated docs/praxis_core_refusal_taxonomy.md"))
        })
        .collect();
    let mut sorted_md_offsets = md_offsets.clone();
    sorted_md_offsets.sort_unstable();
    assert_eq!(
        md_offsets, sorted_md_offsets,
        "docs/praxis_core_refusal_taxonomy.md row order does not match the live ontology's \
         lexical scenario order"
    );
}
