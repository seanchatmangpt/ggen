---
to: src/praxis_core_refusal_table.rs
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/praxis-core-pack
sparql:
  scenarios: "PREFIX pxc: <http://seanchatmangpt.github.io/packs/praxis-core#> SELECT ?scenario ?categoryLabel ?lane ?kind ?note WHERE { ?s a pxc:RefusalScenario ; pxc:scenarioName ?scenario ; pxc:hasCategory ?cat ; pxc:denialLane ?lane ; pxc:variantKind ?kind ; pxc:note ?note . ?cat pxc:categoryLabel ?categoryLabel } ORDER BY ?scenario"
---
//! Generated by praxis-core-pack from RefusalScenario individuals. Do not edit.
//!
//! Mirrors `praxis_core::refusal::RefusalScenario::category`/`denial_lane`
//! for all 13 variants: each row is
//! `(scenario, category, denial-lane constant, variant kind)` plus a note.
//! `category` is projected from the ontology's closed `pxc:RefusalCategory`
//! object-property target (`pxc:hasCategory`), not a duplicated string --
//! the template only reads `?cat`'s own `pxc:categoryLabel`.

/// One refusal-taxonomy row precipitated from the pack ontology.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct RefusalTaxonomyRow {
    /// `RefusalScenario` variant name.
    pub scenario: &'static str,
    /// 8-bucket `RefusalCategory` (lowercase `Display` form).
    pub category: &'static str,
    /// `bcinr_powl_receipt::denial::DenialPolarity` lane constant.
    pub denial_lane: &'static str,
    /// `"unit"` (no payload) or `"struct"` (one named, typed field).
    pub variant_kind: &'static str,
    /// Human-readable note.
    pub note: &'static str,
}

/// Refusal-taxonomy reference table, sorted by scenario name. Covers all 13
/// `RefusalScenario` variants (ontology is the complete enumeration, not a
/// subset).
pub const PRAXIS_CORE_REFUSAL_TAXONOMY: &[RefusalTaxonomyRow] = &[
{% for row in scenarios %}    RefusalTaxonomyRow {
        scenario: "{{ row.scenario }}",
        category: "{{ row.categoryLabel }}",
        denial_lane: "{{ row.lane }}",
        variant_kind: "{{ row.kind }}",
        note: "{{ row.note }}",
    },
{% endfor %}];

/// Look up the category for a scenario name, purely as a projection of the
/// generated table above (real control flow generated from RDF, not a
/// hand-written match arm) -- a step toward closing the handler gap: a
/// consumer can call this instead of re-deriving the mapping by hand.
#[must_use]
pub fn category_for_scenario(scenario: &str) -> Option<&'static str> {
    PRAXIS_CORE_REFUSAL_TAXONOMY
        .iter()
        .find(|row| row.scenario == scenario)
        .map(|row| row.category)
}

/// Look up the denial-lane constant for a scenario name, purely as a
/// projection of the generated table above.
#[must_use]
pub fn denial_lane_for_scenario(scenario: &str) -> Option<&'static str> {
    PRAXIS_CORE_REFUSAL_TAXONOMY
        .iter()
        .find(|row| row.scenario == scenario)
        .map(|row| row.denial_lane)
}
