---
to: src/praxis_core_refusal_table.rs
sparql:
  scenarios: "SELECT ?scenario ?category ?lane ?note WHERE { ?s a <http://seanchatmangpt.github.io/packs/praxis-core#RefusalScenario> ; <http://seanchatmangpt.github.io/packs/praxis-core#scenarioName> ?scenario ; <http://seanchatmangpt.github.io/packs/praxis-core#categoryName> ?category ; <http://seanchatmangpt.github.io/packs/praxis-core#denialLane> ?lane ; <http://seanchatmangpt.github.io/packs/praxis-core#note> ?note } ORDER BY ?scenario"
---
//! Generated by praxis-core-pack from RefusalScenario individuals. Do not edit.
//!
//! Mirrors `praxis_core::refusal::RefusalScenario::category` for the
//! `DenialPolarity`-lane variants: each row is
//! `(scenario, category, denial-lane constant)` plus a human note.

/// One refusal-taxonomy row precipitated from the pack ontology.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct RefusalTaxonomyRow {
    /// `RefusalScenario` variant name.
    pub scenario: &'static str,
    /// 8-bucket `RefusalCategory` (lowercase `Display` form).
    pub category: &'static str,
    /// `bcinr_powl_receipt::denial::DenialPolarity` lane constant.
    pub denial_lane: &'static str,
    /// Human-readable note.
    pub note: &'static str,
}

/// Refusal-taxonomy reference table, sorted by scenario name.
pub const PRAXIS_CORE_REFUSAL_TAXONOMY: &[RefusalTaxonomyRow] = &[
{% for row in scenarios %}    RefusalTaxonomyRow {
        scenario: "{{ row.scenario }}",
        category: "{{ row.category }}",
        denial_lane: "{{ row.lane }}",
        note: "{{ row.note }}",
    },
{% endfor %}];
