---
to: "docs/retrofit/intervention/介入計画.md"
sparql:
  plans: |
    PREFIX ret: <https://seanchatmangpt.github.io/ontology/retrofit#>
    PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
    SELECT ?id ?classLabel ?currentLabel ?targetLabel ?reason ?ceiling WHERE {
      ?i a ret:Intervention ; ret:interventionId ?id ; ret:interventionClass ?class ; ret:currentObjective ?current ; ret:targetObjective ?target ; ret:rationale ?reason ; ret:standingCeiling ?ceiling .
      ?class skos:prefLabel ?classLabel . ?current skos:prefLabel ?currentLabel . ?target skos:prefLabel ?targetLabel .
    }
  work: |
    PREFIX ret: <https://seanchatmangpt.github.io/ontology/retrofit#>
    PREFIX dct: <http://purl.org/dc/terms/>
    SELECT ?index ?title ?reversible ?criterion WHERE { ?w a ret:WorkPackage ; ret:sequenceIndex ?index ; dct:title ?title ; ret:reversible ?reversible ; ret:acceptanceCriterion ?criterion . } ORDER BY ?index
---
