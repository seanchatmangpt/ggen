# github-actions-pack — WORKFLOW-BODY individuals (B3, generated-product bodies)
#
# SEPARATE ontology file from ontology.ttl (layer model, B1). The engine loads
# extra ontology files via the consumer's `ggen.toml` pack entry:
#   github-actions-pack = { path = "packs/github-actions-pack", extra_ontologies = ["packs/github-actions-pack/bodies.ttl"] }
# (crates/ggen-engine/src/pack.rs `extra_ontology_paths` — unioned into the pack
# graph after ontology.ttl, hash-pinned alongside it).
#
# Every gha:artifactBody below is verbatim-adapted from the REAL as-built YAML
# surveyed in SURVEY.md (ci.yml, quality.yml, tcps-drift bootstrap pattern,
# ggen-verify-pack evidence emitter contract). Permission blocks are DERIVED
# minimal blocks per the operation mapping, never copied broad blocks.
# HARD CONSTRAINT honored: zero backslashes inside every triple-quoted literal.

@prefix gha:  <http://seanchatmangpt.github.io/packs/github-actions#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# ---------------------------------------------------------------------------
# 検査 family — reusable Rust inspection workflow (shadow retrofit beside ci.yml)
# ---------------------------------------------------------------------------

gha:ReusableRustInspectionWorkflow a gha:GeneratedArtifact ;
    rdfs:label "reusable Rust inspection workflow (検査): fmt, lint, build, test, doctest jobs, adapted from the real ci.yml/quality.yml" ;
    gha:family "検査" ;
    gha:artifactPath ".github/workflows/reusable-rust-inspection.yml" ;
    gha:artifactBody """name: Reusable Rust Inspection (検査)

# GENERATED by ggen sync from packs/github-actions-pack (bodies.ttl,
# gha:ReusableRustInspectionWorkflow). Shadow retrofit: this reusable
# workflow lands BESIDE the handwritten ci.yml/quality.yml, it does not
# replace them yet (retrofit sequence in packs/github-actions-pack/README.md).
# Job content is verbatim-adapted from the real ci.yml (check/build/test/
# doctest) and quality.yml (fmt/clippy) at origin/main f775fbb8b.
#
# Permission derivation (operation -> minimal GITHUB_TOKEN permissions):
# every job only reads the repo and runs cargo/just — contents: read.
# No job creates check runs via the API (results surface as job statuses),
# so checks: write is NOT justified and is deliberately absent.

on:
  workflow_call:
    inputs:
      exclude-crate:
        description: "crate excluded from workspace-wide cargo invocations (ci.yml deliverable scoping)"
        required: false
        type: string
        default: ggen-lsp

permissions:
  contents: read

env:
  CARGO_TERM_COLOR: always
  RUST_BACKTRACE: 1

jobs:
  fmt:
    name: fmt
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683  # v4.2.2
      - uses: ./.github/actions/setup-ggen-build
        with:
          components: rustfmt
          cache-key-suffix: reusable-fmt
      - name: just fmt-check
        run: just fmt-check

  lint:
    name: clippy
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683  # v4.2.2
      - uses: ./.github/actions/setup-ggen-build
        with:
          components: rustfmt,clippy
          cache-key-suffix: reusable-clippy
      # cargo-direct, mirroring quality.yml: the just lint recipe wraps clippy
      # in a short local-loop timeout that fires mid-compile on CI cold builds.
      - name: cargo clippy
        run: cargo clippy --workspace --all-targets --exclude ${{ inputs.exclude-crate }}

  build:
    name: Build
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683  # v4.2.2
      - uses: ./.github/actions/setup-ggen-build
        with:
          cache-key-suffix: reusable-build
      - name: cargo build
        run: cargo build --workspace --exclude ${{ inputs.exclude-crate }}

  test:
    name: Test
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683  # v4.2.2
      - uses: ./.github/actions/setup-ggen-build
        with:
          cache-key-suffix: reusable-test
      - name: cargo test (lib)
        run: cargo test --workspace --lib --exclude ${{ inputs.exclude-crate }}

  doctest:
    name: Doctest
    runs-on: ubuntu-latest
    timeout-minutes: 20
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683  # v4.2.2
      - uses: ./.github/actions/setup-ggen-build
        with:
          cache-key-suffix: reusable-doctest
      - name: cargo test (doc)
        run: cargo test --doc --workspace --exclude ${{ inputs.exclude-crate }}

  inspection-status:
    name: Inspection Status
    runs-on: ubuntu-latest
    timeout-minutes: 5
    needs: [fmt, lint, build, test, doctest]
    if: always()
    steps:
      - name: Assert all inspection jobs succeeded
        run: |
          set -euo pipefail
          echo "fmt=${{ needs.fmt.result }}"
          echo "lint=${{ needs.lint.result }}"
          echo "build=${{ needs.build.result }}"
          echo "test=${{ needs.test.result }}"
          echo "doctest=${{ needs.doctest.result }}"
          ok=true
          if [ "${{ needs.fmt.result }}" != "success" ]; then ok=false; fi
          if [ "${{ needs.lint.result }}" != "success" ]; then ok=false; fi
          if [ "${{ needs.build.result }}" != "success" ]; then ok=false; fi
          if [ "${{ needs.test.result }}" != "success" ]; then ok=false; fi
          if [ "${{ needs.doctest.result }}" != "success" ]; then ok=false; fi
          if [ "$ok" != "true" ]; then
            echo "::error::One or more inspection jobs failed."
            exit 1
          fi
          echo "All inspection jobs succeeded."
""" .

gha:ReusableRustInspectionCaller a gha:GeneratedArtifact ;
    rdfs:label "caller example for the reusable inspection workflow (shadow retrofit: kept in docs/, not .github/workflows/, so it cannot run yet)" ;
    gha:family "検査" ;
    gha:artifactPath "docs/github-actions/inspection-caller-example.yml" ;
    gha:artifactBody """# GENERATED by ggen sync from packs/github-actions-pack (bodies.ttl,
# gha:ReusableRustInspectionCaller). Example caller for the generated
# reusable workflow. Deliberately placed in docs/ — the shadow-retrofit
# step that would activate it is copying this file into .github/workflows/
# and retiring the duplicated jobs from the handwritten ci.yml/quality.yml
# (retrofit sequence in packs/github-actions-pack/README.md).
name: Inspection (caller example)

on:
  pull_request:
  merge_group:

permissions:
  contents: read

jobs:
  inspection:
    uses: ./.github/workflows/reusable-rust-inspection.yml
    with:
      exclude-crate: ggen-lsp
""" .

# ---------------------------------------------------------------------------
# 受領 family — evidence-emitting composite action
# ---------------------------------------------------------------------------

gha:EmitEvidenceAction a gha:GeneratedArtifact ;
    rdfs:label "composite action emitting ver: evidence facts (受領) via the ggen-verify-pack emitter contract" ;
    gha:family "受領" ;
    gha:artifactPath ".github/actions/emit-evidence/action.yml" ;
    gha:artifactBody """name: emit-evidence
# GENERATED by ggen sync from packs/github-actions-pack (bodies.ttl,
# gha:EmitEvidenceAction). 受領 family: enumerate the required checks, run
# them capturing REAL exit codes + freshness + graph-hash binding, and
# append the ver: evidence facts — all by DELEGATING to the
# ggen-verify-pack evidence emitter (scripts/verify-evidence.sh, generated;
# bootstrap copy under packs/ggen-verify-pack/bootstrap/ on a fresh
# consumer). Delegation, not duplication: the ver: fact format
# (ver:Check with ver:name/tool/exitCode/summary/verifiedGraphHash/
# recordedAt) has exactly one implementation, so this action cannot drift
# from it. The emitter always exits 0 — it records reality; judgment
# belongs to ggen-verify-pack's gates at the next ggen sync run.
description: Run the ggen-verify-pack evidence emitter and surface the recorded ver:Check facts

inputs:
  working-directory:
    description: Consumer root containing ggen.toml (and scripts/verify-evidence.sh once generated)
    required: false
    default: .

outputs:
  evidence-path:
    description: Path of the emitted evidence ontology
    value: ${{ steps.emit.outputs.evidence-path }}

runs:
  using: composite
  steps:
    - name: Emit evidence facts (real exit codes, graph-hash bound)
      id: emit
      shell: bash
      working-directory: ${{ inputs.working-directory }}
      run: |
        set -euo pipefail
        if [ -x scripts/verify-evidence.sh ] || [ -f scripts/verify-evidence.sh ]; then
          bash scripts/verify-evidence.sh
        elif [ -f packs/ggen-verify-pack/bootstrap/verify-evidence-bootstrap.sh ]; then
          echo "scripts/verify-evidence.sh not generated yet - running the committed bootstrap copy"
          bash packs/ggen-verify-pack/bootstrap/verify-evidence-bootstrap.sh
        else
          echo "::error::no evidence emitter found (scripts/verify-evidence.sh or ggen-verify-pack bootstrap). Wire ggen-verify-pack first."
          exit 1
        fi
        echo "evidence-path=${{ inputs.working-directory }}/evidence/ontology.ttl" >> "$GITHUB_OUTPUT"

    - name: Show recorded evidence
      shell: bash
      working-directory: ${{ inputs.working-directory }}
      run: |
        set -euo pipefail
        echo "--- evidence/ontology.ttl (ver:Check facts) ---"
        cat evidence/ontology.ttl
""" .

# ---------------------------------------------------------------------------
# setup-ggen composite action (bootstrap pattern from tcps-drift.yml)
# ---------------------------------------------------------------------------

gha:SetupGgenAction a gha:GeneratedArtifact ;
    rdfs:label "checkout-independent ggen setup composite action: release asset if usable, else cargo build (tcps-drift.yml bootstrap pattern)" ;
    gha:artifactPath ".github/actions/setup-ggen/action.yml" ;
    gha:artifactBody """name: setup-ggen
# GENERATED by ggen sync from packs/github-actions-pack (bodies.ttl,
# gha:SetupGgenAction). Checkout-independent ggen provisioning, verbatim-
# adapted from the bootstrap-fallback pattern in gh-terraform-pack's
# tcps-drift workflow body: prefer the latest release binary (asset name
# from release.yml's package step), fall back to cargo build only when no
# runnable release binary exists. Distinct from ./.github/actions/
# setup-ggen-build (which provisions the whole sibling build environment):
# this action only makes a runnable ggen binary available.
description: Provide a runnable ggen binary (release asset preferred, cargo build fallback)

inputs:
  repo:
    description: Repository to download the release asset from
    required: false
    default: seanchatmangpt/ggen
  asset-pattern:
    description: Release asset pattern (from release.yml's package step)
    required: false
    default: ggen-x86_64-unknown-linux-gnu.tar.gz
  github-token:
    description: Token for gh release download (contents read is sufficient)
    required: true

outputs:
  ggen-path:
    description: Absolute path of the runnable ggen binary
    value: ${{ steps.relbin.outputs.path }}
  from-release:
    description: Whether the binary came from a release asset (true) or cargo build (false)
    value: ${{ steps.relbin.outputs.found }}

runs:
  using: composite
  steps:
    - name: Try release ggen binary
      id: relbin
      shell: bash
      env:
        GH_TOKEN: ${{ inputs.github-token }}
      run: |
        dir="$RUNNER_TEMP/relbin"
        mkdir -p "$dir"
        set +e
        gh release download --repo ${{ inputs.repo }} --pattern '${{ inputs.asset-pattern }}' --dir "$dir" &&
          tar -xzf "$dir/${{ inputs.asset-pattern }}" -C "$dir" &&
          "$dir/ggen" --version
        ok=$?
        set -e
        if [ "$ok" -eq 0 ]; then
          echo "release binary usable - skipping cargo build"
          echo "found=true" >> "$GITHUB_OUTPUT"
          echo "path=$dir/ggen" >> "$GITHUB_OUTPUT"
        else
          echo "no usable release binary - falling back to cargo build"
          echo "found=false" >> "$GITHUB_OUTPUT"
          echo "path=$GITHUB_WORKSPACE/target/debug/ggen" >> "$GITHUB_OUTPUT"
        fi

    - uses: Swatinem/rust-cache@f13886b937689c021905a6b90929199931d60db1 # v2.8.1
      if: steps.relbin.outputs.found != 'true'

    - name: Build ggen
      if: steps.relbin.outputs.found != 'true'
      shell: bash
      run: cargo build -p ggen-cli-lib --bin ggen
""" .

# ---------------------------------------------------------------------------
# Ownership facts only — no bodies here (do NOT double-own)
# ---------------------------------------------------------------------------

# 漂流検査 family: tcps-drift.yml is generated by gh-terraform-pack.
gha:TcpsDriftWorkflowFact a gha:Workflow ;
    rdfs:label "scheduled Terraform drift detection (漂流検査) — body owned by gh-terraform-pack, modeled here as a fact only" ;
    gha:family "漂流検査" ;
    gha:workflowPath ".github/workflows/tcps-drift.yml" ;
    gha:ownedBy "gh-terraform-pack" .

# 公開 family: publish/release workflows are owned by ggen-release-pack.
gha:PublishCandidateWorkflowFact a gha:Workflow ;
    rdfs:label "Publish Candidate (公開) — body owned by ggen-release-pack, fact only" ;
    gha:family "公開" ;
    gha:workflowPath ".github/workflows/publish-candidate.yml" ;
    gha:ownedBy "ggen-release-pack" .

gha:ReleaseWorkflowFact a gha:Workflow ;
    rdfs:label "Release (公開) — body owned by ggen-release-pack, fact only" ;
    gha:family "公開" ;
    gha:workflowPath ".github/workflows/release.yml" ;
    gha:ownedBy "ggen-release-pack" .
