---
to: src/mfact_catalog.rs
force: true
sparql:
  stages: |
    PREFIX mfa: <http://seanchatmangpt.github.io/packs/mfact#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?order ?actor ?label ?doc WHERE {
      ?s a mfa:PipelineStage ; mfa:order ?order ; mfa:actor ?actor ; rdfs:label ?label ; rdfs:comment ?doc .
    } ORDER BY ?order
  dirs: |
    PREFIX mfa: <http://seanchatmangpt.github.io/packs/mfact#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?path ?doc WHERE {
      ?d a mfa:AuthorityDir ; mfa:path ?path ; rdfs:comment ?doc .
    } ORDER BY ?path
---
//! Typed catalog of ~/mfact's ggen-projects -> Lean-admits -> mfact-certifies
//! pipeline and its 5 top-level authority directories, transcribed from
//! `packs/mfact-pack/ontology.ttl`.
//!
//! Generated by `mfact-pack`. Reference only -- this crate is not mfact
//! itself and does not run its `just` recipes.

/// One stage of mfact's 3-actor certify pipeline.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct MfactStage {
    pub order: u32,
    pub actor: &'static str,
    pub label: &'static str,
    pub doc: &'static str,
}

/// Pipeline stages, ordered.
pub const MFACT_PIPELINE: &[MfactStage] = &[
{% for row in stages %}    MfactStage { order: {{ row.order }}, actor: "{{ row.actor }}", label: "{{ row.label }}", doc: "{{ row.doc }}" },
{% endfor %}];

/// One top-level authority directory.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct MfactAuthorityDir {
    pub path: &'static str,
    pub doc: &'static str,
}

/// Authority directories, alphabetized by path.
pub const MFACT_AUTHORITY_DIRS: &[MfactAuthorityDir] = &[
{% for row in dirs %}    MfactAuthorityDir { path: "{{ row.path }}", doc: "{{ row.doc }}" },
{% endfor %}];
