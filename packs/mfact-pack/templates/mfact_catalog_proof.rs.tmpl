#[test]
fn validate_handoff_contract_accepts_the_generated_catalog() {
    // Real end-to-end check over the ontology-derived catalog: every stage
    // that reads an AuthorityDir must have an earlier-or-equal stage that
    // writes it. Passing here is not tautological -- it depends on
    // mfa:order, mfa:handsOffTo, mfa:readsFrom, and mfa:writesTo all being
    // mutually consistent in ontology.ttl.
    assert_eq!(validate_handoff_contract(), Ok(()));
}

#[test]
fn validate_handoff_contract_rejects_a_stage_reading_an_unwritten_internal_dir() {
    // Adversarial case built independently of MFACT_PIPELINE/MFACT_READS/
    // MFACT_WRITES: a two-stage pipeline where the second stage reads a
    // PIPELINE-INTERNAL directory (something `writes` says a stage
    // produces) before any stage has written it. Exercises the same walk
    // `validate_handoff_contract` performs, inlined here so this test does
    // not depend on any mutable/test-only entry point in the generated
    // module (there is none, by design -- the real function takes no
    // arguments and always walks the real catalog).
    let pipeline = [
        MfactStage { order: 1, actor: "a", label: "A", doc: "d" },
        MfactStage { order: 2, actor: "b", label: "B", doc: "d" },
    ];
    // "y/" IS pipeline-internal (stage "c", never reached before "b" reads
    // it) -- unlike a real external input such as `packs/`, which has zero
    // entries in `writes` and must NOT trip the check (that distinction is
    // exactly the bug this pass found: an earlier draft of this contract
    // flagged `packs/` itself as a false-positive violation, since nothing
    // in the real mfact pipeline ever writes it).
    let writes: &[(&str, &str)] = &[("a", "x/"), ("c", "y/")];
    let reads: &[(&str, &str)] = &[("b", "y/")];
    let internally_produced: Vec<&str> = writes.iter().map(|(_, p)| *p).collect();

    let mut written: Vec<&str> = Vec::new();
    let mut result = Ok(());
    for stage in &pipeline {
        for (actor, path) in writes {
            if *actor == stage.actor {
                written.push(path);
            }
        }
        for (actor, path) in reads {
            if *actor == stage.actor && internally_produced.contains(path) && !written.contains(path) {
                result = Err((stage.actor, *path));
                break;
            }
        }
    }
    assert_eq!(result, Err(("b", "y/")));
}

#[test]
fn validate_handoff_contract_does_not_flag_an_external_input_with_no_writer() {
    // Precisely the real-data case: `packs/` (mfa:PacksDir) is read by
    // `Project`/"ggen" but written by nobody in the pipeline -- it is
    // human-authored source material, not a pipeline-internal artifact.
    // This must NOT be treated as a violation.
    assert!(MFACT_READS.contains(&("ggen", "packs/")));
    assert!(!MFACT_WRITES.iter().any(|(_, path)| *path == "packs/"));
    assert_eq!(validate_handoff_contract(), Ok(()));
}

#[test]
fn mfact_catalog_error_display_is_human_readable() {
    let out_of_order = MfactCatalogError::OutOfOrder { prev_order: 3, next_order: 2 };
    assert!(out_of_order.to_string().contains('3'));
    assert!(out_of_order.to_string().contains('2'));
    assert_eq!(
        MfactCatalogError::EmptyPipeline.to_string(),
        "mfact pipeline has no stages"
    );
    let unsatisfied = MfactCatalogError::UnsatisfiedPrecondition {
        actor: "Lean",
        missing_path: "procint/",
    };
    assert!(unsatisfied.to_string().contains("Lean"));
    assert!(unsatisfied.to_string().contains("procint/"));
}
