//! Anti-drift proof for `src/mfact_catalog.rs`, GENERATED by `mfact-pack`.
//!
//! Deliberately carries NO `sparql:` frontmatter key (it defaults to an
//! empty map in `ggen-engine`'s `Frontmatter` struct when omitted), so this
//! file cannot reuse `mfact_catalog.rs.tmpl`'s SPARQL derivation path.
//! Every expected value below was hand-transcribed from
//! `packs/mfact-pack/ontology.ttl` by reading the ontology directly, not
//! computed by evaluating any query -- if a future ontology edit changes an
//! `rdfs:comment`/`rdfs:label`/`mfa:order`/`mfa:path` and the catalog
//! template still renders correctly, this proof only keeps passing if a
//! human updates the literal here too. That friction is the point, not a
//! bug.

#[path = "../src/mfact_catalog.rs"]
mod mfact_catalog;

use mfact_catalog::{MfactAuthorityDir, MfactStage, MFACT_AUTHORITY_DIRS, MFACT_PIPELINE};

#[test]
fn catalog_has_three_stages_and_five_authority_dirs() {
    // ontology.ttl declares exactly 3 mfa:PipelineStage individuals
    // (Project, Admit, Certify) and exactly 5 mfa:AuthorityDir individuals
    // (PacksDir, ProcintDir, PaperDir, ReleaseDir, ArtifactLedger).
    assert_eq!(MFACT_PIPELINE.len(), 3);
    assert_eq!(MFACT_AUTHORITY_DIRS.len(), 5);
}

#[test]
fn stage_order_1_is_project_by_ggen() {
    // ORDER BY ?order ascending in the generator query is a real structural
    // guarantee; this index-based check independently re-affirms it with a
    // hand-copied literal rather than re-querying.
    let s = MFACT_PIPELINE[0];
    assert_eq!(s.order, 1);
    assert_eq!(s.actor, "ggen");
    assert_eq!(s.label, "Project");
    assert_eq!(
        s.doc,
        "ggen projects a Lean 4 declaration catalog from mfact's own packs/ (lean-math-pack, quadrature-pack, post-release-pack)."
    );
}

#[test]
fn stage_order_2_is_admit_by_lean() {
    let s = MFACT_PIPELINE[1];
    assert_eq!(s.order, 2);
    assert_eq!(s.actor, "Lean");
    assert_eq!(s.label, "Admit");
    assert_eq!(
        s.doc,
        "Lean admits the projected declaration catalog under the pinned toolchain."
    );
}

#[test]
fn stage_order_3_is_certify_by_mfact() {
    let s = MFACT_PIPELINE[2];
    assert_eq!(s.order, 3);
    assert_eq!(s.actor, "mfact");
    assert_eq!(s.label, "Certify");
    assert_eq!(
        s.doc,
        "mfact certifies the admitted result: every standing claim (proven/stated counts, gate results, fixture status) is computed from a build, axiom audit, or git commit -- never hand-typed prose."
    );
}

fn find_dir(path: &str) -> &'static MfactAuthorityDir {
    MFACT_AUTHORITY_DIRS
        .iter()
        .find(|d| d.path == path)
        .unwrap_or_else(|| panic!("no mfact authority dir found for path={path:?}"))
}

#[test]
fn dir_artifact_ledger_sorts_first_and_has_its_doc() {
    // ORDER BY ?path ascending: '.' (0x2E) sorts before every ASCII letter,
    // so ".mfact/artifacts.toml" precedes packs/, paper/, procint/, release/
    // -- verified by hand, not assumed.
    let d = MFACT_AUTHORITY_DIRS[0];
    assert_eq!(d.path, ".mfact/artifacts.toml");
    assert_eq!(
        d.doc,
        "The artifact ledger; authority comes from here, not file paths or headers."
    );
}

#[test]
fn dir_packs_sorts_second_and_has_its_doc() {
    // "packs/" vs "paper/": common prefix "pa", then 'c' (0x63) < 'p' (0x70).
    let d = MFACT_AUTHORITY_DIRS[1];
    assert_eq!(d.path, "packs/");
    assert_eq!(
        d.doc,
        "Ontology fragments and Tera templates ggen renders from; the actual math source, never hand-edited downstream."
    );
}

#[test]
fn dir_paper_sorts_third_and_has_its_doc() {
    // "paper/" vs "procint/": common prefix "p", then 'a' (0x61) < 'r' (0x72).
    let d = MFACT_AUTHORITY_DIRS[2];
    assert_eq!(d.path, "paper/");
    assert_eq!(
        d.doc,
        "The LaTeX paper; standing-derived numbers are rendered fragments, never hand-typed."
    );
}

#[test]
fn dir_procint_sorts_fourth_and_has_its_doc() {
    // "procint/" vs "release/": 'p' (0x70) < 'r' (0x72).
    let d = MFACT_AUTHORITY_DIRS[3];
    assert_eq!(d.path, "procint/");
    assert_eq!(
        d.doc,
        "The rendered Lean 4 package: event logs, process models, conformance checking, Petri nets, OCEL, plus axiom audit and correctness-ladder fixtures."
    );
}

#[test]
fn dir_release_sorts_fifth_and_has_its_doc() {
    let d = MFACT_AUTHORITY_DIRS[4];
    assert_eq!(d.path, "release/");
    assert_eq!(
        d.doc,
        "The manifest, gates, and standing artifacts that are the actual authority for any claim about this project's state."
    );
}

#[test]
fn find_dir_helper_locates_docs_by_path_lookup() {
    // Not tautological: `find_dir` locates a row by scanning for `path`,
    // then this asserts on the OTHER field (`doc`) against a fresh literal
    // hand-transcribed from ontology.ttl -- proving the lookup returns the
    // right row's full content, not merely echoing the search key back.
    assert_eq!(
        find_dir("packs/").doc,
        "Ontology fragments and Tera templates ggen renders from; the actual math source, never hand-edited downstream."
    );
    assert_eq!(
        find_dir("release/").doc,
        "The manifest, gates, and standing artifacts that are the actual authority for any claim about this project's state."
    );
}

#[test]
fn pipeline_is_strictly_increasing_by_order() {
    // Proves the ORDER BY ?order the catalog template promised actually
    // landed in the emitted const slice -- a real state-based check over
    // the rendered data, not a re-check of the query.
    for pair in MFACT_PIPELINE.windows(2) {
        assert!(
            pair[0].order < pair[1].order,
            "pipeline stages out of order: {:?} then {:?}",
            pair[0],
            pair[1]
        );
    }
}

#[test]
fn authority_dirs_are_strictly_increasing_by_path() {
    // Same structural check as above for ORDER BY ?path.
    for pair in MFACT_AUTHORITY_DIRS.windows(2) {
        assert!(
            pair[0].path < pair[1].path,
            "authority dirs out of order: {:?} then {:?}",
            pair[0],
            pair[1]
        );
    }
}

#[test]
fn every_stage_field_is_non_empty() {
    // Mirrors the mandatory (non-OPTIONAL) triple patterns
    // `mfa:order`/`mfa:actor`/`rdfs:label`/`rdfs:comment` the catalog's own
    // SPARQL requires to exist for every mfa:PipelineStage individual.
    for s in MFACT_PIPELINE {
        assert!(s.order > 0, "stage order must be positive: {s:?}");
        assert!(!s.actor.is_empty(), "stage actor must not be empty: {s:?}");
        assert!(!s.label.is_empty(), "stage label must not be empty: {s:?}");
        assert!(!s.doc.is_empty(), "stage doc must not be empty: {s:?}");
    }
}

#[test]
fn every_authority_dir_field_is_non_empty() {
    // Mirrors the mandatory (non-OPTIONAL) triple patterns
    // `mfa:path`/`rdfs:comment` the catalog's own SPARQL requires to exist
    // for every mfa:AuthorityDir individual.
    for d in MFACT_AUTHORITY_DIRS {
        assert!(!d.path.is_empty(), "dir path must not be empty: {d:?}");
        assert!(!d.doc.is_empty(), "dir doc must not be empty: {d:?}");
    }
}
