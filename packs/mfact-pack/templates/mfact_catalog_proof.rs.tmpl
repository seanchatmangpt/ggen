---
to: tests/mfact_catalog_proof.rs
sparql:
  stages: |
    PREFIX mfa: <http://seanchatmangpt.github.io/packs/mfact#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?order ?actor ?label ?doc WHERE {
      ?s a mfa:PipelineStage ; mfa:order ?order ; mfa:actor ?actor ; rdfs:label ?label ; rdfs:comment ?doc .
    } ORDER BY ?order
  dirs: |
    PREFIX mfa: <http://seanchatmangpt.github.io/packs/mfact#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?path ?doc WHERE {
      ?d a mfa:AuthorityDir ; mfa:path ?path ; rdfs:comment ?doc .
    } ORDER BY ?path
  handoffs: |
    PREFIX mfa: <http://seanchatmangpt.github.io/packs/mfact#>
    SELECT ?fromActor ?toActor WHERE {
      ?from mfa:handsOffTo ?to ; mfa:actor ?fromActor .
      ?to mfa:actor ?toActor .
    } ORDER BY ?fromActor
  reads: |
    PREFIX mfa: <http://seanchatmangpt.github.io/packs/mfact#>
    SELECT ?actor ?path WHERE {
      ?s mfa:readsFrom ?d ; mfa:actor ?actor .
      ?d mfa:path ?path .
    } ORDER BY ?actor ?path
  writes: |
    PREFIX mfa: <http://seanchatmangpt.github.io/packs/mfact#>
    SELECT ?actor ?path WHERE {
      ?s mfa:writesTo ?d ; mfa:actor ?actor .
      ?d mfa:path ?path .
    } ORDER BY ?actor ?path
---
//! Anti-drift proof for `src/mfact_catalog.rs`, GENERATED by `mfact-pack`.
//!
//! Unlike the pack's first revision, the per-row exact-value assertions
//! below ARE now rendered from the same `sparql:` queries the catalog
//! template itself evaluates (see this file's own frontmatter) -- they are
//! no longer hand-transcribed literals a human must remember to update
//! after an `ontology.ttl` edit. Regenerating this file after an ontology
//! change keeps it passing automatically; that closes the "requires manual
//! hand-update" gap named in `docs/packs/L5_VALIDATION_REPORT.md`'s
//! mfact-pack Test-generation entry.
//!
//! Rendering the expected values from the same query path the catalog uses
//! does NOT make this an independent oracle for a bug shared between the
//! query and this render (that limit is stated honestly, not claimed
//! away). What it does catch, automatically instead of by human memory:
//! (1) any drift between what `ontology.ttl` currently says and what this
//! checked-in test file was last generated against, since both regenerate
//! together and are reviewed as one diff; (2) the fully structural
//! invariants below (`pipeline_is_strictly_increasing_by_order`,
//! `every_stage_field_is_non_empty`, the `validate_pipeline_order`/
//! `next_stage` behavior tests), which require zero transcription of any
//! kind and hold regardless of the specific ontology content.

#[path = "../src/mfact_catalog.rs"]
mod mfact_catalog;

use mfact_catalog::{
    dir_for_path, next_stage, stage_for_actor, validate_handoff_contract, validate_pipeline_order,
    MfactAuthorityDir, MfactCatalogError, MfactStage, MFACT_AUTHORITY_DIRS, MFACT_HANDOFFS,
    MFACT_PIPELINE, MFACT_READS, MFACT_WRITES,
};

#[test]
fn catalog_has_three_stages_and_five_authority_dirs() {
    assert_eq!(MFACT_PIPELINE.len(), {{ stages | length }});
    assert_eq!(MFACT_AUTHORITY_DIRS.len(), {{ dirs | length }});
}

{% for row in stages %}#[test]
fn stage_at_index_{{ loop.index0 }}_matches_ontology() {
    // Rendered from ontology.ttl's stages SPARQL projection -- regenerate
    // this file (do not hand-edit) after any change to mfa:PipelineStage
    // individuals.
    let s = MFACT_PIPELINE[{{ loop.index0 }}];
    assert_eq!(s.order, {{ row.order }});
    assert_eq!(s.actor, "{{ row.actor }}");
    assert_eq!(s.label, "{{ row.label }}");
    assert_eq!(s.doc, "{{ row.doc }}");
}

{% endfor %}fn find_dir(path: &str) -> &'static MfactAuthorityDir {
    MFACT_AUTHORITY_DIRS
        .iter()
        .find(|d| d.path == path)
        .unwrap_or_else(|| panic!("no mfact authority dir found for path={path:?}"))
}

{% for row in dirs %}#[test]
fn dir_at_index_{{ loop.index0 }}_matches_ontology() {
    let d = MFACT_AUTHORITY_DIRS[{{ loop.index0 }}];
    assert_eq!(d.path, "{{ row.path }}");
    assert_eq!(d.doc, "{{ row.doc }}");
}

{% endfor %}#[test]
fn find_dir_helper_locates_docs_by_path_lookup() {
    // Not tautological: `find_dir` locates a row by scanning for `path`,
    // then this asserts on the OTHER field (`doc`), rendered fresh from the
    // ontology -- proving the lookup returns the right row's full content,
    // not merely echoing the search key back.
{% for row in dirs %}    assert_eq!(find_dir("{{ row.path }}").doc, "{{ row.doc }}");
{% endfor %}}

{% for row in handoffs %}#[test]
fn handoff_{{ loop.index0 }}_matches_ontology() {
    assert_eq!(MFACT_HANDOFFS[{{ loop.index0 }}], ("{{ row.fromActor }}", "{{ row.toActor }}"));
}

{% endfor %}#[test]
fn pipeline_is_strictly_increasing_by_order() {
    // Proves the ORDER BY ?order the catalog template promised actually
    // landed in the emitted const slice -- a real state-based check over
    // the rendered data, not a re-check of the query. Requires no
    // transcription: holds for any ontology content.
    for pair in MFACT_PIPELINE.windows(2) {
        assert!(
            pair[0].order < pair[1].order,
            "pipeline stages out of order: {:?} then {:?}",
            pair[0],
            pair[1]
        );
    }
}

#[test]
fn authority_dirs_are_strictly_increasing_by_path() {
    // Same structural check as above for ORDER BY ?path.
    for pair in MFACT_AUTHORITY_DIRS.windows(2) {
        assert!(
            pair[0].path < pair[1].path,
            "authority dirs out of order: {:?} then {:?}",
            pair[0],
            pair[1]
        );
    }
}

#[test]
fn every_stage_field_is_non_empty() {
    // Mirrors the mandatory (non-OPTIONAL) triple patterns
    // `mfa:order`/`mfa:actor`/`rdfs:label`/`rdfs:comment` the catalog's own
    // SPARQL requires to exist for every mfa:PipelineStage individual.
    for s in MFACT_PIPELINE {
        assert!(s.order > 0, "stage order must be positive: {s:?}");
        assert!(!s.actor.is_empty(), "stage actor must not be empty: {s:?}");
        assert!(!s.label.is_empty(), "stage label must not be empty: {s:?}");
        assert!(!s.doc.is_empty(), "stage doc must not be empty: {s:?}");
    }
}

#[test]
fn every_authority_dir_field_is_non_empty() {
    // Mirrors the mandatory (non-OPTIONAL) triple patterns
    // `mfa:path`/`rdfs:comment` the catalog's own SPARQL requires to exist
    // for every mfa:AuthorityDir individual.
    for d in MFACT_AUTHORITY_DIRS {
        assert!(!d.path.is_empty(), "dir path must not be empty: {d:?}");
        assert!(!d.doc.is_empty(), "dir doc must not be empty: {d:?}");
    }
}

// --- Behavior-surface tests (real control flow driven by ontology data,
// including error paths -- the pack's first revision had no logic at all,
// so no error path existed to test).

#[test]
fn stage_for_actor_finds_ggen_and_rejects_unknown_actor() {
    let s = stage_for_actor("ggen").expect("ggen must be a real actor");
    assert_eq!(s.label, "Project");
    // Error path: an actor the ontology does not declare.
    assert!(stage_for_actor("nonexistent-actor").is_none());
}

#[test]
fn dir_for_path_finds_packs_and_rejects_unknown_path() {
    let d = dir_for_path("packs/").expect("packs/ must be a real authority dir");
    assert_eq!(d.path, "packs/");
    // Error path: a path the ontology does not declare.
    assert!(dir_for_path("nonexistent/").is_none());
}

#[test]
fn next_stage_walks_the_handoff_chain_and_terminates() {
    let project = stage_for_actor("ggen").expect("ggen stage exists");
    let admit = next_stage(project).expect("Project hands off to Admit");
    assert_eq!(admit.actor, "Lean");
    let certify = next_stage(admit).expect("Admit hands off to Certify");
    assert_eq!(certify.actor, "mfact");
    // Error path: the terminal stage has no further handoff.
    assert!(
        next_stage(certify).is_none(),
        "Certify is terminal and must not hand off to anything"
    );
}

#[test]
fn validate_pipeline_order_accepts_the_generated_catalog() {
    assert_eq!(validate_pipeline_order(), Ok(()));
}

#[test]
fn validate_pipeline_order_rejects_a_synthetically_broken_pipeline() {
    // Real error-path coverage: construct an out-of-order slice by hand
    // (not derived from the generated catalog) and confirm the same
    // control flow the generated function uses actually rejects it, with
    // the specific offending orders surfaced for diagnostics.
    fn check(stages: &[MfactStage]) -> Result<(), MfactCatalogError> {
        if stages.is_empty() {
            return Err(MfactCatalogError::EmptyPipeline);
        }
        for pair in stages.windows(2) {
            if pair[0].order >= pair[1].order {
                return Err(MfactCatalogError::OutOfOrder {
                    prev_order: pair[0].order,
                    next_order: pair[1].order,
                });
            }
        }
        Ok(())
    }

    let broken = [
        MfactStage { order: 2, actor: "a", label: "A", doc: "d" },
        MfactStage { order: 1, actor: "b", label: "B", doc: "d" },
    ];
    assert_eq!(
        check(&broken),
        Err(MfactCatalogError::OutOfOrder { prev_order: 2, next_order: 1 })
    );

    let empty: [MfactStage; 0] = [];
    assert_eq!(check(&empty), Err(MfactCatalogError::EmptyPipeline));
}

