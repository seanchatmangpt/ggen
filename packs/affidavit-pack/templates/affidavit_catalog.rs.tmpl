---
to: src/affidavit_catalog.rs
force: true
sparql:
  stages: |
    PREFIX afd: <http://seanchatmangpt.github.io/packs/affidavit#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?order ?label ?doc WHERE {
      ?s a afd:CertifyStage ; afd:order ?order ; rdfs:label ?label ; rdfs:comment ?doc .
    } ORDER BY ?order
  commands: |
    PREFIX cnv: <http://seanchatmangpt.github.io/packs/clap-noun-verb#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?noun ?verb ?doc WHERE {
      ?c a cnv:Command ; cnv:noun ?noun ; cnv:verb ?verb .
      FILTER(STRSTARTS(STR(?c), "http://seanchatmangpt.github.io/packs/affidavit#"))
      OPTIONAL { ?c rdfs:comment ?comment_raw . }
      BIND(COALESCE(?comment_raw, "") AS ?doc)
    } ORDER BY ?noun ?verb
---
//! Typed catalog of ~/affidavit's 7-stage certify pipeline and its 4 named
//! core verbs, transcribed from `packs/affidavit-pack/ontology.ttl`.
//!
//! Generated by `affidavit-pack`. Reference only -- this crate does not
//! invoke `affi`.

/// One stage of the 7-stage certify pipeline.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct CertifyStage {
    pub order: u32,
    pub label: &'static str,
    pub doc: &'static str,
}

/// Certify pipeline stages, ordered.
pub const CERTIFY_STAGES: &[CertifyStage] = &[
{% for row in stages %}    CertifyStage { order: {{ row.order }}, label: "{{ row.label }}", doc: "{{ row.doc }}" },
{% endfor %}];

/// One `affi <verb>` command row (`cnv:noun` is always "affi" here).
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct AffidavitCommand {
    pub verb: &'static str,
    pub doc: &'static str,
}

/// The 4 named core verbs (README's "Core Verbs (The Provenance Loop)").
pub const CORE_VERBS: &[AffidavitCommand] = &[
{% for row in commands %}    AffidavitCommand { verb: "{{ row.verb }}", doc: "{{ row.doc }}" },
{% endfor %}];
