//! Proof tests for `affidavit-pack`'s generated catalog
//! (`src/affidavit_catalog.rs`), asserted against literal values
//! hand-transcribed from `packs/affidavit-pack/ontology.ttl`.
//!
//! Fully static template: no SPARQL, no Tera substitution. Every expected
//! value below is a literal the author copied from the ontology, never a
//! value recomputed via the same query path that produced
//! `CERTIFY_STAGES`/`CORE_VERBS` -- so a broken `ORDER BY` or a dropped/
//! mismatched row fails these tests even though it would not fail a
//! tautological self-comparison.
//!
//! Generated by `affidavit-pack`.

#[path = "../src/affidavit_catalog.rs"]
mod affidavit_catalog;

use affidavit_catalog::{AffidavitCommand, CertifyStage, CERTIFY_STAGES, CORE_VERBS};

#[test]
fn certify_stages_has_seven_entries() {
    assert_eq!(CERTIFY_STAGES.len(), 7);
}

#[test]
fn core_verbs_has_four_entries() {
    assert_eq!(CORE_VERBS.len(), 4);
}

#[test]
fn certify_stages_order_is_ascending_one_through_seven() {
    let orders: Vec<u32> = CERTIFY_STAGES.iter().map(|s| s.order).collect();
    assert_eq!(orders, vec![1, 2, 3, 4, 5, 6, 7]);
}

#[test]
fn certify_stage_1_decode_matches_ontology() {
    assert_eq!(
        CERTIFY_STAGES[0],
        CertifyStage {
            order: 1,
            label: "Decode",
            doc: "Structural presence and version parsing.",
        }
    );
}

