#[test]
fn core_verbs_are_alphabetical_by_verb() {
    // ORDER BY ?noun ?verb, and every row's ?noun is the constant "affi",
    // so the actual ordering reduces to plain verb-alphabetical -- a
    // structural claim derived by hand-reasoning about the query shape,
    // not a value pulled from the query's own output.
    let verbs: Vec<&str> = CORE_VERBS.iter().map(|c| c.verb).collect();
    assert_eq!(verbs, vec!["assemble", "emit", "show", "verify"]);
}

#[test]
fn core_verb_assemble_matches_ontology() {
    assert_eq!(
        CORE_VERBS[0],
        AffidavitCommand {
            verb: "assemble",
            doc: "Finalize and seal the current receipt.",
        }
    );
}

