to: tests/affidavit_certify_proof.rs
sparql:
  stages: |
    PREFIX afd: <http://seanchatmangpt.github.io/packs/affidavit#>
    SELECT ?s WHERE { ?s a afd:CertifyStage . }
---
//! Proof tests for `affidavit-pack`'s generated executable logic
//! (`src/affidavit_certify.rs`). Unlike `tests/affidavit_proof.rs` (which
//! only checks a static table against hand-copied literals), these tests
//! exercise real generated behavior: the stage dispatcher and the
//! `check_continuity` predicate, including adversarial/error-path inputs
//! (duplicate sequence numbers, out-of-order sequence numbers, a single
//! event, an empty receipt). A passing run here is evidence the generated
//! *logic* works, not merely that two tables agree.
//!
//! `EXPECTED_STAGE_COUNT` is re-derived live via SPARQL `COUNT(?s)` over
//! `afd:CertifyStage` individuals (not hand-transcribed), so an ontology
//! edit that adds/removes a stage changes this literal on the next `ggen
//! sync` automatically -- drift between the ontology and this assertion is
//! caught by construction, addressing the exact gap the L5 validation
//! report named for `tests/affidavit_proof.rs`.
//!
//! Generated by `affidavit-pack`.

#[path = "../src/affidavit_certify.rs"]
mod affidavit_certify;

use affidavit_certify::{
    check_continuity, check_stage, check_strictly_increasing, check_unique, is_terminal,
    next_stage, Stage, ALL_STAGES, STAGE_CHECKS,
};

/// SPARQL-derived (`sparql_count()` over `?s a afd:CertifyStage`), not
/// hand-copied -- regenerates correctly if the ontology's stage count changes.
const EXPECTED_STAGE_COUNT: usize = {{ sparql_count(rows=stages) }};

#[test]
fn all_stages_len_matches_sparql_derived_count() {
    assert_eq!(ALL_STAGES.len(), EXPECTED_STAGE_COUNT);
}

#[test]
fn stage_dispatch_walks_the_entire_chain_in_order() {
    let mut current = ALL_STAGES[0];
    let mut visited = vec![current];
    while let Some(next) = next_stage(current) {
        assert!(
            next.order() > current.order(),
            "next_stage must strictly increase ontology order"
        );
        visited.push(next);
        current = next;
    }
    assert_eq!(visited.len(), ALL_STAGES.len(), "dispatch must visit every stage exactly once");
    assert!(is_terminal(current), "walking next_stage to exhaustion must land on the terminal stage");
}

#[test]
fn only_the_last_stage_is_terminal() {
    for (i, stage) in ALL_STAGES.iter().enumerate() {
        let expected_terminal = i == ALL_STAGES.len() - 1;
        assert_eq!(is_terminal(*stage), expected_terminal, "stage at index {i} ({stage:?})");
    }
}

#[test]
fn continuity_accepts_empty_sequence() {
    assert!(check_continuity(&[]).is_ok());
}

#[test]
fn continuity_accepts_single_event() {
    assert!(check_continuity(&[0]).is_ok());
}

#[test]
fn continuity_accepts_strictly_increasing_sequence() {
    assert!(check_continuity(&[0, 1, 2, 3, 100]).is_ok());
}

#[test]
fn continuity_rejects_duplicate_sequence_numbers() {
    // Adversarial: a replayed/duplicated event -- afd:Continuity's
    // rejectCondition names "unique" explicitly.
    let result = check_continuity(&[0, 1, 1, 2]);
    assert!(result.is_err(), "duplicate sequenceNumber must REJECT");
    assert!(result.unwrap_err().contains("duplicate"));
}

#[test]
fn continuity_rejects_out_of_order_sequence_numbers() {
    // Adversarial: an event log tampered with or replayed out of order --
    // afd:Continuity's rejectCondition names "strictly-increasing".
    let result = check_continuity(&[0, 2, 1, 3]);
    assert!(result.is_err(), "non-monotonic sequenceNumber must REJECT");
}

#[test]
fn continuity_rejects_at_the_first_violation_not_the_last() {
    // Adversarial: multiple violations present -- must fail fast at index 2
    // (value 1, duplicate of index 1's value), not scan past it.
    let result = check_continuity(&[0, 1, 1, 5, 5]);
    assert!(result.unwrap_err().contains("index 2"));
}

#[test]
fn reject_condition_text_is_non_empty_for_every_stage() {
    for stage in ALL_STAGES {
        assert!(!stage.reject_condition().is_empty());
    }
}

// -- Round 3 (2026-07-18): tests for the check_strictly_increasing /
// check_unique / check_stage composition mechanism itself, independent of
// check_continuity's own adversarial tests above. These certify the
// *dispatch* -- that ontology flags actually drive which generic primitive
// runs -- not just that Continuity happens to reject bad input.

#[test]
fn only_continuity_has_both_structural_check_flags_set() {
    // Ontology-derived: exactly one stage (afd:Continuity) currently sets
    // both afd:checksMonotonic and afd:checksUnique. If a future ontology
    // edit adds a second stage with flags, this assertion (not this test's
    // *logic*) must be revisited -- it documents today's real fact, not an
    // invariant the pack enforces.
    let flagged: Vec<Stage> = STAGE_CHECKS
        .iter()
        .filter(|(_, m, u)| *m || *u)
        .map(|(s, _, _)| *s)
        .collect();
    assert_eq!(flagged, vec![Stage::Continuity]);
}

#[test]
fn check_stage_on_an_unflagged_stage_trivially_accepts_any_input() {
    // Decode has no structural-check flags (this pack does not know how to
    // check it yet); check_stage must not silently apply Continuity's
    // checks to a different stage.
    assert!(check_stage(Stage::Decode, &[5, 1, 1, 0]).is_ok());
}

#[test]
fn check_stage_on_continuity_matches_check_continuity_exactly() {
    // check_continuity is documented as a thin named call into check_stage;
    // prove the two are actually equivalent, not just similarly named.
    for seq in [
        vec![],
        vec![0u64],
        vec![0, 1, 2, 3, 100],
        vec![0, 1, 1, 2],
        vec![0, 2, 1, 3],
    ] {
        assert_eq!(
            check_stage(Stage::Continuity, &seq).is_ok(),
            check_continuity(&seq).is_ok(),
            "seq={seq:?}"
        );
    }
}

#[test]
fn check_unique_alone_is_silent_about_ordering() {
    // The generic primitive in isolation: a non-increasing but duplicate-free
    // sequence must pass check_unique even though it would fail
    // check_strictly_increasing -- proves the two primitives are genuinely
    // independent, not one calling the other internally.
    assert!(check_unique(&[5, 3, 1]).is_ok());
    assert!(check_strictly_increasing(&[5, 3, 1]).is_err());
}

#[test]
fn check_strictly_increasing_alone_is_silent_about_duplicates() {
    // A duplicate pair (equal, not decreasing) passes check_strictly_increasing
    // -- its comparison is strict-less-than only, deliberately leaving
    // equality to check_unique -- but fails check_unique. Proves the two
    // primitives partition the "strictly increasing, no duplicates"
    // predicate rather than overlapping.
    assert!(check_strictly_increasing(&[1, 1]).is_ok());
    assert!(check_unique(&[1, 1]).is_err());
}
