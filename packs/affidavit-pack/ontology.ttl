# affidavit-pack ontology — the real receipt data model and 7-stage
# certify pipeline from ~/affidavit/README.md's "Core Concepts" section,
# plus the 4 "Core Verbs (The Provenance Loop)" it names explicitly.
# The README also claims "59 canonical verbs" total; only the 4 named
# core verbs are modeled here -- the rest were not enumerated in a table
# and are not guessed.
#
# Target-API fidelity note (dated hand-verification, real source read):
# checked 2026-07-18 against the actual ~/affidavit checkout on this
# machine (crates.io `affidavit` v26.6.22, per its own Cargo.toml
# `[package] version = "26.6.22"`). Every CertifyStage label/order/comment
# triple below, and all 4 afd:Command individuals, are a byte-for-byte
# match against ~/affidavit/README.md lines 63-71 and 79-83 (not merely
# "the README" in the abstract -- the literal file inside the pinned
# source tree). `afd:sourceVersion` below records the pinned version this
# was checked against so a future re-verification has something concrete
# to diff. This is still an L2-rung check (one dated hand-verification),
# not L5 (fidelity is definitional only if affidavit itself exposed an
# ontology to track -- it does not; see pack.toml's fidelity note).

@prefix afd:  <http://seanchatmangpt.github.io/packs/affidavit#> .
@prefix cnv:  <http://seanchatmangpt.github.io/packs/clap-noun-verb#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

afd:Receipt
    a rdfs:Class ; rdfs:label "Provenance Receipt" ;
    rdfs:comment "Primary unit of evidence: an append-only, content-addressed BLAKE3 chain of operation-events." .

afd:Event
    a rdfs:Class ; rdfs:label "Event" ;
    rdfs:comment "Discrete operation record with a monotonic sequence number." .

afd:Commitment
    a rdfs:Class ; rdfs:label "Commitment" ;
    rdfs:comment "BLAKE3 digest of payload data; the payload itself is never stored in the receipt." .

afd:hasEvent      a rdf:Property ; rdfs:domain afd:Receipt ; rdfs:range afd:Event ;
    afd:minCardinality 0 ; rdfs:comment "A Receipt has zero or more Events (append-only log; empty at assembly time is legal)." .
afd:hasCommitment a rdf:Property ; rdfs:domain afd:Event ; rdfs:range afd:Commitment ;
    afd:minCardinality 1 ; afd:maxCardinality 1 ; rdfs:comment "Exactly one Commitment per Event -- payload digests are 1:1 with events." .
afd:sequenceNumber a rdf:Property ; rdfs:domain afd:Event ; rdfs:range xsd:integer ;
    afd:monotonic "strictly-increasing" ; afd:unique "true" ;
    rdfs:comment "Monotonic, unique per Receipt -- this is the exact structural property afd:Continuity (stage 4) checks." .

afd:CertifyStage
    a rdfs:Class ; rdfs:label "Certify pipeline stage" ;
    rdfs:comment "One of 7 stages every receipt passes through before an ACCEPT/REJECT verdict." .

afd:order a rdf:Property ; rdfs:domain afd:CertifyStage ; rdfs:range xsd:integer .
afd:rejectCondition a rdf:Property ; rdfs:domain afd:CertifyStage ; rdfs:range xsd:string ;
    rdfs:comment "The structural predicate that, if false, makes this stage emit REJECT and halt the pipeline (fail-fast, no later stage runs)." .

afd:Decode             a afd:CertifyStage ; afd:order 1 ; rdfs:label "Decode" ; rdfs:comment "Structural presence and version parsing." ;
    afd:rejectCondition "receipt bytes deserialize to a well-formed Receipt with a recognized version tag" .
afd:FormatCheck        a afd:CertifyStage ; afd:order 2 ; rdfs:label "Format Check" ; rdfs:comment "Verification against the core/v1 standard." ;
    afd:rejectCondition "every field required by the core/v1 schema is present and correctly typed" .
afd:ChainIntegrity     a afd:CertifyStage ; afd:order 3 ; rdfs:label "Chain Integrity" ; rdfs:comment "Cryptographic re-computation of the rolling hash." ;
    afd:rejectCondition "recomputed BLAKE3 rolling hash over all Events equals the receipt's stored chain seal" .
afd:Continuity         a afd:CertifyStage ; afd:order 4 ; rdfs:label "Continuity" ; rdfs:comment "Logical sequence and uniqueness validation." ;
    afd:rejectCondition "afd:sequenceNumber values across all Events are strictly increasing with no duplicates" .
afd:CommitmentVerify   a afd:CertifyStage ; afd:order 5 ; rdfs:label "Commitment Verify" ; rdfs:comment "Structural validation of all payload digests." ;
    afd:rejectCondition "every Event's afd:hasCommitment resolves to exactly one well-formed BLAKE3 digest" .
afd:ProfileEvaluation  a afd:CertifyStage ; afd:order 6 ; rdfs:label "Profile Evaluation" ; rdfs:comment "Conformance scoring against business logic." ;
    afd:rejectCondition "conformance score against the configured profile meets its pass threshold" .
afd:FinalVerdict       a afd:CertifyStage ; afd:order 7 ; rdfs:label "Final Verdict" ; rdfs:comment "Atomic ACCEPT or REJECT output." ;
    afd:rejectCondition "all 6 prior stages returned no rejection" .

afd:Verdict a rdfs:Class ; rdfs:label "Certify pipeline verdict" ;
    rdfs:comment "The only two atomic outcomes afd:FinalVerdict (stage 7) may produce." .
afd:Accept a afd:Verdict ; rdfs:label "ACCEPT" ; rdfs:comment "All 7 stages passed; receipt is certified." .
afd:Reject a afd:Verdict ; rdfs:label "REJECT" ; rdfs:comment "At least one stage's afd:rejectCondition was false; pipeline halted at that stage." .

afd:emit     a cnv:Command ; cnv:noun "affi" ; cnv:verb "emit"     ; rdfs:comment "Record a new operation-event." .
afd:assemble a cnv:Command ; cnv:noun "affi" ; cnv:verb "assemble" ; rdfs:comment "Finalize and seal the current receipt." .
afd:verify   a cnv:Command ; cnv:noun "affi" ; cnv:verb "verify"   ; rdfs:comment "Run the certify pipeline against a receipt." .
afd:show     a cnv:Command ; cnv:noun "affi" ; cnv:verb "show"     ; rdfs:comment "Inspect receipt details." .
