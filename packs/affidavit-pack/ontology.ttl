# affidavit-pack ontology — the real receipt data model and 7-stage
# certify pipeline from ~/affidavit/README.md's "Core Concepts" section,
# plus the 4 "Core Verbs (The Provenance Loop)" it names explicitly.
# The README also claims "59 canonical verbs" total; only the 4 named
# core verbs are modeled here -- the rest were not enumerated in a table
# and are not guessed.

@prefix afd:  <http://seanchatmangpt.github.io/packs/affidavit#> .
@prefix cnv:  <http://seanchatmangpt.github.io/packs/clap-noun-verb#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

afd:Receipt
    a rdfs:Class ; rdfs:label "Provenance Receipt" ;
    rdfs:comment "Primary unit of evidence: an append-only, content-addressed BLAKE3 chain of operation-events." .

afd:Event
    a rdfs:Class ; rdfs:label "Event" ;
    rdfs:comment "Discrete operation record with a monotonic sequence number." .

afd:Commitment
    a rdfs:Class ; rdfs:label "Commitment" ;
    rdfs:comment "BLAKE3 digest of payload data; the payload itself is never stored in the receipt." .

afd:hasEvent      a rdf:Property ; rdfs:domain afd:Receipt ; rdfs:range afd:Event .
afd:hasCommitment a rdf:Property ; rdfs:domain afd:Event ; rdfs:range afd:Commitment .
afd:sequenceNumber a rdf:Property ; rdfs:domain afd:Event ; rdfs:range xsd:integer .

afd:CertifyStage
    a rdfs:Class ; rdfs:label "Certify pipeline stage" ;
    rdfs:comment "One of 7 stages every receipt passes through before an ACCEPT/REJECT verdict." .

afd:order a rdf:Property ; rdfs:domain afd:CertifyStage ; rdfs:range xsd:integer .

afd:Decode             a afd:CertifyStage ; afd:order 1 ; rdfs:label "Decode" ; rdfs:comment "Structural presence and version parsing." .
afd:FormatCheck        a afd:CertifyStage ; afd:order 2 ; rdfs:label "Format Check" ; rdfs:comment "Verification against the core/v1 standard." .
afd:ChainIntegrity     a afd:CertifyStage ; afd:order 3 ; rdfs:label "Chain Integrity" ; rdfs:comment "Cryptographic re-computation of the rolling hash." .
afd:Continuity         a afd:CertifyStage ; afd:order 4 ; rdfs:label "Continuity" ; rdfs:comment "Logical sequence and uniqueness validation." .
afd:CommitmentVerify   a afd:CertifyStage ; afd:order 5 ; rdfs:label "Commitment Verify" ; rdfs:comment "Structural validation of all payload digests." .
afd:ProfileEvaluation  a afd:CertifyStage ; afd:order 6 ; rdfs:label "Profile Evaluation" ; rdfs:comment "Conformance scoring against business logic." .
afd:FinalVerdict       a afd:CertifyStage ; afd:order 7 ; rdfs:label "Final Verdict" ; rdfs:comment "Atomic ACCEPT or REJECT output." .

afd:emit     a cnv:Command ; cnv:noun "affi" ; cnv:verb "emit"     ; rdfs:comment "Record a new operation-event." .
afd:assemble a cnv:Command ; cnv:noun "affi" ; cnv:verb "assemble" ; rdfs:comment "Finalize and seal the current receipt." .
afd:verify   a cnv:Command ; cnv:noun "affi" ; cnv:verb "verify"   ; rdfs:comment "Run the certify pipeline against a receipt." .
afd:show     a cnv:Command ; cnv:noun "affi" ; cnv:verb "show"     ; rdfs:comment "Inspect receipt details." .
