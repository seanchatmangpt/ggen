# affidavit-pack ontology — the real receipt data model and 7-stage
# certify pipeline from ~/affidavit/README.md's "Core Concepts" section,
# plus the 4 "Core Verbs (The Provenance Loop)" it names explicitly.
# The README also claims "59 canonical verbs" total; only the 4 named
# core verbs are modeled here -- the rest were not enumerated in a table
# and are not guessed.
#
# Target-API fidelity note (dated hand-verification, real source read):
# checked 2026-07-18 against the actual ~/affidavit checkout on this
# machine (crates.io `affidavit` v26.6.22, per its own Cargo.toml
# `[package] version = "26.6.22"`). Every CertifyStage label/order/comment
# triple below, and all 4 afd:Command individuals, are a byte-for-byte
# match against ~/affidavit/README.md lines 63-71 and 79-83 (not merely
# "the README" in the abstract -- the literal file inside the pinned
# source tree). `afd:sourceVersion` below records the pinned version this
# was checked against so a future re-verification has something concrete
# to diff. This is still an L2-rung check (one dated hand-verification),
# not L5 (fidelity is definitional only if affidavit itself exposed an
# ontology to track -- it does not; see pack.toml's fidelity note).

@prefix afd:  <http://seanchatmangpt.github.io/packs/affidavit#> .
@prefix cnv:  <http://seanchatmangpt.github.io/packs/clap-noun-verb#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

afd:Receipt
    a rdfs:Class ; rdfs:label "Provenance Receipt" ;
    rdfs:comment "Primary unit of evidence: an append-only, content-addressed BLAKE3 chain of operation-events." .

afd:Event
    a rdfs:Class ; rdfs:label "Event" ;
    rdfs:comment "Discrete operation record with a monotonic sequence number." .

afd:Commitment
    a rdfs:Class ; rdfs:label "Commitment" ;
    rdfs:comment "BLAKE3 digest of payload data; the payload itself is never stored in the receipt." .

afd:hasEvent      a rdf:Property ; rdfs:domain afd:Receipt ; rdfs:range afd:Event ;
    afd:minCardinality 0 ; rdfs:comment "A Receipt has zero or more Events (append-only log; empty at assembly time is legal)." .
afd:hasCommitment a rdf:Property ; rdfs:domain afd:Event ; rdfs:range afd:Commitment ;
    afd:minCardinality 1 ; afd:maxCardinality 1 ; rdfs:comment "Exactly one Commitment per Event -- payload digests are 1:1 with events." .
afd:sequenceNumber a rdf:Property ; rdfs:domain afd:Event ; rdfs:range xsd:integer ;
    afd:monotonic "strictly-increasing" ; afd:unique "true" ;
    rdfs:comment "Monotonic, unique per Receipt -- this is the exact structural property afd:Continuity (stage 4) checks." .

afd:CertifyStage
    a rdfs:Class ; rdfs:label "Certify pipeline stage" ;
    rdfs:comment "One of 7 stages every receipt passes through before an ACCEPT/REJECT verdict." .

afd:order a rdf:Property ; rdfs:domain afd:CertifyStage ; rdfs:range xsd:integer .
afd:rejectCondition a rdf:Property ; rdfs:domain afd:CertifyStage ; rdfs:range xsd:string ;
    rdfs:comment "The structural predicate that, if false, makes this stage emit REJECT and halt the pipeline (fail-fast, no later stage runs)." .

# Formal structural-predicate flags (round 3, 2026-07-18): afd:rejectCondition
# above remains prose for human docs, but afd:Continuity's actual check is now
# ALSO expressed as two independent, composable, machine-readable boolean
# facts -- afd:checksMonotonic / afd:checksUnique. These name generic,
# domain-independent structural primitives (strict-monotonicity, set-uniqueness)
# that a template can dispatch on directly, instead of only reading a free-text
# sentence a human must translate into code by hand. This does not yet reach
# a full pre/post-condition calculus (L4 "behavior contracts" bar) -- there is
# no encoded postcondition, effect, or composition operator beyond AND-of-flags
# -- but it moves afd:Continuity's specific check from "prose the template
# author transcribed" to "boolean facts the template composes", which is a
# real, verifiable step toward ontology expressiveness and shrinks the
# hand-written seam in affidavit_certify.rs.tmpl to two small, reusable,
# non-domain-specific primitives (check_strictly_increasing/check_unique)
# instead of one affidavit-specific check_continuity body. Every other stage
# below still has no boolean flags -- their rejectCondition remains prose only,
# because Decode/FormatCheck/ChainIntegrity/CommitmentVerify/ProfileEvaluation/
# FinalVerdict all require external receipt-format knowledge (see pack.toml)
# this pack does not have; adding false-by-omission flags for them would be
# fabrication, not a real fact.
afd:checksMonotonic a rdf:Property ; rdfs:domain afd:CertifyStage ; rdfs:range xsd:boolean ;
    rdfs:comment "True iff this stage's rejectCondition includes a strict-monotonicity requirement over afd:sequenceNumber. A composable structural primitive, not affidavit-specific." .
afd:checksUnique a rdf:Property ; rdfs:domain afd:CertifyStage ; rdfs:range xsd:boolean ;
    rdfs:comment "True iff this stage's rejectCondition includes a set-uniqueness requirement over afd:sequenceNumber. A composable structural primitive, not affidavit-specific." .

afd:Decode             a afd:CertifyStage ; afd:order 1 ; rdfs:label "Decode" ; rdfs:comment "Structural presence and version parsing." ;
    afd:rejectCondition "receipt bytes deserialize to a well-formed Receipt with a recognized version tag" .
afd:FormatCheck        a afd:CertifyStage ; afd:order 2 ; rdfs:label "Format Check" ; rdfs:comment "Verification against the core/v1 standard." ;
    afd:rejectCondition "every field required by the core/v1 schema is present and correctly typed" .
afd:ChainIntegrity     a afd:CertifyStage ; afd:order 3 ; rdfs:label "Chain Integrity" ; rdfs:comment "Cryptographic re-computation of the rolling hash." ;
    afd:rejectCondition "recomputed BLAKE3 rolling hash over all Events equals the receipt's stored chain seal" .
afd:Continuity         a afd:CertifyStage ; afd:order 4 ; rdfs:label "Continuity" ; rdfs:comment "Logical sequence and uniqueness validation." ;
    afd:rejectCondition "afd:sequenceNumber values across all Events are strictly increasing with no duplicates" ;
    afd:checksMonotonic true ; afd:checksUnique true .
afd:CommitmentVerify   a afd:CertifyStage ; afd:order 5 ; rdfs:label "Commitment Verify" ; rdfs:comment "Structural validation of all payload digests." ;
    afd:rejectCondition "every Event's afd:hasCommitment resolves to exactly one well-formed BLAKE3 digest" .
afd:ProfileEvaluation  a afd:CertifyStage ; afd:order 6 ; rdfs:label "Profile Evaluation" ; rdfs:comment "Conformance scoring against business logic." ;
    afd:rejectCondition "conformance score against the configured profile meets its pass threshold" .
afd:FinalVerdict       a afd:CertifyStage ; afd:order 7 ; rdfs:label "Final Verdict" ; rdfs:comment "Atomic ACCEPT or REJECT output." ;
    afd:rejectCondition "all 6 prior stages returned no rejection" .

afd:Verdict a rdfs:Class ; rdfs:label "Certify pipeline verdict" ;
    rdfs:comment "The only two atomic outcomes afd:FinalVerdict (stage 7) may produce." .
afd:Accept a afd:Verdict ; rdfs:label "ACCEPT" ; rdfs:comment "All 7 stages passed; receipt is certified." .
afd:Reject a afd:Verdict ; rdfs:label "REJECT" ; rdfs:comment "At least one stage's afd:rejectCondition was false; pipeline halted at that stage." .

afd:emit     a cnv:Command ; cnv:noun "affi" ; cnv:verb "emit"     ; rdfs:comment "Record a new operation-event." .
afd:assemble a cnv:Command ; cnv:noun "affi" ; cnv:verb "assemble" ; rdfs:comment "Finalize and seal the current receipt." .
afd:verify   a cnv:Command ; cnv:noun "affi" ; cnv:verb "verify"   ; rdfs:comment "Run the certify pipeline against a receipt." .
afd:show     a cnv:Command ; cnv:noun "affi" ; cnv:verb "show"     ; rdfs:comment "Inspect receipt details." .

# ---------------------------------------------------------------------------
# Round 5 (2026-07-21) -- cap01 partial closure for round 4's transcribed
# modules (l5-promotion program, .specify/pack-l5-promotion.ttl
# l5p:pack_affidavit's disclosed regression: round 4's src/affidavit_types.rs
# /affidavit_chain.rs/affidavit_verifier.rs were "a hardcoded,
# ontology-independent Rust port... NOT SPARQL-projected").
#
# Scope of this round, stated precisely: only the plain-data SHAPES in
# src/affidavit_types.rs -- the four structs that carry no algorithmic
# behavior of their own (ObjectRef/OperationEvent/CheckOutcome/Verdict) and
# the single-variant ProfileId enum's name<->wire-string mapping -- are
# promoted from hand-written struct/enum literals to facts below, projected
# by affidavit_types.rs.tmpl's new `structs`/`fields`/`profile_variants`
# SPARQL queries (same a_sections/fields/bounds pattern star-toml-pack and
# praxis-core-pack already proved). NOT in scope, and still hand-written
# hardcoded Rust (disclosed, not fabricated as closed): Blake3Hash's three
# methods and its Display impl (thin delegation to the `blake3` crate,
# genuinely not ontology-expressible data); Receipt's struct body, its
# `sealed()` constructor, and its custom `Deserialize` impl (the chain-hash
# forgery check -- real security logic, calls into affidavit_chain, not an
# enumerable fact); canonical_bytes/sort_value (a generic JSON-canonicalization
# algorithm with no affidavit-specific facts to derive from, same "generic
# structural primitive" treatment round 3 gave check_strictly_increasing/
# check_unique); and all of src/affidavit_chain.rs (ChainAssembler's rolling
# BLAKE3 fold_event loop) and src/affidavit_verifier.rs (the six stage_* fns'
# real format/hash/commitment checks) -- genuine algorithmic/cryptographic
# logic that would require a computation-IR in the ontology to express, not
# just data facts, and was not attempted this round. See pack.toml for the
# full disclosure of what remains hardcoded after this round.
afd:DataStruct a rdfs:Class ; rdfs:label "a plain-data Rust struct transcribed from ~/affidavit's real source" ;
    rdfs:comment "Carries only field shape (name/type/order) -- never a struct with hand-written algorithmic behavior of its own (Blake3Hash, Receipt are deliberately NOT modeled here; see round-5 disclosure above)." .
afd:DataField a rdfs:Class ; rdfs:label "a named field of an afd:DataStruct, in declared order" .

afd:structName  a rdf:Property ; rdfs:domain afd:DataStruct ; rdfs:range xsd:string .
afd:structDoc   a rdf:Property ; rdfs:domain afd:DataStruct ; rdfs:range xsd:string .
afd:structOrder a rdf:Property ; rdfs:domain afd:DataStruct ; rdfs:range xsd:integer .

afd:inStruct   a rdf:Property ; rdfs:domain afd:DataField ; rdfs:range afd:DataStruct .
afd:fieldName  a rdf:Property ; rdfs:domain afd:DataField ; rdfs:range xsd:string .
afd:fieldType  a rdf:Property ; rdfs:domain afd:DataField ; rdfs:range xsd:string ;
    rdfs:comment "The literal Rust type exactly as declared in the checksummed reference (packs/affidavit-pack/reference/affidavit_v26.6.22_src/types.rs) -- e.g. 'Option<String>' is the literal fact, not a required-flag-derived wrapper (unlike star-toml-pack's ConfigField model, this pack's fields have no separate optionality axis)." .
afd:fieldOrder a rdf:Property ; rdfs:domain afd:DataField ; rdfs:range xsd:integer .

afd:objectRefStruct a afd:DataStruct ; afd:structName "ObjectRef" ; afd:structOrder 1 ;
    afd:structDoc "A qualified reference from an operation-event to an OCEL object." .
afd:objectRefStruct_id        a afd:DataField ; afd:inStruct afd:objectRefStruct ; afd:fieldName "id"        ; afd:fieldType "String"         ; afd:fieldOrder 1 .
afd:objectRefStruct_objType   a afd:DataField ; afd:inStruct afd:objectRefStruct ; afd:fieldName "obj_type"  ; afd:fieldType "String"         ; afd:fieldOrder 2 .
afd:objectRefStruct_qualifier a afd:DataField ; afd:inStruct afd:objectRefStruct ; afd:fieldName "qualifier" ; afd:fieldType "Option<String>" ; afd:fieldOrder 3 .

afd:operationEventStruct a afd:DataStruct ; afd:structName "OperationEvent" ; afd:structOrder 2 ;
    afd:structDoc "A single append-only operation-event in a receipt chain." .
afd:operationEventStruct_id                a afd:DataField ; afd:inStruct afd:operationEventStruct ; afd:fieldName "id"                 ; afd:fieldType "String"            ; afd:fieldOrder 1 .
afd:operationEventStruct_seq               a afd:DataField ; afd:inStruct afd:operationEventStruct ; afd:fieldName "seq"                ; afd:fieldType "u64"               ; afd:fieldOrder 2 .
afd:operationEventStruct_eventType         a afd:DataField ; afd:inStruct afd:operationEventStruct ; afd:fieldName "event_type"         ; afd:fieldType "String"            ; afd:fieldOrder 3 .
afd:operationEventStruct_objects           a afd:DataField ; afd:inStruct afd:operationEventStruct ; afd:fieldName "objects"            ; afd:fieldType "Vec<ObjectRef>"    ; afd:fieldOrder 4 .
afd:operationEventStruct_payloadCommitment a afd:DataField ; afd:inStruct afd:operationEventStruct ; afd:fieldName "payload_commitment" ; afd:fieldType "Blake3Hash"        ; afd:fieldOrder 5 .

afd:checkOutcomeStruct a afd:DataStruct ; afd:structName "CheckOutcome" ; afd:structOrder 3 ;
    afd:structDoc "The result of a single decidable pipeline stage." .
afd:checkOutcomeStruct_stage  a afd:DataField ; afd:inStruct afd:checkOutcomeStruct ; afd:fieldName "stage"  ; afd:fieldType "String" ; afd:fieldOrder 1 .
afd:checkOutcomeStruct_passed a afd:DataField ; afd:inStruct afd:checkOutcomeStruct ; afd:fieldName "passed" ; afd:fieldType "bool"   ; afd:fieldOrder 2 .
afd:checkOutcomeStruct_detail a afd:DataField ; afd:inStruct afd:checkOutcomeStruct ; afd:fieldName "detail" ; afd:fieldType "String" ; afd:fieldOrder 3 .

afd:verdictStruct a afd:DataStruct ; afd:structName "Verdict" ; afd:structOrder 4 ;
    afd:structDoc "The final verdict of the certify pipeline over a receipt." .
afd:verdictStruct_accepted a afd:DataField ; afd:inStruct afd:verdictStruct ; afd:fieldName "accepted" ; afd:fieldType "bool"            ; afd:fieldOrder 1 .
afd:verdictStruct_profile  a afd:DataField ; afd:inStruct afd:verdictStruct ; afd:fieldName "profile"  ; afd:fieldType "ProfileId"       ; afd:fieldOrder 2 .
afd:verdictStruct_outcomes a afd:DataField ; afd:inStruct afd:verdictStruct ; afd:fieldName "outcomes" ; afd:fieldType "Vec<CheckOutcome>" ; afd:fieldOrder 3 .
afd:verdictStruct_reason   a afd:DataField ; afd:inStruct afd:verdictStruct ; afd:fieldName "reason"   ; afd:fieldType "String"          ; afd:fieldOrder 4 .

afd:ProfileIdVariant a rdfs:Class ; rdfs:label "a variant of the afd:ProfileId enum, with its as_str() wire-format mapping" .
afd:variantName  a rdf:Property ; rdfs:domain afd:ProfileIdVariant ; rdfs:range xsd:string .
afd:variantStr   a rdf:Property ; rdfs:domain afd:ProfileIdVariant ; rdfs:range xsd:string .
afd:variantOrder a rdf:Property ; rdfs:domain afd:ProfileIdVariant ; rdfs:range xsd:integer .

afd:profileIdCoreV1 a afd:ProfileIdVariant ; afd:variantName "CoreV1" ; afd:variantStr "core/v1" ; afd:variantOrder 1 .
