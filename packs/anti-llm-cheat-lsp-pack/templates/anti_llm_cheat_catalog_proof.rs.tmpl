---
to: tests/anti_llm_cheat_catalog_proof.rs
freeze_policy: checksum
freeze_slots_dir: .ggen/freeze/anti-llm-cheat-lsp-pack
sparql:
  layers: |
    PREFIX alc: <http://seanchatmangpt.github.io/packs/anti-llm-cheat-lsp#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?order ?label ?doc WHERE {
      ?l a alc:DetectorLayer ; alc:order ?order ; rdfs:label ?label ; rdfs:comment ?doc .
    } ORDER BY ?order
  rules: |
    PREFIX alc: <http://seanchatmangpt.github.io/packs/anti-llm-cheat-lsp#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    SELECT ?rule_id ?label ?doc ?pattern ?pattern_kind WHERE {
      ?r a alc:Rule ; alc:ruleId ?rule_id ; rdfs:label ?label ; rdfs:comment ?doc ;
         alc:pattern ?pattern ; alc:patternKind ?pattern_kind .
    } ORDER BY ?rule_id
---
//! Data-fidelity proof for `anti-llm-cheat-lsp-pack`'s generated catalog.
//!
//! GENERATED by `anti-llm-cheat-lsp-pack`. Unlike an earlier version of this
//! template, the per-row assertions below are emitted by looping over the
//! *same* `layers`/`rules` SPARQL bindings the catalog template consumes --
//! a human is no longer transcribing literals by hand into this file. A
//! corrupted binding, a broken Tera loop, or a bad ontology edit changes
//! both `DETECTOR_LAYERS`/`DETECTION_RULES` *and* this file's expectations
//! together, from the same source query, at the same `ggen sync`.
//!
//! This still isn't a re-query at test time (there is no live triplestore
//! at `cargo test` time to ask "does the compiled catalog match the graph
//! right now?") -- it is a compile-time-baked comparison of two independent
//! renders of one query. The behavioral tests below (`scan_for_dead_alt`/
//! `scan_for_hedge` against adversarial input strings, plus the
//! `dead_alt_tests`/`hedge_tests` modules pulled in via `#[path]` below,
//! which are the real target's own test bodies) are what make this a proof
//! of behavior rather than only of data-transcription fidelity.
//!
//! `mod config` here mirrors `anti_llm_cheat_lib_wiring.rs.tmpl`'s inline
//! `AntiLlmConfig` port: this file is its own separate crate root (every
//! file under `tests/` is), so the `crate::config::AntiLlmConfig` references
//! inside the path-included `dead_alt_tests` module (see
//! `anti_llm_cheat_catalog.rs`) need a `config` module declared at *this*
//! crate's root too.
pub mod config {
    #[derive(Debug, Default, Clone)]
    pub struct AntiLlmConfig {
        pub allowed_suppression_paths: Vec<String>,
    }

    impl AntiLlmConfig {
        pub fn is_suppression_allowed(&self, file_path: &str) -> bool {
            self.allowed_suppression_paths.iter().any(|path| file_path.contains(path))
        }
    }
}

#[path = "../src/anti_llm_cheat_catalog.rs"]
mod anti_llm_cheat_catalog;

use anti_llm_cheat_catalog::{
    scan_for_dead_alt, scan_for_hedge, DetectionRule, DetectorLayer, DETECTION_RULES,
    DETECTOR_LAYERS,
};

#[test]
fn detector_layer_count_matches_ontology() {
    assert_eq!(DETECTOR_LAYERS.len(), {{ layers | length }});
}

#[test]
fn detection_rule_count_matches_ontology() {
    // ontology.ttl declares {{ rules | length }} alc:Rule individuals (its
    // README states the full rule set is larger; only these are tabulated).
    assert_eq!(DETECTION_RULES.len(), {{ rules | length }});
}

#[test]
fn detector_layers_are_contiguously_ordered() {
    // Structural invariant on the *generated* array itself -- order values
    // must be 1..=N and match array position. Not a re-query.
    for (i, layer) in DETECTOR_LAYERS.iter().enumerate() {
        assert_eq!(layer.order, (i + 1) as u32);
    }
}
{% for row in layers %}
#[test]
fn detector_layer_{{ loop.index0 }}_matches_ontology() {
    let expected = DetectorLayer {
        order: {{ row.order }},
        label: "{{ row.label }}",
        doc: "{{ row.doc }}",
    };
    assert_eq!(DETECTOR_LAYERS[{{ loop.index0 }}], expected);
}
{% endfor %}
{% for row in rules %}
#[test]
fn detection_rule_{{ loop.index0 }}_matches_ontology() {
    let expected = DetectionRule {
        rule_id: "{{ row.rule_id }}",
        label: "{{ row.label }}",
        doc: "{{ row.doc }}",
        pattern: "{{ row.pattern }}",
        pattern_kind: "{{ row.pattern_kind }}",
    };
    assert_eq!(DETECTION_RULES[{{ loop.index0 }}], expected);
}
{% endfor %}

#[test]
fn rule_ids_follow_the_anti_llm_naming_convention() {
    // Structural invariant on rule_id format -- not derivable from
    // re-running the emitting query.
    for rule in DETECTION_RULES {
        assert!(rule.rule_id.starts_with("ANTI-LLM-"));
        assert!(rule.rule_id.ends_with("-001"));
    }
}

// --- Behavioral proofs: exercise the generated detector functions against
// concrete, adversarial inputs. These certify actual subsystem behavior
// (Generation depth / Test generation), not merely that a data table was
// transcribed correctly.

#[test]
fn scan_for_dead_alt_flags_uncalled_v2_function() {
    let src = "fn run_with_timeout_v2(ms: u64) -> bool {\n    true\n}\n";
    let hits = scan_for_dead_alt("example.rs", src);
    assert_eq!(hits.len(), 1);
    assert_eq!(hits[0].construct, "run_with_timeout_v2");
    assert_eq!(hits[0].line, 1);
}

#[test]
fn scan_for_dead_alt_does_not_flag_a_called_alt_function() {
    let src = "fn foo_alt() -> u32 {\n    1\n}\n\nfn main() {\n    let _ = foo_alt();\n}\n";
    assert!(scan_for_dead_alt("example.rs", src).is_empty());
}

#[test]
fn scan_for_dead_alt_ignores_functions_without_a_configured_suffix() {
    let src = "fn foo_bar() -> u32 {\n    1\n}\n";
    assert!(scan_for_dead_alt("example.rs", src).is_empty());
}

#[test]
fn scan_for_hedge_flags_in_a_real_implementation_comment() {
    let src = "// In a real implementation, this would call the API.\nfn stub() {}\n";
    let hits = scan_for_hedge("test.rs", src);
    assert_eq!(hits.len(), 1);
    assert_eq!(hits[0].line, 1);
}

#[test]
fn scan_for_hedge_flags_for_now_comment_case_insensitively() {
    let src = "// FOR NOW, we skip validation entirely.\n";
    let hits = scan_for_hedge("test.rs", src);
    assert_eq!(hits.len(), 1);
}

#[test]
fn scan_for_hedge_ignores_non_comment_lines_containing_hedge_words() {
    // The literal phrase appears, but not inside a `//` comment -- the real
    // target's scanner only fires on comment lines, and this is now the
    // target's actual regex (via the `regex` crate), not an approximation.
    let src = "let s = \"for now, this is fine\";\n";
    assert!(scan_for_hedge("test.rs", src).is_empty());
}
