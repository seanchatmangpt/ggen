//! Data-fidelity proof for `anti-llm-cheat-lsp-pack`'s generated catalog.
//!
//! GENERATED by `anti-llm-cheat-lsp-pack`. This pack is pure data: its
//! catalog template emits only two plain structs and two static slices, no
//! functions beyond field literals -- so there is no behavior to exercise
//! with concrete inputs. Instead this proof pins the *compiled* catalog's
//! literal contents against values hand-transcribed from
//! `packs/anti-llm-cheat-lsp-pack/ontology.ttl` by the pack author, entirely
//! independent of the SPARQL query that produced them at generation time. A
//! corrupted binding, a broken Tera loop, or a bad ontology edit would
//! change `DETECTOR_LAYERS`/`DETECTION_RULES` without changing this file --
//! and these assertions would fail.

#[path = "../src/anti_llm_cheat_catalog.rs"]
mod anti_llm_cheat_catalog;

use anti_llm_cheat_catalog::{DetectionRule, DetectorLayer, DETECTION_RULES, DETECTOR_LAYERS};

#[test]
fn detector_layer_count_matches_ontology() {
    // ontology.ttl declares exactly 6 alc:DetectorLayer individuals.
    assert_eq!(DETECTOR_LAYERS.len(), 6);
}

#[test]
fn detection_rule_count_matches_ontology() {
    // ontology.ttl declares exactly 2 alc:Rule individuals (its README
    // states the full rule set is larger; only these 2 are tabulated).
    assert_eq!(DETECTION_RULES.len(), 2);
}

#[test]
fn detector_layers_are_contiguously_ordered() {
    // Structural invariant on the *generated* array itself -- order values
    // must be 1..=6 and match array position. Not a re-query.
    for (i, layer) in DETECTOR_LAYERS.iter().enumerate() {
        assert_eq!(layer.order, (i + 1) as u32);
    }
}

#[test]
fn raw_text_scanner_matches_ontology() {
    let expected = DetectorLayer {
        order: 1,
        label: "Raw Text Scanner",
        doc: "Detects forbidden victory-claim terms, SemVer template defaults, log-based routing indicators.",
    };
    assert_eq!(DETECTOR_LAYERS[0], expected);
}

