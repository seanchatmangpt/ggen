/// Direct port of `~/anti-llm-cheat-lsp/src/rules/dead_alt.rs::extract_fn_name`,
/// unchanged.
fn extract_fn_name(trimmed: &str) -> Option<&str> {
    let mut s = trimmed;

    if s.starts_with("pub(") {
        let close = s.find(')')?;
        s = s[close + 1..].trim_start();
    } else if s.starts_with("pub") {
        s = s["pub".len()..].trim_start();
    }

    for _ in 0..4 {
        if s.starts_with("async") && s[5..].starts_with(|c: char| c.is_whitespace()) {
            s = s[5..].trim_start();
        } else if s.starts_with("unsafe") && s[6..].starts_with(|c: char| c.is_whitespace()) {
            s = s[6..].trim_start();
        } else if s.starts_with("extern") {
            let fn_pos = s.find("fn ")?;
            s = &s[fn_pos..];
            break;
        } else {
            break;
        }
    }

    if !s.starts_with("fn ") {
        return None;
    }
    s = s["fn ".len()..].trim_start();

    let end = s.find(|c: char| !c.is_alphanumeric() && c != '_').unwrap_or(s.len());
    if end == 0 {
        return None;
    }
    Some(&s[..end])
}

/// Direct port of `~/anti-llm-cheat-lsp/src/rules/dead_alt.rs::scan_for_dead_alt`.
/// The only change from the target: `ALT_SUFFIXES` (a local `const`) is
/// replaced by a lookup into `DETECTION_RULES` for `ANTI-LLM-DEAD-ALT-001`'s
/// `alc:pattern` (`patternKind = "suffix_list"`), so the suffix list
/// precipitates from the ontology instead of being duplicated by hand.
pub fn scan_for_dead_alt(filepath: &str, content: &str) -> Vec<Observation> {
    if !filepath.ends_with(".rs") {
        return Vec::new();
    }

    let alt_suffixes: Vec<&str> = DETECTION_RULES
        .iter()
        .find(|r| r.rule_id == "ANTI-LLM-DEAD-ALT-001" && r.pattern_kind == "suffix_list")
        .map(|r| r.pattern.split(' ').collect())
        .unwrap_or_default();

    let lines: Vec<&str> = content.lines().collect();
    let mut obs = Vec::new();

    for (line_idx, line) in lines.iter().enumerate() {
        let line_num = line_idx + 1;
        let trimmed = line.trim_start();

        let fn_name = extract_fn_name(trimmed);
        let fn_name = match fn_name {
            Some(n) => n,
            None => continue,
        };

        let has_alt_suffix =
            alt_suffixes.iter().any(|suffix| fn_name == *suffix || fn_name.ends_with(suffix));
        if !has_alt_suffix {
            continue;
        }

        let call_site_count = lines
            .iter()
            .enumerate()
            .filter(|(idx, l)| *idx != line_idx && l.contains(fn_name))
            .count();

        if call_site_count == 0 {
            obs.push(Observation {
                file_path: filepath.to_string(),
                start_byte: 0,
                end_byte: 0,
                line: line_num,
                column: 1,
                kind: "dead_alt_smell".to_string(),
                construct: fn_name.to_string(),
                context: line.to_string(),
                message: format!(
                    "Dead alternative function '{}' defined on line {} but never called",
                    fn_name, line_num
                ),
            });
        }
    }

    obs
}

/// Direct port of `~/anti-llm-cheat-lsp/src/rules/dead_alt.rs::evaluate`.
pub fn evaluate(obs: &[Observation], config: &crate::config::AntiLlmConfig) -> Vec<AntiLlmDiagnostic> {
    let mut diags = Vec::new();

    for o in obs {
        if o.kind != "dead_alt_smell" {
            continue;
        }
        if config.is_suppression_allowed(&o.file_path) {
            continue;
        }

        diags.push(AntiLlmDiagnostic {
            code: "ANTI-LLM-DEAD-ALT-001".to_string(),
            category: "dead_alternative".to_string(),
            file_path: o.file_path.clone(),
            line: o.line,
            column: o.column,
            message: format!(
                "Dead alternative function '{}' — defined but never called; broken primary may be in use",
                o.construct
            ),
            forbidden_implication: format!(
                "DeadAlternative({}) => BrokenPrimaryInUse",
                o.construct
            ),
            blocking: true,
            required_correction:
                "Either use the correct alternative function or delete it".to_string(),
            required_next_proof:
                "Show that only one version exists and it is the correct one".to_string(),
        });
    }

    diags
}

/// Direct port of `~/anti-llm-cheat-lsp/src/rules/hedge.rs::is_comment_line`.
fn is_comment_line(trimmed: &str) -> bool {
    trimmed.starts_with("//")
}

/// Looks up `ANTI-LLM-HEDGE-001`'s `alc:pattern` (`patternKind = "regex"`) and
/// compiles it with the `regex` crate -- the exact regex the real target
/// compiles in `hedge_re()`, not a substring approximation of it.
fn hedge_re() -> &'static Regex {
    static RE: OnceLock<Regex> = OnceLock::new();
    RE.get_or_init(|| {
        let pattern = DETECTION_RULES
            .iter()
            .find(|r| r.rule_id == "ANTI-LLM-HEDGE-001" && r.pattern_kind == "regex")
            .map(|r| r.pattern)
            .unwrap_or(r"(?i)$^"); // never matches, if the rule is ever removed from the ontology
        Regex::new(pattern).unwrap()
    })
}

/// Direct port of `~/anti-llm-cheat-lsp/src/rules/hedge.rs::scan_for_hedge`.
pub fn scan_for_hedge(filepath: &str, content: &str) -> Vec<Observation> {
    let mut obs = Vec::new();
    let mut in_block_comment = false;

    for (line_idx, line) in content.lines().enumerate() {
        let line_num = line_idx + 1;
        let trimmed = line.trim_start();

        if trimmed.starts_with("/*") {
            in_block_comment = true;
        }

        let is_comment = in_block_comment || is_comment_line(trimmed);

        if is_comment {
            if let Some(m) = hedge_re().find(line) {
                let matched_phrase = m.as_str().to_string();
                obs.push(Observation {
                    file_path: filepath.to_string(),
                    start_byte: 0,
                    end_byte: 0,
                    line: line_num,
                    column: 1,
                    kind: "hedge_smell".to_string(),
                    construct: matched_phrase.clone(),
                    context: line.to_string(),
                    message: format!(
                        "Hedge comment '{}' detected on line {}",
                        matched_phrase, line_num
                    ),
                });
            }
        }

        if in_block_comment && line.contains("*/") {
            in_block_comment = false;
        }
    }

    obs
}

/// Direct port of `~/anti-llm-cheat-lsp/src/rules/hedge.rs::evaluate` (renamed
/// `evaluate_hedge` here since both dead_alt's and hedge's `evaluate` live in
/// the same generated module, unlike the target where they live in separate
/// files and can share the name).
pub fn evaluate_hedge(obs: &[Observation], config: &crate::config::AntiLlmConfig) -> Vec<AntiLlmDiagnostic> {
    let mut diags = Vec::new();

    for o in obs {
        if o.kind != "hedge_smell" {
            continue;
        }
        if config.is_suppression_allowed(&o.file_path) {
            continue;
        }

        diags.push(AntiLlmDiagnostic {
            code: "ANTI-LLM-HEDGE-001".to_string(),
            category: "hedge_implementation".to_string(),
            file_path: o.file_path.clone(),
            line: o.line,
            column: o.column,
            message: format!(
                "Hedge comment detected: '{}' — implementation admitted incomplete via comment",
                o.construct
            ),
            forbidden_implication: format!(
                "HedgeComment({}) => IncompleteImplementation",
                o.construct
            ),
            blocking: true,
            required_correction:
                "Remove the hedge comment and either complete the implementation or use todo!()"
                    .to_string(),
            required_next_proof: "Show the completed implementation with no hedging language"
                .to_string(),
        });
    }

    diags
}

