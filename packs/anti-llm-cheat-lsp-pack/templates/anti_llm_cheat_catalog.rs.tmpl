//! Typed catalog of ~/anti-llm-cheat-lsp's 6-layer detector stack and its 2
//! tabulated detection rules, transcribed from
//! `packs/anti-llm-cheat-lsp-pack/ontology.ttl`.
//!
//! Generated by `anti-llm-cheat-lsp-pack`. Reference only -- this crate does
//! not run the LSP server itself, but `scan_dead_alt`/`scan_hedge` below are
//! real, callable detector logic whose patterns precipitate from
//! `ontology.ttl`'s `alc:pattern`/`alc:patternKind` facts, not hardcoded in
//! this template.

/// One layer of the multi-layered detector stack.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct DetectorLayer {
    pub order: u32,
    pub label: &'static str,
    pub doc: &'static str,
}

/// Detector layers, ordered.
pub const DETECTOR_LAYERS: &[DetectorLayer] = &[
{% for row in layers %}    DetectorLayer { order: {{ row.order }}, label: "{{ row.label }}", doc: "{{ row.doc }}" },
{% endfor %}];

/// One named, ID'd detection rule, carrying its actual detection pattern
/// (`pattern`/`pattern_kind`) alongside its metadata -- not just a label.
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct DetectionRule {
    pub rule_id: &'static str,
    pub label: &'static str,
    pub doc: &'static str,
    pub pattern: &'static str,
    pub pattern_kind: &'static str,
}

/// Tabulated rules (the README states the full rule set is larger; only
/// the tabulated rows are modeled -- see the pack's own description).
pub const DETECTION_RULES: &[DetectionRule] = &[
{% for row in rules %}    DetectionRule { rule_id: "{{ row.rule_id }}", label: "{{ row.label }}", doc: "{{ row.doc }}", pattern: "{{ row.pattern }}", pattern_kind: "{{ row.pattern_kind }}" },
{% endfor %}];

/// One occurrence of a dead-alternative-function name found in `source`.
#[derive(Debug, Clone, PartialEq, Eq)]
pub struct DeadAltHit<'a> {
    pub line: usize,
    pub name: &'a str,
}

/// Real detector behavior for `ANTI-LLM-DEAD-ALT-001`, driven entirely by the
/// `alc:pattern` (`patternKind = "suffix_list"`) fact on `alc:DeadAlt` in
/// `ontology.ttl` -- the suffix list below is looked up from
/// `DETECTION_RULES`, not hardcoded in this function body. Flags `fn <name>`
/// definitions whose name ends with a configured suffix and that are never
/// referenced again in `source`. This mirrors (a simplified form of) the
/// real target's `dead_alt::scan_for_dead_alt`.
pub fn scan_dead_alt(source: &str) -> Vec<DeadAltHit<'_>> {
    let suffixes: Vec<&str> = DETECTION_RULES
        .iter()
        .find(|r| r.rule_id == "ANTI-LLM-DEAD-ALT-001" && r.pattern_kind == "suffix_list")
        .map(|r| r.pattern.split(' ').collect())
        .unwrap_or_default();

    let lines: Vec<&str> = source.lines().collect();
    let mut hits = Vec::new();

    for (idx, line) in lines.iter().enumerate() {
        let trimmed = line.trim_start();
        let after_fn = trimmed
            .strip_prefix("pub fn ")
            .or_else(|| trimmed.strip_prefix("fn "))
            .or_else(|| trimmed.strip_prefix("pub async fn "))
            .or_else(|| trimmed.strip_prefix("async fn "));
        let Some(rest) = after_fn else { continue };
        let name = rest.split(|c: char| c == '(' || c.is_whitespace()).next().unwrap_or("");
        if name.is_empty() {
            continue;
        }
        let matches_suffix = suffixes.iter().any(|s| name.ends_with(s));
        if !matches_suffix {
            continue;
        }
        let referenced_elsewhere =
            lines.iter().enumerate().any(|(other_idx, l)| other_idx != idx && l.contains(name));
        if !referenced_elsewhere {
            hits.push(DeadAltHit { line: idx + 1, name });
        }
    }
    hits
}

/// Real detector behavior for `ANTI-LLM-HEDGE-001`: returns every line of
/// `source` whose trimmed form starts with `//` and matches the hedge phrase
/// list carried in `alc:pattern` (`patternKind = "regex"`) on `alc:Hedge`.
/// The phrase list is parsed out of the ontology-sourced pattern string at
/// call time (a `(a|b|c)` alternation group), not duplicated by hand here --
/// so editing `ontology.ttl`'s pattern is the only way to change what this
/// function flags.
pub fn scan_hedge(source: &str) -> Vec<(usize, &str)> {
    let rule = DETECTION_RULES
        .iter()
        .find(|r| r.rule_id == "ANTI-LLM-HEDGE-001" && r.pattern_kind == "regex");
    let Some(rule) = rule else { return Vec::new() };
    // Pull the plain-text alternatives out of the `(?i)(a|b|c|...)` pattern.
    // This is a deliberately simple parse (no regex engine dependency): it
    // extracts the literal alternatives, splits each on the small set of
    // regex metacharacters the real patterns use, and matches the
    // longest surviving literal fragment as a substring. This is a
    // conservative approximation of the real regex, not a full regex
    // engine -- see the pack's Regeneration lifecycle / Ontology
    // expressiveness notes for what a full-fidelity version would need.
    let inner = rule.pattern.trim_start_matches("(?i)").trim_start_matches('(').trim_end_matches(')');
    let phrases: Vec<&str> = inner
        .split('|')
        .map(|alt| {
            alt.split(|c: char| "?()'".contains(c))
                .max_by_key(|s| s.len())
                .unwrap_or(alt)
                .trim()
        })
        .filter(|s| s.len() > 3)
        .collect();

    let mut hits = Vec::new();
    for (idx, line) in source.lines().enumerate() {
        let trimmed = line.trim_start();
        if !trimmed.starts_with("//") {
            continue;
        }
        let lower = trimmed.to_ascii_lowercase();
        if phrases.iter().any(|p| lower.contains(&p.to_ascii_lowercase())) {
            hits.push((idx + 1, line));
        }
    }
    hits
}
