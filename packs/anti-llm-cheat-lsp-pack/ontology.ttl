# anti-llm-cheat-lsp-pack ontology — the 6-layer detector stack and the
# 2 tabulated rules from ~/anti-llm-cheat-lsp/README.md. The README states
# the rule set is larger than this table; only the tabulated rows are
# modeled (no rule was invented to round out the set).
#
# Target-fidelity verification pass (2026-07-18): the two rules' `alc:pattern`
# values below were re-checked directly against the target's own source
# (not just its README) on this date:
#   - alc:DeadAlt's alc:altSuffix values == the literal `ALT_SUFFIXES` array
#     in ~/anti-llm-cheat-lsp/src/rules/dead_alt.rs:3-5.
#   - alc:Hedge's alc:pattern value == the literal regex in
#     ~/anti-llm-cheat-lsp/src/rules/hedge.rs:10-12 (`hedge_re()`), including
#     the `(?i)` case-insensitivity flag.
# This satisfies L2 target-API fidelity ("verified by hand against one
# target version, once"). It does not reach L5 ("fidelity is definitional,
# not checked") -- these are still copied literals that can silently drift
# from the target's next edit; nothing here re-derives them automatically.

@prefix alc:  <http://seanchatmangpt.github.io/packs/anti-llm-cheat-lsp#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

alc:DetectorLayer
    a rdfs:Class ; rdfs:label "Detector layer" ;
    rdfs:comment "One layer of the multi-layered detector stack that produces diagnostics." .

alc:order a rdf:Property ; rdfs:domain alc:DetectorLayer ; rdfs:range xsd:integer .

alc:RawTextScanner    a alc:DetectorLayer ; alc:order 1 ; rdfs:label "Raw Text Scanner" ; rdfs:comment "Detects forbidden victory-claim terms, SemVer template defaults, log-based routing indicators." .
alc:TreeSitterScanner a alc:DetectorLayer ; alc:order 2 ; rdfs:label "Tree-Sitter AST Scanner" ; rdfs:comment "Traverses Rust source for plain tower-lsp imports, unsafe smells (unwrap/panic), direct writes to read-only paths." .
alc:ManifestParser    a alc:DetectorLayer ; alc:order 3 ; rdfs:label "Cargo Manifest Parser" ; rdfs:comment "Verifies Cargo.toml/Cargo.lock reject plain tower-lsp and enforce CalVer." .
alc:MarkdownParser    a alc:DetectorLayer ; alc:order 4 ; rdfs:label "Markdown Claims Parser" ; rdfs:comment "Checks docs for overclaim victory words or unverified route claims." .
alc:TranscriptParser  a alc:DetectorLayer ; alc:order 5 ; rdfs:label "JSON-RPC Transcript Parser" ; rdfs:comment "Validates initialize capability transcripts request LSP 3.18 features, not plain-LSP fallback." .
alc:ReceiptValidator  a alc:DetectorLayer ; alc:order 6 ; rdfs:label "Receipt JSON Validator" ; rdfs:comment "Inspects BLAKE3-signed receipts to verify mutations carry real admission proof." .

alc:Rule
    a rdfs:Class ; rdfs:label "Detection rule" ;
    rdfs:comment "A named, ID'd pattern this canary flags as evidence of LLM-generated cheating." .

alc:ruleId a rdf:Property ; rdfs:domain alc:Rule ; rdfs:range xsd:string .

# alc:pattern carries the ACTUAL detection behavior for the rule -- either a
# regex (for regex-shaped rules) or a space-separated list of literal suffixes
# (for suffix-shaped rules; alc:patternKind distinguishes the two so a
# generated function knows how to interpret the string instead of guessing).
# Sourced verbatim from the target's own rule modules (see verification note
# at the top of this file), not invented -- this is what lets the generated
# catalog carry real, executable detector behavior instead of merely naming
# that a rule exists.
alc:pattern     a rdf:Property ; rdfs:domain alc:Rule ; rdfs:range xsd:string .
alc:patternKind a rdf:Property ; rdfs:domain alc:Rule ; rdfs:range xsd:string .

alc:DeadAlt
    a alc:Rule ; alc:ruleId "ANTI-LLM-DEAD-ALT-001" ;
    rdfs:label "Dead alternative functions" ;
    rdfs:comment "Functions like _v2/_alt/_correct/_fixed/_working defined but never called." ;
    alc:patternKind "suffix_list" ;
    alc:pattern "_v2 _v3 _alt _correct _real _proper _fixed _working _new _better" .

alc:Hedge
    a alc:Rule ; alc:ruleId "ANTI-LLM-HEDGE-001" ;
    rdfs:label "Hedge comments" ;
    rdfs:comment "Comments admitting incomplete implementation, e.g. 'In a real implementation...', 'For now...'." ;
    alc:patternKind "regex" ;
    alc:pattern "(?i)(in a real implementation|for now,? (we('ll)?|this)|temporary workaround|this is a placeholder|stub implementation|not yet implemented|will be replaced|production implementation would|todo: replace this with a real)" .
