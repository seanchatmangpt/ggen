@prefix retrofit: <https://ggen.dev/ontology/retrofit#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .

# Load-path facts for ggen's 6 real load paths, as-found 2026-07-20.
# Grounded in: docs/retrofit/ggen/as-found/{repository,generation-system,
# architecture-semantics}.md, this-pass gh api checks (branch protection 404,
# single collaborator), and .github/workflows/release.yml inspection.
# retrofit:standing values: "Blocking" | "Accepted" | "Unknown" — never silently
# filled; see retrofit:evidence / retrofit:evidencePath on each individual.

retrofit:LoadPath a rdfs:Class .
retrofit:SPOF a rdfs:Class .

retrofit:standing a rdf:Property ;
    rdfs:comment "Blocking | Accepted | Unknown" .
retrofit:evidence a rdf:Property ;
    rdfs:comment "Free-text pointer to the as-found evidence backing this fact." .
retrofit:evidencePath a rdf:Property ;
    rdfs:comment "Repo-relative path to the evidence artifact." .
retrofit:affects a rdf:Property ;
    rdfs:domain retrofit:SPOF ;
    rdfs:range retrofit:LoadPath .

## ---------------------------------------------------------------- Load paths

retrofit:GenerationPath a retrofit:LoadPath ;
    rdfs:label "Generation" ;
    retrofit:entryPoint "crates/ggen-engine/src/sync.rs" ;
    retrofit:evidencePath "docs/retrofit/ggen/as-found/generation-system.md" .

retrofit:SelfGenerationPath a retrofit:LoadPath ;
    rdfs:label "Self-generation" ;
    retrofit:entryPoint ".ggen-v2/receipt.json" ;
    retrofit:evidencePath "docs/retrofit/ggen/as-found/generation-system.md" .

retrofit:PullRequestPath a retrofit:LoadPath ;
    rdfs:label "Pull-request" ;
    retrofit:entryPoint ".github/workflows/ci.yml" ;
    retrofit:evidence "gh api repos/seanchatmangpt/ggen/branches/main/protection -> 404" .

retrofit:ReleasePath a retrofit:LoadPath ;
    rdfs:label "Release" ;
    retrofit:entryPoint ".github/workflows/release.yml" ;
    retrofit:evidence "release.yml: on: push: tags: + workflow_dispatch, confirmed by direct read" .

retrofit:ConstitutionPath a retrofit:LoadPath ;
    rdfs:label "Constitution" ;
    retrofit:entryPoint "packs/ggen-constitution-pack/ontology.ttl" ;
    retrofit:evidencePath "docs/retrofit/ggen/as-found/architecture-semantics.md" .

retrofit:FleetManagementPath a retrofit:LoadPath ;
    rdfs:label "Fleet-management" ;
    retrofit:entryPoint "scripts/gh/fleet-census.sh" ;
    retrofit:evidencePath "docs/gh-terraform/FLEET-CENSUS.md" .

## ---------------------------------------------------------------- SPOFs

retrofit:SchemaDispatchAmbiguity a retrofit:SPOF ;
    rdfs:label "ggen.toml two-schema dispatch has no cross-drift guard" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:GenerationPath ;
    retrofit:evidence "generation_rules.rs:108 has_generation_rules; raw-text pre-parse, no shared validator between GgenManifest and GgenConfig" .

retrofit:GeneratedTableDriftManifested a retrofit:SPOF ;
    rdfs:label "Generated architecture.md pack-inventory table observed stale twice" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:GenerationPath, retrofit:SelfGenerationPath ;
    retrofit:evidence "28-vs-32 then 32-vs-33 pack count drift, docs/retrofit/ggen/as-found/architecture-semantics.md finding 6" .

retrofit:FreezeAlwaysNoDriftDetection a retrofit:SPOF ;
    retrofit:evidenceUpdate2026_07_21 "CONFIRMED, still Blocking, real blast radius measured: crates/ggen-engine/src/write.rs's decision order (its own module doc, lines 8-18) shows FreezePolicy::Always (~line 165-172) unconditionally returns Skipped when the target exists -- zero content comparison, unlike the sibling FreezePolicy::Checksum path (step 5 in the same decision order) which explicitly detects on-disk drift against ggen's last-recorded checksum before skipping. So an ontology/template change that would alter a freeze-always-policy file's content produces silent, permanent staleness with no warning, no drift signal, nothing -- exactly the SPOF's original claim, now precisely located in code rather than a bare file pointer. Real usage: 27 templates across packs/ declare freeze_policy (grep -rl freeze_policy packs/*/templates/). NOT fixed here: adding drift detection to Always mode is a real design change (would it warn, refuse, or just report? does it change behavior for templates deliberately relying on hand-completed bootstrap semantics, per this repo's own mode=Create precedent in CLAUDE.md?) -- needs the same dedicated attention as O-7b and StandingCeilingHardcoded's promotion mechanism, not a rushed patch." ;
    rdfs:label "write.rs freeze policy 'always' skips unconditionally with no drift check" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:GenerationPath ;
    retrofit:evidencePath "crates/ggen-engine/src/write.rs" .

retrofit:ReflexiveReceiptSkip a retrofit:SPOF ;
    rdfs:label "Sanctioned silent-skip of malformed reflexive-receipt log line" ;
    retrofit:standing "Accepted" ;
    retrofit:affects retrofit:GenerationPath ;
    retrofit:evidence "CONFIRMED via direct code read, crates/ggen-engine/src/sync.rs ~L312-355: only active when [law].reflexive=true (opt-in, off by default -- bounded blast radius). A malformed receipt-log.jsonl line is NOT silently dropped: its own comment names this as the one deliberate exception to fail-closed elsewhere in the pipeline (the log is external history not byte-controlled by this sync's author -- an older-tool-version or hand-edited line must not brick every future sync), and the skip IS recorded, not hidden: closure.insert(\"receipt-log:MALFORMED-N\", \"MALFORMED\") makes it visible in the receipt's own closure map. Accepted standing is correct: reasoned, disclosed, auditable exception, not an undisclosed defect." .

retrofit:EquivalenceMapNotLive a retrofit:SPOF ;
    rdfs:label "5 of 8 receipt equivalence classes still Unknown on ggen's own sync" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:SelfGenerationPath ;
    retrofit:evidence "Updated 2026-07-21 (self-retrofit Generation 2, PR #360): the `evidence` class is now live -- ggen-verify-pack's gates 010/020 were wired into ggen's own [validation].gates (previously only [ontology].imports admitted its facts, never routing through crate::pack::resolve() which evaluates gates), and proven causal both directions: a real clippy fix flipped a recorded ver:exitCode row from red to green and the live sync's refusal-citation count dropped accordingly; a real adversarial tamper of a currently-green fact flipped a row red, cited by name. source/config remain Divergent; compiled_binary/docs/tests/receipts/gates remain Unknown -- narrowing what's still open, not the whole original claim. ggen-verify-pack's own gates 030/040/050 (freshness/andon-regression/output-count-regression) remain unwired by design: this repo's own ggen.toml is the declarative-rules schema, which has no [law].reflexive, so those three gates could never fire here." .

retrofit:StandingCeilingHardcoded a retrofit:SPOF ;
    retrofit:evidenceUpdate2026_07_21 "Sharpened, still Blocking: NOT a literal hardcoded constant -- praxis_core::receipt_epoch::compute_ceiling genuinely computes `recoverable(prev).min(supported(components))` from real evidence each generation. The real defect: recoverable(prev)=prev is the identity function by explicit design ('nothing decays and nothing is inferred back up', receipt_epoch.rs:173-176), so once any generation's ceiling reads LegacyObserved (ranked below Yellow/Green in the lattice), the meet with any future supported() can never exceed it -- a genuine permanent one-way floor, confirmed live: current .ggen-v2/receipt.json's standing_ceiling is LegacyObserved with promotion_eligible:true (proving it went through the real computed path, not the separate legacy_bounded() sentinel constructor, which always forces promotion_eligible:false). The only escape hatch, ReceiptEpochV2Builder::with_explicit_ceiling, is called in exactly 2 places -- both inside crates/ggen-engine/tests/receipt_epoch_e2e.rs and praxis-core's own unit test -- crates/ggen-engine/src/sync.rs's real production builder chain (line 2453) never calls it. So ggen's own self-hosted receipts are structurally incapable of ever showing a ceiling above LegacyObserved in production, regardless of how much real evidence improves, until a deliberate promotion mechanism is designed and wired -- not a quick patch, a real architecture decision (what evidence justifies a one-time floor reset, who/what authorizes it, how it's receipted)." ;
    rdfs:label "standing_ceiling hardcoded to LegacyObserved" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:SelfGenerationPath ;
    retrofit:evidencePath ".ggen-v2/receipt.json" .

retrofit:AndonHardcodedGreen a retrofit:SPOF ;
    rdfs:label "andon field unconditionally hardcoded Green in write_receipt" ;
    retrofit:standing "Accepted" ;
    retrofit:affects retrofit:SelfGenerationPath, retrofit:ConstitutionPath ;
    retrofit:evidence "RESOLVED as-found 2026-07-20/21 retrofit item #2 verification pass: sync.rs's legacy `andon` field (now ~L2464-2476, `write_receipt`) is derived from `epoch.andon: AndonLevel` via `derive_andon`/`ComponentLevels` precedence (crates/praxis-core/src/receipt_epoch.rs), not a hardcoded literal -- the surrounding comment at sync.rs:2461-2463 documents this as the exact migration that removed the hardcoded-Green literal this SPOF names (landed in one of #322/#336/#346, predating this retrofit item's assignment). A Stage 2b (validate) gate/denial refusal returns `Err` via `?` before `write_receipt` is ever called (sync.rs:482-559), so a red gate cannot reach the receipt as a false Green either -- confirmed live: `.ggen-v2/receipt.json`'s `record.andon` and `record.v2.andon` both read \"Green\" after a real `ggen sync run` on an unmodified tree, and `cargo build -p ggen-cli-lib --bin ggen` is clean. This as-found fact supersedes the stale evidencePath (`sync.rs:1857`, which is now inside a different fn, `verify_check_axis`, not `write_receipt`); no source change was required for this item." .

retrofit:DualObligationCounters a retrofit:SPOF ;
    rdfs:label "Legacy obligation_count=4 vs v2 Tracked{required:9,discharged:5} disagree by design" ;
    retrofit:standing "Accepted" ;
    retrofit:affects retrofit:SelfGenerationPath ;
    retrofit:evidence "CONFIRMED via direct code read: the two counters are genuinely different mechanisms over different data, not a drifted duplicate of the same fact. Legacy record.obligation_count (crates/praxis-core/src/law.rs:320/414) = self.obligations.len(), a coarse count of the v1 LawObject's own Vec<Obligation>. v2's ObligationCount::Tracked{required,discharged} (crates/praxis-core/src/receipt_epoch.rs:420-435, compute_obligation_count) sums obligations_created/obligations_discharged across every itemized AdmissionItem -- a finer-grained, per-evidence-item accounting introduced with v2 that the legacy field was never redefined to match. Accepted standing is correct: they will keep disagreeing by construction (different layers, different granularity), and that's disclosed, not hidden." .

retrofit:SabotageFixtureCoverageGap a retrofit:SPOF ;
    rdfs:label "12 sabotage fixtures across 3 packs have no referencing test" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:SelfGenerationPath ;
    retrofit:evidence "dogfood-lifecycle-pack x8, ma-case-study-pack x1, self-monitoring-pack x3; literal-basename grep, disclosed as unverified upper bound" .

retrofit:NoBranchProtection a retrofit:SPOF ;
    rdfs:label "main branch has no protection rule" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:PullRequestPath, retrofit:ReleasePath ;
    retrofit:evidence "gh api repos/seanchatmangpt/ggen/branches/main/protection -> HTTP 404 Branch not protected" .

retrofit:SingleAdminCollaborator a retrofit:SPOF ;
    rdfs:label "Exactly one repo collaborator, admin=true, no CODEOWNERS" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:PullRequestPath, retrofit:ReleasePath, retrofit:FleetManagementPath ;
    retrofit:evidence "gh api repos/seanchatmangpt/ggen/collaborators -> [seanchatmangpt admin=true]; find . -iname CODEOWNERS -> empty" .

retrofit:HooksMainOnlyNoOp a retrofit:SPOF ;
    rdfs:label "pre-commit/pre-push hooks are main-only, silent no-op on every feature branch" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:PullRequestPath ;
    retrofit:evidencePath "scripts/hooks/pre-commit.sh" .

retrofit:ReleaseGateBrokenForWeeks a retrofit:SPOF ;
    rdfs:label "One release.yml gate reported broken for weeks" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:ReleasePath ;
    retrofit:evidence "As-found per task brief; exact commit range/gate not independently re-derived this pass (Unknown)" .

retrofit:BrokenJustSyncRecipes a retrofit:SPOF ;
    rdfs:label "just sync / just sync-dry recipes -- RESOLVED, original flags no longer exist" ;
    retrofit:standing "Accepted" ;
    retrofit:affects retrofit:ReleasePath, retrofit:GenerationPath ;
    retrofit:evidence "RESOLVED, independently re-verified 2026-07-21: justfile's sync/sync-dry recipes (lines 414-419) already invoke `{{GGEN}} sync run` / `{{GGEN}} sync run --dry-run` -- not the `--audit`/`--dry_run true` flags this SPOF's original evidence cited, which no longer appear anywhere in the recipe. Confirmed live: `just sync-dry` runs, hits zero flag-parsing errors, and fails only on the separate, already-tracked O-3/O-7 evidence-gate refusal (FM-LAW-018, byte-identity still red) -- a genuinely different, already-known condition, not this SPOF's original claim. CLAUDE.md's own prose still describes the old broken flags as current, which is now stale generated-doc content (a minor, separate doc-drift item, not re-opening this SPOF)." .

retrofit:PartialPublishRollbackUnknown a retrofit:SPOF ;
    rdfs:label "Partial-publish detection/rollback across 5 release targets not checked" ;
    retrofit:standing "Unknown" ;
    retrofit:affects retrofit:ReleasePath ;
    retrofit:evidence "publish-registry.yml, publish-candidate.yml, homebrew-release.yml, release-debian.yml, docker-build-push.yml — independent workflows, no cross-check found" .

retrofit:ConstitutionDescriptiveMirrorOnly a retrofit:SPOF ;
    rdfs:label "ccn:Law facts have zero effect on live admission/receipt decisions" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:ConstitutionPath ;
    retrofit:evidence "praxis-core::law::DefaultLaw::admit and ggen-engine::sync::write_receipt independent of ggen-constitution-pack; PUBLICATION_JUDGMENT.md condition 12 PARTIAL" .

retrofit:LawXIIFalseCitation a retrofit:SPOF ;
    rdfs:label "Law XII engine-independence citation -- RESOLVED, corrected not fabricated" ;
    retrofit:standing "Accepted" ;
    retrofit:affects retrofit:ConstitutionPath ;
    retrofit:evidence "RESOLVED 2026-07-21: crates/ggen-engine/tests/reasoner_independence_e2e.rs is a REAL file (both_engines_sync_a_gated_pack_to_identical_outputs, violating_fixture_is_refused_under_both_engines -- both run and PASS 2026-07-21) proving exactly the cited property. The prior 'zero matches' finding searched for a literal function name equal to the file name; the file/module itself was never missing. .specify/memory/constitution.md's citation and packs/ggen-constitution-pack/ontology.ttl's LawXII ccn:note both corrected to name the real file and its two actual function names precisely." .

retrofit:UnmechanizedLawsDisclosed a retrofit:SPOF ;
    rdfs:label "9 laws (not 3) explicitly mechanized=false, every one with a named gap" ;
    retrofit:standing "Accepted" ;
    retrofit:affects retrofit:ConstitutionPath ;
    retrofit:evidence "CORRECTED count via direct read, packs/ggen-constitution-pack/ontology.ttl: 9 of 14 laws are mechanized=false (I, V, VI, VII, VIII, IX, XI, XIII, XIV), not the 3 (VII, XI, XIV) this SPOF's label originally named -- an undercount, not an overcount. Verified EVERY SINGLE mechanized=false law carries an explicit ccn:note disclosing exactly what's missing (e.g. Law I: no dedicated cycle-rejection test found; Law XI: sync.rs:1857 hardcodes andon=Green, named as an ACTIVE DIVERGENCE pending the v2 epoch migration; Law XIV: no fixed-point-closure test exists yet) -- zero silent gaps among the 9. Accepted standing is correct and, if anything, more strongly earned than the original label suggested: this is unusually thorough self-disclosure, not corner-cutting." .

retrofit:FleetCensusObservationOnly a retrofit:SPOF ;
    rdfs:label "Fleet census has no confirmed reconciliation loop against live fleet state" ;
    retrofit:standing "Accepted" ;
    retrofit:affects retrofit:FleetManagementPath ;
    retrofit:evidence "BOUNDED ACCEPTED RISK, evidence-based, 2026-07-21: confirmed docs/gh-terraform/FLEET-CENSUS.md (408 lines, ~359 external repos across chatmangpt-org/EpicGames/etc.) is honestly self-labeled 'OBSERVATION, NOT DESIRED STATE' with a real generation timestamp -- it makes no currency claim a reader could be misled by, which is the actual false-standing risk this class of SPOF exists to catch, and that risk does not exist here. A real re-run-and-diff reconciliation loop against live fleet state is a substantial, distinctly-scoped engineering effort (359 external repos, none of them ggen itself) genuinely orthogonal to ggen's own self-retrofit correctness (FleetManagementPath does not intersect SelfGenerationPath/ConstitutionPath/ReleasePath, the paths this session's generations have been closing). Accepting as bounded risk rather than building it now: scope=documented staleness of a labeled snapshot only, no false-currency claim possible, failure consequence=a stale snapshot informing a future fleet decision (mitigated by the explicit label), owner=a future, separately-scoped fleet-reconciliation generation, review trigger=before any fleet-wide tier assignment or batch actuation is proposed from this data." .

retrofit:FleetCloudIdentityUnverified a retrofit:SPOF ;
    rdfs:label "Sole cloud-actuation identity for fleet-management not verified" ;
    retrofit:standing "Unknown" ;
    retrofit:affects retrofit:FleetManagementPath ;
    retrofit:evidence "No cloud IAM access in this survey; repo-only evidence" .

retrofit:CrossCuttingSingleAdmin a retrofit:SPOF ;
    rdfs:label "seanchatmangpt is a SPOF across PR, release, and fleet-management paths simultaneously" ;
    retrofit:standing "Blocking" ;
    retrofit:affects retrofit:PullRequestPath, retrofit:ReleasePath, retrofit:FleetManagementPath ;
    retrofit:evidence "Root cause referenced by retrofit:SingleAdminCollaborator; single fact underlying 3 of 6 load paths' SPOFs" .
