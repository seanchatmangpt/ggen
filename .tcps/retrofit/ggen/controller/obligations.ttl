@prefix retrofit: <https://ggen.dev/ontology/retrofit#> .
@prefix ctl:      <https://ggen.dev/ontology/retrofit-controller#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .

# Controller obligation DAG for the ggen self-retrofit, seeded 2026-07-21 from
# real observed state (PR #359/#360, the Generation-3 BUG-004 workflow's
# independently-verified fix + reconcile, the 21-SPOF ledger in
# ../load-path.ttl, and AP-001 in ../../../../docs/retrofit/ggen/authorization-packets.md).
# ctl:state values: READY | ACTIVE | VERIFYING | WAITING_FOR_CI |
#   DEPENDENCY_BLOCKED | EXTERNALLY_GATED | CLOSED | REFUSED | REPLACEMENT_REQUIRED

ctl:Obligation a rdfs:Class .

ctl:state a rdf:Property ; rdfs:comment "One of the 9 controller states -- never a generic BLOCKED." .
ctl:priority a rdf:Property ; rdfs:comment "Integer, 1 = highest, per the mandate's 15-tier ordering." .
ctl:nextAction a rdf:Property .
ctl:verificationRequirement a rdf:Property .
ctl:sabotageRequirement a rdf:Property .
ctl:receiptRef a rdf:Property .

ctl:O-1 a ctl:Obligation ;
    rdfs:label "Wire ggen-verify-pack evidence into ggen's own live sync/gates" ;
    ctl:priority 3 ;
    ctl:state ctl:CLOSED ;
    ctl:receiptRef "PR #360 commit 7b07e8670" ;
    rdfs:comment "Proven causal both directions: real clippy fix flipped a row green (3->2 refusal citations); adversarial tamper of a real fact flipped a row red, citing exactly the injected fact." .

ctl:O-2 a ctl:Obligation ;
    rdfs:label "Fix 3 real pre-existing clippy::correctness/perf violations surfaced by O-1" ;
    ctl:priority 8 ;
    ctl:state ctl:CLOSED ;
    ctl:receiptRef "PR #360 commit 7b07e8670" .

ctl:O-3 a ctl:Obligation ;
    rdfs:label "BUG-004: ggen agent install reads global path instead of project-local lockfile" ;
    ctl:priority 4 ;
    ctl:state ctl:CLOSED ;
    ctl:receiptRef "commit 15c1a55a3, retrofit/ggen-self-g2" ;
    ctl:verificationRequirement "cargo test -p ggen-cli-lib --test agent_lifecycle_test; cargo test -p ggen-marketplace; cargo clippy -p ggen-marketplace -p ggen-cli-lib -D correctness -D suspicious -D perf -- all passed" ;
    ctl:sabotageRequirement "Global-decoy-vs-project-local discrimination -- executed 2026-07-21, both scenarios passed with real filesystem evidence." .

ctl:O-7b a ctl:Obligation ;
    rdfs:label "ontology_union_and_declaration_order_are_canonical assertion scope" ;
    ctl:priority 9 ;
    ctl:state ctl:CLOSED ;
    ctl:receiptRef "commit 6d3b28e64, retrofit/ggen-self-g2" ;
    ctl:nextAction "Fixed the test's assertion scope (exclude the legitimately order-sensitive closure.ggen.toml raw-byte hash), not engine behavior -- canonicalizing that one closure entry would have been an inconsistent special-case against every other raw-byte-hashed closure entry. Added a dedicated sabotage test proving the exclusion doesn't mask a genuine pack-set difference. 7/7 cross_pack_matrix tests pass." .

ctl:O-Promotion a ctl:Obligation ;
    rdfs:label "Standing-promotion protocol for the permanent LegacyObserved ceiling floor" ;
    ctl:priority 3 ;
    ctl:state ctl:CLOSED ;
    ctl:receiptRef "commit 3f080f7fa, retrofit/ggen-self-g2" ;
    ctl:nextAction "Implemented PromotionWitness{from_ceiling,to_ceiling,evidence_receipts,closed_obligations,verifier_identity,authorization_basis} + validate_promotion() + ReceiptEpochV2Builder::with_verified_promotion() in praxis-core. 8 tests: valid promotion raises the ceiling, self-authored refused, stale from_ceiling refused, non-raising refused, each required-nonempty field independently refused, normal generation still cannot raise it (no regression), witnessed-value-wins sabotage. Deliberately NOT wired into ggen-engine's production sync.rs loop -- who holds verifier_identity trust in ggen's own autonomous context is genuine external business intent (who is authorized to vouch for ggen's own promotion), the narrow case the design-uncertainty law's escalation exception covers. The mechanism itself is real, tested, and callable once that trust decision is made." .

ctl:O-5-restand-FreezeAlwaysNoDriftDetection a ctl:Obligation ;
    rdfs:label "FreezePolicy::Always silent drift" ;
    ctl:priority 1 ;
    ctl:state ctl:CLOSED ;
    ctl:receiptRef "commits c0cddb253 + 69729d219, retrofit/ggen-self-g2" ;
    ctl:nextAction "Full repair, both halves: write.rs's check_freeze now compares candidate content against on-disk content for Always and returns a DRIFT-marked skip reason without changing mutation behavior (7 tests); sync.rs's admission-item construction detects the DRIFT marker and produces Fail+Quarantined with obligations_created:[FROZEN-DRIFT:<path>], pulling derived Andon off Green (2 real e2e tests against an actual parsed receipt.json, including a no-drift control/sabotage proving the detection discriminates rather than always-flagging)." .

