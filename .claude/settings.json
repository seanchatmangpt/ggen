{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "RUST_BACKTRACE": "1",
    "CARGO_TERM_COLOR": "always"
  },
  "permissions": {
    "mode": "acceptEdits"
  },
  "model": "claude-sonnet-5",
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "ggen": {
      "source": {
        "source": "directory",
        "path": "plugins"
      }
    }
  },
  "extendedThinking": true,
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "ggen-lsp@ggen": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 15,
            "statusMessage": "Loading ggen session context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/user-prompt.sh",
            "timeout": 5,
            "statusMessage": "Injecting doctrine..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre_tool_use_guard.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
