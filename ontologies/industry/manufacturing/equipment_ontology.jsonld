    {
      "@id": "schema:height",
      "@type": "rdf:Property",
      "rdfs:comment": "The height of the item.",
      "rdfs:label": "height",
      "schema:domainIncludes": [
        {
          "@id": "schema:MediaObject"
        },
        {
          "@id": "schema:OfferShippingDetails"
        },
