                &#34;@type&#34;: &#34;Offer&#34;,
                &#34;priceCurrency&#34;: &#34;RUB&#34;,
                &#34;price&#34;: &#34;4399.00&#34;
            }
        },
        {
            &#34;@type&#34;: &#34;Product&#34;,
            &#34;name&#34;: &#34;...&#34;
        }
    ]
}
&lt;/script&gt;
</pre>
