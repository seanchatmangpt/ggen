        }
      ],
      "schema:domainIncludes": [
        {
          "@id": "schema:Organization"
        },
        {
          "@id": "schema:Person"
        },
        {
          "@id": "schema:Place"
        },
        {
          "@id": "schema:Product"
        },
        {
          "@id": "schema:Service"
        }
      ],
