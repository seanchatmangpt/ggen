    <div class="bg-white px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
      <dt class="text-sm font-medium text-gray-900">URI</dt>
      <dd class="mt-1 text-sm text-gray-700 sm:col-span-2 sm:mt-0 flex items-center gap-2">
        <code class="font-mono text-xs break-all bg-gray-100 px-1.5 py-0.5 rounded">http://purl.org/dc/elements/1.1/contributor</code>
        <button type="button"
                onclick="navigator.clipboard.writeText('http:\/\/purl.org\/dc\/elements\/1.1\/contributor').then(() => { const el = this.querySelector('.copy-icon'); const check = this.querySelector('.check-icon'); el.classList.add('hidden'); check.classList.remove('hidden'); setTimeout(() => { el.classList.remove('hidden'); check.classList.add('hidden'); }, 1500); })"
