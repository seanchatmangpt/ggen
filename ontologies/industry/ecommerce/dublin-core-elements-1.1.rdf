          <li class="text-gray-600">http://purl.org/dc/terms/Period</li>
          
          <li class="text-gray-600">http://purl.org/dc/terms/Jurisdiction</li>
          
        </ul>
      </dd>
    </div>
    
    

    
    

    
    

    
    

    
    
    <div class="bg-gray-50 px-4 py-4 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
