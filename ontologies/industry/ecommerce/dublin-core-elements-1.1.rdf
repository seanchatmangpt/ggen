        <code class="font-mono text-xs break-all bg-gray-100 px-1.5 py-0.5 rounded">http://purl.org/dc/terms/coverage</code>
        <button type="button"
                onclick="navigator.clipboard.writeText('http:\/\/purl.org\/dc\/terms\/coverage').then(() => { const el = this.querySelector('.copy-icon'); const check = this.querySelector('.check-icon'); el.classList.add('hidden'); check.classList.remove('hidden'); setTimeout(() => { el.classList.remove('hidden'); check.classList.add('hidden'); }, 1500); })"
