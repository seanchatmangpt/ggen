<article id="abstract" class="mt-6 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm scroll-mt-20">
  
  <div class="flex flex-col gap-2 bg-gray-50 px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-6">
    <div class="flex flex-wrap items-center gap-2 sm:gap-3">
      <h3 class="text-base font-semibold text-gray-900">
        abstract
      </h3>
      
      <a href="#index-properties-terms" class="inline-flex items-center rounded-full px-2 py-1 text-xs font-medium ring-1 ring-inset transition-colors bg-blue-50 text-blue-700 ring-blue-600/20 hover:bg-blue-100">
        Property
