@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix gcat: <https://ggen.io/ontology/catalog/v1#> .

# ═══════════════════════════════════════════════════════════════
# ggen Vision 2030 Ontology Catalog
# DCAT 2 — W3C Data Catalog Vocabulary
#
# Three tiers:
#   gcat:Core       — Embedded in binary (include_str!), always available offline
#   gcat:Cached     — Downloaded to XDG cache on first use, verified by BLAKE3
#   gcat:Referenced — URL reference only, fetched on demand
# ═══════════════════════════════════════════════════════════════

<https://ggen.io/ontology/catalog>
    a dcat:Catalog ;
    dcterms:title "ggen Vision 2030 Ontology Catalog" ;
    dcterms:description "Complete catalog of ontologies referenced by the ggen code generation system, from W3C foundations to domain-specific vocabularies." ;
    dcterms:version "1.0.0" ;
    dcterms:creator <https://github.com/seanchatmangpt> ;
    dcterms:license <https://spdx.org/licenses/MIT> ;
    dcterms:modified "2026-06-20"^^xsd:date .

# ─── Tier vocabulary ────────────────────────────────────────────

gcat:Tier a owl:Class ; rdfs:label "OntologyTier" .
gcat:Core a gcat:Tier ; rdfs:label "Core" ;
    rdfs:comment "Tier 0: embedded in the cpmp binary via include_str! — always available offline." .
gcat:Cached a gcat:Tier ; rdfs:label "Cached" ;
    rdfs:comment "Tier 1: downloaded to XDG cache directory on first use; integrity verified by BLAKE3." .
gcat:Referenced a gcat:Tier ; rdfs:label "Referenced" ;
    rdfs:comment "Tier 2: URL reference only; fetched on demand when SPARQL reasoning requires it." .

gcat:tier a rdf:Property ; rdfs:label "tier" ; rdfs:domain dcat:Dataset ; rdfs:range gcat:Tier .
gcat:prefix a rdf:Property ; rdfs:label "prefix" ; rdfs:domain dcat:Dataset ; rdfs:range xsd:string .
gcat:embeddedPath a rdf:Property ; rdfs:label "embeddedPath" ; rdfs:range xsd:string .
gcat:authority a rdf:Property ; rdfs:label "authority" ; rdfs:range xsd:string .
gcat:capability a rdf:Property ; rdfs:label "capability" ; rdfs:range xsd:string .

# ══════════════════════════════════════════════════════════════════════
# TIER 0: CORE — embedded in binary (7 entries)
# ══════════════════════════════════════════════════════════════════════

<http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    a dcat:Dataset ;
    dcterms:title "RDF 1.1 Vocabulary" ;
    dcterms:description "The Resource Description Framework syntax namespace — foundation of all RDF data models." ;
    gcat:tier gcat:Core ;
    gcat:prefix "rdf" ;
    gcat:embeddedPath "ontologies/core/rdf-syntax-ns.ttl" ;
    gcat:authority "W3C" ;
    gcat:capability "rdf-foundation" .

<http://www.w3.org/2000/01/rdf-schema#>
    a dcat:Dataset ;
    dcterms:title "RDF Schema 1.1" ;
    dcterms:description "RDF Vocabulary Description Language (RDFS) — classes, properties, domains, ranges." ;
    gcat:tier gcat:Core ;
    gcat:prefix "rdfs" ;
    gcat:embeddedPath "ontologies/core/rdf-schema.ttl" ;
    gcat:authority "W3C" ;
    gcat:capability "rdf-foundation" .

<http://www.w3.org/2002/07/owl#>
    a dcat:Dataset ;
    dcterms:title "OWL 2 Vocabulary" ;
    dcterms:description "Web Ontology Language 2 — full class axioms, property restrictions, reasoning support." ;
    gcat:tier gcat:Core ;
    gcat:prefix "owl" ;
    gcat:embeddedPath "ontologies/core/owl2.ttl" ;
    gcat:authority "W3C" ;
    gcat:capability "owl-reasoning" .

<http://www.w3.org/2001/XMLSchema#>
    a dcat:Dataset ;
    dcterms:title "XML Schema 1.1 Datatypes" ;
    dcterms:description "XSD built-in primitive and derived datatypes used in RDF/OWL literals." ;
    gcat:tier gcat:Core ;
    gcat:prefix "xsd" ;
    gcat:embeddedPath "ontologies/core/xmlschema-datatypes.ttl" ;
    gcat:authority "W3C" ;
    gcat:capability "datatype-validation" .

<http://www.w3.org/ns/shacl#>
    a dcat:Dataset ;
    dcterms:title "Shapes Constraint Language (SHACL)" ;
    dcterms:description "W3C SHACL — defines node and property shapes for RDF graph validation." ;
    gcat:tier gcat:Core ;
    gcat:prefix "sh" ;
    gcat:embeddedPath "ontologies/core/shacl.ttl" ;
    gcat:authority "W3C" ;
    gcat:capability "shacl-validation" .

<http://www.w3.org/ns/prov#>
    a dcat:Dataset ;
    dcterms:title "PROV-O: The PROV Ontology" ;
    dcterms:description "W3C provenance ontology — entity, activity, agent, derivation, attribution, generation." ;
    gcat:tier gcat:Core ;
    gcat:prefix "prov" ;
    gcat:embeddedPath "ontologies/core/prov-o.ttl" ;
    gcat:authority "W3C" ;
    gcat:capability "provenance-chain" .

<http://purl.org/dc/terms/>
    a dcat:Dataset ;
    dcterms:title "Dublin Core Metadata Terms" ;
    dcterms:description "DCMI Metadata Terms — the complete set of descriptive metadata properties." ;
    gcat:tier gcat:Core ;
    gcat:prefix "dcterms" ;
    gcat:embeddedPath "ontologies/core/dcterms.ttl" ;
    gcat:authority "DCMI" ;
    gcat:capability "metadata" .

# ══════════════════════════════════════════════════════════════════════
# TIER 1: CACHED — downloaded on first use (12 entries)
# ══════════════════════════════════════════════════════════════════════

